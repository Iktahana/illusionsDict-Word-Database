[
  {
    "uuid": "91127167-bfb4-5992-aca9-8a7e267eabb4",
    "entry": "再転",
    "reading": {
      "primary": "さいてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "changing directions",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すなわち一転すれば冒険心となり、再転すれば山気となるのである。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "再転し三転しては甲の事を仕ながら乙・丙の事を思い丁の事に当たりながら戊・己・庚・辛・壬・癸の事を思うようになり、終には全く散る気の習癖が付くようになるのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、人の心身に係わる或る意味を表わすことに於いて、漢字の気の字も、邦語の「いき」という語も、気息の義から一転再転三転して、甚だ含蓄の多い字となり語となっている。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃一と度は政治家たらんと欲し、転じて建築に志ざし、再転して今度は実業界に入ろうとした一青年たる自分が文学に興味を持つようになったのもまた、直接には龍渓鉄腸らの小説、間接にはこれらの新傾向を胚胎した英国の政治家的文人の典型であった。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "美人と童子　一朝にして王侯の生活、再転して乞食の境遇。",
              "citation": {
                "source": "高島異誌",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "泡鳴初め浪漫主義を信じ、転じて表象主義に入り、再転して霊肉｜合致より本能の重大を力説して刹那主義なる新語を鋳造せり。",
              "citation": {
                "source": "遠藤（岩野）清子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "転封して来たものは再転封されてこの土地を去ったというのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "米連対欧弗の戦争｜勃発が伝えられ、それが再転して、両国の握手となり、極東に対して共同作戦をとると見えたが、今また三転して、再び米連と欧弗とは、険悪なる関係に投げこまれ、すでに両軍の間には、激戦が展開されているようであった。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "室町時代の小説類に多い「さんげ物」は勿論だが、江戸の謡ひ物の祭文は「山伏し祭文」から出て、ある人の罪業告白の自叙伝式の物になり、再転して「色さんげ」から、故人の恋愛生活などを言ひ立てることになつた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに手長・足長は、先住穴居民が一旦土蜘蛛の名によって、手足の長い人と信ぜられ、再転して巨人伝説中に収容せられ、或いは遠方の貝を採ったという話などから、手の長い事を主として手長と云い、或いは高い山に昇降したという話などから、足の長い事を主として八握脛などと呼んだものではなかろうか。",
              "citation": {
                "source": "手長と足長",
                "author": "土蜘蛛研究",
                "note": "青空文庫"
              }
            },
            {
              "text": "子を捨る親、養父を殺す子、君を殺す家来、家来を計る君、昨日の味方は今日の敵、悲風惨憺たる戦国時代では、なまじ出家などするよりも賊になった方が気が利いていると、更に心機を再転させ、その手始めに恋する女を浮田の奥殿から奪ったのである。",
              "citation": {
                "source": "郷介法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルサス説は再転してその第三期に入る。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "願わくは父なる神よ、我に汝の知恵と力とを賜いて、汝の道を歩ましめ給え――　青草の丘にひろげられた神の国の予表は一瞬に幻と消えて、たちまちサタンとの戦場となり、再転して父なる神への祈りの場所となりました。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってヤトもまたヤツからの再転訛か、または「ヤの処」の義ではあろうが、これをある部落の地名とする場合には当字の誤りと見ねばならぬ。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会層というものは他方社会身分という意味を持つようになり、再転して社会に於ける職業的定位をも意味するようになるものだが、之は云うまでもなく、社会階級そのものではない。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "受付から一転して平社員に、再転して課長心得に、五年目にはもう、笠森仙太郎と並んで、若手社員の双璧と云われるようになっていたのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "運命の釦",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にそれが再転すれば君主専制となるに過ぎぬ。",
              "citation": {
                "source": "日支親善策如何",
                "author": "――我輩の日支親善論",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗鑑、守武、貞徳、宗因等の人々は、優にやさしい和歌、連歌から別に一派の俳諧を分岐せしめるためには俗語を使用し、俗情を直叙して洒落滑稽を主としなければならなかったのでありますが、芭蕉はさらにそれを再転して、その滑稽、俳諧の奥に潜んでいる人生の寂し味に手をつけたのであります。",
              "citation": {
                "source": "俳句とはどんなものか",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻布の家で無事だということを知ってからも、ここへこぎつけるまでの再転三転は、物に動じない彼にとってさえかなりな心の負担であった。",
              "citation": {
                "source": "花咲かぬリラ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが再転向もまたあり得るというのがなんとも興味深い点である。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "内海を渡って四国に入れば、「たを」とは言わずに「とう」と呼ぶけれども、「とう」はまた「たを」の再転に相違ない。",
              "citation": {
                "source": "峠に関する二、三の考察",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "東日本の方には、この場合の儀式のみはなお残って、名称はハバキヌギもしくはスナバタキなどとなっているが、脛巾脱ぎは恐らく砂払いからの再転で、人が神事から人事に移って行く際にも、何かその境目をはっきりとさせる必要があることを意味したものらしい。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
