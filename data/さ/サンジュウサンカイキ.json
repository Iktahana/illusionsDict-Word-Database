        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "後家は五人扶持をもらい、新たに家屋敷をもらって、忠利の三十三回忌のときまで存命していた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月二十八日に、蘭軒の父にして榛軒の祖父なる信階の三十三回忌が営まれたらしい。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "示幻童女三十三回忌。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "月々の持斎には経を上げ膳を出す習慣であるが、殊に其日は三十三回忌とやらで、好物の栗飯を炊いて、仏にも供へ、下宿人にも振舞ひたいと言ふ。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "はつの母親が没して三十三回忌の日、還ってきて家の前に立っていた。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
