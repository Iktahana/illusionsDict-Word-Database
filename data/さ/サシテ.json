[
  {
    "uuid": "70332ced-3e4f-5d93-8213-c01162519ef6",
    "entry": "指し手",
    "reading": {
      "primary": "さして",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "move",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "加藤八投の解説によると、六八桂、今までにある手、当然の指し手で、三十八手負けの塚田八段の指し手がひどすぎたのださうだ。",
              "citation": {
                "source": "散る日本",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの賢夫人ほどの将棋差しが、家の変りかたを見たぐらいで、かんたんに指し手を変えるとは考えられない。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四十六章　二局の指し手　マクスグラジャ大将が一瞬返答に詰まった。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か、僕に、食べさして下さい。",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "きんとんでもよい、何でもよい、　　何か、僕に食べさして下さい！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さして何もしなかつた人といふのは、なまなか人の袖と自分の袖を比べてみるやうなことばかりに心を用ゐたのかもしれない。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間は落付かないし、出掛けてもさして面白くないので、私には朝早く起きることは大変時間の損失なのだ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はすつかり嫌気がさして、今貰つて来た景品の包装を破いてみた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場の蒼黒い顔には弱い西日がぽっと明るくさしていて、夕靄がもやもや烟ってふたりのからだのまわりを包み、なんだかおかしな、狐狸のにおいのする風景であった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして相談に水をさしてやろうじゃありませんか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パラソルをさして歩くと、少したすかるかも知れませんが、男がパラソルをさして歩いている姿は、あまり見かけませんね。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒菊や日の照る村の片ほとり　冬の薄ら日のさしてる村の片ほとり、土塀などのある道端に、侘しい寒菊が咲いてるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家苞に參らせん、と思ふほどに、はや出でさせ給ひにければ、と云ひさして、根もとをこなたに向けて、三把ばかり出だしけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の中でつくつくほうしがゆるやかに鳴いて、日陰だから人が蝙蝠傘を阿弥陀にさしてゆる／＼あるく。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すじ向いに座を構えたまうを帽の庇よりうかゞい奉れば、花の御かんばせすこし痩せたまいて時々小声に何をか物語りたまう双頬に薄紅さして面はゆげなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘定をすませ丸く肥え太りたる脊低き女に革鞄｜提げさして停車場へ行く様、痩馬と牝豚の道行とも見るべしと可笑し。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はまだ一度も行った事がないが病後の事であるからと思うて座敷で書見をしている父上に行ってもよう御座いましょかと聞くと行くはよいが傘をさして行けとの事であったから、帽をかぶってわるい方の蝙蝠傘を持って裏門へまで行くと、要太郎はもう網をこしらえて待っていた。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側へ日が強くさして何だか逆上する。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝馬に乗って櫂を動かしている女の腕に西日がさして白く見える。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "怖ろしい夢は破れて平和な静かな冬の日影は斜に障子にさしている。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源はやがて蘭人が指さして呉れる大きな国を想像して居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前面には阜のような山が二つ、小隆起をしている、赤沢岳頂上の三角点も、大空を指さしている、谷は次第に高くなる、高くなると共に蹙まって来て、雪の蜿ねり方も、波のように烈しいが、嘉門次の語るところに依ると、雪の下は大小の石塊ばかりで、雪解けがしたら、却って歩きづらくて堪まらないということだ。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸の如くに降りしきる雨の中にたたずんで、モミや落葉松の美しい木立に見とれる、この辺から、裾野式の高原を展開して、桔梗がさき、萩がさき、女郎花がひょろひょろと露けく、キスゲが洞燈のような、明かる味をさしている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩煎餅屋の取散らされた店先に烈日の光がさしていたのが心を引いた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冥通の力によって山に土民たちの望むことを聴き容れさしてやった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで親孝行をさして頂けますわ」　家の中のいちばんよい部屋を翁のために設けて呉れた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水無瀬は何となく生きて行くことにくさくさして来た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、手頃に傷けてまだ息を残さしてある雄鹿を小脇に抱えていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さみだれが煙るように降る夕方、老妓は傘をさして、玄関横の柴折戸から庭へ入って来た。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことを生業として宿々に知り合いが出来るとなおこの街道から脱けられなくなり、家を離散さしてから二十年近くも東海道を住家として上り下りしていると語った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
