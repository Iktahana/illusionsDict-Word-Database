  {
    "uuid": "d6f7b19b-7c4d-57df-9fbe-6c0f72dc6c8e",
    "entry": "差し手",
    "reading": {
      "primary": "さして",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
