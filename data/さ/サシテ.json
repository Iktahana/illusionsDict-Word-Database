    "definitions": [
      {
        "index": 1,
        "gloss": "slipping one's hand beneath the opponent's arm and latching on to the underside of his belt",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは刀が悪いのではなく、差し手が悪いのだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "差し手はいかに離れていようとも、刀と刀が求め合って、早晩一つにならずにはおかねえというのだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "読みの深い将棋指しのようなもので、いまおろす差し手は、三年も前に見透してしまった手だと思って差し支えない。",
              "citation": {
                "source": "我が家の楽園",
