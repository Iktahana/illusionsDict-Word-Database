    "definitions": [
      {
        "index": 1,
        "gloss": "relatively quickly (esp. actions)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ジョバンニはなぜかさあっと胸が冷たくなったやうに思ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんた、何でもあたしの方から仕向けなければ……狡いのか、意気地なしなのか、どっちなのよ」　小初の言葉のしんにはきりきり真面目さが透っていながら手つきはいくらかふざけたように、薫の背筋の溝に砂をさあっと入れる。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはなぜかさあっと胸が冷たくなったように思いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時風がざあっと吹いて来て土手の草はざわざわ波になり、運動場のまん中でさあっと塵があがり、それが玄関の前まで行くと、きりきりとまわって小さなつむじ風になって、黄いろな塵は瓶をさかさまにしたような形になって屋根より高くのぼりました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻の、あの雨の音、さあっと他愛なく軒へかかって通りましたのが、丁ど彼処あたりから降り出して来たように、寝ていて思われたのでございます。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはさあっと血が頭にのぼるのを感じました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔からさあっと血がひいていくのを感じた。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "教室では、案のじょう、みんながさあっとふりむいて久助君の方を見たので、久助君はあがってしまって、先生のところへ欠席届を出し、じぶんの席へ帰るまでに、つくえのわきにかけてある友だちのぼうしを、三つばかりはらい落としてしまった。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さあっと驟雨が走って来た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧がさあっとかかって来た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　やがて、両びらきのとびらがさあっとあいて、こどもたちが、まるで、クリスマスの木ごとたたきおとしそうないきおいで、とびこんできました。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "風が吹くと雨の音がさあっと乱れる。",
              "citation": {
                "source": "焔",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは十二時過ると扉もおとなしく片開きにしてある入口が、今夜はさあっと開いたままで、煌々と燈火のついた広間に人影もない。",
              "citation": {
                "source": "十四日祭の夜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう決心して、気味わるがる彼女を引っぱって突入しようとすると、眼のまえの群集がさあっと逃げて、そこへ、最初の若い巨人と、もうひとり中年の男とがひどく英雄的態度で立ちはだかった。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあっと電灯の滑って光る部分が俄かに広くなった。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは本当に心の窓という風で、私はそこから偶然自分に向って注がれる視線にあうと、さあっと暖い血汐が体の中を流れるように感じた。",
              "citation": {
                "source": "時代と人々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "転げつ、倒れつ、悶々のたうち返る美人の肉塊の織り作す美、それは白いタイルにさあっと拡がってゆく血潮の色を添えて充分カメラに吸収された。",
              "citation": {
                "source": "電気風呂の怪死事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "風につれて、さあっ、さあっと山から山へ立ちこめる霧雨が降って来た。",
              "citation": {
                "source": "小村淡彩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあっ、さあっと水の音か、樹上を渡る風の音か、ちょっと判断のつかない響がして、鳥の声が妙に澄んで来る、道を行く者も自ずと黙ってしまう。",
              "citation": {
                "source": "木曾御嶽の両面",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓地の樹木もその度にさあっと葉の落ちた梢を鳴らした。",
              "citation": {
                "source": "年末の一日",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあっと民衆は息を吹きかえして歩きはじめる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うだけの一瞬がさあっと何処かへ逃げてゆく。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ひらめの学校の生徒は、さあっと二列に並びました。",
              "citation": {
                "source": "ひらめの学校",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その雨もやがてまた谷間の底の方へさアーと音をたてて逃げて行ったと思うと、はるかな向こうの方に、さあっと陽が登りはじめ、海のような光がとんび岩のからだの下に見えました。",
              "citation": {
                "source": "ふしぎな岩",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、これをきいた峯子の顔がさあっと上気した。",
              "citation": {
                "source": "杉垣",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚開ける度にさあっと流れ入る太陽の光を浴びる壮快さ。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "風がさあっと西から吹いて来る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたん、さあっと音がして、雨が降出した。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "が夕方近くなって、もうあの子も帰ってくるだろうと思っていた時分、俄かに空が暗くなり、つめたい風が吹きはじめたかと思うと、あたりの木々の葉がさあっと無気味にざわめき出した。",
              "citation": {
                "source": "かげろうの日記",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
