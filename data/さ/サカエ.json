[
  {
    "uuid": "dac3ea97-f734-5f5b-a0c5-da4e459e304b",
    "entry": "栄え",
    "reading": {
      "primary": "さかえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
