          "standard": [
            {
              "text": "軟骨は、豊富な細胞間物質によって柔軟性と弾力性を保っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "細胞間物質の異常は、様々な病気の原因となることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この顕微鏡写真、細胞と細胞の間にあるのが細胞間物質だね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この組織の細胞間物質は液体ではあった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "細胞間物質の生命は細胞の生命とあるていど違うが両者は同じように生きていると我々はみなすようになっている。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
