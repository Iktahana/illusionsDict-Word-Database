        "examples": {
          "standard": [
            {
              "text": "バレーボールの試合で、相手チームのサーブをレシーブし、見事にサイドアウトを取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "サイドアウトを取ることで、流れを自分たちのチームに引き寄せることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの場面でのサイドアウトは、チームに大きな勇気を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
