    "definitions": [
      {
        "index": 1,
        "gloss": "cherry tree east of the southern stairs of the Hall for State Ceremonies (in Heian Palace)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
