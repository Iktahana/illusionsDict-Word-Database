[
  {
    "uuid": "9cbba921-eb63-56b1-9376-0e81f8d5d464",
    "entry": "再出",
    "reading": {
      "primary": "さいしゅつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
