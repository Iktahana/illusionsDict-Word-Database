  {
    "uuid": "6370b76e-5334-5af1-a55d-79b602c10c1b",
    "entry": "下げる",
    "reading": {
      "primary": "さげる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
