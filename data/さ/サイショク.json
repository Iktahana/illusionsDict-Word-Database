[
  {
    "uuid": "7d41bd34-8392-5a02-8316-21a321c24418",
    "entry": "才色",
    "reading": {
      "primary": "さいしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
