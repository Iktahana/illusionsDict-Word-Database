          "literary": [
            {
              "text": "三度目の正直つて云ふこともある。",
              "citation": {
                "source": "麺麭屋文六の思案（二場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "三度目の正直　親友と不仲になって面白くない日を送っているところへ、松本君が訪ねて来て用談を切り出した。",
              "citation": {
                "source": "合縁奇縁",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（斬り付けて引ッ外される）三度目の正直だぞ。",
              "citation": {
                "source": "沓掛時次郎　三幕十場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの者ならこんなことを頼めやあしねえ、あにきだからこそ、怒られるのを承知で頼むんだ、三度目の正直、こんどこそまちげえのねえ娘なんだから。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "三度目の正直",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おめえは三度目の正直と云った、と藤吉は忍耐づよく云った。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "三度目の正直",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして猪之は口の中で、「三度目の正直なんだがな」と呟いた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "三度目の正直",
                "note": "青空文庫"
              }
            },
            {
              "text": "三度目の正直とはなんだ。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "三度目の正直",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だってお松のときに自分で、これが三度目の正直って云ったじゃあねえか。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "三度目の正直",
                "note": "青空文庫"
              }
            },
            {
              "text": "――のぼせてたからそんな気がしたんだろう、こんどこそ本当に三度目の正直なんだ。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "三度目の正直",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は三度目の正直で、漸くだったもの」「受けた数から言えばそうだけれど」「もう少しで三振だ。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は三度目の正直で漸く○○大学へ入った。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三度目の正直を通り越しているから一生懸命になっている。",
              "citation": {
                "source": "嫁取婿取",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうです」「三度目の正直と言うのよ、それを」　ほどなくふたりは喫茶店を出た。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
