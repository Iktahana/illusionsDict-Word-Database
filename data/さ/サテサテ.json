        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "みんなは、がっかりして思いました、「さてさて。",
              "citation": {
                "source": "狐のつかい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "拝む、おっと笑った、さてさて御機嫌が取悪いぞ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……広縁をこの体は、さてさて尋常事ではない。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さてさて捻るわ、ソレそこが捻平さね。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねてたのみし、ひとの、かへられければ、さてさて、つまらぬ。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にとって見なければ信ぜられぬとは、さてさて、あわれむべき御心魂。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、川の中で小便をしている牛を見て青砥は怒り、「さてさて、たわけた牛ではある。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆は先刻から、にこにこ笑ってこの男の話に相槌を打っていたが、心の中で思うよう、さてさて馬鹿な男だ、よくもまあそんな大嘘がつけたものだ、お客の口先を真に受けて私たちの商売が出来るものか。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さてさて、日が永い。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」悟空｜曰く「東勝神州｜傲来国華果山に石卵より生まれたるこの俺の力を知らぬとは、さてさて愚かなやつ。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、申すまじき事なれども、せんだって計らずもおがみました、貴方のお姿、お顔だちが、さてさて申すまじき事なれども、過去りました、あの、そのものに、いやいや貴女、令嬢、貴女とは申すまい、親御でおわす母君が。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてさて思い切った、豪の者なり」と、褒めたというが、これで見ても、かなり朝倉方もやった事が分る。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長、「さてさて不憫の次第なり、汝の心底さぞや」と同情した。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さてさてよう物のわかるご婦人じゃ。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主｜噴飯して、さてさておかしきことを云う人よと云う。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "舅この敷物は北国より到来せし熊皮にて候といえば、聟｜撫で見てさてさて所柄とてよき御皮なり、さて思い出しました、妻も宜しく御言伝申し上げますとあるは、熊皮は毳々たらぬがその色を以て聯想したのだ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚老に逢いて語りけるは、さてさて目出たき御代かな、我ごとき土民までも安楽に栄え美々しき事どもを見きく事のありがたさよ、今が弥勒の世なるべしという。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "困つた話　さて此編輯が終つたら、海へゆかうか山へゆかうかなどゝ考へてゐる、海だつたら得意の水泳をやりたくなつて大切な小説が書けなくなつてしまふだらう、普段余り旅を好まない私は地理にも不明で、さてさて何処がよからうかな、と同じことばかりで一向定まらないのにはとんと困つて仕舞ひました。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてさて量見の狭い酒客じゃて。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてさて絵師というものは鈍なものじゃて。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてさて慌てもの達よ喃。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "王　　さてさてすきこのみの多い人じゃ。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "法　　さてさて、　鏡のかげんであばたもえくぼ　己惚の生んだ児の頭は小うござってのう。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてさて困ったものに御座候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "また同人の歌にかありけんうつせみの我世の限り見るべきは　　　　　嵐の山の桜なりけりというが有之候｜由、さてさて驚き入ったる理屈的の歌にては候よ。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く一、師の云、発句案ずる事諸門弟題号の中より案じいだす是なきものなり、余所より尋来ればさてさて沢山｜成事なりと云り、予が云、我『あら野』『猿蓑』にてこの事を見出したり、予が案じ様たとへば題を箱に入てその箱の上にあがりて箱をふまへ立ちあがつて乾坤を尋るといへり、云々　と、けだしこれ題詠の秘訣なり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてさて困つた者に御座候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "また同人の歌にかありけんうつせみの我世の限り見るべきは嵐の山の桜なりけりといふが有之候由、さてさて驚き入つたる理窟的の歌にては候よ。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八歳にして十三歳の分別しかなければ問題にしてもよきなるに、十八歳が四十歳の分別とは、さてさて困ったものじゃ」　利常公はそう言って、人間には、その時代その時代の年齢にあった力量こそ正しくもあり、人間として一番尊いものであることを近習にさとし――その十八歳の息子の取立てを断わられたという。",
              "citation": {
                "source": "旧作",
                "author": "上村松園",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
