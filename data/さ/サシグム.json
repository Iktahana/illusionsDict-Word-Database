    "definitions": [
      {
        "index": 1,
        "gloss": "to be moved to tears",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "松の青葉に晴れすぎし天景のおもひでにさへさしぐむものを。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人は肌ををさめて愁はしくさしぐむごとし。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さはひとり、われとさすらひ、われと弾き、聴きもほれつつ、日もすがら涙さしぐむ、青き葉のかげをゆく身は。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "何らの修飾なく声あげて泣く人の悲哀より一木一草の感覚にも静かに涙さしぐむ品格のゆかしさが一段と懐しいではないか。",
              "citation": {
                "source": "桐の花とカステラ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わがゆくかたは、末枯の葦の葉ごしに、爛眼の入日の日ざしひたひたと水錆の面にまたたくに見ぞ醉ひしれて、姥鷺はさしぐむ水沼、――「歎かひ」と、「追懷」のすむ郷ならじ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "わがゆくかたは、末枯の葦の葉ごしに、爛眼の入日の日ざしひたひたと、水錆の面にまたたくに見ぞ醉ひしれて、姥鷺はさしぐむ水沼、――『歎かひ』と、『追懷』のすむ郷ならじ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊笛の音生命の路のもろ側に聳やぎ立てる『かなしび』の女木、『よろこび』の男木、今宵さしぐむ月代のまみの濕みに、すずろに木靈うらびれて、天の幸夜にあくがるる沈默の深みを、笛の嘆きの音をいたみ、上枝そよろに囁やきて散りこそまがへ、二木の落葉ほろほろに。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "さしぐむ目の濕ひに、目耀ふ天の羽ぐるまや、ああ曙のうはじらむ唐棣のころも。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八『花を待ちみる事榮に、さこそは齋へ、ともすれば青水無月の小野の香に、むかしの夢のうらびれて、古巣を見てはさしぐむ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "覆盆子のやうに真紅になつて、眼には一杯涙さへさしぐむでゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となくうすあったかい胞で私はさしぐむ様な気持になって居た。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "友は笑ひて、さて云ひぬ、「な偽りそ、つとばかり涙さしぐむ君ならずや、恋人の名を耳にするにも。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "車で来る筈の母親を待ち合せて、父親の切符を買うのをジッと見て居た千世子はわけもなくさしぐむ様な気持になった。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に皈り給はぬはもしやなだれにといひて眉を皺めければ、親子は心あたりときゝてたのみし事も案にたがひて、顔見あはせ泪さしぐむばかり也。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――」　苦惱を刻んだ若い顏を見ると、父親の伊左衞門は、ツイ涙がさしぐむ樣子です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青葉の寮",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
