        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さもないと箸の先で汚ならしくも潰れてしまわないとも限らないのである。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと、その子は、二度と、ちゃんとした人間にはなれないし、いつまでも雪の女王の言うなりに、なっていなければならないんだよ！",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないとやあ公がそれをあやしみはじめるかもしれないからだ。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと、どんなお咎めを受けるかも知れないからな。",
              "citation": {
                "source": "牛",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが正直一遍、忠義一途に世の中を貫いて行く武士のまことの心がけじゃまで……さもないと不忠不義の輩に欺されて一心、国家を過つような事になる。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと読者はペテンにかけられたような不愉快を心の片隅に残すところがあるのだから、ナカナカ事が面倒である。",
              "citation": {
                "source": "創作人物の名前について",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "南はこうして紹介せられておれば、手に入れることはぞうさもないと思った。",
              "citation": {
                "source": "竇氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう狡はなしだ、さもないと――」「どうぞ信じて、信じてくださいよ！",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに必ずいてください、さもないと首ですぞ。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと、じぶんにしても、他人のわたしたちにしても、始末のわるい遠方までとんでいってしまうところでした。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないとこの白い歯でかみつくよ。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでお助んなすればよし、さもないと僕が手伝をして殺したも同然だ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来ることならば独り身におなり遊ばすとよいが、さもないとあなたばかりではない、お嬢さまにも、おそろしい災難が落ちて来るかも知れない』と諭すように仰しゃいました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと貴様の眼をつぶすぞ」と、四、五人は彼の面にのぼって来たので、士はいよいよ閉口した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと、あなたは暑さにあたって死にましょうぞ」　実際暑さに苦しんでいるので、石はその言うがままに誘われてゆくと、西のかた五、六里のところに果たして密林があって、大勢の僧が水のなかを泳ぎまわっていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと私の致しました事を、つまらない感情の爆発から来た、一時的のお芝居ぐらいに思って軽蔑なさるといけませんから……。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと、土地の神霊のために重い罰を受けるようになりますから、彼を懲らすのは彼を救うがためです」　どんな事をするのかと見ていると、劉はその晩、燈火を消した後、自分の寝床の前に炭火をさかんにおこして、なにか一種の薬を焼きました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "稽神録",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早く洗ってくれ、洗ってくれ、さもないと、おまえの為にならないぞ」　公はかまわずに寝床にのぼると、外では焦れて怒って、しきりに洗ってくれ、洗ってくれと叫んでいたが、公はやはりそのままに打ち捨てて置くと、暁け方になるにしたがって、外の声は次第に弱って来た。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと、わたしは職務上、君を引致しなければならないことになる。",
              "citation": {
                "source": "鴛鴦鏡",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと、あたくしはこれから警察に参り、あの井戸まで出張して頂くようにお願いいたしますわ」「待ちなさい」と夫の声が慄えた。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の国内にこんな物騒なものを据えつけるような卑怯な国の人間に、いい具合にこきつかわれてたまるものか」「なんでもいいから早くやれ、さもないとお前の生命は無いぞ。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと、あたしは、焼け死んでしまうよォ」　明らかに女は、極度の恐怖に気が変になりかけているのに違いなかった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないとお千は川の中へボチャンと落ちてしまうにきまっている。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと、もう今度は通さんぞ」「へえい。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと、物が間違いますからね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "化け銀杏",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと家事不取締りの廉で、おれの身分にも拘わるからな」と、長八は溜め息まじりで云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと盲目のおふくろを代官所へ引き摺って行って水牢へ叩き込むが、いいか」　お竹はわっと泣き出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "小女郎狐",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと、彼の作物に見られるやうな、この樹のもつ性格気品のあんなにすばらしい表現が容易に出来るものではない。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと、梅雨の雨がすぐにやつて来るからといふいひ伝へになつてゐる。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
