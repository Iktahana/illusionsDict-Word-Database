    "definitions": [
      {
        "index": 1,
        "gloss": "Records of the Three Kingdoms (Chinese historical text)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
