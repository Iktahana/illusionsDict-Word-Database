    "definitions": [
      {
        "index": 1,
        "gloss": "rust (colour)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "右手に提げたる百錬鉄の剣は霜を浴び、月に映じて、年紀古れども錆色見えず、仰ぐに日の光も寒く輝き候。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前僕の描いた山吹の色は錆色でした。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに赤みがちの錆色にも古びがつき、硝子窓の切り方などもかなりに凝って、尖った屋根飾りや軒飾りなども単純で、いかにもまた雪の深い樺太の情趣を忍ばせるものであった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンツリー・クラブは緩い勾配の屋根の、錆色の羽目の中二階で、簡素ないい趣味の建築である。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸山、大宮を守る佐久間右衛門尉が五千騎に向って、浅木辺より進軍する武田勢三千、その真先に、白覆輪の鞍置いた月毛の馬を躍らし、卯の花｜縅の鎧に錆色の星冑｜鍬形打ったのを着け、白旗の指物なびかせた老武者がある。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンツリー・クラブは緩い勾配の尾根の、錆色の羽目の中二階で、簡素ないい趣味の建築である。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗中に、銃口から吐きだされる錆色の焔。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭には椿も大半｜錆色に腐って、初夏らしい日影が、楓などの若葉にそそいでいた。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "錆色の帆が一点水平線の上にじっとしていた。",
              "citation": {
                "source": "御身",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く見れば、浅間はただなだらかで端正に裾をひいているが、近づいて見ると、緑色の上着の胸を寛げて、自己の履歴を語るように、焼け爛れた赤錆色の四角な肌を露出している。",
              "citation": {
                "source": "浅間山麓",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "土で大方埋まって底に用水が錆色をして溜ってゐる。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "海、装甲、扉――と、こりゃ三重の密室だ」　法水麟太郎と支倉検事が「｜鷹の城」を訪れたのは、かれこれ午を廻って二時に近かったが、陽盛りのその頃は、漁具の鹹気がぷんぷん匂ってきて、巌は錆色に照りつけられていた。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上に錆色のコートを着、裾から太い二本の脚がにゅっと出ていました。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婢が気を附けて、萎びぬやうにと井戸端の水桶の中に、私の燈籠は前夜もその前夜も入れられてあつたのですが、それにも関らず青白かつた彫跡は錆色を帯び、青い地は黒い色になつて居るのです。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老僕の傍には盛をすぎた一匹の獵犬と名だたるバンタム、これは小さな老ぼれの小馬で、もじやもじやの鬣に長い赤錆色の尾をたらし、睡たげに、温和しく路傍に立つて、やがて自分が忙しい目をすることなどは夢にも思ひ及ばぬ樣子であつた。",
              "citation": {
                "source": "驛傳馬車",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "――サボテンのような、トーテム・ポールのような、麒麟の首のような、こういう異様な羅列が、中期原生代の赤錆色の湧出物でおおわれた不気味な谷間の中にヒョイヒョイと立っている。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "津軽海峡の鉄錆色の海の中へ突き出した孤独な岬の上に建っているこの「｜灯台の聖母修道院」にもこんな風に気ぜわしい春がくる。",
              "citation": {
                "source": "葡萄蔓の束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "安芸子は脇窓から、急に冬めかしくなった錆色の風景をながめながら、呟くようにいった。",
              "citation": {
                "source": "雪間",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い尾までも黒い筋の入つた、黄色の大きな翅を持つてゐてその底の方に大きな錆色の眼と青い斑とを持つてゐるのはあげはのてふと云ふのだ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "七戸から北は、砂丘まじりの地表が茫漠とひろがり、屋根に石を載せた暗ぼったい家が、二里に三軒、三里に二軒というぐあいにバラ撒かれ、そのむこうに錆色の荒くれた海が見える。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルリンの未決監獄は、アルトモアブ街に、おそろしげな赤錆色の高壁をめぐらして建っていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわりに、春のころは、協同販売所という看板をかけてあるぎりで、入口の赤錆色の鉄扉がしめられていた店舗が二軒並んで開かれていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤土の地面であって、中央の狭い金色の野には、遅麦や錆色の燈心草が生えていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "林檎の汁は錆色に濁るのが難である。",
              "citation": {
                "source": "胆石",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "花崗岩が錆色に※爛して、大きな磊塊をなしたり、砂泥になったりする所を、乗り越えはいあがって、煙の源へ出る。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下生えの馬酔木の小枝にまで霧藻がもつれ、岩うちわが岩間に錆色の厚葉を光らせる。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東のほうに遠く、隣藩との境をなす伊鹿山が見え、その上にひろがっている棚雲が、金錆色に染まっていた。",
              "citation": {
                "source": "橋の下",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤錆色の、少しも暖かさの感じられないうすら陽は、林になっているくぬぎの木の幹を、片明りに染め、枯れた芒のくさむらの、ほほけてしまった穂を、鮮やかに白く浮き立たせていた。",
              "citation": {
                "source": "薊",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾妻村下羽田では、庭田恒吉方の杉林をはじめ附近一帯の杉林が未だ去年の夏までは青々とした繁りを見せていたのに、今はもうどれも赤錆色になっていた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "音もなく、こまかく、あかさびいろに染まった砂が、せまいガラスの管をとおってしたたっている。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
