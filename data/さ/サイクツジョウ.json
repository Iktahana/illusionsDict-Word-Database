        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "プレトリアという所に近い採掘場で地下十八フィートの穴から見出された。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "硫黄採掘場の風景画もとうとう私の手もとには届いて来なかった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "低く砂だらけの西オーストラリア海岸の光景がいかに私の気分を重くしたかも、またいかに私が粗野な鉱山町やトラクターに最後の荷物を積み込んだ荒涼たる金採掘場を疎んだかも、語る必要がない。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "立坑や採掘場に何千ドルもつぎ込んだ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の知る限り、金採掘場で誰一人、このことは知らない。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
