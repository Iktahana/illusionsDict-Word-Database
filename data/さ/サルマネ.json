    "definitions": [
      {
        "index": 1,
        "gloss": "indiscriminate imitation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
