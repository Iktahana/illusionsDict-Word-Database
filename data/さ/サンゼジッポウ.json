        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夫れ真に神を見て信ずるものの信念は、宇宙の中心より挺出して三世十方を蔽ふ人生の大樹なる乎。",
              "citation": {
                "source": "予が見神の実験",
                "author": "綱島梁川",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいらの目も安物じゃねえが、み仏のおん目は、三世十方お見通しだぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに三世十方とは、「無限の時間」と「無限の空間」ということです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰ぎ願くは三世十方の諸佛、愛護の御手を垂れて出離の道を得せしめ給へ。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈迦牟尼仏よ、三世十方の諸仏菩薩よ。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "倶胝和尚は指を竪て、趙州和尚は柏の樹を指さしたということだから、慢心和尚がああして幽霊のような手つきをして、自分の円い頭を辷らしているところに、三世十方を坐断する活作略があるのではなかろうか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "慢心和尚の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
