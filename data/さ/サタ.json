[
  {
    "uuid": "806616cc-110d-59be-90a5-c05dde8c42fd",
    "entry": "沙汰",
    "reading": {
      "primary": "さた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "affair",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二　帰省者田舎よりの手紙　拝啓　御無沙汰しましたが、お変りもありませんか。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は手持無沙汰なのでやがて耕二の机の方に近づかうとした。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹村君は外套の襟の中で首をすくめて、手持無沙汰な顔をして娘の脱ぎ捨てた下駄の派手な鼻緒を見つめていたが、店の時計が鳴り出すと急に店を出た。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "云々と書いたら、百點滿點笑止の沙汰、まさしく佐藤家の寶物だ、と殘念むねん、へそを噛むが如き思ひであつた。",
              "citation": {
                "source": "先生三人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはどうも色戀の沙汰には同情を持てないたちでねえ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世人はこれを、雀大臣と呼んで、この出世も、かれの徃年の雀に對する愛情の結實であるといふ工合ひに取沙汰したが、しかし、お爺さんは、そのやうなお世辭を聞く度毎に、幽かに苦笑して、「いや、女房のおかげです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『立像』の新短歌について何か思ったことを書けとの御沙汰でしたから手近にあった第三号をあけてはじめから歌だけ拾って読んで行きました。",
              "citation": {
                "source": "御返事（石原純君へ）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえ等は、福慈とは交際っていないのかい」　すると弟の岳神は言訳らしく「なにしろ自分の持山のことで忙しく、ついついご無沙汰をしております」　そのとき岳神の妻が傍から、ちょっと口を入れた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、夢中で狂気染みた沙汰を醒めて冷く指摘されたように、口｜銜り、みると額に冷汗までかいている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、それからだんだん国元の様子が父に不利になって来て、近頃ではまるっきり音沙汰もありません。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一説によれば chicane の略で裁判沙汰を縺れさせる「繊巧な詭計」を心得ているというような意味がもとになっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局は、やればやり得る学位を、無用な狐疑や第二義的な些末な考査からやり惜しみをするということが、こういう不祥事やあらゆる依怙沙汰の原因になるのである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『武家義理物語』の三の一に「すこしの鞘とがめなどいひつのり、無用の喧嘩を取むすび、或は相手を切りふせ、首尾よく立のくを、侍の本意のやうに沙汰せしが、是ひとつと道ならず。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に見たくないという格段の理由がある訳でもなんでもないが、またわざわざ手数をして見に行きたいと思う程の特別な衝動に接する機会もなかったために、――云わば、あまり興味のない親類に無沙汰をすると同様な経過で、ついつい今まで折々は出逢いもした機会を、大して惜しいとも思わずに取外して来たのである。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで今年はとうとう竹の台の秋には御無沙汰をすることにあきらめていた。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために、あらゆる義理を欠き、あらゆる御無沙汰をして、寒さを逃げ廻っては、こそこそと一番大事なと思う仕事だけを少しずつしている。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには小さい卓が置いてあつて、その傍に、丈の高い腕附きの椅子に、金巾の覆ひを掛けたのが二つ、手持無沙汰な風をして据ゑられてゐる。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "）ちょいちょい覗いて見ようと思うのだけれど、つい御無沙汰になってね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（手持｜無沙汰に、ほとんど恐る恐る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまや狂気の沙汰、音楽師、ピアノの波が尼僧呼びよせる。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、私の詞が氏に影響するなどと考へるのは、或は少々の烏滸の沙汰かも知れないが……。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那語の達者な友人は早速笑ひ聲を交へながら女と何やら話しはじめたが、僕は至極手持ち無沙汰である。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」じいさんは階下の自分等にあてがわれた四畳半で手持無沙汰に座っていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "饂飩屋も、お湯屋も、煙草屋も、商売の一寸した手落ちにケチをつけられて罰金沙汰にせられるのが怖い。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか気になるので、五月の末に無沙汰の詫びながら手紙を出すと、すぐその返事が来て、来月は氷川様のお祭りで強飯でも炊くから遊びに来てくれとのことであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きょうのことは、誰にも当分沙汰なしにして置いてくんねえよ」四　寺の門を出ると、半七は松吉に逢った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも御無沙汰をいたして居りました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これが表沙汰になりましては、御屋敷の名前にもかかわります。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああふるさとの永日に少女子どものなつかしさたとしへもなきなつかしさやさしく指を眼にあててももいろの秋の夕日をすかしみるわが身の春は土にうもれて空しく草木の根をひたせる涙。",
              "citation": {
                "source": "秋日行語",
                "author": "〔菊もうららに〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しその面白さたるや「感覚的」に終止するものであることは争はれない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
