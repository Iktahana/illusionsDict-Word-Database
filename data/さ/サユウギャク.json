        "examples": {
          "standard": [
            {
              "text": "事故の後、彼は左と右が逆になっていることに気づいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "鏡像は、すべてが左右逆になっているように見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この地図は左右が逆になっているようだ、ナビゲートできない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ところが、上下逆さまにならない代りに、今度は左右逆さまになることを彼は気がつかなかった。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、谷川岳の道標を書かせると、上下が逆さまだというのに気がついて、頭だけ逆さまにならないようにそろえるまでは気がついても、今度は左右逆の方向から書かないとアベコベの方向を指してしまうということまでは気がつかないような脆さがある。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
