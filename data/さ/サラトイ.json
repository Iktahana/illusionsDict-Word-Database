[
  {
    "uuid": "45ac3f57-82ce-5f5b-9451-4e2a80b65e75",
    "entry": "更問",
    "reading": {
      "primary": "さらとい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
