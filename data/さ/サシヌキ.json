    "definitions": [
      {
        "index": 1,
        "gloss": "type of hakama worn in ancient times",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
