      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "operation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "主観的であるとは、具体的表象に規定されず、芸術の形成原理が自由に抽象的に作動する場合である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作品の制作動機、手段方法は、一つの謎としてのこされていゝだらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "フ氏曰く、竜は仮作動物で、普通に翼ありて火を吐く蜥蜴また蛇の巨大なものと。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "「興津彌五右衛門の遺書」は、鴎外が人間の異常な行動のモメントとして、強烈な感銘を本人に与えた一片の恩義が猶よくその人の生命を左右する力をもっていることを、美と感じたロマンティックな創作動因に立っている。",
              "citation": {
                "source": "鴎外・芥川・菊池の歴史小説",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "創作動機など言うものは、瞬間に通り過ぎるもので、こんな部分までも、記憶に残らないことがあるものである。",
              "citation": {
                "source": "山の湯雑記",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅林寺のは、製作動機から見れば、稍後出を思はせる発展がある。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "禪林寺のは、製作動機から見れば、稍後出を思はせる發展がある。",
              "citation": {
                "source": "山越しの阿彌陀像の畫因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅林寺のは、製作動機から見れば、稍後出を思わせる発展がある。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、普遍的の低級な熟せない創作動機から出来た其等の作物を以て、人麻呂の芸術を論ずるめどとしてはならぬ。",
              "citation": {
                "source": "叙景詩の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした宴遊の場に於てくり返された労苦が積りつもつて、短歌成立前から兆して居た創作動機を、故意に促す文学態度が確立した訣である。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "万葉集の抒情詩すら、叙事詩脈の劇的表現・民謡式の誇張発想・儀礼上の伝襲的叙述法などから出来たと言ふ事情の忘れられた後代に、古代人の素朴と言ふ予断で、製作動機も醇化せられ、不当に高く評価せられたものであつた。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "其例の物に伊勢物語系統の歌物語の型をとり容れて来たのがあつて、自分の贈答や述懐の短歌の製作動機を、あはれに書く風が出来た。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "金葉・詞花の時代は、短歌の創作動機が鈍つて、或は、連歌が室町を待たずに勢力を持つに到つたかも知れない状態になつて居たらしい。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の新手法は模倣と言ふにはあまりに早く、他の人々の創作動機に入りこんでゐた。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の宮内卿・良経の作物も、強い印象が即時又は時を隔てゝ、創作動機を衝いた為に、類似の発想法を促したのであることは言へる。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々な試みもしてゐるが、此集は、わりあひに、創作動機の濃やかに動いた痕は見えない。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "至尊族の生活法が、一番短歌の創作動機を自然に起し得る様になつて居たのかも知れない。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "物語歌と地の文との関係に創作動機の別殊な動きを感じて、此をとり入れようとしたのは女房風に対する理会があつたからである。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "後鳥羽院は盟主として、その朋党の間に※釀せられた潮流に、第一義の素質的創作動機を落された。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術家の立場によつて、その制作過程や、制作動機がまちまちであることは当然であるが、所謂「主題」の捉へ方に於て、劇作家が小説家と異る一点は、ただ、生命の韻律に興味を繋ぐか、或はその姿態に心を傾けるかによつて生じるのであると思ふ。",
              "citation": {
                "source": "戯曲以前のもの",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来、戯曲作家は、その製作動機に於て、小説家とやゝ趣を異にし、如何に舞台にかけるといふ意識なしに書かれた戯曲でも、この創造的努力は完全な上演によつて初めて完全に報いられる性質のものである。",
              "citation": {
                "source": "戯曲時代去る",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、近頃、「演劇の本質は動作にあり」といふ昔ながらの議論を蒸し返して、大に「動作を主とする演劇」の提唱を試みてゐる人々もあり、それに対して、「動作動作といふが、動作を如何にすれば、今日の演劇が向上するか」といふ反問を発したこともある。",
              "citation": {
                "source": "演劇本質論の整理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、創作動機から見れば、純粋な抒情詩人である。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、次第に、創作動機を刺戟して、文学の芽生えが、民謡のうちに現れて、まだ類型風でありながら、いくぶんの個性を出すようになつた。",
              "citation": {
                "source": "短歌様式の発生に絡んだある疑念",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二つの像はおよそ等身大のものであるが、製作動機にむしろ人形意識がつよくはたらき、ただその傳統的形式のために彫刻としての諸性質が備わるにいたつた觀がある。",
              "citation": {
                "source": "古代エジプトの作品",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水温を任意の値に保ったり、或いは必要な温度の上下に、必要量だけ変化させることは、電熱を使って、自動的に作動する装置を作れば簡単に出来ることである。",
              "citation": {
                "source": "稲の一日",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方法は記載してないが、昨年の十二月、この記者がイースト・アングリアの飛行場でＦＩＤＯの作動状態を見せられた時の記事から推察することが出来る。",
              "citation": {
                "source": "霧を消す話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前様、今の住居は、隣の嚊々が小児い産んで、ぎゃあぎゃあ煩え、どこか貸す処があるめえか、言わるるで、そん当時黒門さどうだちゅったら、あれは、と二の足を蹈ましっけな。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「噺の外でがさどうも、彼此れはあ、小卅日にも成んべが、まあだかたでどつちから手つけてえゝか分んねえんでがさどうもはあ、わし等方見てえに洪水ばかし出たんぢや、居んのも厭んなつちまあやうなのせ本當に、さう云つてもこつちの方はようがすね」おつたは相手を見つけて力を得たやうにいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四つ又へ頼んでおくんですから何とかして呉れんでせうが本當に困つたもんでさどうも」　こんなことに過ぎない。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
