[
  {
    "uuid": "5a1d1044-f8b5-56d5-82c3-2fe5606fc0af",
    "entry": "作動",
    "reading": {
      "primary": "さどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
