        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二　叫びたいことが直接形を採るためには非常に熱烈である必要があるのだが、その熱度の聊低い者は叫ぶ者の容態を描くことになる。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしく萬歳を叫ぶべし。",
              "citation": {
                "source": "南京陷落の日に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の玄関へつくと、車夫がとても威勢の好い大きな声で、『オ帰リイ』と叫ぶ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、振りかえりざま、叫ぶようにして言った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は珈琲店の椅子で酒を飲み、大衆と共に「あなたと呼べば」を唄つた後で、自ら自分の髪の毛をむしりながら、自分に向つて「この大馬鹿野郎奴」と叫ぶのである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともあれ蕭条たる秋の夜半に、長く悲しく寂しみながら、物におびえて吠え叫ぶ犬の心は、それ自ら宇宙の秋の心であり、孤独に耐え得ぬ、人間蕪村の傷ましい心なのであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野へ入れば往来の人ようやくしげく、ステッキ引きずる書生の群あれば盛装せる御嬢様坊ちゃん方をはじめ、自転車はしらして得意気なる人、動物園の前に大口あいて立つ田舎漢、乗車をすゝむる人力、イラッシャイを叫ぶ茶店の女など並ぶるは管なり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右へ廻れば藤棚の下に「御子供衆への御土産一銭から御座ります」と声々に叫ぶ玩具売りの女の子。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽笛の吼ゆるごとき叫ぶがごとき深夜の寂寞と云う事知らぬ港ながら帆柱にゆらぐ星の光はさすがに静かなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘却というものがなかったら生きていられないと詩人は叫ぶ。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしのやうな小国の王の杯は受けぬと言ふのか、恩知らず奴ツ」彼はこう叫ぶやいなや、その大杯を丈の高い蘭人の額にハツシとぶつけた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると心は叫ぶのだ、あれでもない、これでもない、あれでもないこれでもない！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は切なく叫ぶ、「この大根、嫁かずであれ、――今に」　といい、あとをも見ずに駈け去った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この薑、口｜疼く　男は、叫ぶと猛然、女の代りに鹿に飛びかかって、毛深く逞しい拳を振り上げて、丁々と撃った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と叫ぶやうにきゝました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お、おれ先に叫ぶから、みんなあとから、一二三で叫ぶこだ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈々ちゃんお先においでよ奈々ちゃんと雪子が叫ぶ。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "出口がせまいので少しからだを横にようやく通る窮屈さをいっそう興がって、ふたりは笑い叫ぶ。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういううち、医者はどうして来ないかと叫ぶ。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は叫ぶ、坂部さんがいなければ木下さんへゆけってこかねい。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "君がもしこの原稿をよんだならば、どんなに腹を立てて叫ぶかを想像する。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都の駅前でバンザイを叫んだ人と××の街頭でバンザイを叫ぶ人と顔色が違う。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "叫ぶ人の悲劇　叫ばれる奴の悲劇。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "源兵衛爺とお静、叫ぶ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎長、代官と戦い乍ら叫ぶ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっかりしろ」　無念の石松、叫ぶ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝坊遂に三次を見つけ出して大声に「目つけたよ」と叫ぶ。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次が突然すっくと立上って叫ぶ。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝長屋表　棚倉一味と捕方が、Ｔ「確にこの長屋だ――」　と叫ぶ。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔雪とひのきの坂上に〕宮沢賢治雪とひのきの坂上に粗き板もてゴシックを辛く畳みて写真師の聖のねぐらを営みぬぼたと名づくる雪ふりていましめさけぶ橇のこらよきデュイエットうちふるひひかりて暮るゝガラス屋根",
              "citation": {
                "source": "〔雪とひのきの坂上に〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
