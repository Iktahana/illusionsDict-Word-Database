[
  {
    "uuid": "8ec9d2fa-cc3c-5b03-b157-d4ca51d2160d",
    "entry": "匙",
    "reading": {
      "primary": "さじ",
      "alternatives": [
        "しゃじ",
        "かい"
      ],
      "is_heteronym": false
