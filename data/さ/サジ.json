    "definitions": [
      {
        "index": 1,
        "gloss": "spoon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし、ここで匙を投げたら、或いは、日本のお伽噺はギリシヤ神話よりも殘酷である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」母は遂々、匙を投げた。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十一月十七日『東京朝日新聞』）　　　　　　　　　四十　　　　　　ノルウェーの夫婦匙　ノルウェーで結婚式の時に用いる木彫の匙がある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎖で二つの匙をつないだようなものであるが、ただ一本の木で作るそうな。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚の朝、新郎新婦はこの夫婦匙で睦まじく御馳走を食うという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家兎のやうな目をしてゐるフランス女は、子供の手から匙をもぎ取つた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今の家内を貰ってから、福沢宗になりましてね、堅蔵ですよ」「お金をたくさん持って面白い」「何とか有効に使わなくちゃならないと考えて来るようになっちゃ、もう面白くありませんな」「そう」　小初は、もう料理のコースの終りのメロンも喰べ終って、皮にたまった薄青い汁を小匙の先で掬っていた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "匙を持つ手は、ヘロ中の結果、ニコチン中毒のひどい奴より、もっとひどくブル／＼ふるえた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……もっと、もっと、円匙と、つるはしを持って来い。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）という時たちまち犯すべからざる者になったから、私は口をつぐむと、婦人は、匙を投げて衣の塵を払うている馬の前足の下に小さな親仁を見向いて、（しょうがないねえ、）といいながら、かなぐるようにして、その細帯を解きかけた、片端が土へ引こうとするのを、掻取ってちょいと猶予う。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼をつぶつて仰向のまま、二匙すすると、もういい、と言つた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の、ひとのよい無學ではあるが利巧な、若く美しい妻は、居並ぶ近親たちの手前、嫉妬でなく頬をあからめ、それから匙を握つたまま聲しのばせて泣いたといふ。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼をつぶって仰向のまま、二｜匙すすると、もういい、と言った。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の、ひとのよい無学ではあるが利巧な、若く美しい妻は、居並ぶ近親たちの手前、嫉妬でなく頬をあからめ、それから匙を握ったまま声しのばせて泣いたという。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはイクラ猪口兵衛どんでも知らっしゃれん事じゃが、私がこの事件に限って匙を投げかけておるについては、深い仔細があることじゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴嬢が掌に宝丹移せし時、貴嬢は再びわが顔を打ち守りたまいぬ、うるみたる貴嬢の目の中には、むしろ一｜匙の毒薬たまえ刻き君とのたもう心｜鮮やかに読まれぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "指程の腸詰十八を白葡萄酒で煮て冷してから匙でくずす。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "給仕はそれを匙で抉ってそっと皿へ落す。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "リキュール酒、グラス一ぱいを半分に煮詰めたもの、それに二倍のクリームと肉汁二匙とを前の鍋に入れどろどろまで混ぜ合せて煮る。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂で家鴨の血の汁を掻き立てる匙の音が霰のようだ。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼等が見合いかたがた河内屋に滞在しているうちに彼等はことごとく匙を投げた。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが、丸持の祕藏子だと、匙庵老が脈を取つて、氣鬱の症でごわす、些とお氣晴を、と來て、直ぐに野幇間と變化る奴。",
              "citation": {
                "source": "一席話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――シユウとあわが立つて、黒いしるの溢れ出るのを匙でかきまはす代ものである。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ここで匙を投げたら、或いは、日本のお伽噺はギリシヤ神話よりも残酷である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は二度目の成功を期待しながら、執念深く同じ行為を繰返して、再度｜茶匙を床に落した。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀製の光った匙は、床の上で跳ねあがり、鋭く澄んだ響を立てた。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "教師は左の手で一つの匙を、鉢の蔬菜の上へ控えた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて伍長の肩書も持たば、鍛工場の取締りとも言はれなば、家は今少し広く、小女の走り使ひを置きて、そのかよわき身に水は汲まさじ。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が良人が所為のをさなきも強いて隠くさじ。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "時は旧き暦の五月にさへあれば、おのが時たゞ今と心いさみて、それよりの夜な／＼目もあはず、いかで聞きもらさじと待わたるに、はかなくて一夜は過ぎぬ。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
