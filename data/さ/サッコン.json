[
  {
    "uuid": "5fc1c6a0-03aa-5c30-8290-16c40bf93136",
    "entry": "昨今",
    "reading": {
      "primary": "さっこん",
      "alternatives": [
        "さくこん"
      ],
      "is_heteronym": false
    },
    "grammar": {
