      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ligature mark",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "が、しかし、気管中にも栓塞したらしい物質は発見されず、口腔を閉息した形跡もないばかりか、索痕や扼殺した痕跡は勿論見出されなかった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つは四肢の妙な部分に索痕があると云う事で、各々上膊部の中央と、膝蓋骨から二寸許り上の大腿部に残されていた。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか君は、四肢の妙な部分に索痕が残っていたのを憶えて居るだろうね。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
