[
  {
    "uuid": "e54dc546-e4a1-5d4f-ba87-8ea8b8a4080b",
    "entry": "最奥",
    "reading": {
      "primary": "さいおう",
      "alternatives": [
        "さいおく"
      ],
      "is_heteronym": false
    },
    "grammar": {
