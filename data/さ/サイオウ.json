      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "deep inside",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私たちの心の最奥には仏智見と言って完全無欠の霊智があるのですが、その上を無明な痴が遮ぎっているので、みすみす自分に持ち合せる霊智を働かせることが出来ないのです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間、渠も彼らとともに自然詩人となって宇宙の調和を讃え、その最奥の生命に同化することを願うた。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは、港の最奥部で、馬蹄形の頂点になっていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "この悲哀は華やかな青春の悲哀でもなく、単に男女の恋の上の悲哀でもなく、人生の最奥に秘んでいるある大きな悲哀だ。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の最奥に秘める暗黒なる力に対する厭世の情は今彼の胸を簇々として襲った。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の主観の最奥に横たわってる運命的なものは、抽象的に拵えあげられた運命などというなまやさしいものではない。",
              "citation": {
                "source": "待つ者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾等が悪魔を見出し得ざるは、その姿が、全然吾等が肖像の中に求め得ざればなり――と、勿論、この事件最奥の神秘は、そういう超本質的な――形容にも内容にも言語を絶している、あの哲学径の中にあるのです。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その循環にある最奥の意義と云うのは、僕等が看過していた五回目の一踏みにあったのだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その足跡は、奥の垂幕の蔭に消え、最奥の棺室に続いているのである。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、私は悪魔の尿溜に入りこんで、最奥の神秘をみた全人類中のたった一人の男だ。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か陰暗のうちに、思いも付かない黙闘が行われているのではないか――そう考えると、はやそれから、秘密っぽい匂が感じられて来て、是非にも、最奥のものを覗き込みたいような、ときめきを覚えるのだった。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――隠れたる最奥の紅玉石よ、そは凡ゆる場面にあり。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、幡江の最奥のものに触れた手を、しばらくそのまま、そっとして置きたいのだよ」　法水は冷然と云い放って、湯気のなくなった紅茶を、一気に啜り込んだ。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして心のずつと奥の方で、例へば向ひ合つて立てられた二枚の反射鏡の無限に連らなる映像の最奥のポイントと思はれるあたりで、こつそりにやりと微笑し、どうせ乗りかかつた船だ、と呟くのであつた。",
              "citation": {
                "source": "道化芝居",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間が人間自身の内的な力で生き、人間の最奥の力で生きてゐるんだ。",
              "citation": {
                "source": "道化芝居",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命最奥の動乱より発するものではない。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "語を崩して新しい語を拵へて行く場合だつて、もつと芸術式に、もつと最奥処から出て来てほしいものです。",
              "citation": {
                "source": "新しい国語教育の方角",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが斗満｜最奥の人家で、駅逓から此処まで二里。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか、利根の最奥の部落、大芦から上流へ入って行けば、岩魚は本場である。",
              "citation": {
                "source": "蛙を食う岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "然り、造化の妙機は秘して其最奥にあるなり。",
              "citation": {
                "source": "万物の声と詩人",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の最奥なるところ、之を人間の空と言ひ、造化の最奥なるところ、之を造化の霊と言ふ。",
              "citation": {
                "source": "万物の声と詩人",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "是非と善悪とを弁別するに最大の力を持てる宗教なかつせば、寧ろブルータルなる情熱を得ることあるとも、優と聖と美とを備へたる情熱は之を期すべからず、宗教的本能は人心の最奥を貫きて、純乎たる高等進化をすべての観念に施すものなり。",
              "citation": {
                "source": "情熱",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "加茂氏は吉備真備の裔にして、八世加茂保憲最奥儀を極め、陰陽頭に任ぜられ、天文博士を兼ねしが、天文道は門人安倍晴明に伝へ、暦道は子光栄に伝へたりと云。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "最奥の部落を離れて間もなく水際に大きな葉を拡げた大木の梢に、白い花の簇り咲くのを見るであろう。",
              "citation": {
                "source": "渓三題",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "双六谷が峡流らしくなるのは、最奥にある金木戸の部落を後にして、笠ヶ岳を西から北へ大廻りに廻るあたりからである。",
              "citation": {
                "source": "渓三題",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白壁も見える、麦の畑桑の畑も見える、早川谷最奥の部落奈良田であろう。",
              "citation": {
                "source": "白峰の麓",
                "author": "大下藤次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地図と対照して実際の地形を視ると、皇海山の西方から発源する不動沢の左股を遡るのが楽でもあり、かつ都合もよいように思われるので、それを登ることとして沢を渡り、道に沿うて最奥の小屋まで行き右に折れて林中を進むと左から来るかなりの沢に出た。",
              "citation": {
                "source": "皇海山紀行",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも傾斜が急であるから、最奥の部落清水瀬あたりを出発点としても、二日は懸るものと見なければなるまい。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
