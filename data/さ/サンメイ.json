[
  {
    "uuid": "e108f195-4db3-5506-8a97-a187d428c0e4",
    "entry": "山名",
    "reading": {
      "primary": "さんめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
