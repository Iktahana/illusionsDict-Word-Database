[
  {
    "uuid": "829cf3b2-4fa3-5a6e-af09-4e032c95feb3",
    "entry": "詐欺",
    "reading": {
      "primary": "さぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
