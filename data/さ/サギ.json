      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fraud",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これではまるで詐欺師であるが、これはおそらく彼の敵のいいふらした作り事であろう。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "詐欺師や香具師の品玉やテクニックには『永代蔵』に狼の黒焼や閻魔鳥や便覧坊があり、対馬行の煙草の話では不正な輸出商の奸策を喝破しているなど現代と比べてもなかなか面白い。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生犀星の名をかたつて、僕を欺きに來た詐欺師ぢやないか？",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とは或る向うの消息通が僕に聞かせた詞だが、ばくち好きで、またばくちの天才の支那人だけに麻雀道に於ても中には恐ろしい詐欺、いんちきを企てるものが可成りあるらしい。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（私の美に対する情熱が娘に対する情熱と胎を共にした双生児だったことが確かに信じられる今、私は窃盗に近いこと詐欺に等しいことをまだ年少だった自分がその末犯したことを、あなたにうちあけて、あとで困るようなことはないと思います。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗難や詐欺にかかった被害者の女師匠などが、加害者でもなんでもない赤の他人の立派なお役人を、どうでもそうだと言い張る場合などがそれである。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の罪名は、結婚詐欺であった。",
              "citation": {
                "source": "あさましきもの",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで芸術表現の詐欺取財だ。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "可愛い妻子に美味いものも喰わせず、楽しみもさせずに、恥は掻き放し、義理も欠き捨て、人情も踏付け通しで、そのたんびに首を縮めて盗賊と、詐欺と、非人の気持を繰返し繰返し、アチラで一文コッチで三文とクスネ込み溜め込むようになります。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "投機者には通有らしい、めまぐるしく動く大きな眼――それはもう一歩というところで詐欺師のそれと一致するものだが――の眼尻に、この人に意外な愛嬌を添える小皺ができはじめた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "てっきりこいつ大詐欺に極まった。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが読者のうちにも已に御承知の方もあらうが、古来の小説随筆類のうちから詐欺的犯罪行為に関する小話を原文のまゝに抜萃したもので、長短百種の物語を収めてある。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故世の中には情死や殺人や強盗や姦通や自殺や放火や詐欺や喧嘩や脅迫や謀殺の騒が斷えぬのであらうか、何故また狂人や行倒や乞食や貧乏人が出來るのであらうか。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "後で銀子も知ったことだが、猪野は大きな詐欺事件で、長く未決へ投げ込まれていたが、このごろようやく保釈で解放され、係争中をしばらく家に謹慎しているのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはちょうどそのころ世の中を騒がしていた鈴弁事件と似たか寄ったかの米に関する詐欺事件だったが、隠匿の方法がそれよりも巧妙に出来ており、相手の弁護士をてこずらせていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ猪野の詐欺横領事件は、大審院まで持ち込まれ、審理中であるらしく、猪野はいつも憂鬱そうに、奥の八畳に閉じ籠もり、酒ばかり呑んでいた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　十月の末、控訴院から大審院まで持って行った猪野の詐欺、横領に関する事件がいよいよ第二審通り決定した旨の電報が入り、渡弁護士の斡旋によって、弁護士の権威五人もの弁論を煩わしたこの係争も、猪野の犯した悪事の割には、事実刑も軽くて済むのにかかわらず、寿々廼家夫婦は今更のように力を落とした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は詐欺か何かの玉に使われているような気になって磨き上げた廊下をあるいて行った。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニイチェは如何にその師匠に叛逆し、昔の先生を「老いたる詐欺師」と罵つたところで、結局やはりショーペンハウエルの変貌した弟子にすぎない。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやしくも五感以外の方法、たとへば考察や冥想や空想によつて神祕を感觸したと稱するものがあれば、それは詐欺師であるか狂人であるかの一つである。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いどころか詐欺だった。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人たちのする事は、一から十まで心理の駈引き、巧妙卑劣の詐欺なのだから、いやになる。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪辣なる詐欺と言ってよかろう。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るべし、支那の君子の言葉もいまは、詐欺師の韜晦の利器として使用されているではないか。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文盲不才、いさぎよく罪に服さうと存じます。",
              "citation": {
                "source": "文盲自嘲",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぎといふものは、みんな天の川の砂が凝って、ぼおっとできるもんですからね、そして始終川へ帰りますからね、川原で待ってゐて、鷺がみんな、脚をかういふ風にして下りてくるとこを、そいつが地べたへつくかつかないうちに、ぴたっと押へちまふんです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）ジョバンニは首を垂れて、すっかりふさぎ込んでしまひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かささぎですねえ、頭のうしろのとこに毛がぴんと延びてますから。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿河原のぼろぼろの仇討決闘の話でも、我執無慙を非難すると同時にまた「死を軽くして、少しもなづまざるかたのいさぎよさ」を讃えている。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのたびに手術室に逃げこんでいさぎよく離婚してしまった。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
