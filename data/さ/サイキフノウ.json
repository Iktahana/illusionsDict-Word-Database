    "definitions": [
      {
        "index": 1,
        "gloss": "being beyond recovery",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
