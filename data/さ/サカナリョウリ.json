    "definitions": [
      {
        "index": 1,
        "gloss": "fish-based cooking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
