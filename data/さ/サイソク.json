[
  {
    "uuid": "bbe93d48-8d28-527c-b03f-16c1075dec48",
    "entry": "催促",
    "reading": {
      "primary": "さいそく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
