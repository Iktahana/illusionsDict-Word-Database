        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pressing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ひどくがっかりして、しかし結局あきらめて辛抱して待って、さてもういいかと思って催促すると、今度は何とかがどうとかして何とかで工合が悪いからもう二、三日待てという、その何とかが実に尤千万な何とかで疑う余地などは鷹の睫毛ほどもないのだから全く納得させられる外はなかった。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「武士は食わねど高楊子」主義で突っぱった当時の青年文士は、いいかげんシビレを切らしても、原稿料の催促はしたくなかった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにその年の秋も過ぎて、いよいよ手元切迫に及んだので、からめ手から催促するような手紙をやった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、娘、何とかいわんかい」　と催促されてもうそ寒そうに袖の中に手を入れ合して立っているだけだった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　催促に來た商人たちは、眞つ蒼になつてばたばたと逃げ出した。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャンパンのキルクがボーイの鉤鼻から落下すると私のパートナアが横目をつかってボーイに現金で酒代とチップを渡すように催促して別に靴先につける天花粉の代金十｜仙を請求する。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ、こんな催促の手紙が来とるんだぞ！",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く申し立てろ」　そばにはお登久が執念深そうな眼をして睨みつけているので、千次郎も少しためらっているらしかったが、半七に催促されて彼はとうとう思い切って白状した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様にしてはちっと足が鈍いな」　八丁堀同心の岡崎からときどきに催促されて、半七も気が気でなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "催促はするがね……それ、な、これえ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、鰯の催促をしたようで。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と冷かしたが、元来、衣裳鞄の催促ではない、ホツキ貝の見舞に来たのだから、先づ其次第を申述べる処へ……又近処から、おなじく、氷砂糖、梅干の注意連の女性が来り加はつた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから十二、十三と三日も経っとるのに下手人がわからんとは余りにも手｜緩いちゅうて、大目付から矢の催促じゃ」「ふうん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "さようなれば吾々も役目柄、その通りに大公儀へ申上げねばならぬが……サア、サア、サアとか何とか難癖をつけて催促をしおるらしい。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方それは袖の下の催促じゃろう」「もちろんじゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この良助を捕まえては、まだかまだかと言う日増しの催促じゃが、今度の事件ばっかりはイカナ俺も手に立たぬ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何度も本屋へ通ってまだかまだかと催促してやっと手に入れたときの喜びはおそらくそのころのわれわれ仲間の特権であったかもしれない。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝田樗陰君が木曜面会日の朝からおしかけて、居催促で何枚でも書かせるのを、負けずにいくらでも書いたそうである。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが昨日本屋の奴が来やがって、いやに催促がましいことをいうもんだから、ひとまず君にはすまないが――そっちを綺麗にして鼻をあかしてやれという気になったのさ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と哲が返事をしても、お末が何んとも言葉をつがないので、「姉や何んだ」　と催促したが、お末は黙つたまゝだつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "境遇は円覚寺ほど幽邃ではありませんが、それでも兎に角仕事は終えました、電報までよこして催促している足助に早くこの稿をこれから送ります。",
              "citation": {
                "source": "●「或る女」巻頭のホイットマンの詩",
                "author": "\"Not till the sun excludes you, do I exclude you;",
                "note": "青空文庫"
              }
            },
            {
              "text": "貸越しをもう少し催促して取立て、前借りをもう少し引緊めて拒絶する。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……替りには、刻限までだと、何時に口を掛けても、本人が気にさえ向けば、待つ間が花と云う内に、催促に及ばずして、金屏風の前に衣紋を露す。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」六時がすぎるとお糸さんはいつも催促した。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺がやつと寒い寝台から出たと云ふのに、もう電話で裁判所から催促だ。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで居催促という形もある。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どことかの大金持だの、何省の大臣だのに売ってやると言って、だまして、熊沢が皆質に入れて使ってしまって、催促される、苦しまぎれに、不断、何だか私にね、坊さんが厭味らしい目つきをするのを知っていて、まあ大それた美人局だわね。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二度まで爺やが出て来て、催促をされたあとで、お澄が膳を運んだらしい。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "石橋山の御約束はもはや御忘れなされたかと、たびたび催促に及ぶといへども、四の五の云うて埓があかぬ。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時も御金のさいそくで私もほんとに困って居ります。",
              "citation": {
                "source": "悶悶日記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
