  {
    "uuid": "0edc80c9-4a43-5ef7-9266-a8ef489655d4",
    "entry": "菜園",
    "reading": {
      "primary": "さいえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "vegetable garden",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "櫟林や麦畠や街道や菜園や、地形の変化に富んだその郊外は静かで清すがしかった。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘の菜園には、今日も余るほどの、陽光がそそいでゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ屋舎十の四、池水九の三、菜園八の二、芹田七の一、とあるので全般の様子は想いやられるが、芹田七の一がおもしろい。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "千九百八年十一月廿九日霜白き曉　　　　　　　　　　　　　　　　木下尚江三河島の菜園に於て",
              "citation": {
                "source": "小説「墓場」に現れたる著者木下氏の思想と平民社一派の消息",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども先生は其家を圍む幾畝かの空地を自から耕して菜園とし種々の野菜を植ゑて居ます。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜園の斜面よ、阪よ、風景は近く動けり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "風を祭る、菜園の斜面に祭る。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　この菜園でも、白い蝶のひらひらが低く、燕麦の穂から穂へわたっていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は何回となく立ち止まっては、これでちょっと気の利いた菜園用の小屋が作れると考えました。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの家の前にも円形に道を附けた、小い菜園がある。",
              "citation": {
                "source": "十三時",
                "author": "THE DEVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが三人とも前の菜園で豚の番をしてゐる。",
              "citation": {
                "source": "十三時",
                "author": "THE DEVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜園に飼つてある豚でさへ、此人を見るには目を側てて見る。",
              "citation": {
                "source": "十三時",
                "author": "THE DEVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時市の菜園に作つてあるキヤベツの頭が、皆腹を立てたやうに真つ赤になつた。",
              "citation": {
                "source": "十三時",
                "author": "THE DEVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "△中塚一杉――『菜園初秋』いりくんだ菜園を混沌もなく描き得てゐる日本画の本領の優れた点はかういふ時に良く現はれるといふべきだらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに、越中褌一つで、その前ごをキチンと三角にして、すっぱだかで菜園の中に立っている姿が、今も私の目の前に浮ぶ。",
              "citation": {
                "source": "私の父",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今日訪ねて来た医者のＭ氏は、応接室の窓越しに菜園の高棚にぶら下っている糸瓜を見つけて、さも感心したようにいった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが家の菜園の名なり。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なつかしい少年のこころに圓い、軟かな BALLのやるせなさ…………柚子の果が黄色く、日があかるく、さうして投げかはす BALL.　尿する和蘭陀人尿する和蘭陀人…………あかい夕日が照り、路傍の菜園には、キヤベツの新らしい微風、切通のかげから白い港のホテルが見える。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なつかしい少年のこころに圓い、軟かな BALL のやるせなさ…………柚子の果が黄色く、日があかるく、さうして投げかはす BALL.尿する和蘭陀人尿する和蘭陀人…………あかい夕日が照り、路傍の菜園には、キヤベツの新らしい微風、切通のかげから白い港のホテルが見える。",
              "citation": {
                "source": "思ひ出",
                "author": "抒情小曲集",
                "note": "青空文庫"
              }
            },
            {
              "text": "アトレの馬ではあるまいし鐘がならうがなるまいが子供のしつたことでなしうらの菜園の椎の木にザボンのやうな月がでた。",
              "citation": {
                "source": "どんたく",
                "author": "絵入り小唄集",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、東京の市内ではどんな大厦高樓を見てもついぞ好ましいと思つた事はないが、田舍で北に山を持ち、南に果樹園、菜園、田畑を持つた白壁の家を見ると、今は人手に渡つて住むべくもない生れ故郷の家屋敷がなつかしまれる、「業もし成らずんば死すとも歸らず」と言つて郷關を出たのだが、そも／＼業とは何であつたらう。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "故園　土蔵の跡の石に囲まれた菜園、ここは一段と高く、とぼしい緑を風に晒してゐる。",
              "citation": {
                "source": "画集",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "真夏になつてあの地方の小村を通りかかる人達は、そこらの農家の垣根だとか、菜園の片隅だとかいつたやうなところに、細かく群り咲いた白い花が、しなしなと風に揺られてゐるのを見かけるだらう。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうすれば海鼠の涎臭い臭みを嗅ぎつけて、昨日まで野菜の根を噛み、茎を傷つけなどしてゐた※鼠が、その菜園から逃げ出すといふ言伝へだつた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜園滿地の露のひそめき乎？",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜園満地の露のひそめき乎？",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでは時ならぬ菜園がアセチリンの光りを吸いながら、青々と街底の道路の上で開いていた。",
              "citation": {
                "source": "街の底",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜園の上からは白い一条の煙が立ち昇っていて、ゆるく西の方へ靡いていた。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより先にかついえ公は、きよすにおつきなされますとおくがたへお目どおりあそばされましてねんごろな御あいさつでござりましたが、そのゝち三七どのへみつ／＼におたのみなされましたとみえ、或る日三七どのおくがたの御殿へおこしなされましてかついえ公へ御さいえんの儀をおすゝめなされたらしゅうござります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれどもひでよし公へ御さいえんの儀は、じゃまがありましてもありませいでもまとまる道理はござりませなんだ。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
