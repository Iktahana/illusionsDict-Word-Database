          "literary": [
            {
              "text": "ロケ先、成城の田圃道へ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロケ先は多摩川で、メイコちゃんと釣りをしてるところ、川っぷちで寒いが陽当りよく風もないのでわりにいゝ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "八時起き、砧村のロケ先へ直行する。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロケ先は新宿の空地、バスの通るのを水町庸子と眺めるところ、此んなとこのロケは、ワイ／＼人が集るからやり切れない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
