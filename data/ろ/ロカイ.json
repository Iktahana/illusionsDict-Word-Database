[
  {
    "uuid": "100c1495-81b5-5e09-9ee0-b03637eeb064",
    "entry": "蘆薈",
    "reading": {
      "primary": "ろかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
