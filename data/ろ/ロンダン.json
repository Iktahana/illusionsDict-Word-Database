    "definitions": [
      {
        "index": 1,
        "gloss": "conclusion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この二つの場合のどちらが蓄音機のレコードに適するかを一般的概念的に論断するのは困難ではあるまいか。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはこの表題の示すごとく、日本国語の根源が南洋にある事を論証し、従って国民祖先の大部分もまた南洋から渡来したものだと論断しようとするものである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論断ったが、十八にも成ってと嘲けられたのがぐっと胸に来て登楼った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、ただこの絵本の絵に依つて、論断せざるを得ないのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一たび此論断を肯つたとき、彼等は彼等の主観のうちに、又彼等の理想のうちに、彼等の平素排斥しつゝあるが如く見ゆる諸の善、諸の美、又もろ／＼の壮と烈との存在を肯はねばならぬ。",
              "citation": {
                "source": "文芸とヒロイツク",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに就いて理学博士小川琢治氏も、次のやうに論断してゐるやうである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し余が難じたるは、（１）世を益するの目的を以て、（２）英雄の剣を揮ふが如くに、（３）空の空を突かんとせずして、或｜的を見て、（４）華文妙辞を退けて、而して人生に相渉らざるべからずと論断したるを難じたるなり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この論断には君も吹き出すだろうと思うね。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "――麻布からは大抵の苦労じゃない、勿論断る法はありません。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初にヨブの子らの死を以て罪の結果のみと一挙に論断し去る如きは、相手の心を少しも察せざる無分別の言といわねばならない。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論断言は出来ませんが、持物でも調べれば直ぐ判るでしょう。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論断言は出来ませんが、持物でも調べれば直ぐ判るでせう。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "某大家に対しても、未だ会わぬ中は多少の敬意を有っていたけれど、一たび其人の土気色した顔が見え、襟垢が見え、襁褓が見えて想像中の人が現実の人となると、木地の吾が、貧乏だから下らんと、別天地では流行せぬ論法で論断して之を軽蔑して了ったのだ。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち一般に自然科学が「現段階的には階級性を有たないと論断」することは出来ない。",
              "citation": {
                "source": "再び「科学の歴史的社会的制約」に就いて",
                "author": "――岡邦雄氏に答える――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　以上は松田氏が柏軒の癸亥七月十九日淹京中の死を以て所を得たものとする論断である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "松田氏の精確なる記性と明快なる論断とが微つたなら、わたくしは或は一堆の故紙に性命を嘘き入るゝことを得なかつたかも知れない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論私は、日本の新陣営の作家を悉く、バルザックやツルゲネーフなどと比較して論断するの意はない。",
              "citation": {
                "source": "性格を求む",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルストイの「戦争と平和」に、構想の欠乏――「母線」を見る明の欠乏――を難じ、事実の堆積に過ぎないと論断することは、或は至当であろう。",
              "citation": {
                "source": "文学以前",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはこれは私が「母性の国庫保護説」を主張される女史たちに対して「短見者流」という評語を加えたることに由って憤激されたのかも知れませんが、女史たちの主張が短見であり幻想であることは、一条忠衛氏が本年一月の『六合雑誌』で明晰に論断しておられます。",
              "citation": {
                "source": "婦人改造の基礎的考察",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、その曲折紛糾奇異を超絶した状況から推しても、しだいに、伸子の失神を犯人の曲芸的演技とする点に綜合されてゆくけれども、しかし、公平な論断を下すなれば、依然として紙谷伸子は、ただ一人の、そして、最も疑われてよい人物であることは勿論である。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に商業会議所会頭某｜男爵のごときは大体｜上のような意見と共に、蟹の猿を殺したのも多少は流行の危険思想にかぶれたのであろうと論断した。",
              "citation": {
                "source": "猿蟹合戦",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば有機体とのアナロギーに依つて、社会に目的関係の存在することを論断しようと云ふのは、むしろ正当な論理的順序に逆行するものではないでせうか。",
              "citation": {
                "source": "消息一通",
                "author": "一九二四年一月一日　マールブルク",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は、これを日本固有の武士道による外はないと論断した。",
              "citation": {
                "source": "手巾",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（「明治の作家」――〔美妙斎美妙〕」）と言ひ切つたこの論断と、自分の古い記憶に残つてゐる美妙斎の作品の印象と、さらに本間氏の明治文学史に詳細な説明をしてゐられるのとを思ひ合せて見て、改めて美妙斎の新文体のよつて来る所以が明白になつた感がされる。",
              "citation": {
                "source": "言文一致",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長と教頭はさうだらう、新聞屋が学校に恨を抱いて、あんな記事をことさらに掲げたんだらうと論断した。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長と教頭はそうだろう、新聞屋が学校に恨みを抱いて、あんな記事をことさらに掲げたんだろうと論断した。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代文学は皆この弊に陥っているとは無論断言しませんが、いろいろな点においてこの傾向を帯びていることは疑いもないと思います。",
              "citation": {
                "source": "文芸の哲学的基礎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、朝から晩まで気骨を折って、世の中に持て囃されたところで、どこがどうしたんだという横着は、無論断わる時からつけ纏っていた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処に、永久に論断を下すことの出来ない仮説を申してみると、天照大神も最高至尊の地位にあらせられた、女神である。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程、シェイクスピイヤなり、イプセンなりは、学問的には相当に研究もされ、理解もされたらうが、劇作家として、殊にそれらの戯曲がもつ「劇的美」そのものについて、一度でも解剖的に、主題と結構と文体とを、それぞれの有機的関係から分離して、論断した者があるか。",
              "citation": {
                "source": "対話させる術",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
