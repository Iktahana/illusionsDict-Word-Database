[
  {
    "uuid": "00066ce2-12ca-501b-82d8-2bdc09c455eb",
    "entry": "老朽",
    "reading": {
      "primary": "ろうきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
