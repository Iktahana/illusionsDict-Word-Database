    },
    "definitions": [
      {
        "index": 1,
        "gloss": "infirmity (due to old age)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "實に今日の老廢した、あまりに老朽衰廢した日本の既成文壇で、芥川君の如く「若さに充ちてゐる」作家はない。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずまた火山の噴出は植物界を脅かす土壌の老朽に対して回春の効果をもたらすものとも考えられるのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……また、忘れるために、その上、年に老朽ちて世を離れた、と自分でも断念のため。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉山　窈くして而して深し、性を養ひて　老朽を甘んず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "（下略）　嘯詠寒山に擬すの句は、此老の行為に照せば、矯飾の言に近きを覚ゆれども、若夫れ知己に遇わずんば、強項の人、或は呉山に老朽を甘んじて、一生｜世外の衲子たりしも、また知るべからず、未だ遽に虚高の辞を為すものと断ず可からず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "対手は老朽ちたものだけで、年紀の少い、今の学校生活でもしたものには、とても済度はむずかしい、今さら、観音でもあるまいと言うようなお考えだから不可んのです。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――老朽の准訓導でさ。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "法海和尚は「今は老朽ちて、験あるべくもおぼえ侍らねど、君が家の災を黙してやあらん」と云って芥子の香のしみた袈裟を執りだして、「畜をやすくすかしよせて、これをもて頭に打被け、力を出して押しふせ給え、手弱くあらばおそらくは逃去らん」と云った。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は義雄と同じ學校の漢學講師であつたが、老朽の爲めにやめられた後、郷里の田地を融通して、谷町に二三の借家を建てた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、これを私の老朽のせいとも、行詰まりのせいとも思いたくありませぬ。",
              "citation": {
                "source": "スランプ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや老朽だ」といいふらしていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "年月と老朽からくる匂いが、崩れかかった建物全体に充溢していた。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ我々に取っては、これを渡初めした最年長者より、もっと老朽ちた橋であるから、ついこの居まわりの、砂利場の砂利を積んで、荷車など重いのが通る時は、埃やら、砂やら、溌と立って、がたがたと揺れて曇る。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "老朽の教師の俸給で七人の糊口は容易なことでないのだから到底好な酒までには及ばないのである。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "覆ひのビロードには金の糸よりも、雨洩りの痕の唐草模様の方が鮮やかであり、ゼンマイの工合も余程鈍つて、「アイ・アイ・アイ」などをかけると、オルゴールが自分の老朽を嘆いてゐるやうでおもしろくなかつた。",
              "citation": {
                "source": "幽霊の出る宮殿",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "総領は児供の時から胆略があって、草深い田舎で田の草を取って老朽ちる器でなかったから、これも早くから一癖あった季の弟の米三郎と二人して江戸へ乗出し、小石川は伝通院前の伊勢長といえばその頃の山の手切っての名代の質商伊勢屋長兵衛方へ奉公した。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、まだ老朽船と云うほどでもない北海丸が、秋口の時化とは云え、何故そんなに激しい浸水に見舞われたのか、それは当の沈没船から発せられた信号によってさえも、聞きとることは出来なかった。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は近頃ラムの『エッセー・オブ・エリヤ』を取り出して、「老朽者」という一文を読んだ。",
              "citation": {
                "source": "或教授の退職の辞",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十ぐらいの平田という老朽と若い背広の関という准教員とが廊下の柱の所に立って、久しく何事をか語っていた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の老朽教師の低い蜂のうなるような活気のない声にくらべては、たいへんな違いである。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の面積の極めて広大なるに比して、高さが前記の如くであるから、一寸見には、根からダラシの無い、不恰好な、何処に主峰があるかさえ分らぬ草山で、云わば火山中の老朽者と云う位置であるが、登って見て、何処までも奥行の知れぬ広さが、他の佶屈な少壮火山（形から見立てて）と異なったよい感じを与える。",
              "citation": {
                "source": "女子霧ヶ峰登山記",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては老朽してもさすがはまだ職に堪えるものか、しかし日本服でも勤められるお手軽なお身の上、さりとはまたお気の毒な。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが骨肉の老朽を自ら感じる者等は活力に溢れ、日々の冒険で世界を拡張させて行く者共に、絶大な期待と信任を覚えたに違いない。",
              "citation": {
                "source": "われを省みる",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や、旧社会は其の繁栄の絶頂を超えて、既に老朽の坂を降りつつある。",
              "citation": {
                "source": "新しき世界の為めの新しき芸術",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生舞台の上で花を咲かせる時もなく老朽ちてしまったような俳優がその座敷の床の間の花を活けるために、もう何年となく通って来ているということまで岸本は知っていた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一階建のところもあれば、二階建になっているところもあって、必らずしもその老朽を防ぐよすがにはなりそうもない黝んだ屋根の上には、二つの展望台が相向いにニュウと突っ立っているが、どちらも曾ては塗ってあった色の跡形だになく、今はもうぐらぐらになっている。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "下人部屋だの、納屋だの、穴倉だのといった、明らかに老朽した建物の群れが前庭を満たしており、その両側には右と左に別の庭へ通ずる門が見えている。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でももう老朽の英語の先生だそうで、どこでも傭ってくれないんだって云いますから、大方暇つぶしに来るんでしょう。",
              "citation": {
                "source": "毛利先生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "学者をして学問の貴きを説かしめたらば、政事の如きは小児の戯にして論ずるに足らざるものなりといい、政事家もまた学問を蔑視して、実用に足らざる老朽の空論なりとすることならんといえども、これはいわゆる双方の偏頗論にして、公平にいえば、政事も学問もともに人事の至要にして、双方ともに一日も空しゅうすべからず。",
              "citation": {
                "source": "学問の独立",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる翹望が窒息しない間は、大都市も老朽しないであろう。",
              "citation": {
                "source": "風俗時評",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
