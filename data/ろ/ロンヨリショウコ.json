    "definitions": [
      {
        "index": 1,
        "gloss": "the proof of the pudding is in the eating",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
