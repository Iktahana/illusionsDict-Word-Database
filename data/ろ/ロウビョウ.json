[
  {
    "uuid": "1a8c8bb8-f4c1-5b09-95a9-a7a079e875f8",
    "entry": "老病",
    "reading": {
      "primary": "ろうびょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "infirmities of old age",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "生老病死の姿を採りながら一筋に燃えて居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生老病死の恐れなく、いつも生れたての赤児のように新らしくある聖なる花嫁！",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度彼の世界で浄められたお前達の心は再びもとの世界に降って恋にも入り愛にも入り、生老病死にも同化して現実の煩悩を内面より荘厳する時節あるを忘れてはならぬ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大坂陣の時は老病の床に在ったが、子の重綱に対って、此戦は必ず一度和談になって、そして明年に結局を見るだろう、と外濠を埋められてから大阪が亡びるに至るだろうことを予言した片倉小十郎と共に実に伊達家の二大人物であった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "不死不朽、彼と与にあり、衰老病死、我と与にあり。",
              "citation": {
                "source": "一夕観",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "最早某が心に懸かり候事｜毫末も無之、ただただ老病にて相果て候が残念に有之、今年今月今日殊に御恩顧を蒙り候松向寺殿の十三回忌を待得候て、遅ればせに御跡を奉慕候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その肝心の極楽へ来て見ると、如何にも苦も悲しみもない、老病生死の厄もない。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "老病死の解決を叫んで王者の尊を弊履のごとくに捨てられた大聖｜釈尊は、そのとき年三十と聞いたけれど、今の世は老者なお青年を夢みて、老なる問題はどこのすみにも問題になっていない。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "藏の傭人の爲に抱へてある醫者に見て貰つても、老病だから藥を飮んで見た處で、さう效驗が見えるのではないがそれでも、飮みたけりや飮むが善いといふのみで別段身に沁みていつてくれるのでもない。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其頃兼次の家では婆さんが長らく老病に罹つて居た。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが世界はどんなに進化しても、老病困厄は絶えない。",
              "citation": {
                "source": "妄想",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "『池北偶談』二六に、〈釈典に三必死あり、いわく人の老病、竹の結実、騾の懐胎、しかるに康熙某年、旗下人の家に、騾ありて子を生みついに恙なし〉。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その出所について問い合わせたが氏既に老病中で明答を得ず。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "生老病死の諸苦、性格の欠陥、あらゆる失敗、それを十分に噛みしめて見ればそれでいいのだ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の両親はもう、三個月ばかり前に老病で相前後して死んでいた。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "其年の春、祖母は老病で死んで了つたが、此年ほど藤田家に取つて運の悪い年は無かつたので、其初夏には、父親が今年こそはと見当を付けて、連年の養蚕の失敗を恢復しようと、非常に手を拡げて養つた蚕が、気候の具合で、すつかり外れて、一時に田地の半分ほども人手に渡して了ふといふ始末。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "老病で死にかゝつた時、枕もとに媼さんを呼んで言つた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の中ごろに年取った伯母の老病を見舞いに行った母親は、そのころまでも伯母の傍に附いていた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "生老病死は無常なる人生における現実である。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "臣年六十一而シテ老病日ニ迫ル。",
              "citation": {
                "source": "直訴状",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "生老病死は哀別離苦と共に必ず僕等を苦しめるであらう。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "啻に出産老病の一事のみならず、人間の子にして父母を親しみ父母を慕い、父母にして子を愛し子を親しむは、天性の約束なるに、女子が他家に嫁したればとて、実の父母を第二にして専ら舅姑の方を親愛し尊敬して孝行せよとは、畢竟出来ぬ事を強うるものと言う可し。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくする間に、その年の十二月十五日に、惠果阿闍梨は老病を以て遂に入寂された。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "老病について岸田國士　内科の医者である私の友人Ａは先日面白い話をきかせてくれた。",
              "citation": {
                "source": "老病について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時弟の淡路守後基を招きよせて、「わしはもう老病で遠くはあるまい。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "長年かかりつけの桑島先生が老病で世を去ったのもやはりその頃であった。",
              "citation": {
                "source": "寐顔",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚の黄色い紙片、母の手紙――失業と放浪と病気と老病の愚痴とそしてほんとの子供のように愛してゐる二十三の自分への信任と――僕は不愉快げに二人の視線をさへぎった「母！",
              "citation": {
                "source": "長詩",
                "author": "バイロン・ハイネ――獄中の一断想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し我国古来、老病者遺棄の忌む可き風習の存ぜしことは、明かに正史の証する所なり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姨捨」の、文字が、この風習の存在の記臆と結合して、彼山に老病者を棄てしとの説話を生じ、之によりて山名の起原を説明するに至りしなり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（つづけてよむ）いかなるちしき上人、そのかみ、しゃか仏ほどのにょらいも、五体に身を受けたまえば、やまいのくるしみ、しょうろうびょうしとて、なくてかなわぬ物にて候。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
