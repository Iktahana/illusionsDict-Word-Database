[
  {
    "uuid": "b9324431-993f-531a-9941-91c79bc51064",
    "entry": "浪費",
    "reading": {
      "primary": "ろうひ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞",
