    "definitions": [
      {
        "index": 1,
        "gloss": "sleeping outdoors",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
