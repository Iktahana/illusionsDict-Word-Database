    "definitions": [
      {
        "index": 1,
        "gloss": "Roman Catholic Church",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
