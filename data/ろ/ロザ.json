    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sitting in the open air",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大日堂の裏手より裏見の滝へとこころざす。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから毎日日のさす所へとこころざして、市の公園へ跛を引きながら往つて、菩提樹の下のベンチに腰を掛ける。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "林をきたなくせまいとの、そのおこころざしはじつに辱けない。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『これは右手指といって、こういう具合にさすので、』かれは短刀を拾って後ろざまに帯にさした。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こころざしは受けますが、三宝にのったものは、あとで、食べるのは、あなた方ではありませんか。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "林をきたなくせまいとの、そのおこゝろざしはじつに辱けない。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――鬘ならではと見ゆるまでに結なしたる圓髷に、珊瑚の六分玉のうしろざしを點じた、冷艷類ふべきなきと、こゝの名物だと聞く、小さなとこぶしを、青く、銀色の貝のまゝ重ねた鹽蒸を肴に、相對して、その時は、雛の瞬くか、と顏を見て醉つた。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高綱　　今日はこゝろざす佛の命日。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀才、はざま貫一、勉学を廃止して、ゆたかな金貸し業をこころざしたというテエマは、これは今のかずかずの新聞小説よりも、いっそう切実なる世の中の断面を見せて呉れる。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきに文豪をこころざして、失敗して、そのとき第一の通信。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして革命家をこころざしてからは、文學のブの字も言はせぬこと。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして革命家をこころざしてからは、文学のブの字も言わせぬこと。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾時、御新姐の顔の色は、こぼれかかった艶やかなおくれ毛を透いて、一入美しくなったと思うと、あのその口許で莞爾として、うしろざまにたよたよと、男の足に背をもたせて、膝を枕にすると、黒髪が、ずるずると仰向いて、真白な胸があらわれた。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、硝子を飛び、風に捲いて、うしろざまに、緑林に靡く煙は、我が単衣の紺のかすりになって散らずして、かえって一抹の赤気を孕んで、異類異形に乱れたのである。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……心中を仕損った、この人の、こころざし――　私は門まで遁出したよ。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝ムッチェンのかたをこころざしてここを立ちぬ。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは航海者がこゝろざす港に著くと、船の小使に遣つてしまふ。",
              "citation": {
                "source": "長谷川辰之助",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山岸はわたしと同じ下宿屋に住んでいるという以外に、特別にわたしに対して一種の親しみを持っていてくれるのは、二人がおなじ職業をこころざしているのと、わたしが先輩として常に彼を尊敬しているからでした。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は籠の内なる丸の有らん限を我頭に擲げ付け、續いて籠を擲げ付けしに、われ驚きて跳り下るれば、車ははや彼方へ進み、和睦のしるしなるべし、娘のうしろざまに投じたる花束一つ我掌に留りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "飽くまで潔き人のこゝろざし、恨を殘さずとは斯くても吾を憎み給はぬ情けと知らる。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "太平の夢を破られた江戸市中には、武芸をこころざす者が俄かに殖えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はこころざしの高い人物として、湘楚のあいだに知られて居りましたが、山林に隠れて富貴栄達を望みませんでした。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "後生でございます」「うるさい」と佐渡は後ろざまに蹴った。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕雀いずくんぞ大鵬のこころざしを知らんと、昔の陳勝呉廣も云っているのだ。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角のおこゝろざしだが、兄きに代つておれが斷るから、こんなものは持つて歸つて貰ひてえ。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく考へてみると、成程こりやあ八の云ふ通りで、折角のおこゝろざしは有難てえが、どうもおまへさんからこんな物を貰ひたくねえ。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに学問ばかり秀でようとも、根本のこころざしが邪道にねじけておっては詮ない。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのこころざしの嬉しさに、再び昔の形を見せまする」　寒月に照らされた彼女は、むかしのように光り輝いていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
