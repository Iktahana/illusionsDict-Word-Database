    "definitions": [
      {
        "index": 1,
        "gloss": "young man",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その旅館（湯本館）には尾崎士郎君の夫妻が居た。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　亀井勝一郎君からも手紙をもらった。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅忠太郎君は、私と大学が同期で、けれども私のように不名誉な落第などはせずに、さっさと卒業して、東京の或る雑誌社に勤めた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君の厳父には、私は未だお目にかかった事は無いが、美事な薬鑵頭でいらっしゃるそうで、独り息子の忠太郎君もまた素直に厳父の先例に従い、大学を出た頃から、そろそろ前額部が禿げはじめた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいま友人、大隅忠太郎君から、結納ならびに華燭の典の次第に就き電報を以て至急の依頼を受けましたが、ただちに貴門を訪れ御相談申上げたく、ついては御都合よろしき日時、ならびに貴門に至る道筋の略図などをお示し下さらば幸甚に存じます、と私も異様に緊張して書き送ってやったのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "数日後、大隅忠太郎君は折鞄一つかかえて、三鷹の私の陋屋の玄関に、のっそりと現われた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷崎潤一郎君と始めて逢つたのも此所であつた。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "和辻哲郎君がまだ京都にいた頃のことである。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の歳末にその天野君と落合太郎君と私とで寒い晩に四条通の喫茶店へ茶を飲みに行ったことがある。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをひねくり廻している矢先へ通りかかったのが保険会社社長で葬儀社長で動物愛護会長で頭が禿げて口髯が黒くて某文士に似ている池田庸平事大矢市次郎君である。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが彼にはひどく自慢であつたが、或る日毒舌家の尾山篤二郎君が訪ねて來て、「何だそりやあ。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷崎潤一郎君が訪ねて來て、ミカン箱の本箱を見て吃驚し、「詩人といふ奴は、妙なことをするものだなあ！",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梶井基次郎君は、日本の現文壇に於ては、稀れに見る眞の本質的文學者であつた。",
              "citation": {
                "source": "本質的な文學者",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時僕と一所に、同じ「創作」に詩を書いてゐた人々は、室生君の外、白鳥省吾君、山村暮鳥君、中川一政君、吉川惣一郎君等であつたが、この内で吉川惣一郎君と室生犀星君とが、最も數多くの詩を毎號書いてゐた。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の父が出て來てみると、見知らぬ薄汚ない風采をした、一見乞食坊主のやうに見える男が――と父は後に僕に話した――横柄にかまへて「朔太郎君は居ますか」と言つたので、てつきり何かの不良記者かゆすりの類と考へ、散歩中の不在を幸にして、すげなく追ひ歸してしまつたさうだ。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡本君の人物評は、前に萩原恭次郎君等に好評を聞いてゐたので、この場合彼が私の敵に立つとは思はなかつた。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "松雲閣の玄関からそのまゝ事務所へ廻りみちして支配人の福地第三郎君に会った。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう次第であるから、わが国で、鈴木清太郎、藤原咲平、田口※三郎、平田森三、西村源六郎、高山威雄諸氏の「割れ目の研究」、またこれに連関した辻二郎君の光弾性的研究や、黒田正夫君のリューダー線の研究、大越諄君の刃物の研究等は、いずれも最も興味ありまた有益なものである。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また未発表ではあるが池田芳郎君の注意されたガラス管の内部的｜歪による破壊の現象などもこの部類に属するもので、そこにもおもしろいわれ目の週期性が現われるのである。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これについては前に鈴木清太郎君の研究がある。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の疎開していた町から、汽車で三、四時間、或る港町の駅に降りると、小川新太郎君は、りゅうとした背広服姿で、迎えに来ていた。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と襖のかげから、女のひとが、新太郎君を呼んだ。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると三郎が、「吉郎君、きみは上流から追って来るんだよ。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白亜の洋館に行き養魚の有様を見んと訪えば、ここに偶然にも、僕の旧知、法科大学生｜福田甚二郎君がいて、種々養魚上の説明をしてくれ、ここの所長をしている谷口利三郎氏も出て来られて、雨中に学術上の説明をしてくれた。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "水戸の有志家｜杉田恭介君、川又英君、及び水戸中学出身の津川五郎君で、孰れも健脚御自慢、旅行は三度の飯より好きだという愉快な連中だ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "市郎君は色男だ、柳屋の女が大層チヤホヤしていたと……。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、市郎君、この夏も君と※に就て種々と研究した事があったじゃないか。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に檳郎君にお詑します。",
              "citation": {
                "source": "雑信（二）",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "』出勤際に、鏡台へ向って、紳士の身躾をほどこしていた文太郎君が、突然叫びたてました。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
