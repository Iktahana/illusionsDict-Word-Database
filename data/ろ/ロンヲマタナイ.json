          "literary": [
            {
              "text": "最善の法が共産なることは論を待たない。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから一番結構な名誉職を持つてゐる大時計の番人が尊敬せられることは論を待たない。",
              "citation": {
                "source": "十三時",
                "author": "THE DEVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "藐姑射山人は荘子から出てゐること論を待たない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "商業的にもっとも成功したのがマイクロソフトであることは論を待たないが、同社が何から何までをやってくれたわけでないことは、あらためてそんなことを口にするのも馬鹿らしいほど明らかである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに度々細かい技術を要するのであるから、これが中小品に適するのは論を待たない。",
              "citation": {
                "source": "樺細工の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "メアリが不幸に立ち向かうことは論を待たない。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
