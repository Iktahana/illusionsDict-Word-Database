          "literary": [
            {
              "text": "尤も老人病弱者にても若し肉食を嫌うものがあればこれに適するような消化のいい食品をつくる事に就ては私共只今充分努力を致して居るのであります。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人病と言へば第一に動脈硬化があげられるであらう。",
              "citation": {
                "source": "老病について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは特に老人（典型的な老人病）や障碍者や不摂生者のように循環が活気の無いものの病気である。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年、老人病學なる醫學がアメリカで流行り出し、それがわが國にも傳染して來た。",
              "citation": {
                "source": "老人退場説",
                "author": "山浦貫一",
                "note": "青空文庫"
              }
            },
            {
              "text": "安んじて天壽を完うせしめよ　老人病學の對象と云えば、高血壓にガンが兩大關だろう。",
              "citation": {
                "source": "老人退場説",
                "author": "山浦貫一",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、老人病學は富者の獨占になる。",
              "citation": {
                "source": "老人退場説",
                "author": "山浦貫一",
                "note": "青空文庫"
              }
            }
          ]
        }
