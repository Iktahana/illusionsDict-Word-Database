        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "魚の梱包部屋はもう不要となり、炉壁は冷えて、鳥たちがひさしに巣を作っている。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓は楓枠に曇りガラス、暖炉壁には二人の女羊飼いが描かれて装飾されており、経過年月は途方もない。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子は僕のところへきて、股引佩かないでもよい様にお母さんにそう云ってくれと云う。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、お姫さまは、森の中の、どろどろした広いところへきました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「失礼ながら『基督教青年』は私のところへきますと私はすぐそれを厠へ持っていって置いてきます。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに遠くの空からとんで来て、私の家の屋根の、とんがりのところへきて、一二度くるりと輪を画き、太くたくましい足を、充分に宙にのばしてから、その目的物である私の屋根の上に立つ、そして二三度、黒くつや／＼とした体を、上下にゆり動かしてから、落ついたみなりとなる。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかむずかしいところへきたとみえる。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハムレットがオフェリヤに向かって、尼寺へ行け尼寺へ行けと言うところへきた時、三四郎はふと広田先生のことを考え出した。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝの主人は小松｜三香と云ひ、将棋は四段であつたが、ある日、わたしがたづねて行くと、「ちやうどいゝところへきた。",
              "citation": {
                "source": "駒台の発案者",
                "author": "関根金次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び交う数字と一種名状すべからざる緊張した熱意で飽和している空気の中をそっと、一人の婦人党員が舞台から日本女のところへきた。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は黙ってイヤイヤしていたが、女があまり云うとベンチのところへきて、低い声で然しきっぱり云った。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三〇年の暮にモスク※から帰って、三一年のはじめプロレタリア文学運動に参加した当時の作者の心理は、自分にとって古典である「伸子」を、過去の作品としてうしろへきつく蹴り去ることで、それを一つの跳躍台として、より急速な、うしろをふりかえることない前進をめざす状態だった。",
              "citation": {
                "source": "あとがき（『二つの庭』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "繁野君というのは、こんどおとなりの本田さんのところへきた子どもで、おとうさんと、おかあさんと、ねえさんと四人で満州の奉天からもどって来たのです。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、ホーベス、いいところへきた、早く舟に乗れ」　ホーベスは、だまって海蛇に近づいた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のところへきて犧牲を出せとお求めなすつたことは一度もない。",
              "citation": {
                "source": "『人形の家』解説",
                "author": "島村抱月",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰ってからも丈夫でさえ居るんならどこに居たってかまわないとは思うけれ共何となく不安心なあの人の身の上に変った事が起ったんじゃああるまいかと思われた、思い出すとやたらに気になって翌日も翌日も幾日頃帰りますって伯父さんのところへききに行った。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、用意よしの返事が大将のところへきた。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のところへきた人がむしろ虫の声に近いねというふうに、スズムシのような声で鳴く。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな難路をわざ／＼降りて水浴にくる娘達の気が知れないが、然し、愈々水面の見えるところへきて、下の方にひつそり澱んだ深い色を見たときには、なるほどさすがに修吉も、ちよつと疲れを忘れるやうな気になつた。",
              "citation": {
                "source": "木々の精、谷の精",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、その白い花崗岩のはげは、窓のところへきて寝ころぶと、前の木の枝の中にある。",
              "citation": {
                "source": "山と雪の日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "猟師の庄吉さんも、この窓のところへきて、煙草をのみながら話をする。",
              "citation": {
                "source": "山と雪の日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまちみんなが留っているところへきた時はとても止らない。",
              "citation": {
                "source": "五色温泉スキー日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "名人位がひつくりかへるといふ終盤の勝負どころへきて、全く間髪を入れず、スースースーと駒が一本の指に押へられて横へ前へすべつて行く。",
              "citation": {
                "source": "散る日本",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は、なんの用があって、こんなところへきたんやろ」　牛丸平太郎も不思議そうな顔をしている。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして、こんなところへきたのかね」　老探検家は、健康色の顔に、ほおえみを見せて、テッド博士にきく。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしにこんなところへきたか」　そのガン人は、三根夫を知っていた。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまがつぱを　ぬいだ　おとこのこ　と　ちひさな　おんなのこが　ガラスまどの　ところへきて　いひました。",
              "citation": {
                "source": "あめくん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は素子の性格を解剖するところへきた。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネズミの足あとなどは、まるでゆうびん切手のミシンの線のようにきれいにこまかく、てんてんてんてんとつづいて、さいごに小屋のえんの下のところへきている。",
              "citation": {
                "source": "山の雪",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいどうしてこんなところへきたのか。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
