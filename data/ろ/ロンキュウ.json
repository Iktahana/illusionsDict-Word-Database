[
  {
    "uuid": "e5ab139c-9f85-501b-97a2-641798d5b581",
    "entry": "論究",
    "reading": {
      "primary": "ろんきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
