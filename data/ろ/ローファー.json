          "standard": [],
          "literary": [
            {
              "text": "そろいのローファーとか？",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ローファーなんか買わないよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒と茶の二足のローファーと、ウィングチップまでもってる奴に、あんなイヤミはむだだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "金ボタンの紺のブレザー、紺のボウタイ、タータンチェックのスカート、白いハイソックス、茶のローファーというかっこうの令子は、母親にうながされ、玄関のほうに足を向けた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、私がローファーなのは決して、淋しい想像で考えて下さらずとよい。",
              "citation": {
                "source": "初夏（一九二二年）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方散歩に出、切角のろのろと心持よく歩いて居たら、いやなローファーに会い心持を悪くしてしまった。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
