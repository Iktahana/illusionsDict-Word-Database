  {
    "uuid": "1d52c7d0-3618-56ad-83a4-ff55991cbec1",
    "entry": "ロト",
    "reading": {
      "primary": "ロト",
      "alternatives": [
        "ロット"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lottery",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　弟はまたトロトロ帰つて行つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは仲間に入れてもらえなかった人の怨恨によるともいわれ、またクロトンの市民等がピタゴラス一派の権勢があまり強すぎて暴君化することを恐れたためともいわれている。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "司令官、兵ニ破ッタ始末書ヲ渡シ、海ヘ捨テロト云フ　兵室ヲ出ル、消灯ラッパ聞コエル　兵戻ッテ来ル　司令官「遅レタ罪ダ」ト兵ヲ叱ル。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲ハ経紙ノ紺ニ暮レ、　　　　　樹ハカグロナル山山ニ、梢螺鈿ノサマナシテ、　　　　　コトトフコロトナリニケリ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者は集積し凝縮し電子となりプロトーンとなり、後者は一つにかたまり合って全能の神様になり天地の大道となった。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年に至って原子は電子とプロトーンによって置き換えられ、ごくごく最近に波動力学の出現によってこれら物質的素量に関する観念に始めて目立った変化をきたしつつある。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台の何処かで眼に見えない鬼火がトロトロと燃えているような……ソンナ時のスゴイこと……。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう意味において映画というものの一つのプロトタイプとでも言わるべきものは絵巻物の類である。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して壁際のガラス張りの棚の中から、ミクロトームのメスを取り出して剃刀砥にかけ始めた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝、妻を解剖する可否を兄と論じながら、彼れが自信と興味とに心ををどらして、殘りもなく準備したミクロトーム、染色素、その外のものゝきちんと一つの机の上に列べてあるのが、積み重ねられた枯枝のやうに今の彼れには見えた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おキレの角はケンケンケン　ばけもの麦はザランザララ　とんびトーロロトーロロトー、　鎌のひかりは　シンシンシン。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フィーガロ、フィガロト、フィガロット。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィーガロ、フィガロト、フィガロット。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "オンナジヤウナ　カタチヲ　シテ　ヰテモ、フエナンカ　ピロ　ピロト　ナクダケヂヤ。",
              "citation": {
                "source": "カナヅチ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――俺のやうな耄碌を捕まへてからに、ヘルバロトが何うの、ペスタ何とかが何うの、何段教授法だ児童心理学だと言つたところで何うなるつてな。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日の午前中、ロトゥアヌウからの砲声が我々を脅した。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "出がけに見ると、家の入口の左右に、黄と紅と紫との鮮やかなクロトンの亂れ葉が美しく簇つてゐた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "出がけに見ると、家の入口の左右に、黄と紅と紫との鮮やかなクロトンの乱れ葉が美しく簇っていた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "魂が見る間にトロトロと溶けた二人は、腰の蝶番が外れたらしい。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子窓が深夜にワナワナとふるえるようなポーのペンに対して、眼の球が白昼にトロトロと流れ落ちるような乱歩氏の筆が対立している事を初めて知ったのでした。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今日になって考えてみると、先生自身もやはりその男の中に、一つのプロトタイプを認められたのではなかったかという気もするのである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば年を取つた方の尼さんが、丁度ソドムでのロトの妻のやうに、振り上げた手に蝙蝠傘を持つて、凝り固まつたやうに立つてゐて、しやがれた声で繰り返すのです。",
              "citation": {
                "source": "尼",
