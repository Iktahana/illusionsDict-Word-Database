    "definitions": [
      {
        "index": 1,
        "gloss": "satisfactory",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして自分にも碌に分らないような事をいい加減に教えていると、次第々々に自分が堕落して行くような気がすると云っていたが、一年ばかりでとうとう止してしまった。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "登山の準備をしたくも、碌なものがないところで、この節の日本アルプスの登山口の、設備の方が、よほど行き届いているくらいだから、その貧弱さの、見当がつくであろう。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことを考える時ゃ碌な事あねえんだ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の会など、見ているうちに何だか少しむっとするような気がして来てとうとう碌に見ないで帰って来て、それきりもう二度とは入場しなかったくらいである。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは耄碌と云われても仕方がない。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべは碌々に眠らなかったお徳は、早朝から店をあけて亭主の帰るのを待っていたが、藤吉はやはりその姿をみせなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "七之助はまるで気抜けがしたようにぼんやりとして、隅の方に小さくなっているばかりで碌々口も利かなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、てめえの挙げて来るのに碌なことはねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし達が子供のときに何か取留めのない化物話などを始めると、叔父はいつでも苦い顏をして碌々に相手にもなつて呉れなかつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小幡はお春を賺して色々に問ひ糺したが、年弱の三つでは碌々に口もまはらないので些つとも要領を得なかつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "後悔と心配とでお道も碌々に眠られなかつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かずかず列べられた見事な御料理にも彼女は碌々箸をつけなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "まげて御承知くださるように重ねておねがい申します」「娘はゆうべ帰りまして、それからなんだか気分が悪いとか申して、きょうも一日｜臥って居りますので、まだ碌々に相談いたす暇もございませんで……」　お亀は一寸｜遁れの口上で、なんとか此の場を切り抜けるつもりらしかったが、相手はなかなか承知しなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "碌に旅行という程の旅行を仕た事も無いのですもの、御談し仕度くっても是といって御談し申上げるような事も有りません。",
              "citation": {
                "source": "旅行の今昔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに、疑いもなく、これは耄碌の姿でないか。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "碌な本は在りやがらねえ……といったような恰好で悠々とバットの煙を輪に吹きながら出て行くんだから大した度胸でげす。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頭の頼うだ御方の背広に耄碌頭巾と調子を合わせたものであろう。",
              "citation": {
                "source": "お茶の湯満腹談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……余子碌々……おいおい貴様たちは何んとか物をいえよ、俺にばかりしゃべらしておかずに……園、貴様惚れろ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃は虫あつかいに、碌々食うものも食わせ無えで置いて、そんならって虫の様に立廻れば矢張り人間だと仰しゃる。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してそれはもうお末に対してゞはなく、兄が家の事も碌々片づかない中に、かみさんを迎へる算段ばかりして居ると云ふやうな事を毒々しく云ひつのつて居るのだつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴も鶴だ、不景気不景気だと己ら事ぶつ死ぬまでこき使ふがに、末を見ろ毎日々々のらくらと背丈ばかり延ばしやがつて」　姉はこの口ぎたない雑言を聞くと、妙にぶッつりして、碌々挨拶もしないで帰つて行つてしまつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ碌々遊びもしないと思ふ頃、ふと薄寒いのに気がついて空を見ると、何時の間にか灰色の雲の一面にかゝつた夕暮の暮色になつて居た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴吉はすぐ又喧嘩があつたのだなと思つて、あたりさはりのない世間話に口を切つて見たが、母は碌々返事もしないで布巾をかけた精進の膳を出してすゝめた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度客の顔をあたつて居た鶴吉は碌々見返りもしなかつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにも行かずに家の中でごろ／＼してゐる中におやぢとの不和が無性に嵩じて、碌でもない口喧嘩から、おやぢにしたゝか打ちのめされた揚句、みぞれの降りしきる往来に塵のやうに掃き出されてしまつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が放慢なためにそんなことを考えて見たこともないのに依るかも知れないが、一つは十二年も北海道で過しながら、碌々旅行もせず、そこの生活とも深い交渉を持たないで暮して来たのが原因であるかも知れないと思う。",
              "citation": {
                "source": "北海道に就いての印象",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔つめたき朝の真鍮に〕宮沢賢治つめたき朝の真鍮に胸をくるしと盛りまつりこゝろさびしくをろがめばおん舎利ゆゑにあをじろく燐光をこそはなちたまへり",
              "citation": {
                "source": "〔つめたき朝の真鍮に〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔われらひとしく丘に立ち〕宮沢賢治われらひとしく丘に立ち青ぐろくしてぶちうてるあやしきもののひろがりを東はてなくのぞみけりそは巨いなる塩の水海とはおのもさとれども伝へてきゝしそのものとあまりにたがふこゝちしてたゞうつゝなるうすれ日にそのわだつみの潮騒のうろこの国の波がしらきほひ寄するをのぞみゐたりき",
              "citation": {
                "source": "〔われらひとしく丘に立ち〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜はほのじろく明けんとす僕はここに去りまた新しい汽車に乘つて行かうよ僕の孤獨なふるい故郷へ。",
              "citation": {
                "source": "別れ",
                "author": "旅の記念として、室生犀星に",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、手紙をろくろく見ずに、声立てて読みました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
