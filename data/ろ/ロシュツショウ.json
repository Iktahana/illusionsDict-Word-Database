        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お前のは露出症だよ、あれは下品だ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、原因と結果との間に、一種不可解な跳躍があり、原因がそのまゝ、結果になつてゐるとでも云ひたい露出症的な風景である。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "百間氏の被害妄想症に対比されるべきものは森田氏の有名な露出症である。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "この露出症が学生の気に入って、若い卒業生達に担がれて反野上の巨頭となったのだが、元々大した見透しがあったのではない。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒステリイはエギジビジョナリズム（露出症）の一種ですから。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、つまりコグラカッちまつた人間の特色でねえ、今言つた閉塞症みたいになるかと思うと、今度は出しぬけに、露出症にもなるんです。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（２）彼らはよく知られている露出症――すなわち受け入れられるにせよ反対されるにせよセンセーショナルな注目を受けるのを願望すること――に罹っている。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
