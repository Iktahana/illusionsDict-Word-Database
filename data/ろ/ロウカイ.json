[
  {
    "uuid": "21158337-a9ef-51d1-b005-aca51d2807ab",
    "entry": "老獪",
    "reading": {
      "primary": "ろうかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
