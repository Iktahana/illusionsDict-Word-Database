        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ＮＥＣ内部の動きに関しては、数か月前に雑誌の仕事でかなり念入りに取材しており、資料の整理やインタヴューの録音テープを書き起こす作業もすませていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一方の柱となる友人からも、あらかじめ長い時間をかけて話を聞いており、録音テープを元にノートを作っていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルガ姫は、録音テープを捲きとって、発声装置にかけているところであった。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで英語の録音テープを送っておいた。",
              "citation": {
                "source": "テレビの科学番組",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車する停留所名を、録音テープ合成音声が順番に告げた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
