    "definitions": [
      {
        "index": 1,
        "gloss": "free seat (e.g. a park bench)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　銀子は事もなげに言って、ロハ台を離れて歩こうとしたが、頭がふらふらして足ががくがくして、そのまま芝生のうえに崩れてしまった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロハ台を立って、柳の下から乗り出して、熟と瞻る内に、花吹雪がはらはらとして、それっきり影も見えなくなる、と物干の在所も町の見当も分らなくなってしまった。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに晴れようと、ロハ台に腰を掛けた、が、その上に蔽い掛った紅楓の大木の美しさ。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "時雄は堪え難い自然の力の圧迫に圧せられたもののように、再び傍のロハ台に長い身を横えた。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園のロハ台は木の影で涼しかった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはロハ台に横たわりながら、その希望と今の失望との間にはさまった一場の光景をまた思い浮かべた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロハ台から起き上がる気分になるまでには、少なくとも一時間はたった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎や鴛鴦やそのほかさまざまの水鳥のいる前のロハ台にかれはまた腰をおろした。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹の台に来て、かれはまた三たびロハ台に腰をかけた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　乾からびた葡萄棚の下に跼ったとき、ロハ台に寝ていた男がムクムクと起きあがって、帆村に剣突をくわせた。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つのロハ台へ腰を掛け、好きなラ・ラビアを喫かすのが、夏以来の習慣であった。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬も冬、一月中旬、冷たい風が吹き迷っていたのに、この習慣は止められず、その日も私はロハ台に倚って、ラ・ラビアを喫かしていた。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詐欺師と邂逅ったロハ台へ、私は一人で腰をかけていた。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死の深淵へ落ちることが出来る」　私は私の両膝を、ロハ台の上へ抱き上げた。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はロハ台に腰を下ろした。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐伯氏と逢ったロハ台であった。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご機嫌よろしゅう」　ロハ台を離れて大股に、町の方へ歩いて行った。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はロハ台から離れなかった。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひとつ彼女を祝福しに行こう」　それでもロハ台から離れなかった。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で私は公園へ行き、首を釣りかけた木へ触れたり、佐伯氏と逢ったロハ台に、腰を掛けて考えたりした。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園のロハ台はそのロハ台たるの故をもってことごとくロハ的に占領されてしまった。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロハ台は依然として、どこの何某か知らぬ男と知らぬ女で占領されている。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "木賃ホテルにも居堪れなくなって、昨夜は芝公園のロハ台に一泊したんです。",
              "citation": {
                "source": "朝起の人達",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どんな事が起ったんだ、話してくれなきゃ気になるじゃないか」　千種十次郎が斯う言った時は、二人は日比谷公園のロハ台の上へ、二羽の十姉妹のように押し並んで居りました。",
              "citation": {
                "source": "女記者の役割",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "咽び泣く麗子を扶けて、深い木立の中のロハ台に陣取った加奈子は、涙の隙から、漸くこれだけの事を聞きました。",
              "citation": {
                "source": "向日葵の眼",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
