[
  {
    "uuid": "757508bf-b0b9-5443-8fce-003cdb8d7ff3",
    "entry": "論ずる",
    "reading": {
      "primary": "ろんずる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
