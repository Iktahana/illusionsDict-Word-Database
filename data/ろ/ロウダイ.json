[
  {
    "uuid": "8aebdf33-d84a-500a-bd7b-e927f009736b",
    "entry": "老大",
    "reading": {
      "primary": "ろうだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "形容動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "growing old",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自作を語るなんてことは、老大家になってからする事だ。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこのご両人は、あまりに老大家であって、「一群」からは、かけ離れていた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロレンツのごとき優れた老大家は疾くからこの問題に手を附けて、色々な矛盾の痛みを局部的の手術で治療しようとして骨折っている間に、この若い無名の学者はスイスの特許局の一隅にかくれて、もっともっと根本的な大手術を考えていた。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから僕は、老大家たちが好きになれないんだ。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、新人と逢えば新人、老大家と逢えば老大家、自然に気持がそうなって行くんですから面白いですよ。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも、その逝去した老大家には、お義理一ぺん、話題は、女に就いての、極めて不きんしんな事。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一人の独身の絵画の老大家が巴里に住んでいました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし老大家は、彼の新工夫の描き方を、仲間に盗まれるのを惧れて、絶対に人に見せませんでした。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老大家の描こうと企てているのは、この世の中で最も美しい女性、それを生きたもの同様な溌剌さで画布の上に現そうとするのでした。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかして老大家の作を見たくて堪りません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老大家は相変らず頑固に画室の扉を押えて、中へ入れないのでした。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、その画家の恋人に老大家が眼をつけます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は、若い画家のため老大家のモデルになることを承知しました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど苦心して近寄った老大家の傑作は、どうでありましたろうか。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし老大家は得意の絶頂です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老大家の画家は、十年、女の肉体を凝視、分析し続けて行って、いま、その「空」の世界に突き当ったのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老大家は、ひとたび「空」の世界に行き当って、その自由さ、豊饒さに酔ってしまったのでありました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老大家は、農夫の肥田を見付けたときと同程度の心の段階で楽しんでいるのでした。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この肥えた土地を発見した老大家は、それへ創造工夫の種子を蒔いて、折角掴んだ理想美を誰にも解りやすく摘み取れるよう、成長開花せしむべきでありました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "模糊の絵を見て不審がっている若い画家の顔を見て、老大家は自信を裏切られたように感じました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老大家というものは、ずいぶんわがままなものだと思った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老大家のような落ち付きを真似して、静かに酒を飲んでいたのであるが、酔って来たら、からきし駄目になった。",
              "citation": {
                "source": "作家の像",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのう永井｜荷風という日本の老大家の小説集を読んでいたら、その中に、「下々の手前達が兎や角と御政事向の事を取沙汰致すわけでは御座いませんが、先生、昔から唐土の世には天下太平の兆には綺麗な鳳凰とかいう鳥が舞い下ると申します。",
              "citation": {
                "source": "三月三十日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日も早く西洋の科学を消化して列国に拮抗しなければ、支那もまた、いたずらに老大国の自讃に酔いながら、みるみるお隣りの印度の運命を追うばかりであろう。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "査閲がすんで、査閲官の老大佐殿から、今日の諸君の成績は、まずまず良好であった。",
              "citation": {
                "source": "鉄面皮",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故ならば、くるしいことには、私は六十、七十まで生きのびて、老大家と言われるほどの男にならなければ、いけない状勢に立ちいたってしまっているのである。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、日本の或る老大家の文体をそっくりそのまま借りて来て、私、太宰治を語らせてやろうと企てた。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その老大家の手記こそは、この「狂言の神」という一篇の小説に仕上るしくみになっていたのに、ああ、もはやどうでもよくなった。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、顧みて日本の文壇を考えると、今なお無気力なオルソドックスが最高権威を持っていて、老大家は旧式の定跡から一歩も出ず、新人もまたこそこそとこの定跡に追従しているのである。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの親分に楯ついて、組合作ったら、どげなことになるか、玉井が一番よう知っとろうだい」　筒袖の男は、まだ、つづけている。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
