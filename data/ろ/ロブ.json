        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私達はいつも無意識の裡にそれ等を眞として數學のプロブレムを取扱つて來た。",
              "citation": {
                "source": "海から歸る日",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガイ・マナリングやロブ・ロイやアンドルウ・フェアサーヴィスなどを。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "粘り強さもロブスターのようだ。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それへラスプーチンの死骸を載せ、トロブスキー橋の方へ走らせた。",
              "citation": {
                "source": "世界の裏",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の宰相はロブコウヰチ公といふ政治家で、ひどくそれを苦に病んで、幾度か市民あてに訓令を出しは出したが、市街はいつまで経つても少しも綺麗にはならなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にはオブストロブスキイなどいう人の「ストルム」や、ハウプトマンの二、三の作などがあった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルービンスタインがまずやったのは、自分の二週間前にＩＭＳＡＩをやめていた同社の元ソフトウエア開発部長、ロブ・バーナビーを雇うことだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな細君に、肩掛だの、いろんな＊11ロブロンだのという、碌でもないものを買ってやるためで！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊11　ロブロン　腰に箍骨を入れた古風な婦人の衣裳。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "二万マイルの道、北は、新疆のロブ・ノールから外蒙へまで、あるいはソ領｜中央アジアへもコーカサスへも、アフガニスタン、イランをとおり紅海のしたから、この地下の道はサハラ沙漠まで、ゆくだろう。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "たるんだブロブロ声で笑いながら紙のあおる音の様なテカテカテカをやって居る男や、万燈をかついで走り廻って居る男やはそんな事は一寸も知らずに――又知って居てもすっかり忘れて狂いまわって居る。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピョートルの性格、ニコラーイ・スタフローギンは勿論、ユーリア・ミハイロブナ、その他、実に奇怪な、いやに深い、ロシア的存在が描かれて居る。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○イフゲーニア・ミハイロブナ、Ｙ、いやがって、いやがって閉口、双方がいやなのだろう。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "イフゲーニア・ミハイロブナの稽古。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日よりエフゲーニア・ミハイロブナ毎日稽古。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○エフゲーニア・ミハイロブナの稽古。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月十四日（火曜）　エフゲーニア・ミハイロブナの稽古二月十五日（水曜）　今日から、Ｙ稽古に毎朝十一時から通うことになった。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンナ・ミハイロブナとは比較にならず落付いていい先生の由。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダム・キリロフスキー二月十六日（木曜）　エフゲーニア・ミハイロブナの稽古　Ｙ、キリロフスキーのところへ行ってから、又ミハイロブナ故、くたびれて閉口して居る。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月十八日（土曜）　エフゲーニア・ミハイロブナの稽古二月十九日（日曜）　第一大学の日曜大学の講義をききにゆく。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日エフゲーニア・ミハイロブナのところへゆく筈であったが、やめにして、家でけいこをして貰った。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝仕事をしてから、ベゲテリアンへゆき、それからエフゲーニア・ミハイロブナのところへ出かける。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ニキートスキエ・ボロータ〔ゲルツェン通りの端の地名〕の近くで、アンナ・サモロブナのところを見た。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからアンナ・サモイロブナのところへ行ったら、しまっていた。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕合に、サモロブナ引退式があって、いろいろの人――ダンチェンコも出てよんだり話したりした。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "サモロブナも挨拶したが、カッ采鳴り止まず。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分サモロブナが、この拍手も、こうやって見物を見渡すのも、もう此夜ぎりと思って感じる心持ちを感じ、淋しいような同情されるような印象のつよい心持がした。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨー子もう大分飲んだ由、姉が「今日は何も判りゃしないんだから」　パッサージで、シーツ大二つ麻のを買い、マーリア・ドーミトロブナのところに行く。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはやはりロブスター（伊勢えびの類。",
              "citation": {
                "source": "アメリカの牛豚",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
