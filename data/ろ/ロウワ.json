        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……お、お、お……これで私ッしらも助かろうわい。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも罪人は一｜刻も早よう引っ捕えいと言う注文じゃから先ず、これ位、困難しい探偵事件はなかろうわい。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、そうじゃあないよ、一旦は何、私だって、先刻のように云ったけれど、お前さんの心配をすることだもの、それに、どうせ、こんなからだだから、お前さんさえ愛想をお尽しでないことなら、もうどんなにでも私ゃなろうわね。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "源兵衛さんは本望であろうわいなあ。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "再婚で子供があって、その上赤坂や新橋といろいろうわさを立てられているくせに、まだ処女を要求している！",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "母　　　そうやけど嫁入りの時に、一枚でも余計ええ着物を持って行きたいのだろうわい。",
              "citation": {
                "source": "父帰る",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "母　　　たねが、ちいと相手が気に入らんのだろうわい。",
              "citation": {
                "source": "父帰る",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「目違いするにも程があろうわッ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと泡吹かしてやろうわ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺社奉行さまが、さばきのむちと情とを持って、お待ちかねでござろうわ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるはよし木から落ちることがあっても、右門の目に狂いのあろうわけはないはずでしたから、いってるうちにことりと表の辺にあたって、足音を止めたけはいがありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、よいよい、この境内へ追い込んでおかば、またお目にかかる事もあろうわい。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大網ならば夕刻あたりまでに、小鰯の一匹位かかろうわい。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "同志の身が危ういときくからは、われらも素姓知らしてやろうわ。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりそちの口車なぞに乗ったら、この兄の身体、骨と皮ばかりになろうわ。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "助太刀頼んで乗り込んだとあらば眉間傷が悲しがろうわ。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、一幕書いてやろうわい、京弥」「はッ」「もそっと耳を寄せい」「何でござります？",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではこちらも泡を吹かしてやろうわッ。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "抜身の二本三本あの度胸ならへし折ろうわい」「いいえ、やられましてござります……」　そのとき不意でした。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            }
          ]
        }
