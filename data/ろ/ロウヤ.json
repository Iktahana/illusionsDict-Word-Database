    "definitions": [
      {
        "index": 1,
        "gloss": "jail",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "リゼットが始めて彼に捉えられてサン・ラザールの館――即ち牢屋へ送り込まれるときには生鳥の鶉のように大事にされた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝牢屋敷門前　一同が到着した。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりひらが、Ｔ「これを早馬で牢屋敷へ届けて戴き度いんだが」　よろしゅう御座ると左衛門。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝遂に牢屋敷の表　馬が駈け込む。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "造りが、頑丈に、──丁度牢屋のように頑丈に出来ている。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "軟派が曝露して罰金や牢屋ですむところを、硬派は命をかけなければならなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば兵営の浴室と隣の休憩室との間におけるカメラの往復によって映出される三人の士官の罪のない仲のいいいさかいなどでも、話の筋にはたいした直接の関係がないようであるが、これがあるので、後にこの三人が敵の牢屋に入れられてからのクライマックスがちゃんと生きて来るように思われる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢屋でフォーサイスが敵将につかみかかって従者に打ちのめされる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋愛はもとより、ひとの細君を盗むことや、一夜で百円もの遊びをすることや、牢屋へはいることや、それから株を買って千円もうけたり、一万円損したりすることや、人を殺すことや、すべてどんな経験でもひととおりはして置かねばいい作家になれぬものと信じていた。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか牢屋でお正月を送るやうなこともあるまい。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お正月も牢屋も檢事も、僕たちにはどうでもよいことなのだ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで何処の牢屋へ入れなさったか」「馬鹿な。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢屋や留置場の窓の鉄格子、工場の窓の十字格子。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢屋は町の外れの砂山の松原の中にあつた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれが常習犯の盗賊であるのと、その体格が逞しくみえたのとで、彼は一度に笞打と石抱きとの拷問を加えられたが、歯を食いしばり、口を閉じて、とうとう一言も白状しなかったので、その日はそのままで牢屋へ下げられた。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢屋の下男はすぐにその疵口に砂をふりかけて血止めをして、打役の者がまたもや打ちつづけるのである。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそのままで牢屋へ下げられた。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで彼の運命は一旦定まったのであるが、間もなく病気にかかったという牢屋医者からの届け出があったので、その仕置は来春まで延期されて、かれは暗い牢獄のなかで天保六年の春を迎えた。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿のように疲れきって牢屋に帰ってくると、名主や役附の者どもは彼の剛胆を褒めそやして、総がかりで介抱してやった。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれが今日は海老責に逢うことを牢屋附の下男の内報によって、牢内でも薄々承知していたので、ひそかにその安否を気配っていると、かれは問い落されもせず、責め殺されもせず、弱りながらも無事に帰って来たので、牢内の者どもは跳りあがって喜んだ。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロマンティストは、金の工面に奔走したり、友情を強要したりすることよりも、自分一人で牢屋に入った方が、ずっとロマンティックだと思いますからね。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "北國の雪解の時分と來たら、全て眼に入るものに、恰で永年牢屋にぶち込まれた囚人が、急に放たれて自由の體となツたといふ趣が見える。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "「恨ましやすんな、諦めなされ、　日の眼拜まぬ牢屋の中で、　　手錠、足械悲しいけれど、　長い命ぢやもうあるまいに　何うせ自暴だよ……」　皺嗄れた殆ど聴取れない程の聲で、恁う唄ふのが何處ともなく聽えた。",
              "citation": {
                "source": "虚弱",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人共牢屋へ入れられました。",
              "citation": {
                "source": "お金とピストル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中の人間の「実生活」というものを恐怖しながら、毎夜の不眠の地獄で呻いているよりは、いっそ牢屋のほうが、楽かも知れないとさえ考えていました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、牢屋にいれられる事だけが罪じゃないんだ。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎兵衛は重い罪にとわれ、牢屋へいれられた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎兵衛は牢屋へはいってからもそのどこやら落ちつきはらった様子のために役人から馬鹿にはされなかったし、また同室の罪人たちからは牢名主としてあがめられた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはいま牢屋から出て来たばかりだよ。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして牢屋へはいったのです。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
