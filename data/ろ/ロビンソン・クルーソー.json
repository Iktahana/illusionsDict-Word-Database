        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一方ではゲーテの「ライネケ・フックス」や、それから、そのころようやく紹介されはじめたグリムやアンデルセンのおとぎ話や、「アラビアン・ナイト」や「ロビンソン・クルーソー」などの物語を、あるいは当時の少年雑誌「少国民」や「日本の少年」の翻訳で読み、あるいは英語の教科書中に採録された原文で読んだりした。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今ロビンソン・クルーソー、或いはウォルト・ホイットマンの生活を実験しつつある。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラリッサ・ハアロウとロビンソン・クルーソーとを比較せよ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、ロビンソン・クルーソーを五回以上読んだことがないか、どうか、それが些か疑わしいだけのことだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロビンソン・クルーソーといえば、当然、私の「宝島」が問題になる。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともコンナ風に話して参りますと、何のことはないお伽話みたような筋道になってしまいますが、併し、そこまで来る間の私共の辛苦｜艱難と、それから後の孤軍奮闘的生活といったら、優にロビンソン・クルーソー以上の奇談を綴るに足るものがあったのですよ。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アレビアン・ナイツ」「イソップ」「アンデルセン」「ロビンソン・クルーソー」はいづれも童話の聖書であるから、これをのぞくことは出来ない。",
              "citation": {
                "source": "「小学生全集」について",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤島に上陸したばかりの孤独なロビンソン・クルーソーにも自己に対しての道徳はあったと思う。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文芸評論の中で漱石は、ディフォーの「ロビンソン・クルーソー」を批評している。",
              "citation": {
                "source": "風俗の感受性",
                "author": "――現代風俗の解剖――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロビンソン・クルーソーの「詩的に下等」なる所以は、これが「ただ労働の小説である」そして「どの頁をあけて見ても汗の匂いがする。",
              "citation": {
                "source": "風俗の感受性",
                "author": "――現代風俗の解剖――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで、ロビンソン・クルーソーのような生活をして、大戦がいつ終ったかも知らないし、おまけに子まで出来た。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいか、俺はどんな蛮地にいようとも、立派なドイツ国民として行動して見せるのだ」　この今様ロビンソン・クルーソーがなにを言いだすのだろうと、一同は興味深く顔をのぞき込んだが、斉しくのっぴきならぬ危険が起りそうな予感を覚えた。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、　スタンレーの「アフリカ探険記」、キャピテン・クックの「世界三週航実記」、「ロビンソン・クルーソー」、「不思議の国巡廻記」「アラビアン・ナイト」等が翻訳された。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、「竹取物語」、「西遊記」、「アラビアン・ナイト」、スチブンソンの「宝島」、アミーチスの「クオレ」、マロオの「家なき少女」、トウエンの「ハックルベリー・フィンの冒険」「トム・ソーヤの冒険」、「ロビンソン・クルーソー」、「不思議の国巡廻記」等。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "その第一は陸の生活と遠離の感で、まるでロビンソン・クルーソーになった気持である。",
              "citation": {
                "source": "荒磯の興味",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが冬期の激浪にもまれ解氷時に至ってロビンソン・クルーソーの行動を起すもののようである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし人類はかのロビンソン・クルーソーがごとく偶然として絶海の孤島に漂泊したるものにあらず。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "その茅屋を結ぶにはみずから木挽・大工・石工・泥匠とならざるべからざるところのかのロビンソン・クルーソーを学ばざるべからざらしめたり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロビンソン・クルーソーみたいな生活をしている内には、戦争も終るだろうと考えたものである。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の日々の生活はロビンソン・クルーソーそっくりであった。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身もまた、そんな薄情な存在は、何んの未練もなく振り捨てて、ロビンソン・クルーソーのように一本立になってしまいました。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第七夜　歓楽の夢魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロビンソン・クルーソーの気分だったよ。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで少年はロビンソン・クルーソーのように自給自足で逞しく生きるんだ」「ふうん」　隼人はおもむろにパーラメントをくゆらした。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも少年がロビンソン・クルーソーみたいな生活を送るという設定自体が、君の性格を反映してるんだ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その島は発見者の名を負うているが、そこへ十八世紀の頃にイギリスの水夫アレキサンダー・セルカークが漂着し、その体験譚がダニエル・デフォーの『ロビンソン・クルーソー』となったのである。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "野蛮人でもなんでも、人間がいてくれれば、僕たちは何とか工夫して助かる見込があるんだけど、人間が一人もいないとすると、僕たちは、ホラあのロビンソン・クルーソーのお話とおんなじになってしまうじゃないか。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロビンソン・クルーソーはあの淋しい無人島に二十五年も一人ぼっちでいたんだよ。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
