        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この人の絵には落ち着いた渋みの奥にエロティックに近い甘さがある。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために一種サディズムのにおいのあるエロティックな深刻味があって近代ドイツ派の好きな人には喜ばれるかもしれないが、甘みのすきな私にはこれよりももう一つの「裸婦」のほうが美しく感ぜられる。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はこれをサンキロティズムに対してサンバカミズム（Sansbakamism）と呼ぶだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子が短いパンツをはいて腰を振ったり足を上げたりするだけでは、大したエロティシズムもないし、豪華だとか青春の夢だとかいって騒いでいたのもおかしい。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、まだもう一つ、さうやつて無言で向ひ合つてゐる中に次第に微かながらエロティッシュな興味が生じて來たからでもあつた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロティとメルヴィルの畫いたポリネシアの色褪せた再現を見てをるに過ぎぬのだ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "取上げて見ると、一册は厨川白村の「英詩選釋」で、もう一つは岩波文庫の「ロティの結婚」であつた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ雰圍氣の中で、厨川白村やピエル・ロティを見付けた時は、實際、何だかへんな氣がした。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の「ロティの結婚」に就いては、マリヤンは不滿の意を洩らしてゐた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、まだもう一つ、そうやって無言で向い合っている中に次第に微かながらエロティッシュな興味が生じて来たからでもあった。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロティとメルヴィルの画いたポリネシアの色｜褪せた再現を見ておるに過ぎぬのだ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "取上げて見ると、一冊は厨川白村の『英詩選釈』で、もう一つは岩波文庫の『ロティの結婚』であった。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう雰囲気の中で、厨川白村やピエル・ロティを見付けた時は、実際、何だかへんな気がした。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その『ロティの結婚』については、マリヤンは不満の意を洩らしていた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、まだもう一つ、さうやつて無言で向ひ合つてゐる中に次第に微かながらエロティッシュな興味が生じて来たからでもあつた。",
              "citation": {
                "source": "夾竹桃の家の女",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三六年という年は、かようにして「もののあはれ」、「ますらをぶり」等が晦渋に呈出されつつある一方で、万歳と漫談、とりとめなくエロティックな流行歌とが異常な流行を見た時であった。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白さが読者大衆から要求されているということを、すぐエロティックなものだのチャンバラだの、くすぐりと見なすのは大衆の感情そのものを実際知らないものであるし、作家らしからぬ粗笨さである。",
              "citation": {
                "source": "今日の文学に求められているヒューマニズム",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "良子嬢が東郷元帥の孫としてのつまらない生活の反対物をカフェーに見出したところに、子供のうちから消費生活にだけ馴らされた娘の気分と、今日の貴族階級が生活感情の実質においては、赤化子弟に対する宗秩寮の硬化的態度に逆比例するデカダンスや低俗なエロティシズムに浸透されていることが分る。",
              "citation": {
                "source": "花のたより",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファッシズムや、エロティシズムの方向をとることはさし当り見易い一つの危険である。",
              "citation": {
                "source": "一九三四年度におけるブルジョア文学の動向",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東大でも、伊藤ハンニまがいの山師がでているし、きわめてエクセントリックな性格と生活態度の女子学生が大阪の実家で弟に殺されたという事件があったし、法科の学生が教室でエロティックな映画を公開したというおどろくべきこともありました。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、あすこに、そばへ寄るときっとラックフォルト乾酪と酸菜のにおいのしそうな、伯林ドロティン・ストラッセ街から来た紳士がいるでしょう？",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の障子の風情を愛すのはピエル・ロティとヨネ・野口に止まらぬ。",
              "citation": {
                "source": "是は現実的な感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "依然として、読ませて儲けるのが眼目である出版物は、猛烈な新円獲得の目的もあって、この頃はいわゆる大衆性を得るということを、エロティシズムに集注している傾きがある。",
              "citation": {
                "source": "商売は道によってかしこし",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをまぎらそうとする気分の追求の一つとしてエロティックなものへひかれる気もちもあるだろう。",
              "citation": {
                "source": "商売は道によってかしこし",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "民主日本の航路から大衆の精悍さを虚脱させるために空腹時のエロティシズムは特効がある。",
              "citation": {
                "source": "商売は道によってかしこし",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在日本のジャーナリズム文学を大幅に流れているデカダンティズムやエロティシズムの傾向とその作家たちは、けっして日本の現代文学の代表として推される文学的価値はもっていない。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果一番うれる最低の安全性としてエロティシズムに陥っている。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに昨今の特徴として目立つ傾向はデカダニズム、またはエロティシズムです。",
              "citation": {
                "source": "一九四六年の文壇",
                "author": "――新日本文学会における一般報告――",
                "note": "青空文庫"
              }
            },
            {
              "text": "個々の作家についてみればそれぞれ異った作風、デカダンスの解釈とエロティシズムへの態度があるけれども、総体としてみて、今日、新しい人間性の確立がいわれている中で、デカダンス、エロティシズムの文学が流行していることについては注目の必要があると思います。",
              "citation": {
                "source": "一九四六年の文壇",
                "author": "――新日本文学会における一般報告――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
