    "definitions": [
      {
        "index": 1,
        "gloss": "death comes to old and young alike",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
