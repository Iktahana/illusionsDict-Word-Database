    "definitions": [
      {
        "index": 1,
        "gloss": "discussing and deciding",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "徂徠が野にいたのも、白石が官儒として立ったのも、たんなる表面観察では誤りに陥りやすいことを論定したかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が地球の年壽は今論定し易く無い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論定家の假名遣で書くと云ふ人は物語類でも讀むとか、北村季吟などが作つた「湖月抄」とか、あゝ云ふ物でも讀んで居る人の上であつて、其外は矢張亂雜でありませう。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨子の説は墨子の創唱になつたものか、或は古より其の一派傳統のあつたものか、これも論定されてゐないことである。",
              "citation": {
                "source": "墨子",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が地球の年寿はいま論定し易くない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "（王の顔が見度いばつかりに皇后を救つてやる、とは云つたが、それは全くの出任せで未だ悪魔を退治して后を助け出さうとする真実の決心も計画も勿論定めてはなかつた。",
              "citation": {
                "source": "闘戦勝仏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "信實の子孫の事に就ては『古畫備考』等にも載せられ、最近には粟野秀穗君が、信海の不動明王圖を研究して、信海は信實の四子なる事を論定せられしものあり、又近年西本願寺にて發見せられし親鸞聖人像は、專阿彌陀佛と云ふ信實の子の筆なりと言はる。",
              "citation": {
                "source": "日本の肖像畫と鎌倉時代",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "さはいえ摸写々々とばかりにて如何なるものと論定めておかざれば、此方にも胡乱の所あるというもの。",
              "citation": {
                "source": "小説総論",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸子は環坐して古本を披閲し、これが論定をなした。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ書に、録惟れ勤め、各部｜頓に成るといってあるのを見れば、論定に継ぐに編述を以てしたのも、また当時の事であったと見える。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし大久保氏の家世は諸書記載を異にしてゐて、今｜遽に論定し難い。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩はまた前期の沿革に連繋してこれを論定せんのみ、何となれば何事も断然滅するものなくまた突然生ずるものなければなり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "武后は秋官侍郎劉如睿（また劉如などに作る）等八學士に命じて『老子化胡經』の眞僞を論定させたが、八學士は老子化胡の事は漢・隋の正史に載せ、一概に捏造とのみ認め難しと復奏した。",
              "citation": {
                "source": "老子化胡經",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、治にも亂にも忘るべからざるは武備にて、武備不整候得ば、假令國論定り人心の向ふ所不動候とも、事に臨、其議論を押立候力無之、後れを取候樣可相成奉存候。",
              "citation": {
                "source": "御時務の儀に付申上候書付",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二法典の関係を論定するは、一般の法学の知識の外、特にセミチック語、旧約全書の歴史などに通ぜねば出来ぬ事であるし、且つこの夜話の目的としては余り精微の点に入り過ぎるから、ここにはその論点を紹介することを略するが、この問題の詳細を知らんとする者は、左の諸書に就いて見るがよかろう。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの法隆寺の年代論が、それを前提として論定せられたものである以上、これまた到底問題とすべきものでは無いのである。",
              "citation": {
                "source": "法隆寺再建非再建論の回顧",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "余、同志と議し、苟くも二、三の名侯心を協え力を戮せ、正義を発し俗説を排するもの有らば、則ち天下の論定まらんと。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "言いつけられた時刻に、時刻がきたと注意しても、先方がその注意を無にする以上は、向をむいてうんさえ発せざる以上は、その曲は夫にあって、妻にあらずと論定したる細君は、遅くなっても知りませんよと云う姿勢で箒とはたきを担いで書斎の方へ行ってしまった。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは石経の断片的な残字から丹念に碑面の文章を復元し、それによって漢石経の本文が魏の何晏の「集解」序にいうところの「魯論」のテキストであることを論定されたものである。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、勿論此の問題に就ては、いづれが是、いづれが非と言ふやうに、どちらが文学の本道であるか、はつきりした論定が、決して出来て居る訳ではない。",
              "citation": {
                "source": "「私」小説と「心境」小説",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "又論定が出来る訳のものではない。",
              "citation": {
                "source": "「私」小説と「心境」小説",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの一事だけで論定することはできない。",
              "citation": {
                "source": "文化史上より見たる日本の数学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは充分に比較してからではないと論定はできないが、とにかく、整数論、連分数、統術などの方法または結果に類似したものが幾つか存在することを注意しておきたい。",
              "citation": {
                "source": "文化史上より見たる日本の数学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "果たしてしからば、余輩は宇宙間唯一の必然の天則のみ存せることを論定せざるべからず。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとく論じきたるときは、余は世に全く妖怪なしと論定するもののごとし。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの試験法によりて、余は先年、不思議研究会において、そのいわゆる細糸は、断じて空中に浮かぶところの塵毛なることを論定せり。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二者のいずれが原因にして、いずれが結果なるやは論定し難しといえども、睡眠中血液の減少することは確然たるがごとし。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点まで論定するには長い説明を要すれば、これまた『破唯物論』およびその他の著書に譲り、ただここに、精神が物質の裏面に潜むときには、意識を失って無知覚となるか、もし無知覚となるならば、いかにして再び知覚を生ずることになるかを説明せねばなりませぬ。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "かのスピノザが、因果の理法のほか一理一法なきことを論定したるは、実に近世の卓見というべし。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
