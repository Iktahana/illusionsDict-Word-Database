[
  {
    "uuid": "6606368c-7bb6-56ad-80b0-6ead17184e79",
    "entry": "論結",
    "reading": {
      "primary": "ろんけつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
