    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lost",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "荒涼、陰惨、ディスマル、トロストロース、あらゆる有り合わせの形容詞の総ざらえをしても間に合わない光景である。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラート教授の下宿の朝食のトロストロースな光景はかなりよくできている。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて、いまは不吉な敵国の言葉になったが、パラダイス・ロストをもじって、まあ「人間失格」とでもいうような気持でそんな題をつけたのであって、その日記形式の小説の十一月一日のところに左のような文章がある。",
              "citation": {
                "source": "鉄面皮",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フィロストラトスでございます。",
              "citation": {
                "source": "走れメロス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽罐の上のストーヴのロストルのような上を渡って、またタラップを下った。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "その習慣が長く続くと、生理的に、ある方面がロストしてしまって、肉と霊とがしっくり合わんそうだ」　「ばかな……」　と笑ったものがある。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その習慣が長く続くと、生理的に、ある方面がロストしてしまって、肉と霊とがしっくり合わんそうだ」「ばかな……」　と笑ったものがある。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロストフ市から数十哩東にソヴェト一の大国営農場「ギガント」がある。",
              "citation": {
                "source": "砂遊場からの同志",
                "author": "――ソヴェト同盟の共学について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐうたら手記□エロストロゴスとの抱擁！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお北京駐在露国公使コロストウェツの特に任地より来あわせる等の事実より推測すれば、時を同じゅうして来遊の噂ある伊藤公爵とわが蔵相との会見は、なんらか他に重大なる使命を秘するもののごとく想像に難からずと、某消息通は語れり。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワ、レーニングラード、ロストフその他少し目ぼしいСССРの都会は、街のどっかにきっと「農民の家」と看板をかかげた建物をもっている。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロストフ市の郊外に新しくプロレタリア文化の壮麗な城のような「セルマシストロイ」（農業機械製造）の大工場都市がある。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロストフはウクライナ共和国の主都で、附近にはソヴェト第一の大国営農場「ギガント」があった。",
              "citation": {
                "source": "明るい工場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がロストフへきていたのもその「ギガント」を見るためなのである。",
              "citation": {
                "source": "明るい工場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポチョームキン（グリゴーリイ・アレクサンドロストーポリ等の商港を開き、大いに南方治政に貢献した功により、翌年、陸軍元帥、参謀総長に任ぜられた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「別れたる妻に送る手紙」という小説を書いた、近松秋江氏に同情して、この人のロストラブの哀史を、同情をもって読んでみようと思うといったりしていた。",
              "citation": {
                "source": "遠藤（岩野）清子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夏は、モスクワばかりでなく、イワノヴォ・ヴォズネセンスクにもロストフの工場にも消費組合監督の突撃隊が出来た。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし同船は、その後一七八六年に、アリューシャン列島中のアマリア島で難破したのであるから、当然その一冊も、船長フロストの遭難記にほかならぬのである。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これによく似ているのは、ロストックで数学の教授をしていた Becker に起った実例でございましょう。",
              "citation": {
                "source": "二つの手紙",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリスにおいて、ミルトンの一夫一婦　純潔な家庭を称揚したパラダイス　ロストフランスの人々も家庭というものの幸福のために坊主の追放を考えた。",
              "citation": {
                "source": "バルザック",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば――　アサー・コナン・ドイルの「ロスト・ワールド」のごときものである。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ロスト・ワールド」は、既に映画化もされ読者諸君も御承知のように、南米の人跡未踏の内地に、前世界の動物である恐竜や飛竜や類人猿なぞが棲息している高地を探険する物語で、科学的智識に豊富なる空想力を加えて創造されたのである。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "その開いた戸の間から汽罐室の中を見た時に、僕が先づ思ひ出したのは「パラダイス・ロスト」の始めの一章である。",
              "citation": {
                "source": "軍艦金剛航海記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "波止場には、新司令官フロスト陸軍少将が、守備隊をひきつれて出ている。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐しい秘密の作戦　その夜、フーラー博士、グレー中将、参謀長、フロスト陸軍少将の四人は、金剛石砲台の山上の小屋で、秘密の作戦会議をひらいた。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　フロスト少将が横から口を出した。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　フロスト少将も、眼をかがやかした。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　フロスト少将は、カーキー軍服の肩をいからした。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ライオン』戦車上陸す　フーラー博士の第一中隊が太東岬の向うへ去ると、後は、第一運送船に乗っているフロスト陸軍少将が指揮をとった。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　フロスト少将は、にやりと笑った。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
