          "literary": [
            {
              "text": "今度日本へ来た加奈太政府の労働大臣さ。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国では、マクドナルド労働党内閣は婦人労働大臣にミス・ボンフィールドを任命していた。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の婦人参政運動者をよろこばせた婦人労働大臣ミス・ボンフィールドはどうなっただろうか。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が持っていたかも知れない小さい人道主義的な立場に立つ協調主義はけとばされて、地主資本家の利益のはっきりした擁護者保守党のネヴィル・チェンバーレンが労働大臣に任命されている。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギユイヨオ君（労働大臣）――その意見は今日も変更しません。",
              "citation": {
                "source": "仏国議会に於ける脚本検閲問題",
                "author": "――ゴンクウルの『娼婦エリザ』――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
