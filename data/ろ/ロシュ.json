          "literary": [
            {
              "text": "「よろしゅうございます。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしゅうございます、暁の祭までにはまだ間の時刻もございます。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやいや皆まで申されるな」　「では」となりひらが、Ｔ「この連判状は貴殿に進呈致すその代り」　と言って、Ｔ「但馬屋源兵衛を早速放免して戴きたい」　「よろしゅう御座る」と左衛門、　「では」となりひら連判状を其処へ置く。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりひらが、Ｔ「これを早馬で牢屋敷へ届けて戴き度いんだが」　よろしゅう御座ると左衛門。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯が食いてえな」　よろしゅう御座ると左衛門。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、失礼でございますが、お店へあがりましてもよろしゅうございましょうか」と、女は忍びやかに云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも御機嫌よろしゅう、結構でございます」「おお、お亀さんか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前もこんなことで食らい込んじゃあ嬉しくあるめえが、半七が見た以上は、まさかに御機嫌よろしゅう、はい左様ならと云うわけには行かねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは王様、ごきげんよろしゅう。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それではごきげんよろしゅう。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜巻は二人をおろして「さよなら、ごきげんよろしゅう」と云いながら風のように海に帰って行きました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（はい、よろしゅうございます、何事もおっしゃりつけは背きますまい。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よろしゅうござる。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな手あてをいたしたらよろしゅうございましょうか。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても恐ろしゅうて恐ろしゅうて、気が揉めて気が揉めて……という涙ながらの物語で、蔵元屋の内幕を洗い泄い喋舌って帰りましたが、イヤモウ肝の潰れるお話ばっかりで……」　松倉十内はここが大事と思ったらしく、眼を丸くしたまま点頭いた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よろしゅう御座います、それでは一つ戴きましょう。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヘイ、お話ししてもよろしゅうございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "女難といえばその時もう女難に罹っていたといってもよろしゅうございましょう。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "）舎利弗　――世尊、御機嫌はよろしゅう御座いますか。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お髪はこの通りの型でよろしゅうございますか。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしゅうござります。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた様はそのために、ご病気にさえおなりになったとの事でございましたが、もうおよろしゅうございますか」　親子のひばりは、たくさんおじぎをしてまた申しました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしゅうございます。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「よろしゅうございます。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は仕方なく、「ええ、よろしゅうございます。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
