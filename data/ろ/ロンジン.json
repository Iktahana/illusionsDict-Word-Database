  {
    "uuid": "0f906cbc-cee9-5bca-86c4-1913165d3374",
    "entry": "ロンジン",
    "reading": {
      "primary": "ロンジン",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Longines",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼はどこで借りてきたのか金ガワのロンジンの腕時計をつけ、上等のネクタイに真珠のネクタイピンをさしていました。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "六｜号室の第五｜番目は、元来郵便局とやらに勤めた男で、気の善いような、少し狡猾いような、脊の低い、瘠せたブロンジンの、利発らしい瞭然とした愉快な眼付、ちょっと見るとまるで正気のようである。",
              "citation": {
                "source": "六号室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "八｜月にアンドレイ、エヒミチは市役所から、少し相談があるに由って、出頭を願うと云う招状があった、で、定刻に市役所に行って見ると、もう地方軍令部長を初め、郡立学校視学官市役所員、それにドクトル、ハバトフ、またも一人の見知らぬブロンジンの男、ずらりと並んで控えている。",
              "citation": {
                "source": "六号室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、ブロンジンのドクトルは笑い出す。",
              "citation": {
                "source": "六号室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "院長は茫然とブロンジンのドクトルを見たが。",
              "citation": {
                "source": "六号室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "』それから続いて、ハバトフとブロンジンのドクトルとは下手なのを感じている試験官と云ったような調子で、今日は何曜日だとか、一｜年の中には何日あるとか、六｜号室には面白い予言者がいるそうなとかと、交々尋問ねるのであった。",
              "citation": {
                "source": "六号室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "急場をしのぐものと云えば、腕にまいたロンジンぐらいのものであった。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い盤面の、普通ならロンジンとかウォルサムとかあるべき場所にはハムレットという銘があった。",
              "citation": {
                "source": "汝自身を知れ",
                "author": "ベルンにて",
                "note": "青空文庫"
              }
            },
            {
              "text": "中尉遺愛のツワィス望遠鏡とロンジン夜光時計とだけは、懇請に任せ我ら一同よりの微意として、中尉の岳父たるべかりしメラニデス氏にこれを贈りました。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
