[
  {
    "uuid": "9c24f10d-a7ef-59be-8939-4f1529598674",
    "entry": "老臣",
    "reading": {
      "primary": "ろうしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "old or key retainer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "側に老臣が一人控えて居る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "老臣に「爺ッ」　ハッと老臣。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お殿様が、Ｔ「其の方」「娘があった喃」　と訊ねられた老臣。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　エッと老臣が訳の分らん顔。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿様が「分らん奴だＴ「其の方が、誰かに　斬られて死ぬのじゃ」　あの拙者が、と老臣「メッ、滅相も無い」　殿様が「イヤイヤＴ「心配致すな　其の方の娘に　立派な仇討を　させてやる」　老臣も呆れ果てた。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿様が嬉しそうに、Ｔ「女の仇討は　珍しいぞ」　老臣がイヤイヤ、Ｔ「御免蒙ります」　断わられて、お殿様、悲観した。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝橋の上――夜　お殿様と老臣と家臣が五名程川端を歩いて居る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「非人に迄、身を落し　さだめて辛いであろう」　とハラハラと落涙して、Ｔ「其の方の至孝　天に通ぜぬ　道理が無い」　と乞食の手を掴んで、Ｔ「仇討本懐の日を　祈り申すぞ」　と老臣に金子を包ませて、　それを乞食に与え、Ｔ「些少乍ら　余の志じゃ」　乞食はまるで、鳩が豆鉄砲を喰った形。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へ殿様と老臣連の御忍びが通り掛った。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "文六尚も苦しそうに、Ｔ「未だ、仇敵に　廻り逢わざるに　路用の金子は　尽き果てて」　殿様聞くより「アイヤＴ「皆迄申すな　泣けて来る」　と文六の手を握って、Ｔ「辛いで　あろう喃」　と言って、老臣を振り返って、それッと言う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿様も老臣も家臣も驚いた。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "老臣から何から隅から隅まで繃帯だらけ。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸老臣の深根｜固蔕の議をウフンと笑ったところは政宗も実に好い器量だ、立派な火の玉だましいだ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "金七の復命は政宗及び其老臣等によって注意を以て聴取られた。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "金七を退かせてから政宗は老臣等を見渡した。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、何様である、徳川殿の勧めに就こうかと思うが、といいながら老臣等を見渡すと、ムックリと頭を擡げたのが伊達藤五郎｜成実だ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は真に政宗が頼み切った老臣で、小十郎も剛勇だが智略分別が勝り、藤五郎も智略分別に逞しいが勇武がそれよりも勝って居たらしい。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると原田左馬介宗時という一老臣、これも伊達家の宗徒の士だが成実の言に反対した。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "政宗と家康と馬の合ったように氏郷と仲の好かった前田利家は、温厚にして長者の風のあった人で、敵の少い人ではあったが、それでも最上の伊白という鍼医の為に健康を危うくされて、老臣の村井｜豊後の警告により心づいて之を遠ざけた、という談がある。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は故郷の歴史をよく知らないが、かの元亀天正の時代には長曽我部氏がほとんど四国の大部分を占領していて、天正十三年、羽柴秀吉の四国攻めの当時には、長曽我部の老臣細川源左衛門尉というのが讃岐方面を踏みしたがえて、大いに上方勢を悩ましたと伝えられている。",
              "citation": {
                "source": "こま犬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "天正十六年十月四日、岡豊から大高坂へ移ったばかりで未だその城普請の最中であった領主の長宗我部元親は城中へ一族老臣を集めて家督相続の評定をした。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "親輿は長岡郡比江村日吉の城主で、長宗我部家の老臣の一人であった。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "相良は筑前の人間で義隆に仕えたが、才智人に越え、其の信任、大内譜代の老臣陶、杉、内藤等に越えたので、陶は不快に感じて遂に義隆に反して、天文十九年義隆を殺したのだ。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、元就、老臣共を集め座頭の聞くか聞かないか分らぬ位の所で、わざと小声で軍議を廻らし、「厳島の城を攻められては味方の難儀であるが、敵方の岩国の域主、弘中三河守は、こちらへ内通しているから、陶の大軍が厳島へ向わぬよう取計らってくれるであろう」と囁いていた。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてまたこの信行であるが、末森城に於て重臣林通勝、柴田勝家等に鞠育されて居たが、老臣共は信長の粗暴を嫌って信行に織田の跡を継せようと企てた。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "老臣岡本新兵衛は、士卒をして船で沿岸を偵察せしめるが、ほとんど、津々浦々が一揆である。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "老臣黒田｜睡鴎追い付いて諫めたので、鎧は着けたが、猶｜冑を冠らない。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時老臣の中で、當時｜道柏と名告つてゐた井上｜周防之房と、小河内藏允との二人が、忠之の袂に縋つて、それは餘り輕々しい、江戸へ聞こえても如何である、利章をば我々が受け合つてどうにも處置しよう、切腹させよとなら切腹もさせようと云つて諫めた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
