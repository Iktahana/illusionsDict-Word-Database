    "definitions": [
      {
        "index": 1,
        "gloss": "crest of the Sanada clan (featuring six sen coins, trad. to pay for crossing the Sanzu River)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "死人に六文銭を添へて葬るのが古来の習である。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その六文銭のある間、母はわが子を養育するために毎日一文づつの飴を買つてゐたのであるが、けふは六日目でその銭も尽きた。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸村槍を駢べて迎え、六文銭の旌旗、甲冑、その他赤色を用いし甲州以来の真田の赤隊、山の如く敢て退かず。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、庭に出て、白河原毛なる馬の逞しきに、六文銭を金もて摺りたる鞍を置かせ、ゆらりと打跨り、五六度乗まわして、原に見せ、「此の次ぎは、城｜壊れたれば、平場の戦なるべし。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "内には、六文銭の旗三四｜旒、朝風に吹靡いて整々としていた。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭占判断といって、六文銭で吉凶禍福を占うその次第書を、駿河半紙二切り六枚綴の小本に刷って、それを町の盛場で一冊三銭に売るのだ。",
              "citation": {
                "source": "世間師",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓地に六文銭の紋章を刻んだ大名の墓がいくつも倒れてゐる寺である。",
              "citation": {
                "source": "枯葉の記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓地に六文銭の紋章を刻んだ大名の墓がいくつも倒れている寺である。",
              "citation": {
                "source": "枯葉の記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "右女助も若手で目をパチパチと「六文銭」を聴かせてくれた。",
              "citation": {
                "source": "寄席行燈",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "在りし日と姿かわった司馬先生は、経かたびら、頭巾、さらし木綿の手甲脚絆をまとい、六文銭を入れたふくろを首に、珠数を手に、樒の葉に埋まっている。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな小さい六文銭があるものか、それは賽の目の六だよ」「賽の目にしちゃ大き過ぎはしませんか、豆粒ほどの大きさですぜ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌を押し脱ぐと、背筋を真ん中にして、左右へ三枚ずつ、真田の紋のように、六文銭の文身、これは何となく気がきいておりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お珊文身調べ",
                "note": "青空文庫"
              }
            },
            {
              "text": "背中へ藍墨で、六文銭を描いて行ったが、濡れ手拭で拭くと、綺麗に消えるよ」「ヘエ――」「すると親分の文身はペテンだったんですね」　とガラッ八。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お珊文身調べ",
                "note": "青空文庫"
              }
            },
            {
              "text": "わっしの背中へ六文銭を描いてくれた、人形町の彫辰の顎を探ったら、大方女の住家の当りが付きましょう、御免」　平次はフラリと八丁堀の役宅を出ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お珊文身調べ",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、そこの川を渡るったって、十六文銭がいるんだ、それを一文なしでどうするんだい。",
              "citation": {
                "source": "一本刀土俵入　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
