          "literary": [
            {
              "text": "いちばん奥の台で、ラリー・デイヴィスが常連を相手にローテーションをしていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、輸送員のローテーションを二十四時間休みなしで組む必要上、たいていの輸送員は、一週間をふたつに分けて、休まなくてはならない。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "輸送員全員のローテーションを考えに入れなくてはならないから、それは駄目だという。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
