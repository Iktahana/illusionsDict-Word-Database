[
  {
    "uuid": "3925d472-d84a-5623-b154-07a3b973099f",
    "entry": "ロス",
    "reading": {
      "primary": "ロス",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
