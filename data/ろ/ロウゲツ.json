        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "臘月みふゆの火すばるを高み、　　のど嗽ぎあるじ眠れば、千キロの氷をになひ、　　　　かうかうと水車はめぐる。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その麗かな臘月の午前へ。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『長崎ぶり』　　　　　例言一、本集に収めたる六章約百二十篇の詩は明治三十九年の四月より同四十一年の臘月に至る、即最近三年間の所作にして、集中の大半は殆昨一年の努力に成る。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "臘月の十九日、丑満の夜の館。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "同三十九年の四月から四十一年の臘月に至る約三年間の所作を収めたもので、私の初期の象徴詩その他を代表した集であつた。",
              "citation": {
                "source": "「白秋詩集」第二巻解題",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化十一年の元旦は臘月願済の湯治日限の内であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "折ふし延宝二年｜臘月朔日の雪、繽紛として六美女の名に因むが如く、長汀曲浦五里に亘る行路の絶勝は、須臾にして長聯の銀屏と化して、虹汀が彩管に擬ふかと疑はる。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自らを愛づるこころに準らへてしら梅を嗅ぐ臘月の人　早く十二月に咲いた白梅の花の香を自分自身を賞美すると云ふのに近い気持ちで嗅いで居る。",
              "citation": {
                "source": "註釈與謝野寛全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒きは寒き臘月の――過ぎしはゆきし日のごときその間も一人われをおもふ、世はみな忘れはつるともなほ一人のみわれを憶ふ。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま黄生臘月のすゑ故郷に帰りぬ。",
              "citation": {
                "source": "『聊斎志異』より",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "延慶元年｜臘月、七十四を以て示寂。",
              "citation": {
                "source": "南浦紹明墨蹟",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "時維昭和廿二年歳次｜丁亥臘月の某日である。",
              "citation": {
                "source": "葛飾土産",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十七年臘月下浣函嶺強羅にて",
              "citation": {
                "source": "和紙十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "するうちに季節は早くも臘月（十二月）のはじめ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて予は今、臘月の末日に際してつくづく生の虚無なるを思ふ。",
              "citation": {
                "source": "落葉",
                "author": "レミ・ドゥ・グルモン　Remy de Gourmont",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近私の見た東北大学の図書館にある一本のごときは、書名を『鬼三太残齢記』と称し、序文に歳は重光大康落にある臘月十日とあって、仙台の城下で人の話を筆記したといっている。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
