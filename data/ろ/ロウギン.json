[
  {
    "uuid": "a7486222-56a5-51fc-be5b-63efb8c0487b",
    "entry": "労銀",
    "reading": {
      "primary": "ろうぎん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wages",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "被告一人の力では労銀の上げ下げをどうすることも出来ない事であるのだから。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働時間の制定、労銀増額、公休日、出帆、入港は翌日休業、公傷、公病手当の規定及び励行、深夜サンパン不可、などが乱雑に書かれてあった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "要求条件は、労働時間と、労銀増額と、公傷病手当の三つは完全に利害をファヤマンの方と一致した。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫らは、自分らに酬いられる、労銀は何であるか？",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は、サイパンの店の一隅に巌丈な錠前をとりつけた銭箱を備へて、酒樽到着の夢を見ながら、漁りの業人は海原へ、牛飼等は山向ふの牧場へ、小作家は田畑へ、皆々孜々として仕事に励み、一日の労銀を携へて帰る夕暮時に、その幾部分かをサイパンの箱へ投げ入れてバツカスを祈つた。",
              "citation": {
                "source": "酒盗人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対して、物価調節、各家庭に対する節約宣伝のような、やや消極的方面の問題、また積極的には女性の自給自立、労銀等の問題から、根本に近い、社会主義上の諸問題が、惹起されます。",
              "citation": {
                "source": "男…は疲れている",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばしば例に引く科学主義工業の主唱者は、高賃銀低コストを目標としているのであるが、本年の春、ある村で作業場の賃銀が村の労銀の水準に対して高すぎるという苦情が出たことが報告されている。",
              "citation": {
                "source": "新しい婦人の職場と任務",
                "author": "――明日の婦人へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の労銀というのは恐らく従来の救済工事の日当や日傭労働賃銀（女三十五銭ぐらい）を標準にしてのことであったろう。",
              "citation": {
                "source": "新しい婦人の職場と任務",
                "author": "――明日の婦人へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ意外な苦情を受けた専門家たちは「労銀が多すぎる為に起る弊害について大いに考えさせられた。",
              "citation": {
                "source": "新しい婦人の職場と任務",
                "author": "――明日の婦人へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、それに対する賃銀となると村の標準、しかも村の女の労銀との比較で問題になって、結局彼女たちの労力に対する報酬としては全く未熟練な日傭娘に等しいものを受けなければならなくなって来る。",
              "citation": {
                "source": "新しい婦人の職場と任務",
                "author": "――明日の婦人へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それはお婆さんが近所の使い走りや洗濯をして、僅かに得た労銀なのだった。",
              "citation": {
                "source": "雨の回想",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また或人たちが各種にわたる家庭の内職を紹介して婦人や小児に奨励されるのを見ると、その労銀の余りに低いことや、その仕事の余りに人間を過労させることや、殊に幼年期の子女までを昼夜にわたって時間の制限もなく座職の中に虐使することやについて、経済的、倫理的、人道的の顧慮が全く払われていないのです。",
              "citation": {
                "source": "婦人指導者への抗議",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "労銀、利子、企業所得……「一家の管理。",
              "citation": {
                "source": "たね子の憂鬱",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "社外の苦力の労銀は大抵一日四十銭であるが、彼等の一日の食費は十銭内外で足ると云ふ事である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東州に資料の硅石が豊富にあること、及び労銀の低廉なことが此地に工場の起つた理由であるが、製品は内地向きより主として支那向きの物である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "苟くも人格を有するものには、経済学の教える労銀論は決して当を得たとはいわれぬことが多い。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八九　以上の如くであるから、企業者は、原料を他の企業者から購い、地代を支払って土地所有主から土地を賃借し、労銀を支払って労働者の人的能力を賃借し、利子を支払って資本家の資本を賃借し、最後に生産用役を原料に適用し、得られる生産物を自分の計算で販売する所の人（個人または会社）である。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "印刷工は労銀が高い、一時間三ドルくらいが普通であるから、大いに痛いわけである。",
              "citation": {
                "source": "校正の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって印刷工の労銀も、高くなるわけである。",
              "citation": {
                "source": "校正の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう荷揚人足等の或る組は仕事を終つて其の日の労銀を受取つて、そこらの寄りつけの酒場へてんでに押しかける頃だつた。",
              "citation": {
                "source": "煤煙の臭ひ",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他の労銀は何とか理窟をつけて、権蔵部屋の主人が捲き上げてしまつた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（一デナリは当時労働者一日分の労銀で、英貨八ペンス半ないし七ペンス半、邦貨では平価三十四銭ないし三十銭くらいにあたる。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "前二つは労銀の制度に伴う悪、後二つは個人の作家に伴う罪。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働は協団の組織を去って、労銀の制度に転じた。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「農村の労銀は大体に於て今日は大都市の三分の一である。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も三倍の労銀を得る大都市の労働者の方が、生活は却って遙かに困難であって、半農半工の農村の方が遥かに恵まれている。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで驚いたのは例の二万余の登録労働者の諸君であった、早速代表三十名を先頭に約百名の者が即日市庁に押しかけて牛塚市長に面会し、労銀値下げ反対その他の要求を含む要求書を提出して陳述する処があった。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子の労銀は男子より安く、一週間男子が二十円ならば女子は十円で宜しいという割合である。",
              "citation": {
                "source": "婦人問題解決の急務",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵、今まで、この姫君から命ぜられた課役に対し、それを完全に仕遂げた時は、通常の労銀の二倍は下し置かれることが例になっているから、迷惑の色は、報酬の艶を以て消し去らるるのを例とする。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
