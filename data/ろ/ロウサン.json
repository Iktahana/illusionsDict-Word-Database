        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その寺は庭が広く、背後に老杉の茂った林があったので、彼の瞑想的な散歩に最も好ましい所であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の小屋の上に聳えた美しい老杉までが其爲に物凄く恐ろしく無氣味なものに感ぜられた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小屋の上にそびえた美しい老杉までがそのために物すごく恐ろしく無気味なものに感ぜられた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上まで殆ど一直線に付けられた巌石の道で、西側には老杉亭々として昼なお暗く、なるほど道の険しい事は数歩｜前の巌角の胸を突かんばかり、胸突き八丁の名も道理だ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "去って日枝神社に詣でると、境内に老杉多く、あわれ幾百年を経たかと見えるのもあった。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "料亭と旅館を兼ねた家であって、老杉に囲まれ、古びて堂々たる構えであった。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老杉の陰から白い浴衣を着た小さい人が、ひょいとあらわれた。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌障子にすずろにひびく筬の音山辺の春はすでに動きぬ山かげの懸樋の縁の紐氷柱本末ほそうなりにけるかも造り酒屋の歌水きよき多摩のみなかみ、南むく山のなぞへ、老杉の三鉾五鉾、常寂びて立てらくがもと、古りし世の家居さながら、大うから今も居りけり。",
              "citation": {
                "source": "海阪",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌柿｜双樹　梅｜五三本　この庭のさましづかなり小雨流らふ多摩の浅春造り酒屋の歌水きよき多摩のみなかみ、南むく山のなぞへ、老杉の三鉾五鉾、常寂びて立てらくがもと、古りし世の家居さながら、大うから今も居りけり。",
              "citation": {
                "source": "篁",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから順慶自身は、光秀の勧誘に、心うごいたが、家老杉倉右近、島左近の二人が主人を諫めて出陣せしめず、ただ人数だけを山崎の対岸なる八幡の洞ヶ峠に出した。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて神林伐採の許可を得たるが、その春日社趾には目通り一丈八尺以上の周囲ある古老杉三本あり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "また野中王子社趾には、いわゆる一方杉とて、大老杉、目通り周囲一丈三尺以上のもの八本あり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "十間四方の本堂、仁王門をひかへ、觀音堂をひかへ、一切經藏をひかへ、鐘樓をひかへて、老杉の森の中に、燦然として光る。",
              "citation": {
                "source": "鹿野山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "築山をひかへ老杉に圍まれて、瀟洒にして間寂、別天地中の別天地也。",
              "citation": {
                "source": "鹿野山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　鳥居崎鳥居崎にも、老杉の下に掛茶店あり。",
              "citation": {
                "source": "鹿野山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "神野寺の老杉、雲を呼びて、夏あるを知らず。",
              "citation": {
                "source": "鹿野山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "老杉、石壇を狹み、左右にひろがる。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "提燈の光をたよりて、老杉の中の石段を上る。",
              "citation": {
                "source": "箱根神社祈願の記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "圓錐丘を中心にして、五百年外の老杉繁り、丘上に念の入りたる淺間祠を安んず。",
              "citation": {
                "source": "石田堤",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "古檜老杉欝として、百餘級の石磴を夾む。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "家隆卿の植ゑたりと稱する老杉最も偉大也。",
              "citation": {
                "source": "白河の關",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "殷紅血を流すが如き夕燒の空を背にして進みゆくほどに、暮靄、乾坤を封じて、老杉の下の小路くらく、燈を點ずる頃、鹿野山宿に達す。",
              "citation": {
                "source": "房州紀行",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "崛起せる丘上、千年の老杉森々として、神さび立てる一宇の古龕、神鈴音なく、樓門の矢大臣も寂しげなり。",
              "citation": {
                "source": "北總の十六島",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "老杉しげりて、古色一層掬すべし。",
              "citation": {
                "source": "房州の一夏",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "高峯には、三百級の石磴ありて通じ、全體に老杉しげる。",
              "citation": {
                "source": "房州の一夏",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "農科大學の植林も盛んにして、樹木しげり、峯容秀拔、眺望もよく、げに房州第一の靈山、堂前老杉の偉大なること、天下有數也。",
              "citation": {
                "source": "北條より一ノ宮へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "老杉を通して城山の今を盛りの櫻を左に見、右に三峰川の蒼い水を見る、凉しい風が額の汗を吹いて、青草の匂ひが肌に沁む心地である。",
              "citation": {
                "source": "伊那紀行",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふくろうさん、ふくろうさん。",
              "citation": {
                "source": "物のいわれ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、たろうさんが　ききました。",
              "citation": {
                "source": "三人と　二つの　りんご",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、たろうさんが　いいました。",
              "citation": {
                "source": "三人と　二つの　りんご",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
