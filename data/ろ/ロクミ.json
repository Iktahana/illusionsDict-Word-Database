        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "池田菊苗博士が、古来いわれている五味、すなわち甘・酸・鹹・苦・辛の五つの味をどう組合せても、うまいという味は出てこない、うまいというのは第六味である、と喝破されたのは、たしかに卓見である。",
              "citation": {
                "source": "犬がなくとガラスがこわれるか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "をんなのはだかをならべたやうなばかにしろくみえる森のうへに、ひらひらと紙のやうに坊さんはとんでいつた。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、役人にならないで、ほんとうに自由で、ほんとうのひとりだちの生活とは、こういうものだと、せけんの人々に、ひろくみせてやりたいとおもうのだ。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏のその時刻は客の数もまばらで、そのせいか、がらんとした店内がよけいひろくみえる。",
              "citation": {
                "source": "十三年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上の二三の例からいっても、女性史研究の意義はひろくみとめられてよいものであり、ねがわくは同学者の輩出参加によって、新史学建設に寄与したいと思う。",
              "citation": {
                "source": "女性史研究の立場から",
                "author": "高群逸枝",
                "note": "青空文庫"
              }
            }
          ]
        }
