[
  {
    "uuid": "86aae0a2-d60d-5d77-a8e5-8eb2ba1a50cb",
    "entry": "露呈",
    "reading": {
      "primary": "ろてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
