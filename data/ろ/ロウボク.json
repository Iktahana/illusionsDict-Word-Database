    },
    "definitions": [
      {
        "index": 1,
        "gloss": "old tree",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "寂しさや華のあたりのあすならふ「あすは檜の木とかや、谷の老木のいへることあり。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑とも庭ともつかない地面には、梅の老木があったり南瓜が植えてあったり紫蘇があったりした。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらみな樫の老木を楯にしてその陰にうずくまりぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど路傍なる梅の老木のみはますます栄えて年々、花咲き、うまき実を結べば、道ゆく旅客らはちぎりて食い、その渇きし喉をうるおしけり。",
              "citation": {
                "source": "詩想",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にも省みられないけれども、春が来るごとに黙って葉を連ねているあの楡の大樹、あの老木が一度でも分外な涙を流したか。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "口碑から云へば百五十年以上の老木である。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "今彼は自然に此老木の下に立つた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼馴染の老木であるからの親しみでなく、此の心が彼の心に流れ込んだ神会の懐かしみである。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はふてぶてしい心になつて、老木の下を離れて親様の方へと足を進めた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちかきころ水無月中旬、二十日余り照り続きたる、けふ日ざかりの、鼓子花さへ草いきれに色褪せて、砂も、石も、きら／＼と光を帯びて、松の老木の梢より、糸を乱せる如き薄き煙の立ちのぼるは、木精とか言ふものならむ。",
              "citation": {
                "source": "紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏畑の三本、前の家の二本、いずれも老木、満開のころは、一人で観るのにもったいないほどであった。",
              "citation": {
                "source": "三八九雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "欽明寺峠は峠としては何でもないが何しろ長い、秋草、虫声がよかつた、萩の老木は口惜しいほど欲しかつた。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "見上げると梅の実をたたき落されたあとの梅の老木が、杏平の上に一ぱい枝をひろげてゐた。",
              "citation": {
                "source": "登つていつた少年",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "植物にしても若い木は隨分甚だしい傷を負うても直に癒るが、老木が少し傷を負ふと、動もすれば枯れたがる。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるも老木の春寒しとや、枝も幹もただ日南に向いて、戸の外にばかり茂りたれば、広からざる小路の中を横ぎりて、枝さきは伸びて、やがて対向なる、二階家の窓に達かんとす。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "六百年の久しき後にまで人の肩になまめかしくしなだれかゝる老木の桜の一念を見るにつけ、手植の主の少女の、否、なべての女の永劫に見果てぬいのちの夢が今更に想い遣られます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水屋口に山椒の木が在りましたがあまりの老木なので葉は僅か許りしか出ませんでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに引きかえこの劇場わきの老木の新芽というものは脆弱で辛味もこっくりしているのだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文吉が山椒の葉を採るのに橋に近い清光寺の卵塔場にも行かず、製紙工場の社宅にも行かず、遥かに遠いこの劇場まで来るのは老木の山椒の葉のうまさを知ってのことゝしか思われない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其壁を越して、桑樹の老木が繁り、壁の折り曲つた角には幾百年經つか、鬱として日影を遮つて居る樫樹が盤居つて居ます。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭には無論｜朱欒の老木が十月となれば何時も黄色い大きな実をつけた。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "春はどうにものびやかでの、老木の藤の花房までが、揺れてゐたといの。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の日胡桃の老木ながめつつ、けふも胡桃をわりゐたり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "營庭の老木の櫻過ぎにけりわれは立ちつくす光る眞土に立ち待つと心澄みゐる晝さなか兵あらはれて來り列竝むわが前に歩兵第三聯隊竝び立ち隊歌うたふと聲大いにあがる葉ざくらは風やや強し耳とめて宮の御聲を聽きまつらくは夜宴あり。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなあはれ老木の二木、親しくも並ぶ姿の、寂しくも隣り合ふ木の、頼り無き二木を見れば涙しながる。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にそれが老木になったほど喬く、また鬱蒼と張っている。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し離れて左手にまた一本の、それは最も完全な老木の楡が涼しい繁りをそよがしていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "営庭の老木の桜過ぎにけりわれは立ちつくす光る真土に立ち待つと心澄みゐる昼さなか兵あらはれて来り列竝むわが前に歩兵第三聯隊竝び立ち隊歌うたふと声大いにあがる葉ざくらは風やや強し耳とめて宮の御声を聴きまつらくは夜宴あり。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなあはれ、老木の二木、親しくも並ぶ姿の、寂しくも隣り合ふ木の頼り無き二木を見れば涙しながる。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
