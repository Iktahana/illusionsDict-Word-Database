    "definitions": [
      {
        "index": 1,
        "gloss": "six feet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　見習は、六尺位の仁王様のように怒った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ろよ、三尺鑿よりゃ六尺鑿の方が、先細と来てやがら」　小林は、鑿の事だと思って、そんな返答をした。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オイ、もう五尺は入っただろう」　ガラガラッとハンドルを廻しながら、六尺鑿を抜き出した。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋敷の西側に一丈五六尺も廻るような椎の樹が四五本重なり合って立って居る。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」父は稲束を荷って帰った六尺棒を持ってきて、三時間ばかり、牛をブンなぐりつゞけた。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞍は毀れ、六尺は折れてしまった。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊は、夢中に、六尺の塀をよじのぼった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "醤油袋一枚、縄切れ五六尺でさえ、労働者が塵の中へ掃き込んだり、焼いたりしていると叱りつけた。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と曖昧に塩入れ場の前に六尺の天秤棒や、丸太棒やを六七本立てかけてある方に顎をちょいと突き出して搾り場を通り抜けて行ってしまった。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ体が凌ぎよくなったために足の弱も忘れたので、道も大きに捗取って、まずこれで七分は森の中を越したろうと思う処で五六尺｜天窓の上らしかった樹の枝から、ぼたりと笠の上へ落ち留まったものがある。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "向う岸はまた一座の山の裾で、頂の方は真暗だが、山の端からその山腹を射る月の光に照し出された辺からは大石小石、栄螺のようなの、六尺角に切出したの、剣のようなのやら、鞠の形をしたのやら、目の届く限り残らず岩で、次第に大きく水に※ったのはただ小山のよう。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山土のいろもあかく見えたる、あまりうつくしさに恐しくなりて、家路に帰らむと思う時、わが居たる一株の躑躅のなかより、羽音たかく、虫のつと立ちて頬を掠めしが、かなたに飛びて、およそ五六尺隔てたる処に礫のありたるそのわきにとどまりぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "手をあげて走りかかれば、ぱっとまた立ちあがりて、おなじ距離五六尺ばかりのところにとまりたり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような人には時や空間はただ自分の周囲、たとえば方六尺の内に限られた、そして自分といっしょに付随して歩いて行くもののようにしか考えられぬのかもしれぬ。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人は六尺もある筆の先へちょっと絵の具をくっつけて、鳥でも刺すようにして一点くっつけてはまたながめて考え込むというのである。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六尺の筆を使う意味が少しわかりかけたのである。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしか六尺も上にあったら、せっかく花の用意をしてもなんの役にも立たないであろう。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐禅寺では、北上川が一丈六尺増したと誰かが云ひました。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "われその故を解し得ず、ただ見る六尺ばかりの大男の影おぼろなるが静かに事務室の中に消え去りしを。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが可厭ならお止しだけれど、極った人が出来た上は、片時も、寝衣で胡坐かいた獣なんぞ、備前焼の置物だって身のまわり六尺四方は愚なこと、一つ内へは置けないから、即座帰れ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶屋の際の葉柳の下枝を潜って、ぬっくりと黒く顕われたのは、鬣から尾に至るまで六尺、長の高きこと三尺、全身墨のごとくにして夜眼一点の白あり、名を夕立といって知事の君が秘蔵の愛馬。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は此処でも後になり先になり、脚絆の足を入れ違いに、頭を組んで白波を被ぐばかり浪打際を歩行いたが、やがてその大きい方は、五、六尺｜渚を放れて、日影の如く散乱れた、かじめの中へ、草鞋を突出して休んだ。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、また直ぐに、近常さんが、人の顔と頭の間で、ぐっと鶏の蹴爪を圧えたんですってね、場合が場合だもんだから、何ですか……台の車が五六尺、ひとりでにきりきりと動出すのに連れられて、世に生れて、瞳の輝く第一番に、羽搏き打って、宙へ飛ぼうとする処を、しっかり引留めたようでしたとさ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして、男女は、台石の巌ともに二丈六尺と称するその大銅像の下を、一寸ぐらいに歩行いていた。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "島田の鬢の白い顔が、宙にかかり、口で銅像の耳を噛んで踏辷る褄の紅を、二丈六尺、高く釣りつつ、鏨を右の目に当てて、雪の腕に、拳銃を、鉄鎚に取って翳した。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づくと、「あッ、」　思わず、忍音を立てた――見透す六尺ばかりの枝に、倒に裾を巻いて、毛を蓬に落ちかかったのは、虚空に消えた幽霊である。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝々のなかの水田の水がどんよりして淀んでいるのに際立って真白に見えるのは鷺だった、二羽一ところに、ト三羽一ところに、ト居て、そして一羽が六尺ばかり空へ斜に足から糸のように水を引いて立ってあがったが音がなかった、それでもない。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三方に壁を塗りて、六尺の開戸あり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」「血」「血」「血」と貴婦人方は鸚鵡返し、皆五六尺｜飛退る。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それから、あの、」　小指を折って、「吹雪の熊太、韋駄天弥助、書生の源、あの、太い声で、六尺坊の悪右衛門っていったんです。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
