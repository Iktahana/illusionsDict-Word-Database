        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "重兵衛さんは自分の心にファンタジーの翼を授け、自分の現実世界の可能性の牢獄を爆破してくれた人であった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の眼は牢獄の壁で近視になっていた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）牢獄　源兵衛がいる。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも自分が長いこと都會の中か、それとも牢獄の中に暮らしてでもゐたかのやうに。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は青い窓から、マルセーユ岸壁の遙かに淡く浮き出た神秘なシャトウ・ド・ディフの牢獄の島を眺めているうちに、故国の姉を憶い出して感傷的になっていました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、冷酷な牢獄の感じが、たゞよっていた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪なくして、薄暗い牢獄に投じられた者が幾人あることか！",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後は降り止んだが晴れさうにもせず雲は地を這ふようにして飛ぶ、狹い溪は益々狹くなつて、僕は牢獄にでも坐つて居る氣。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦場は、「一兵卒」の場合では、大なる牢獄である。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は、一度そこへ這入ると、いかにもがいても、あせっても、その大なる牢獄から脱することが出来ない。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『牢獄の五月祭』の持つ魅力が他の小説の光りを消すのだ。",
              "citation": {
                "source": "「青空語」に寄せて（昭和二年一月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して屈静源は有司に属して追理しようとしたから、王廷珸は大しくじりで、一目散に姿を匿してしまって、人をたのんで詫を入れ、別に偽物などを贈って、やっと牢獄へ打込まれるのを免れた。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "拷問の後にほうり込まれた牢獄の中で眼前に迫る生死の境に臨んでいながらばかげた油虫の競走をやらせたりするのでも決してむだな插話でなくて、この活劇を生かす上においてきわめて重要な「俳諧」であると思われる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは其大望の成就の爲めには牢獄に投げ入れられる事を前から覺悟してゐた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢獄生活の空想は度々彼れの頭に釀された。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢獄も如何する事も出來ない孤獨と、其孤獨の報酬たるべき自由とが、暗く、冷たい、厚い牢獄の壁を劈いて勝手に流れ漂ふのを想像するのは、彼れの一番快い夢だつた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢獄はこんな親しみのある場面を彼れの眼から遠けるだらう。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは彼れの孤獨の自由を使つて、牢獄からこの井戸の傍に來る事が出來るであらうか。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は嘗て牢獄に行くことを一つの栄誉とも思ひ、勇士が戦場に赴くが如き勇しさを想見したこともあつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が斯うして牢獄の苦を嘗めて居ることはむしろ誇るべきことなのではあるまいか。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで彼の運命は一旦定まったのであるが、間もなく病気にかかったという牢屋医者からの届け出があったので、その仕置は来春まで延期されて、かれは暗い牢獄のなかで天保六年の春を迎えた。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一回以来、かれは前後十八回の拷問をうけながら遂に屈伏しないというのは、伝馬町の牢獄が開かれてから未曾有のことで、拷問に対して実に新しいレコードを作ったのであるから、かれは石川五右衛門の再来として牢内の人気を一身にあつめた。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭は牢獄だ、とは思わないが、家庭は沙漠である、と思わざるをえない。",
              "citation": {
                "source": "砕けた瓦",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "深い井戸からか、それとも溜息の橋のそばの牢獄からか、一つの溜息が聞えてきます。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあいだ、わたしは牢獄の建物を見おろしました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、わたしは牢獄の格子の中をのぞいてみました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にまたその時以来、僕は物質の窮乏などというものが、精神の牢獄から解放された自由の日には、殆んど何の苦にもならないものだということも、自分の生活経験によって味得した。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "學校の社會そのものが、彼には呪ふべき最惡であり、その殺風景なる建物は、彼を苦しめる牢獄の如く思はれた。",
              "citation": {
                "source": "非論理的性格の悲哀",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、騎士城や、引上げ橋や、城内のろうごくの話を読んだり、アフリカ奥地の探検の話を聞いたりしました。",
              "citation": {
                "source": "家じゅうの人たちの言ったこと",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞窟のろうごく　そのとき、賢吉少年は、洞窟の中のろうごくにおしこめられていました。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
