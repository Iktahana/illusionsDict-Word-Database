[
  {
    "uuid": "a33b8d9c-3280-5684-835b-3eb796f8bd8b",
    "entry": "炉利",
    "reading": {
      "primary": "ロリ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "prepubescent girl",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "極く田舎の、孝行息によくある、不整で毛の長い眉を持ち、学校に少しでも関係のある者を見る時はその下の黒い瞳がキロリと動いた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず雨戸をしめて後に寝床へはいるとチンチロリンの声が聞こえなかった。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この外、近頃多く用いらるるエレクトロリチック・デテクターというのがある。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち発信器の方では不断に規則正しい波を送りそのアンテナに電話の送話器を接続し、受信器には前述のエレクトロリチック・デテクターを用うればよいのである。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最早それはいひツこなしとゝめるも云ふも一筋道横町の方に植木は多しこちへと招けば走りよるぬり下駄の音カラコロリ琴ひく盲女は今の世の朝顔か露のひぬまのあはれ／＼粟の水飴めしませとゆるく甘くいふ隣にあつ焼の塩せんべいかたきをむねとしたるもをかし。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京へ着いて酒保が一日開かれたので、早速一本二十銭のヨーカン五本買ってペロリと平らげて、まだ食いたい気がします。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次がソッと五郎蔵に囁く、Ｔ「もてますね」　「いや、其れ程でもない」顔の相を崩して得意がる五郎蔵の助平面がジロリと横目で睨んだ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「こんな極楽はない」　老人の悲痛な叫び聞いては、雪枝もホロリとせざるを得ません。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　半次、ジロリと仲蔵を睨み、Ｔ「何から何まで　俺の先生そっくりだァ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ジロリと、進藤等の方一睨して又群衆に向って、Ｔ「むかつく奴　居ないのか？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々五郎蔵の方ジロリと見ては、嬉しそうに笑って居る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "主膳、近侍を呼び止めて、Ｔ「門前にふんぞり七兵衛と申す御用聞がうろうろ致して居る」　と言ってなりひらの方をジロリと睨んで、Ｔ「その七兵衛に斯う申せ」　と言って、Ｔ「お尋ね者のなりひら小僧が拙宅に忍び込んだ」　えッ、となりひら油断なく大刀を掴む。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫く立つてから、この奥様はたしかに故人ペエテル様の奥様で、カロリイネ様だと極めた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "カロリイネ様には、丁度三十年｜前に鹿の肉を差し上げた筈である。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで次に皿を差し出す檀那は誰様だらうと思案したが、これはカロリイネ様の御亭主でペエテル様だと極めた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤色のテロリズムが東西の紡績工場を襲ったのが午後七時、黄埔軍官学校の軍艦飛鷹から飛行機が一台、上海の空に火薬庫を装置した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "上海に於けるガロン、チルキンス、陳独秀等の赤色テロリズムの敢行によって二十世紀の支那の赤い花が散り落ちた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひる間商品窓に飾ってあった、マルセーユの歌劇女のきるような華美な衣裳をつけて、白い羽根のついた黒い帽子を目深にかぶり、ネロリ油の強烈な蠱惑的な香をさしてサーカスの女のようなミサコは高慢な夜を感じていた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――じゃ妾、ここを出てフロリダで一踊りしてから帰っていますわ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "此處らでゴロリとやつちまひたいな‥‥」「全くだ。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、――寢てはならん‥‥と、一｜所懸命に考へてはゐながら、何時の間にかトロリと瞼が落ちて、首がガクリとなる。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　トロリとした間に鶴見も神奈川も過ぎて平沼で眼が覺めた。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間、兵士達は、意識的に、戦争を忘れてケロリとしようと努めるのだった。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "啓一は彼の膝に腰かけて、包んだ紙を拡げては、小さい舌をペロリと出してザラメをなめた。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケロリとして睡ってやがる。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚ジロリと伝六をにらんだ。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "といった時には、その赭い頬に涙の玉が稲葉をすべる露のようにポロリと滾転し下っていた。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
