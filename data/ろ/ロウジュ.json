[
  {
    "uuid": "1aaff75f-1979-5ee5-b538-2c8b46a05ec8",
    "entry": "老儒",
    "reading": {
      "primary": "ろうじゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
