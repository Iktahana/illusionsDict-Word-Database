    "definitions": [
      {
        "index": 1,
        "gloss": "route (bus, train, air, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
