    "definitions": [
      {
        "index": 1,
        "gloss": "textbook of Buddhist treatises (containing interpretation of the sutras)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "勿論書を讀んで深く考へたら、道に到達せずにはゐられまい。",
              "citation": {
                "source": "寒山拾得",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論書いて見ない内は、どんなものになるやら分らない。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「無論書きますよ、然し僕は現在では書く気がしません、私は暫く自分の生活を瞶めた後で、ほんとうに書いたといふ気持が自分の胸にドサンと響く様なものを……」「飽までも体験に待つ。",
              "citation": {
                "source": "眠い一日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論書斎の空想で、実行する意があったとも思われなかったが、計画は頗る科学的であった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "包世臣は書のことには精苦に思ひを費した人であつて、其論書を讀むと、極めて綿密に研究をした事が分る。",
              "citation": {
                "source": "北派の書論",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "というよりはむしろほとんど忘れ果てて、社会評論とも文学評論ともつかない妙な評論書きになってしまった。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲學においては、概論書から入ることを必ずしも必要としないし、またそれが必ずしも最善の道でもないのである。",
              "citation": {
                "source": "哲學はどう學んでゆくか",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは概論書を讀むよりももつと大切なことである。",
              "citation": {
                "source": "哲學はどう學んでゆくか",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり概論の名に拘泥して、先づ概論書に取り附いてこれを物にしなければならぬといふやうに形式的に考へる必要はないのである。",
              "citation": {
                "source": "哲學はどう學んでゆくか",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "概論書や入門書の如きものは多く出てゐるが、かうした形でなくて、それを辞書の形で書くことを企てるのも面白からう。",
              "citation": {
                "source": "辞書の客観性",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もこちらへ来ましてから半月にもなりますが、まだ本当におちついて物を考へることは勿論書くこともよむことも出来ないしまつです。",
              "citation": {
                "source": "九州より",
                "author": "――生田花世氏に",
                "note": "青空文庫"
              }
            },
            {
              "text": "又警視庁の活躍としては、銀行の一件だのカフェー・ユートピアの出来事などは無論書いてある筈がない。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し談論書記する計りで、自からその事に当ろうと思わぬその趣は、恰も診察医が病を診断してその病を療治しようとも思わず、又事実に於て療治する腕もないようなものでしょうが、病床の療治は皆無素人でも、時としては診察医も役に立つことがある。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや彼の西洋諸大家の理論書を窺い、有形の物理より無形の人事に至るまで、逐一これを比較分解して、事々物々の原因と結果とを探索するにおいてをや。",
              "citation": {
                "source": "旧藩情",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってそれは世に行われる概論書の如く哲学史上に現われた種々の説を分類し系統立てることを目的とするものでなく、或いはまた自己の哲学体系を要約して叙述することを目的とするものでもない。",
              "citation": {
                "source": "哲学入門",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "未来に属する政治家、文学者、詩人、美術家、史家、哲学者、事業家などと云ふものは勿論書生だつたのに違ひない。",
              "citation": {
                "source": "大久保湖州",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい歌合せは、歌評から見ても、前代の歌学書・歌論書よりは、用語も、態度も、論理も、鑑賞も、文学的になつてゐる。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説など勿論書けなくなるのだらう。",
              "citation": {
                "source": "柊の垣のうちから",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは又評論書きにも似合はない奇々怪々な先生だと思つて、ひどく好きになつてしまつた。",
              "citation": {
                "source": "大井広介といふ男",
                "author": "――並びに註文ひとつの事――",
                "note": "青空文庫"
              }
            },
            {
              "text": "演劇新潮と築地小劇場岸田國士　僕は、此の一年間、色々な事情で、あまり芝居を観にも行かず、月々発表される脚本も割合に読んでゐないから、劇壇全般に亘る感想といふやうなものは勿論書けない。",
              "citation": {
                "source": "演劇新潮と築地小劇場",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "○都見物左衛門先生が『時勢粧』あまりの面白さに、己れもまけじと洋服論書きて見たれど、どうやら種も尽きたれば自然これにて完結とはなりけらし。",
              "citation": {
                "source": "洋服論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論書く方が喋舌るより遅いから、口述筆記の時間は放送時間の四倍くらいかゝったが、大体枚数が分っているので、あとですらすら読んで見ると、時間はきっちりあった。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『ヂオゲンは勿論書齋だとか、暖い住居だとかには頓着しませんでした。",
              "citation": {
                "source": "六號室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『ジオゲンは勿論書斎だとか、暖い住居だとかには頓着しませんでした。",
              "citation": {
                "source": "六号室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論書くならイスカリオテのユダを、当然主人公にしなければなるまい。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論書物を読んでそんな考へになつたのでもない。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば、大小の雑誌に載る「ブック・レヴュー」（「新刊紹介」・「新刊批評」・其の他）其の他、は勿論書物の内容に就いての解説・注解・批評・を含んでいるので、単にそれが、原稿用紙にして数枚とか十数枚とかいう短いものに過ぎないのが多い、というまでである。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "背筋の凍る鈍雷のような声で話しはじめ、訛りのひどい、主に学術に用いられた中世ラテン語と推察される、私が研究の中でたびたび見た古代の錬金術の書や悪魔を扱った論書に近しいものであったと感じました。",
              "citation": {
                "source": "錬金術師",
                "author": "THE ALCHEMIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "書評は好意をもってかいていて、それは勿論いいのですが、いろいろごたついたあと、そんなことへの全く私だけの心くばりがあってつとめてよく見たというところが、あとから見ると、文芸評論書評として不満になったわけです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
