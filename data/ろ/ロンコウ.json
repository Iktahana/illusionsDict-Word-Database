    "definitions": [
      {
        "index": 1,
        "gloss": "study (of)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「尤も生徒の個性的傾向は無論考えなければならない。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――無論考えられないさ。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "この書の目的は主として郷里の青年に郷土の知識を与えるに在ったが、恩師新村博士が中央の学界に紹介されたお蔭で、端なくも南島研究の手引となり、大正五年に論考数篇を加え、口絵二十余枚を添えて、再版を東京で刊行することが出来、同十一年には、岡村千秋君の尽力によって、第三版を郷土研究社で出して頂いた。",
              "citation": {
                "source": "「古琉球」改版に際して",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "四晩に一度は屹度忍んで寢に來る丑之助――兼大工の弟子で、男振りもよく、年こそまだ二十三だが、若者中で一番幅の利く――の事も、無論考へられた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "四晩に一度は屹度忍んで寝に来る丑之助――兼大工の弟子で、男振りもよく、年こそまだ二十三だが、若者中で一番幅の利く――の事も、無論考へられた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけ、この『現代文学論』一冊は、評論としての正統な理論的追究と同時に、文学の芸術的因子にこまかくふれた論考であるということが云えるのだと思う。",
              "citation": {
                "source": "作家に語りかける言葉",
                "author": "――『現代文学論』にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "窪川鶴次郎の『現代文学論』は昨年の冬出版され、数年来の文学の動向を、個々の現象に即しながらそれを原理に近づいて論考した所産として、少なからぬ興味を有するものであった。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて『近時政論考』の著あり、余の意想を啓発すること鮮少ならざりき。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまた『政論考』の補遺として巻中に挾入せり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "上智の人はしばらく措き、中人以下に至りては必ず先入を主となすの思想を有す、しかれどももし自他の思想を比較し今昔の変遷を考量するときは、あるいはもってようやく己れの誤謬を知るを得べく、あるいはもっていよいよ己れの真正を確かむるを得べし、しからば吾輩のここに『近時政論考』を草する豈に無用の業ならんや。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩は政論考を草して保守中正論派に至り、編を重ぬることすでに十七、最後において吾輩の持説たる国民論派を略叙せんと欲す。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩は保守論派をもってこの篇の終尾となし、さらに「国民論派」と題してこれが補遺とし、もって政論考を完了せんと欲す。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩は『近時政論考』を草し終わらんとするに臨み、いささかその大旨を明らかにしてこれが妨障を除かざるべからずと信ず。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論考へるまでもなく、彼は彼女が眠つてゐる暇に、そつと部屋を抜け出して、帰つたかも知れないと云ふ気はあつた。",
              "citation": {
                "source": "南京の基督",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分には単なる利己とは勿論考えられない。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "よした方がいゝかしらとも勿論考へたが、間近く來ると明かに先方でも自分を認めてゐる樣子なので、彼は黒い中折の山に手をかけた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七、結語（遊藝民蔑視の問題）　私のこの蕪雜な論考に結論を與へる時は未だ當分來さうにない。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで女房から証跡を発見されてはいけないと無論考えたのである。",
              "citation": {
                "source": "競馬",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "（職務に忠実で無い人とも無論考えないが）ただその集配人をそんな羽目にまで置く郵便の組織を感心する。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――とここまで明暸には無論考えなかったが、ただ坑夫と聞いた時、何となく陰気な心持ちがして、その陰気がまた何となく嬉しかった。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云ってせっかく行くと云うものを、意見までして思い止まらせるほどの口実は無論考え出せないから、なすがままにさせて放っておいた。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "生死などは無論考えの中になかった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "微かな羽音、遠きに去る物の響、逃げて行く夢の匂い、古い記憶の影、消える印象の名残――すべて人間の神秘を叙述すべき表現を数え尽してようやく髣髴すべき霊妙な境界を通過したとは無論考えなかった。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が死んだあとで自分らの運命にどんな結果が来るか、彼らには無論考え得られなかった。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴンペルツの「ギリシアの哲人」の第※巻に自然研究家としてのアリストテレスについての見事な論考を見るであろう。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大はしゃぎで本を掲げて彼は叫んだ「ドイツの大教授が書いた『化学論考集』だよ！",
              "citation": {
                "source": "犬酸漿",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に百合子論考えておいて下さい。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふむ……」　容易には、刑部は頷かないのである、家康と三成との関係――またすでに垂井まで来ている自分が、行軍を止めて、佐和山城へ立ち寄ったという事が、上杉攻めの発向に日を急いでいる他の諸侯へ響いたら、どんな嫌疑をうけるか――そういう事も無論考えずにはいられない筈である。",
              "citation": {
                "source": "大谷刑部",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論考へたことはあるに違ひないが、無意識に考へたのだ。",
              "citation": {
                "source": "死",
                "author": "アルチバシェッフ・ミハイル・ペトローヴィチ　Artsybashev Mikhail Petrovich",
                "note": "青空文庫"
              }
            },
            {
              "text": "石井翁はむろんこういうことを考えて研究もせず、ただ気の毒がる仲間の一人ゆえ、どうにかして今の境遇も聞いてみたいと思い、古い事まで話題にしてみたが、河田翁は少しも引き立たない。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
