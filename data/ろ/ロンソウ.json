    },
    "definitions": [
      {
        "index": 1,
        "gloss": "treatise or essay collection",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小宮豊隆「演劇｜論叢」。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラトコフの「セメント」、リベディンスキーの「一週間」等の小説のほか、マルクス主義芸術理論叢書としてプレハーノフ『芸術論』、同『階級社会の芸術』、ルナチャルスキーの『芸術の社会的基礎』などが出版されていた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和二年十月十五日稿）（昭和三年二月『狩野教授還暦記念支那學論叢』所載）",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "近く新村博士が「経済論叢」（大正七年一月発行四巻一号）に於いて発表せられた「賤民名称考」の如きも、またこの餌取説を祖述せられたものである。",
              "citation": {
                "source": "「エタ」名義考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、これに関しては右の武内義雄氏が「漢石経論語残字攷」（『狩野教授還暦紀念支那学論叢』）という非常に優れた考証を書いておられる。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京で沖縄文献の蒐集と保存とが講じられているのは、実に有難く『沖縄論叢』の上梓もその資を得るためといわれます。",
              "citation": {
                "source": "沖縄の思い出",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルービンシュタイン前掲書、同じく「サヴェート同盟に於ける技術的再建の基礎としての電化」（『新興自然科学論叢』――“Science at the Crossroads”の邦訳――の内）、ブハーリン前掲書、岡邦雄氏「科学と技術との計画的結合」（『唯物論研究』創刊号・第二号）等々。",
              "citation": {
                "source": "技術の哲学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　プラトンの対話篇『ティマイオス』に於けるこのプラトン的質料の解釈に就いては V. Brochard, Le Devenir dans la Philosophie de Platon（邦訳・岩波『哲学論叢』二〇号）を見よ。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　理想型という概念は M. Weber : Methodische Grundlagen der Soziologie.――坂田太郎氏訳『社会学の方法的原理』（哲学論叢32）に見られる。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅薄な通俗書籍雑誌の濫出、新聞紙上に時々現われるいかがわしいいわゆる「世界的大発見」の紹介などは、もちろんそうである。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "順次かくのごとくして、できるならばまた、世界の各方面から出発して、同じようにして、それぞれの鎖を――もちろんそういう鎖が存在するとの作業仮設のもとに――たぐって行く。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんそういう簡単な無機的な現象の実験から、一足飛びに有機的現象の機構を説明しようというのならば、それは問題外であるが、研究者のほうではそれほど大胆な意図はもちろんあるはずはない。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、もちろんそうなんです。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘエヘエむろんそうですとも。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんそうでない場合もまたはなはだ多いようであるがだいたいにおいては自然にそうなるべきはずのものではないかと思われ、そういう意識をもって作句してもしかるべきではないかと思うのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗竹春隆もむろんそうだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むろんそうあるべきである」そう私は心に思った。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんそうですとも。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「むろんそうだろう。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろんそうでなければ口頭で話を伝えたはずです。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、王子のほうでは、むろんそういうことをまるで知りませんでした。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんそうだと思うが、私は私でまた別のことを考えた。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これからずッと長く勤めているのかしら」「むろんそうだろう。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんそうして平和がある。",
