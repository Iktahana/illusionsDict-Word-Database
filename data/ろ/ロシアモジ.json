          "literary": [
            {
              "text": "薄汚い裏町のようなところの雑貨店の軒にロシア文字の看板が掛かっていたりした。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシア文字68以上の由。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその下に、「ケレンコ」とロシア文字がしるしてあった。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはロシア文字ではСだから、それ一つを飾り文字としては淋しすぎるのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
