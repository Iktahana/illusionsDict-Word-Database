[
  {
    "uuid": "5a312059-6ac8-55dd-a968-9696610600f6",
    "entry": "鹵簿",
    "reading": {
      "primary": "ろぼ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
