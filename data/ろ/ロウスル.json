[
  {
    "uuid": "0b589d38-86ed-5c45-b94a-989549c1b95e",
    "entry": "弄する",
    "reading": {
      "primary": "ろうする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to play with",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "特に月々の「文藝春秋」に出すアフォリズム風の文字（侏儒の言葉）は、機智のために機智を弄する弄筆者流の惡皮肉で、憎惡的にさへ不滿を感ぜずに居られなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「マイがマイセルフに……」、――「彼はオスカアワイルドの如き軽薄子にして、詭弁を弄するのみ……」――私は私の書いたことに或批評家がそんな冷い言葉を掛けさうな気がした。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "小細工を弄する時ではない、と僕は思ふ。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在科学の極限を見極めずして徒らに奇説を弄するは白昼｜提灯を照らして街頭に叱呼する盲者の亜類である。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれ素人の楽器を弄するのは、云わば、楽譜の中から切れ切れの音を拾い出しては楽器にこすりつけ、たたきつけているようなもので、これは問題にならない。",
              "citation": {
                "source": "断片（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは実際存在することであり、資本家は、それらの裏切者を手なずけるために、間接、直接に、あらゆる手段を弄するのである。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "買い物という行為を単に物質的にのみ解釈して、こういう人を一概に愚弄する人があるが、自分はそれは少し無理だと思っている。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を愚弄すること甚しきものあり）万事御了察のうえ、お願い申しあげます。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "格式に拘泥しない自由な行き方の誹諧であるのか、機知｜頓才を弄するのが滑稽であるのか、あるいは有心無心の無心がそうであるのか、なかなか容易には捕捉し難いように見える。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "既得の領土に安住を求むるか、センセーションを求めて奇を弄するかに迷わざるを得ないのである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "容貌甚だ憔悴し、全身黒み痩せて、爪長く髯短し、ただこれのみならむには、一般｜乞食と変わらざれども、一度その鼻を見る時は、誰人といえども、造化の奇を弄するも、また甚だしきに、驚かざるを得ざるなり。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男は決っして策略などを弄する様な男でないとぼくは考えた。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "袈裟のかげに隠れる、嘘の経文を読む、貰いの技巧を弄する、――応供の資格なくして供養を受ける苦脳には堪えきれなくなったのである。",
              "citation": {
                "source": "私を語る",
                "author": "――（消息に代えて）――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと前にヘシ折られた大男の両足を愚弄する音……。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるものは私の理性を愚弄するために作ったと思われますね。",
              "citation": {
                "source": "虚子君へ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論ヘーゲル程神秘の雲のうちに隠れて弁証の稲妻を双手に弄する人ではなかつた。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その設備の費用や、交際や、仲に立って狡計を弄する金魚ブローカーなどもあって、金魚のため――わずか飼魚の金魚のために家産を破り、流難｜荒亡するみじめな愛魚家が少からずあった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "有色人種特有の嘆きと浮れと決意のメロデーが運動筋を不思議に飜弄する（殖民地のお化）の曲の波に乗つてダーポーシュ帽の赤い房が揺れる。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚弄するにも程度がある。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、あいつというのは、博士と高等学校、大学、ともにともに、机を並べて勉強して来た男なのですが、何かにつけて要領よく、いまは文部省の、立派な地位にいて、ときどき博士も、その、あいつと、同窓会などで顔を合せることがございまして、そのたびごとに、あいつは、博士を無用に嘲弄するのでございます。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たち親子はぐるになって、森岡の一家を嘲弄する気なのであろう。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで此の至當な欲望に乘じて、推命者だの、觀相者だの、卜筮者だのが起つて、神祕的の言説を弄するのであるが、神祕的のことは姑らく擱いて論ずまい。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人を以て殊更に詭弁を弄するものとなす勿れ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と嘲弄するごとく、わざと丁寧に申しながら、尻目に懸けてにたりとして、向へ廻り、お雪の肩へその白い手を掛けました。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時代に於ける所謂美文学なるものを観察するに至りては、吾人更に其の甚しきを見る、人間の生命の根本を愚弄すること彼等の如くなるは、吾人の常に痛惜する処なり。",
              "citation": {
                "source": "内部生命論",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「腐朽」わが右にあり、「死淵」わが左にあり、剣を揮ふもの誰ぞ、筆を弄するもの誰ぞ、天を談ずるもの誰ぞ、地を説くもの誰ぞ、何れに進歩あらむ、何れに退歩あらむ。",
              "citation": {
                "source": "頑執妄排の弊",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは世の俗韻俗調の詩人が徒らに天地の美を玩弄するを悪むこと甚だし。",
              "citation": {
                "source": "哀詞序",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れば今の地位に漱石君がすわるには、何の政策を弄するにも及ばなかったと信ずる。",
              "citation": {
                "source": "夏目漱石論",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊子の病気を冷笑する心は、やがてまた僕の妻のそれを嘲弄する心になった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あでやかな顔は目前に歴々と見えて、ニッと笑う涼い目の、うるんだ露も手に取るばかり、手を取ろうする、と何にもない。",
              "citation": {
                "source": "木精（三尺角拾遺）",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
