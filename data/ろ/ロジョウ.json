[
  {
    "uuid": "d548d005-53e8-5491-8503-5c07a59aa785",
    "entry": "路上",
    "reading": {
      "primary": "ろじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "on the road",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは深窗にゐようと、路上にゐようとおんなしである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――銀座松坂屋の屋上にて――無用の書物蒼白の人路上に書物を賣れるを見たり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "路上に行人は散らばり去り烈風は砂を卷けどもわが古き感情は叫びて止まず。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "草原の草を縛り合わせて通りかかった人を躓かせたり、田圃道に小さな陥穽を作って人を蹈込ませたり、夏の闇の夜に路上の牛糞の上に蛍を載せておいたり、道端に芋の葉をかぶせた燈火を置いて臆病者を怖がらせたりと云ったような芸術にも長じていた。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　黄色い小菊の花が一つ路上に棄てゝある――。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこっちは、ゆくりなく、漂泊う旅の路上で、ふと伯母に見出されたという形であらしめ度い。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "石畳の路上を横にそれようとする途端黒い人がつきあたった。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "太田ミサコの黒いスカートが冷たい路上で地下の電光に白く煌いた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、まるで酒場の醉ひどれのやうな兵士の集團は濕つた路上に重い靴を引き摺りながら、革具をぎゆつぎゆつ軋らせながら劍鞘を互にかち合せながら、折折寢言のやうな唸り聲を立てながら、まだ五六｜里先のＮ原まで歩かなければならなかつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はつ‥‥」と、田中はあわてて路上を腹這ひになつて手を延ばした。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特派員の眼前には頭蓋骨を叩き割られた死体の脳味噌が塵の路上にこぼれていると知らせた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車は、くさい瓦斯を路上に撒いた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "路上のどんな小さな石粒も一つ一つ影を持っていて、見ていると、それがみな埃及のピラミッドのような巨大な悲しみを浮かべている。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人の話によると、友人は何もせず横丁を懐手してぶらぶら歩いていると、犬が道路上にちゃんと坐っていた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "俥の影が見えなくなると、この古い宿場の往還も、にわかに幅広く見渡せて、霜の溶け沁みた路上の土に、近くの村落から集まって都の方へ通って行く荷車の軌の跡が、幾筋も続いて居た。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私の道はどこにありましょうか』『道は前にあります、まっすぐにお行きなさい』　私は或は路上問答を試みられたのかも知れないが、とにかく彼は私の即答に満足したらしく、彼の前にある道をまっすぐに行った。",
              "citation": {
                "source": "道〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆ど概ねの女たちが、今では家庭の妻として愛されるより、むしろ路上を散歩する情婦として、コケツトとして愛されるであらうことを、その良人に対してすら望んでゐる。",
              "citation": {
                "source": "家庭の痛恨",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さびしい路上の聖人よわたしは別れ　もはや遠くあなたの沓音を聽かないだらう悲しみのしのびがたい時でさへもああ　師よ！",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "街路樹のプラタナスの茂みの影がまだらに路上にゆらめいた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨に濡れながら二人、路上でむき合って立ったまま、しばらく黙っている。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――Ｋと私とは暗い路上に視線を落したまま、詞もなく、あてどもなく歩き續けて行くのだつた。",
              "citation": {
                "source": "霧の夜に",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　其夜も、自分は古い妄想に沈みながら路上を漫歩してゐた。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒田清輝氏の「小督物語」は偶然路上に遭遇した人群から暗示を受けたといふが、僧侶、藝子及び舞子、嫖客、草刈の少女等は眞に京都的の 〔Ele'ments〕 である。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "路上の商いの常として、気軽るに、癪に触ることも受け流し、如才なく客の多情へ下手につけ入って行く。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし堂島は遂に姿を見せないで、路上には漸く一月の本性の寒風が吹き募って来た。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒さは強く、路上の雪は稜角ある氷片となりて、晴れたる日に映じ、きらきらと輝けり。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "小樽の人はそうでない、路上の落し物を拾うよりは、モット大きい物を拾おうとする。",
              "citation": {
                "source": "初めて見たる小樽",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の頃から、彼は外出の時いつも一冊のノートをポケットに持ち、路上で見るもの、聞くもの、考えついたことの凡てを、直ぐ其の場で文字に換えて見ることを練習した。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正勝がその路上から投げ込んだままどこの岩角にも突き当たらずに、直接そのＬの字形の岩の上の雑草の上に落ちたのに相違なかった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてくれるか……」　正勝はそう言って、戸口から路上へ向けて銃口を突き出した。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
