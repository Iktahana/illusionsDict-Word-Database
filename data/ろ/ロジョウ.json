  {
    "uuid": "38d58d87-ce1e-570e-88b1-27089781a414",
    "entry": "露場",
    "reading": {
      "primary": "ろじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
