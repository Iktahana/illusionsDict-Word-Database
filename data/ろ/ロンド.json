    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rondo",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昔の江戸時代には帰らないでも、せめて巴里かロンドン位の程度にまで、余裕のある閑散の生活環境を作りたい。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この論文は去る四月ロンドンの動物学会で述べたものである。",
              "citation": {
                "source": "卵の形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽い双眼鏡　今度ロンドンのネグレッチ・アンド・ザンブラで売り出した新形の双眼鏡「ミニム」というのは従来の双眼鏡中で最も軽いものである、その倍率は八倍で重量七十五匁くらい、柔らかい皮袋に入れて隠袋に収めるように出来ている。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして流行着のマネキンを乗せたロンドン通いの飛行機が悠長に飛んで行く。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一般にブロンドの髪のけばけばしい黄金色よりは、黒髪のみどりの方が「いき」の表現に適合性をもっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがために暗黒アフリカの真只中にロンドン製品の包紙がちらばるようなことになる。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国の有名な物理学者が近頃ロンドンのローヤルインスチチューションでやった講演の中で「人は何故浴場で歌いたくなるか」という問題を提出したら聴衆は大いに笑ったそうである。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつてロンドン滞在中、某氏とハンプトンコートの離宮を拝観に行った事がある。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンからの便りでは、新聞や通俗雑誌くらいしか売っていない店先にも、ちゃんとアインシュタインの著書（英訳）だけは並べてあるそうである。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより先、一八六九年にロンドンで彼の学友アーサー・バルフォーアの二人の姉妹エリーノア（Eleanor）とイヴリン（Evelyn）とに紹介され、その後しばしば出遭う機会があった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰途はギリシアからブリンデイシ、ヴェニスを経て一八七三年五月初旬にロンドンに着いた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが晩年までも彼のロンドンでの定宿となり、ほとんど毎年数週ないし数月をここに送ることになったのである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドン中に八箇所の牛乳配達店をもっていた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポンチの漫画を見せたり、また Engineering 誌の器械の図を見せたり、また「ロンドンを見せてやる」と称して子供に股覗きをさせ、股の間から出した腕をつかまえて、ひっくら返す遊戯をした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇一年にロンドンのチューブ地下鉄道が開設されたが、このために家が振動して困るという苦情が出たので、政府はそのために調査委員を設け、レーリーが委員長になった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフリカでキンバーレー、ヴィクトリア滝を見てプレトリアへの途上赤痢に罹り、その報知はロンドンを驚かせた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、次にロンドンへ来た折に二人で一緒にやってはどうかという子息の申出を喜んだように見えた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画の頂点はヒロインが舞台で衣裳をかなぐり捨てブロンドのかつらを叩きつけて煩わしい虚偽の世界から自由な真実の天地に躍り出す場面であって、その前のすべてのストーリーはこの頂点へ導くための設計であるように見える。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧で有名なはロンドンで、石炭や煤の粉交じりだから特別な不快な色をしている。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "来年はロンドンでこの会を開くとの事である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十一月二十八日『東京朝日新聞』）　　　　　　　　　四十七　　　　　　英国の軍用軽気球　先月初、ロンドン附近で軍用軽気球の試乗があった。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルダーショットからロンドンまで一時間二十四マイルの速度で飛行し、聖ポールの寺院を一まわりして今度は風に逆らって進んだが、あまり風が強かったから水晶宮の辺で地上に下った。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十二月十六日『東京朝日新聞』）　　　　　　　　　五十　　　　　　濃霧を消散する新案　ロンドンは霧の名所であるそうなが、近頃マジョラという人がこの霧を消す新案をして気象台でこれに関する研究をしているそうな。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはウワーナー・ポオリーの法と云うので、去る十月ロンドンで開かれた天然色写真会で展覧に供した。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日パリ・ロンドン間の長距離電話に故障があってただ一線しか通じないので、電話申込人は何十人もつかえて順番の来るのを待ち兼ねている有様であった。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年二月四日『東京朝日新聞』）　　　　　　　　　六十四　　　　　　煤煙問題　ロンドン地下電鉄会社の発電所で焚く石炭の煙がウェストミンスターの町へ掛かって損害を与えるというので、同市会から会社を相手取って訴訟を起した。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議なことには、このドイツ語で紹介された老子はもはや薄汚い唐人服を着たにがにがとこわい顔をした貧血老人ではなくて、さっぱりとした明るい色の背広に暖かそうなオーバーを着た童顔でブロンドのドイツ人である。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "星の世界の住民が大砲弾に乗込んで地球に進入し、ロンドン附近で散々に暴れ廻り、今にも地球が焦土となるかと思っていると、どうしたことか急にぱったりと活動を停止する。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
