    "definitions": [
      {
        "index": 1,
        "gloss": "open air",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "………かの女たちは、ハンド・バッグさえあれば、たとえ露天の夜だってたえ忍ぶことができる、浪速へなりと、上海だって、街のエロチシズムの集散地へなりと、こころのままに行くことができる。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "露天店の、たった一箇二銭か三銭の山梨を、うまそうに頬張らして貰うしおらしい奴もあった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃厚な朱や青に塗りこくられた支那家屋、ほこりをかむったさま／″＼の、ずらりと並んだ露天店、トンキョウな声で叫んでいる支那人、それらのものは、闇と霧にさえぎられて見分けられなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二四　塵埃ッぽい通りの一角に、露天商が拡げられた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古城子の露天掘りだ！",
              "citation": {
                "source": "防備隊",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜はずゐぶん久しぶりで、愉快な露天に寝るんだな。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜はずいぶん久しぶりで、愉快な露天に寝るんだな。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大晦日にこれでは露天の商人がかわいそうだと、女中は赤い手をこすった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本橋五丁目の附近には、五会という古物露天商人の集団があり、何かにつけて便利だった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを大阪の伝統だとはっきり断言することは敢てしないけれど、例えば日本橋筋四丁目の五会という古物露天店の集団で足袋のコハゼの片一方だけを売っているのを見ると、何かしら大阪の哀れな故郷を感ずるのである。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「千日堂」はもう飴を売らず、菱の実を売ったり、とうもろこしの菓子を売ったり、間口の広い店の片隅を露天商人に貸して、そこではパンツのゴム紐や麻の繩紐を売ったりしていた。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は初酉だそうですが、天気がいいせいか頗る繁昌しているので、混雑のなかを揉まれながら境内と境外を一巡して、電車通りの往来まで出て来ると、ここも露天で賑わっている。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、いよいよ切符を切り構内に入って露天のプラットフォオムのベンチに、トランクにもたれ、毛布をしいて、ほっと腰を下した伯父を見た時、――沈んで間もない初夏の空は妙に白々とした明るさであった、――三造は、はっきりと、伯父の死の近づいたことを感じさせられた。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラックを出ると、一人の男があのカレー屋ははじめ露天だったが、しこたま儲けたのか二日の間にバラックを建ててしまった、われわれがバラックの家を建てるのには半年も掛るが、さすがは闇屋は違ったものだと、ブツブツ話し掛けて来たので相手になっていると、煙草を一本無心された。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳牛は露天に立って雨たたきにされている。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが財産の主脳であるところの乳牛が、雨に濡れて露天に立っているのは考えるに堪えない苦しみである。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳牛は露天に立つて雨たゝきにされて居る。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が財産の主腦である處の乳牛が、雨に濡れて露天に立つて居るのは考へるに堪へない苦みである。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは露天市場を見物に行つた帰途であつた。",
              "citation": {
                "source": "一室",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇妙な店頭の封筒　東京市中到る処の縁日や露天には、封筒や書簡箋の店が多い。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "露天に机が並べてあるところで、でんでに戸籍簿を借りて自分で書き、それから判を窓口で押してもらえばいいのだった。",
              "citation": {
                "source": "広島の牧歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の一隅にある露天のカフェーの上だけは紅の霧を流したようにぼうと明るい。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "）等を精製するのだそうであるが、その露天泉を眺めた時、自分は別府温泉の地獄まわりで坊主地獄と云ったか、それを思い出した。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠りを破るのを遠慮して、借りている部屋にも帰らずに露天に寝たり、自分の用さえ足しかねるほど忙しい苦しい身でありながら、しないでもいい便所の掃除までしたそれらの心づくしは、遂に何ものにも価いしなかったのである。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "譜も見ず、ゆらめき出て来た月の真下で、彼等は露天にそれを仰ぎさざめく波に合せつつ弾くのだった。",
              "citation": {
                "source": "罌粟の中",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はどこでも簡単な屋外育が流行ってゐて、露天のテント張りの中で飼ふ家もあったので、志津も廂へ出して見たので、さうでもなければ、一度一度蚕沙を代へる手間はとてもなかった。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "更科の木も目あるごと恐れつつ露天湯にあり拙き役者　上山田の温泉には露天湯があると見え、作者も物好きにそれに浸つて見た。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところてんを突くように人の行列が押し送られて行った。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "政党大臣や大学教授や官展無審査員ならば、ところてんのようにお代わりはいつでもできる。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の茶屋には筧の水があふれて、ところてんが澄んでゐた。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
