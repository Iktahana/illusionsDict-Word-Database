  {
    "uuid": "1cab052b-3ad8-55fd-b264-2f58f7ddbdad",
    "entry": "露点",
    "reading": {
      "primary": "ろてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
