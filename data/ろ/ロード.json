[
  {
    "uuid": "652061d2-5c8d-5625-a5c0-1cd5d0c0c265",
    "entry": "ロード",
    "reading": {
      "primary": "ロード",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
