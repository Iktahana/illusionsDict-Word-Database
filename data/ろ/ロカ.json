[
  {
    "uuid": "426990cb-9855-5369-8af2-1413f450a051",
    "entry": "濾過",
    "reading": {
      "primary": "ろか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
