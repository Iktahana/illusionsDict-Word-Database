          "literary": [
            {
              "text": "露天風呂でひと風呂あびる。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "露天風呂があって、そこへ常に谷川の水が流れてくるように上流から林の中を曲りくねってトヨがひかれている。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "露天風呂には天水がたまって、蛙が棲んでおり、私は煮炊きの水を谷川まで往復して運ばなければならなかった。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱衣所から離れた冬場の露天風呂へ向かう人間のように、さぶさぶさぶさぶ言いながら、湯まで走ってやってきたのか。",
              "citation": {
                "source": "ぞなもし狩り",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、露天風呂とかそんな話を、ちらっとしてたかなあ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "露天風呂には入ってみたい。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、旅館の離れに泊まると、その離れの庭に専用の露天風呂があって、夜中でも入ることができるんだって。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝、露天風呂のある宿を出てすぐに、ガス・ステーションの自動販売機で買ったにぎりめし。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
