        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は、ロープに蹴つまずいた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "出鱈目にロープなんぞ抛り出しやがって」　彼は叱言を独りで云いながら、ロープの上へ乗っかった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロープ、捲かれたロープは、………　どうもロープらしくなかった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "躯を直角に曲げて、耳をおっ立てて、彼は「グニャグニャしたロープ」を、闇の中に求めた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "見習は、腐ったロープのような、仲間を見た。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしたってんだい」　ロープは腐っていた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "オイ」　と云いながら、彼は、ロープを揺ぶった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "小初は掘り下げた櫓台下の竪穴から浅瀬の泥底へ水を掻き上げて行くと、岸の堀垣の毀れから崩れ落ちた土が不規則なスロープになって水底へ影をひくのが朦朧と目に写って来た。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャンデリヤにネオンサインが螺旋に巻きついた、水灯のような新衣裳のもとで、ロープモンタントをつけた女と華奢な男とが、スポットライトの色彩に、心と心を濡らして跳舞するのだ。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "また絶えず石炭を積み込む荷揚ロープの緩急が打ち寄せる波の音と和して、消燈された甲板のゴルフ棒の蔭で船員と港の土人街の女とが抱擁して別離を悲しんでいる。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　へリオトロープ　よく晴れた秋の日の午後｜室町三越前で電車を待っていた。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このいたずらを利用したものの例としては三角測量の際に遠方の三角点から光の信号を送るへリオトロープがあり、その他色々な光束が色々の信号に使われるのは周知のことである。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本橋橋畔のへリオトロープは単なる子供のいたずらであったであろうが、同じようなのでただの悪戯ではない場合があり得る。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、このヘリオトロープの信号は少なくも映画や探偵小説の一場面としてはこれも一遍だけは適当であろう。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――ちゃんと、ケージのロープまで、もとの継いだやつにつけ直しちゃったんだよ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」助手はマニラロープを持って、囲いの中に飛び込んだ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし幾十百億年後の人間の言語が全部数学式の連続に似たものになりはしないかという空想をほんの少しばかりデヴェロープして考えてみると、この譬喩が必ずしも不当でない事がわかるかと思う。",
              "citation": {
                "source": "数学と語学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一人山頂の櫓に回照器（ヘリオトロープ）を守って、時々刻々に移動する太陽の光束を反射して数十キロメートルかなたの観測点に送る。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、眼底網膜の視像の持続性を利用するという点ではゾートロープやソーマトロープのようなおもちゃと似た点もあるが、しかしこれらのものと現在の映画――無声映画だけ考えても――との間の差別は単なる進化段階の差だけでなくてかなり本質的な差であると考えられる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "切れ切れになって飛んでは来るけれど、まるですずらんやヘリオトロープのいいかおりさえするんだろう、その音がだよ。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらかじめロープをもって銘々の身をつないで、一人が落ちても他が踏止まり、そして個々の危険を救うようにしてあったのでありますけれども、何せ絶壁の処で落ちかかったのですから堪りません、二人に負けて第三番目も落ちて行く。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダグラス卿とあとの四人との間でロープはピンと張られました。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちる四人と堪える四人との間で、ロープは力足らずしてプツリと切れて終いました。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
