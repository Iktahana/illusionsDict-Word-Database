[
  {
    "uuid": "d595f246-e985-5b73-a72e-5ca797e2ac59",
    "entry": "聾唖",
    "reading": {
      "primary": "ろうあ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
