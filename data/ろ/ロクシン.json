    "definitions": [
      {
        "index": 1,
        "gloss": "the six articles of faith (in Islam)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "六月二十一日　第六信（ベルリンにて）今日は一日ジャネットの家で話して暮しました。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十三日（火曜）　昨日、第十六信を送る。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔発信〕第二十六信　昨夜岡田さん達がかえる時はミゾレがちらちらしていたが、晴天。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外に〕面会二月十七日（水曜）〔発信〕第六信二月十八日（木曜）　金原来、寿江子　夜フラリと稲子来。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（九枚）六月十一日（金曜）　スメドレイとバックについて（二〇）六月十九日（土曜）〔欄外に〕　うた子さんとはじめて巣鴨にゆく六月二十日（日曜）〔発信〕第十六信『帝大新聞』「愛怨峡」の印象　６枚六月二十一日（月曜）　仕事をはじめる。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月二十三日（月曜）『報知』の時評五回　１　時局と作家　２　東も西も　３　三人の婦人作家　４　軛はひとつ　５　ヒューマニスムとは何であろうか〔欄外に〕大雷雨八月二十四日（火曜）〔発信〕二十六信　夜仕事にかかりはじめたら、寿江子太郎をつれて来る。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月十五日（日曜）〔発信〕第六信〔受信〕十三日づけの第三信一月十六日（月曜）『はたらく一家』の序文をよみ、なかの小説二つよんで感慨無量である。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月二十九日（日曜）〔発信〕第十信〔受信〕一月二十七日づけの手紙、第六信　○日記十枚五日分「寒の梅」をおくる『文芸』。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月十九日（日曜）〔発信〕第十六信二月二十一日（火曜）雪〔発信〕第十七信〔受信〕達ちゃんより　二月十一日〔欄外に〕面会二月二十二日（水曜）　○小説はじまる　三枚二月二十三日（木曜）〔発信〕第十八信〔受信〕二十一日づけの手紙着三月一日（水曜）　面会。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月二十一日（火曜）〔受信〕三月十八日づけ第十六信着。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月二十六日（日曜）〔発信〕第二十六信。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月九日（火曜）〔発信〕第三十六信五月十日（水曜）〔発信〕第三十七信五月十二日（金曜）　面会。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "『法政』〔欄外に〕面会　　6.00六月三日（土曜）〔発信〕第四十六信〔欄外に〕上野へゆく、図書館六月四日（日曜）「『藪の鶯』このかた」をかきはじめる。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二十六日（月曜）〔発信〕第五十六信　○小説「日々の映り」ナゴヤへ送る。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月十日（日曜）〔発信〕八十六信　ひる頃本田死去の知らせ。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月五日　〔市ヶ谷刑務所の顕治宛　上落合より（封書）〕　第六信。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三五年（昭和十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十八日夕　〔市ヶ谷刑務所の顕治宛　駒込林町より（封書）〕　八月十六日（第六信）　夜中。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十二日　〔市ヶ谷刑務所の顕治宛　長野県上林温泉より（封書）〕　十月十二日（月）　第十六信　九月三日に下さったお手紙は十日につきました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "-------------------------------------------------------　一月八日午後　〔市ヶ谷刑務所の顕治宛　駒込林町より（封書）〕　一月八日　　第二十六信　晴れ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の本年に入ってからの手紙は一月八日に林町から第二十六信を出し、十五日頃この家に引越した印刷のハガキをさしあげ、十六日には、あなたの一月六日のお手紙と十二月二十六日のお手紙に答える手紙を目白の家から出して居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月十七日に六信をかき、二十日すぎに七信をかきました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十六信　きょうは母の三年祭の日です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月二十四日　〔巣鴨拘置所の顕治宛　国府津より（封書）〕　八月二十四日　国府津　　第二十六信。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三十六信（きょうはじめて勉強部屋へ火鉢を入れました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月十六日　〔巣鴨拘置所の顕治宛　目白より（封書）〕　十一月十六日　晴　　第三十六信　きょうは、おなかのわるい日の手紙。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五日第五、そしてきょうの第六信。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月五日朝　〔巣鴨拘置所の顕治宛　目白より（封書）〕四月四日　　第十六信　落付かない天候ですが、ずっとお体の調子はつづいて平らかですか。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　第二十六信　さっき十二時のサイレンが鳴ったところ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日七月十六日　〔巣鴨拘置所の顕治宛　目白より（封書）〕七月十六日　　第三十六信　久しぶりにテーブルに向ってこれを書き出します。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかぜを呉々大事に願います九月二十五日夜　〔巣鴨拘置所の顕治宛　目白より（封書）〕九月二十五日　　第五十六信　きょうは可笑しい借家人物語を二つ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
