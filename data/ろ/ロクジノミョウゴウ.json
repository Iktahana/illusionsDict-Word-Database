    "definitions": [
      {
        "index": 1,
        "gloss": "the six written characters of Buddha's name (used in prayer)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
