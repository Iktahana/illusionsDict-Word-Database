        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "粘り強さもロブスターのようだ。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはやはりロブスター（伊勢えびの類。",
              "citation": {
                "source": "アメリカの牛豚",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし伊勢えびには鋏がないが、ロブスターにはザリガニのように大きなはさみがある。",
              "citation": {
                "source": "アメリカの牛豚",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "水族館のように、ガラスのケースの中に塩水を満たし、それがロブスターの生簀というわけです。",
              "citation": {
                "source": "アメリカの牛豚",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、男衆が、もうロブスターがよいと知らせてくれる。",
              "citation": {
                "source": "西洋の浜焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に真赤なロブスターと黄色い玉蜀黍とが、際立って鮮かな色彩を見せている。",
              "citation": {
                "source": "西洋の浜焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番の御馳走は、やはりロブスターである。",
              "citation": {
                "source": "西洋の浜焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたりからメイン州にかけたところが、アメリカでのロブスターの本場とされている。",
              "citation": {
                "source": "西洋の浜焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューヨークの少し凝った料理店で、メインのロブスターを註文すると、初めに生きた奴をもって来て、客に元気のよいのを選ばせ、それを料理してくれる。",
              "citation": {
                "source": "西洋の浜焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白いことにはこのクラムベークでは、ナイフもフォークもついていないので、丸のままのロブスターを手で食べなければならない。",
              "citation": {
                "source": "西洋の浜焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかみは　あかい　ロブスター　２び、　ハム　１ぽん、　おさかな　１まい、　デザート　ひとつ、　そのほか　ナシと　オレンジも　いくつか。",
              "citation": {
                "source": "わるねずふたりぐみのはなし",
                "author": "THE TALE OF TWO BAD MICE",
                "note": "青空文庫"
              }
            },
            {
              "text": "デザートを　こわし、　さらには　ロブスター、　ナシと　オレンジまで。",
              "citation": {
                "source": "わるねずふたりぐみのはなし",
                "author": "THE TALE OF TWO BAD MICE",
                "note": "青空文庫"
              }
            },
            {
              "text": "）「するってえとまさかロブスターにも顔合わせたことがねえ――」（「食べたことはあ――」と言いかけたけどあわてて口をつぐんで、「ない、ぜんっぜん。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言い直すと、）「なら、ごぞんじねえわけですな、うっきうきのロブスターのカドリールは！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と声を上げるウミガメフーミ、「アザラシにウミガメにシャケにいっぺえよ――２歩前ん出て――」「てめえごとで相手にロブスターをだな！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とウミガメフーミ、「２歩出て相手につらを向けてな――」「ロブスターを取りかえ、元の列にもどる――」と横入りするグリフォン。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それからほら、」と先を続けるウミガメフーミ、「投げんだよ――」「ロブスターを！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「またロブスターの取っかえ！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ウミガメフーミからグリフォンへ、「まあロブスターなしでもできましょうて。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "海ばらの底ロブスターびっしり――かこまれ、ふたりでダンスを、シャケさま！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」10　ロブスターのカドリール　ウミガメフーミは深々ため息、ひれのうらで目元をぬぐってね。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "）――「するってえとまさかロブスターにも顔合わせたことがねえ――」（「食べたことはあ……」と言いかけたけどあわてて口をつぐんでから、「ない、ぜんっぜん。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」）「……なら、ごぞんじねえわけですな、うっきうきのロブスターのカドリールは！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――２歩前ん出て……」「てめえごとで相手にロブスターをだな！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とウミガメフーミ、「２歩出て相手につらを向けてな……」「――ロブスターを取りかえ、元の列にもどる。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それからほら、」と引きつぐウミガメフーミ、「投げんだよ……」「ロブスターを！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあつまりは、」とグリフォン、「マダラはロブスターといっしょにおどりに行くもんだからよ。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            }
          ]
        }
