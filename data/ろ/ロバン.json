[
  {
    "uuid": "6a8331e6-d4eb-5b98-adf3-2bdb855fa381",
    "entry": "露盤",
    "reading": {
      "primary": "ろばん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
