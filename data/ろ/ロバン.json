    },
    "definitions": [
      {
        "index": 1,
        "gloss": "roban",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「小指は高くゝりの覚」で貸借の争議を示談させるために借り方の男の両手の小指をくくり合せて封印し、貸し方の男には常住坐臥不断に片手に十露盤を持つべしと命じて迷惑させるのも心理的である。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもそうでなかったらいかに彼の名文をもってしても、書肆の十露盤に大きな狂いを生じたであろうと思われる。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石抱きは十露盤板と称する三角形の板をならべた台のうえに罪人を坐らせて、その膝のうえに石の板を積むので、石は伊豆石にかぎられ、長さ三尺、厚さ三寸、目方は一枚十三貫である。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "水噴かぬ錆びたる噴水の露盤より静かに滴る水滴。",
              "citation": {
                "source": "春の暗示",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "水噴かぬ※びたる噴水の露盤より静かに滴る水滴。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼と我れとの相違は、いわば十露盤の桁が違っているだけで、喜助のありがたがる二百｜文に相当する貯蓄だに、こっちはないのである。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　或晩のこと、義雄の室にも電燈が付いてから間もなく、「御免を被ります」と、千代子がお客帳と支出簿と十露盤とを提げて、にや／＼笑ひながら這入つて來た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "十露盤絞りの手拭をかぶった若い野郎です」「てめえはそれをどうして知っている」　定吉は少しゆき詰まった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんから彼に対する憎悪が一度に発して、定吉はまさかに彼を殺すほどの料簡もなかったが、せめてその顔に疵でも付けてやろうと思って、料理屋の門口に忍んで、その帰るのを待っていると、十露盤絞りの手拭をかぶった若い男がおなじくその門口にうろうろしていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十露盤絞りをかぶっていたのは若い野郎だな。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "双子の半纏をきて十露盤しぼりの手拭をかぶった男は、そのころ江戸じゅうに眼につく程にたくさんあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今来た男、あれがどうも十露盤絞りらしゅうござんすよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "手習い一方でなく、十露盤も教えていたが、人物も手堅く、教授もなかなか親切であるというので、親たちのあいだには評判がよかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "玩具のやうな小さな十露盤を出して商人は「皆掛が四百廿三｜匁二｜分だからなそれ」秤の目をお品に見せて十露盤の玉を彈いた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それぢや差引四十一｜錢三｜厘小端か、こつちのおつかさま自分でも商してつから記憶がえゝやな」商人は十露盤を持つて「どうしたえ、鹽梅でも惡いやうだが風邪でも引いたんぢやあんめえ」といつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼と我との相違は、謂はば十露盤の桁が違つてゐるだけで、喜助の難有がる二百文に相當する貯蓄だに、こつちはないのである。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり初めから十露盤が取れないような無理な仕組みに出来あがっているんですから、自然そこにいろいろの弊害が起って来て、岡っ引とか手先とかいうと、とかく世間から蝮扱いにされるようなことになってしまったんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までは奉公人まかせにしておいた帳簿などを自分で丹念に検めて、ついぞ持ったことのない十露盤などをせせくるようにもなった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら帳簿を整理しても十露盤をはじいても、いまさら療治のできるような浅い手疵ではなかった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は細かい十露盤の珠をせせっているのをもどかしく思って、堂島の米あきないに濡れ手で粟の大博奕を試みると、その目算はがらりと狂って、小さい身代の有りたけを投げ出してもまだ足りないような破滅に陥った。",
              "citation": {
                "source": "心中浪華の春雨",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に手重いのになると、教授用の大きい算露盤を背負わせて、教師が附き添って各級の教場を一巡し、この子はかくかくの不都合を働いたものであると触れてあるくのである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも帳面をならべて十露盤をはじいている。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三人は再び帳面や十露盤にむかっている。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝兵衛は帳場に戻り、弥助も帳面と十露盤を取る。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来の興行法ではどうしても観劇料が高くなるから、東京で一回の興行を終ると、その大道具衣裳かつら一切を持って地方幾カ所の巡回興行をつづけ、それを通算して十露盤を取ることにする。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下の大事が胸一杯につかへてゐるので、十露盤なんぞを彈いてゐる氣にはなれませんよ。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十以上の大番頭が帳場に坐って、その傍に二人の若い番頭が十露盤をはじいていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "勘平の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "手代の伊吉が忙しそうにそろばんを弾いている。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていったいとんびは大へん機敏なやつで勿論その染屋だって全くのそろばん勘定からはじめましたにちがひありません。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西へ渡って、右側のそろばん屋という妙な名前の本屋へ、鶴雄は何の気なしにはいって行った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
