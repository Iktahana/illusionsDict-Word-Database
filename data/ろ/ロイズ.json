        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "單に人道主義といふ如き感傷觀で、二者を無差別に崇拜する白樺派のヒロイズムは、僕にとつてあまり子供らしく淺薄に思はれた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の文豪である大トルストイが、救世軍的人道主義者として擔がれたり、通俗モラルのセンチメンタリストとして、女學生の涙劇的ヒロイズムの對象であつたりしたことを考へると、今から考へて全く馬鹿馬鹿しく滑稽である。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の方にはヘロイズムがなくなって享楽生活を非常に重要視している。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この魅力を、「弱き者の味方」という意地に置きかえることによって、千恵造は些かヒロイズムを味った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何等かそこには、権力を否定することによって痛快とする、或る逆説的のヒロイズムがあり、意地の悪いニヒリズムが冷笑を浮べている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）一つの決定的な事実を言えば、詩に於ける一切のヒロイズムは、畢竟して「逆説的のもの」にすぎないということである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に詩に於けるヒロイズムは、本質的に「悲痛なもの」を情操している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "安価なヒロイズムだ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ苛酷に批判してわたしという男は、何という馬鹿正直な、ヒロイズムを好む、偶像性を多分に持った見栄坊の男だろう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その生涯の馬鹿正直さ加減を、おかしな男気を、ヒロイズムを、自分を捨てゝ人の注文に嵌るその偶像性を、その見栄坊を、嘲りながら泣いた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ロイズ船名録や古新聞の山をあさって、八三年一月および二月に印度のポンディシェリに寄った全船舶のその後の航路を調べた。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気のヒロイズムが文学を書かせるとき森山啓を、地球の滅亡の不安が捉へる君はもつと君の体温計に相談してものを書く必要がある。",
              "citation": {
                "source": "小熊秀雄全集-12",
                "author": "詩集（11）文壇諷刺詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "男子の一言金鉄の如しというヒロイズムだけを彼は頑固に信じている。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公である先生の理屈の上でもっともな面だけを描いているし、終りも突然のヒロイズムで結ばれていて、読者にはこまかい心のいきさつがのみこめない。",
              "citation": {
                "source": "選評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "観念の上でのヒロイズムで決して解決しなかった力であったからこそあれだけ私たちは苦しめられた。",
              "citation": {
                "source": "選評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう題材でヒロイズムは作品の人間らしさを奪う役にしか立たない。",
              "citation": {
                "source": "選評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は、そんな似而非ヒロイズムを呟きながら、がくんがくんと玩具のやうに首を動かせた。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "人道主義的なセンチメンタリズムを蹴たおして、仮借なく現実を踏み越えて生きようとする気組も、作品として十分の落付いた肉づけ、客観的な描破力を伴わないと、結果としては案外に単純な神経性ヒロイズムやスリルの追求に堕す危険をもつのである。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダヌンツィオが飛行機で飛びまわってヒロイズムを発揮したような時代からこのかた、今日の世界の動きとその間に生きる作家の気持とは、いか程多角的に、観察と沈着と現実に対する透徹した洞察力を求めるところへ進んで来ていることであろう。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼に『ヌウ※ル・エロイズ』があれば、是に物のあはれの説があり、戀愛の説があるのも似てゐる。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "アベラアルとエロイズの墓だ。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーロッパの天地は再び震撼しはじめているが、この前のように盲目の狂暴に陥るまいとする努力は到るところに見られており、男に代って社会活動の各部署についた婦人たちも、二十五年昔よりは高められている技能とともに単純なヒロイズムにのぼせていないものを持っている。",
              "citation": {
                "source": "これから結婚する人の心持",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉体主義の文学が、「肉体をはる」生き方にヒロイズムを描き出している。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は学校の先生達の卒業生売込運動や卒業生の各種のヒロイズムでも解消しないし、「世間雑話」的な世渡り精神でも役に立たぬ。",
              "citation": {
                "source": "学生の技能と勤労大衆",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒロイズムの自己陶酔は私たち女を愚劣にします。",
              "citation": {
                "source": "身ぶりならぬ慰めを",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きく日本の世界におけるありようを知って、自分の愛する家族たちの動き、浮沈について利害をこえた理解同情をも抱ける婦人の感情の高まりは、単純なヒロイズムからは期待されまいと思う。",
              "citation": {
                "source": "女性の歴史の七十四年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小市民的なヒロイズムそのものが人民の前衛ではありません。",
              "citation": {
                "source": "第一回日本アンデパンダン展批評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "非現実のヒロイズムで目のくらむような照明を日夜うけつづけて育った。",
              "citation": {
                "source": "生きつつある自意識",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり文学というものに連関して私たちの感情の中にとかく刺戟されやすいブルジョア的な個人的ヒロイズムや、それに対する個人的な反感などというものをわたしたちは、階級の全線的な関係からみてゆけるように文学感覚そのものにおける政治性をたかめてゆかなければならないということがいえると思います。",
              "citation": {
                "source": "平和運動と文学者",
                "author": "――一九四八年十二月二十五日、新日本文学会主催「文芸講演会」における講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "非合法だった時代の党の気の毒な官僚主義、ヒロイズム、独善などがかりに小林多喜二の「工場細胞」に反映しているならば、小林多喜二的身がまえによって――積極的に歴史の課題に答えようとする民主的文学者の行動性で、その弱点は今日の「工場細胞」の現実描写を与えられてゆくべきだと思います。",
              "citation": {
                "source": "討論に即しての感想",
                "author": "――新日本文学会第四回大会最終日に――",
                "note": "青空文庫"
              }
            }
          ]
        }
