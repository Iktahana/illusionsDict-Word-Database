    "definitions": [
      {
        "index": 1,
        "gloss": "ronin",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "犀星の評によれば、僕もまた彼と同じく、馬込村に於ける劍客の一人であるさうだが、僕がもし武士としても、月代をのばした浪人組の部類であつて、彼の藩士の眼から見れば、一個の浮浪人にすぎないだらう。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へ又浪人者が「許せ！",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹が浪人の処へ茶を持って来ると、酔っ払った遊び人は横あいからお絹の腕を掴みに行って再び振り放された。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次がその間に、つッと浪人の傍に寄り添って、　「旦那」と小声で呼ぶ。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だ」と浪人が三次を見る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪人は変な事を云う奴だなァと思い乍ら「持って居るよ」と懐中を探って驚いた。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と慌てて、　三次が背中へ廻した彼の左手に握られて居る浪人の紙入れの大写。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次が浪人に、Ｔ「此奴は巾着切ですよ」　と言う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪人は「ナニッ」と遊び人の胸倉をとる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊び人の懐から半分覗いて居る浪人の紙入れの大写。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナニをするんだと抵抗する遊び人の懐から紙入れを取り出した浪人が、　「憎い奴！",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げ廻る遊び人と浪人の三枚目がかった立廻りがあって、浪人は結局フラフラになった遊び人の首筋掴んで引きずって行く。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　急ぎ足にすたすたと橋の袂にまで来た時、一人の浪人者とどんと突き当ってはずみを喰らって三次すってんどうと倒れた。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪人鵜飼三四郎、御免と一言謝罪してすたすたと去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「仇討だとよ」　と言う声を三次耳にしてフト見れば、　鵜飼三四郎が棚倉伝八郎初め十余名の浪人者と斬り合っている。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "追わんとする三四郎に討って掛かる浪人者二三を斬って追う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げる伝八郎と浪人たちを追う三四郎。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏み止まって三四郎に向う浪人。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎遂に足に傷付き倒れ、伝八郎は生き残った浪人と逃げ去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝通り　深編笠の浪人者の移動稍長く、　腰に下っている印籠の大写。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その浪人と三次がすれ違った。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「大勢を手に掛けたとあって、　錦糸堀五百石の御邸は　御取り潰しになり……」　「とうとう浪人生活」と云えば、五郎蔵「そりゃそうだろう」半次尚も、Ｔ「その上、　そのおきよって女が　見掛けによらんあばずれでしてね」　と話し続ける半次。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の気なしに仲蔵がその男見送ると、　蛇の目傘の浪人者（大吉）が跣足で走り去る（所謂定九郎の恰好よろしく）。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台に噛ぶり付いて瞬きせず仲蔵に見入って居る老いさらばえた浪人体の老武士がある。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しも、その向いの家の表に訪れる浪人がある、後姿（大吉らしい）。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の旗本、数名の浪人者の立廻り。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、浪人者サンザンの態にて逃げ去る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の浪人者と、二人の若い旅侍の果し合い。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
