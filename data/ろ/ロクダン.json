    "definitions": [
      {
        "index": 1,
        "gloss": "sixth dan (in martial arts, go, shogi, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "サ、タ、ナ、ラの四行は六段で、ア行とヤ行が五段、ワ行が四段となります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝負事を否定する（第百十一段）かと思うと、双六の上手の言葉を引いて（第百十段）修身治国の道を説いたり、ばくち打の秘訣（第百二十六段）を引いて物事には機会と汐時を見るべきを教えている。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとうに啖い殺したのかしら、鉄砲疵には似たれども、まさしく刀でえぐった疵、とんだ六段目じゃあねえかな」「さあ」と、庄太も少し考えていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "二段ずつ飛ぶこともあり五六段ずつ飛び上がるときもある。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間にけばけばしい色彩で壁に淫靡な裸体女と踏み躙られた黒人を描いて、思わせ振りな暗い入口が五六段の階段の上についている｜食しんぼう小屋のようなものが混っている。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁ど瞳を離して、あとへ一歩振向いた處が、川の瀬の曲角で、やゝ高い向岸の、崖の家の裏口から、巖を削れる状の石段五六段を下りた汀に、洗濯ものをして居た娘が、恰もほつれ毛を掻くとて、すんなりと上げた眞白な腕の空ざまなのが睫毛を掠めたのである。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五六段階子を残して、女中が廊下の高い処へ顔を出して、『まだ、お帰り遊ばしません。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時は将棋盤の八十一の桝も坂田には狭すぎる、といわれるほど天衣無縫の棋力を喧伝されていた坂田も、現在の棋界の標準では、六段か七段ぐらいの棋力しかなく、天才的棋師として後世に記憶される人とも思えない。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六段敵は名に負ふ大陸の銅羅のかけひき、騎乗の功者。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ心に打ちうなづき、薄｜湿りせる石階のほの暗きを爪探りて、やゝ五六段ほど降り行きしと思ふ処に扉と思しき板戸あり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この会所で、今の萩原六段と知り合になつた。",
              "citation": {
                "source": "将棋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は、二十二三歳の頃今の宮坂六段と一度打ったことがある。",
              "citation": {
                "source": "碁の手直り表",
                "author": "菊地寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっち側は、その生垣と向い合った、しもた家で、その隣がまたしもたや、中に池の坊｜活花の教授、とある看板のかかった内が、五六段石段を上って高い。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "六段目までの稽古が済んで、もう討ち入りまでは用がないと、あとへ引きさがって煙草をすっていると、うしろから自分の腰を強く蹴って通るものがあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は祖父から教会にあるやうな立派な燭台やストツプのついたオルガンを買つて貰ひ、母親の琴と、六段や春雨を合奏した。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて教により果を得て人間以上になるのを、下位から數へて六段階がまだ欲界、其上の十八段階位が色界、其上の四階位が無色界、合せて二十八天界は、苦惱は無く歡樂はあれども、まだ生死を免れない階級で、無色界の上の四階位は種民天といふ、種民天になれば生死三災の及ぶ能はざるところである。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "近時も西アフリカのボンニ地方や、セレベス、ブトン、ルソン諸島民は専ら家近く棲むを吉兆として懼れず（シュルツェ著『フェチシスムス』五章六段）。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は祖父から教會にあるやうな立派な燭臺やストツプのついたオルガンを買つて貰ひ、母親の琴と、六段や春雨を合奏した。",
              "citation": {
                "source": "文學的自叙傳",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "本多忠朝の先手が、二、三発敵にさぐりの鉄砲を放つと、等しく越前勢たちまち七、八百挺の鉄砲を一度に打ち掛け、立ち籠めた煙の中を潜って、十六段の軍勢林の動くがごとく、一同茶臼山に打ってかかった。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その段々に飯粒や蟹の肉や茶色のドロドロしたものが、ゴジャゴジャになった嘔吐が、五、六段続いて、かかっていた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろは学校でオルガンに新曲を合わせてみることに興味をもって、琴の六段や長唄の賤機などをやってみることがある。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "（座敷のまん中には忠臣蔵六段目の勘平に扮したる和泉屋の若い息子角太郎がうしろ向きに横たわっている。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）おさき　今夜の六段目は大変に出来がよかったと云って、みんなも感心して見ていたら、中途から角太郎が急に倒れたのでびっくりしました。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "みな様方も御覧の通り、六段目の幕があきまして、腹切りまでは滞りなく済みましたが、若旦那の勘平が刀を腹へ突っ込んで、手負いの台詞になってから、何だか様子がおかしくなったのでございます。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときに和泉屋の若旦那が六段目の勘平で切腹すると、刀がいつの間にか本身に変っていたので、ほんとうに腹を切ってしまいました。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀吉　芝居の六段目がほんとうの六段目になったのは不思議さね。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知の通り、わたくしは勘平役者で、これまでに五段目や六段目の勘平はたびたび勤めていますが、どういう廻りあわせか道行の勘平は一度も勤めたことがありません。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おん母さま」　地べたにつく程低くお辞儀をすると、のろくだんだんに背中をのばして、再び次第に熱心に感動的にささやいた。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
