[
  {
    "uuid": "bcc522ae-44cf-54c6-a3e5-2a88a087ecb4",
    "entry": "露頭",
    "reading": {
      "primary": "ろとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
