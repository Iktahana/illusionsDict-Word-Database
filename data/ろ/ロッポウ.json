      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the six directions (north, south, east, west, up, and down)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この石は何だろうと云っていたら、居合わせた土地のおじさんが「これは伊豆の六方石ですよ」と教えてくれた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど玄武岩の天然の六方柱をつかったものである。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すきとおる複六方錐［※３］の粒だったのです。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "※３　複六方錐＝六辺の三角錐が上下に合わさったもの。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すきとおる複六方錐の粒だったのです。",
              "citation": {
                "source": "インドラの網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤坂だったら奴の肌脱、四谷じゃ六方を蹈みそうな、けばけばしい胴、派手な袖。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉原の女芸者は見番大黒屋庄六方から、きわ、ぎん、春、鶴等が招かれた。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸侯の別業で、一器、六方石の、その光沢水晶にして、天然に簫の形をしたのがある。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八郎は稚い時、よく出入をして知っているので、その六方石を私に教えようとして、弾かれたように指を引いた。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "花道から八才子が六方を踏んで現れるという花々しい出に、どうしたものだかお約束の素足の下駄｜穿きを紅葉だけが紺足袋を脱ぐのを忘れていた。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いましがたまでふぐのようにふくれていた伝六は、たちまちえびす顔に相好をくずしながら、運ぶこと、運ぶこと、はしと茶わんが宙に六方を踏んで目まぐるしいくらいでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "その白衣観音は今日から考えても別段目先の変ったものではなく、従来の型の如く観音は置き物にするように製作えましたが、厨子などは六角形塗り箔で、六方へ瓔珞を下げて、押し出しはなかなか立派であった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "初めて博覧会の開かれた当時のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "右や左に気兼ねをして、然もどんな実践力も示さない未組織インテリの態度に歯かみをした所まではいいが、ブルジョア才人は才に堕して、彼の「青春行状記」に現われた直木的科学万能論と共に、六方を踏みながらファッショの陣営へ乗り込んだ。",
              "citation": {
                "source": "ブルジョア作家のファッショ化に就て",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "六方から町の集まって来ている広場の一方にはルュキサンブウルの公園の入口を望み、一方には円い行燈のような天文台の石塔を望んだ。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その四十二　東堂が質に入れたのは、銅仏｜一躯と六方印一顆とであった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "六方印は六面に彫刻した遊印である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "また六方印は中井敬所の有に帰していたそうである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴詞は一種粗雜な言葉づかひ、六方ことば、關東べい、とある。",
              "citation": {
                "source": "凡愚姐御考",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "崎には、六方角の相竝べる處もあり。",
              "citation": {
                "source": "十和田湖",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは奈良の六方法師・六方衆ともいふ者の流れであらう。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが芝居の六方の語源をなすものです。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "闊達といへば闊達、乱暴狼藉なる六方衆の風が、芸能化して伝つたのが芝居の六方である。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この六方と語は変るが、かぶきと言ふ語からして、そもそもさうだし、其から寛闊丹前などゝ、外形も内容も変つて行つたが、この六方法師は祇園の犬神人、加茂の放免などに似た行装であつたからだらうと思ふ。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから大和大名の連衆、六方の連衆が出た。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其がもつと外面式に表現せられたものは、六方・丹前の類の語で、所作行動から、性格までも偲ばせるやうになつたのだ。",
              "citation": {
                "source": "文芸の力　時代の力",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「丹前」「六方」総じては「寛濶ぶり」と称すべきもので、市井の無頼の横行する様を誇張した物まねが、其である。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其道中に踏む八文字は歌舞妓狂言の六方とおなじ発生を持つものである。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
