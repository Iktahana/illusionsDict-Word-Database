[
  {
    "uuid": "13b85558-d83e-5433-be25-dd3ed9c42ca2",
    "entry": "六方",
    "reading": {
      "primary": "ろっぽう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
