[
  {
    "uuid": "754535b2-dfd6-5014-931b-62c0a0242771",
    "entry": "親船",
    "reading": {
      "primary": "おやぶね",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
