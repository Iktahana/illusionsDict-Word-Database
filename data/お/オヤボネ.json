        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "提灯の親骨が折れてしまったので、新しいものに交換した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "扇子の親骨には、繊細な彫刻が施されていることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "傘の親骨は、雨風から身を守るために重要な役割を果たす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
