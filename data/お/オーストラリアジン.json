        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅行先で出会ったオーストラリア人の旅行者は、とてもフレンドリーだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の家族には、オーストラリア人の親戚が何人かいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "国際会議では、多くのオーストラリア人が活発な議論に参加していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの人、すごく日焼けしてるけど、やっぱりオーストラリア人なのかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "クリッケットといふ球戯にかけてはオーストラリア人のやうにずばぬけた腕をもつてゐます。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中にオーストラリア人、南アフリカ人、イングランド人、スコットランド人、アイルランド人の別あれども、要するに大英人種のみである。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "管理区域を出る時に顔を合わせて挨拶した相手は一人――タッパーという名のオーストラリア人鉱夫――だけだった。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも三人の男――全員オーストラリア人――は空気の中に何か不吉なものを感じていた。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はオーストラリア人です。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人はルイザ・レイナーズというオーストラリア人で、舞台の大ベテランだ。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "セルウィンという若いオーストラリア人がおり、大金持ちのアホですが、自分は物知りと思っています。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
