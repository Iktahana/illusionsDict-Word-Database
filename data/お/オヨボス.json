[
  {
    "uuid": "fbe912a4-9772-55df-b80e-a46c961de7f3",
    "entry": "及ぼす",
    "reading": {
      "primary": "およぼす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
