[
  {
    "uuid": "d99b32cd-10cd-5cfb-8c2e-c39aaf191de6",
    "entry": "親譲り",
    "reading": {
      "primary": "おやゆずり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
