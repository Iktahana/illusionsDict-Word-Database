        "examples": {
          "standard": [
            {
              "text": "新しく入ってきた人が、いきなり親分風を吹かせ始めたから、みんな困惑してるよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は少し実績を上げただけで、すぐに親分風を吹かすから嫌がられるんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "いくら年上だからって、そんなに親分風を吹かすのはどうかと思う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "富田は何となしに親分風を吹かす男であつた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺の詰め襟の服を着て五六人の仲間と一緒に車坐になって飲んでいた土方の親分風の男が、いきなり土間に立ち上って桟敷の客に「さあ来い」と云いながら喧嘩を買って出たのである。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
