[
  {
    "uuid": "b26dad65-b533-5efa-9ebc-170080c7aa55",
    "entry": "及びもつかない",
    "reading": {
      "primary": "およびもつかない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "far beyond one's power",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その研究は私の知識では及びもつかない領域だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の才能は凡人の私には及びもつかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "こんな難解な問題、私の頭では及びもつかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "今の彼れの心には、その二人の少女は彼れの及びもつかない美しい存在のやうに見えたからだ。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで及びもつかないわ。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "強い信仰もなく、烈しい愛国心もない自分には、とても及びもつかないことながら、生来の自分にも何かそれと一味共通の清らかさ雄々しさがあったようにも思われ、ジャンヌを見た途端に、それが喚び覚まされるような気持で、咀わしい現実の自身と環境にすっかり厭気が差してしまうのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして造物主は、造物主が人類に与えた野猿山羊的の形骸や機能等、即ち一般動物の持つのと同じ低級約束に対して、或る程度の自由で之を辞し之を脱することを許しているし、一方にはまた野猿山羊等には及びもつかない高級権利、即ち造物主の分身たる権利を人類に与えているのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけどもとても及びもつかない。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってその知能や文化程度においては、とてもわが地球人類の及びもつかない程、高級の生物たちであると推定して差支えないと思う。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり同じ失敗の作で、成功というような見事な不自然なことは到底及びもつかない夢だと思う。",
              "citation": {
                "source": "作家の生活",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "特定の場所へ行かなければ見られないという苛酷な制限が映画の本質であるかどうかはまだ疑問としておきたいが、残念ながら現在のところでは映画の普及率は新聞雑誌やラジオの浸透性には及びもつかないのだという簡単な事実に今さら私は眼を見張つているのである。",
              "citation": {
                "source": "映画の普及力とは",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "むずかしい理屈を言うことはとても諸君に及びもつかないが、世俗のことについてならば、諸君なぞはとても彼女の足もとにも及び得るものでない。",
              "citation": {
                "source": "男女関係について",
                "author": "女房に与えて彼女に対する一情婦の心情を語る文",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりあなた方の一生は私共の一生の及びもつかないような生活をしなければつまらないと思います。",
              "citation": {
                "source": "幸福の建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二世紀昔のスウィフトの馬には及びもつかないゾシチェンコの猿にひきまわされて、自身の尽瘁と価値の上にゲラゲラ笑いのつばをとびちらしているとしたら、それは忍びがたい光景ではないだろうか。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この新方法は、これまでの日本のむきだしなファシストたちの知慧では及びもつかない巧みさで心理的に準備された。",
              "citation": {
                "source": "三年たった今日",
                "author": "――日本の文化のまもり――",
                "note": "青空文庫"
              }
            },
            {
              "text": "康頼　それは及びもつかない願いでございます。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実的な望みなぞ、嘘みたいにはかなく消えて、雲や水に同化したいと云ふ及びもつかない野心を起すこともある。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞奴のあの魅惑のある艶冶な微笑みとあの嫋々たる悩ましさと、あの楚々たる可憐な風姿とは、いまのところ他の女優の、誰れ一人が及びもつかない魅力と風趣とをもっている。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "文壇と云うものに孤独であり、遅筆で病身なので、この『第七官界彷徨』が素晴らしいものでありながら、地味に終ってしまった、年配もかなりな方なので一方の損かも知れないが、この『第七官界彷徨』と云う作品には、どのような女流作家も及びもつかない巧者なものがあった。",
              "citation": {
                "source": "落合町山川記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも見渡した景色は、瞬間に、私の及びもつかない想像をも期待をも押し退けた。",
              "citation": {
                "source": "転機",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして芳公と二人で百姓の手伝ひをしたり、小間物の行商をしたりして若い者の到底及びもつかない働きぶりを見せてゐました。",
              "citation": {
                "source": "白痴の母",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "径三尺ばかりの分厚なもので、田舎の広々とした蓮田には及びもつかないが、一二株の蓮の生長には充分らしかった。",
              "citation": {
                "source": "蓮",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "到底及びもつかないことだ。",
              "citation": {
                "source": "柳原※子（白蓮）",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "超人には常人などの、及びもつかない神性がある。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれぐらゐの時がすぎたか、こんな稀代な場合にのぞんで、とても時間の測定などは及びもつかない。",
              "citation": {
                "source": "波子",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、話が人間ということになっては、私の屁理窟やおしゃべりはもう及びもつかない。",
              "citation": {
                "source": "土の中からの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "とてもそんな金は及びもつかないが、それが出来たら愉快だろう。",
              "citation": {
                "source": "公孫樹",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "長助なんぞの及びもつかない凄いタマを投げる奴は、くさるほどいらア」「フロ屋の三平、三助じゃないか。",
              "citation": {
                "source": "町内の二天才",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、話が人間といふことになつては、私の屁理窟やおしやべりはもう及びもつかない。",
              "citation": {
                "source": "土の中からの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらはわたしの感情に強い感銘をあたえ、とうてい現代の記念碑に多く見うけられる風変りな姿態や、凝りすぎた奇想や、象徴的な彫像の群などは及びもつかないのである。",
              "citation": {
                "source": "ウェストミンスター寺院",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "羊や猪や、牛や豚、狐の焼肉など及びもつかない。",
              "citation": {
                "source": "食指談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもＡ川の上流が、七八里余り渓山の間を流れつづいて、べつだん村落が展けるでもなく、両岸には蒼潤の山が迫り、怪石奇巌｜駢び立つて、はげしい曲折の水が流れては急渓、湛へては深潭――といつた具合で、田山先生も曾遊の地らしく、耶馬渓などおよびもつかない、真に天下の絶景であると言つてゐられた。",
              "citation": {
                "source": "故郷に帰りゆくこころ",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同の悲愴な決意を見るにつけ、ケートは心のなかで泣いた、少年らがいかに胆力があり、知恵があるとしても、悪漢どものすぐれた体格や、悪にかけては底の知れない悪知恵をもったかれらとくらべれば、とうていおよびもつかない差がある。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
