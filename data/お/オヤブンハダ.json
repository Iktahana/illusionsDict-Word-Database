        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は困っている人を見ると放っておけない親分肌の性格だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい店長は親分肌で、従業員みんなから慕われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は親分肌だから、何かあったら頼りになるよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "強盗をしたのだか何をしたのだか知らないが、黄金を沢山持って武者修行、悪く云えば漂浪して来た伊勢新九郎は、金貸をして利息を取りながら親分肌を見せては段々と自分の処へ出入する士どもを手なずけて終に伊豆相模に根を下し、それから次第に膨脹したのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅葉は親分肌で、門下や友人の面倒を能く見た。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな塩梅に人の世話もしたが十分感謝して自分を立てないと満足しない親分肌通有の欠点をも持っていた。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来が軍人志願の漢学仕込で、岳武穆や陸宣公に鍛えられていた上に、ヘルチェンやビェリンスキーの自由思想に傾倒して意気｜欝勃としていたから、一から十までが干渉好きの親分肌の矢野次郎の実業｜一天張の方針と相容れるはずはなかった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分肌の学者で、跛者だ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲盛はここで、徹底した粘りと親分肌のリーダーシップを発揮して、特殊磁器分野を松風工業の大きな柱に育てた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分肌で、体は小柄であるが才気が勝っている。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありゃ俗物です、俗物ですけれども、一流の親分肌のところもありましたね……絵の本当の師匠は古人にあるのです、古人よりも山水そのものですな。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は人に頼まれると、例の親分肌を発揮して、よくいろんな人を採用したものだが、子羔を費邑の代官に任命したのも、そのころのことである。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "折助の上には役割、小頭、部屋頭というようなものがあって、それは折助の出入りを司り、兼ねてその博奕のテラと折助の頭を刎ねるが、これらは多少、親分肌の気合を持っている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白根山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは苦学生時代の恩義に報いるためであったことは云う迄もないが、もともと上総の木更津の生れである彼は、関東者らしい熱血漢で、親分肌の、情誼に厚いところのある、一風変った性格の持主なのであった。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼にはどこか、そんな風に慕われる親分肌な人がらがあったとみえる。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
