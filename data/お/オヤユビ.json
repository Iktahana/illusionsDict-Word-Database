          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "熱い皿を持ったので、思わず親指を火傷してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "赤ちゃんが親指をしゃぶっている姿は、とても可愛らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "目的地を指すために、彼は親指で後ろを差した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スマホ操作で親指が疲れるのは、もはや現代病だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "文学のほうではアンドレ・ジッドとトオマス・マンが好きです、と言ってから淋しそうに右手の親指の爪を噛んだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の時代の子供たちは、もはや昔の子供のやうに、フアンタスチツクで荒唐無稽のお伽話――森の妖精の話や、魔法使の話や、赤頭巾の話や、鉛の兵隊の話や、親指太郎の話や、ピノチヨの話や、惡魔が人間に化けた話や――などを悦ばないといふのである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで担保に入れてあったガージュを銘々に返していたとき、一本の鉛筆をさし上げて「これはどなたのでしたか」と主婦が尋ねたら、一座の中の二人のイタリア女の若い方が軽く立上がって親指で自身の胸を指さし、ただ一言ゆっくり静かに Il mio. と云った。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの腕の皮を親指と人差指で力一ぱい抓って圧えててご覧」　柚木はいう通りにしてみた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょいとこれで結わえて下さいな」　親指の中ほどで疵は少しだが、血が意外に出た。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "生あつたかい生物の呼吸が親指の腹をくすぐつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人で二つ願っちゃあ、あんまり慾張っているようで勿体のうござんすから、自分は自分、妹は御代参と、こう役割を決めてまいりました」「これが病気とでもいうのかえ」　松吉は親指を出してみせると、女は肩を少しそらせて笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "親指が没する、踝が没する、脚首が全部没する、ふくら脛あたりまで没すると、もうなかなか渓の方から流れる水の流れ勢が分明にこたえる。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は、父のおっしゃる言葉をちっとも聞こうとなさらず、腕を伸ばして私の傍の七輪のお鍋を、どさんと下におろして、あちちと言って右手の親指と人さし指を唇に押し当て、「おう熱い、やけどしちゃった。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、なるほど、親指と人さし指のさかいのところに、一センチぐらいはなれて、小さいいぼがふたつありました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "親指の股に仕事｜疣のはいった巌丈な手が、不覚にも心持ち戦えるのを感じた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おすめさん、これ（と云って小指を出して）が居ねえでまたしばらく、これ（と云って親指を出して）がよけいと怒鳴るべいな」と婆やが前こごみに小声で云う。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "親指三本の大さですよ。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば春松の醜く押しつぶされている右の手の親指のことは、彼女の回想には泛んで来ない。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "親指くらいの大きさにキチッと握れないものかしら、といつも考えていました）そのひとを、待っていました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親指をこぶしの外へ出して置くと親指をくじかれるおそれがある。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎兵衛はいろいろと研究したあげく、こぶしの中に親指をかくしてほかの四本の指の第一関節の背をきっちりすきまなく並べてみた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文學のはうではアンドレ・ジツドとトオマス・マンが好きです、と言つてから淋しさうに右手の親指の爪を噛んだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかあたしが、足の親指の爪をはがした時、お母さんは顔を真蒼にして、あたしの指に繃帯して下さりながら、めそめそお泣きになって、あたし、いやらしいと思ったわ。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "転がすと、一が出ようというやつを親指でなめずりながら、酒は鉢前で、焚火で、煮燗だ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とばかり、やにわに対手の玉将を引掴むと、大きな口をへの字形に結んで見ていた赭ら顔で、脊高の、胸の大きい禅門が、鉄梃のような親指で、いきなり勝った方の鼻っ頭をぐいと掴んで、豪いぞ、と引伸ばしたと思し召せ、ははははは。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "右足の親指を痛めただけで胡弓をぶち折らなかったのはまだしも仕合わせというべきだった。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "反射的に、ねんどを親指と人さし指の腹ですりつぶしながら、春吉君は見ていた。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから偉大なる掌の、親指と、小指を隠して、三本に箔を塗り、彩色したように見えるのが、横通りへは抜けないで、ずんずん空地の前を、このお伽堂へ押して来た。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お礼だよ」というと、手首をちゃっと握り、鉈豆のような親指と人差指とでぐり／＼と捻ります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花田が烏を追っかける姿を腹を押えて笑いこけて見ていた啓司は親指で眼がしらの涙をこすりながら言います。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな他愛もない術を正気の者なら直き感づくであろうに、と其処の杉の生垣の葉を片手の親指と人差指とでお民は暫くしゃりしゃり揉んで居た。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "薩摩下駄の小倉の緒、太いしっかりしたおやゆびで、蝮を拵えねばならぬほど、弛いばかりか、歪んだのは、水に対して石の上に、これを台にしていたのであった。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子はおやゆび半分の大きさしかありませんでした。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりにも小さいので、女の子は『おやゆび姫』と呼ばれることになりました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
