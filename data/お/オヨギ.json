        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女の優雅な泳ぎに見とれてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プールで数時間の泳ぎを楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "赤ちゃんは初めての泳ぎで大喜びだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし泳ぎの達人であった王は、盾の下で鎖帷子を脱ぎ捨てここを逃げのびてヴェンドランドの小船に助けられたといううわさも伝えられた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは泳ぎが出來ねえのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が此夏、鮎釣りに泳ぎ渡つた際、大きな蟻に臍を食ひつかれて愕いた、竜宮岩も紅葉の間に浮んで、静もりかへつてゐる。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、一人ずつ木からはね下りて、河原に泳ぎついて、魚を手拭につつんだり、手にもったりして、家に帰った。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくも木からおりて、しゅっこといっしょに、向うの河原へ泳ぎだした。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこは、泳ぎながら、まるであわてて、何かに足をひっぱられるようにして遁げた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その水へ半分顔を浸して泳ぎながら横目で海岸の方を見ますと、泥岩の向うのはずれは高い草の崖になって木もゆれ雲もまっ白に光りました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはまた冷たい水に飛び込んで、小さな湾になった所を泳ぎまわったり、岩の上を走ったりしました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはいまにだんだん深い処へさえ来れば、兵隊たちはたてがみにとりついて泳ぎ出すだろうと思って待っていました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は、もう私たちはすっかり川の心持ちになれたつもりで、どんどん上流の瀬の荒い処から飛び込み、すっかり疲れるまで下流の方へ泳ぎました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてその人と私らは別れましたけれども、今度はもう要心して、あの十｜間ばかりの湾の中でしか泳ぎませんでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春さきの小川の淀みの淵を覗いていると、いくつも鮒が泳ぎ流れて来て、新茶のような青い水の中に尾鰭を閃めかしては、杭根の苔を食んで、また流れ去って行く。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがわずかに「わが青海流は都会人の嗜みにする泳ぎだ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここのところをわが青海流では、死屍水かかずしてよく浮くといって、平泳ぎのこころだ」「それは、よくおとうさんがおっしゃる、あの渾沌未分の兄弟か何かなの」　小初は食後の小楊枝を使いながら父親を弥次った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "精いっぱい泳ぎっこね。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "列には泳ぎ達者が一人ずつ目印の小旗を持って先頭に泳いだ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "薫はときどき小初の側面へ泳ぎ出る。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒達は今日の遠泳会を一度も船へ上って休まず、コースを首尾好く泳ぎ終せれば一級ずつ昇級するのである。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、ここからみんな抜き手よ」　やがて一行は扇形に開く河口から漠々とした水と空間の中へ泳ぎ入った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小初はだんだん泳ぎ抜き、離れて、たった一人進んでいるのか退いているのか、ただ無限の中に手足を動かしている気がし出した。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小初が無闇に泳ぎ抜くのは、小初が興奮しているからである。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小初は無闇やたらに泳ぎ出した。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒達の一行にさえ頓着なしに泳ぎだした。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「泳ぎつく処まで……どこまでも……どこまでも……誰も決してついて来るな」　と口に出しては云わなかったが、小初は高まる波間に首を上げて、背後の波間に二人の男のついて来るのを認めた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四丁のぼると、すきを伺って、相手の頸もとへひらりと飛びこんでくるシャモのように、舳の向きをかえ、矢のように流れ下りながら、こちらへ泳ぎついてきた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょせん手の着けようもねえので、おれも途方に暮れてしまったが、それでも川下の方へ流されて行くうちには、どこかの岸へ泳ぎ付くことがあるかも知れねえと、暗い堤下を探るようにして、どんどんの堰の落ち口まで行ってみたが、真っ暗な中で水の音がどんどときこえるばかりで、為さんの上がって来る様子はねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "為さんは無事に泳ぎついて助かったのかも知れないが、亭主のゆくえ不明がどうしても判らなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "上流秋立つけふをくちなはの、　　沼面はるかに泳ぎ居て、水ぎぼうしはむらさきの、　　花穂ひとしくつらねけり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらまじめに眺めていても、そんな巨きなちょうざめは、泳ぎも浮びもしませんでしたから、しまいには、リチキは大へん軽べつされました。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は頭を半分水の中につけて横のしでおよぎながら時々頭を上げて見ると、その度ごとに妹は沖の方へと私から離れてゆき、友達のＭはまた岸の方へと私から離れて行って、暫らくの後には三人はようやく声がとどく位お互に離ればなれになってしまいました。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
