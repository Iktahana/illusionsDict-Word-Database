    "definitions": [
      {
        "index": 1,
        "gloss": "to reach",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "日没後も、山頂まで光が及んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の声は会場の隅々まで及んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "討論は深夜にまで及んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "火災は隣の家にも及んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ヘルンが学校に行ってる間、夫人は暇を盗んで熱心に読書をし、手の及ぶ限り、日本の古い伝説や怪談の本を漁りよんだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに長者らしき、なごやかな、人柄そのままの自然の風ありて、われらの及ぶところでないと思つた。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点に考え及ぶと私は少し心細くなる。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一種の小動物だけでも、その影響の及ぶところははかり知られぬ無辺の幅員をもっているであろう。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつその変位の程度は長唄においてはさほど大でないが、清元および歌沢においては四分の三全音にも及ぶことがあり、野卑な端唄などにては一全音を越えることがある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼灑掃応対進退の節と説き、寡妻に法り、兄弟に及ぶと云い、国を治むるのもとは、家を治むるにありと云い、家整うて国則整うと云い、其の家庭の問題を如何に重大視したか、詩経などの詩を見ても、家庭を謳うたものが多いのである。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人の説によれば視力の及ぶ距離は霧の滴の直径に比例し、空気の一定容積中に含まるる水の量に反比例する。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日こんな話はあまりに夢のように聞えるかも知れぬが、過去百年間の歴史に鑑みればそのくらいな事は出来るはずだと云ったと聞き及ぶ。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが力の及ぶだけ、貧しい表現をつくしてみよう。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正に一時間半餘に及ぶ珍しき力戰、梅原さんの無念の色は深かつたが、かういふ一戰は負けても勝つても寧ろ憾みなしと言ふべきか？",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、プロレタリア文学のことに話が及ぶと、Ｔ君は、いまどきプロレタリア文学などといったら、馬鹿か、気ちがいだと思われるよと笑い出してしまった。",
              "citation": {
                "source": "田舎から東京を見る",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれでも今の公報を読めば愉快だ、それを読んで愉快な気持ちになっておるところなら平凡な事で、別にこの大先生を煩わすに及ぶまいハヽヽヽヽ」「なぜだ、これはおかしい、なぜです。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "好きこそ物の上手とやらで、自分も他の學課の中畫では同級生の中自分に及ぶものがない。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "好きこそ物の上手とやらで、自分も他の学課の中画では同級生の中自分に及ぶものがない。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "火影及ぶかぎりは雪片きらめきて降つるが見ゆ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにその後、竹村書房に對して、讀者からの直接の註文が、かなりあるので、竹村書房主はその註文を受ける度毎に憂鬱、なんとかして讀者の求めに應じたいと煩悶、あげくの果は一日、著者の陋屋をおとづれ、名案なきかと相談に及ぶ始末であつた。",
              "citation": {
                "source": "『老ハイデルベルヒ』序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、頑丈で、闘志があって、米俵をかつぐ力持にかけては村中、誰も親爺に及ぶ者がなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この広ッ場でも目の及ぶ限り芥子粒ほどの大さの売薬の姿も見ないで、時々焼けるような空を小さな虫が飛び歩行いた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……大通り四ツ角の郵便局で、東京から組んで寄越した若干金の為替を請取って、三ツ巻に包んで、ト先ず懐中に及ぶ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてまた隅田川を説きながら語次横に逸れて枝路に入ること多きは、これまた黄序に言ひけん如く、伊洛を談ずるものは必ず熊外を連ね、漆沮を語るものは遂に荊岐に及ぶ、また自然の偶属にして半離すべからざるものなればなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "池をめぐりて夜もすがらといふの情も妙ならざるにはあらざれど、川上とこの川下や月の友といふの景のおもしろさには及ぶべからず。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたり川は南東に向つて流れ、水は西岸の方深く、安宅町地先に至つては川の東部に洲を見はすに及ぶ。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の花にて菊を除きては美しさこれに及ぶべきもの無し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に思い及ぶものは、だれもが昔からよく問題にする、水の波や流れやまたは風による砂泥の波形である。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かにの弱さいくじなさをののしってみたところでかにをさるよりも強くすることは人力の及ぶ限りでない。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一種の小動物だけでもその影響の及ぶところは測り知られぬ無辺の幅員をもっているであろう。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今宵は泊るのが小菅ひとりであるし、わざわざ隣りの病室を借りるにも及ぶまいと、みんなで相談して、小菅もおなじ病室に寢ることにきめた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人とも愉快に談じ酒も相当に利いて十一時に及ぶと、朝田、神崎は自室に引上げた、大友は頭を冷す積りで外に出た。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしの春遊んだ吉野山中の宿坊に似た庭景色だと思うが、あの色つやのいい青苔と、座敷一杯に舞い込む霧のわびしさは、およぶべくもない。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一歩來やうが遲いと、最早言を費すにおよぶまい。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to be up to the task",
