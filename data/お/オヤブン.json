          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この町内会で一番の親分は、やはり昔からの酒屋のおじさんだね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はチームの親分として、いつもみんなをまとめ役を担っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔からの友人が、今では建設会社の立派な親分になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "誰か其處に來る筈の人――それは多分親分か何かゞ未だ來て居ないのを待遠しがつて噂をして居るらしかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あれァ都田村の吉兵衛親分じゃねえか」　「そうじゃねえんだ、吉兵衛親分と将棋をさしてる男よ」　「このあたりじゃ、見かけぬ顔だが……誰でえ」Ｓ＝二階の一室　離れ座敷と庭を隔てた二階の座敷。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝離れ　七五郎、傍の若い者に、　「おッ、兄哥さん、お前さんに訊ねるが、あれァ確か武井の御貸元で御座ンすね」　「そうだ」　石松が、　「そうか、あれが武井のども安親分か」　七五郎が若い者に、　「聞きゃ今日の昼間、町外れの街道で武井の御身内が一人斬られなすったと云う話だが。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」Ｓ＝二階座敷　将棋盤を中に武井のども安親分と都田村の吉兵衛。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ」　「七五郎って人が、折入って親分に話してえ事があるそうで、此処に来て居りますが」　「七五郎？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の用だ」　「これは都田村の親分で御座いますか」　安五郎が吉兵衛に、　「吉兵衛、お前の知ってる人か」　「へえ、この近在の村の若い者で御座いますよ」　「そうか、七五郎さんとやら、一体俺に何の話か知らねえが、丁度今将棋の面白え処だ、もうじき済むから済んでから話を聴こう。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「手は金銀に桂二枚」　「金銀に桂二枚と……ウー」　「へえ、親分」　また児分が襖の処へ来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ」　「清水港の長五郎って人が来て、親分にお目に掛りてえと言って下に居りますが……」　「清水の長五郎？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "金銀に桂二枚か金銀に桂二枚と」　「へえ親分へ」　児分が襖の処へ次郎長を案内して来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方が清水港の長五郎と云う方で……へえ長五郎さん、向って右が武井の御貸元、左が都田村の吉兵衛親分で御座います」　次郎長が安五郎に、　「初めてお目にかかります。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、手前共親分が石松つあんに色々御厄介に相成りましたそうで、親分に代りまして厚くお礼申し上げます」　と菓子包か何かを差し出して、　「失礼で御座いますが、どうかお納めなすって……」　源兵衛、考え込んでいる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半五郎、フト思い出して、　「じゃ源兵衛さん、うちの親分の身内になりてえと云う石松ってなァ」　「そうよ、俺の伜だ」　「ほう、じゃ、あの当時、いつも姐さんに抱かれてたあの子供が、そうかい？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今、海道一の親分と言うのは誰でしょうね」　「さー東海道には博奕打の数は多いけれど図抜けて豪いのが居ませんからね」　旅人又一人店へ入って来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年たちゃ海道一の親分が出来るって。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "海道一の親分は今あるじゃねえか」　「誰です」　「駿河の国は有度郡清水港に住む山本長五郎。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい皆ンな、石松が帰って来たぞ」Ｓ＝奥座敷　土地の御用聞き、紺久親分が来て居る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "児分、襖の外から、　「親分、石松兄哥が帰って参りました」　「そうか、帰ったか」　と次郎長、紺久に、　「帰って来ました」　「じゃ、次郎長どん、儂はお暇しよう。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分、金毘羅様って一体何処の金毘羅様で……？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "で親分何日発ちます？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "路用の金が此処に三十両、これをお前に渡すから……」　「親分、ちょッ、一寸待ってお呉んなせえまし」　「何ンだ？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「弱ったな、親分、言いにくいが……。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か他の奴を選ンでやっておくんなせえまし」　大瀬の半五郎が次郎長に、　「親分」　「何ンだ、半五郎」　「親分が石松に使えに行って来いと仰しゃるから、俺ァ隣へ釘抜きでも借りに行くのかと思って居たら、金毘羅様迄行くんじゃ石松が可哀そうだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前も旅から帰ったばかりで、お半にも逢えねえ中に、旅に出るなァ辛えだろうが、なーに、半年も経ちゃ、ほとぼりもさめるだろう」　その時、児分の一人、表から来て、　「親分、変な野郎が五六人、先刻から、表をウロウロしていますが、何かあるんじゃありませんか？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに……うちの親分もお半さんが気の毒だ、石松が帰って来れば、たとえ燧箱みた様な家でも二人の為に家を一軒建ててやるって、そう言ってたよ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺ァそれだけ言いに来たんだ」　「わざわざ有難うございました」　「じゃ帰るよ」　「親分様によろしく仰しゃって下さいね」Ｓ＝二階　お半、上って来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「親分が俺達に家を建てて呉れるって話よ」　「そうなると楽しいわね」　「お前がいつも言ってたな。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そッ其奴ァいけねえ」　鶴吉、泡喰って二階へ駈け上った処で、（Ｆ・Ｏ）Ｓ＝茶店　都田村の吉兵衛親分と、久六の児分、布橋の兼吉に小島の松五郎、それに吉兵衛の児分数吉が訪ねて来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえさん、ぶらつきやのほうでは、たいしたおやぶんさんだよ。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ぜにがたのおやぶん、たすけてください――こんや、らんとうばで、おめにかかりましょう、ひな――「…………」　平次は言葉もなく眼を見張りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幽霊にされた女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
