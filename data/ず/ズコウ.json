    "definitions": [
      {
        "index": 1,
        "gloss": "halo (of a Buddhist statue)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
