  {
    "uuid": "b5fa91a3-3d3f-5e2c-8c7d-ddb90d25fd99",
    "entry": "図工",
    "reading": {
      "primary": "ずこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
