[
  {
    "uuid": "b51f5b91-17a0-536f-876e-8eb8198f0edf",
    "entry": "銑",
    "reading": {
      "primary": "ずく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
