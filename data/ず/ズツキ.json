        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　と焦って頭突きに首を振る。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドンと鳴つて、犬の頭突きに、扉が開いた。",
              "citation": {
                "source": "雪靈續記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドンと鳴って、犬の頭突きに、扉が開いた。",
              "citation": {
                "source": "雪霊続記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くに豕箱あるを見付けて這い往き、戸を開くと大豕二頭突き出て去った。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝ると云っても六畳二室の家、唐紙一重に主人組は此方、客は彼方と頭突き合わせである。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺田は胃袋にこの頭突きをマトモにくらったから、たまらない。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁談を拒絶されても、下男の存八に不覚の頭突きをぶちかまされて気を失っても、へこたれるような寺田ではなかった。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩をも砕く頭突きの鍛錬のために脳天の二撃は致命に至らず脱するを得たが、かの小便はトドメの一刀であったと朝之助は観じた。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手をとらへて後手にねぢあげやうとしたのであるが、お綱は男の手首に血の滲むまで噛みついて執られた腕をふりはなし、男の胃袋をめがけて激しいそして敏活な一撃の頭突きをくらはせた。",
              "citation": {
                "source": "禅僧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "紋也はハーッと息を呑んだが、窮して通ずるさっそくの気転で、必ず今度こそは討って取ると、大上段に刀を上げて、切り下ろそうとしてのしかかって来た兵馬の肩へガッとばかりに、自分の頭で頭突きをくれた。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲労をしている紋也の頭突きが、猛気に精一杯燃えている、兵馬にどうして感じようぞ！",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（言いながら今度は百姓に飛びかかり、その帯のわきを両手で掴み、百姓の腹に頭突きをするように頭を当てて、グリグリしながら、両脚をピンピン跳ねる。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野郎ッ」　早くも形勢を察した大男は、女を後ろにかばって、身を沈めたと見るや、恐ろしい勢いで平次の胸へ頭突きをくれて来たのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「格子戸へ頭突きをくれて、クルリと廻ってバアと入るなんざ、よっぽどイキの良い人間でなきゃ出来ない芸当だよ」「親分落ちついていちゃいけねえ、八丁堀は煮えくり返る騒ぎだ」　八五郎は委細構わずわめき立てるのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手をとらえて後手にねじあげようとしたのであるが、お綱は男の手首に血の滲むまで噛みついて執られた腕をふりはなし、男の胃袋をめがけて激しいそして敏活な一撃の頭突きをくらわせた。",
              "citation": {
                "source": "禅僧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「白」は最後の力をふりしぼって「黒」の胸に頭突きを試みたのである。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その打撃はすばやく、的確に才次の鼻柱に当り、才次がよろめくところを、栄二は身を跼め、相手の胸へ烈しい頭突きをくれた。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――刀を抜いたとたんにどぶ板を踏み割り、三平の頭突きを胸にくらった。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いまするどく鋭刃を合せ、手はしろがねとなり、われの額きずつき、劍術は青らみつひにらじうむとなる。",
              "citation": {
                "source": "決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが彼が帰化を決心し、日本の土となることを覚悟した時、言い知れぬ寂しさとやるせなさが、心の底にうずつき迫るのを感じたであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "星が一つずつきえてゆきます。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔貌にもなんだかいやな線があらわれて来て、誰の目にも彼の陥っている地獄が感づかれそうな不安が絶えずつきまとった。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は近所のあらゆる曲がり角や芝地や、橋のたもとや、大樹のこずえやに一つずつきわめて格好な妖怪を創造して配置した。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まあ聞いてて…………まったくあなたは今まで私の気儘な謎に何の説明も求めずつき合って下さったわね。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この彷浪者魂は彼の一生に絶えずつきまとっていたように見える。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、こうなると、愚にもつかぬ、この長い袖の底には、針のようを褐色の毛がうじゃうじゃ……で、背中からむずつきはじめる。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけにまた母の不幸な生涯わけても自分の出生以前の母について順吉は想像し、そこで必ずつき當るのは最初の結婚の破綻だつた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "級全体が選挙して、文化委員、衛生委員、学務委員というものを何人かずつきめる。",
              "citation": {
                "source": "従妹への手紙",
                "author": "――「子供の家」の物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの海浜にでも、そこが少し有名な場所なら必ずつきものの、船頭の古手が別荘番の傍部屋貸をする、その一つであった。",
              "citation": {
                "source": "明るい海浜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は常に他人との接触に何時も幼い時から私についてまはつてゐる習俗的なあるものが殆んど絶えずつきまとつて私を苦しめる。",
              "citation": {
                "source": "人間と云ふ意識",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
