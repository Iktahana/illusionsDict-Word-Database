          "standard": [
            {
              "text": "律令制下において、徒人は官司での労役に従事することを命じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「徒人としての刑期を終え、彼はようやく故郷の村へ帰ることができた」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "五刑の一つである徒は、罪の重さに応じて一、二、三年の三段階があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "成吉思汗　それから、僕が忘れようとしても忘れることのできないのは、父の也速該巴阿禿児が泰赤宇徒人に攻められた時、あの危急存亡の場合に僕を助けてくれたのは、君だった。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            }
          ]
        }
