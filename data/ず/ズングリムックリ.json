        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "押並んで、めくら縞の襟の剥げた、袖に横撫のあとの光る、同じ紺のだふだふとした前垂を首から下げて、千草色の半股引、膝のよじれたのを捻って穿いて、ずんぐりむっくりと肥ったのが、日和下駄で突立って、いけずな忰が、三徳用大根｜皮剥、というのを喚く。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大高源吾とか云う、ずんぐりむっくりした人がね、笹を担いで浪花節で歩行いては、大事な土地が汚れるって。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かみの毛はぼうぼう、からだは、ずんぐりむっくりです。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずんぐりむっくりした身体で赭ちゃけた色をして、首から上が麻布団の上に向うむきに見えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "背の高い西洋の女が手に持っておもちゃにするには好かろうが、ずんぐりむっくりしたお常が持って見ると、極端に言えば、物干竿の尖へおむつを引っ掛けて持ったようである。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずんぐりむっくりだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝸牛のような私のずんぐりむっくりした影。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おむこうさまは、あたしのようなずんぐりむっくりとちがって、すらりしゃんとしていらっしゃるんですから、おなじ吉野のひき立つことといったら、着手がちがうと、こうまで変るものかと、つくづく見惚れたくらい……　そうそう、その話ね。",
              "citation": {
                "source": "猪鹿蝶",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "八穂　どうせ、あたしはずんぐりむっくりよ。",
              "citation": {
                "source": "喪服",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "下のほうでは、ずんぐりむっくり、林檎の木が、枝の林檎をゆすぶり、鈍い力で地べたを叩く。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなぐまトミーが　あんまり　ずんぐりむっくり　にやけ顔だったもので。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうすこし、やさしく扱ってくれよ」　もうひとりの、ずんぐりむっくりの猪首の女は、戸口に立ちはだかって、部屋のなかを見まわしながら、「ここは、いぜん、おれの巣だった部屋だぜ。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "おむこうさまは、あたしのようなずんぐりむっくりとちがって、すらりしゃんとしていらっしゃるんですから、おなじ吉野のひき立つことといったら。",
              "citation": {
                "source": "姦（かしまし）",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は脚の線が綺麗なので、洋服でいると、却って少女じみた可愛らしさが感じられるのであったが、和服だと脚の長所が隠されるので、変にずんぐりむっくりしていた。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "名は知らないがよく聞えよがしに「革袋革袋」と云った奴である、こいつはずんぐりむっくり小男なので、追い越しながら、「子供がこんな処へはいって来ちゃいけない」と叱りつけ、これにも明朝六時的場の森の約束手形を振出した。",
              "citation": {
                "source": "評釈勘忍記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
