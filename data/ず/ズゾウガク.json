          "standard": [
            {
              "text": "図像学の視点から名画を分析すると、画家の隠された意図が浮かび上がってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は大学で西洋美術における図像学を専攻し、神話の象徴体系を研究している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "中世ヨーロッパのステンドグラスを読み解くには、図像学の知識が不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いかなる隠微な忘れられた図像学が、一つ一つの繊細な陰影とニュアンスをかくも永続的かつ正確に再現し、夜毎の眠りに現れる幻覚を変わることなく包含し続け得たというのだ？",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
