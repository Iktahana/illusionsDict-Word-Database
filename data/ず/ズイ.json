    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Sui dynasty (of China; 581-618)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "隋の文帝の宮中には、桃花の粧あり。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "捷術　隋の沈光字は總持、煬帝に事へて天下第一驍捷の達人たり。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬曰く、隋文揚広は父子にあらずやと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "秦や隋や王笑して以て狂と為し、或は陰に之を詆詬す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "止観は隋の天台智者大師の所説にして門人｜灌頂の記したものである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人二氣あれば即ち病むとは、隋の王子の名言であつて、二氣になると病むけれども、一氣では病まぬ。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大｜隋円形の白き琅※の、沈みたる光沢を帯べる卓子、上段の中央にあり。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "武帝はけっして庸王ではなかったが、同じく庸王ではなかった隋の煬帝や始皇帝などと共通した長所と短所とを有っていた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖徳太子は、天成の御英才を以て、第三十三代｜推古天皇の摂政となり給うたが、仏教思想と共に、鋭意隋唐の文物諸制度を輸入することに努力し給うた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "太子は、内治に御心を用ゐられたばかりでなく、欽明天皇の御世に亡んだ任那日本府を復興せんとし、屡々｜新羅を御征討になつたし、又推古天皇の十五年｜小野妹子を隋に遣はされて対等の国際的関係を結ばれ、尋いで高向玄理、南淵請安などの留学生を送られたことも亦、著名な事件である。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし隋の煬帝、父を弑し継母を強姦し、しかして仏教を尊信することはなはだし。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "智者大師の滅後に、隋の煬帝が立てたと云ふ寺である。",
              "citation": {
                "source": "寒山拾得",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人二気あれば即ち病む」とは隋の王子の名言であって、二気になると病気になるが一気では病気にならない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その役にも立たない有様は、智永（中国の陳・隋時代の僧であり書家）が永い年月の間、書道を学んで終にものに出来なかったことを、米元章（中国の北宋末の文学者・書家・画家）が嘲って、「憐れむべし智永、空臼を研す」『寄薛氏詩』と言ったように、物が入っていない臼をいじりまわして日を送るのに酷く似ている。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊楠案ずるに『隋書』に日本人の獄訟を、〈あるいは小石を沸湯中に置き、競うところの者にこれを探らしむ、いわく理曲なればすなわち手｜爛る、あるいは蛇を甕中に置きこれを取らしむ、いわく曲なればすなわち手を螫す〉。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『隋書』に〈女国は葱嶺の南にあり、云々、樹神あり、歳初め人を以て祭り、あるいはと為り鶴と為り、小人は虫と為り沙と為る〉。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "隋朝起ってなお文帝に事え食を進む。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝、彪に向い、汝｜娑婆に還って大隋天子に告げ、我がこの苦を免れしめよと言うたと。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『隋書』に文帝の時、四月八日魏州に舎利塔を立つ。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "（鉄囲山叢談）　　　古御所　洛陽の御所は隋唐五代の故宮である。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "一體、類書と云ふものは詔勅誥令其他の詩文を作るために、六朝、隋書で盛んに利用せられたものであるが、之れは日本に於ても同じであつた。",
              "citation": {
                "source": "平安朝時代の漢文學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那には歴代の正史に大抵藝文志とか經籍志とか其時代の書籍目録があつて、此れに依て或る時代にどんな書物が有つたかと云ふことを知ることが出來るのであるが、唐代の書物を知るには先づ隋書經籍志、新唐書藝文志、舊唐書經籍志に依る外は無い。",
              "citation": {
                "source": "平安朝時代の漢文學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が唐代と云つても中々長い間であつて、隋書經籍志と新唐書藝文志との間には、大分永い年數がたつて居るのであるが、丁度日本で出來た日本國現在書目と云ふのが其の中間に在るので、此れに依て隋書經籍志、新舊唐書藝文志に見えない唐代の書籍を知り得るのである。",
              "citation": {
                "source": "平安朝時代の漢文學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に北朝の字の好くなつたのは北齊、北周以後であるが、これは梁の孝元帝の沒落の爲、南方の王羲之の字帖が北方に流れて入り、又王襃などが北周に南方の書を傳へたので、それが隋の頃に至つて大成して、南北を綜合したとも言ふべき立派な文字が出來たのであるが、實は南方の風を以て北派の猥陋なる書風を變化したのである。",
              "citation": {
                "source": "北派の書論",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "梁書、北史、隋書皆臺に作れり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "隋書及び北史に倭國都於邪摩堆、則魏志所謂邪馬臺者也といへり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れ隋の時には大和を以て邪馬臺と看做したる證なり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾支　　隋書、北史に擧げたる我國の官名に、伊尼翼あり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶんたくさん書くことを用意していた筈なのに、異様にこわばって、書けなくなった。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん皆にわかってもらいたくて出来るだけ、ていねいに書いた筈である。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
