[
  {
    "uuid": "421dd7a5-b126-5215-b782-2fc34337df28",
    "entry": "隋",
    "reading": {
      "primary": "ずい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
