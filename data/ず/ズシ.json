[
  {
    "uuid": "821266c9-d64d-5735-bbb0-a77292d5d469",
    "entry": "図示",
    "reading": {
      "primary": "ずし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "showing by a diagram",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "長いガラスの円筒の直径をカリパーのようなもので種々の点で測らせ、その結果を適当な尺度に図示して径の不同を目立たせて見るのもよい。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果を図示してみるとそれらの角度の統計的分布は明瞭に典型的な誤差曲線を示している。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには下に述べるような図示的方法を利用することにする。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、いかなる危険といえども、それに対する確乎たる防備さえあれば、いささかも怖るには足りないのであります」　そう云いながら、彼はくるりと黒板の方へ対いて、今度は図示に依って、実際的の説明に入った。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、いかなる危険といへども、それに対する確乎たる防備さへあれば、いささかも怖るには足りないのであります」　さう云ひながら、彼はくるりと黒板の方へ対いて、今度は図示に依つて、実際的の説明に入つた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「図示しましたその枝川がトウベツ川の本流と合する地点に年古りたる水松が屹立いたし、そこを基点として――」と阿賀妻は説明した。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその仕掛の特殊の構造も図示されたので、大概は承知していた。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "去る一月二十八日、大和御所町における差別撤廃講演のさいに、同地大正村西松本の前川増吉君所蔵の部落関係書類を借覧した中に、牛の疾病治療法を図示した一巻の伯楽伝書があった。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『正保図』を見ると大水上山の東では、駒子下と駒かたけとが最も大きく図示してある。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＱとＤとの関係を図示すると第七図のようになる。",
              "citation": {
                "source": "墨並びに硯の物理学的研究",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを十四・五度が七回、十五・五度が十回ということにして、全気温範囲について図示したものが第２図ａである。",
              "citation": {
                "source": "農業物理学夜話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　気候半旬の平均の標準値をとって、その年変化を図示すると第３図の如くなる。",
              "citation": {
                "source": "農業物理学夜話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に私は全領域を簡潔にカバーする一連の論文を用意し、夢から想起した姿、光景、装飾のモチーフ、及び象形文字のいくたりかをラフなスケッチの形で図示した。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブタの解剖学についてのある本は当時においてよく使われていた課目を図示している(6)。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにはその須弥世界と三界を、線彫りで大胆簡明に図示してある。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この雪の幻像は、東北から中部にかけての山地、殊に山形、新潟、長野、山梨の各県にわたって数多く存在するが、ここにはそのうち日本アルプスのものを幾つか選んで図示して見よう。",
              "citation": {
                "source": "残雪の幻像",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "衛生学専門書、薬理学についての著作、外科臨床のための便覧、包帯術について図示した小冊子、である。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "助産婦のための問答はラテン語に翻訳され図示されていて中世を通じて使われた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "モルガーニは試料のあるものを図示することができた筈であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊後の玖珠地方のものは久留島武彦氏が図示してくれられた。",
              "citation": {
                "source": "こども風土記",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく、人が、思はず云ひ過ぎをしてしまふやうに、自殺も、思はずしてしまふやうなものに相違ない。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論時代といふものは極めて包括的に観る場合にのみその姿を現すがやうなものであるから、現代が芸術のためには明かに不幸な時代であるとしてからが、それは必ずしも芸術家個人々々にまで直ちに不幸な時代といふことを意味しはしまい。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、事々に、真実と虚飾とを篩ひ分ける感情基底を失はずしてあることが既に問題なのである。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "則ち、右の二つの場合に就いてみると、心理的優秀といふことは、必ずしも実質的優秀を意味しない。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題を持たずしての心理的慧眼とは、文章なくての修辞の如きに過ぎまいではないか。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて貧困の家に育ち、肉親の愛にめぐまれずして家庭的、環境的の不遇に成長した人々は、そのかつて充たされなかった心の飢餓を、他の何物にも増して熱情するため、後に彼が一家の主人となった場合、その妻子の忠実な保護者となり、家庭を楽園化することに熱心である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら神にならずして、だれが眞に完全に、自分自身の主人になり得るか。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからの映画は、必ずしも「敗者の糧」を目標にして作るような事は無いかも知れぬ。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が講義のあいまあいまに大学の裏門から公園へぶらぶら歩いて出ていって、その甘酒屋にちょいちょい立ち寄ったわけは、その店に十七歳の、菊という小柄で利発そうな、眼のすずしい女の子がいて、それの様が私の恋の相手によくよく似ていたからであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、私から見れば、そんな陰口は、必ずしも当を得ているとは思えなかった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
