    "definitions": [
      {
        "index": 1,
        "gloss": "throbbingly (of pain)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
