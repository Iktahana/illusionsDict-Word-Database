        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まだズキズキするが、右手でなくてよかった」　と言って涙ぐんでいる。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう思うと、私の身うちの方々が、不可思議な快感でズキズキして来るように感じた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝、彼が母屋の中央の贅沢な呉蓙の上で醒を覚ます時は、身体は終夜の労働にぐったりと疲れ、節々がズキズキと痛むのである。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの女をいまここで殴れば、おれの自尊心は二重に傷つくのだ」　章三は傷ついたままズキズキと膿み出している自尊心のはけ口のない膿を、持て余したまま、踵をかえすと、三等車との間のドアをあけて、デッキへ出た。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "草の根方に引っかかるたんびに、眼も眩むほどズキズキと高潮する股の痛みを、一生懸命に我慢しいしい森の方へ近づいて行きました。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい生活の最初の馴れない疲労が、ズキズキと背中や後頭部にうずいていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "指はズキズキと身に応えた。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い間の無理な仕事で、小作の板のようになった腰が、今度はズキズキと痛んだ。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして全身がズキズキ痛む。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はズキズキ痛む脚を引き摺って、それでも五、六歩は走ったであろう。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一番長そうに思われる細い金針が腰骨の両側あたりへ深く入って、ズキズキと病める部分に触れて行った時は、睡気を催すほどの快感がその針の微かな震動から伝わって来た。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてズキズキと病める腰のことなぞは忘れてしまった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぞれ違う顔のなかで、彼に一番｜懐いていた長女のズキズキした表情が目だっていた。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、年寄つた女は、唇が出張つて、ズキズキした顔が多かつた。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぞれ違ふ顔のなかで、彼に一番懐いてゐた長女のズキズキした表情が目だつてゐた。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互いにあまり強く接吻し合ったものだから、二人ともその日一日じゅう前歯がズキズキ疼いたくらいであった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「別にどこも……相変らずズキズキ疼くだけよ」「どうかその、疼くだけでも早く医者の力で直らないものかねえ！",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ、一歩戸外へ出ると物凄い吹雪はまともに吹き揚げてくるし、油で真黒だったスキー靴も、寒さのため瞬く間に黄色く変り、足の指がズキズキと痛みだしたときはさすがに彼もたじたじとしました。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠くって頭の芯がズキズキするのをこらえて、朝の街に出てゆくと、汚い鋪道の上に、散しの黄や赤が、露にベトベト濡れて陽に光っていた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人はもうかなりな年であったし、私は歯がズキズキする程胸さわがしくなってしまった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼から、あんまり頭がズキズキ痛むので、娘と二人黒犬を連れて、日在浜に出て見る。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなハガキ一本で来ると云う速達、それにあっちの人はもうかなりな年だし、私は歯がズキズキする程胸さわがしくなってしまった。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ腫れてんで……ズキズキしてるんですがね……恐ろしいもんですね」「間抜けめえ。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜なぞは外した義足を、煖房の這入った壁に立てかけて寝るんですが、大雪の降る前なぞは、その義足の爪先や、膝っ小僧の節々がズキズキするのが、一｜間も離れた寝台の上に寝ている、こっちの神経にハッキリと感じて来るんです。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、そんな言葉を頭に閃めかしているうちに又、何とも知れない異常な衝動がズキズキと私の全身に疼き拡がって行くのを、私はどうする事も出来なくなって来た。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイは、婆さんに押しつけられた洗いものまで竿にとおしてしまうと、徹夜して来た眼玉の芯がズキズキ疼くような疲労を覚えた。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、まず順序として、あの夜その時刻頃、裏庭へ行ったという易介が、そもそも二つのいずれであるか――それを第一に、決定する必要があると思うのだよ」　と異常に熱してきた空気の中で、法水の解析神経がズキズキ脈打ち出した。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何故と申しますに、十四年前の古い思い出が甦り蝮に噛まれた昔の傷がちょうどズキズキ痛むように痛んで参ったからでござります。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一つにはまだ醒め切らない酒のために、頭の後ろの方がズキズキと痛んだからであった。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その烈しい光りを全身に浴びると、まだ酒に爛れている池田の神経は、ズキズキと痛んだ。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
