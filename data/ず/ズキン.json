    "definitions": [
      {
        "index": 1,
        "gloss": "headgear (esp. one made of cloth)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今の時代の子供たちは、もはや昔の子供のやうに、フアンタスチツクで荒唐無稽のお伽話――森の妖精の話や、魔法使の話や、赤頭巾の話や、鉛の兵隊の話や、親指太郎の話や、ピノチヨの話や、惡魔が人間に化けた話や――などを悦ばないといふのである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "画はやはり田舎の風景で、ゆるやかな流れの岸に水車小屋があって柳のような木の下に白い頭巾をかぶった女が家鴨に餌でもやっている。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "警報くらゐでは立ち上らぬのだが、高射砲が鳴り出すと、仕事をやめて、五歳の女の子に防空頭巾をかぶせ、これを抱きかかへて防空壕にはひる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大晦日の夜の十二時過ぎ、障子のあんまりひどく破れているのに気がついて、外套の頭巾をひっかぶり、皿一枚をさげて森川町へ五厘の糊を買いに行ったりした。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなおかしな服装をして」　四郎は赤い羽織に大黒さまのような頭巾を冠っていた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い天鵞絨の頭巾をかぶったちひさな子が、毛布につつまれて窓の下の飴色の壁に上手にたてかけられ、まるで寢床に居るやうに、足をこっちにのばしてすやすやと睡ってゐます。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人たちの頭巾やえり卷には氷がまっ白な毛のやうになって結晶してゐて、ちょっと見ると山羊の毛でも飾りつけてあるやうでした。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏の黒い尾を飾った頭巾をかぶり、あの昔からの赤い陣羽織を着た。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の頭巾は　鶏の黒尾、月のあかりは………、　しっ、歩け、しっ。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は白｜頭巾に白の上っ被りという姿である。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その実験装置のそばに僧侶のような黒頭巾をかぶったＢ教授が立って説明している。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭巾をぬぎましょうよ」「そんなことだろうと思った」と、半七も笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隊長とその附近にいた将校達は、丘の上に立ちながら、カーキ色の軍服を着け、同じ色の軍帽をかむった兵士の一団と、垢に黒くなった百姓服を着け、縁のない頭巾をかむった男や、薄いキャラコの平常着を纏った女や、短衣をつけた子供、無帽の老人の群れが、村に蠢き、右往左往しているのを眺めていた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れた百姓服や、頭巾は無抵抗に、武器を取り上げられたり、××××たり、――殺されたりなどされるがままになっている訳には行かなかった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の証拠というのはね、ゆうべお月さまの出るころ、署長さんが黒い衣だけ着て、頭巾をかぶってね、変な人と話してたんだよ。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬四郎が頭巾で顔を隠してそっと尾行します。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言い棄てに、ちょこちょこと板の間を伝って、だだッ広い、寒い台所へ行く、と向うの隅に、霜が見える……祖母さんが頭巾もなしの真白な小さなおばこで、皿小鉢を、がちがちと冷い音で洗ってござる。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭巾黒く、外套黒く、面を蔽い、身体を包みて、長靴を穿ちたるが、わずかに頭を動かして、屹とその感謝状に眼を注ぎつ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　時にかの黒衣長身の人物は、ハタと煙管を取落しつ、其方を見向ける頭巾の裡に一双の眼爛々たりき。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白の頭巾に黒服で丸く肥った｜尼たちが二人そばに立って監督している。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっ白い大きな頭巾を着た尼さんが袋をさし出している。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お高祖頭巾をかぶっている。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お篠はお高祖頭巾をかぶって、おとなしく私の後について来た。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、その検査官かも知れませんよ、私が橋場から戻る途中で、せいの高い鼠色の毛糸の頭巾を被って、黒いオーバアを着た老人技師風の人たちや何かと十五六人に会ったんです。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその赤頭巾は、苔のかんむりでせう。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭がずきんずきん痛んだ。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、あなたの上の苔がみな赤ずきんをかぶりました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か言いそうにした口の、ただまたニヤニヤとなって、大な涎の滴々と垂るる中へ、素直にずきんと刺した。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだよかないけれど、註文の間に合わそうと思って、今日初めてやりかけの仕事にかかってみたんだが、少し詰めてやるてえと、頭がずきんずきん痛むんでかなわねえ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずきんを、まぶかにかぶっていますが、その下から顔も見えました。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
