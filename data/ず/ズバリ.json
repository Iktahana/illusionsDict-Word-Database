        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今度は二人一度にズバリ――　平土間騒然たり。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同「ドッコイやらぬ」と立廻り――　＝道――　大吉、縄持ってた奴をズバリ斬って、　其処に現れた数名の捕吏と立廻り。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小郷虎吉に会いに来たのよ」　弓子はズバリと言った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この男は世の中に怖いものがないのであろうか」　弓子はピシャリと小郷の顔を撲りたい衝動を感じながら、「それから、もう一つ投書が来てるんですが……」「あはは……小郷虎吉ついに投書欄の人気者になったか」「投書の内容は、実は……」　居並ぶ芸者や舞妓の顔を、素早く見廻して、弓子はズバリと言った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしの罪じゃないわ」　寝る前とは打って変ったように、娘はズバリと言ってのけた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――それとも、あなたは自分自身を一流だと思いますか」　喋りつづけて来た信吉は、最後にズバリとそう言った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妾を……妾をつけまわしていらしたんでしょう……」　ズバリとそう言ううちに彼女の大きな眼から珠のような涙がポタリポタリと落ちた。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから先はもう家も何も無い上に、仕合わせと人間もまだ追い付いて来ていない様子で、往来には誰も居ないようですから、ヒョロ子は占めたと思いまして、高い屋根の上からその低い屋根の上に両足を揃えて飛び降りますと、その屋根は腐っていたものと見えまして、ヒョロ子と豚吉の重たさのためにズバリと破れました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏郷は是の如く厳しい男だったが、他の一面には又人を遇するにズバリとした気持の好いところも有った人だった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ズバリと度胆を抜いて頭ゴナシの短時間に退引ならぬところへ逐い詰めてしまわねばならぬ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの腐敗、堕落したユダヤ人の中で、あれだけの思い切った事をズバリズバリ云いよったところが豪い。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩歌以外に於いても遠い昔から、四季が人間に及ぼすところのものを、ズバリと言い切っているものは決して少なくない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちに待った名人のすっと胸がすくような伝法句調が、はじめてズバリと言い放たれました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "ズバリといった看破の一言に、居合わした供頭らしい尾州家の藩士が、ぎょッならんばかりにうろたえながら、荒々しくこづき返すと、江戸八百八町の大立て物をなんと見誤ったものか、けわしくきめつけました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "――行くぞッ」　ズバリと叫んで、今こそまことに冴え冴えと冴えやかに冴えまさったあの眉間｜傷に、凄婉な笑みを泛べつつ、ずいと前なるひとりにつめよろうとした刹那！",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "焚いてそのお膝の前に格之進が捧げ持っていったのをズバリと言った。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君の方がよく知ってるじゃないか」「やはりベーリング海峡ですね」と帆村はズバリといった。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しやがれた大聲で一と口にズバリと言つてのけて、それから、ざまア見やがれ、おどろいたか、と言はんばかりの調子でヘツヘツヘツとひつつるやうな笑ひ聲を長く引きながら監房の中に消えて了つた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "呀ッと驚く議員たちを尻目に、彼は忽ちシュウシュウと音をさせたかと思うと、途端に器械の尖端から噴きだす目も昏むような真青な火焔をズバリと金庫の扉にさし向けた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、小川さんとここでお話していますから」　　　　　　４　ひろ子はズバリとこう云つてツンと横を向いてしまつたが、さだ子もこの時は少しも驚かなかつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのはじめは姦通劇さ」　林田はズバリと云つて藤枝の顔を見た。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この絵巻物を使って、この事件を捲き起した犯人の正体をズバリと指す事になるかも知れないではないか。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度は思わず喝采をしたものの、流石の荒くれ男共もこうしたお作のズバリとした思付きに、スッカリ荒胆を奪られてしまって、その次の瞬間には、水を打ったようにシンとして終ったのであった。",
              "citation": {
                "source": "斜坑",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ウン、ところが熊城君、僕がズバリと云い当てたばかりに思いがけない収穫があったのだよ。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は法水に気づいて、静かに会釈したが、「ですけど先生、いったい小六さんは、自分から首を縊ったのでしょうか、それとも、誰かほかに……」　と逢痴が、ズバリと云いきったのは、この場合けっして不自然な質問ではなかった。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしが、鉄砲でおどかしているうちに、ズバリと殺っておくんなさいよ――本堂へ引き出すからさ――」　――ケッ、ケッ、ケッ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺人だって必要さ」　そこで若侍はズバリと云った。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ズバリと見抜いて了やアがった。",
              "citation": {
                "source": "柳営秘録かつえ蔵",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
