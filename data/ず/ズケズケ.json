    "definitions": [
      {
        "index": 1,
        "gloss": "(speaking) bluntly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」まるで、年増｜芸妓のような言葉を、はずかし気もなくズケズケいった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」沈着な声でズケズケと聞く。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼女はズケズケと云い放った。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "サーカスにいるだけにズケズケと言う。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると桔梗様は一層真面目に、それでいて途方もなく愉快そうに、ズケズケこんなことを云い出した。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そこでこっちも順当にいおうぜ……家の造作から推し計ると、ざっと茶の湯の師匠かな」　ズケズケとその男はいうのであった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私があからさまに彼の腕を押しのけて、そんな老獪な助平たらしい魂胆はイヤダ、とズケズケ言つてやると、「自分の浮気をうまいぐあひにおれに背負はせやがる」　彼はせゝら笑つて、とりあはなかつた。",
              "citation": {
                "source": "花火",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "入って来て、また本をおかりしますとズケズケよって行ってより出して見せもせず。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "政子は本当のところをズケズケ云ってるのだが、警察の方では男女関係アリとくれば、さてこそと二人を堅く結びつけて考えはじめるのも理の当然。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤな客にはハッキリと、「今夜は龍ちゃんが小夜子サンを送りますから、あなたはひきとって下さい」　などとズケズケ云いました。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "身から、放したことがないわよ」　笑いながら、ズケズケ云った。",
              "citation": {
                "source": "都会の中の孤島",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのご貴殿に今日逢うとは全く縁は奇なものでござる」　すると今度は裸体武兵衛がズケズケと無遠慮に訊き出した。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一葉ずつ、妙な落ち方をさせない方が、サッパリしてよかろう」　こうズケズケ言うと、放二は笑って、「先生は貧乏人の心境をお忘れですね」「そうかい」「宿がないということと、タヨリがないということは、やりきれないことなんです。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はこんなことをズケズケ云うが、倉三も奉公中はなかなか口の堅い男で、主家の話をしたがらない風があったが、ヒマをもらえば赤の他人、酒に酔わせて語らせて隣家の世にもまれな珍な内幕をききだそうという草雪の物好き。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十　冷笑鬼",
                "note": "青空文庫"
              }
            },
            {
              "text": "魯迅さんの生活は全く原稿生活でしたが、あんまり思うことをズケズケパッパッというものですから圧迫が来るのです。",
              "citation": {
                "source": "魯迅さん",
                "author": "内山完造",
                "note": "青空文庫"
              }
            },
            {
              "text": "（人が土産にくれたものをズケズケと言う）中年　（若い女を顧みてクスリとして）ばさまにかかっちゃたまったもんで無え。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小杉さんはぬけぬけした、或はズケズケした触りの微塵も無い人であるが、ふうはりした中にしまりのある、思ひやりの届く出所進退をよく弁へた、万事にキメの細かい人である。",
              "citation": {
                "source": "小杉放庵",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そればかりでなく奧樣の御歎きは、大袈裟ではありましたが、決してお人柄相應のものではなく、多分にお芝居があつたやうに見受けました」「――」　平次はズケズケと言つて退けます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "神隱し",
                "note": "青空文庫"
              }
            },
            {
              "text": "ズケズケ言う赭熊の肱に手を掛け、さも済まなそうに、「あら、勘忍して頂戴な。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの家へ入り込もうなんて無理な望みさ」　八五郎はズケズケと素ッ破抜くのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "お銀の宿　八五郎にズケズケいわれながらもお銀は黙ってついて行きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お孃さんは、昨夜外へ出なかつたのか」　指ヶ谷町の喜七は、顏見知りのお輝に、ズケズケしたことを訊ねます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "白梅の精",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「つばめの弟の與吉ですよ、九つだ相で、身體は相當ですが、智惠は少し遲い方で」　八五郎がズケズケ斯んな事を言ふのを、少年與吉は大して氣にする樣子もなく、指をくはへたまゝ、默つて二人を見詰めて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美しき鎌いたち",
                "note": "青空文庫"
              }
            },
            {
              "text": "御覽よ、先刻お前さんに嘗められたお駒ちやんの頬が、火膨れになつたぢやないか」　お勢がズケズケとやり乍ら、一番若くて美しい藝妓お駒の頬を指すのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "麝香の匂ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "勢いと力の付いている喜太郎にしては、親分の評判などは、どうでもいい問題だったにしても、改めてこう訊かれると、さすがにズケズケしたことも言えません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鐘五郎の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死骸が自分の足の下へ踏台を持って来るかね、馬鹿な話だ」　相変らずズケズケ物を言うのは下男の宇太松でした。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "お竹大日如来",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭形の親分に三月越し塩を舐めさせて、影法師も掴ませねえんだから」　ガラッ八は遠慮のないところをズケズケやります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "江戸阿呆宮",
                "note": "青空文庫"
              }
            },
            {
              "text": "御覧よ、先刻お前さんに嘗められたお駒ちゃんの頬が、火脹れになったじゃないか」　お勢がズケズケとやりながら、一番若くて美しい芸妓お駒の頬を指すのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "麝香の匂い",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那は――ズケズケ申しますが、あの宗方様を怨んでいるようなことはございませんか」「怨んでいるよ」「ヘエ――」　平次は少し度胆を抜かれました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "遺書の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、この家の總領の弟に、執こく絡みついてゐることを、薄々は知つてる私ですもの」　お清は齒に衣きせずに、斯うズケズケ言ふのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "花嫁の幻想",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
