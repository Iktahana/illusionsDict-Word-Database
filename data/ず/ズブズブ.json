    "definitions": [
      {
        "index": 1,
        "gloss": "(sink) deeply (into mud, snow, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "低い駒下駄はズブズブはいった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "……この切っ尖であんたの心臓をヒイヤリと刺しとおして、その血のついた刃先を、すぐにズブズブと妾の心臓に突き刺して死んで終おうと思っているのよ……トテモ気持ちのいい心臓と心臓のキッスよ。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "手拭を引さいた細紐を帯がわりにして、縞の着物を尻はし折りにした与太者の雑役が、ズブズブに濡らした雑巾で出来るだけゆっくり鉄格子のこま一つ一つを拭いたりして動いている。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジメネスが、一年も費ってやっとゆけた道を、俺は、ズブズブ沼土を踏みながら十日で往ってしまったよ。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあみんなの着換と子供の一組ずつここへ入れなさい」リュックに入れて河村に負って貰い、母、友子、文子（一人ずつ子供）わたし、多賀子の順で屋根から出る、畑のところ水は膝の上までズブズブもぐる。",
              "citation": {
                "source": "日記",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "と初七日の晩から女中へおみねの死霊が憑いて、「伴蔵さん、貝殻骨から乳の下へ掛けてズブズブと突きとおされた時の痛かったこと」などといいだす。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、おれはかまわず踏みこんで行くと、三歩と歩かないうちにいきなりズブズブと腰のへんまでぬかった。",
              "citation": {
                "source": "南部の鼻曲り",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "間髪をいれずに老人も、鎖に引かれて、これも滑り込むように、ズブズブと足の方から陰険なようすをした泥河の中へはまりこんで行った。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷竜は長大な頸を振りながら、浅瀬の上を歩きまわっていたが、そのうちに、足のほうからズブズブと沼の中へ入り、水の上に頸だけ出しながら、向うの岸のほうへ歩いて行ってしまった。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜半には大町に着く予定であったが、思いの外に雪が深く、斜面に来てもスキーをはいたまゝ膝の上までズブズブと埋ってしまうという始末。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜半には大町に着く予定であったが、思いのほかに雪が深く、斜面に来てもスキーをはいたまま膝の上までズブズブと埋まってしまうという始末。",
              "citation": {
                "source": "針の木のいけにえ",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭金では購えない一種特別の喜びが、圓朝の身体中をズブズブに浸した。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさ早く長雨があがったばかりのところで、土がズブズブになっているからわけはない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "金鳳釵",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷かと思って踏みこむと、ズブズブと足首まで埋まってしまう。",
              "citation": {
                "source": "白雪姫",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々ドツとあがる笑ひ聲、それも次第に納まつて、亂舞も大方｜凪いだ頃、船は向島の土手の下、三間ほどのところへズブズブと沈んでしまひました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "笑ひ茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々ドッとあがる笑い声、それも次第に納まって、乱舞も大方｜凪いだ頃、船は向島の土手の下、三間ほどのところへズブズブと沈んでしまいました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "笑い茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは板や柱の腐れ掛った所は土やペンキを塗って胡魔化してあるからちょっと見ただけでは分らぬといって、警察の役人が槍を持って来てズブズブ突き通して少しでも怪しい所があると皆取り換えさせたそうです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハテナ、もう二、三間さきかな」客　「それなら河岸をつきやれ」船頭「アイ」と竿を立てれば、ズブズブと土の中にはいる。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨灰の中に、ズブズブと踝まで隠してやって来る小坊主の腰で、その鈴が鳴りつづけているのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、列車が遅れた為、暗闇で道に迷い、イバラに足を取られて転んだ、ズブズブの沼地に迷い込み、泥まみれになったとか。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴をぬいで、水の中にはいって、球のところまで行けばよいのですが、そこはどろ沼のようなきたない池でしたから、水の中にはいろうものなら、いきなりズブズブと底のどろの中へ足をふみこみ、ズボンも上着もどろまみれになってしまいます。",
              "citation": {
                "source": "智恵の一太郎",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならば、坊主あたまの槍仕たちが、われがちに獲物を争う猟家の犬みたいに、追いまわしてズブズブ突き刺しているのは、彼らとは、味方であるはずの牢人たちへ向ってであった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨大なる角柱は、ズブズブとその中へつかって行った。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　穴の底につもった土は、底なし沼のようにドロドロして、足でふむと、ズブズブとしずんでしまいます。",
              "citation": {
                "source": "夜光人間",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "人無き駕　もがけば※くほど、彼の脚は、河の底泥土へ食い込んで、胸――肩の辺まで、黒い河水にズブズブと浸ってしまうばかりだった。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは脇差をぬいて、いきなり、あっちこっちの壁をズブズブとつき刺した。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
