        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "先ず第一に表紙の図案が綺麗で目新しく、俳味があってしかも古臭くないものであった。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏絵や図案の募集もあって数回応募した。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大網の尖端は、紐のように太く揺れて、アール・ヌーボー式の図案に見るような、印象の強い輪廓を作って、幾筋となく繋がっては、環を作る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋画家並びに図案家としての津田君は既に世間に知られている。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれらに対抗して自分の赤裸々の本性を出そうとする際に、従来同君の多く手にかけて来た図案の筆法がややもすれば首を出したくなる。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は永い前から同君の油画や図案を見ながらこういう点に注意を引かれていた。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた同君の図案を集めた帖などを一枚一枚見て行くうちにもそういう讃美の念がますます強められる。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は不幸にして未来派の画やカンジンスキーのシンクロミーなどというものに対して理解を持ち兼ねるものであるが、ただ三色版などで見るこれらの絵について自分が多少でも面白味を感ずる色彩の諧調は津田君の図案帖に遺憾なく現われている。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中や表紙の図案を流用しながら、自分の意匠を加えて、画工に描き上げさせ、印刷屋に印刷させて、問屋の註文に応じていた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "舌のさきで青い蛍のやうな色や橙いろの火やらきれいな花の図案になってチラチラ見えるのでした。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏は悪徳である、貧者はその自覚の抑圧に苦しみ、富の美徳を獲得せんと焦慮するために働きあるいは盗み奪う……」　呉服の地質の種類や品位については全く無知識な自分も、染織の色彩や図案に対しては多少の興味がある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家は農業でお父さんは村長でしたが平太はお父さんの賛成によって、家の門の処に建築図案設計工事｜請負といふ看板をかけました。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その中学の制帽の徽章にも、制服のボタンにも、桜の花が図案化せられて咲いていました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでちよつと作者は物識り振るが、この島の松林を写生して図案化したのが、煙草の「敷島」の箱に描かれてある、あれだといふ話だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙台地方には昔から、雀が多かつたのか、仙台笹とかいふ紋所には、雀が二羽図案化されてゐるし、また、芝居の先代萩には雀が千両役者以上の重要な役として登場するのは誰しもご存じの事と思ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その青年は、むす子が熱心に覗くであろう筈の新しい縞柄が飾ってある洋服地店のショウウインドウや、新古典の図案の電気器具の並んでいるショウウインドウは気にもかけずに、さっさと行き過ぎた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは偶然規則的な図案になって大河底を流れ下る氷の渦紋のようにも見えた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の聡明な物象の把握力、日本人特異の単純化と図案化。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私「重だった客は先達てのＸ図案家や、詩人のＸ氏や、哲学科のＸ氏あたりでしょう。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」麻川氏「図案家Ｘ氏も行きづまりの恰好ですな。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝の姿は見えねど、滝壺の裾の流れの一筋として白絹の帯上げの結び目は、水沫の如く奔騰して、そのみなかみの※々の音を忍ばせ、そこに大小三つほどの水玉模様が撥ねて、物憎さを感ぜしむるほど気の利いた図案である。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "発生の早い英国のメーデーは既に今日歴史を帯ばされて年中行事的に図案化した。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし見方によつては鋼の螺線で作つたルネサンス式の図案様式の扉にも思へた。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が、はっと思ったことは、あの人の図案を、ちらと見て、それが見覚えのある図案だったことでございます。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの銀座の有名な化粧品店の、蔓バラ模様の商標は、あの人が考案したもので、それだけでは無く、あの化粧品店から売り出されている香水、石鹸、おしろいなどのレッテル意匠、それから新聞の広告も、ほとんど、あの人の図案だったのでございます。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、奇妙に、あの図案にひかれて、女学校を出てからも、お化粧品は、全部あの化粧品店のものを使って、謂わば、まあ、フアンでございました。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん、うっかり者のようでございますが、けれども、それは私だけでなく、世間のひと皆、新聞の美しい広告を見ても、その図案工を思い尋ねることなど無いでしょう。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "図案工なんて、ほんとうに縁の下の力持ちみたいなものですのね。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又三郎が昨日のことなど一言も云わずあんまりそらぞらしいもんですからそれに耕一に何も云われないように又日曜のことなどばかり云うもんですからじっさいしゃくにさわったのです。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まずあんた方にご理解いただきたいのは、俺とあいつは幼なじみってことです。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
