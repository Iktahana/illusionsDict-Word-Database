[
  {
    "uuid": "e4862331-a851-5f3b-871e-4460b1c21854",
    "entry": "済み",
    "reading": {
      "primary": "ずみ",
      "alternatives": [
        "すみ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
