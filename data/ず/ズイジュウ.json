[
  {
    "uuid": "c6bee5f7-20f7-55a1-879c-8a4726122631",
    "entry": "随従",
    "reading": {
      "primary": "ずいじゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
