        "examples": {
          "standard": [
            {
              "text": "副腎の髄質からは、驚いたり緊張したりした際にアドレナリンが分泌される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "腎臓の構造を調べると、皮質と髄質でそれぞれ異なる機能を持っていることがわかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "組織標本を作成し、髄質部分の細胞形態に異常がないかを確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "（＊アドレナリンは副腎髄質ホルモンであり、アディソン病は副腎皮質機能低下である）　科学の歴史でこれらのいわゆる内分泌腺の発見以上に魅惑的な話は多分ないであろう。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして浅い油皿に入っている木髄質の燈心若干に点火するのである。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
