        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "湛々タル露アリ陽ニ非ザレバ晞ズ厭々トシテ夜飲ス酔ハズンバ帰ルコトナシ　明らかに貧しい生活なのにもかかわらず、まことに融々たる裕かさが家中に溢れている。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "體刑ト明示セル所以ハ其ノ弊風實ニ體刑ヲ以テセズンバ一掃スル能ハザル官吏横暴國ナルヲ以テナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "而シテ其責ヤ実ニ政府当局ノ怠慢曠職ニシテ上ハ陛下ノ聡明ヲ壅蔽シ奉リ下ハ家国民生ヲ以テ念ト為サヾルニ［因→在］ラズンバアラズ。",
              "citation": {
                "source": "直訴状",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "一類之ヲ哀ンデ而シテ之ヲ諫メズンバ、亦世人ヲシテ一類ヲ哀マシメン。",
              "citation": {
                "source": "阿房山賦",
                "author": "成島柳北",
                "note": "青空文庫"
              }
            },
            {
              "text": "然リト雖ドモ吾徒ノ奇禍ヲ買ヒ苦境ニ堕ルモ、亦汝ニコレ因ラズンバアラズ。",
              "citation": {
                "source": "祭活字子文",
                "author": "成島柳北",
                "note": "青空文庫"
              }
            },
            {
              "text": "子寿｜欣然トシテコレヲ受ケ改メズンバ措カザルナリ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人ハ古器ヲ好ミ一人ハ新器ヲ好メバ則チ人ハイマダ古器ヲ好ムヲ以テ勝レリトナサズンバアラズ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「素面｜欄鉤ニ倚リ、嬌声｜外頭ニ出ヅ、若シ是織女ニ非ズンバ、何ゾ必シモ牽牛ヲ問ハン」　これに驚いたのは夫人でなくて、その良人の県令であった。",
              "citation": {
                "source": "岷山の隠士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然レドモ同一ノ人民ヲ目的ト為シテ強奪ヲ恣ニシ悪俗ヲ改メシメズンバ、遂ニハ自主自裁ノ特権ヲ以テ国内ヲ悩マスニ至ルベシ。",
              "citation": {
                "source": "アメリカ独立宣言",
                "author": "福沢諭吉訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "会スヤ　明月清風　自己ノ三昧青山緑水　打成一片モト自カラ地獄ナシアニ又　天堂アランヤモシ未ダ会セズンバ山僧ガ提携シ去ルヲ看ヨ……　洪天さんの右肩が、ぐいとあがる。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "一旦青銅器ヲ使用スルニ非ズンバ鐵器ヲ使用スル事能ハズトノ理由一モ存スル事無シ。",
              "citation": {
                "source": "石器時代總論要領",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶望シ、悲観シ、空シク絶滅スルカ、然ラズンバ辱ヲ忍ンデ逃ゲテ故国ノ空ニ帰ランカ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "而シテ其責ヤ実ニ政府当局ノ怠慢曠職ニシテ、上ハ陛下ノ聰明ヲ壁蔽シ奉リ、下ハ家国民生ヲ以テ念ト為サザルニ在ラズンバアラズ。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、阿難ヨ、カクノ如キ人モシ慾惑ヲステズ、マタ出家セズンバ、必ズ地獄ニ堕セン。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに頼もしく思うか知れめえ」「…………」「権三、虎穴ニ入ラズンバ虎児ヲ得ズ――ってえのはこのことだよ。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "新田｜右衛門佐義貞誅伐セズンバ有ル可カラズ一族相催シ急ギ馳セ参ジラレヨ　と、すべて同文で、また、はなはだ簡である。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            }
          ]
        }
