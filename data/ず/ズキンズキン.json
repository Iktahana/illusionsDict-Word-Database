        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "頭がずきんずきん痛んだ。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだよかないけれど、註文の間に合わそうと思って、今日初めてやりかけの仕事にかかってみたんだが、少し詰めてやるてえと、頭がずきんずきん痛むんでかなわねえ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして紙の上に思い出すままに勝手な字を書いたり、形の知れない形を書いてみたりしながら、ずきんずきんと痛む頭をぎゅっと肘をついた片手で押えてなんという事もなく考えつづけた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、翌日の晩、奴をやっつけた同じ時刻になると、右の眼が又もやずきんずきんと痛み出しました。",
              "citation": {
                "source": "按摩",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると又、その翌日の同じ時刻に、右の眼が前晩よりも一層はげしく、ずきんずきんといたみ出しました。",
              "citation": {
                "source": "按摩",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "こごんだまま唖のように先達の惨死を弔っていた徳一老人は、急にどこかずきんずきん痛み出したように顔をしかめた。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "体中にうけた傷がずきんずきん痛みますし、もう疲れきってのどが渇いてたまりませんので、水があるかと思って谷へずんずん下りていきますと、はるかの谷底に一すじ、白い布をのべたような清水が流れていて、月の光がほのかに当たっていました。",
              "citation": {
                "source": "葛の葉狐",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その静寂の中に聞えるものとては、ただ自分の動悸と、顳※のあたりにずきんずきん波打っている血の音だけだ。",
              "citation": {
                "source": "空家",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "顳※のあたりがずきんずきんして、総身が憤恚で酔っぱらっているようであった。",
              "citation": {
                "source": "麦畑",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "手も足も、動かせば、すぐずきんずきんと頭に響いた。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は、そのとき始めて、脈をうつたびに、左腕がずきんずきんと痛むのに気がついた。",
              "citation": {
                "source": "人造人間の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「船長、いよいよメリー号が浮きあがりますよ」　老船長は、安楽いすの上に寝そべって、ずきんずきんといたむ腰をさすっていたが、クーパーのこの言葉に、子供のように目をかがやかすと、「わしは夢をみているのじゃないかな。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずきんずきん……という音のようなものが、手拭越しに伝わってきた。",
              "citation": {
                "source": "変な男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯がずきんずきん痛んでいた。",
              "citation": {
                "source": "溺るるもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の頭は、急に、ずきんずきんと痛みだした。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身におぼえるけだるさ、そしてずきんずきんと頭のしんが痛む。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がついてみると、脳天がまるで今にも破れそうに、ずきんずきんと痛んでいるのです。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭はずきんずきんと痛む。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずきんずきんと頭痛がして、眼に見る物の線がそれにつれてちらちらと震えた。",
              "citation": {
                "source": "蘇生",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずきんずきんする右手の疼痛から、一切の情景が記憶によみがへつて来た。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭痛がずきんずきんしてゐた。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの腰は、その時すごい力でなぐり倒されて、いやっというほど地面にうちつけたので、いまでもずきんずきん痛んでますよ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭はぐらぐらして、熱のためにずきんずきん痛んだ。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "心臓はずきんずきんと打って、呼吸が喉につまりそうなのであった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずきんずきん蟀谷がうずき、頭の皿の皮がつっぱってしめつけられるようで、この手紙をかくこともやっとの思いです。",
              "citation": {
                "source": "人魚",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
