[
  {
    "uuid": "8ed5f4cb-e7df-520a-8373-bdd7806430c7",
    "entry": "図",
    "reading": {
      "primary": "ず",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-接尾辞"
