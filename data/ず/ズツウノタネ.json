[
  {
    "uuid": "219d856b-b982-52c5-870f-ccb726e9d29b",
    "entry": "頭痛の種",
    "reading": {
      "primary": "ずつうのたね",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
