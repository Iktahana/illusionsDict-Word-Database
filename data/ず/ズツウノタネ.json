    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cause for headaches",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "カントは頭痛の種である。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが柳吉の頭痛の種だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "当人からと思われるこちらの手紙が、彼の頭痛の種に少しく光を当ててくれるやも。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角僕は、これから一寸警察へ行かなくちゃあならん――」　さて、青山喬介が雄太郎君の頭痛の種を取り除いて呉れたのは、それから三日後のことだった。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そこで、そのあなたの頭痛の種を一掃してしまう手段が、ここに一つあります。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "輝子の家の家業は栄えてゐるが、妙なことには去年から中学生となつた長男が放浪癖が甚だしくて頭痛の種にされてゐる。",
              "citation": {
                "source": "奇友往来",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛馬の両便と都市の美観衛生問題は、これ誰しも頭痛の種である。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち極東ソ領や、ヒリッピン等はソ、米のため軍事上の弱点を形成し彼らの頭痛の種となるのであるが、その反面、ソ、米は我が国の中心を空襲し我が近海の交通を妨害するに便である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果は、母親のない子供等を慰めることは出来ても叱ることの出来ない人達に取って、いかに頭痛の種であるかを見た。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、それよりも明日に迫つてゐる大事件が頭痛の種だ。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「その舅さんが俺の頭痛の種だて！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは六人兄弟で、私の下にまだ三人も小さいのがいるので、一日の食事は頭痛の種だとお父さんが口癖のように云うようになつた。",
              "citation": {
                "source": "淪落",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞に私が離縁したことが出ると同時に、いろんな人がいろんな手で私に結婚を申込んで来て、これがまた頭痛の種でした。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "切支丹禁令以来、神父を入牢せしめれば牢番が感化され、斬首火刑に処すれば刑吏や観衆が感動して却つて改宗する者がある始末に、この対策が頭痛の種で、死の荘厳を封じることが、一代の大事となり、一六三三年、穴つるしといふ殺し方が発明された。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、某名流婦人の感想にもあつた通り、盆暮の「進物」が収入の重要部分を占めてゐるやうな職業もあるとのことであるし、一般の場合でも、日本人はこれを「義理」と呼んでゐるところをみると、この義理の始末をどうつけるかといふことが頭痛の種になるであらう。",
              "citation": {
                "source": "続言葉言葉言葉（その二）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その礼になにを持つて行かうか、といふよりも、どの程度のものを持つて行かうかといふことが頭痛の種になる。",
              "citation": {
                "source": "日本文化の特質",
                "author": "――力としての文化　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろ嫁を貰つてやりたいのだが、これがまた、頭痛の種だつて、おやぢさん、嘆いてゐたよ」　父の言葉にかぶせて、母が引きとつた。",
              "citation": {
                "source": "髪の毛と花びら",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま一塁か三塁よりへファウルフライがあがって、スパイクがグローブにひっかゝってエラーしたら、どういうことになるのだろうと気にかかって見ていると頭痛の種になるのである。",
              "citation": {
                "source": "神経衰弱的野球美学論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "タツノに恋人のなかつたことが、今となつては人々の頭痛の種になるのであつた。",
              "citation": {
                "source": "老嫗面",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ頭痛の種もあつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "老教育家先生だちの本当の頭痛の種になっていい害毒は、まだまだ他に沢山ある。",
              "citation": {
                "source": "流行唄",
                "author": "兼常清佐",
                "note": "青空文庫"
              }
            },
            {
              "text": "お偉がたにしてみればそれが頭痛の種でしてね、ですからお顔の剃り方、おぐしの作り方が、それはそれは大事な役目だったわけです。",
              "citation": {
                "source": "かもじの美術家",
                "author": "TUPEJNYJ HUDOZHNIK",
                "note": "青空文庫"
              }
            },
            {
              "text": "新たな外来の勢力、五か国も束になってやって来たヨーロッパの前に、はたしてこの国を解放したものかどうかのやかましい問題は、その時になってまだ日本国じゅうの頭痛の種になっていた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちこっち、無茶苦茶によごすのではあるまいか……これ等の心配は、海軍側の頭痛の種子でもあった。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "音があると思う人には、これぐらいウルサクて頭痛の種のところもないかも知れないが、無神経の私には、こんなに音のないところはなかった。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "南茅場町の金山寺味噌問屋八州屋の女隠居が両三日｜行方不識になっていること、これがこのごろ藤吉の頭痛の種だった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "三つの足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争この方、贅沢品にちがひない銀狐の毛皮はぱつたり売行がとまり、そのうへ、飼料たる生ニシンや馬肉の入手もすこぶる困難になつたので、増殖はおろか、百頭あまりもゐた狐をどう始末するかゞ頭痛の種であつた。",
              "citation": {
                "source": "それができたら",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "過剰労働力がうようよしていて夫が頭痛の種でさえある処に、特殊な女性向き労働を除いて、不熟練な婦人労働力など何の必要があろう。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は一切の反唯物論的認識論者の頭痛の種であるらしい。",
              "citation": {
                "source": "認識論とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "他のどこでも雇ってもらえないようなやる気のない貧乏な残りかすに落ちこぼれていく彼の事務員たちも激しい頭痛の種だった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
