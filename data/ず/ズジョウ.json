[
  {
    "uuid": "c1fb7ead-9b10-51f6-9b26-703291ab4075",
    "entry": "頭上",
    "reading": {
      "primary": "ずじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
