        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "八雲立ちといひたまはで、八雲立つと言い切り玉へるも彼の奇しき瑞雲に驚かせ給へる語勢なりなどいへる、ことに奇しき言なり。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "慧鶴が清水の土地を思い切り、美濃の檜木の瑞雲寺へ入って馬翁という詩僧に従ったのは、勿論、娘と得体の判らぬ心理の関係にある、その境地から逃れよう為もあったが、僧でもなく俗でもない身持で、風雅に対してだけ快楽を求める生活が、俄に不安を増して来たからだった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "美濃の大垣の町から西北に当って、町へは一日のうちに往来出来る里程のところに在る檜木村の瑞雲寺へ来てみると、聞きしにまさる破れ寺で、寄宿して勉強するのは許して呉れたが、台所向きは苦しそうで、待遇は随分ひどかった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の初めから夏安居に入って、破れ寺の瑞雲寺でも型ばかりの結制を行っていた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来上がったのが四月……桜の花の散る頃でありました（手伝わせた弟子には林美雲氏も山本｜瑞雲氏もおりました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "皇居御造営の事、鏡縁、欄間を彫ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "また山本瑞雲氏は現存で今日盛んに活動しております。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "皇居御造営の事、鏡縁、欄間を彫ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は元萩原国吉といいましたが、後に実家の山本姓に復し号を瑞雲と改めました）。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "皇居御造営の事、鏡縁、欄間を彫ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、私は自分の名札を出し、住所氏名を改めて名乗り、これから自分で狆を伴れて行こうかと思いましたが、貴君の書き附けを持ってお出でならお使いでもお渡ししますと、充分に私を信じてくれておりますので、私は家に帰り、弟子の萩原国吉を使いにやりました（この国吉は今の山本瑞雲氏の旧名。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "葉茶屋の狆のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今夜は屹度大漁だ、あれは君、マグロ雲といふ瑞雲だよ――」と云ひ終らないうちに鴎丸は、腰の法螺貝を取りあげて歓喜の合図を吹いた。",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この子供が後の山本瑞雲氏であります。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "西町時代の弟子のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "国吉は後に仔細あって旧姓山本に復し山本瑞雲と号したのです。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "西町時代の弟子のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞雲氏は実父、養父の気性を受けてなかなか人の世話をよく致します。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "西町時代の弟子のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも名高いのは和泉の中瑞雲斎で、これは長男克己、二男鼎、三男建と共に入牢した。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "知名の士にして親兵の籍に入つたものには、先づ中瑞雲斎がある。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞雲斎は根来氏の三男に生れて宗家を襲ぎ、三子を生んだ。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞雲斎は早く家を克己に譲つて、京都に入り、志士に交つた。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "四郎左衛門等の獄起るに及んで、三子と共に拘引せられ、瑞雲斎は青森県に護送せられる途中で死し、克己、建は京都の獄舎に死し、鼎は幽囚十年の後｜赦された。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞雲斎と事を与にした人に十津川産の宮太柱がある。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "繍帳原形は中央に浄土変相をあらわし、瑞雲、霊鳥、霊樹、雲形、花鳥、人物、鬼形、仏像などを、周りに大銭のような亀甲が一百ばかりつらなり、一甲に四字あて、すべてで四百字、この繍文によって繍帳製作の由来をあらわしたと言われる。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山本国吉（後の瑞雲さん）が一所懸命父の代作をして、それを三幸商会に持って行き、其の日の薬代などにしていたらしい。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の弟子分では山本瑞雲などが美術学校に就職する前の輸出物を拵えていた時分からの弟子で、高村家の大久保彦左衛門だと威張っていた。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みゑ子が手離しで歩きだしたと言って笑い、転んだと言っては騒ぎ、家のなかはいつも薫風瑞雲が漂った。",
              "citation": {
                "source": "盗難",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ、なにか変った趣向があるのだろうが、ちょうどいい折だから、かまわず出かけて行って遠慮なしに御馳走にあずかることにしよう」　馬鹿な顔で、陽ざしを見あげているとき、すぐそばの瑞雲寺の刻の鐘、ゴーン。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "よもやと思っていた係与力の耳へ、谷中瑞雲寺の閻魔堂のそばで、つい、たった今、また娘がひとり殺られたという急な報せ。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞雲寺の石塀をへだてた隣りの家。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "物干場から瑞雲寺の石塀までは、大体、五間ほど離れている。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "六、「鶴の子石鹸」の事　　並に博士の怪弁の事　新玉の年たちかえる初春の朝、大内山の翠松に瑞雲棚引き、聖寿万歳を寿いで鶴も舞い出でよう和やかな日和。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞雲院の庭のつくばいは二方の踏石から辿ることになり、一枚の短冊石を踏んで行くのであるがその打ち方も厳格であった。",
              "citation": {
                "source": "庭をつくる人",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "光太郎さんの現代の魅力はそこに在り、同時に、その魅力の故に、岸田さんなんかに引っぱり出されて、いくらか理性のくらい詩を瑞雲たなびく式に書いたりするところが、あぶないあぶないよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、君がぐずぐずいうんなら、あすこへ行ったらわかるよ。",
              "citation": {
                "source": "予謀殺人",
                "author": "A CASE OF PREMEDITATION",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
