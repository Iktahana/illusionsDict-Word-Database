[
  {
    "uuid": "4f610d05-0f14-5eb3-99a0-cdd5f862ec73",
    "entry": "ずり込む",
    "reading": {
      "primary": "ずりこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
