[
  {
    "uuid": "a0c09d2e-934e-5e6a-a386-68b04607b252",
    "entry": "随身",
    "reading": {
      "primary": "ずいじん",
      "alternatives": [
        "ずいしん"
      ],
      "is_heteronym": false
    },
    "grammar": {
