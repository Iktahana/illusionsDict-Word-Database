[
  {
    "uuid": "1eaefdff-d75a-5a50-858f-eac97bf85c0e",
    "entry": "砰",
    "reading": {
      "primary": "ずり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "earth removed from a mine (or tunnel, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "短歌や俳句がちやんとした娘ならば、詩の多くは云つてみればおひきずりであつた。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ン坊の泣声や、おひきずりの靴の音や、昆布や烏賊や洟紙や首巻や、みんなみんな、街頭沿ひの電線の方へ荷馬車の音も耳に入らずに、舞ひり吁！",
              "citation": {
                "source": "暗い天候",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時三つ斗りなる兒の、小く太りたるが、大きなる大人の下駄を引きずりて、縁先近く參りたる、覺束なき足もとなり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "行きずりの小草の中に。",
              "citation": {
                "source": "絶句四章",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "草花に処々釣り下げたる短冊既に面白からぬにその裏を見れば鬼ころしの広告ずり嘔吐を催すばかりなり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶壁の下なる大深谷からは、霧がすさまじいいきおいで、皺嗄れ声を振り立てて上って来る、近づくほど早くなるかと思うと、端から砕けてサアッと水球を浴びせる、そうして呻りながら、尾根につかまり、槍先へ這いずり上って、犠牲になる生霊もがなと、捜し廻っている。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の峰からは、大残雪が横尾の谷へと白く走っている、御幣岳からずり下りに、梓川の方へと立て廻わす大岩壁は、屏風岩とも、仙人岩とも言うそうで、削ったようなのが、大手をひろげて立ち塞がっている、東の空にピラミッド形をしてそそり立っているのは、常念岳らしい。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを刳りつくすと、また雪がずり下りて、一段低い所へ同じものを作るので、日本北アルプスにはそれが頗る多い。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "浚渫船のデッキには、石油缶の七輪から石炭の煙が、いきなり風に吹き飛ばされて、下の方の穴からペロペロ、赤い焔が舌なめずりをして、飯の炊かれるのを待っていた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時に彼の足は小荷物台から攫われて、尻や背中でゴツンゴツンと調子をとりながら、コンクリートの上へ引きずり下された。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の中の蠅のように、船舶労働者は駆けずり廻って、荷役をした。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、土方風の男が一人縄で何かガラガラ引きずりながら引っぱって来るのを見ると、一枚の焼けトタンの上に二尺角くらいの氷塊をのっけたのを何となく得意げに引きずって行くのであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "負傷した片足を引きずり引きずり杖にすがって行く若者の顔にはどこへ行くというあてもないらしい絶望の色があった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間の心が蒸発して霞になりそうな日だね」と言ったら、一｜間ばかりあとを雪駄を引きずりながら、大儀そうについて来た妻は、エヽと気のない返事をして無理に笑顔をこしらえる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓜わらべにちょっと頬ずりして土に置いた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラムプのあかりに暗の中から引きずり出された梢の緑、　実に恐ろしく青く見える。",
              "citation": {
                "source": "女",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある家庭で歳末に令嬢二人母君から輪飾りに裏白とゆずり葉と御幣を結び付ける仕事を命ぜられて珍しく神妙にめったにはしない「うちの用」をしていた。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏白やゆずり葉を輪の表に縛り付けるか裏につけるかを議論していた。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と僕が改めて質問したのは、彼が金澤の舊家である古寺から、煤で黒くなつたまひら戸を引きずり出し、玄關や茶座敷の戸にしたのを見た時であつた。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "容貌から言へば、君は猪のやうにゴツゴツしてゐたし、おまけに亂暴書生の如く肩を怒らし、ステツキを突いて高下駄を引きずり歩いた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と又、Ｔ「引ッ込ま無きゃ　ひきずり下す！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、首筋掴んだ儘、五郎蔵を曳きずり起し、Ｔ「さすれば　命だけは助けて　やるとなァ」　と叫んでドンと突けば、　五郎蔵二三間コロコロと転がった。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三マルでおゆずりくださいませ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうか、それでもまだ先はなかなか遠いなあ‥‥」と、河野は右手の銃を重さうにずり上げながら云つた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "防寒靴は雪の中へずりこみ、歩くたびに畚のようにがく／＼動いた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柵を開けてやると、彼女は大きな腹を地上に引きずりながら低く呻いてのろのろ外へ出た。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、雪の上にそれを引きずりながら、馳せていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに老人や子供等にも一人一人｜丁寧に礼を云ってから、とぼとぼと片足を引きずりながら出て行くのであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々休んで何か捜すような様子をするかと思うとまた急いで下りて行く、とうとう枝の二叉に別れたところまで来ると、そこから別の枝に移って今度は逆に上の方へ向いて彼の不細工な重そうな簑を引きずり引きずり這って行くのであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
