          "literary": [
            {
              "text": "もし茶祖が今｜甦るなら随喜の涙を流すであろう。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に「茶」の方では、神様に近いまでの位置を得て、彼らに随喜の涙を流す人たちさえ少くない。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶人が見たら随喜の涙を流すね。",
              "citation": {
                "source": "台湾の民藝について",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「南――無」　群衆はこの奇蹟に直面して、ただ感嘆の声を併せるばかり、中には大地に土下座して、随喜の涙を流す者さえあります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "火遁の術",
                "note": "青空文庫"
              }
            }
          ]
        }
