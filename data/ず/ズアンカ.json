    "definitions": [
      {
        "index": 1,
        "gloss": "designer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "洋画家並びに図案家としての津田君は既に世間に知られている。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私「重だった客は先達てのＸ図案家や、詩人のＸ氏や、哲学科のＸ氏あたりでしょう。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」麻川氏「図案家Ｘ氏も行きづまりの恰好ですな。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その父は相変らず会社の重役であり、兄は豪勢な図案家であると吹聴した。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「杉浦ね、図案家の。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とかいう京都の扇工場に西班牙人の図案家がいて――ま、扇のことはこのさい第二だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにもない様に顔の小さい、足の長い美人たちが、それが商売である図案家によって、奇想天外に考え出されたモードのおしゃれをして、たったり坐ったり寝そべったりしています。",
              "citation": {
                "source": "若人の要求",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち今の図案家の渋江終吉さんである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "終吉は図案家で、大正三年に津田青楓さんの門人になった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の遊覧地の広告がしたいので注文すると、図案家は早速銀泥を皿に盛って大きな月を塗るであろう。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "図画教師たちや図案家、名家の令嬢、細君、女学生、会社員、あらゆる職を他に持っている人たちの余技として、絵画が普及し隆盛になりつつあるようである。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "新進作家にして同時に小学校の訓導であり、百貨店の宣伝部員であったり、図案家であったり、会社員であったり、ヱレヴェーターボーイであったりする。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の図画の教師達や図案家、名家の令嬢、妻君、女学生、会社員、あらゆる職を他に持っている人達の余技として、絵画が普及し、隆盛になりつつある様である。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の図案家程度では図案にならない、帝展の工芸じゃしようがないというんだろ。",
              "citation": {
                "source": "素人製陶本窯を築くべからず",
                "author": "――製陶上についてかつて前山久吉さんを激怒せしめた私のあやまち――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして総ての図案家は愚かにも絵画と図案とが如何に異うかをまるで知らないのである。",
              "citation": {
                "source": "北九州の窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれは私には、もっと現実的に――あたかも図案家が単にありきたりの囲あるいは後光でないように、しかしよく見ると真の魚であるように故意にしたものであるように見えました。",
              "citation": {
                "source": "金の十字架の呪い",
                "author": "チェスタートン",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
