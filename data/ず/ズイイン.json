[
  {
    "uuid": "8b1b2b1e-0a5e-5578-89ee-509ec6ee073e",
    "entry": "随員",
    "reading": {
      "primary": "ずいいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
