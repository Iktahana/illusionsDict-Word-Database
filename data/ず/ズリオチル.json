    "definitions": [
      {
        "index": 1,
        "gloss": "to slip down",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "娘というのは数え歳は十六だそうだが、見たところやっと十二か十三で、脾弱な胴に結んだ帯がともすればずり落ちるほど腰の肉などなかった。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こんどはもっと大きく、ずり落ちるスカートの紐をひきあげながら声を掛け、戸はたたかず、ガタガタとひっぱりながら、無理にこじあけようとしていると、酒くさい息がふっと上から落ちて来て、「誰……？",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずり落ちる下界は、自動車が（ここへは通る）待っていました。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆はふらふらとしたまま、欄干からずり落ちるように身を投げた。",
              "citation": {
                "source": "身投げ救助業",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも踏みしめても、踏みしめても、足下の大地のずり落ちるような心を制することができないのだ。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　レエスやナプキンの中へずり落ちる道。",
              "citation": {
                "source": "軽井沢で",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車は、不意にずり落ちるやうに、切通しの坂を下つて行つた。",
              "citation": {
                "source": "イボタの虫",
                "author": "中戸川吉二",
                "note": "青空文庫"
              }
            },
            {
              "text": "信仰生活の大安心、大喜悦の中に入り得るためには、血を吐くような深刻な悩みと、砂漠をうろつくような彷徨と、大地のずり落ちるような不安と、盲目になるほどの迷いとがあるべきはずだと思う。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "反射的な全身の努力によつて、自分が尻もちをつき、信子が胸からずり落ちるのに、嘘のやうに緩慢な時間があり得たことを意識した。",
              "citation": {
                "source": "恋をしに行く（「女体」につゞく）",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭がしぜん台のほうへ垂れさがって、ジャガイモが眼のなかでちらつき、庖丁が手からずり落ちる。",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆき子は、足がかりもない砂山の中途から、ずるずるずるずると不可抗力で谷底までずり落ちるような恐怖に打たれた。",
              "citation": {
                "source": "我に叛く",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘が一人の女友だちと話しているうちに、何だかはしゃいだ様子で笑いながら、首をぐっと横に曲げたところと、その手を――大して細くもなく大して上品でもない小娘風の手を、一種の所作で後頭へ持って行った拍子に、白い紗の袖口が、肱から肩のほうへずり落ちるところとを見た。",
              "citation": {
                "source": "トニオ・クレエゲル",
                "author": "TONIO KROGER",
                "note": "青空文庫"
              }
            },
            {
              "text": "インゲボルグが何だかはしゃいだ様子で笑いながら、首をぐっと横に曲げて、その手を――大して細くもなく大して上品でもない、小娘風の手を、一種の所作で後頭へ持って行った拍子に、軽い袖口が肱から肩の方へずり落ちるのを見た。",
              "citation": {
                "source": "トニオ・クレエゲル",
                "author": "TONIO KROGER",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会的にずり落ちればずり落ちるほど、そして第二、第三の妻との関係がうまくいかなければいかぬほど、この男の呪いと怨嗟の対象は、昔自分に一顧も払わなかったアンジェリカというその初恋の女にかかっていくらしく思われました。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "足首を挫いたらしいつなは、駆けだそうとして低く呻き、抱えている万三郎の手からずり落ちるように、雪の中へ倒れた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
