        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "強い男、半次を肩に担いでズドンと投げた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ズドンと大砲をぶっぱなしたら、陰気くさい支那人が『デモだ』なんて云ってるのよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那で金を多額に懐中していることは、ズドンとやられる機会を、より多く持つことだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ズドンと一発やられたあとで、来なけゃよかったと、後悔したって、もう追っつかねえでがすよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ズドンの音とともに僕自身が後ろに倒れた。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "小十郎はぴったり落ち着いて樹をたてにして立ちながら熊の月の輪をめがけてズドンとやるのだった。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ズドンと一発やりたいなと署長は思った。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろ向きになって、的の姉さんを袖姿見に映して狙いながら、銃口を、ズッと軽く柔かに肩に極めて、そのうしろむき曲打にズドンと遣るんだ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊は鉄砲をとりあげると、あおむけに寝たまま額の真上の空にねらいをつけてズドンと射ち放した。",
              "citation": {
                "source": "兵隊の死",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "人相と言い、場合と申し、ズドンとやりかねない勢いでごさいますから、画師さんは面喰らったに相違ございますまい。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなかったら、馬に一発ズドンとやってしまうぞ」　ホームズは私の膝の上に手綱を置いて、馬車から飛び降りた。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "16権太郎は殆んど全身をむき出しにしてズドン、ズドンと何時までも射撃してゐるばたり、ばたりと山鳥は果実でも落ちるやうに足元へ落ちてきて地上で狂はしく羽を舞はしてゐる。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "網苧の山里の立場茶屋に猪嚇しの鉄砲が用意してあるほどなら、道節も宝刀を捻くり廻して居合抜の口上のような駄弁を弄して定正に近づこうとするよりもズドンと一発ブッ放した方が余程早手廻しだったろう。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち本店を復興すると同時に、東京市内各区に一つ宛デパート式のデパートを作ったが、それがズドンと当って繁昌するわ繁昌するわ。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「――『赤毛のゴリラ』よ、地下に瞑せよ」　ズドン。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――Ｂ首領の「折れた紫陽花」は決心をしたものか、その返事の代りに、ズドンズドンと拳銃の銃口を、組みあった二人の方に向けた。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と恋人は野に転び小指をつなぎ合はせて接吻したが恋人は此世ではとても食つて行けないからと私の小さい胸をぶち抜かうとした赤い火花が固いセツケンになつてしまつた私は支那料理が食ひたくなつて海上を一目散に逃げ出したズドン一散！",
              "citation": {
                "source": "蒼馬を見たり",
                "author": "蒼馬を見たり",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も先方は君を恋しい恋しい兄さんと認めてくれたので、まず半分は成功した訳だが、御本尊の君自身が、あの美少女にズドンと肘鉄砲を喰わせた……自分の従妹とも許嫁とも、何とも認めなかったので、今度は手段をかえて、君をこの室に連れて来る様子だ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち絵巻物探索の唯一無上の手がかりとして、手を換え、品を変えて機嫌を取っていたＴ子から、抵抗不可能ともいうべき自分の急所に、思いもかけぬ肘鉄砲を一発ズドンと喰わされたのであった。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちでもズドン、こっちでもビシンと爆発して、生き残った魚群の神経に猛烈な印象をタタキ込むばかりでない。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をするか知らぬと思う間もなく、三日半も干乾にして庭樹の枝に縛り付けてあった囚人目がけてズドンと一発放つや否や、キャッという叫び声。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "町「それ撃たれなよ」　と云う間もあらばこそ、一発ズドンと打放しました。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、運の悪いときは仕方のないもので、その手のかゝつた枝が枯れてゐたとみえ、ポッキリと音がして、キクッタはずる／＼、ズドンと地に落ちました。",
              "citation": {
                "source": "熊捕り競争",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが車内でズドンという音を聞いたものがないではないか。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ帆村君、あのピストルが屋根裏でズドンと鳴った頃には、一平の奴上野署の豚箱のなかで、虱に噛まれていたらしいよ」「……」帆村は黙りこくっていた。",
              "citation": {
                "source": "ネオン横丁殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "素六ちゃーん」　鬼川は、断髪女が、仆れた少年を抱いて、大声で呼び戻しているのを見ると、又もや、ズドンと、第二発目を、紅子に向けた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
