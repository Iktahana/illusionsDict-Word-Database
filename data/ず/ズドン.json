    "definitions": [
      {
        "index": 1,
        "gloss": "with a bang (of a gun)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
