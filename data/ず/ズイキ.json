[
  {
    "uuid": "ea54125d-537b-5b4d-bc40-c6f98d06632b",
    "entry": "芋茎",
    "reading": {
      "primary": "ずいき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
