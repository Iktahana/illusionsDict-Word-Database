        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "富士登山家として、富士に関する図画典籍の大蒐集家として、君は疑いもなく第一人者であった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その出品は重に習字、図画、女子は仕立物等で、生徒の父兄姉妹は朝からぞろぞろと押かける。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "図画室は既に生徒及び生徒の父兄姉妹で充満になっている。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はまず家へ帰ったらおっ母さんの前へ行って百けたぐらいの六かしい勘定を一ぺんにやって見せるんだ、それからきっと図画だってうまくできるにちがいない。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちキッコは算術も作文もいちばん図画もうまいので先生は何べんもキッコさんはほんとうにこのごろ勉強のために出来るようになったと云ったのでした。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "図画の先生に頼んで東京の飯田とかいううちから道具や絵の具を取り寄せてもらって、先生から借りたお手本を一生懸命に模写した。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひるすぎは先生もたびたび教壇で汗をふき、四年生の習字も五年生六年生の図画もまるでむし暑くて、書きながらうとうとするのでした。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かな田舎で地味な教師をして、トルストイやドストエフスキーやロマン・ローランを読んだりセザンヌや親鸞の研究をしたり、生徒に化学などを授けると同時に図画を教えたり、時には知人の肖像をかいてやったりするような生活は、おそらく亮が昔から望んでいた理想によほど近いものではなかったかと思う。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校の図画のお手本はつまらないし、先生の絵は下手くそだし、自分は、全く出鱈目にさまざまの表現法を自分で工夫して試みなければならないのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、学校の図画の時間にも、自分はあの「お化け式手法」は秘めて、いままでどおりの美しいものを美しく画く式の凡庸なタッチで画いていました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、そこの壁に図画が五六枚はつてあつた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "久助君も図画はとくいであつたが、この画のやうに色を大胆に豊かにぬることはできなかつた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "文はもとより、又詩をも善くし、図画、奕棋、営造、音律、何にも彼にも通暁して、茶も此人から蔡嚢へかけて進歩したのであり、蹴鞠にまで通じていたか、其詩が温公詩話と詩話総亀とに見えている。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "女学校の図画の先生であった。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "図画を除いては、すべて九十点以上であった。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "図画は、六十点、ときたま七十三点なぞということもあった。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女学校の図画の先生であつた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "図画を除いては、すべて九十点以上であつた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "図画は、六十点、ときたま七十三点なぞといふこともあつた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後の図画の時間には、皆、校庭に出て、写生のお稽古。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵というと面倒だから図画で行くのさ。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども趣味性に係る学科、習字とか手芸とか図画とかはまるでゼロです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども趣味性に係る学課、習字とか手芸とか図画とかの才能はまるでゼロでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、帰郷のたびごとに、再度生老人を懐しく思い出すのであるが、その菅公の像というのは、今になって見ると、中学生の図画と選ぶところがないほど、ひどく下手なものである。",
              "citation": {
                "source": "再度生老人",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空しく図画と解説の不十分なもののみが残存せり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか彼の背後にひとりの鼻眼鏡の立派な体格の紳士が立つて、青年の膝の上に展かれてゐる「奉天の会戦」や「旅順の夜襲」や「日本海大海戦」の花々しい図画を認めて、「実にも愛国の熱情の充ち溢れた素晴しい図画だね。",
              "citation": {
                "source": "私の万年筆",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「故国の長男の作成に依つた図画であります。",
              "citation": {
                "source": "私の万年筆",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それらの傑れた図画を私は、君から贈らるゝ、悦びが能ふであらうかしら？",
              "citation": {
                "source": "私の万年筆",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはもう、疲れしぼみ、悔とさびしい微笑としか持つてはをらぬけれど、それは此の世の親しみのかずかずが、縺れ合ひ、香となつて籠る壺なんだ。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人がその空想の中で画くような、ファンタスチックな夢の国は、現実の地球上にあるはずがない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
