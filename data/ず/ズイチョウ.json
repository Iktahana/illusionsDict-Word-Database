    "definitions": [
      {
        "index": 1,
        "gloss": "auspicious sign",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "将来の喜多流万々歳の瑞兆に外ならぬのである。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "御城の瑞兆、天人のごとき鶴を御覧あって、殿様、鷹を合せたまえば、鷹はそれて破蓑を投落す、……言語道断。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対に、お誓さんが故郷へ帰った、その瑞兆が顕われたとして、しかも家の骨に地蔵尊を祭る奇特がある。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人々はこれこそこの場所が世界の主都となる瑞兆であるということを信じて疑わなかったとある。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしエリスの『古英国稗史賦品彙』二版一巻六二頁に、古ブリトン王アーサーの父アサー陣中で竜ごとき尾ある彗星を見、術士より自分が王たるべき瑞兆と聞き、二の金竜を造らせ、一をウィンチェスターの伽藍に納め、今一を毎に軍中に携えた。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "惟うに麒麟や鳳凰、それから獅子を五采｜燦爛たるように和漢とも絵くは、最初外国から似寄った動物を染め飾り持ち来ったのに欺かれ、瑞兆として高く買ったでなかろうか。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "善男は瑞兆の夢だと考へて居たのに、妻の言ひ草を聞いて縁起でも無いと思つて夢解きの名人に占なつて貰ふと、その名人は「非常に吉い夢であるが、惜しいかなよく無い人に喋べつてしまつたので、上運に傷が附いた」と云ひました。",
              "citation": {
                "source": "夢の影響",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなに蛇をこはがつてばかりゐた僕の、丁度寢てゐる眞上でもつて、その蛇が夜なかに脱皮をしてゐる物音を聞きとがめながら、それとは知らずに平氣で寢てゐたなんて、どうも知らぬが佛とはいへ、僕にとつて何かの瑞兆であればよい。",
              "citation": {
                "source": "山日記　その一",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "北辺の領国福井にも、軈て栄光の瑞兆がきざし染めて来た。",
              "citation": {
                "source": "橘曙覧",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一首の意は、年のはじめに當りまして、かやうに大雪の降りましたことは、豐年の瑞兆でございませう。",
              "citation": {
                "source": "愛國百人一首評釋",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年に降った雪に瑞兆を託しつつ、部下と共に前途を祝福した、寧ろ形式的な歌であるが、「の」を以て続けた、伸々とした調べはこの歌にふさわしい形態をなした。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れて来る子のために祝ってやれば、たったこれだけのことでも、瑞兆といっても好い。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞兆といってよかろう。",
              "citation": {
                "source": "食指談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、明るい青空からお札がちらちら降って来たのを目撃したと言うものがあり、何かこれは伊勢太神宮のお告げだと言うものがあり、豊年の瑞兆だと言って見るものもある。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「世の中が大きく変わる時には、このくらいの瑞兆があってもいいなんて、そんなことをさももっともらしく言い触らすものもありますぜ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は初木氷の名も知らず、亦これが詩人の喜んで瑞兆となすものであることも知らなかったが、近年に至ってたまたま大窪詩仏の集を読むに及んで始て其等の次第を審にしたのである。",
              "citation": {
                "source": "申訳",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのやうな篤志家が現はれたのは、椎茸産業界にとつて、感謝すべき瑞兆です。",
              "citation": {
                "source": "椎茸と雄弁",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や天下にありては、相将その相将に非ず民心動揺して天朝の恢復と胡虜｜剿滅の天の瑞兆あるを見る。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした江戸前のスッキリした眺めも、いよいよ自分も一人前の芸人の仲間入りができるかの瑞兆のような、いいしれぬ喜ばしさを圓朝の胸に滲ませないではおかなかった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと我にかえった師長は、「平家のために流罪にならずばこの瑞兆もみることができなかった」　と感激の涙をもらすのであった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "国家的瑞兆という三段抜きの大｜標題で手の込んだ記事を書上げ、名士、博士を総動員して感想を執筆させた。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "折よくそこへ赤襷をかけた背広の男がチラシを配りながらやって来るからその一枚を受取って読んでみると、その表紙には牛の糞ほどの大きな木彫活字で、　　今朝九時十二分鶴の噴水唄わん　　来りて瑞兆を見よ　　　来れ日比谷公園へ！",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初にこれを発見したのは酒月という日比谷公園の園丁長だったが、夕陽新聞は他社に先んじて逸早くこの事実を報じ、これは国民ひとしくお待ち受け申上げる国家的瑞兆に相違ないと竹の園生の御繁栄を慶賀し、有名人士の祝辞を掲げる一方、学士博士を総動員してこの不思議なる現象に対する感想を述べさせた。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日のこの行進は愈々以て高潮した市民の好奇心をもう一ト煽り煽り立て、急速に膨張した夕陽新聞の地盤を確固不動なものにしようという、社長兼編集長、幸田節三の秘策中の秘策で、その名も芽出たい「鶴の子石鹸」とタイアップし、「瑞兆祝賀会」の名に仮りて古今未曽有の大芝居を打つことになったのである。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "式の順序を言えば、まず幸田節三の挨拶、東京市役所水道課長の感想、この瑞兆の最初の発見者たる酒月園丁長に対する賞品の授与式、名士の祝辞、この不可思議なる現象に対する兼清博士の大講演などがあって聖寿万歳を三唱して解散する段取り。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "来会者にはこの瑞兆に肖るように洩れなく「鶴の子石鹸」を贈呈するほか、夕陽新聞の半額購読券を配布する。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて八時真近かになると、幸田節三は万雷のような喝采を浴びながら演壇に登って行き、今日の瑞兆祝賀会について所感を述べることになったが、その所感なるものは、すでにしば／＼夕陽新聞に掲載されたものと同巧異曲だから、ここにそれを叙述する必要はあるまい。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに何ぞや国家的瑞兆だと！",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "時はあたかも一月元日、理屈は兎も角、青銅の鶴が還宮楽を咏ずるなんてえのは確かに何かの瑞兆に違いない。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が、従来「白人」のヨーロッパによって支配されて来たアジアにとって、ヨーロッパ大戦以来、「復興の瑞兆」が現われ始めた、今後は愈々アジアが支配する世界が来るのだ、というのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
