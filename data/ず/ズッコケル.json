    "definitions": [
      {
        "index": 1,
        "gloss": "to fall down (e.g. off a chair)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "椅子を後ろに傾けて遊んでいたら、バランスを崩して派手にずっこけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "濡れた床で足を滑らせてずっこけてしまい、周りの視線が恥ずかしくてたまらなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "段差があることに気づかず、派手にずっこけて膝を擦りむいてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしそれにしても、正直ずっこける。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネクタイの結び方を忘れて、すぐにずっこける。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
