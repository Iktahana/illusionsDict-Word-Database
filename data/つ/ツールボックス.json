        "examples": {
          "standard": [
            {
              "text": "昔、父親が持っていた大きな木製のツールボックスが懐かしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいツールボックスには、ドライバーやペンチなど、必要な工具がすべて入っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ソフトウェア開発者にとって、デバッグツールはなくてはならないツールボックスの一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "マッキントッシュは、ウインドウやメニューを組み立てるソフトウエアの部品をあらかじめ用意し、ツールボックスと名付けてＲＯＭに収めていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツールボックス内の部品がじつに巧妙に作られていることや、サードパーティーが各々マッキントッシュ用のアプリケーションを書いたとしても、同じツールボックスの部品を使わせれば使い勝手をそろえられるというアップル側の戦略には感心させられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツールボックスを用意し、ソフトウエアベンダーにインターフェイスのガイドラインを示すことで、アップルはマッキントッシュ用のすべてのアプリケーションに統一感を生み出そうと試みた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
