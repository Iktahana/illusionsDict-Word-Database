        "examples": {
          "standard": [
            {
              "text": "「頑固な彼も、今回ばかりは周囲の説得に負けて角を折ったようだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「妥協案を提示して、ようやく双方が少しずつ角を折る形で合意に至った。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いつまでも意地を張っていないで、たまには自分から角を折ることも大切だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "最近に、享保十八年板『商人軍配団』四を見ると、向う猪に矢が立たぬとて、直ちに歎かば、鬼のような物も、心の角を折るものなりとありて、原意は、ともかく、当時専ら謬り入って来る者を、強いて苦しめる事はならぬという喩えに用いたと見える。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうすると、東山の鬼瓦も、今度こそ、閉口して角を折るにきまつてる。",
              "citation": {
                "source": "にらめつくらの鬼瓦",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
