    "definitions": [
      {
        "index": 1,
        "gloss": "meeting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "左脇の家に人｜数多集い、念仏の声洋々たるは何の弔いか。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く行て船室へ場を取りませねばと立上がれば婢僕親戚｜上り框に集いて荷物を車夫に渡す。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山村水廓の民、河より海より小舟｜泛かべて城下に用を便ずるが佐伯近在の習慣なれば番匠川の河岸にはいつも渡船集いて乗るもの下りるもの、浦人は歌い山人はののしり、いと賑々しけれど今日は淋びしく、河面には漣たち灰色の雲の影落ちたり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおぜいのひとたちは祖母のまわりに駈せ集い、一斉に鈴虫みたいな細い声を出して泣きはじめた。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽の人々、そと集い覗く。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まひるの草木と石土を　照らさんことを怠りし　赤きひかりは集い来てなすすべしらに漂えよ。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では第二服　まひるの草木と石土を　照らさんことを怠りし　黄なるひかりは集い来てなすすべしらに漂えよ」　空気へうすい蜜のような色がちらちら波になりました。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの兵隊達は皆見送人と、あちこちに集いながら団欒しているので、自分がその見張りの役を買っているのだと、彼は淋しい顔もせずに言った。",
              "citation": {
                "source": "面会",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "他生の縁あってここに集い、折も折、写真にうつされ、背負って生れた宿命にあやつられながら、しかも、おのれの運命開拓の手段を、あれこれと考えて歩いている。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人のもの、毎夜ここに集い、句会をひらいているというのである。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそびなかまの暮ごとに集いしは、筋むかいなる県社｜乙剣の宮の境内なる御影石の鳥居のなかなり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらぬも近隣の少年は、わが袖長き衣を着て、好き帯したるを疎じて、宵々には組を造りて町中を横行しつつ、我が門に集いては、軒に懸けたる提灯に礫を投じて口々に罵りぬ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵は夜ごとにここに集い来る骨牌仲間も「ホテル」に宿りて、舟に残れるは余一人のみなれば。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "カラザースさんは、大へん親切で、音楽もよく解り、夕の集いはとても愉快でした。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "カラザズさんはお優しく音楽もお好きで、夕べの集いはとても楽しいものでした。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "自転車の男も酒場の主人の言う館の週末の集いに参加していることは相違ないが、何者で目的は何なのかいまだはっきりしない。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "老若男女打ち集い歓喜限りなし。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて数日の間は此処の宴会｜彼処の招待に日も足らず、平生疎遠なりし親族さえ、妾を見んとてわれがちに集い寄るほどに、妾の評判は遠近に伝わりて、三歳の童子すらも、なお景山英の名を口にせざるはなかりしぞ憂き。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小杜の蔭に潜んで覗きいると、暫時して妍華超絶｜止に別嬪どころでなく、真に神品たる処女、多人数諸方より来り集い、全く露形して皎月下に身を洗う。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "特にこの方々呼び集めたのは、力も人の一倍、働らきも人一倍でおじゃるゆえ、わざわざえりすぐってお集いを願うたのじゃ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "重きものの中に罪深く集いて隠れしは後の世に起りし争闘の萌芽なりき。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は語る友もなく侘しい新年を迎えて、あなたがたの東京での集いを少しお羨ましく思っています。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲイツにはゲイツの道があったが、さまざまなクラブに集いはじめたホビイストたちにも、彼ら自身の道があった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう閉めている店もあったが、扉の隙間から長い灯影が洩れているのは、まだ彼らの集いがひけていないこと――おそらくそれらの召使たちは、彼らの居どころがわからなくて、自分らの主人たちがすっかり当惑しているのをよそに、まだいつもの無駄口や世間話にけりをつけようとしている最中だということを物語っていた。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には彼の目にも、何か面白そうな集いや談笑の仲間入りがしたくてたまらないという激しい欲望のほの見えることもあったが、これも、それではあまりにこちらから身を低うすることになりはせぬか、なれなれしすぎはすまいか、こんなことをしては自分の沽券にかかわりはせぬか、などといった杞憂に阻まれてしまう。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮方より同じ漁師仲間の誰彼寄り集いて、端午の祝酒に酔うて唄う者、踊る者、跂る者、根太も踏抜かんばかりなる騒ぎに紛れて、密と汀に抜出でたる若き男女あり。",
              "citation": {
                "source": "片男波",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして結綿や唐人髷などに結った娘達が、四五人｜雪洞の下に集い寄って、真赤な桜炭の上で手と手が寄り添い、玉かんざしや箱せこの垂れが星のように燦めいている――とでも云えば、その眩まんばかりの媚めかしさは、まことに夢の中の花でもあろうか。",
              "citation": {
                "source": "絶景万国博覧会",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの式場に臨む人は日本の学校のようにただに卒業生に限らず、また親戚に限らず、あるいは十年二十年、中には五十年以前に卒業したなどという人々も昔を偲ぶために出席し、地方の紳士淑女はいうまでもなく、遠方からもわざわざ集い来たる数ははなはだ少なくない。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし物語によくあります、峰の堂、山の祠で、怪しく凄い神たちが、神つどいにつどわせたという場所へ、破戒坊主が、はい蹲ったという体で、可恐し可恐し、地蔵様の前に踞んで、こう、伏拝む形をして、密と視たんで。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わが家の正月」「詩集と結婚と出産と」などには、実にあったかくて、清潔で、狎れ合ってしまわない人間同士の、親と子と、良人と妻とのつどい、生き、たたかううたがあります。",
              "citation": {
                "source": "鉛筆の詩人へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
