          "literary": [
            {
              "text": "火事は付け火を除くのほかは、すべて天火と称して、天より罪を受けたるものと定めている。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "全市の、各町ごとに、常備の駈付け火消しを、三十人ずつおいて、ジャンと鳴れば、競って、鳶口、まといを振り出して、消火に協力する。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを桑つみにいつた拍子にふいと私が見つけびつくりして飛んでかへり訳をきいたがみんなはなんのかのとはぐらかして相手にしようとしない。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
