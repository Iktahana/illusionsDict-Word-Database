[
  {
    "uuid": "6d2a406b-5315-5a12-9015-3d62c159ffd9",
    "entry": "継ぐ",
    "reading": {
      "primary": "つぐ",
      "alternatives": [
        "ツぐ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ガ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to succeed (a person, to a position, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もはやあなたとわたくしを継ぐとか切るとかいうせきは放れております」と女神は淡々としていった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の伜が大きくなれァ森の石松の二代目を継ぐに決まってらァ」　と言ったものの石松、ふと故郷の親父の事を思い出して居ます――　「そうだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "因縁果の理法によって出来たものとすれば、その因と縁を突き止め、その善きを加え継ぐことによって極楽はいよいよ続き、地獄はその性を失う。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは進んで深く語り継ぐであろう。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と口々に言い継ぐ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに極重悪の罪名を負せられ、夜を日に継ぐ厳しい訊問を続けられ、果ては死を以て罪を天下に謝さなければならないと云ふ、そんな大胆な覚悟は、彼が心中には未だ嘗て芽を吹かうともしたことはないのであつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだのはそこの当主で、あと総領の永助が家業を継ぐわけだが、未だ若かった。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダムは死際に、浜龍にはどうせ好い相手があって、家を出るだろうから、銀子は年も行かないから無理かも知らないけど、気心がよく解っているから、マダムの後釜になって、商売を受け継ぐようにと、そんな意味のことも洩らしていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その遺産を受け継ぐべき婆さんのたった一人の娘と、その婿になっている電工夫は、目下東京に居るが、急報によって帰郷の途中である。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "事件に引き付けられて息が継げないと云つても嘘ではないが、実を云ふと、寧ろ苦しくつて息を継ぐ余裕を著書から与へられないのである。",
              "citation": {
                "source": "『煤煙』の序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "復一の育ての親とはいいながら、宗十郎夫婦はこの家の夫婦養子で、乳呑児のまま復一を生み遺して病死した当家の両親に代って復一を育てながら家業を継ぐよう親類一同から指名された家来筋の若者男女だったのだから。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは確にこの場の打切りになった感興の糸目を継ぐために違いなかったが、かの女は無意識に叫び出して仕舞ったのである。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると私は早く日本の叔母の元へ帰り、また、物語を書き継ぐ忍従の生活に親しみ度い心のコースが自然私に向いて来た。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明応年中、近衛尚通の子政信、家を継ぐ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊勢父子がドジを踏んでマゴマゴすれば蒲生は之を捨てて置く訳にはゆかぬ、伊勢父子の居る地方と蒲生の会津とは其間遥に距って居るけれども必ず見継ぐだろう。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お米が烈々と炭を継ぐ。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだのはそこの当主で、あと総領の敬吉が家業を継ぐわけだが、未だ若かった、先代は理髪養成学校の創立委員で、嘱託されて教師にもなり、だから死なれて見ると、二代目の敬吉の若さは随分目立つ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れの時代にも預言者あり、大預言者あり、小預言者あり、其宗教に、其思想に、彼等は代表者となり、嚮導者となるなり、彼等は己れの「時」を代表すると共に、己れの「時」を継ぐべき他の「時」を嚮導するなり。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は心を抑え、税を納めるような気持で原稿を書き継ぐ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中でも兄の方は、とりあえず家督を継ぐには継いだが、病弱で物にならぬ。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠からず滅亡の運命に瀕しつつある能楽喜多流の命脈を僅かに残る一人の老師から受け継ぐべく精進した。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、前に云った養子が幸いにして前代以上の芸を養い、第二代の家元を継ぐ事になると、層一層、自奮自励して流風を向上させ、倍一倍絶妙の境界に達する。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "良真の積りでは兄である自分が家を継ぐべきなのに、自分丈が氏輝、義元と母を異にして居る為に除者にされたのだと、とうとう義元と戦ったが敗れて花倉寺で自殺したという事があった。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな事が可能かどうか分らぬが、とにかく秀吉に忠信の冑を受け継ぐものは、忠勝の外にないと云われたり、関東の本多忠勝、関西の立花宗茂と比べられたりした典型的の武人である。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに彼を取巻く総ての雰囲気が、此の少年を、亡父の義挙を継ぐべき情熱へと駆り立てて行ったのであろう。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉幕府と元寇　平家の衰亡は、武家にして、藤原氏を学んで、大宮人としての弊害を承け継ぐと共に、土地を根拠とする武士自身の生活を忘れたためである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "家を継ぐべき養子として、当時十八歳の父が迎えられる事になったが、江戸詰めの藩公の許可を得るために往復二か月を要した。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし彼が、弥平氏の養子として前田鉄工場の支配権を継ぐなら、自分が全然否定しているところのその工場の待遇制度を、全人格的に肯定できる待遇制度へと変革することができるからであった。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "森谷家の遺産はわたしが継ぐべきものでもなく、正勝が継ぐべきものでもないのです。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まひる利根川のほとりを歩めば、二人歩めばしばなくつぐみ、つぐみの鳴くに感じたるわが友のしんじつは尚深けれども、いまもわが身の身うちよりもえいづる、永日の嘆きはいやさらにときがたし、まことに故郷の春はさびしく、ここらへて山際の雪消ゆるを見ず。",
              "citation": {
                "source": "利根川の岸邊より",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
