    "definitions": [
      {
        "index": 1,
        "gloss": "to pile up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "花のしんにはプリマ・ビスケットを積み上げる。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、コメット・ビスケットを積み上げる。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この節目は、天に宝を積み上げる営みの、出発点となしうる。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの浅ましい行為によってお前は本当の人間の生活を阻害し、生命のない生活の残り滓を、いやが上に人生の路上に塵芥として積み上げるのだ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　習性的生活はその所産を自己の上に積み上げる。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明けからそれを運んで湖岸の田圃に積み上げる。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手で稻扱機のペダルを踏んで、齒車を※轉させながら、右手で麥を取り、左手に握り代へては齒車に當てて扱き終つた麥殼を左側に積み上げる。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "米俵を積み上げることは何も彼等の完結を意味しはしない。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ山のなかの木のない廣場のやうなところに、落葉を運んで來て積み上げる。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "無機的な棘の痛みに一瞬凍り付いた指は、よきものを生み出すまでにマイクロコンピューターの上に積み上げるべき、おびただしい変化と成功の実りの厚みを知って震えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "手探りのチェックを繰り返しながら、古山は賽の河原で石を積み上げるような気分にとらわれていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラフィックス、音に加えて、アニメーションや動画、そしていつかは人の話す言葉までを取り扱い、五感に訴えるさまざまな情報を相互のマシン間でやり取りする環境を用意するためには、積み上げるべきソフトウエアの技術は山ほど数え上げることができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "監督の命令で崩れた土はすぐ停車場前の広場に積み上げる、夜を日についでも隧道工事を進めよというので、土方は朝からいつにない働き振りである。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "こづむとは、積み上げる事である。",
              "citation": {
                "source": "霊魂の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、頭の上に重たいものを積み上げるんだ。",
              "citation": {
                "source": "村で一番の栗の木（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして遂にもう間に合わない今となって、彼は彼を愛してくれる暖い、やさしい心の方が、天地の間に積み上げることの出来る、どれほどの宝よりも、どんなに貴いか知れないということを、しみじみと感じたのでした。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち前に述べた鉄橋、その他の土木建築では、まず土台を固めてすべての物をその上に積み上げるが、人間の知識もその流儀でゆかねばならぬと思い込んだゆえである。",
              "citation": {
                "source": "我らの哲学",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、ブリュネットがぺしゃっとなってしまわないように、そのまわりに藁を積み上げる。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために雪の面に溝を掘り、その掘り上げた雪を溝の片側に積み上げることにした。",
              "citation": {
                "source": "雪を消す話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただわたしに手まねをして、門の前にわらを積み上げるようにと言った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "御浪人の織部鐵之助樣も、上總屋の番頭の金五郎さんも、若吉親方も、こゝの息子の幾松さんも――」　お由良の父親は、娘の威力を勘定するやうに、慕ひ寄つた男の名前を一つ／＼積み上げるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お由良の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "御浪人の織部鉄之助様も、上総屋の番頭の金五郎さんも、若吉親方も、ここの息子の幾松さんも――」　お由良の父親は、娘の威力を勘定するように、慕い寄った男の名前を一つ一つ積み上げるのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お由良の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "金額としてはそう驚くほどではないにしても、銭に換えてこうして積み上げると、田舎の者の眼を驚かすに足るほどの夥しさでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "石燈籠をつくるために積み上げる石、小さな庭園の橋をつくる板石、詩文を刻む石、その他の目的に使用する石を日本人は熱心に求める。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを杉なりに積み上げると、ケチな石垣よりは餘つ程堅固な筈だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "屠蘇の杯",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの像は飛鳥の彫刻が、立体的なものを積み上げるような造型性を示したのに対し、立体を包む線条の美しさを示すところに、新しい造型美を示している。",
              "citation": {
                "source": "百済観音と夢殿観音と中宮寺弥勒",
                "author": "野間清六",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京では、コップの底に、タネモノ（シロップなり小豆なり）を入れて、その上へ、氷をかいて積み上げる。",
              "citation": {
                "source": "氷屋ぞめき",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち大きい者が彼等を抱えて、ごろりと横に寝かすのをニヨーチンダというのだそうだが、これならばなるほど稲村に稲束を積み上げるのとちとばかり似てもいる。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "居間につみあげ、残りを座敷と土間の客席の隅へもつみあげる。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こういう工合というとき、伸子は、労働者、インテリゲンツィア、資本家という順に上へ上へとつみあげる手つきをした。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
