    "definitions": [
      {
        "index": 1,
        "gloss": "false eyelashes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『今日私、面白い所見つけました。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど『美しいシャボン玉』を壊さないように、注意に注意して気をつけましたと、未亡人となった夫人が後で言っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤シャツの農夫はだまって針をにらみつけました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子さん、いやに見せつけますね。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから政夫さん、こういう訣です……夜が明けてから、枕を直させます時、あれの母が見つけました、民子は左の手に紅絹の切れに包んだ小さな物を握ってその手を胸へ乗せているのです。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白い電灯　近頃室内に取りつけまたは卓上に置く電灯に面白い自働装置を附したものが工夫された。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そのうちにその見知らぬ男は、ステッキの丸く曲つた握りを彼の襟のうしろに引つかけ、そして歩き續けたまま、それを自分の背骨の眞上に、垂直に、押しつけました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自分の顏を何度もリュクサンブウル公園の柵に押しつけました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だれがそんな癖をつけました、わたしに。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして算術帳国語帳理科帳とみんな書きつけました。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからは気をつけます。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　Ｏは私の机の上においてあった紙に眼をつけました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "向後気をつけます、御免なさいまし」と叩頭したが、それから「片鐙の金八」という渾名を付けられたということである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "都合で夕食後にバウムに灯をつけました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一刻も早く修理したくて、まだ空襲警報が解除されていないのに、油紙を切って、こわれた跡に張りつけましたが、汚い裏側のほうを外に向け、きれいなほうを内に向けて張ったので、妻は顔をしかめて、あたしがあとで致しますのに、あべこべですよ、それは、と言いました。",
              "citation": {
                "source": "春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」やまねこは巻たばこを投げすてて、大いそぎで馬車別当にいいつけました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」雪童子はわらいながら、手にもっていたやどりぎの枝を、ぷいっとこどもになげつけました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とどなりつけましたので、柏の木はみんな度ぎもをぬかれてしいんとなってしまいました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わたしがあとをつけます。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが平二は人のいゝ虔十などにばかにされたと思ったので急に怒り出して肩を張ったと思ふといきなり虔十の頬をなぐりつけました。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どしりどしりとなぐりつけました。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでその子供の助手が、アセチレン燈を四つ運び出して、鏡の前にならべ、水を入れて火をつけました。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土神はいきなり狐を地べたに投げつけてぐちゃぐちゃ四五へん踏みつけました。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏は怒ってまっくろのまま染物小屋をとび出して、仲間の鳥のところをかけまはり、とんびのひどいことを云ひつけました。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かしはは、何べんも古い葉を落して、新らしい葉をつけました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六発の弾丸が六｜疋の雁を傷つけまして、一ばんしまいの小さな一疋だけが、傷つかずに残っていたのでございます。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言いながら鉛筆をふところの中へ入れて、あとはシナ人がおじぎするときのように両手を袖へ入れて、机へぴったり胸をくっつけました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
