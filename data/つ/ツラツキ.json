        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "むろん米の酢じゃけに飲むとどことなくポーッと酔うたような気持になるのでなあ……まことに面目ない、浅ましい話じゃったが、奈良原が、あの面付きでシカメて酢を飲みよるところはナカナカ奇観じゃったよ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴等は、戦争に負けた時が、死んだ時という覚悟を女子供の端くれまでもチャンと持っているので、生きたまま捕虜にされると何とのう不愉快な、理窟のわからんような面付きをしておった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あからさまに言えば、こいつはにたにた笑ってはいるが、ずうずうしい陰険な面付きをしていた。",
              "citation": {
                "source": "鐘塔の悪魔",
                "author": "THE DIVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その職人は竹と云って、年も若し、面付きこそ人並だが、酒はのむ、博奕は打つ、どうにもこうにもしようのねえ野郎だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとて彼の面付き、眼の配り、世のつねの乱心狂気ともおぼえませねば、何か子細ありげな奴、あらためて吟味いたすまでは館の内に繋ぎ置こうと存じまする。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも面付きが気に食わねえと思った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "春の雪解",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは、大体そのノツペラボーな、面付きが昔から気にくわんのだ。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "門の側には遍路車が据ゑてあつて、中には面付きの悪い十二にはなるまいと思ふ子が、足が立たぬ様な態度をして栄一の這入つて行くのを見守つて居る。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お留守のところへあがり込んで、どうも済みませんが、娘がいろいろお世話になって」と、丁寧にさげたあたまを再びあげるところを見ると、心持ちかは知らないが、何だか毒々しいつらつきである。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鳥居のやうに両足ふんばつて　山をにらんで拝むつらつきというのです、ちょっとおもしろいと思いました。",
              "citation": {
                "source": "木曾御岳の話",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木下杢太郎、長田秀雄、吉井勇、斎藤茂吉、谷崎潤一郎、茅野蕭々、萱野二十一の諸氏とならんで、つらつき一人前になって私の詩がヒナドリのように羽根をぴくぴく動かしていた。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "面は本物のうはばみのつらつきはしてゐるものの白面で女らしく優しく、口のところでは未だ十三四くらゐに見える娘の唇が、ぬれて見えた。",
              "citation": {
                "source": "末野女",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでフィリッピンから来た男のつらつきであった。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日後から私は烈しい咳はしていたが、なおった患者のつらつきで病院の廊下を歩いた。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
