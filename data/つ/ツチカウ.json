    "definitions": [
      {
        "index": 1,
        "gloss": "to cultivate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "胸に思い溜めた情熱を美しく培うことに力一ぱいらしくあった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むす子は若いいのちの遣瀬ない愛着を新興芸術に持ち、新興芸術を通して、それを培う巴里の土地に親しんだむす子は、東洋の芸術家の挺身隊を一人で引受けたような決心の意気に燃えて、この芸術都市の芸術社会に深く喰い入っていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた私達のセンチメンタリストは、廃墟に自然が培う可憐な野草に、涙含ましい思いを寄せることがある。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人妻であると云う道徳的な柵が取払れて、その古木が却って、彼の慾情を培う、薪木として投ぜられたようである。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、一度首都の地を踏むと、それ等の勢力の純真さ、熱烈さは、いつとなく方便化され、御都合化されて、結局、ブル生活の根底を培う腐土と化し去ったのである。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "利行とは、善巧な方便をめぐらして、他人の生命を培う行為です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことに自信を培うしかない時が来ているのだと思うがどうだろう。",
              "citation": {
                "source": "若い娘の倫理",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の美の感情を培うたものには政子姉と、従姉の藤子とが私より四つ、五つ年上で、美しい娘として三味線や、琴や、手芸などを競って習い、揃いの着物を着たりして、絶えず美と芸との雰囲気を発散させていたことだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の創造性を培う自由な学びの場を日本の農村に作り、娘も息子もそこに入れる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自らの手を以て、自らの生命を培うがいいのだ。",
              "citation": {
                "source": "旅人の言",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は私の個性の自由と尊貴を護りかつ培うために貴方の許を離れます。",
              "citation": {
                "source": "柳原※子（白蓮）",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "一粒の麦か米かを培うつもりなのであろうか、それとも、ただ遊んでいるのであろうか。",
              "citation": {
                "source": "夢の図",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平一郎にとってこのすぐれた女二人――母と冬子との愛が彼を培うに役立ったことは言うまでもない。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "君子の記憶に間違いがなければ、父は仏様から罰を与えられるような原因があったのであろうか、そういえば父が近郷近在に聞こえるほど善根を培うことに、なにか原因がありはしなかったか。",
              "citation": {
                "source": "抱茗荷の説",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "魂の内なる善の芽を培うて、「空の鳥来たつてその影に棲む」やうな豊かな大樹となしたいのである。",
              "citation": {
                "source": "善くならうとする祈り",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "魂の内なる善の芽を培うて、「空の鳥来たってその影に棲む」ような豊かな大樹となしたいのである。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い地方に必要な薪炭ややせた土を培うための芝草を得たいにも、近傍付近は皆官有地であるような場所もある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "この慈悲的の心、すなわちその思い遣りの心を私は何んで養い得たか、私はわが愛する草木でこれを培うた。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家にして、同時に熱烈な詩人であったミレーの永久に民衆の良心に培う叫びが聞かれる所以なのです。",
              "citation": {
                "source": "民衆芸術の精神",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "この慈悲的の心、すなわちその思いやりの心を私はなんで養い得たか、私はわが愛する草木でこれを培うた。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその観念は、ピーター・パン的な精神を、幼い頃から培うことによって生れてくるのではないかと思われる。",
              "citation": {
                "source": "ピーター・パン",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "果実のためには、できるならば、根を培う肥料をえらばなくてはならぬ。",
              "citation": {
                "source": "樹の根",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに多く知識を取り入れても、それが心の問題とぴったり合っているのでなくては、自己を培うことにはなりません。",
              "citation": {
                "source": "すべての芽を培え",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "490自分だけの世界を造って、それを負うて、培うた胸、己達霊どもと同じ高さの位置に立とうと、歓喜の震を以て張った胸はどこにある。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台に立つ人間にしては、大した化粧もせず、殆んど地のままの青春の血を培う頬の色を見ただけでも、その豊艶な生命の匂いに、グイグイ引き付けられるような気がします。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第八夜　蛇使いの娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史性必ずしも常に階級性とは限らないが、現代では、歴史性はやがて階級性となるべきであり、歴史性を言うことは階級性の萌芽を培うことであり、階級性への出発をすることなのである。",
              "citation": {
                "source": "イデオロギーの論理学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてすこしの遮るものもない島はそのうえに鬱蒼と生い繁った大木、それらの根に培うべく湖のなかに蟠ったこの島さえがよくも根こぎにされないと思うほど無惨に風にもまれる。",
              "citation": {
                "source": "島守",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "実を言えば、わたしは主義として個人的慈善には同感できない、なぜならば、慈善は悪を根本的に絶滅しないばかりでなく、かえってそれを培うようなものだからです。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自分の上に降りかかってくるように感じられる運命に対しては、それがいかに苦しいことであっても、勇ましく堪え忍び、それによって自己を培う。",
              "citation": {
                "source": "「ゼエレン・キェルケゴオル」序",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし差当りは閣下の信任を培うことに努めた。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
