[
  {
    "uuid": "57bed873-55d5-5c3c-a8c5-8626d38e8551",
    "entry": "付け加える",
    "reading": {
      "primary": "つけくわえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
