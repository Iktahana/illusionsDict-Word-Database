    "definitions": [
      {
        "index": 1,
        "gloss": "these past months",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大正十四年八月頃、いよいよ詩を専心しようと大体決まる。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月頃小林に見せる。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは何月頃であろうか。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体に、谷は、四月の末か、五月頃の柔々しい呼吸で充ちていて、大きな声を出すのすら、いたいたしいようだ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜など、燭を秉って、湯殿へ通うと、空には露が一杯で、十一月頃の冷たさが、ひしひしと肌に迫る、そうして凸凹のないところは、ないくらいな山の中にも、梓川が、静かな平坦な大道路となって、森の中を幅びろくのしている。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬は言うまでもないとして、三月四月頃、試みに郊外に出て見給え、遠くに碧い山か、斑らな雪の縞を入れて、菜の花の末、または青葉若葉の上に、浮ぶように横たわっている。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に一月元旦に降ったからとて、必ずしも初雪とはいわず、前年の九月や十月頃に降った方のを、かえって初雪と称する。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし年の初め、例えば四、五月頃に七、八月の気候を予察して年の豊凶を卜し、そうしてあらかじめこれに備えることには十分な可能性がある。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月頃から、一度子供連れで熱海へでも行ってみようと云っていたが、日曜というと天気が悪かったり、天気がいいと思うときっと何かしら差障りがあって、とうとう四月二十日の今日の日曜までこのささやかな欲望を果たす機会がなかった。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十　四、五月頃に新宿駅前から帝都座前までの片側の歩道にヨーヨーを売る老若男女の臨時商人が約二十人居た。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは丁度、或る年の九月頃であつたが、僕が折あしく外出してゐるところへ、飄然と牧水氏が訪ねて來て、玄關へ取次ぎを乞はれたのである。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一文を書いたのは、本年五月頃のことであつた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月頃の薄暗い天気の日に、十一時頃になっても光線が足りない時なんぞは、どんなにか気を揉んだものだ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの盛にかいていらっしゃった十一月頃と同じような御様子に見えますの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "外は色の白けた、なんということもない三月頃の野原である。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹は翌年の三月頃の初産を兩親のゐる私の家で濟ますために暫く上京するのであつた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村役場から配布される自治案内に、七分搗米に麦をまぜて食えば栄養摂取が十分になって自から健康増進せしむることができると書かれてあって、微苦笑を催させずに措かなかったのはこの二月頃だったが、産業組合購買部から配給される米には一斗に二升の平麦が添加されることになった。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この四、五月頃から父親が毎日絵を描いていたのが子供等に影響して、みんなが熱心な自由画家になってしまった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか二月頃にお貸し申したやうに覺えてゐます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、明治三十七年、十月頃の「明星」に出た。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "静岡の何でも町端れが、その人の父が其処の屋敷に住んだところ、半年ばかりというものは不思議な出来事が続け様で、発端は五月頃、庭へ五六輪、菖蒲が咲ていたそうでその花を一朝奇麗にもぎって、戸棚の夜着の中に入れてあった。",
              "citation": {
                "source": "一寸怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが嵩じて、あくる年の三月頃になると、かれは燈火をも嫌うようになった。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは去年の九月頃のことで、お父さんの方からこれを受取ったという返事が来たのはその年の暮だったが、年があけると早々に、その娘は流行性感冒にかかって、一週間ばかりで可哀そうに死んでしまった。",
              "citation": {
                "source": "河鹿",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大雪の夜から、ひとつきほど経って、たしかあれは明治三十九年のお正月頃の事だったように思う。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御記憶がうすくなって居られると考えますが、二月頃、新宿のモナミで同人雑誌『青い鞭』のことでおめにかかり、そしてその時のわかれ方が非常に本意なく思われて、いつもすまなく感じていて、自分ひとりでわるびれた気持になっています。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『春服』創刊から二号にかけて、ぼくは昨年暮から今年の三月頃まで就職に狂奔しました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月頃送った百枚位の小説はどうなっておるか。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の塵も冬空です……澄透った空に晃々と太陽が照って、五月頃の潮が押寄せるかと思う人通りの激しい中を、薄い霧一筋、岸から離れて、さながら、東海道で富士を視めるように、あの、城が見えたっけ。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏神の祭禮は、四五月頃と、九十月頃と、春秋二度づゝあり、小兒は大喜びなり。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
