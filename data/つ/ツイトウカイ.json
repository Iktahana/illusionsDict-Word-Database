        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "街上　富永の追悼会。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "親しかった人々は追悼会や遺作展覧会を開いてくれ、またいろいろの余儀ない故障のために親戚のものだれ一人片付けに行く事のできなかった遺物の処理までも遺憾なく果たしてくれた。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、山田三造は追悼会に参列したところで、もうとうに歿くなったと云うことを聞いていた旧友にひょっくり逢った。",
              "citation": {
                "source": "雨夜続志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何なる意見が交換されたかは今なお不明であって、先年追悼会の席上後藤男自らの口からもその談話の内容を発表する事は出来ぬといわれたが、左に右くこの会見に由て男爵の知遇を得、多年の夙志が男爵の後援で遂げられそうな緒を得たのは明らかであった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "近く同君のためにも友人仲間で追悼会を催したいと思っている。",
              "citation": {
                "source": "黒岩涙香のこと",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかに桜田浪士の追悼会を催すわけでもあるまい。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴婦人と音曲５・22（夕）　大阪美術｜倶楽部で催された故｜清元順三の追悼会に、家元｜延寿太夫が順三との幼馴染を懐ひ出して、病後の窶れにも拘らず、遙々下阪して来たのは美しい情誼であつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "上田敏博士の追悼会が先日知恩院の本堂で営まれた時、九十余りの骸骨のやうな山下管長が緋の袈裟を被つて、叮嚀にお念仏を唱へた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、左に録する俳諧連歌は十八句より成り、召波十三回の追悼会に催せし者と知らる。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "河合の追悼会があったものですから、今帰ったばかりなのです。",
              "citation": {
                "source": "将軍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まあ、こんな点ですね、たとえば今日｜追悼会のあった、河合と云う男などは、やはり自殺しているのです。",
              "citation": {
                "source": "将軍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "護謨林を出て馬車に乗り、案内者となつて呉れた三井物産の支店員から、故長谷川二葉亭君の遺骸を此地で荼毘して追悼会を開いた時の話を聞き乍ら、前年｜護謨林に従事して居た長田秋濤氏夫妻が住んで居たと云ふ林間の瀟洒たる一｜屋を過り、高地にある三井物産支店長の社宅の楼上で日本食の饗応を受けた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すらっとしたものなの……志貴子の追悼会をやったあとで、久能徳が本門寺の書院で、いろいろとお助けいただいたご恩にたいしても、生涯、志貴子は東京へ出しません。",
              "citation": {
                "source": "猪鹿蝶",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "有楽座にて細川風谷追悼会開かる。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本橋鴻巣亭にて上田博士追悼会あり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月二十九日（日）　千葉豊治氏の追悼会をやる。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学当局者達の遺憾の念いは一通りでなかったと見え、夫人の追悼会場に於て博士エドワード・ビー・クラップの演説に、我がカリフォルニヤの到る所に、此のカムパニールの姿を眼に刻みつけ、その美しい鐘の音に胸を高鳴らせた人々が、やがて多く現われることであろう。",
              "citation": {
                "source": "バークレーより",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先夜、浜本浩の建碑の帰りに「はせ川」で追悼会をやった時、吉川夫婦が駈けつけて列したが、床の間に、一本の銚子を飾って吉川さんはいった。",
              "citation": {
                "source": "吉川さんの声と眼",
                "author": "平野零児",
                "note": "青空文庫"
              }
            },
            {
              "text": "すらっとしたものよ……志貴子の追悼会をやったあと、久能徳が本門寺の書院で、いろいろとお助けいただいたご恩にたいしても、生涯、志貴子は東京へ出しません。",
              "citation": {
                "source": "姦（かしまし）",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡くなられた六条松子夫人の命日に、夫人を崇拝している人達が集って、追悼会を開いたんです。",
              "citation": {
                "source": "消えた霊媒女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから間もなく追悼会を芝の青松寺で催し、二十人足らずの人が集まったが、その中に芦田均君がいたので聞くと、兄さんの方の友達だそうであった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "和辻君に初めてあったのは、黒坂達三の追悼会の席上であったかと思いこんでいたところ、最近学士院で和辻君に聞いてみて、その前に一度会っていたことが判った。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰の時だったか、築地の本願寺で盛大な追悼会があってね、私も行った。",
              "citation": {
                "source": "私は隠居ではない",
                "author": "吉田茂",
                "note": "青空文庫"
              }
            },
            {
              "text": "永い間人気なく、しめこまれていた埃と湿気のにおう広間の一隅で、その日の午後から開かれる解放運動犠牲者追悼会のために、演壇に下げる下げビラを書いている人たちが四五人働いているかぎりだった。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "泉石に魂入りし時雨かな天地の間にほろと時雨かな十一月二十二日　長泰寺に於ける花蓑追悼会に句を寄す。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "抱琴が死んで初七日に、私たち若い仲間が築地本願寺で追悼会を開いた。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時すぎに済むと、もう帰ってねたい位なのだが、今晩十時から林葉三追悼会の発起人になってゐるので、それ迄の間を持たねばならず、日劇へ行って、「エノケンの千万長者」を見て感心し、ローマイヤで食事、浅草へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "山野と十時みや古へ行き、林葉三の追悼会。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "出版記念会、受賞祝いの会、追悼会。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどの火野葦平氏のもまた同氏の設計になるらしいが、その追悼会の夜、谷口さんが「佐々木道誉のデザインはおもしろいですな」と私へいわれた。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
