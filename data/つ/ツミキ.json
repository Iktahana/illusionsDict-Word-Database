        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ちょうど子供がおもちゃの積み木で伽藍の雛形をこしらえようとしているのとよく似た仕事である。",
              "citation": {
                "source": "浮世絵の曲線",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし古来の名匠は天然の岩塊や樹梢からも建築の様式に関する暗示を受け取ったとすれば、子供の積み木細工もだれかに何かの参考になる場合がないとは限らない。",
              "citation": {
                "source": "浮世絵の曲線",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒こげの材木が、積み木をひっくり返したように重なりあって、そこからけむりがくさいにおいといっしょにやって来た。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの坊やに積み木を一箱買って帰る、と。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそこから子ども用の積み木が転げ落ちる。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "郡奉行の平兵衛は陣笠陣羽織姿で川縁へ出張して、人夫を指揮して堤防の処どころへ沙俵を積み木杭を打ち込ましていた。",
              "citation": {
                "source": "水面に浮んだ女",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "電子計算機をどう構成すればいいか、どんな回路が必要でどうプログラムを組めばいいか、渡部は積み木でももてあそんでいるように素直に理解できた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼い頃は病身で弱かったので、自分の部屋に起居する日が多く、ひとりで積み木遊びなどをしているうちに、幾何学の知識を自然に覚えこんでしまったということです。",
              "citation": {
                "source": "ヘルムホルツ",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "一段高い積み木の上に正座した年かさの子。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "木製舗道があたりに散乱し、保育園で子供の巨大積み木箱を床にぶちまけたみたいだ。",
              "citation": {
                "source": "見えざる力",
                "author": "THE INVISIBLE FORCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は一方ならぬ胸騒ぎが、つつみきれないようすで、顔は耳まであかくなってるのが、自分にはいじらしくしてたまらなかった。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　夫人はつつみきれぬよろこびをもってたずねた。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "つつみきれぬ喜びと驚きとがその顔にあふれています。",
              "citation": {
                "source": "少年探偵　呉田博士と与一",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくわけを話してくれ」「わけったって簡単ですよ」と満面につつみきれぬ得意の笑みを浮かべながら与一は語り出しました。",
              "citation": {
                "source": "少年探偵　呉田博士と与一",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも一大危険を冒したという得意さがつつみきれず、ていねいに繃帯を巻いた指を前のほうへ差し出している。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、しばらく母さんの云ふことをきいて、気分転換をしていらつしやい」　そこで、弘は、膨れた顔をゆるゆる元へ戻して、悦しさをつつみきれぬやうに、「そんならさうと早く云へばいいのに……。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、つつみきれない好奇心で、遠慮がちに、「――お葬式、どうだったい？",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらか頬にやつれが目立って、それがかえって若妻らしいおとなびた美しさを添えた小枝は、親たちの留守に入っているという自分たちの立場からひかえめなものごしを失うまいとしているけれども、パリへ来てはじめて夫婦ぎりのアパルトマン暮しの楽しさは、つつみきれないそぶりだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがとうございました、あんた、なんの不服があるもんですか、これまでして貰えればいくらか助かります、いろいろお骨折ありがとうございましたと、嬉しさがつつみきれず、にこにこして、何度もお礼を云った。",
              "citation": {
                "source": "糞尿譚",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "その睦じさはつつみきれない。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木下七郎兵衛が祖先は、平相国の孫｜維盛より出で、杉原伯耆守が十代の末孫、血すじも正しい者にござります」　親ごころは、つつんでもつつみきれない歓びをすぐ現わして、縷述するのであった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお」　藤吉郎の面には、つつみきれない歓びが耀いた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "村重は、生来の正直さが、こんな場合にもつつみきれず、官兵衛の眼でなでまわされているあいだに、ひどく羞恥して、顔をも赤めたいようにむずむずしていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "祝宴の席でも、蘭丸の面には、つつみきれない得意があふれていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、遽に、各※の面につつみきれない明るさがさして来たのは、取りも直さず、大きな心の変化でなければならない。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の勅使は、その御内詔をお伝えに参ったわけです」　そういって、じっと董卓の面を見ていると、つつみきれぬ喜びに、彼の老顔がぱっと紅くなった。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "つつみきれない歓びと野望の火が、眸の底に赫々とうごいた。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれを携えて葭萌関にある玄徳にまみえ、さすがに喜悦の色をつつみきれず、「ご一見を」と、見参に供えた。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "つつみきれず、ついに高氏の名も明かされた。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "何といっても、故郷に帰れる、良人にも会える、そうした女心は、つつみきれない。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            }
          ]
        }
