        "examples": {
          "standard": [
            {
              "text": "甘い言葉で投資話を持ちかけ、初心者を巧みに釣り込む詐欺の手口には十分注意しなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "作家は読者を物語の世界へ釣り込むために、冒頭の数ページに衝撃的な展開を用意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "野球の試合で、キャッチャーは絶妙なリードでバッターを自分たちのペースに釣り込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それから女を自分に蕩し込むにはまず囮の女を立てゝそれに競争心を起させ釣り込むこと、周囲にあらぬ噂を立てさせ嘘から出たまことの寸法で破れかぶれになった女を自分の手に入れる。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝋燭に静まりかへる牡丹かな　　　　　　許六どや／＼と牡丹つりこむ塀の内　　　　　士朗　の二句を比較せば前者の牡丹大にして後者の牡丹小なるを感ずべし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしに、金銀のぬひのあるすばらしい着物をきせ、世の中をすくつて下さる聖者さまだといひふらし、お堂をたてゝその中にまつりこむ……そしてびんにつめた水を、ありがたいお薬水だといつてうりだす……そして大まうけをする……さういふつもりらしいんです。",
              "citation": {
                "source": "スミトラ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
