    "definitions": [
      {
        "index": 1,
        "gloss": "two",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「コートリ、タマゴ、ハーカマ、ハオリ……」「アーメ、カサ、カーラカサ、アサヒ……マツ、ツル、シカノ……ツノ、ウシノツーノ。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に、昨一九三四年の『ナツーアウィッセンシャフテン』第三十一号に、その飼育法に関する記事が掲載されていたくらいである。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今月｜一ぱいで店を畳んで、はあ、ツール在の土となるまでの巣を見つけて買い取りましたよ。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂や写真部はもちろん、理髪店、ツーリスト・ビュロー、何でもある。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に昨一九三四年のナツーアウィッセンシャフテン第三十一号に、その飼育法に関する記事が掲載されていたくらいである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにもうお日さまは、空のまん中までおいでになって、林はツーンツーンと鳴り出しました。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにもうお日さまは空のまん中までおいでになって、林はツーンツーンと鳴り出しました。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道は小店を並べた横町を貫いてツールノンの大通りに出る。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家鴨料理ツール・ダルジャン　家鴨の番号数二万――八。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツール・ダルジャンの酒倉は世界の食通の一度は見学すべき博物館になっている。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スルト　トツゼン　マンナカノ　ホシガ、ダマツテ　ツート、下ノ　ハウヘ　スベツテ　イツテ　シマヒマシタ。",
              "citation": {
                "source": "ナガレボシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "家鴨料理のツール・ダルジャンでゆっくりした晩餐をとった後、新吉とリサとは直ぐ前のセーヌ河の河岸に沿って河下へ歩き出した。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大地はいつの間にか透けて、地中で白玉の数本の根枝に纒められて、地上のものを、また支へてゐる巨根がカツーン映画の影像のやうに明かに覗かれる。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういった、アマツール的な気持からは、ただ、太宰治のくるしみを、肉体的に感じてくるばかりで、傍観者として呆然としているばかりである。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「少しまだ寒いのね」「あ、あ、少しまだ寒い」　わたくしはツーピースの洋装の胸を、池上は朝服のジャンパーの胴をごし／＼撫でました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里から西南へ三時間程汽車に乗って行くとロアール河の都ツール市へ着きます、其処から汽車を乗り換えて二十分｜許りで此のモントリシヤへ到着します。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツール市からモントリシヤへかけて沢山の城や宮殿が建って居ります。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩甲骨の下の所に汗が湧き、それが一つの玉となつて背中をツーツと傳はつて行くのがはつきり判る。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩甲骨の下の所に汗が湧き、それが一つの玉となって背中をツーッと伝わって行くのがはっきり判る。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩甲骨の下の所に汗が湧き、それが一つの玉となつて背中をツーツと伝はつて行くのがはつきり判る。",
              "citation": {
                "source": "夾竹桃の家の女",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "春先ではあるがダンダラ縞のモノスゴイ藪蚊がツーンツーンと幾匹も飛んで来て、筆者の鼻の先を遊弋する。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちえ子の知恵無し落第坊主、一年二度ずつエンヤラヤ、学校出るのに……ツーツータアカアセ」　と悪い男の生徒がはやしても、家の中から笑っていました。",
              "citation": {
                "source": "白椿",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにハウス・ツー・レットとかいた紙が、剥がれている。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査は手を鼻へやってかぐまねをしてそして手をふって「ノー・グード」と言い、今度は食うまねをして「ツー・イート・グード」と言う。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、今ごろ本屋でスコットの「湖上の美人」やアーヴィングの「スケッチブック」やニーチェの「ツァラツーストラ」でも探すとしたらすぐに手に入るかどうか心もとないような気がする。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この Expanded Book によってコンピューターで読むという世界を開きはじめたボイジャーが新たに打ち出したのが、この電子本を作るためのオーサリングツールである。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
