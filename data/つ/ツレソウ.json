[
  {
    "uuid": "cb9226cb-d6d3-53dc-badd-4e11b0f00bce",
    "entry": "連れ添う",
    "reading": {
      "primary": "つれそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
