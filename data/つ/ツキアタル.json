[
  {
    "uuid": "592082d1-c7d0-5141-ab33-7afe897f1155",
    "entry": "突き当たる",
    "reading": {
      "primary": "つきあたる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
