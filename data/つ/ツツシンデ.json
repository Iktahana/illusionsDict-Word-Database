        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女　あたしは仮りに他に好きな人がゐたにしろ、今迄の男の所にゐる間は絶対に謹んでます！",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「寒い」と上衣を着る「おい、俺の上衣じゃ」「儂のは」「お前のは……」○芝居の台詞を活弁の口調で言う兵「近衛後備歩兵第一聯隊長須知源二郎聯隊を代表して謹んで奏上し奉る。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主、謹んで聴いて居たが、　「では又、後程」と引き退る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう思つて爺いさんは謹んでお給仕をしてゐる。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の久保田万太郎夫人の告別式にお辭儀役の件、勿論そのつもりでゐたので謹んで承諾する。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、謹んで、拝見する。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……巌の層は一｜枚づゝ、厳かなる、神将の鎧であつた、謹んで思ふに、色気ある女人にして、悪く絹手巾でも捻らうものなら、たゞ飜々と木の葉に化して飛ぶであらう。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に、肩には更紗を投掛け、腰に長劍を捲いた、目の鋭い、裸の筋骨の引緊つた、威風の凛々とした男は、島の王樣のやうなものなの……　周圍に、可いほど間を置いて、黒人の召使が三｜人で、謹んで給仕に附いて居る所。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……餘り謹んでは居ないわね……一寸、お話の中へ出ておいで。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "名道人謹んで、微妙うもおはしまし候ものかな。",
              "citation": {
                "source": "妙齡",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御辞退を申す筈なれども、謹んで承ります。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "謹んで夜を守つたのである大正十五年四月―五月",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "謹んで、辞して、天界一叢の雲を下りた。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、金屏風の背後から謹んで座敷へ帰ったが、上段の室の客にはちと不釣合な形に、脇息を横倒しに枕して、ごろんとながくなると、瓶掛の火が、もみじを焚いたように赫と赤く、銀瓶の湯気が、すらすらと楊貴妃を霞ませる。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前で、謹んで言うのです。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、翌日は謹んで、参拝した。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その工合が、謹んで聞け、といった、頗る権高なものさ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君、私は謹んで、これなる令嬢の淑徳と貞操を保証いたします。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は謹んできいた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒ありて活く生命にや河豚汁　　　　　　　　一月十八日午前十時　　　　　　　　　　　　　田螺公　謹んで申す（椋鳥会五句集『河豚』明治四十五年一月）",
              "citation": {
                "source": "雑信（一）",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "出版に就て私の序文が御入用だとの仰は謹んで承りましたが、私はあらゆるミスに就て何事もいふ權利を有たない無學者なのだから少からず困却します。",
              "citation": {
                "source": "『傳説の時代』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは、五月のなかば、いいお天気の日でございましたが、尼御台さまは御奥へお越しなされて、将軍家と静かに御物語をなされ、私も謹んでお傍に控へて居りましたが、まことにのどかな、合掌したいくらゐの御立派な御賢母と御孝子、仕へるわが身のさいはひをしみじみ思ひ知りました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まづ箱根権現に参籠して謹んで祈誓の誠を致され、それから伊豆山権現に向つて出発いたしましたが、その前日あたりから一片の雲もなく清澄に晴れて、あたたかい日が続き、申しぶんの無いたのしい旅が出来ました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "農場の入口に、大きい石碑が立つてゐて、それには、昭和十年八月、朝香宮様の御成、同年九月、高松宮様の御成、同年十月、秩父宮様ならびに同妃宮様の御成、昭和十三年八月に秩父宮様ふたたび御成、といふ幾重もの光栄を謹んで記してゐるのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "臣謹んで俯伏して命を俟つ、と言辞を飾り、情理を綺えてぞ奏しける。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "謹んで奉先殿の左に収め奉れりと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し政宗も悪くはなかった、遠国に候故、と云って謹んでおとなしくしたという。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、笑って串戯を言いながら、瓶なる花と対丈に、そこに娘が跪居るので、渠は謹んで板に片手を支いたのである。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "母様の口ぶりが、」　とややその調子が強くなったが、急に事も無げな串戯口、「ええ、隊長、ちと謹んでくれないか。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と謹んで色には出ぬが、午飯に一銚子賜ったそうで、早瀬は怪しからず可い機嫌。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
