    "definitions": [
      {
        "index": 1,
        "gloss": "to follow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして汽車の進行する方角が、いつのまにか反対になり、西から東へと、逆に走ってることに気が付いてくる。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸触つても指に付いてくる六月の棕梠の花粉のやうに、月夜の温室の薄い硝子のなかに、絶えず淡緑の細花を顫はせてゐるキンギン草のやうに、うら若い女の肌の弾力のある軟味に冷々とにじみいづる夏の日の冷めたい汗のやうに、近代人の神経は痛いほど常に顫へて居らねばならぬ。",
              "citation": {
                "source": "桐の花とカステラ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに電子本には、コンピューターならではのメリットがいくつも付いてくる。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲州街道の砂を浴びて、気味のわるい襟元の汗をふきながら、文字春は四谷の大通りをまっすぐに急いでくる途中で、彼女は自分のあとに付いてくる十六七の娘を見かえった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが見る見る近付いてくると、窓のところへドッと打ち当り、砕けて、ザアー……と泡立つ。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "外へ出れば、やはりそのあとから付いてくる。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がついて追おうとすると、そこらの水草は、いよいよ深くなって、名も知れない長い藻は無数の水蛇か蛸のように彼の手足にからみ付いてくるので、大原もほとほと持て余した。",
              "citation": {
                "source": "鐘ヶ淵",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "済みませんが、少しお話し申したいことがありますから、小僧さんだけを先に帰して、おまえさんはちょいと其処らまで一緒に来て下さいませんか」「はい、はい」　云われた通りに小僧を帰して、利兵衛は素直に半七のあとに付いてくると、半七はかれを富岡門前の或る鰻屋へ連れ込んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "弁天娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の夕方は木も屋根も乾いた色に一とつ／＼凝結して、そうして靜に絡み付いてくる薄暗の影にかくれて行つた。",
              "citation": {
                "source": "木乃伊の口紅",
                "author": "田村俊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハードを買えば、当然付いてくるものと思われていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本体にもともと付いてくる二五六バイト、五一二バイトといったレベルのメモリーで使うのは、すでにここでは常識はずれとなっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながらその子供もやがて人心がつき初める頃には、もう智恵と慾が付いてくるので、何かの技法を心から要求するようになってくる。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "遮二無二に噛り付いてくる少年の前額に掌をかけて、力任せに押除けようと※いているうちに、浅田の夢は破れて、蚊帳を外した八畳の間にぽっかりと目を覚した。",
              "citation": {
                "source": "秘められたる挿話",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉羽之介は今更ながら、自分の魂の醜くさをまざまざと眼の前の絵姿の上に見せつけられて後悔｜慚愧に身の置き処もなく、まるで死んだもののように俯伏しているのであったが、ふと誰やらが近付いてくる跫音に、我れに返って起き直り、何気ない容子を装いました。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてひたすら縋り付いてくる。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎は九州から山陽線に移つて、段※京大坂へ近付いてくるうちに、女の色が次第に白くなるので何時の間にか故郷を遠｜退く様な憐れを感じてゐた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして、不思議なことには、竹山が落付いてくるにつれて、川村さんの方が何か気懸りらしく、竹山の様子をそれとなく観察しだしたのだった。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は誰一人、僕に組付いてくるものもない。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿呆鳥を釣るには、小さな板のうえに、餌のついた釣針を乗せて、浪の上に流してやると、阿呆鳥は、それに食付いてくる。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一月もゐれば此の辺の様子もわかりませうし、心持も落付いてくるでせう。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると僕は却って気が落付いてくるのを覚えた。",
              "citation": {
                "source": "宇宙尖兵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、先が強ければ、どこまでもそのあとにしたがい、また、こちらが強ければ、向こうから付いてくるというのが、それが牛の性分に近いものなのですから。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、うちの若い奴がきたら構わず何でも婆やさんからいいつけて貰ってうんと働かせて下さいよ」　もう一度、また名残りは尽きじという風にしげしげと、またしても涙で一杯の師匠の顔を見守って、やっとそれからその場をあとにした、まだ手拭で涙拭き拭き後くっ付いてくる圓太郎といっしょに。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハテだんだんこっちへ近付いてくるようだが、あ、万歳、やっぱり万歳、万歳だ万歳だ。",
              "citation": {
                "source": "初看板",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "自身の仕事は勿論門下生の研究でも少し目鼻が付いてくると、必ずきちんと纏めて発表させるような態度であった。",
              "citation": {
                "source": "リチャードソン",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "苗売りの声が舟松町を湊町の方へ近付いてくるのを、勘次は聞くともなしに放心聞いていた。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "梅雨に咲く花",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀の光りは南より北に向って真一文字にシャロットに近付いてくる。",
              "citation": {
                "source": "薤露行",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "足音はだんだん近付いてくる。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じようなことを繰返すのでも、中途半端の繰返しは鼻についてくるが、そこを通り越して徹底的に繰返していると、また一種別の面白味が出て来るようである。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくが行くと鼻を鳴らしてついてくるよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
