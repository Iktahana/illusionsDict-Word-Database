    "definitions": [
      {
        "index": 1,
        "gloss": "attendant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だが、同じそういう取りまきでも、徳川家康のような“付き者”となると、これはまた大いに趣のちがったものだ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉場と階段はとかくつきものである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの途迷信は人間にはつきものであって、これのない人はどこにもない。",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "密輸入につきものの暴利をむさぼるだけではなかった。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "杖がつきものになっている魔法使いはたいていばあさんかじいさんであるが、しかし彼らの杖はだいぶ使用の目的が違っていて、孫悟空のなんとか棒と同様にきわめて精巧な科学的内容をもっていたものと思われる。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二八　軍隊と戦争には、殺戮と掠奪はつきものである。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰惨｜忍刻の趣は、元来、この婦につきものの影であったを、身ほどのものが気付かなんだ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの宗教で肉食を禁ずることが大切の儀式にはつきものになっているのでもわかりましょう。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近間ではあるし、ここを出たら、それこそ、ちちろ鳴く虫が糸を繰る音に紛れる、その椎樹――（釣瓶おろし）（小豆とぎ）などいう怪ものは伝統的につきものの――樹の下を通って見たかった。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君たちは敗戦につきものの混乱と頽廃の園に咲いた悪の華だ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どやどやと、つきものも入って来たのは勿論である。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の家はそのひとつきもの間、火事のやうな騷ぎであつた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "増賀は参議｜橘恒平の子で、四歳の時につきものがしたように、叡山に上って学問をしよう、と云ったとか伝えられ、十歳から山へ上せられて、慈慧に就いて仏道を学んだ。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲霧は山につきものであり、塵埃は都の屬物であるが、萬丈の塵は景氣が好い代りに少し息苦しい。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "前座のような情実でもあって、一旦内へ入れたものなら、猫の児の始末をするにも、鰹節はつきものだ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から恁うした男には得てつきものゝ戀がある。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから宿の者に、お酒を言いつけて、やあ、この部屋は汚いなあ、君はよくこんな部屋で生活が出来るね、まあ我慢しよう、ここでその大将とお酒を飲みながら、ゆっくり話合ってみようじゃないか、商談には饗応がつきものだ。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "菎蒻は豆府屋につきものと知り給ふべし。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに兵隊にあるまじいことには、兵隊につきものの厚かましさが欠けていた。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇受女命は、お乳もお腹も、もももまるだしにして、足をとんとん踏みならしながら、まるでつきものでもしたように、くるくるくるくると踊り狂いました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "調子のよいときの武帝は誠に高邁闊達な・理解ある文教の保護者だったし、太史令という職が地味な特殊な技能を要するものだったために、官界につきものの朋党比周の擠陥讒誣による地位（あるいは生命）の不安定からも免れることができた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹一は告白という、青年につきものの行為を恥しく思う男だったのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、満面に微笑の輝いているその容貌の表情には、完全なる美にはいつでもつきもののあの憂鬱の微かな影が（不可解の変則だが！",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔からこうした男には得てつきものの恋がある。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸な者につきもののような灯影でございます」　と明石が言った。",
              "citation": {
                "source": "源氏物語",
                "author": "薄雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お天道さまと、生水とは何処へ行つてもつきものだに。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや父祖以來、幕府の恩遇あつきものに於てをや。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えて見れば、天盤も崩落も、火災も地下水も、炭坑にとってはつきものである。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前とひき蛙とは、それぞれ異つた生活をしてはゐるが、どちらも自尊家で、自尊家につきものの孤独性をもつてゐるところはよく似てゐるやうです。",
              "citation": {
                "source": "若葉の雨",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくつかあったと思われる跡が残っているのに、仏壇にはつきものの位牌がもぬけのからとなって一つもないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
