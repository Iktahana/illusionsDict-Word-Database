        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すぐ付け上がるからいやだ」「ハハハ付け上がるものか。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "付け上がるのは華族と金持ばかりだ」「また華族と金持ちか。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな法律を男性は一笑に付して、益つけあがるでありましょう。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「煩いから黙つてゐれば、何処までつけあがるんだらう。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンパにやめたら、こいつ、またつけあがる」　と大森が、手塚の首にかけた手に力を入れた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手に出れば相手はつけあがるなどと恐れる人々は、八紘一宇を口にする資格がない。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、この人は何処までつけあがるのだらう？",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつぱり君は人間か」「ぢやア、なによ」　私は女をおだてるとつけあがることを知つてゐたから黙つてゐた。",
              "citation": {
                "source": "私は海をだきしめてゐたい",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり君は人間か」「じゃア、なによ」　私は女をおだてるとつけあがることを知っていたから黙っていた。",
              "citation": {
                "source": "私は海をだきしめていたい",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまりやさしくしてくれると、わたしは、つけあがるよ」「かわいゝことを言ふやつだ。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "女つてもんは、つけあがるのよ。",
              "citation": {
                "source": "女人渇仰",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "放っておいたら、どこまでつけあがるか知れやしねえ、こんどこそはギュッという目にあわせて、申しわけがございませんの百辺も言わしてやるつもりなんだ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "野伏大名",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのへんまでは我慢が出来たが、酌をしに来いとまでつけあがるんじゃ、この先のことを思いやられる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "かごやの客",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、やがて彼女も、皆が心を柔げてくれるどころか、素直にすればつけあがるだけだということを、悟らなければなりませんでした。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "うッかりからかってオダテたが最後、つけあがること、男という男を鼻息で吹きちらかして尻にしきまくる魂胆なんで、本県じゃア前科十犯の人殺し屋でもチヂミ上るという八丁鼻が、アタピンにかかっちゃ鼻先であしらわれていまさ。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「…………」「おい」「おいが気に入らねえ」「モシモシ、尾沢君」「ばかにするな」　と尾沢生は相手がどこまでも下から出るのを承知でますますつけあがる。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つけあがるばかりだ」　男は深く何度もうなずいた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしここでは、（b）助けおこしてやっても何のかいもなく・むしろそうすれば益々つけあがるような・人間を助けたりおこしたりするのは、不正でもあり無慈悲でもある。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらに附属している太政官の地券、下文、国司の証など、遺産の大部分は、返していただいておりません」「つけあがるなッ」呶喝して、良正は、杯の酒を、ぶっかけようとしたが、良兼が、あわてて、手くびを抑えた。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊太夫は冷かすように、「旅川、お前は案外、女には手荒だな」「そうでもないが、つけあがるからよ。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "鳴門の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
