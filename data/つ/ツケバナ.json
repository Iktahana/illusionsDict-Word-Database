          "literary": [
            {
              "text": "水の溜つた田のわきにはおほばたねつけばなのの」は底本では「おほばたねつけばなの」］聚落が有つた。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのへんに「おほばたねつけばな」の群落でもあれば、春さきにはもつと水量が増す証拠である。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし喰いつけばなかなか離れないから、たやすく叩き殺せる。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
