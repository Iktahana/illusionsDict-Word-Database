      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "thrusting down one's opponent either inside or outside the ring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし、川の中まで足を踏み入れて、人間を嗅ぎ出して、突き倒し兼ねないのは、この川楊ばかりだ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、柵を突き倒しては、役人の間を走りぬけて外へ出た。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、扉口に立っている老婆を突き倒して屋内へ押し入ってきた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻妾を突き倒して、半殺しの目に逢わした奴だ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「帰るとこ、よう忘れんかったこっちゃな」そう言って蝶子は頸筋を掴んで突き倒し、肩をたたく時の要領で、頭をこつこつたたいた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼんやりした顔をぬっと突き出して帰って来たところを、いきなり襟を掴んで突き倒し、馬乗りになって、ぐいぐい首を締めあげた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はドレッバーの襟首につかみかかり、敷地の際まで来ると、突き倒し蹴飛ばして、やつを道へ半ば追い出す格好です。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも、我々がＣ――街からこの通りへ曲ったときに、頭に大きな林檎籠をのせた果物屋が、誤って危うく私を突き倒しそうになったのだった。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "長助も一生懸命で、滅茶苦茶に女をなぐり付けて、どうやらこうやら突き倒して逃げた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳三郎は死神に出合ったよりも怖ろしくなって、殆ど夢中でかれを突き倒して逃げた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は先ずお住を突き倒して、さらに智心の襟首をつかんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜ふけに、ばたばたいう音がきこえて、翌あさの日の出る頃まで戸を明けないので、店の主人が怪しんで、戸をあけて窺うと、内から一頭の熊が飛び出して、人を突き倒して走り去った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドーン、ドドーン、バーン　と天龍の川を挟む両岸の絶壁に木魂して古畳を突き倒し、穴を明け、時には四五間も空へ押し上げるのだった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがいよいよ彼の反感を挑発して、突然に飛びかかって磯貝の咽喉を絞めつけ、そこへ突き倒して逃げ帰りしなりという。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は暗夜にお福を誘い出して、突然かの女を路ばたに突き倒して、大きい石をその脇腹と思われるところに投げつけると、お福は二言といわずに息が絶えてしまった。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小坂部はまだ返答に躊躇していたが、采女はもう彼を突き倒してゆくほどの勇気はなかった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "末次郎　（奮然として巫女を突き倒し）何をぬかすんや、ばかっ！",
              "citation": {
                "source": "屋上の狂人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを突き倒して次の間へ飛び出すと、そこには夜具でも入れてあるらしい押入れがある。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関大尉は、とっさに強敵スミス中尉を、突き倒したが、敵は多勢、味方は一人、しかも敵の人数は刻々ふえるばかりである。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸之助はそれを突き倒して逃げ出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう捨てては置かれないので、牢内へはいって取り鎮めるために、役人たちが入口の大戸の錠をあけると、その途端に五、六人がばらばらと飛び出して来て、役人たちを不意に突き倒して逃げ去りました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ふと、また何者かその地中から頭を上げて、地上の動乱の時機に際して、地上を覆つてゐる人間の家屋を、片端から突き倒しでもしはしないか。",
              "citation": {
                "source": "五月雨",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸ぐらをとって小突きまわしたり、床の上へ突き倒したりしたものである。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "綱手は、よろめいて、倒れかかりながら「兄さまっ」　両手を、下から延すのを「たわけがっ」　左手を、柄から放して、突き倒した、かと、思うと「ええいっ――ええいっ」　猛獣の、吼号するような懸声であった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "小太郎は、一撃を与えると共に、綱手を突き倒しておいて、狼の如く、襲いかかった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが寛文七年の春、家中の武芸の仕合があった時、彼は表芸の槍術で、相手になった侍を六人まで突き倒した。",
              "citation": {
                "source": "或敵打の話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五　その夜駅長は茶を啜りながら、この間プラットホームで蘆工学士を突き倒した小林浩平の身の上話をしてくれた、私がただ学問とか栄誉とかいうはかないうつし世の虚栄を慕うて、現実の身を愧じ、世をかねる若い心をあわれと思ったからであろう。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘八を向うへ突き倒し、その手を帯へ差し入れたが、抜いて握ったは嗜みの懐刀、振り冠ると凜々しく叱咤した。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時そわそわしていようものなら、人間箱をつきたおして、せっかくの獲物が人間に気づかれてしまったり、また、お巡りさんや刑事に怪しまれて、かえってこっちがとりおさえられるから、出来るだけ用心をするんだぞ」　新田先生は、これを聞いていて、ますます驚いた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い廊下をひとつまがると、そこのドアをひらいて、小林君を中へつきたおしておいて、パタンとドアをしめ、外からかぎをかけると、そのまま立ちさってしまいました。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
