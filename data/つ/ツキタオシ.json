[
  {
    "uuid": "9e3e0290-866a-5a0e-b61d-5af04b66ce0e",
    "entry": "突き倒し",
    "reading": {
      "primary": "つきたおし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
