    "definitions": [
      {
        "index": 1,
        "gloss": "to send",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「聞いて遣わす、お酌をおし……御免なさいよ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ遣って印をして、それを目的にまた、同好の士な、手下どもを遣わす、巡査、探偵などという奴が、その喜ぶこと一通でないぞ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一途中相果てたなれば、金子はそのままそちに遣わす。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と綾子眼をしばたたけば、貞子は頷きて、「定や、あれを遣わすが可い。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "木沢殿所持の宝物は木沢殿から頂戴して遣わす。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがしも共に願うて遣わす、斯くの通り。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "就ては此方より人を差添え遣わす。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "共王は斉と結んで、魯を討とうとし、其の出師の期を告げる為に巫臣を使として斉に遣わすことにした。",
              "citation": {
                "source": "妖氛録",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおその方共は身共の下知に従って、隠れたる金銀を探し出し、身共の差図通りに取形付けを致すならば、今日持って参いった賭博の資金は各自に相違なく返し遣わすのみならず、賃銀は望みに任するであろう。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その肝の潰れた博士を選んで法螺丸は、政界の有力者の処へ腎臓病のお見舞に差し遣わすのだから深刻である。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわく、合祀されし社の氏子、遠路を憚り、ことごとく合祀先の社へ参り得ざるをもって、祭日には数名の総代人を遣わすに、多勢に無勢で俘虜降人同然の位置に立つをもって、何のありがたきことなく早々逃げ帰る。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かならず間違い無しにとどけてくれ、あと金は引きかえに遣わすぞ」　しかし自分はこれから他へ寄り道をして帰るから、日が暮れてから持参してくれといった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "一つ目小僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "プレツス怒りてその舅ヨバテースに宛てて隠語もてベを殺しくれるようの依頼状を認め、ベに持たせてヨに遣わす。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠は『説苑』十二に秦と楚と軍せんとした時、秦王人を楚に遣わす、楚王人をしてこれに汝来る前に卜いしかと問わしむると、いかにも卜うたが吉とあったと答えた。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一向｜埒明かずとあってカリブ人、また鼠を遣わすとこやつ小賢しく立ち廻ってたちまち獏の居所を見付けたが、獏もさる者、鼠に向いわれと同類の汝がわが食物を得る場を垢の他人の人間に告げたって、人間ほど薄情な者なければ、トドの詰まりは狡兎死して良狗煮らるだ。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……実は、綾のことですが、今度お国のお侍で大隈という人から是非｜慾しいというので、遣わすことに承諾しましたのですが、まるで娘を掠奪われるような工合で、私も実に驚きました」と、愚痴交じりにいっておられた所を見ると、未亡人も承諾はしたものの、先方の行方が乱暴なので迷惑に感じたような口裏であった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大隈綾子刀自の思い出",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の条々に該当する者共、この建札目にかかり次第予が屋敷へ参らば、金子一両ずつ遣わすべし。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この者共を遣わすこと罷りならぬゆえ、とッとと帰らッしゃい！",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "遣わすこと罷りなりませぬ！",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は決断致してあすにも交易を差し許して遣わすぞ。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまで待てど暮せど埒あかず、あまりに歯痒う覚ゆるまま、この上は使いなど遣わすこと無用と、予がじきじきに催促にまいった。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりゃあお困りでしょう」「勿論、手前方でも相当のとむらい料を遣わすつもりで居りますが、どうもその、相手方の申し条が法外でございまして、どうしても三百両よこせ、さもなければ、お此さんを下手人に訴えると申すのでございます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "弁天娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒姫山の裾野にて、若衆の叩き払い致して遣わすぞ」　力に委せて武道者は、笞刑を美少年に試みようとした。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "拙老が手伝うて遣わすぞ」「何から何まで御親切な」　滝之助は感激した。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも御前にまいって取なして遣わす故、控えおれと申し聞けまして、そのまま出仕致しましたが」「……たわけ奴がッ……」　と忠之は突然に大喝した。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨付を遣わすぞ」「忝けのう御座りまする」　与一は何やら一存ありげに肩を怒らして押戴いた。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お言葉に甘えて老僕イシャク・バイをつかわす。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上は心よく、親鸞影像を戻し返してつかわすのみか、他宗ながら忰源兵衛の菩提も、こなたで弔い追善供養。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠島を仰せつけられるものには、鳥目二百銅をつかわすというのは、当時の掟であった。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では、長吉、この度は、上の特別な慈悲に依って、たたきと云うことにしてつかわす。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
