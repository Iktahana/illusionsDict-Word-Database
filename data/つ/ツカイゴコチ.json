        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "猟銃はどうもグリーナーが使い心地が好いなどと紳士のような事を門前の小僧の身分でありながら思う。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下室の隅から塵だらけになって引出された板、其を日に乾し、水で洗い紙に包んで、丈夫な、使い心地のいい机に仕てくれたのは彼である。",
              "citation": {
                "source": "樹蔭雑記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実非常にいいもので使い心地は申し分のない気持のいいものである。",
              "citation": {
                "source": "南画三題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "タオル二本のうち、私は薄手の方がさっぱりした使い心地だろうと思いますが、実際はどうかしら。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手拭は麻ですから夏は使い心地ようございます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
