[
  {
    "uuid": "6d8e3969-6c21-5fed-b2ec-6b39b6a2ae21",
    "entry": "突き落とし",
    "reading": {
      "primary": "つきおとし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
