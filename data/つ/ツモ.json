    "definitions": [
      {
        "index": 1,
        "gloss": "drawing a tile from the wall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これを行うときは、他家が積んである牌を自摸するときから同人が一枚捨てる迄の、時間で言えば一秒ほどの間を覘ってやると、皆が自摸する人の方へ注意を奪われているので難なくごまかせる。",
              "citation": {
                "source": "麻雀インチキ物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "東南西北苦労の種をツモリ自摸って四喜和っていう歌もあるわ」「アラ。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中、道子の自摸の番となった。",
              "citation": {
                "source": "彼が殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の時俺の手は四七万の両単吊の待であったが、もはや万字を打って一人払いの危険を冒す人もないらしいので、自摸して和る一手しかないのである。",
              "citation": {
                "source": "彼が殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の時自摸したのが最後の一個の東であった。",
              "citation": {
                "source": "彼が殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻雀台を買ひ、いざ――と始めたのが、負ける／＼、自摸が悪すぎて面白くない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "火傷で右手が痛いが、ラストの清一色自摸入の満貫ですっかり気をよくした。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日残念なことをした、満槓を自摸ってゐるのに、あはてゝ捨てゝ打ち込んだ、そのため三千八百の負となる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月二十日（木曜）　昨夜十二時近くから延々長期戦、約十五六時間、相手は色々と変るのだが僕だけは一回もやめず、曳々とばかり打続ける、何年ぶりかで十三※九を自摸る、結局一万も勝った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術家ハ、イツモ、弱者ノ友デアッタ筈ナノニ。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……こんな調子で世界を支配するものは神様でなくてイツモ悪魔であった。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこに来てジイッと突立っておいでになる方はイツモ大抵きまっているんですからね。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお島どんがなあ……御存じかも知れんが、当寺の本堂の……ホラ……あすこの裏手に住んでおりまする非人の処へイツモ立寄って行きましたそうで……これは寺男の話で御座いまするが……」「ハハア。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "又おだてる……実は私が直接にアンタの話を聞いて、それを私の聞込みにして、お目付に申上げても済む事じゃが、それではイツモの通りお前の手柄を横取りするような恰好になるけに気持が悪い……のみならず今度の一件は、模様によると日田のお金奉行を相手に取るような事になろうやら知れぬ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケイサツモンダイニナリ。",
              "citation": {
                "source": "ざんげの塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この樽一つ在れば五十人から百人ぐらいの宴会ならイツモ余りますので……どうぞ御遠慮なくお上り下さい」　と言う重役連の挨拶であったが、サテ、コップが配られると、さあ飲むわ飲むわ。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――オマエ、ヒゲヲ、ハヤス、ツモリカエ？",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「セ、セツシヤヲ　コロス　ツモリカ。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カナヅチハ　クツモ　ツクルンダナ。",
              "citation": {
                "source": "カナヅチ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "イツモハ　ナカヨシダツタノデスケレド、アンマリ　マンナカノ　ホシガ　サムイ　サムイト　イフノデ　ホカノ　二ツノ　ホシニ　イジメラレタノデシタ。",
              "citation": {
                "source": "ナガレボシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「アンマリ、カワイカツタノデ、マダ　ダツコシテル　ツモリデ　カヘツテ　キタノヨ。",
              "citation": {
                "source": "ミチコサン",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "子息ハ宥免ノツモリデヰマシタ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、京吉はツモって上るよりほかに仕方がなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よしッ、ツモってみせる！",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンスを踊らせても、玉を突かせても、マージャンを打たせても、何をやらせても、京吉は天才的な巧さを発揮したが、とくにマージャンの場合、京吉の巧さとは、いざという時には、無理なパイでもツモってみせるという闘志と勝負運の強さだった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五万か八万をツモってみせる！",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、おれツモるよ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツモれや紫、食いつきゃ紅よ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　京吉はパイをツモる時に、気合を掛けるようなことはめったにしなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」紅中ならカンになっており、リンシャンカイホウ（同じパイが四枚の時、もう一度ツモってそれで上る上り方）のチャンスがある。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
