    "definitions": [
      {
        "index": 1,
        "gloss": "(for an object) to be shiny",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
