    "definitions": [
      {
        "index": 1,
        "gloss": "to thrust (something) into (something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「今や、今や、手エ入れるんやったら、今や」　と、いたずらに頭の中で叫んでいたが、しかし、いくら掏摸になるんだとやぶれかぶれの覚悟をきめても、はじめての経験では、他人の袂に無断で手を突っ込むということは、よほど魔がささねば出来なかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何気なくふと暖簾の向うを通る女の足を見たりしているが、汁が来ると、顔を突っ込むようにしてわき眼もふらずに真剣に啜るのである。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ一枚もくれないのね」と突っ込む。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢の前に中腰になり、酒で染まった顔をその中に突っ込むようにしょんぼり坐っているその容子が、いかにも元気がないと、一目でわかった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は傷口へそれを突っ込むようなわけにはいかなかった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハンプシアのベドウズさんとこへ突っ込むわ。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "スズメバチの巣に頭を突っ込むとなれば躊躇しますよ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し先へ転がしたところで、いつもルーシィの指輪を入れていた懐に手を突っ込むと、なんとそこにありません。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもお人好しのやつだったから、こうして友人の事件に首を突っ込むなど、あいつらしいな。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車がレディングを過ぎてずいぶんした頃、最後のひとつを座席の下に突っ込むと、葉巻入れをこちらに差し出した。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『どんな玉が這入っているか知らないが、あの蛇の中へ手を突っ込むことは出来まいね』『なに、訳はないよ』と、おとくは平気で笑っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "知っていて、陥穽に首を突っ込むにゃ当たらないもんなあ」小倉は行く先を忘れた田舎者のように当惑げにそこへ突っ立っていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　信一郎は、夫人の示した僅かばかりの動揺に力を得て突っ込むようにそう言った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の強飯のなかに自分の箸を突っ込むなどは、あまりに行儀の悪いことである。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃には庭の大きい柿の実もだんだん紅らんで、近所のいたずら小僧が塀越しに竹竿を突っ込むこともあったが、阿母さんは例の「誰だい」を呶鳴る元気もなかった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨折って美文でも書くと、杉田君、またおのろけが出ましたねと突っ込む。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうそう突っ込むにも及ぶまい。",
              "citation": {
                "source": "半七雑感",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がようやく起き上ると、女たちは一つの穴へ首を突っ込むように、ばたばたしながら、椅子の足をひっ掻いていた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "無軌道電車が黄包車の群れを追い廻しながら、街角に盛上った果物の中へ首を突っ込むと、動かなかった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを突っ込む勇気もなければ、術も知らず、唯話の途絶えめ途絶えめを、何処からかカンナの音が響いて来ます。",
              "citation": {
                "source": "職業の苦痛",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへまた他のが蹌踉けて来て首を突っ込む。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二人が生きて居れば別々に訊問して、答弁に前後矛盾した所があれば又何とか突っ込む方法もあったかも知れぬが、石子刑事の方でも都合が悪い所は二人のせいにして逃げて終うし、支倉の云い分は少しも通らない事になった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子が失神した原因さえ解れば、なにも君みたいに、最初から石の壁の中に頭を突っ込む必要はないと思うよ」「ところが熊城君」と法水は皮肉にやり返して、「たぶん伸子の答弁だけを当にしたら、まずこんな程度にすぎまいと思うがね。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水に溺れる者の頭を、浮ぶひょうしに水中に突っ込むのと同じだ。",
              "citation": {
                "source": "オランウータン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、皮肉な読者は突っ込むかも知れないが、事実彼の商売は卑しい卑しい牛飼いであった。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間にパッと飛び立った男は右手を懐中へ突っ込むと初めて匕首を抜いたものである。",
              "citation": {
                "source": "三甚内",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石段の中途から薄暗くなってよく見えなかったので、初めはそれが水だとは気がつかず、私は先に立って下りていると、後からサイドに腕をつかまえられて立ち止まったのだが、危うく水の中に片足を突っ込むところだった。",
              "citation": {
                "source": "処女の木とアブ・サルガ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭をそらして翼のあいだにつっこむと、おだやかな湖に浮ぶ白い蓮の花のように、静かに横たわっていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人のことにあまり首をつっこむなよ。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、あのころんで足をくじいたおばあさんからもらった三本のむちのなかの、いちばんながいのをかくしにつっこむと、窓をあけて、町の丘から、お城のほうへ、ひらひらとんでいきました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
