[
  {
    "uuid": "b51541b0-bee5-5ea5-86a9-fcba8b9bd91b",
    "entry": "強まる",
    "reading": {
      "primary": "つよまる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
