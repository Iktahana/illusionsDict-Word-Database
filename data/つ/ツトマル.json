    "definitions": [
      {
        "index": 1,
        "gloss": "to be fit (for a role)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "西部劇のヒロインなら務まるけれど――今日なんてこの通りのベヤー・フツドよ。",
              "citation": {
                "source": "サロメと体操",
                "author": "ヘツペル先生との挿話",
                "note": "青空文庫"
              }
            },
            {
              "text": "母や親類の者共が、どんなにお前を排斥したからとて、斯うなれば最早自分が父の代理が務まるから、決してお前の身の立たぬやうにはしない――彼は、さういふ意味のことをそれとなくお蝶に伝へたつもりなのだつた。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで車掌の役目が務まると思ってるのか、馬鹿っ！",
              "citation": {
                "source": "電車停留場",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様まで此奴に瞞着されて、それで警官が務まると思っとるのか。",
              "citation": {
                "source": "電車停留場",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「危いッ」　飛び上がって後退りした今松、「駄目だ、駄目だよ桃公とても」　真っ青になってフラフラとふるえ上がると、「ツ、務まるもんかこんな家。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私しは船頭」「へー、君が船頭」君にして船頭が務まるものなら僕にも見番くらいはやれると云ったような語気を洩らす。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸っ子が泉岳寺を知らないのは情けない」「知らなくても教師は務まるからな」と主人はいよいよ天然居士になる。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "フガフガ」「そんな三百｜代言みたいなことをするために必要な保証人なら私みたいな人間にだって立派に務まるじゃありませんか」と堪りかねて私は大声を出した。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の姉は、プロフェッショナルなジャズのスモール・グループでピアニストが務まるほどの腕前だった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ヘリコプターどうしで射ちあったらどうですか」「対空機関砲はないのか」「ありません」「それでおまえはよく俺の仕事が務まるな！",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、犯人らしい、多くの弱点を持っている者を挙げれば、それで役目がつとまるのだ。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」たゞでもこの役はつとまる所をしみ／″＼禮をいはれた上に、「たんまり御祝儀を。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それくらいの眼が利かないで、掏摸がつとまるか。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、世の中のことには何一つ興味を感じないらしいんで、あれでよく新聞記者がつとまる――実はあいつは新聞記者でしてね、ところが、あいつの書く記事と来たら、全部あいつがでっち上げたデマなんですよ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなゆるんだ性質では家主はとてもつとまるものではないな、と考えた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍛練に鍛練を重ねても十分につとまるかどうか判らぬとがお能の常習じゃ。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さう言ふと、修一ははじめて口を利いて、「お前みたいな頭の悪い奴に家庭教師がつとまるか。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことでよくお役目がつとまるとある人が感心する。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紡績の工女、看護婦、交換嬢、女給、店番なぞいう、小学卒業程度でもつとまるのを初めとして、タイピスト、事務員、女教員なぞいう高女卒業程度のものまで盛に要求され出した。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "國の方で語學の教師がつとまるほど外國の言葉に親しんだ人でも、一歩海の外へ身を置いた時は、靴一足注文するにもまごつくものだとの話なぞが出たことを覺えてゐる。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人の方は数も少いうえに種類も少くて、大抵女事務員とか令嬢奥様といった位のところだから、君で充分つとまると思ってそう決定てあるんだ。",
              "citation": {
                "source": "階段",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたここの姐さんですか」「そうですよ、もう一人いたんだけれど行っちまったの」「ねえ、私につとまるだろうかね」「そう沢山お客もないし大丈夫だよ……私が教えてあげるわ。",
              "citation": {
                "source": "小村淡彩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その調子なら立派な伯爵夫人としての役もつとまるに違いない。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ位の自傷がわからなくて軍医がつとまると思うのか。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――別に、大殿は、左様な――」「それが判らんで、よく家老職が、つとまるの」「久光、何を、お云いやる」　と、お由羅が、叱った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "是で中学の教頭が勤まるなら、おれなんか大学総長がつとまる。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで中学の教頭が勤まるなら、おれなんか大学総長がつとまる。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェッ、この野郎、てめえ達、遊びたいから遊んでるんぢやねえか、結婚したいなんて嘘つきやがれ、結婚してみてえ、と云ふんだらう、やつぱり遊びぢやねえか、遊び放題に遊びやがつて女房がつとまるもんか、とひやかす。",
              "citation": {
                "source": "パンパンガール",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし僕にどんな仕事がつとまるというのかね。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うちの伜も私の代りが立派につとまるようになりましたよ」　というような伜自慢からはじまって、いつのまにやら伜や伜の女房の尻にしかれてしまう。",
              "citation": {
                "source": "親が捨てられる世相",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
