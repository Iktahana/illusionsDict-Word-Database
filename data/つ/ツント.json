    "definitions": [
      {
        "index": 1,
        "gloss": "standoffishly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "家の娘は四歳であるが、ことしの八月に生れた赤子の頭をコツンと殴つたりしてゐる。",
              "citation": {
                "source": "純真",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だつてね、太つたくせに顔の陰が尖るつて質の女は一度ツンとすると其の後はもう理由もなしにツンとし通すものだから……」「こいつ大した苦労性だな、気の小さい……」　夕方行くとＳ子は最も他人行儀を示した。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の娘は四歳であるが、ことしの八月に生れた赤子の頭をコツンと殴ったりしている。",
              "citation": {
                "source": "純真",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時に彼の足は小荷物台から攫われて、尻や背中でゴツンゴツンと調子をとりながら、コンクリートの上へ引きずり下された。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "空がツンツンと光ってゐる。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の隅っこに淋しく残された鏡台、とり散らかされた化粧道具、（それが静かにダブッて）　鏡台の辺りに転がって居る一升徳利、もう一つコロコロ転がって来て二つコツンと衝突しました。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お光、気強くツンと横向いたが流石に涙ぐんで居る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と忽ち、　団九郎、一つコツンと叩かれた。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、もう爲方がない‥‥‥どうする事も‥‥‥苦しい‥‥‥痛い‥‥‥許して、許して‥‥‥あの晩、ほんとにあの晩‥‥‥貞雄さん‥‥‥誰にも、誰にも‥‥‥考へ‥‥‥思ひ違ひ‥‥‥かんに、かんにして‥‥‥』と、お前の無氣味な鋭さを持つた聲は、何時か絶え入るやうな涙聲に變つて、其處でポツンと切れた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　傲慢で、ツンとした于立嶺が、全く、おびえきった子供のように変っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こくりこくりしかけていた少年兵は、ふと頭をゴツンと打って眼をあけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すゞも、俊も、お母も、自分達の家が、中山服の蟻と、乞食、浮浪漢の群れの中に、ポツンと一つだけ、存在しているのを知っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはツンツン、ツンツンと鳴いて、枝中はねあるく小さなみそさゞいで一杯でした。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "初見の土地へ対しても、すつとこ被りもなるまいし……コツツンと音のするまで、帽子の頂辺を敲いて、嵌めて、「天気模様は如何でせうな。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士の吸ふ巻煙草がポツンと赤く見えるだけ、「斯う納まって見ると、我輩もさながら、洞熊か、洞窟住人だ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "清夫はお日さまで紫色に焦げたばらの実をポツンポツンと取りはじめました。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはツンツン、ツンツンと鳴いて、枝中はねあるく小さなみそさざいで一杯でした。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士の吸う巻煙草がポツンと赤く見えるだけ、「斯う納まって見ると、我輩もさながら、洞熊か、洞窟住人だ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また女の捨てばちな気分を表象するようにピアノの鍵盤をひとなでにかき鳴らしたあとでポツンと一つ中央のＣを押すのや、兵士が自分で投げた団扇を拾い上げようとしてそのブルータルな片手で鍵盤をガチャンと鳴らすのや、そういう音的効果もあまりわざとらしくないようにうまく取り入れられている。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……同じ事を、絶えず休まずに繰返して、この玩弄物を売るのであるが、玉章もなし口上もなしで、ツンとしたように黙っているので。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その爺さんが、コツンコツンと斧を入れる。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、時々ずつと寄つては、じろりと車を見上げるので、やがては、其の婦ツンとして、向うを向いて、失禮な、と云つた色が見えた。",
              "citation": {
                "source": "麥搗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "耕平のおかみさんは、ポツンポツンとむしってゐます。",
              "citation": {
                "source": "葡萄水",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "クねずみはだんだん四方の足から食われて行って、とうとうおしまいに四ひきの子猫は、クねずみの胃の腑のところで頭をコツンとぶっつけました。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十五回　白色巡洋艦大陸の影――矢の如く空中を飛走した――ポツンと白い物――海鳥の群――「ガーフ」の軍艦旗――や、や、あの旗は！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚呼、大事切迫／＼と、私は武村兵曹と顏を見合はしたる儘、身體の置塲も知らぬ程心を惱まして居る、時しも忽ち見る、遙か／＼の水平線上に薄雲の如き煙先づ現はれ、つゞゐて鳥か船か見え分かぬ程、一點ポツンと白い影、それが段々と近づいて來るとそは一艘の白色巡洋艦であつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "とのさまがえるは早速例の鉄の棒を持ち出してあまがえるの頭をコツンコツンと叩いてまわりました。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の席に配つた、座蒲團一つ一つの卓の上に、古色やゝ蒼然たらむと欲する一錢銅貨がコツンと一個。",
              "citation": {
                "source": "九九九會小記",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "座にひらきを置いて、又コツンと一個、會員の數だけ載せてある。",
              "citation": {
                "source": "九九九會小記",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
