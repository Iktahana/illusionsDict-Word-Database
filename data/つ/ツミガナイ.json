[
  {
    "uuid": "47d67f93-4d5d-5233-b8f9-dd5974f05763",
    "entry": "罪がない",
    "reading": {
      "primary": "つみがない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
