    "definitions": [
      {
        "index": 1,
        "gloss": "patching (clothing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
