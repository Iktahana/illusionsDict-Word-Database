        "examples": {
          "standard": [
            {
              "text": "結核の検査には、ツベルクリンが使われることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ツベルクリンは、結核菌から抽出されたタンパク質だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、学校でツベルクリン反応の検査を受けた記憶がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（明治四十年九月十七日『東京朝日新聞』）　　　　　　　　　六　　　　　　結核の初期診断法　一時有名であったコッホのツベルクリンは、その後ただ結核病の診断にのみ用いられていた。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに今度仏国のカルメットという人の発表した所に拠ると、酒精で沈澱させたツベルクリンの一プロセント溶液を眼に点ずると、健康体ならば何の異状も起らぬが、少しでも結核のあるものならば、二十四時間内に充血して紅くなるという事である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツベルクリンの注射だって人の体質に依ると云うじゃないか。",
              "citation": {
                "source": "生あらば",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから林町の子供たち二人はツベルクリンが陰性で、これも予防注射が出来そうです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この新しい治療法とは結核菌の純粋培養のグリセロール抽出液でツベルクリンというものであることが判った。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "1890年にコッホはツベルクリンで治療したモアビット病院の患者のための観察病棟の責任者にエールリッヒを任命し翌年に感染病研究所が創立されたときにエールリッヒにもっと良い研究の機会を与えた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
