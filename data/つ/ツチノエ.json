        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（岡本綺堂）明治元年（戊辰）　一八六八○天下の形勢不穏のため、猿若町の三座とも正月興行を休み、二月に至りて漸く開場。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一年（戊寅）　一八七八○二月二十三日より新富座にて、西南戦争を脚色したる「西南雲晴朝東風」の通し狂言を上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一年（戊子）　一八八八○一月、猿若町市村座の新築落成し、八日より三日間、開場式を行う。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十一年（戊戌）　一八九八○一月三日、狂言作者久保田彦作死す、五十三歳。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十一年（戊申）　一九〇八○一月、歌舞伎座の二番目「競馬春廼魁」にて、競馬場の舞台に本馬を用う。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿一日、戊申、将軍家、三浦三崎に渡御、船中に於て管絃等有り、毎事興を催す、又小笠懸を覧る、常盛、胤長、幸氏以下其射手たりと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿日、戊辰、将軍家貞観政要の談議、今日其篇を終へらる、去る七月四日之を始めらる。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日、戊午、和漢の間、武将の名誉有るの分御尋ね有るに就いて、仲章朝臣之を注し出して献覧せしむ、今日、善信、広元等、御前に於て読み申す、又御不審を尋ね仰せられ、再三御問答の後、頗る御感に及ぶと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿四日、戊戌、将軍家和田左衛門尉義盛の家に入御、御儲甚だ丁寧なり、和漢の将軍の影十二鋪を以て、御引物と為すと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六日、戊午、天晴、将軍家二所の御精進始なり。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿六日、戊辰、晴、将軍家二所より御帰著と云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七日、戊午、陰、和田平太胤長、陸奥国岩瀬郡に配流せらると云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "九日、戊申、陰、御所の造営、重ねて其沙汰有り。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿日、戊子、天晴風静なり、将軍家新御所に移徙なり、御車京都より遅く到るの間、御輿を用ひらる、酉刻、前大膳大夫広元朝臣の第より、新御所に入御、大須賀太郎道信黄牛を牽く。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿二日、戊午、将軍家火取沢辺に逍遥せしめ給ふ、是草花秋興を覧るに依りてなり、武蔵守、修理亮、出雲守、三浦左衛門尉、結城左衛門尉、内藤右馬允等供奉せしむ、皆歌道に携はるの輩なり。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日、戊戌、甘雨降る、是偏に将軍家御懇祈の致す所か。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八日、戊辰、霽、伊豆国の飛御参ず、申して云ふ、去る六日、戌剋、入道遠江守時政、北条郡に於て卒去す、日来腫物を煩ひ給ふと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿日、戊寅、今夜子剋、御霊社鳴動す、両三度に及ぶと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿一日、戊申、晴、巳剋、鷺、御所の西侍の上に集る、未剋地震と云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿五日、戊※、御台所厳閤の薨去に依りて、信濃守行光の山庄に渡御、密儀なりと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一日、戊子、晴、申剋、鶴岳八幡宮の別当三位僧都定暁、腫物を煩ひて入滅す。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿日、戊午、晴、去る二日、将軍家右大臣に任ぜしめ給ふ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戊戌の政変がその一つであり、さらに、その二年後に起った北清事変は、いよいよ支那の無能を全世界に暴露した致命的な乱であった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "再轉し三轉しては、甲の事を仕ながら乙丙の事を思ひ丁の事に當りながら戊己庚辛壬癸の事を思ふやうになり、終に全く散る氣の習の付くやうになるのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉永元年戊申、二歳。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治元年戊辰、二十二歳。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一年戊寅、三十二歳。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一年戊子、四十二歳。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "某が相果て候今日は、万治元｜戊戌年十二月二日に候えば、さる正保二｜乙酉十二月二日に御逝去遊ばされ候松向寺殿の十三回忌に相当致しおり候事に候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "万治元｜戊戌年十二月二日興津弥五右衛門｜華押　　　　　皆々様　この擬書は翁草に拠って作ったのであるが、その外は手近にある徳川実記（紀）と野史とを参考したに過ぎない。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
