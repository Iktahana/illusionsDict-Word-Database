    "definitions": [
      {
        "index": 1,
        "gloss": "dull",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は腹立ち紛れに、『アンタに買うてもろうたチャ詰まらん』　と怒鳴ってメチャメチャに泣出しましたが、あん時はダイブ失恋しておりましたナア。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から慣らしておかにゃ、詰まらんぞ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『貴様はモウ詰まらんぞ』　何度も何度も大惣が合点合点しました。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで……これでは詰まらん博多へ帰ろう。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "知っとっちゃ詰まらん」　末後の一句、甚だ無造作。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の気合いが途中で抜けちゃ詰まらん。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "クニャクニャになって詰まらん」　と云って門弟連中を絶倒させた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは朔造（梅津）さんは病気で稽古を休みますと言伝がありました」　と云ったら、翁は「ウフウフ」と微苦笑して、「今の若い者は弱いけに詰まらん」　と云った。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はこれは吾々にとっちゃ実に詰まらん失敗談だがね。",
              "citation": {
                "source": "近眼芸妓と迷宮事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドウセイ退屈じゃからボンヤリしとったて詰まらん。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "平凡な平凡な涙もろい人間だ……その平凡な平凡な人間に時々立帰ってホッと一息したいために、お前達を養っているのだ……イヤ詰まらん事を云うた。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "詰まらんところから夫婦不仲などといふことは起り勝ちなものです。",
              "citation": {
                "source": "貸家を探す話",
                "author": "高田保",
                "note": "青空文庫"
              }
            },
            {
              "text": "大原は外に窺う人のありとも知らず、我家の前まで来りながら急に内へ入らんともせず、「アア詰まらんな、実に詰まらん。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな詰まらんものを生命を賭して長い年月を費して写しに行く人間心理を、作者として検討したら一層面白くはなかったかと、余計な事を考えたりした。",
              "citation": {
                "source": "冬の法隆寺詣で",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "………」「さあ、………出ても詰まらんもんだから。",
              "citation": {
                "source": "蘿洞先生",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「私はあなたとはとてもくらべものにはならん詰まらん人間でしたから、したがってあなたの注意を惹くこともなかったわけです。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも今度は身を引いた自分に、また一層の憤怒が込み上げて、キョトンと不思議そうに見上げている犬の愚鈍そうな眼を見た途端、息も詰まらんばかりの憎しみと激怒とが私の脳天に衝き上げてきた。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私立の詰まらん学校ですねんけど、絵エと、音楽と、裁縫と、刺繍と、そいからまだ外にも何や、まあそんな風に科ア分れてまして、入学の資格なぞむずかしいことも何にものうて、大人でも子供でも自由に這入れます。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうような塩梅で主人との間は大変｜工合ように行ってましたのんですが、あれは四月の半ば頃でしたか、わたしほんの詰まらん事で学校の校長さんと喧嘩してしまいました。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたは入り口で詰まらんことにこだわってしまってるんだ」三　不死身　その二日後、ポワレとミショノー嬢が植物園の人けのない遊歩道のベンチで日差しを浴びて坐っているのが見られた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はつまらん奴を仲間にいれたなあ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまらんことにもすぐ焼餅を焼くのは、女の癖さ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お光が淋しく、Ｔ「つまらん役ね」　と云われて仲蔵も淋しそうに溜息ついた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イヤとてもお話にもなんにも……」　これが河田翁持ち前の一つで、人に対すると言いたいことも言えなくなり、つまらんところに自分を卑下してしまうのである。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまらん奴と逢ったなあ。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまらんものを書いて、佳作だの何だのと、軽薄におだてられたいばかりに、身内の者の寿命をちぢめるとは、憎みても余りある極悪人ではないか。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つまらん事を言ってはいけない。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なんだ、身の上話はつまらん。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「よせ、そんなつまらんことを。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふつうのつまらん鳥と、すこしもかわらんではないか。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
