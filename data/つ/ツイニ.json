    "definitions": [
      {
        "index": 1,
        "gloss": "finally",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "扨、我々は、斯かる時にも猶環境の詮議を遂に女々しいことであるとした古人の考へに従ふべきであらうか？",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし遂に、ストイシズムは詩を生まない！",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "窮地に陥つた校長は、遂に如何にすべきか、文部省迄陳情して来ました。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "コルビエールは遂に当時の趣味には合はなかつた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして文学のことは遂に一言もすることなく、つまり絶えず『文学は滅びるものだ』といふことを繰返すのである。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞紙も何もないので私は遂に諦めて蹲むだけに満足する。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝもうよさう、片附いたのは夕刻だが、それまで絶えずお説教であつたと、いくら云つたつて同じことだし、それらのお説教をたゞたゞ列挙してゐた日には、退屈なために遂には僕の方が少々大袈裟だと思はれまいものでもない。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういへば、ニコニコの底に、なんだかひどく悲しさうな色があつたのだが、また、何か云ひたげで遂に云はずじまひであつたが、人の悪口を云つてはならぬものとばかりに、相変らずの気持であつたのだらうと、幾分不憫でもあつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "語りたくないのではない、語らうにもどうにも手の附けやうがないから、遂には語りたくなくなりもするのである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはずつと後々までも、彼の自殺の直前までも、遂によく解くことのできなかつた、或る恐ろしい意味をもつた「神祕の謎」であつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして遂に自分は言つた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも遂に何物も、何物の自由も自分には絶望であつたといふことを、悲しい沈鬱の語氣を以てかき口説いた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女ははじめにはそれを少々心の中で笑つてゐたのだが、遂にはそれを信じたらしかつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに芸術とは、自然と人情とを、対抗的にではなく、魂の裡に感じ、対抗的にではなく感じられることは感興或ひは、感謝となるもので、而してそれが旺盛なれば遂に表現を作すといふ順序のものである。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "訝かつても自分に殆んどない要素である故遂に推察出来ず、疑心悪鬼を生じ、芸術家を憎むに到る。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長はそれを聞くと初め一寸は危惧の念に駆られたが、「なあに課業の妨げにはなりませんよなあに」と大きい声で云はれてる中遂に承諾せざるを得なくなつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は校長の権威のために、道場の方には我不関でゐようと考へてゐたのに、遂に昼食時間道場の方に足を運んだ。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで月末には吃度数人の被解雇者を見るといふ現象も、遂には此の会社の常習となつてしまつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした歌詞本位的流行歌曲の進む所は、結局遂に「アメリカ式掛合万才」の全盛時代になるであらう。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした彼の郷愁は、遂に無限の時間を越えて凧きのふの空の有りどころ　と、悲しみ極まり歌い尽さねばならなかった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈迦はその同じ虚無の寂しさから、森林に入って出家し、遂に人類救済の悟道に入った。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "願くは我れを蹈みつけ侮辱し唾を吐きかけまた床の上に蹴りきびしく苛責しああ　遂に――わが息の根の止まる時までも。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は東寺に先祖の一海和尚の墓に参って、室戸岬の荒涼で雄大な風景を眺めたり、昔この港の人柱になって切腹した義人の碑を読んだりしたが、残念ながら鯨は滞在中遂に一匹もとれなくて、ただ珍しい恰好をして五色に彩色された鯨漁船を手帳にスケッチしたりしただけであった。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "静岡にて乗客多く入れ換りたれど美人らしきは遂に乗らず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年の年月を過し、遂に石垣島を陥し入れたのは、つい旬日前のことであつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして人民は皆「王が石垣島を占領した功に誇り、慢心を起し遂にこんなになつてしまつたのだ」と口々に言つて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお爺さんの踊りも、あまりにどうも意氣込みがひどすぎて、遂に完全の失敗に終つた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは逆廻りといって、道者は忌むのだそうで、案内者をもって自任する荷担ぎの男は、私から右の水引と朱印を取りあげて、遂に返してもらえなかった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが遂にアブばかりでなかった、石楠花の甘ずっぱい香気は私を包み、アブを包み、森に漂って、樹々の心髄までしみ透るかのように、私までがアブの眷属になったかのように。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の波紋が遂に汀に達すると、そこに浮いている木の葉や板片が動揺し少時してまたもとの静平に復する。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
