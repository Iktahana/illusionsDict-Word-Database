          "literary": [
            {
              "text": "日露の間の戦雲がだんだんに急を告げて来た。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝露の間は子供に書を教え、それから日々夫婦で労働して居るそうだ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これアフガン争論のつねに英露の間に絶えざるゆえんなり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "きらきら光る露の間を幽霊のように鹿が歩いている。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
