    "definitions": [
      {
        "index": 1,
        "gloss": "increase (in an amount of money or goods)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自由化に向けた業界再編以降も、グループを組んだ東芝と提携先のハネウェルとの意見調整に手間取った日本電気は、累積赤字を積み増していった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その魂を、遠くから来て鐘の音は、柔かにあたたかくつつみました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、たくさんのダイヤモンドだの、ルビーだの、難破船の荷物だのを、つみました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、忘れないで、少し残っていた食べ物もつみました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリ・ババは、ふるえながら、兄さんの切りきざまれた肉を、一きれずつていねいによせあつめて、二ひきのろばにつみました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、あとの一ぴきは強い小さな黒馬でしたが、これには金貨の袋を二つつみました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついすぐそばの花をひとつ手につみました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「最後にころんだ時は、生あたたかい恐竜の息が私の体をつつみました。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おどり子は王に耳打して油あげを沢山買はせて勇士の後の方へつみました。",
              "citation": {
                "source": "おどり子の出世",
                "author": "槇村浩",
                "note": "青空文庫"
              }
            },
            {
              "text": "左膳は手早く壺にすがりをかぶせ、古金襴の布にくるみ、箱に入れて、風呂敷につつみました。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで紫のスミレを二つつみました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女の子はその足をもらって、だいじに布につつみました。",
              "citation": {
                "source": "七羽のカラス",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにをつつみましょう、私は七名の側女を置いておりました。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十面相は、かくれみののポストを、五センチほどにちぢめてしまうと、ポケットに入れておいたふろしきで、もとのようにつつみました。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを古新聞で、いくえにもつつみまして、物置きのがらくたの中へ、ほうりこんでおくのでございます。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにをつつみましょう。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それっと手下の者ども、総がかりとなって、相手の浪人を蔽いつつみましたが、その者の膂力絶倫で、当れば当るほど猛気を加え、如何とも手がつけられません。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
