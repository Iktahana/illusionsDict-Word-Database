    "definitions": [
      {
        "index": 1,
        "gloss": "to break through",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "正宗氏と鍋井氏の絵を見ると、かなり熱心に自分の殻を突き破る事に努力しているという事が感ぜられる。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを突き破るだけの強さを持たない私はせめてはそれを避けたいと念じていたのだ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は突き破るような勢いで、玄関の扉に手をかけた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は突き破るやうな勢ひで、玄関の扉に手をかけた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの障害は自分の説によつて突き破ることは出來ないものであらうか。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛が來て戸や障子を突き破るとかで、小屋の周圍には柵が作つてある。",
              "citation": {
                "source": "烏帽子山麓の牧場",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより外に私は現在の沈滞した生活を突き破る方法が無い。",
              "citation": {
                "source": "突貫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "批評が、印象の単にインターサヴジェクティヴにすぎぬ客観性を如何に突き破るか、又、これを突き破って普遍必然性を齎し得るような批評の処方は何であるかという、あの問題だ。",
              "citation": {
                "source": "所謂批評の「科学性」についての考察",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "事實は意識に内在的でなく、却て意識を突き破るものである。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "行爲の立場は、これを徹底するとき、意識の立場、從つて觀念論的立場を突き破る。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "此点を突き破ると、国語・国文及び、日本神道の研究も、変つて来ると思ふ。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのもやもやしたものを突き破るように、敏子は言いました。",
              "citation": {
                "source": "旅だち",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚妄と真実との累々たるカラクリのあとに築かれた古い習慣を正しく突き破るためには、かやうに習慣的な「からさ」だけでは不足すぎると私は考へる。",
              "citation": {
                "source": "悲願に就て",
                "author": "――「文芸」の作品批評に関聯して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "このままでいると、天井を突き破るおそれがあるので、私はハッとして頭を下げて、再びドカリと坐った。",
              "citation": {
                "source": "蠅",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚妄と真実との累々たるカラクリのあとに築かれた古い習慣を正しく突き破るためには、かように習慣的な「からさ」だけでは不足すぎると私は考える。",
              "citation": {
                "source": "悲願に就て",
                "author": "――「文芸」の作品批評に関聯して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある限りの力を搾って、堰き止めるものと突き破るものとが、ごった返してる渦巻きのうなりが、ごーう、ごーう………と秋子の喉から洩れてきた。",
              "citation": {
                "source": "幻の彼方",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "テスト・パイロットが音速の壁を突き破る時にも上昇のために下降の桿を押すという理論的にでたらめなことを決行する勇気が必要であった。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛が来て戸や障子を突き破るとかで、小屋の周囲には柵が作ってある。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩倉、大久保、木戸らの柱石たる人々が廃藩置県直後の国を留守にし三年の月日を海の外に送っても成し遂げることのできなかったこの難関を突き破るために、時の政治家はあらゆる手段を取りはじめたとも言わるる。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "この嚢を突き破る錐は倫敦中探して歩いても見つかりそうになかったのです。",
              "citation": {
                "source": "私の個人主義",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にそれができなかったのは、学問の交際が基調を構成している二人の親しみに、自から一種の惰性があったため、思い切ってそれを突き破るだけの勇気が私に欠けていたのだという事をここに自白します。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこの牢屋の中に凝としている事がどうしてもできなくなった時、またその牢屋をどうしても突き破る事ができなくなった時、必竟私にとって一番楽な努力で遂行できるものは自殺より外にないと私は感ずるようになったのです。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "産室のほうから、それこそ、天地を突き破るかと思われるような、力みのある産声が聞えて来た。",
              "citation": {
                "source": "キャラコさん",
                "author": "新しき出発",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『その種子は、私たちがそれを金翅にやると、金翅は中の核を取り出さうとして、殻を嘴で突き破るあの粒の事でせう。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "通俗文学と純粋文学との区別もあるが、之を例えば偶然性を用いるか用いないか、必然性がないかあるか、というような区別を通って明らかにするとしても、結局、作品の落ちを既成の常識に求めるか、それとも既成常識を裏がえし又は突き破るか、という区別に帰着する。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽は空のもやの層を突き破ることができないのに、暑さはひどくなっていた。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな声が、八方に聞えて、彼はよけいに戸惑ったが、うしろから、「卑怯ッ」　と、よぶ丈八郎へ、「後日っ」　と、言い返して、木戸へ、肩をぶつけて突き破るがはやいか、地を躍って、深い闇へ、魔形に似た提げ刀の光を、何処ともなく、晦ましてしまった。",
              "citation": {
                "source": "無宿人国記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは彼女を宥めようとしてみましたが、しかし、なんとしても突き破ることの出来ない、冷たい、毒々しい敵意の壁にぶっつかったのです。",
              "citation": {
                "source": "クロイツェル・ソナタ",
                "author": "KREITSEROVA SONATA",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ウム、外道の夢、醒ましてやる」むずと、襟がみを引き寄せて、打ちすえようとすると、なに思ったか、石念はパッと起って、厨の戸を突き破るようにして外へ逃げ出してしまった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　信仰もなく自信もなく抱ふなどの有ろうはずもない男は通りこしてしまう事の出来ない関所の前につきあたるとあとじさりをも又つきやぶる事も出来ないでただなす事と云えば動かない「死」を声のかれるまでののしってそのあげくは普通より以上にものすごくむごく死の手にとりあつかわれなければならない運命をもって居た。",
              "citation": {
                "source": "どんづまり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
