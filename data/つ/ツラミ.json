    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pent-up resentment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "持って居て一生恨み辛みを云わねばならぬ。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事件がこれ以上の解決を見せなくとも、少なくとも人目を惹く形で我らが刑事捜査局の辣腕を見せつけることになった上、全外国人に教訓として、恨み辛みは本国にとどめ英国の地に持ち込まぬが賢明だということを知らしめることになるだろう。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙に書いてあった恨みや辛みは口へも出さないで、彼女はただ懐かしそうな笑顔で男と向き合っていた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "６日　朝　澄んだ心のなかには、偏見や恨み辛みが居着けるような場所はどこにもない。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "15日　朝　わかりさえすればいい、人の恨み辛みなんてものは、その心の平穏や安らぎといったものを殺し、自分を傷つけ、他人を助けもせず、ひとりの同胞も励まさないのだと。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "巫女　いやみ、つらみや、怨み、腹立ち、怒ったりの、泣きついたりの、口惜しがったり、武しゃぶりついたり、胸倉を取ったりの、それが何になるものぞ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤコブ、ヨハネ、アンデレ、トマス、痴の集り、ぞろぞろあの人について歩いて、脊筋が寒くなるような、甘ったるいお世辞を申し、天国だなんて馬鹿げたことを夢中で信じて熱狂し、その天国が近づいたなら、あいつらみんな右大臣、左大臣にでもなるつもりなのか、馬鹿な奴らだ。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おッ母さんだッて、あたいから言えば、承知するに定まってる、わ」　僕は、女優問題さえ忘れれば、恨みもつらみもなかったのだから、こうやって飲んでいるのは悪くもなかった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれ幾ら體が弱つたつてあら位な小わつぱにやまあだ自由にされねえ積だから」「そんなに怒つて騷がねえたつておすがことせえ貰へば怨みもつらみもあんめえ。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はきのうも八橋から呼び出しの手紙が来て、いろいろの恨みつらみや愚痴が長々と書いてあった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は胸に抑えあまる恨みつらみをいい出すには、心があまりに震えて喉がかわききっているので、下くちびるをかみしめたまま黙っていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母の手紙はいつでも恨みつらみで満たされていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恨みつらみを云うような、ケチな野郎は一人だってありゃしねえ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "恨みつらみをいうようなけちな野郎は一人だってありゃしねえ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつらみんな、紳士」　と、非論理的な説得を試みる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつらみんな悪党だからよ。",
              "citation": {
                "source": "首頂戴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨折り損のくたびれもうけです」　四馬剣尺が、どっかと腰をかけた頭目台の前へいって、この山塞の番頭格の木戸が、うらみつらみをのべたてた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはよいことだと弁信さん、あなたも賛成なさいますから、あなたを信じて、ここへこうして三日目になりますけれど……」　ここでも、お雪ちゃんが、弁信の株を奪って、一息にこれだけの恨みつらみを述べたててしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが「よる夜中でも、いい塩梅に寝付いたから疲れを休めようと思って、ごろりと寝ようとすると」揺り起しては豊志賀、「私が斯んな顔で」とか「お前は私が死ぬとねえ」とか怨みつらみのありったけを並べ立てる。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに　こいつらみんな　ちょびひげサミュエルの　ししそんそん　――　子どもに　まごに　ひまごまで。",
              "citation": {
                "source": "ちょびひげサミュエルのはなし",
                "author": "まきまきパンのまき",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれア伊賀の源三郎に、なんの恨みつらみもねえ痩せ浪人。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――『おれ→あの女は１　やつら→あの男は２』――ほほう、こうしてやつはパイをよろしくしたわけか、ほれ……」「でも続きに『あいつらみんなもどる　あの男→おれへ』って。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜太郎は、あの娘に逢ったら、いきなり胸の囲みの中へとりこみ、今迄の、うらみつらみ、うれしさも悲しさも、何もかもいっしょくたに叩きつけ、人形のような、あの脆そうなからだを腕の中で押しつぶしてやるつもりだった。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはなんでしょう」「手紙らしいわ……ながいあいだ書きためた、うらみつらみの恋文、てなもんでしょう」　愛一郎は、うたれたように、はっと顔を伏せた。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことを、今のやつらみたいに、いちいち気にしなかつたんだ。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつらみんなつかまえておくれ」　おばあさんのこう言うのを聞いて、わたしはとにかく自分にも罪がある。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "恨みつらみを無言のうちに思い知らせようとしているとしか思えない。",
              "citation": {
                "source": "鈴木主水",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "一宿一飯の恩があるので、怨みもつらみもねえお前さんに敵対する、信州沓掛の時次郎という下らねえ者でござんす。",
              "citation": {
                "source": "沓掛時次郎　三幕十場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経は荒れすさび、彼は、自分の志望を邪魔したと信じる宮内大臣パッカリングに手紙を送って、怨みつらみのありったけを述べた。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたずら好きの首藤がこさえた日頃の怨みつらみもあってか、いつしか首藤は太田一派から目の敵にされ……「これやからよそ者は好かんちゃ、偉そうにしくさってから」　話し合いの終わり近く、太田はそう吐き捨てた。",
              "citation": {
                "source": "湯けむり",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
