    "definitions": [
      {
        "index": 1,
        "gloss": "child from a previous marriage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "連れ子のあることは、安二郎に子供の出来ないことを見越して、あらかじめ勘定にはいっていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、お君の連れ子の豹一がしっかり者であれば、娘の中で、一番きりょうの悪いのを嫁にやってもいゝと考えていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "盲人の連れ子の忠一と本家の一人息子の弥太郎とは、いわば乳兄弟である。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この問題のご婦人、聞く限り実の子、あなたの連れ子、どちらの子にも手をお上げのようですが。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの連れ子には叩くだけ。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤子への奇行と、連れ子へ手を上げたこと、これらは同時期のことでは？",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのも、あなたの連れ子への愛の深さは重々承知、そのことであなたの心を傷つけては思ったのです。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれの親父と令子のおふくろが離婚して、あいつは母親についていく」「令子ちゃんは……」「連れ子ってやつだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「道さん」などと馴々しく而も幼名を以て余を呼ぶ者は外に無い、幼い時から叔父の家で余と一緒に育てられた乳母の連れ子で、お浦と云う美人で有る、世間の人は確かに美人と褒め、当人も余ほど美人の積りでは居るけれど、余の目には爾は見えぬ、併し悲しい事には此の女が余の妻と云う約束に成って居る。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪美人は決して乳婆などの連れ子ではない。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、このあわれなる靴屋は、自分の姉及びその連れ子を自分の家に引き取り、やせ腕一本でもってその姉を養い、また三人の甥と姪（ロイド・ジョージの父がなくなった時、母は妊娠中であった）とを育て上げ、彼自らはついに独身生活を貫いた。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の娘たちには守が骨を折って婿選びをし、結婚をさせているが、夫人の連れ子の姫君は別もののように思って、なんらの愛情も示さず、結婚について考えてやることもしないのを、妻は恨めしがっていて、どうかしてすぐれた良人を持たせ、姫君を幸福な人妻にさせてみたいと明け暮れそれを心がけていた。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんの連れ子があるなどとは少しも知りませんでした。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は母の連れ子になって、この父と一緒になると、ほとんど住家と云うものを持たないで暮して来た。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "六つになる三郎と云う連れ子があった。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「問はず語り」においても後篇において老画家は妻君の連れ子の雪江と関係を結ぶが、その淫蕩に諦める如くたゞ田舎へ去り、雪江の情夫の音楽家また呆れて逃避して老画家と田舎で落合ふなどと馬鹿げたことばかり、人倫の発展を身を以て究めやうとする根本的な作家精神が欠如してゐる。",
              "citation": {
                "source": "通俗作家　荷風",
                "author": "――『問はず語り』を中心として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタズラしそうな奴といえば女房の連れ子｜箱王ぐらいのものだが、奴め剣術の稽古は無類に好きとはいえ、まだ十一の子供。",
              "citation": {
                "source": "曾我の暴れん坊",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "――居候・やっかい者・まま子・連れ子・ひねくれ・ぐず・お世話・ご恩・真人間……言うほうはなんでもない当たりまえのように使っている言葉。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "中橋がわずかの仕送りを与えて細々と暮しをたててやったも道理、一度は彼の妻たりし小蝶、連れ子のヤスは中橋を父とよんだ幼い時期もあったわけだ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は賢くなつて、二度と逆ひはしなかつたし、その頃の高瀬の家は、先妻の子が四人のほかに、継母とその連れ子がゐる家庭とは、とても見えぬほどの和やかさがあつた。",
              "citation": {
                "source": "母たち",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親が妻の連れ子と関係をつけたと云うて、大喧嘩を始める。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はあい子の実の父ではなくて、あい子が七つの時にお母さんの連れ子でかたづいて来たそうです。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの清五郎さんといふ人は、本當はお内儀さんの連れ子だつたさうです」「さうか、道理で變なことがあると思つたよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの門太郎さんは、朝田屋の亡くなつた主人の先妻の連れ子でございます――朝田屋の後添の娘お縫さんとは、兄妹と言つても他人だから、二人を一緒にしてくれと、父親の生きて居る頃頼んださうで御座いますが、血の繋がりはなくとも。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "水垢離",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前さんは、主人と本当の兄弟ではないそうじゃないか」「私は父親の後添の連れ子で、兄弟は兄弟でも、兄の七郎兵衛とは義理のある兄弟になっております」「長崎ではいっしょに働いたというが――？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "和蘭の銀貨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちヘロデヤのために好機到来、ヘロデ王の誕生祝いの座興として己の連れ子たる少女を踊らせ、それに対する褒美として洗礼者の首を求めさせました。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分」「どんなことがあつたんだ」「越前屋の後添の連れ子で、手代のやうに働いてゐる福松といふのが、昨夜兩國橋の上から大川へ投り込まれたんです」「死んだのかい」「死にはしません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お吉お雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "先の内儀は、お吉お雪の二人の娘を遺して早く亡くなり、後添のお國は連れ子の福松と一緒に入つて、十年前から世帶を切盛りしてをります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お吉お雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "連れ子の福松は一寸意氣な男で、辯舌も才智も相當。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お吉お雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉のお吉の縁談のことは何んにも知らず、たゞお吉は氣位が高くて、手代の吉五郎も、繼母の連れ子の福松も相手にしなかつたといふだけは確かのやうです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お吉お雪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
