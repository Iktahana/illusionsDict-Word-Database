        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こうした貢献は間違いなくあるにしても、書かれている中味を本という形に縛り付けて取り扱っている大本のところに、積み残した問題があるように思います。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大工は十本の柱を、こさえ上げてしまうと、今度は車に積み残してあった材木を下しにかかった。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しいビジネスチャンスを貪欲につかみにかかる過程で、西はいくつかの問題を積み残しもした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと思い出した、七時発上り列車は買い出し客が多く、ときどき積み残しがあるとの噂を。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "積み残しのあるほどの人出だったら一分か三分は遅れるはず。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は往復切符をもっていたので、一人で先きに立って来てみたら、青森では一人の積み残しもなく、全部船に乗れた。",
              "citation": {
                "source": "流言蜚語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧がほとんど山のすそまでおりてきて、わずかにつつみのこした渚に、ほのかに人里があるのである。",
              "citation": {
                "source": "河口湖",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
