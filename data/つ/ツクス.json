[
  {
    "uuid": "626c8ba4-e49d-5fd7-917d-1cfeb2068c52",
    "entry": "尽くす",
    "reading": {
      "primary": "つくす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
