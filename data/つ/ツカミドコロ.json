  {
    "uuid": "344dfd20-aee2-5bd1-820e-c7d549a97123",
    "entry": "つかみ所",
    "reading": {
      "primary": "つかみどころ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
