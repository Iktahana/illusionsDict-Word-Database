        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いきおいヨコ組みが中心になると思うが、そうなったとき、あくまでもタテ書きを前提にデザインされた明朝体のままで突っ走ることができるかどうか。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」笹村の声がまた突っ走る。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事が起ったのか、と、運転手の Casey が狼狽てて制動機を絞ると、トニィは突っ走るような声を弾ませて、「手が見えたんだ。",
              "citation": {
                "source": "土から手が",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "慄然として背筋には冷い惑乱が突っ走る。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂塵を巻いて突っ走る。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろをふり返りふり返り走るのもあり、頭もふらず突っ走るのもある。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "この乾雲は汝の坤竜にこがれてどこまでも突っ走るのだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "幽霊じゃあなかったな」「おきやがれ、面白くもねえ」「どろんと一つ、用いやがったかな」「伊賀流の忍術じゃあるめえし」「まだ遠くへは突っ走るめえぜ。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "突っ走るような初太郎の声で、四十余りのでっぷりした男が、すぐ蒲団を蹴って起きて来た。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "宙に浮く屍骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんぼ朱総が嫌えだっていわば蝉の脱殻だ、そいつを担いで突っ走るがものもあるめえに。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "槍祭夏の夜話",
                "note": "青空文庫"
              }
            },
            {
              "text": "「灯りだ」　主人岩太郎の声が、突っ走ると、一度家の中に入ったお角は、手燭を取って庭へ戻って来ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "春宵",
                "note": "青空文庫"
              }
            },
            {
              "text": "内側にえぐれこんでいる波の壁に向きあい、必死で突っ走る。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんの容赦もなく轟々と突っ走るサーフに、僕にとっての足がかりはまるでなかった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "他は時々傍目もふらずに突っ走る朝鮮の競馬上り。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "出発はゆっくりだったのに、なぜ危険を冒して突っ走るんだ？",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "サーカスへ乗り着けた車は最高時速百キロで突っ走る代物だ。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "モンタギュ卿なら直ちに車を手配して、急行列車より早く、道を突っ走るだろう。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても夫の不名誉な行為をなじるとは」第八章　非常手段　馬車がエレンを乗せて暗闇を突っ走る先にブルース卿宅が有り、立派な田舎風建物はエレンの家から八キロばかり離れていた。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "平坦で単調な田舎を突っ走ると、夜のとばりが降り、あたかも文明が消えたかのよう。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "家は火口のように燃えるでしょう」「どうする、デントン」「車で突っ走るしかありません。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとそばへいって、わたしが目利きをつけてきましょう」「これッ、よけいなとこへ突っ走るな」「へい！",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "声は、まるでトンネルをつっぱしるように、長屋のはしからはしへピーンとひびいてゆく。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
