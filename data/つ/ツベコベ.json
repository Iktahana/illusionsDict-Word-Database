        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "俺もこうやってはいるがいざとなればそのくらいの工面はつくから、苦しいながらあちこち世話をやいてやってみると、そんなところから金を出してもらうのは嫌だとか何んとか、つべこべいいくさる。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老女　――相変らずつべこべとうるさい奴等だ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、けふはいくら歩き探しましても、この犬のほかには……」「ええい、つべこべいふな。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼前にワルトンのつべこべとアイリスに取り入る態度を見てはジョーンの血はたぎった。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だつべこべ、惚れたがどうしただ、家で知つたちゆて添はずにやをかねえだ、世間が何だんべ。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "屁理窟ばかりつべこべと並べやがって。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに思いきって不仕合わせな人はこんな事をつべこべと口になんぞ出しはしませんわ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをつべこべろくろくあなたの世話も見ずにおきながら、いい立てなさるので、筋が違っていようといって聞かせて上げたところだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は……　芦田――今になって、つべこべ余計なことを言うな。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "調子につられて、つべこべとどろ吐きやがって――おれをだれと思ってるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の殺されているのはいいとして、どこで本人が殺されているのか、肝心の方角をいわねえんで、だんなだっても急ぎようがねえんだよ」「つべこべと揚げ足取るなッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうでごわす、拝みに参りましょうか」　つべこべと口早にしゃべるのを聞きながら、じっと目を閉じて、何ものかをまさぐるように考えていましたが、と、突然右門がすっくと立ち上がりながら外出のしたくにとりかかったので、伝六は早がてんしながらいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の苦労も知らねえで、こんなにつべこべといっていたんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴樣こそ小僧の癖に、人の帶を蹈んどきやがつて何をつべこべ理窟を垂れやがるんでえ。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃は一向イタチの道で、いや、一向五丁町へお越し遊ばされませぬが何か――」「つべこべ申すな！",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だ理詰めの詫びと思うが、それにても馬のせいに致したは御勘弁ならぬと仰せあるかな」「つべこべ長談義申さるるなッ、われら、そのような屁理屈聞く耳持たぬわッ。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だ理詰めの詑びと思うが、それにても馬のせいに致したは御勘弁ならぬと仰せあるかな」「つべこべ長談義申さるるなッ、われら、そのような屁理屈聞く耳持たぬわッ。",
              "citation": {
                "source": "旗本退屈男",
                "author": "第五話　三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなにつべこべといろいろなことをいえば、よけい恥ずかしくなるじゃないか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "つべこべと、あの時はああだつた、それはかうだつたと……いやはやもう、何時のこととも分りもしない話を、思ひ出し思ひ出し、ならべ立てること、ならべ立てること。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、何の煙草どころか、つべこべと話に夢中で一服として満足に喫つた者はない始末。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座になって面白う遊ばんせ」「ええ、つべこべとさえずる女め、おのれら売女の分際で、武士に向って仮りにも兄嫁呼ばわり、戯れとて容赦せぬぞ」　彼は扇をとり直して、女の白い頬をひと打ちという権幕に、そばにいる女どもも、おどろいてさえぎった。",
              "citation": {
                "source": "鳥辺山心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「初めはつべこべと誤魔化そうとしたから、あの晩、いや朝のあいつの行動を正確に話してやったら、図星を指されたと見えて、とうとう兜を脱いだよ。",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "つべこべ云わずと早く逢わせろ！",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『牝犬どもめが、つべこべと嘘八百を並べやがつて！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "一言も、つべこべいうな、許さねえ。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそいつらには品がなくてしょっちゅうドルのことしか頭にないのだ〔欄外に〕スタンダールのアメリカ「赤と黒」「選挙のために靴やにつべこべするアメリカ」という風p.82　しかしおれは味もそっけもないアメリカ人の良識ってやつは大きらいだ。",
              "citation": {
                "source": "「緑の騎士」ノート",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を、つべこべ、講釈を披げるか？",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "かご屋、はき物を――」「何をつべこべ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つべこべいうと、どてっ腹に風穴をあけるぞ」「へい、へい、やりますよ、やりますよ、何も海まで運ばないというんじゃありませんやね」　フランソアもラルサンも親分格のモレロにかかると、まるで赤ん坊だ。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
