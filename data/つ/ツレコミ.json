    "definitions": [
      {
        "index": 1,
        "gloss": "taking one's lover to a hotel",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから自動車に乘せて家へ連れ込み、金庫をあけて有りつたけの札束をすつかり相手にやつてしまふ。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "有頂天になった老画家は、思わず娘と一緒に若い画家を画室の中へ連れ込みます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちへ来い」　と云ううちに、無茶先生は豚吉とヒョロ子を連れて奥の手術場に連れ込みました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は自分の左脇にかかえるようにしてツネちゃんを療養所に連れ込み、医務室へ行った。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに於て、わたくしも、本気に心配し出しまして、葛岡を急いで倶楽部内へ連れ込みました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしが擬態で示す愚かしい返事に、われ指導するに堪ゆというような特別な好感を持ったらしく「おとなしくするんだぞ、こっちへ来い」と言って彼は棲家の橋の下へ連れ込み、そこで先ず物を食べさせて呉れました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ寺の境内に連れ込み、新太郎の横面を殴りつけた勢いで、初枝の顔にも手が行ったが、折角の髪をつぶしてはと、この方はさすがに力を抜いて、他吉の眼がさきに火が出るくらい、情けなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "表向き料理店だが、その実連れ込み専門の貸席旅館だから、女を連れずに来る男もいなかったわけだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "福岡にしては何だか近過ぎるようだと思いながら、そのまま一緒に汽車を出ると、男は人力車を呼んで来て、わたくしを町はずれの薄暗い料理屋へ連れ込みました。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、博士が丁度留守だったので、早速、令嬢を研究室に連れ込み、手術台の上に仰臥させた。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "辿り着いた先の戸を開けて、入ってすぐの部屋へ連れ込みました。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇二は先ず塚田の奥様を金造の家へ連れ込み、その明くる晩に文次郎をさそい出して鈴ヶ森で殺してしまい、文次郎から百両の金を奪い取った上に、奥様を東海道筋の宿場女郎に売り飛ばすという、重々の悪事を企んでいたんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "その様子がいつもと違っているので、智心もそっと後を尾けて行きますと、お歌は俊乗を森のなかへ連れ込みまして、お前がこの寺にいては思うように逢うことが出来ないから、いっそ還俗するつもりで私と一緒に逃げてくれと云う。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "有り合わせの薬を飲ませて介抱して、ともかくも奥へ連れ込みまして、表向きは死骸紛失ということにお届けを致させました」「お歌はそれからどうしました」「日が暮れてから気分も快くなったと申しますので、裏山づたいに帰してやりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ時間がありますから……」　と落ち着いた声で仰言って、私の手を引かんばかりにして正面の階段を昇って、二階の廊下のズッと突き当りの空いた教室の片隅に、私をお連れ込みになりました。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに大勢の舞姫は踊りながらだんだん二人へ近寄って来て、手に手に二人を舁ぎ上げたと思うと、そのまま踊りをやめて雪の塔の中へ連れ込みました。",
              "citation": {
                "source": "雪の塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "西の方には夕日が光っているのですから、大したことはあるまいとは思いながらも、丁度わたくしの家の路地のそばでしたから、兎もかくも些とのあいだ雨やどりをしてお出でなさいと、相手が辞退するのを無理に誘って路地のなかにあるわたくしの家へ連れ込みました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし休息するがよい」　ひとりの男が彼をまた案内して、奥まったひと間へ連れ込み、一旦は扉をしめて立ち去ったが、やがて食事の時刻になると、立派な膳部を運んで来てくれた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "池北偶談",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし根岸の家に隠して置くのは剣呑で、菊園の追っ手に探し出される虞れがあるので、すぐに玉太郎を白雲堂へ連れ込みました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "河豚太鼓",
                "note": "青空文庫"
              }
            },
            {
              "text": "独照は女を庫裏に連れ込み、湿れ徹つたその着物を脱がせて鼠色の自分の着物を被せてやつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「震災後できた大きな料理屋ですの、連れ込みのね……あすこに籠もっていれば絶対安全ですからさ。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かが七歳と四歳になる二人の女の児を雪の深い森へ連れ込み零下十何度という厳寒の中へ裸にして捨てて行った。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "せい子は情夫富岡某を頼つて上京中、あとより向井が呼び戻しに行つたが、せい子が復縁を拒絶した為、十二日風呂へ行くせい子を強迫して、自分の部屋へ連れ込み、またも復縁をせまつて口論となり、かつとなつて、手拭でせい子を絞殺し、自首して出たもの。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故今迄もまたしておいて先生はこんな処に私をお連れ込みになるのだらうと思ひますとＴ先生に、腹がたつて来るのでした。",
              "citation": {
                "source": "嘘言と云ふことに就いての追想",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "――推摩居士に兆候が現われたので、盤得尼と浄善が夢殿の中へ連れ込み、盤得尼は油時計に、零時の目盛まで油を充たして点火し、夢殿を出たのが零時五分。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あらかじめ企んだものと見え、道場の前へ差しかかりますと、ご門弟衆バラバラと立ち出で、無理｜無態に私を連れ込み、是非にと試合を望みましたれば……」「おおさようか、是非に及ばぬの……噂によれば近藤、白井、山田等という門弟衆を、苦もなく打ち込んだということだが？",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "連れ込み専門の家ではないとしても、とにかく割烹旅館、志村がよく泊ってくるという家に、婦人を誘ってフグ茶を食いに行くとは、いささか穏当ではなかった。",
              "citation": {
                "source": "無法者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリイ・シェイケビッチ夫人のプルウストに就いてのクロッキによりますと、病弱の彼も然し却々の勇み肌で、あるとき夫人をさらふやうにしてシロといふ料理店へ連れ込みました。",
              "citation": {
                "source": "かげろふ談義",
                "author": "――菱山修三へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして先だってお宮の連れ込みで行った、清月という小さい待合に行ってお宮を掛けると、すぐやって来た。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り少女歌劇もなく、芸者の連れ込みもなく、静かなこともこの上なしである。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
