    "definitions": [
      {
        "index": 1,
        "gloss": "that is to say",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "或る科學の大家に其の弟子の一人が「仕事が行詰まりになつて困つた時はどうすればいゝでせう」と聞いたのに答へて「Do something なんでもいゝ。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の健康の行詰まりには此度の伊香保がサム・シングであつたのである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の行詰まりを救ふサム・シングを世界中の爲政者や思想家やが試みてゐるが、此の利目は未だわからないやうである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、性急な批評家の或る者は氏の芸術の硬化や、行き詰まりを云為してゐる。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうしたらあの気詰まりな丸善も粉葉みじんだろう」　そして私は活動写真の看板画が奇体な趣きで街を彩っている京極を下って行った。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくもあるところまで進んで来て行き詰まりになっている考えに新しい光を投げ、新たな衝動を与える何物かを発見する事は決して珍しくはあるまいと思うのである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はアインシュタインやド・ブローリーがルクレチウスを読んだであろうとまでは思わないが、彼らの仕事に最初の衝動を与え幾度か行き詰まりがちの考えに常に新しい活路を与えたのは、私に言わせれば彼らの頭の中にいるルクレチウスのしわざである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろそういう研究を奨励することが学問の行き詰まりを防ぐ上に有効でありはしないか。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう時代において、それ自身だけに任せておくととかく立ち枯れになりやすい理論に生命の水をそそぎ、行き詰まりになりやすい抽象に新しい疎通孔をあけるには、やはりいろいろの実験が望ましい。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在世界じゅうの学者が争って研究しているような問題が、やがて行き詰まりになるであろうということは当然の事でもあり、また過去の歴史がことごとくこれを証明しているように思われる。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう改まってお尋ねになりますると、実はお答えに詰まりますようで……ヘヘ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "則ち今度の土地解放なるものが毫も小作人の現在組織の行詰まりより来る痛切なる自覚せる欲求に基づいて手放され獲得したる結果でなく、温情的に与へられたる土地であるのだから、彼等旧小作人は其の土地解放の精神を忠実に実行して漸次其の範囲を拡大して行く如き事は迚も難い様に思はれる。",
              "citation": {
                "source": "狩太農場の解放",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本当面の非常時、政治的不安や経済的行き詰まりにいよいよ恐慌を増して来ましたこの頃では、金融は全く逼塞してしまいましたので、日本の大多数の人々は、その命つなぎの金にさえ不自由する有様に立ち至っております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「詰まりはそれだけのことで、ほかにはなんにも手がかりはねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど商売が行き詰まり、母の手元は苦しかったが、それはその時々の食糧や小遣になる零細な金で、銀子は月々の親への仕送りで、いつも懐ろが寂しく、若林からもらう金も、大部分親に奉仕するのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の事を自然の順序に考えて行くと、万事が否定的のフン詰まりになるという、実に不可思議な玄理をあらわした形です。",
              "citation": {
                "source": "夫人探索",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "このアンバイでは俺が兼に十円借りていたに違いないと思い思い薬の袋を破ってみますと、赤玉だというのに青い黴が一パイに生えておりまして、さし渡しが一寸近くもありましたろうか……それを一ツ宛、白湯で丸呑みにしたんですがトテも骨が折れて、息が詰まりそうで、汗をビッショリかいてしまいました」「……フーム。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついそんなことで暮にまで押し詰まり、うやむやのうちに先生は東京にいるのも面白くないといって年内からスキーに行かれたのであった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、生くるにも生きられない苦悩に追い詰められ、頸筋を掴えるようにして鼻先を死の世界に分けられたものは、息も詰まりながら、しかし遂に、この暗い世界から何ものかを愛し出さずにはいられないのです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "詰まり忠孝を標準としてのお説ですね。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詰まりさう云ふ人物のする事を原始的に考へて見ると、ロビンソンになるのではないでせうか。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詰まり君は守成者よりは創業者が好きだ。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詰まり 〔e'galite'〕 という思想が根本から間違っているのですね。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "詰まりそれだけの事さ。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウワアッ」　と三好は夢中になって藻掻いたが、白坊主の力は意外に強く、肩先を羽がい締めにして来るので呼吸が詰まりそうになって来た。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまで広からぬ道は片割月の下近く、山畠の傍なる溜池のほとりに行き詰まりつ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが気詰まりと思わるるならば此方、三味線を引かっしゃれ。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその国産品の氾濫も最早、行き詰まりかけているのではあるまいか。",
              "citation": {
                "source": "路傍の木乃伊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――つまり音楽界は盛んであるのだ。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "）それともも少し上等になると、例へばヴィオロンの批評には、「まづ、ボーイングはと……つまりボーイングなる眼点よりしてこの提琴演奏家はと……」といつた具合らしく、発表された批評文恰かも生理衛生の答案みたいなのがあるのである。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
