        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「まあ、いゝから／＼下に坐って落付きなさいってば、ほんとに大きな身体をしている癖に子供っぽいったらありゃしない、この人」　片眉を挙げて慈しみ深く、ころ／＼と笑ってやります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しぶとい人ったらありゃしないよ、何故はいと云わないの、いくらお前さんが強情張ったってだめじゃないの、早くはいと云いなさいよ、いくら厭だと云ったってだめだから、痛い思いをしないうちに、はいと云って、奥様に可愛がられたら好いじゃないの、はいと云いなさいよ」　讓は少年の顔に注意した。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人くらい、高慢で、しかも自我の強い人ったらありゃしないわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、それはびっくりするったらありゃしない。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうにうちの先生くらい、いけ図々しい人ったらありゃしないわよ。",
              "citation": {
                "source": "或る探訪記者の話",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ただのファンなんですけれど、あんなしつこい子ったらありゃしないのよ。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまんないったらありゃしない……。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっさんがね、お前さん、こういうんだよ、いけすかないったらありゃしないじゃないか、ねえ、などと笑いながら、ついて来た女中と喋っているおゆきの話しかたが、六つ七つの女の子の興味をそそった。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "意気地のないがおったらありゃしない」　と、弱く笑いながら寿女の手をかりて横になった。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先刻からみっともないったらありゃしない。",
              "citation": {
                "source": "母親",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父さんみたいにくだらん見栄をはる人間ったらありゃしないよ。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "口惜しいったらありゃしない」「フーム。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとにいい気味ったらありゃしない。",
              "citation": {
                "source": "ニッケルの文鎮",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気味の悪いったらありゃしない。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の悪いったらありゃしない」　お篠は腹立たしそうに、「一体誰なの、お前さんは。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやあね、薄気味わるいったらありゃしない。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「畜生、育ちの悪いがきったらありゃしない。",
              "citation": {
                "source": "果樹",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "畜生、何て野郎だろう、あの女の図々しいったらありゃしない、一つとっちめて遣らなくちゃ――」　立ち上ると一しょに紳士は二人のあとを追掛けようとした。",
              "citation": {
                "source": "夜汽車",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "（甘えて）憎らしいったらありゃしない。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとにまア、トンマな子だったらありゃしない。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "マネキン　芸術だなんて、人間がうまい言葉をつくり出して、そのために、あくせく、命をかけて、馬鹿らしいったらありゃしない。",
              "citation": {
                "source": "鋏と布と型",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "図々しいったらありゃしない。",
              "citation": {
                "source": "少年の死",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（ため息をついて）わたしゃもう久しいこと、お素麺を食べないよ、情けないったらありゃしない。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとにじれったいったらありゃしない」「手放し恐れ入るな。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとに、おかしいったらありゃしないよ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんぼ因業だって、あんな因業な人ったらありゃしないよ。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、怖いったらありゃしない。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "……まったく物騒と云ったらありゃしない。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……全く執拗いったらありゃしない……（左へ退場）女２　（左より）大体、男って横暴すぎると思うわ。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
