        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "脱ぎ捨てられたレヴューガールの衣裳のようだといおうか、それとも、ハンドバッグの中の使い残りの棒紅のようだといおうか。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "使い残りの小材木や根太石も其の辺に積み重ねられている。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜ふとロンパンの使い残りがあったことを想い出した。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "水溜めの木桶にも、使い残りの水がごくわずかしか残っていなかった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは死人のふところから使い残りの一両あまりを探し出して、わずかに満足するほかはなかった。",
              "citation": {
                "source": "放し鰻",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、ここに使い残りの金が、百五十両ばかりあらあ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、ここに使い残りの金が百五十両ばかりあらあ、みんな十二両ずつくれてやって、残ったのは俺がもらっていくんだ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐にはまだ前夜の使い残りがすこしあった。",
              "citation": {
                "source": "雑木林の中",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "持っててお呉れ、使い残りで悪いけど、それだけばち有りゃせんのや。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は外套のポケットから使い残りの脱脂綿を掴み出してその涙を拭いてやった。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "百城が、手を叩こうとするのを「これを――」　と、化粧した使い残りの水を、鉢から、指の先で、硯へ落して「いいえ、妾が――」　百城が、墨をとったのを見て、硯を、自分の方へ引いた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉の外にはまだ洗面の湯がきていなかったので、私は昨日の使い残りの水で顔を洗った。",
              "citation": {
                "source": "日蔭の街",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは、もう今年も残りは二三日となり、いくら焦ってみても、もうどうにもならぬ、――という気持ちが、あの使い残りの二三日をたいへんゆっくり嬉しく感じさせてくれるのだ。",
              "citation": {
                "source": "火葬国風景",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たったそれだけの事でか」「仙之助の行李の中に、石見銀山の使い残りと、少し血の付いた匕首がありました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "十万両の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "使い残りの毒や、血染めの匕首などは行李の中へ入れてしまっておくものじゃねエ」「左様でございます、親分」　この無能な大番頭からは、平次は何の反応も求められません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "十万両の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それには及びませんよ、口開けですから」　東野南次があわてて手を振りましたが、「でも、少いかもしれませんが――」　幽里子はそういって、百円札を一枚、使い残りのレター・ぺーパーの下へ押込むように、身をかえしてヒラリと扉の外へ出たのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "代作恋文",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかには、使い残りの二十八缶があった。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく筆の持てる頃から絵が好きで、使い残りの紅皿を姉にねだって口のはたを染めながら皿のふちに青く光る紅を溶して虻や蜻蛉の絵をかいた。",
              "citation": {
                "source": "折紙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
