        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "空は昨日までの雨に拭はれて、すがすがしく、それは海の方まで続いてゐることが分ります。",
              "citation": {
                "source": "死別の翌日",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いてラフォルグの弁駁が出たが、それには最初の同情の影だに見えず、不正な批評となり終つてゐる。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて、「俺も齢をとつたな……」と、さう思つた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が直ぐに引返さうとすると、女が少し遊んでゆけといふし、それに続いて新しき男が、一寸上れよと云ふから、私は上つたのであつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨はまだ、ひどい勢ひで降り続いてゐる。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "春雨や小磯の小貝｜濡るほど　終日｜霏々として降り続いている春雨の中で、女の白い爪のように、仄かに濡れて光っている磯辺の小貝が、悩ましくも印象強く感じられる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜の花や鯨も寄らず海｜暮ぬ　菜種畠の遠く続いてる傾斜の向うに、春昼の光に霞んだ海が見え、沖では遠く、鯨が潮を噴いてるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外には木枯しが吹き渡り、家の周囲には、荒寥とした畦道が続いている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕合せに晴天が続いて毎日よく照りつける秋の日のまだなかなか暑かったであろう。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから第五、第六の「あたかも」が、未だ続いて挙げられるが、もうその点は打ち切って、私たち同行四人が、シャスタ山に登ったのは、大正八年（一九一九年）九月十一日のことで、未だこの山の草分けを記念するための、シッソンの名が残っていた時分であった。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドーン、バーン、ドドーンー　発破は機関銃のように続いて、又は速射砲のようにチョット間を置いて、鳴り続けた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばある家庭で、同じ疫痢のために二人の女の児を引続いて失ったとする。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無事な日の続いているうちに突然に起った著しい変化を充分にリアライズするには存外手数が掛かる。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると水銀が蒸発して管の中はこの蒸気が充ちその中を電流が通じるようになるから管を旧位置になおし水銀を一端に返しても電流は続いて通る、この時に水銀の蒸気は強い蒼い光を出す。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そして只今、この大地は、四度目に来た冷い時期の、そのまた中に幾たてもこまかく冷温のきざみのある、ちょうどその二つ目の寒さの峠を下り降った根方の陽気の続いている時期にあるのでございます」　まめ桜はひと年の五月に一度咲き、同じその頃、三光鳥はこの裾野の麓へ来て鳴く。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」すぐみんなが、続いて叫びました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその鶴をもってこっちを見てゐる影ももうどんどん小さく遠くなり電しんばしらの碍子がきらっきらっと続いて二つばかり光ってまたたうもろこしの林になってしまひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは続いてどっと笑いました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "凝灰岩が青じろく崖と波との間に四、五｜寸続いてはいるけれどもとてもあすこは伝って行けない。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うの河原は可成広いし滝までずうっと続いている。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "染色の問答に続いて、三馬はこの二人の女に江戸語と上方語との巧みな使い別けをさせている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "大昔には陸地が続いていたのか、それとも氷がつながっていたのか誰に聞いてみても分らない。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "参拝者の来るのが始めのうちは引切りなしに続いてくるが三十分もたつと一時まばらになりやがてちょっと途切れる。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またひとしきりどかどかと続いて来るかと思うとまたぱったり途絶えるのである。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよはいり切らなくなって吐き出し始めたら餅が一とつながりの紐になって果てしもなく続いて出て来たなどという話を聞かされたこともある。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから引続いて『五人女』『一代女』『一代男』次に『武道伝来記』『武家義理物語』『置土産』という順序で、ごくざっと一と通りは読んでしまった。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の一月下旬、北米合衆国で数日続いて広区域にわたって著しい凍雨と雨氷があった。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おんちゃん、おんちゃん、かちあるかい、かち、奈子ちゃんがかちだって」　続いて奈々子が走り込む。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は疲れているんだ」　すぐつづいて太宰が障子をあけてのっそりあらわれた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて、またひとり、三十ちょっと前くらいの美しい人があらわれ、これもやはり、姉でございます、という御挨拶をなさるのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
