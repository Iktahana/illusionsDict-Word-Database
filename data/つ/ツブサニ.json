    "definitions": [
      {
        "index": 1,
        "gloss": "in detail",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まるで女の子が、人形を玩具にするようである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論今の子供たちは、昔の素朴な玩具よりも、科學的玩具に多くの興味をもつのであるから、今の子供等の悦ぶ童話に、多くの科學的武器や機械が出て來るのは當然である。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の何かしら廻り諄い所作の道具に使われて、命を失いかけている小雄鹿を、その男と共に、無駄なことの犠牲になった悲運のものと思うだけだった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人用の烟管の吸口と雁首に附けた金具に、銀と赤銅とを用いて、銀白色の帯青灰色との横縞を見せているのがある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから散々玩具にした揚句に、空腹だとむしゃむしゃと喰ってしまうのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃太郎や猿蟹合戦のお伽噺でさえ危険思想宣伝の種にする先生方の手にかかれば老子はもちろん孔子でも孟子でも釈尊でもマホメットでもどのような風に解釈されどのような道具に使われるかそれは分からない。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそれをもらつた人が、後で自分の机に置くと、普通の平凡なガラクタ道具に變つてしまふ。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならその古机でさへが、やはり彼の居間の中で、彼の家族たちと一緒に、彼の構成してゐる家のアトモスフィアの中でのみ、始めて藝術的に美しく調和するので、單獨に引き離してしまつては、普通の平凡なガラクタ道具に變つてしまふからである。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうへ、大道具小道具に要した金、練習場、會場に要した金、プログラムや切符に要した金、それらは會員達が何ヶ月もかかつて積立てた準備金の到底補充出來る額ではなかつた。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水は今展覽會へ出す畫が繪具にかゝつてゐるので九月號に何か書く筈のところ書けなかつた。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな防寒具にかゝった雪を払い払い彼につきあたって通った。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョアジーは労働者や、労働者や農民の出身である兵士たちを完全に彼等の道具に使おうとして、軍国主義化しようとしている。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして姉も弟も初めのうちは小学校に出していたのが、二人とも何一つ学び得ず、いくら教師が骨を折ってもむだで、到底ほかの生徒といっしょに教えることはできず、いたずらに他の腕白生徒の嘲弄の道具になるばかりですから、かえって気の毒に思って退学をさしたのだそうです。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言はれたので僕は思はず噴飯だし、『それじア道具が釣るのだ、ハ、ハ、……』　ボズさん少しく狼狽いて、『イヤ其は誰だつて道具に由ります。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "道具も永く使い馴らして手擦れのしたものには何だか人間の魂がはいっているような気がするものであるが、この羅宇屋の道具にも実際一つ一つに「個性」があったようである。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はいろいろの骨董道楽をしただけに煙草道具にもなかなか凝ったものを揃えていた。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当世の詞でいうと、最も平民的で、それで江戸らしいのは、きりぎりすに限りますよ」　老人はしきりに虫の講釈をはじめて、今日では殆ど子供の玩具にしかならないような一匹三銭ぐらいの蟋蟀を大いに讃美していた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷泉家の息女と云い触らしてある美しい行者を、かれは自分の色と慾との道具に使っていたのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台にも、寝具にも、その附近すべてに、支那人の変な匂いがしみこんでいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が顔を洗う前足の横側には、毛脚の短い絨氈のような毛が密生していて、なるほど人間の化粧道具にもなりそうなのである。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵のうち人びとが掴まされたビラの類が不思議に街の一と所に吹き溜められていたり、吐いた痰がすぐに凍り、落ちた下駄の金具にまぎれてしまったりする夜更けを、彼は結局は家へ帰らねばならないのだった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この道具になる概念は必ずしも先験的な必然的なものでなくてもよい。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い修練によってそれをすっかり体得した上で、始めて自分自身の考えを運ぶ道具にする事ができる。",
              "citation": {
                "source": "数学と語学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため人形のほうが人間になり、人間のほうが道具になっているのである。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "因果応報の道具にだけこの世に生れて来たような青年です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば高楼より狙い撃たれ、外よりは悪僕二人が打揃いて入り来しは、さすがの泰助も今迄に余り経験無き危急の場合、一度は狼狽したりしが、かねて携うる絵具にて、手早く血汐を装いて、第三発の放たれしを、避けつつわざと撃たれし体にて叢に僵れしに、果せるかな悪人｜輩は誑死に欺かれぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と意味ありげに言含め、「そこでの、黒瀬の婆様を葬ってやろうと思って用意をしたお棺はね、ちと道具に使用処がある、後でここへ持たしてお寄来し。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と朝から晩まで食｜好、食草臥れれば、緞子の夜具に大の字｜形の高枕、ふて寝の天井の圧に打たれて、潰れて死なぬが不思議なり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の知れるごとく今小樽にありてつぶさに辛酸を嘗めつつあり。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "検事代理村越欣弥は私情の眼を掩いてつぶさに白糸の罪状を取り調べ、大恩の上に大恩を累ねたる至大の恩人をば、殺人犯として起訴したりしなり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
