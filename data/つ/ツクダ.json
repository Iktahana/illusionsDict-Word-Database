    "definitions": [
      {
        "index": 1,
        "gloss": "cultivated rice field",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
