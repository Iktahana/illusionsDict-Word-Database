        "examples": {
          "standard": [
            {
              "text": "庭の片隅で、紫色の釣り鐘草が小さなベルのように下を向いて可憐に咲いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "初夏になると高原のあちこちで釣り鐘草が風に揺れ、ハイカーたちの目を楽しませてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "花屋で買ってきた釣り鐘草をリビングに飾ると、部屋全体がパッと明るくなったような気がした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "つりがねそうか野ぎくかの花が、そこらいちめんに、夢の中からでも薫りだしたというように咲き、鳥が一｜疋、丘の上を鳴き続けながら通って行きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つりがねそうか野ぎくかの花が、そこらいちめんに、夢の中からでもかおりだしたというように咲き、鳥が一｜疋、丘の上を鳴き続けながら通って行きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つりがねそうが朝の鐘を、　「カン、カン、カンカエコ、カンコカンコカン」と鳴らしています。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただあのつりがねそうの朝の鐘だけは高く高く空にひびきました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣くな」　窓の外では霧が晴れて鈴蘭の葉がきらきら光り、つりがねそうは、　「カン、カン、カンカエコ、カンコカンコカン」と朝の鐘を高く鳴らしました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
