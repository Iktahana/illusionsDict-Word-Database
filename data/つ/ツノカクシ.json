    "definitions": [
      {
        "index": 1,
        "gloss": "bride's head-dress",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
