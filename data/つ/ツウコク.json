      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "announcement",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "落第の懸念に苦しまされてゐた私は、その通告簿を片手に握つて、もう一方の手で靴を吊り下げたまま、裏の海岸まではだしで走つた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついで、彼は全国の支店、直営店へ、肺病相談所の看板を揚げさせると同時に、全快写真を提供した支店、直営店に対しては、美人一人あたり二百円、多数の医師に治療を受けたる者二百円、普通百円の割にて報酬を与える旨、通告した。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしが正しい方に加勢してやる」　山崎楽堂氏は大喜びで帰ってこの旨を全教授に通告した。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "御通告申上ましたように、詳細は後日決算報告を御手元へ伝記と共に、差上る事になっておりますので、ここでは荒方工事の報告を致します。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うにあの見張りの者は、モラン大佐に通告したであろう。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は次の通告節に引越していって、そして彼が初め申出たのと同じ状態のもとに、いよいよ開業したのでした。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "記憶が確かなら本文は『Ａ、ＢおよびＣに種を送る』――つまり結社からの通告だ。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "又自分の後に通告になつて居ります中には伊澤君のやうな經驗のある人もあります。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば甲の社員の提言を容れて直ぐ実行してくれと命じたものを乙の社員の意見でクルリと飜えして肝腎の提言者に通告もしないでやめてしまう。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生の知己に対して進退｜行蔵を公明にする態度は間然する処なく、我々後進は余り鄭重過ぎる通告に痛み入ったが、近い社員の解職は一片の葉書の通告で済まし、遠いタダの知人には頗る慇懃な自筆の長手紙を配るという処に沼南の政治家的面目が仄見える心地がする。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから最後に、「いずれその中に行く」と私が書いたに対して、「謀面は今時機に非ず、やがて折あるべし、」と結んで、手もなく当分面会謝絶を通告して来た。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "倭文子さえ、自分を離れないでくれれば、京子に誤って与えた恋愛の約束手形の無効を通告することだって、やってやれないことはないと村川は思った。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "其條件が遂に行はれずして、僕が最後の通告を諸方へ飛ばし、自ら令を下して全校の生徒を休學せしめた時から、豫定の如く免職になり、飄然として故郷の山河を後にした時まで、始終僕の心を解して居てくれたのは、實に唯彼の老助役一人だツたのだ。",
              "citation": {
                "source": "漂泊",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其条件が遂に行はれずして、僕が最後の通告を諸方へ飛ばし、自ら令を下して全校の生徒を休学せしめた時から、予定の如く免職になり、飄然として故郷の山河を後にした時まで、始終僕の心を解して居てくれたのは、実に唯彼の老助役一人だツたのだ。",
              "citation": {
                "source": "漂泊",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず新興キネマは、杉山、毛利、久松の三名を挙げ、右は会社に迷惑をかけた不埓ものであるから、絶対に雇用するなかれという意味の通告を各社に向って送付している。",
              "citation": {
                "source": "映画界手近の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方山下又三郎の名で「総罷業の首謀者四十五名に解傭を通告」という報道がある。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、遂に二時も過ぎて倦怠が傍聴席に満ちて来たとき、開会はもう三十分ほどおくれる見込みであるということがやっと通告された。",
              "citation": {
                "source": "待呆け議会風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはみかたによっては、減刑運動を一つのファシズム示威に応用しようとかまえている人々への無取締り通告である。",
              "citation": {
                "source": "新しい潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらかじめ藤枝から林田に電話で通告がしてあつたと見え、二人はすぐ小ぢんまりした洋風の応接間に通された。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出張を終えて東京にもどった大内に、小林は今度は通告してきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くのユーザーはセットでの注文を選んだが、ＭＩＴＳはできの悪いボードだけを送りつけ、ベーシックに関しては供給が遅れると一方的に通告するのみだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★ＧＵＩが間に合わないと通告を受けたＴＲＯＮの開発チームは、ソフトウエア戦略の修整を迫られた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "よって、万一上述の鼻にして今日中に本来の位置に復帰せざるに於ては、小生は已むを得ず法律による防衛に訴える他之無きことを前以って御通告申しあぐるを小生の義務と存ずる次第に御座候。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判所の通告で、ツァーレヴォ・コクシャイスクから、どこそこの市の監獄へ君を移すことになる。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "私から裁判所へ通告致しておきますが……」「ウン。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "保吉はきのうずる休みをしたため、本多少佐の頓死を伝えた通告書を見ずにしまったのである。",
              "citation": {
                "source": "文章",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "去る明治四十年にオランダで開かれた第二囘萬國平和會議で、戰鬪開始の時期が問題となり、或は通告を要すといひ、或は通告を要せずといひ、彼此議論を鬪はした時、列席の支那委員は、戰鬪開始に先だつて通告するのはよいが、相手がその通告に應ぜざる場合は如何にすべきか。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
