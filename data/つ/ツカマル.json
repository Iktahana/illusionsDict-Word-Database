    "definitions": [
      {
        "index": 1,
        "gloss": "to be caught",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」九　支那では土匪が捕まると、市街をひきずりまわして、見せしめに、群集の面前で断罪に処するのが習慣となっている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "張宗昌の兵タイにだって、逃げて捕まるような馬鹿はいねえだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に新聞社へ宛てて神経衰弱がヒドクなったようだから一箇月ばかり静養して来る……という意味の届けを出して、警視庁の手の届かない遠い処へ飛ぶつもりでいるのだから万に一つも捕まる心配はない。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見ると、豚吉は慌ててヒョロ子の髪毛を放しながら、「ソレ、捕まるぞ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾らでも、全く可笑しい位幾らでも、捕まるのだ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して犯人は捕まる。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "親切で人のいいあの親父が――あんな悪党に捕まるなんて。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだこの時間なら捕まるかと思って。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "手先が捕まることはある。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで来れば、もう捕まる心配は無いからである。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕まる時は捕まる」と笑っていた。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "うぬらに捕まる百化けのお兄さんかい。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕まるとウルサイから用心をする位の事である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体から云って、いろんな犯罪が無茶苦茶に殖えたのと正反対に、捕まる数が恐ろしく減ったのもその証拠と云えば云える。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし又前記の表に依ると、東京市中で詐欺脅喝や横領がかなり増加している一方に、捕まる数が恐ろしく減った事になっている。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して東京市中の賭博は非常に増加しているが、捕まる数も同様に非常に殖えている。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが捕まると、棒杭にしばりつけて置いて、馬の後足で蹴らせたり、裏庭で土佐犬に噛み殺させたりする。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "後でその同志が出てきたとき、私たちは、だから云わないことじゃ無かったんだ、分っていて捕まるなんて統制上の問題だぞと云った。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「捕まるおそれも。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人が高飛びしなければ、捕まるに決まっております。",
              "citation": {
                "source": "白痴の知恵",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年彼はこのスイスから追放されているので、そこにはいれば、見つかり次第捕まる恐れがあったのだ。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに一度、建長寺と円覚寺との間頃で後ろからあかりをつけない自動車が走って来て、やがてまたそれらしい自動車が戻って来た時などは、こんどこそ捕まるものと真面目に覚悟していた。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてたぶんここで捕まるものとまず覚悟して、捕まった上での逃げ道までもそっと考えていたのであった。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼自身も、見つかればすぐ捕まる、そして幾年の間か分らない入獄の危険を冒してやって来たのだ。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、その粘土のところはせまくて、みんながはいれなかったし、それに大へんつるつるすべる傾斜になっていたものだから、下の方の四、五人などは上の人につかまるようにして、やっと川へすべり落ちるのをふせいでいた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分には対手にまた出喰わすとか追手につかまるとかいう事の漠とした恐怖がある。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきまでまっ青で光っていたその空がいつかまるで鼠いろに濁って大へん暗く見えたのです。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「じゃきっと間もなくつかまるねえ。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、兄さんにしっかりつかまるんだよ。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっかりとつかまるんだ。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
