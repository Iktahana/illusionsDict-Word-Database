[
  {
    "uuid": "8d977862-34a6-5a23-add3-587ea831833a",
    "entry": "突棒",
    "reading": {
      "primary": "つくぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "barbed T-shaped weapon for catching thieves (Edo period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "妻と年寄の口の動くさまで、言葉を想像すると、突棒とか刺又とか※とかといふやうな責道具で拷問にかかつてゐる辛さであつた。",
              "citation": {
                "source": "裸虫抄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "道場では、負けぬが、何んしろ、一度は、大作の首を上げた御仁だからの」　一人が、板壁に立ててある突棒をとって、しごきながらいった。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "十手、突棒、袖がらみなどを持った手先、足軽が、門から雪崩れ入った。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "――とある横町の角まで来て、軒に沿うて曲ろうとすると、前を塞ぐ、十人あまりの同勢、「上意」「御用」　の大喝を発しながら、突棒を振り上げて、待ち構えているのだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "門の右手には紅白の幔幕、突棒刺叉捩など、さも厳しく立て並べてある。",
              "citation": {
                "source": "首頂戴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その式台を上った所に、突棒や、袖搦や刺股や、また古ぼけた馬上提灯などが、並んで懸けてあった昔なら、私でもまだ覚えている。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "此方は数十人の役人、突棒刺叉鉄棒などを携えて、取押えようと必死になって働いて居りますが、何しろ死者狂の罪人ども、荒れに荒れて忽ち役人も三四人｜打倒されました。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "その粉砕場は，これも甚だ原始的な操作で、木組の中央には上から特殊な突棒が下り、どすんと落下させて砕くのである。",
              "citation": {
                "source": "出雲鉄と安来節",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして偶然にも、丁度その晩八時頃柳容堂からの電話を女中が知らして来た時、昌作は突棒を置いてゲーム半ばに立上った。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "調べ所の壁に掛かる突棒、さす叉なぞのいかめしく目につくところで、階段の下に手をついて、かねて用意して来た手形を役人たちの前にささげるだけで済んだ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたかはもう突棒を手にして、媚ある眼でじっと見やった。",
              "citation": {
                "source": "球突場の一隅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたかは突棒を捨てて立って行った。",
              "citation": {
                "source": "球突場の一隅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、」と云い乍ら松井は突棒を捨てて椅子に腰を下した。",
              "citation": {
                "source": "球突場の一隅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして突棒を取って林に向いながら彼は強い憎悪を身内に感じた。",
              "citation": {
                "source": "球突場の一隅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は興奮した眼を突棒の先に注いだ。",
              "citation": {
                "source": "球突場の一隅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてゲームを突き切った時、突棒を捨てた。",
              "citation": {
                "source": "球突場の一隅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "組子は突棒、刺叉、槍、長刀を取って、弁慶に打ってかかるから、弁慶も金剛杖では間に合わず、ついに太刀の鞘を外して、縦横無尽にそれを斬り散らす騒ぎになったから、見物は喜びますけれど、道庵は身の毛をよだてました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "白雲が、話題の鼻を折られていると、その前へ繰込んで来たのは、たしかに物騒な一行で、抜身の槍、突棒、刺叉というようなものを押立てた同勢が、その中へ高手小手に縛めた一人の者を取押えながら、引き立てて来たのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼はつくつくぼうし、夜はがちゃがちゃがうるさいほど鳴き立てていたが、それらもいつか遠ざかって、このごろはこおろぎの世界である。",
              "citation": {
                "source": "草と虫とそして",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――木の芽草の芽歩きつづけるはてもない旅のつくつくぼうしけふはけふの道のたんぽぽさいた　　　　　□どうしようもないワタシが歩いてをる（「春菜」層雲二百五十号記念集　昭和七年五月刊）",
              "citation": {
                "source": "歩々到着",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・空も秋がきた地しばり草の花も・つくつくぼうしよ死ぬるばかりの私となつて・死ねる薬が身ぬちをめぐるつくつくぼうし・今が最後の、虫の声の遠ざかる・家があつて墓があつて草が青くて　草の中ゆく私の死のかげ　九月七日曇つた空から雨が落ちる、まつたく秋だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便も来ない日のつくつくぼうし・風が雨となる案山子を肩に出かける・電線とほく山ふかく越えてゆく青葉・竹の葉のすなほにそよぐこゝろを見つめる　昼ふかく虫なく草の枯れやうとして・てふてふもつれつつかげひなた（楠）・風鈴しきり鳴る誰か来るやうな　九月十一日　秋晴、久しぶりの青空だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "つくつくぼうしの声も弱々しくなつて、いつともなく遠ざかつてゆく。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……秋を感じる、昨日はつくつくぼうしが最初の声を聞かせた、萩もこま／″＼と蕾をつけた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうつくつくぼうしは鳴かなくなつたが、まだがちやがちやは鳴いてゐる、何だかそこにも私自身の陰影が残つてゐるやうな気がする。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人となればつくつくぼうし　　　　□・若葉に若葉がかさなつた（酒壺洞第二世出生）残暑といふものを知つた、いや味つた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "春日の森にひぐらしとつくつくぼうしが私の汗をなお更誘惑する。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は絵もかかずにぶらぶらとこの本尊を眺め、めの字に村人のトラホームを考えながらつくつくぼうしの声を聞き、冷たい本堂の冷気を吸いにしばしばここまで足を運んだものだった。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とため息をつくぼうし屋。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあさっさとしろ、」とせっつくぼうし屋、「さもないと話が終わるより先にこいつまたねてしまうぞ。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
