          "literary": [
            {
              "text": "遠い琉球の昔には、姓を称へなかつた筈で、昔の君主なども、追号が多い。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "遥か後の追号としてさうなつたのである。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "清盛は即座に沙汰を下すと、崇徳院には、追号を捧げ、崇徳天皇とし、頼長には、贈官贈位で太政大臣の贈位をし、勅使として少内記惟基が派遣された。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            }
          ]
        }
