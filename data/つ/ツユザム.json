        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今年の梅雨寒は厳しく、長袖の服が手放せない日が続いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "梅雨寒のせいで体調を崩しやすいので、十分に注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "梅雨寒の日は、温かい鍋料理が恋しくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "梅雨寒といふのでもあらう、なか／＼寒い、綿入を出して着た。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間に世に無き人ぞ梅雨寒し七月二十一日　五月二十五日大西一外逝去せし由、此日報あり。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
