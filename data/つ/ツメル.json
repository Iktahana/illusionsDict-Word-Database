    "definitions": [
      {
        "index": 1,
        "gloss": "to stuff into",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "友人と麻雀をしていて、リーチ後すぐにツモ和できたときは、皆から歓声が上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ツモ和は、自分で牌を引き当てて勝つため、親にとっては特に有利な状況と言える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "配牌が悪くても、ツモ和によって逆転のチャンスが生まれるのが麻雀の醍醐味だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "雲隠れする最後の一角まで、追い詰めるように視線を投げた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは蝸牛の肉を茹でて軟かくしたものを上等のバタと細かく刻んだ薄荷とをこね合せたものと一緒にして殻に詰めるだけのことである。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "細心の工夫によってやっとうまく詰め合わせたものを引っくら返されたのであるから、再び詰めるのがなかなか大変であった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、妙におどおどして落ちつかない女の樣子を見てゐると、強ひて問ひ詰めるのもためらはれるやうな氣持だつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句を作る場合のおもなる仕事は不用なものをきり捨て切り詰めることだからである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、マッチを箱に詰めるところや、職工の寄宿舎には、婦人もいるんだから、用事のないのに、そこへむやみに出入りしてはいけない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、森のはずれに立って、云い合わせたように、遠い寺の塔に輝く最後の閃光を見詰める。",
              "citation": {
                "source": "秋の歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず吾々の日常生活を煎じ詰めると、そこに「能」が現われて来る。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　井上博士は横浜にも一ヶ所事務所を持て居ましたが、僕は二十五の春、此事務所に詰めることとなり、名は井上の部下であっても其実は僕が独立でやるのと同じことでした。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "事業と云ふ大きな波にゆられながら、この微妙な羅針盤を見詰めるしみ／″＼した心持ちを何に譬へよう。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓑吉は一人使いの手柄を早く姉に誇ろうと気負い込み、一心に顔を緊張させ、眼は寮の方ばかり見詰めるだろう。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の夫の顔を、校中の学生たちがみんな見詰める。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏教は、この隠れていても実は私達の日常見聞する現実のあらゆるものをあやつっている根本をも、一緒にくっつけて現実を見詰めるのですから、表面だけの変化や矛盾撞着に瞞着されません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皿鍋にこの血の汁を移し家鴨の薄身をいれて掻き廻しながら煮詰めると汁は肉の周囲にチョコレート色に淡く固まる。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（阿難、娘の眼の中へ自分の瞳を差し込むばかり強く視詰める。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議と左を見詰めると、この飾もまた、光を放って、腕を開くと胸がまた晃きはじめた。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時も裏町の人数八九名に取占められて路地内へ遁げ込むのを、容赦なく追詰めると、滝は廂を足場にある長屋の屋根へ這上って、瓦を捲くって投出した。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "拂底な蝋燭の、それも細くて、穴が大きく、心は暗し、數でもあればだけれども、祕藏の箱から……出して見た覺えはないけれど、寶石でも取出すやうな大切な、その蝋燭の、時よりも早くぢり／＼と立つて行くのを、氣を萎して、見詰めるばかりで、かきもの所の沙汰ではなかつた。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "畝も畑もあったものじゃありません、廂下から土間の竈まわりまで、鰯を詰込んで、どうかすると、この石柵の上まで敷詰める。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "映る手なんざ、水へ突込んでるように、畝ったこの筋までが蒼白く透通って、各自の顔は、皆その熟した真桑瓜に目鼻がついたように黄色くなったのを、見合せて、呼吸を詰める、とふわふわと浮いて出て、その晩の座がしらという、一番強がった男の膝へ、ふッと乗ったことがあるんですね。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お杉は窪んだ眼を異様に輝かして、対手の顔を穴の明くほど凝と見詰めると、お葉は少しく茫となって来た。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査等は勝に乗って追い詰めると、穴は漸く広くなった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と自分は熟と流を見詰めると、螢の影は恰で流れるやうだ。",
              "citation": {
                "source": "水郷",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこでもそうだが、今の主人も、表の派手な人に引き換え、内に詰めるだけ詰める方で、夜座敷から帰って来ても、夜食に大抵｜古沢庵の二｜片か三片で、昼も、たまに小猫の食べるほどの鮭の切身の半分もつけば奢った方で、朝の味噌汁の冷え残りか、生揚げの一ひらで済ますという切り詰め方であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは何事かを思い詰めると、狂人の如くその一念に凝り固まり、理想に淫して現実を忘却してしまうために、遂には身の破綻を招き、狂気か自殺かの絶対死地に追い詰められる。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬚がそよそよと伸びるのが肉眼でも判るほどだから、と真顔で教えたら、だまってしゃがんで僕の顎を皿のようなおおきい眼でじっと見つめるじゃないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふのは、それでなくても厳しい父と細々し過ぎる母とが、殊に遊ぶこと以外には何にも考へようとはしない耕二に、執拗にも間がな隙がな小言を言ひつめるので、今もやつと許されて出掛けるらしい耕二に沢山の言葉は掛けないで出してやりたかつた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の眼の周囲には、萌黄にぼかされた穂高の峰々が、神経の電線に燃えついて、掻き消されそうもない、私は眼球の上へ、人さし指を宛てて、グリグリとやって見たが、一、二尺の先を見つめるのが精々で、森の梢は、その燃えさかりの※の中に、暗を縦横に引っ掻き廻し、入り乱れて手を突き、肱を張っている。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋はあるとした上でも、これだけのものを沸騰させ煮つめるだけの「燃料」を自分は貯えてあるだろうか。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "登りつめると綺麗な芝を植ゑた斜面から玉川沿の平野一面を見晴す事が出來た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to shorten",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は本当は手伝うつもりだったが、都合が悪くなって来られなくなったらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "まだ若いから、将来はいくらでも可能性があるというつもりでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このリフォームにかかる費用は、積もり積もってかなりの額になりそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "to reduce (spending)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今回のプロジェクトでは、前例のない新しい手法を試すつもりである。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼ならきっと約束を守るだろうというつもりで、私は彼に大切な仕事を任せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "来週、社内全体でセキュリティ研修を実施するつもりである。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 4,
        "gloss": "to focus intently on",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の言葉は単なる冗談のつもりで言ったのではなく、深い意味が込められていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "わざと相手を怒らせるつもりで言ったのではなく、単に状況を説明しただけだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この指示は、規則を厳密に適用するつもりで出されたもので、例外は認めない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 5,
        "gloss": "to go through thoroughly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今夜から雪が積もり、明日の朝には一面真っ白になるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "日々の小さな不満が積もって、ついに爆発してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "見積もり書を作成するために、各工程の費用を積もる作業を始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 6,
        "gloss": "to be on duty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "手札が悪いので、次に来る牌をツモって状況を打開したい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "リーチをかけた後、期待通りにドラ牌がツモって、一気においしい状況になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "役牌が揃ったので、ツモってリーチ一発で上がることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 7,
        "gloss": "to corner (esp. an opponent's king in shogi)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日のシャンプーとトリートメントで、髪に自然な艶が戻ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ベテラン歌手の歌声は、長年培われた艶があり、聴く者の心を深く揺さぶる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古いカフェの暖かな照明は、どこか懐かしい艶とロマンチックな雰囲気を醸し出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 8,
        "gloss": "to cut off (one's finger as an act of apology)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "近所の方が亡くなられたので、夜、通夜に参列させていただいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "葬儀の前夜に行われる通夜では、故人を偲びながら静かに祈りを捧げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "本来は一晩中起きて故人を偲ぶ通夜だが、最近では半通夜（はんつや）といって、数時間で済ませることも多い。",
