    "definitions": [
      {
        "index": 1,
        "gloss": "Essays in Idleness by Yoshida Kenkou (1283-1352)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
