    },
    "definitions": [
      {
        "index": 1,
        "gloss": "popular name",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "畸人という通称があったが、しかし難儀な病気の診断が上手だと云う評判であった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本街道から製材所の横を切れると、もう既に裾野であるが、富士のそれとは違って、乾き切った砂漠で、セージと通称する白ッ茶けた草や、マンザニタと呼ばれるところの、灌木などが茂って、馬蹄の砂が濛々と舞いあがるのには、馬上｜面を伏せて、眼をねぶるばかりであった。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に始めて渡来した西洋料理がポークカツレツ――通称トンカツであったかどうかは知らないが、西洋にいても日本人はよくこのトンカツを食べたがる。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "舌のない客と鑑別ければ左室の通称「｜悪い側」の方へ入れる。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――通称はツリガネニンジンであるが、色も同じ桔梗を薄く絞つて、俯向けにつら／＼と連り咲く紫の風鈴草、或は曙の釣鐘草と呼びたいやうな草の花など――皆、玉川の白露を鏤めたのを、――其の砧の里に実家のある、――町内の私のすぐ近所の白井氏に、殆ど毎年のやうに、土産にして頂戴する。",
              "citation": {
                "source": "玉川の草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは通称を定蔵といって、先年大阪で入墨の上に重敲きの仕置をうけた者で、窃盗の常習犯人である。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この多那川橋の附近に定住の乞食は文公の外に新参のわたくしを入れて六人いますが、文吉が始終関心を持つのはタガメと通称されるタカリ専門の乞食と、ヅケを貰って歩くお三という母子乞食でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ、赤提灯か」　温泉場などでは、怪しい女のいる家には目印の赤い門燈がついていて、赤提灯という通称が春を売る商売の代名詞になっていたのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "守一、通称は新蔵、鶴歩庵と云った。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "通称は又兵衛、長谷川町の待合茶屋である。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "真国は通称七兵衛である。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "会沢伯民は、諱は安、通称正志斎とも言はれた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "草津電鉄で、駅と旧軽井沢との間に通称「白樺電車」というものを通わせている。",
              "citation": {
                "source": "軽井沢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "河野の名は久、通称は虎五郎、後に俊八とも云った。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "但しこの男が真の時は必ず御定連へ半札を出す例であるから、通称は半札の円公。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "武さんの馬は赤毛の牡で、「どん」といふ通称だつた。",
              "citation": {
                "source": "肉桂樹",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（子曰く）　子は男子の通称であり、ここでは孔子（中国・春秋時代の思想家、儒教の祖、孔丘字は仲尼。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより古臭い滑稽談を単に、ジョー・ミラーと通称する事、わが国の曾呂利咄しのごとし。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "上古の人が遺した石製の斧や槌は雷斧、雷槌など欧亜通称して、神が用いた武器と心得、神の表徴とした。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "通称｜丸山軽焼と呼んでるのは初めは長崎の丸山の名物であったのが後に京都の丸山に転じたので、軽焼もまた他の文明と同じく長崎から次第に東漸したらしい。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃（明治十八年の頃）下谷に通称「佐竹原」という大きな原がありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "佐竹の原繁昌のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "御掛けやす」　その女鹿坂上の、通称一本楓と言われた楓の下の艶めいた行燈の蔭から、女装した目にとろけんばかりの色香を湛えて、しきりに呼んでいるのは、元禄の京に名高い陰間茶屋です。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "通称あばたの敬四郎といわれている同じ八丁堀の同心で、いうまでもなくその顔の面にふた目とは見られぬあばた芋があったからのあだ名ですが、しかし一面からいうと、あばたの敬四郎が、その顔の醜いごとく右門に対して心に醜い敵対心をいだきだしたことは、まんざら無理からぬことでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつは通称「下の道」で、県道からの道がそのまま延びて、校舎と体育館建設予定地を迂回し、グラウンドと野球場の土手下をくだり、寮玄関につながる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうひとつは通称「上の道」で、校舎裏玄関から出て、陸上グラウンドと細長い校舎にはさまれ、途中で直角に曲がり、グラウンドの短いほうの辺、野球場の一塁側ファウルエリアに沿い、一塁のわきから短い橋をわたり、本棟が建つ台地の一〇五のまえに出るものだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の山崎が、ヘッケル／東棟一階の洗濯室のわきにある、通称「おばさん休憩室」、正式名称「職員休憩室」に入ってきたのは、もう四時直前のことで、窓の外に目をこらす余裕があれば、わずかに空が明るくなっているのに気づいたことだろう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この草っぱらと畑の総面積は、どのくらいあると思う」と、母親の附添で仕合せな、せいたか坊やの通称のある瀬田青年が口をきると、「まず五千坪だね」と、口を尖らせるので蛸さんと綽名のある料亭の一人息子が、さっそく見積りをつけた。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "山猫といふ通称を持つた樵夫の吉太郎は、嘗ては強盗を働いた経験があるといふことを、山で酒に酔ふと（里では決して口にしないといふ。",
              "citation": {
                "source": "山男と男装の美女",
                "author": "ミツキイのジヨンニイ",
                "note": "青空文庫"
              }
            }
          ]
        }
