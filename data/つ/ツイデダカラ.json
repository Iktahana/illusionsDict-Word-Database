        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ついでだからそのときの出し物を思ひ出して見よう。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯父は少しも意に介せず、「これ、一生のうちにただ一度いおうと思って、今までおまえにもだれにもほのめかしたこともないが、ついでだから謂って聞かす。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでだから言うが、私は学校をやめてから七、八年間、洋服というものを着た事がない。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなこといってる隙がなかったのが、雨で閉籠って、淋しいので思い出した、ついでだから聞いたので。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでだから、弘前の町名と、青森の町名とを次に列記してみよう。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うむ、」「お前さん、その三尺は、大層色気があるけれど、余りよれよれになったじゃないか、ついでだからちょいとこの端へはっておいて上げましょう。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでだから話すが、今の文壇というものは、鴎外｜陣亡の後に立ったものであって、前から名の聞こえて居た人の、猶その間に雑って活動しているのは、ほとんど彼ほととぎすの子規のみであろう。",
              "citation": {
                "source": "鴎外漁史とは誰ぞ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし筆の走りついでだから、もう一度主筆に追願をして、少しくこの門外漢の評価の一端を暴露しようか。",
              "citation": {
                "source": "鴎外漁史とは誰ぞ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何と云われたって、云われついでだから云いましょう。",
              "citation": {
                "source": "Resignation の説",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもう御厄介になりついでだから為方がない。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しついでだから、順序は逆になるが、虎狩は後廻しにして、その後の彼について、もう少し話して置こうと思う。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでだから」「せっかくでございますけど、今日は急いでおりますからこのまま失礼させていただきます」「結婚をする段になりゃ費用はむろん、全部わしのほうで出してあげるがね。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあついでだからいいますがね。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生――」　ついでだから言うが、学校の教師だから、私を先生と――云う、私も時々、先生と云う。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでだから言うけれども、君たち「洋行者」は、妙にあっさりお世辞を言うネ。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰る時に、ついでだから、午前中に届けてもらいたいと言って、袷を一枚病院まで頼まれた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、ついでだからちょっと聞いておきますがさっきのなんとかベーンですね」「アフラ・ベーンか」「ぜんたいなんです、そのアフラ・ベーンというのは」「英国の閨秀作家だ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎が聞いてみると、よし子が病院の看護婦のところへ、ついでだから、ちょっと礼に行ってくるんだと言う。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょうどついでだから、ここで返しましょう」と言いながら、ボタンを一つはずして、内懐へ手を入れた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでだから、与次郎に教えてくれと頼んだ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよＫ市へ立つという前の晩になって、妻がちょうどいいついでだから、帰りに重吉さんのところへ寄っていらっしゃい、そうして重吉さんに会って、あのことをもっとはっきりきめていらっしゃい。",
              "citation": {
                "source": "手紙",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ねえ、だんな、ないしょにちょっと申しますが、ついでだからころあいなのをひとり見当つけておいたらどうですかい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ついでだから申し添えておきますが、道中しながら天下晴れてこの寄れッ寄れッが掛けられたものは、紀、尾、水のご三家にかぎったものだそうで、声とともに道行く者はいっせいに土下座。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "用を足して、来たついでだからと、観音さまにお詣りしていたら、ぽんと肩を叩いて、篠原の先生、という声がするじゃないかよ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "総桐の小格子造りで、ここにこうやりながらやにさがってすわってみると、お旗本も五千石ぐらいな気持ちだね――ついでだからちょっと念を押しておきますが、まさか本気に昼寝をなさるおつもりで、わざわざこんなところへ来たんじゃござんすまいね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでだから、このご新造さんが夢の中を歩いていても、あのとおり江戸の地勢に詳しかった手品の種もあかしてやるが――な、ご新造さん、あなたは今のその眠白のお囲い者になるまえに、江戸節か、鳥追い節を流して江戸の町を歌い歩いたおかたじゃなかったのかい」「ま！",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いや私は先づいきなりその事に筆を進める前に、ついでだから少し自分のこの頃の状態をも記して置かう。",
              "citation": {
                "source": "輝ける朝",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
