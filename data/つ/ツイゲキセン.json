        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "敵浮足立ったりと見ると、織田徳川の両軍は柵外に出でて追撃戦に移った。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "追撃戦の場合など、工兵の来ないうちに、落ちた橋をかけ直して急場の間に合せるなどといふ芸当はこの部隊でなければできぬだらう。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "爽快なる湖上の追撃戦。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "又しても、湖上の追撃戦。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからは、追撃戦であった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀政もこの時は、多くの味方を得たので、ためらいなく、さきに駈けた部下の一部を救うためにも、急きに急いて、追撃戦へ移っていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "この追撃戦こそ、主力戦となり申そう。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "よい死場所こそ欲しいものよ」　彼もまた、やがて鞭うって後に続き、なおその老躯を、追撃戦の中に働かせていた。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
