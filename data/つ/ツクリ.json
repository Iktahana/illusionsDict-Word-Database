    "definitions": [
      {
        "index": 1,
        "gloss": "making",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "造花作りは花屋を恨む、さて、花は造花程口がきけない。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "麥萩原朔太郎麥はさ青に延び行けり遠き畑の田作りの白き襦袢にえんえんと眞晝の光ふりそそぐ九月はじめの旅立ちに汽車の窓より眺むれば麥の青きに驚きて疲れし心が泣き出せり",
              "citation": {
                "source": "麥",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自己以外のものと争ふことは修辞を作り、自己と争ふことは詩を作る」（三六・一〇・五）",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてかういふことは、判然と示証することは出来ないけれども、短歌を作りたいといふことが、今後とも人々に全的な希望、全的な仕事として考へられることはあり得ないやうに思はれる。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "叙事は謂はば文人画風の型を作り、かくて人間的心情は所謂美――私にとつてはデコレイション――とその余りの部分とに分裂した。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "予て飛行機作りがその先生の道楽だと聞いてゐたから、それは正しく先生の書斎に相違ない。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局環境といふも結局｜各々の作り出すもんだ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "新宿を初めて見た時、田圃の中に建設された、一夜作りの大都會を見るやうな氣がした。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に、芸術とは、興味が、笑ひといふ自然的作品よりも、作品といふ人力の息吹きのかゝつたものを作り出すためには、興味そのものの内部に、生活人よりも格段と広い世界を有さねばならぬ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代人中の極くもう愚劣な、へ理窟屋共が全然人造的なものを作りたいと企図したりする。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その兜の作り方が三通りぐらゐあつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の冬それを作つてみようとしたがその何の作り方も覚えてはゐなかつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて彼等の間では彼等が世間に向つて抱くその野望からの当然の産物として出て来なければならなかつたのは、仲間同志に於ては、その仲間の誰でもを褒めたとも譏つたとも理由の分らない噂――まあまあ噂――さうつまり噂なんだ、それを作り出さんことに閑暇がない。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "人前で鼻クソを丸薬にする漫画を描かれた某様は、以後その必要のない時まで丸薬を、今度はオツピラに作りめされる。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪入りの寝るや小豆の煮える中　という句を作り、さらに春風馬堤曲を作る蕪村は、他人の藪入りを歌うのでなく、いつも彼自身の「心の藪入り」を歌っているのだ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時僕は詩を作り、初めて文壇的に出發したので、二三の友人と共に同人雜誌を發行して居た。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の江戸時代には帰らないでも、せめて巴里かロンドン位の程度にまで、余裕のある閑散の生活環境を作りたい。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "香水、麝香、油煙、マニラの臭氣相混じて一種縁日臭を作り、靄々然として、人自らそが上を蹈み、そが中を歩めり。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎に少しばかりの田地があるから、それを生計のしろとして慰みに花でも作り、余裕があれば好きな本でも買って読む。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、龍宮では、その影法師をたよりに暦を作り、四季を定めます。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、私なんかどうなつたつて、あなたの身にもしもの事があつてはいけないから、あなたの舟をこれから、ふたりで一緒に力を合せて作りませうよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "板切れの舟は危いから、もつと岩乘に、泥をこねつて作りませうよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ、作りごとなんだから。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夜作りの屋根――樅の青枝を解き施して、焚火に燻ゆらしてしまう、どんなに山が荒れても、この谷底まで退かない決心である、脂の臭いのする烟は、シュウシュウと呻りながら霧に交わって※ってゆく。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の天幕作りに取りかかる、古生層地は白峰までつづき、鳳凰地蔵一脈の間で、深谷にフツリと切れているのが、よく見える、人夫たちは雷鳥三羽を捕獲した、みんなして二羽を醤油飯に、一羽を焼いて喰った。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿坊の造りは一定していないが、往還から少し引ッ込んだ門構えに注連を張り、あるいは幔幕をめぐらせ、奥まった玄関に式台作りで、どうかすると、門前に古い年号を刻み入れた頂上三十三度石などが立っている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽殿の傍には、周囲六丈四尺、根廻りは二丈八尺、と測られた神代杉がそそり立って、割合に背丈は高くないけれど、一つ一つの年輪に、山の歴史の秘密をこめて、年代の威厳が作り出す色づけと輪廓づけを、神さびた境内の空気に行わたらせている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "八ヶ岳の泥流が作りあげた凝灰質、集塊岩の美事なる累積である。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は、火山を、それ自ら単独のものとして、観察したのであるが、このような能動的な、積極的な、神経が尖って、触覚が鋭敏な火山が、日本アルプスの大山系に潜ぐり込み、そこから赤裸になって躍り出したところに、いかばかり特色のある山岳景を作り出したか、私は次にこれを言って見たいのである。",
              "citation": {
                "source": "日本山岳景の特色",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "作りもしない者に米を食はせるからには、作つてる農民が米が食へないと云ふ法はないのである。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
