        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "物も言わずに突き膝で箪笥の方へにじり寄り、それをしまいこむその腰のあたりを見ると、安二郎はなぜかおかしいほど狼狽して、しぶしぶ承知した。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて物も言わずに突き膝で箪笥の方へにじり寄り、それを蔵いこむ、その腰のあたりを見ると、安二郎はおかしいほど狼狽した。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は小さな躰へ小さな筒袖を着て突き膝をして居る。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "はッ、と突き膝になり彼は頭を低げて答えた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆の穂を墨つぼにたっぷりひたして、幾らか毳ばだった標木の前に突き膝をした。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "餌を拾う鶏を小舎へ追い込む振りをして、それとなく外を見張っている）子供　　（数人、隠れん坊をして、往きつ来つして遊んでいる）旅姿の下総の博徒突き膝の喜八と宮の七五郎、往来へきて立ちどまる。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜八　　飯岡身内の突き膝の喜八だ。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            }
          ]
        }
