    "definitions": [
      {
        "index": 1,
        "gloss": "you said",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしこの悲しい宿命者も、さすがに日本に渡ってからは、多少の平和と幸福を経験した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京｜帝国大学の招聘に応じて、松江や熊本の地を去ったことも、同じくヘルンの身にとっては、愛する妻への献身的な犠牲だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも彼の夫人にとって――世の多くの若い女性と同じく――東京はあこがれの都であり、そこでの生活は一生最高の理想であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿体ないほどありがたいことでした』と、その追懐談の中で沁々と語っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚十数年、ヘルン既に五十｜歳を過ぎ、二人の男児と一人の女児の親となってる晩年の手紙である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "オババサマとは彼の妻の母であって、名義上、小泉家の養子たる彼にとっては、姑の義母に当る老婦人である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故ある人々は、ヘルンがもし悪妻をめとり、意地悪の姑等と同居したら、彼の神国日本観は、おそらく顛倒した結果になったろうと言っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいつも和服――特に浴衣を好んだ――を着、畳の上に正坐し、日本の煙管で刻煙草を詰めて吸ってた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の知人を訪問しても、洋風の応接間などに通されると、帰ってからも甚だ不機嫌であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人は立派な文明を持っていながら好んで野蛮人の真似をしたがると、彼は常に不満を述べていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は学生に向っても、常に奢侈を戒めて質素を説き、生活を簡易化することの利得を説いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日二三合の米の飯と、少しばかりの副食物と、二三合の日本酒とさえあれば、それで私の生活は充分であると、その訪問客に語っているヘルンは、実際に学者風の簡易生活をしていたのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "書斎に仕事をしている時のヘルンは、周囲のちょっとした物音にも、すぐ『私の考え破れました』といって、腹立しくペンを投げた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "）そうした彼の習慣は、普通に多くの西洋人が、彼等の風習によってするごとき、単なる形式的のものではなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして気味わるく物凄い顔をした、雲助のような男たちに脅やかされたり、黒塚の一軒家のような家に泊って、白髪の恐ろしい老婆に睨まれたりした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人はその時のことを追想して、草双紙で読んだ昔物語を、そっくり現実に経験した様だったと言ってる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた一所に行きます』と言って、ヘルンが妻を連れ出す所はたいてい多くは寂しい静閑の所であり、寺院の墓地や、邸の空庭や、小高い見晴らしの丘などであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし琴、生花、茶道によって教育され、和歌や昔物語によって、物のあわれの風雅を知ってた彼の妻は、良人と共に、その楽しみを別ち味わうことができた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし東京へ移ってから、子供が大ぜい生れたりして、家内が狭くなった上に、貯財も少し出来て来たので、夫人のすすめで売家を一軒買うことにした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日二人は、例によって睦じく連れそいながら、牛込辺の売邸を探しに歩いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何となく陰気に薄暗くじめじめして、妙に気味の悪い厭な感じがしたので、夫人が直覚的に反対したにもかかわらず、ヘルンは一見して大いに気に入り、『面白いの家』『面白いの家』と、子供のように嬉しがって、是非それを買おうと言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局それは、夫人の強硬な反対によって中止されたが、後でそれが有名な化物屋敷と解った時、夫人がほッと胸を撫でおろしたとは反対に、ヘルンは大変失望して、『ですからなぜ、あの家住みませんでしたか。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンについての一不思議は、あれほど広く多方面の文献に亘って、日本人以上に日本のことを知っていながら、日本語をほとんど知らなかったということである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の知ってた日本文字は、片仮名のイロハと僅少の漢字にすぎず、彼の語る日本語は、焼津からの手紙にある通り、不思議な文法によって独創された、子供の片言のような日本語である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう場合に、妻もまたヘルンさんの言葉を使って応答した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
