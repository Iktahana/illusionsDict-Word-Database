    "definitions": [
      {
        "index": 1,
        "gloss": "to follow around",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おふくろ様ばかりでなく、おまえにも同じ祟りが付きまとうています。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンナ・ステンのナナが酒場でうるさく付きまとう酔っぱらいの青年士官を泉水に突き落とす場面にもやはり一種の俳諧がある。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い間｜宅にばかりくすぶっていて、たまたまこのよい時節に外の風に吹かれると気持ちはいいようなものの、あまりに美しい自然とそこにも付きまとう世の中の刺激が病余の神経には少しききすぎるようでもある。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういう選挙制度にいつも付きまとう弊害を防止するためにはこれらの記者の地位を決して物質的に有利なものにしてはならない。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦げた百合の香ばしいにおいや味も思い出したが、それよりもそれを炒ってくれた宿の人々の顔やまたそれに付きまとうた淡いロマンスなどもかなりにはっきりと思い出された。",
              "citation": {
                "source": "球根",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、そういう因縁付きの品には、不思議に何かの事件が付きまとうものです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あくまでも執念く付きまとうて来ますれば、もう是非がござまりませぬ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいですか、僕が一生涯付きまとうものと覚悟して下さいよ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃというて、お身さまに禍いの影が蛇のように付きまとうているのを、どうしてそのままに見ていらりょう」「じゃによって訊いている。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い大名屋敷には往々そんな怪談が付きまとうので、屋敷跡の屯所の築山にも古狐か古猫のたぐいが棲んでいないとは限らない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは昔から言うように、美しさには、時として不幸の予感が付きまとうことがあるからだ。",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "――芸術もさまざまの花の一つだというのは、遙か彼方の社会に於けることで、現在では、今日の条件がいつも重大に付きまとう。",
              "citation": {
                "source": "今日の条件",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「歯形といい人面疽といい、恐ろしいことばかりが付きまとう。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、人気役者に付きまとう様々な噂は、それからそれえと、日毎におせんの耳へ伝えられた。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いやらしく妾に付きまとうあいつ！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも総理大臣が週末休養のためにゴルフ場へ行く時、新聞記者や写真班をうまくまいたように、湖上の突風はうるさく付きまとう群衆をまいて、イエス様を休養の場所に導いたのです。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "著しく不愉快なこともあったが、より多くの場合芳香性で、ぼんやり付きまとう感じの性質を持ち、幻想的な光景を呼び起こす力があるようだった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる原始的かつ信じ難い根源を、幾時代を経た神話群及び付きまとう悪夢の源を、今まさに私は暴こうとしているのか？",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "付きまとう小鳥たちを叱ったり、追うかと思うと呼んだりする。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴がご執心の、ほれご存知でしょう、女に付きまとうから、何回も警告しましたが、平気でした。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの男が一生俺につきまとう。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生、私につきまとう思想であろうか。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの楽屋で始終影のようにつきまとう一人の道化師がある。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　道子はそう呟きながら、道子は、姉の死の悲しい想出のつきまとう内地をはなれて、遠く南の国へ誘う「旅への誘い」にあつく心をゆすぶられていた。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前がお母さんの事を忘れないように、私の心もお前の傍へいつまでもつきまとうております。",
              "citation": {
                "source": "三つの眼鏡",
                "author": "無署名（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘定は月末にきっと払いますから」「勘定なんて、いつでもかまいませんけど、警察のほうが、うるさいのでねえ」　ああ、いつでも自分の周囲には、何やら、濁って暗く、うさん臭い日蔭者の気配がつきまとうのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分につきまとうベッシェール夫人とそれがどう縺れるか。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや人間が梅の木につきまとうのかも知れません。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の摂理に基づけば、ああいう娘にはつきまとう男がいるものだ。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "フェリアは勇敢な男だったが、それでもこの影のようにつきまとう言い知れぬ恐怖には、震えるほかなかった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
