[
  {
    "uuid": "d0d5bb37-84c3-5429-b47e-81a2e4bb28bb",
    "entry": "対語",
    "reading": {
      "primary": "ついご",
      "alternatives": [
        "たいご"
      ],
      "is_heteronym": false
    },
    "grammar": {
