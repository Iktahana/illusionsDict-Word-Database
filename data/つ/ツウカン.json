  {
    "uuid": "8c42fd47-da4e-5a4b-bd01-fa4aa55c0b2b",
    "entry": "通巻",
    "reading": {
      "primary": "つうかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
