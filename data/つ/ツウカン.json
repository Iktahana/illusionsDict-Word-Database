[
  {
    "uuid": "ff34c5f7-fc55-5e23-ac3a-9be3ce6b4a05",
    "entry": "痛感",
    "reading": {
      "primary": "つうかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
