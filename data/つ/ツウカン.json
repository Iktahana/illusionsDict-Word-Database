    },
    "definitions": [
      {
        "index": 1,
        "gloss": "consecutive number of volumes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは、当初の目的とする優秀新人の出現に、通巻十二号の今となってもまったく見極めが付かないからだ。",
              "citation": {
                "source": "獅子は死せるに非ず",
                "author": "終刊の辞に代えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "「同封の書面をお読み下すったならば、私の申上げることの偽りでないことがお分りになりましょう」　と、いう文字を冒頭にして、小間使花からの手紙が二通巻き込んであった。",
              "citation": {
                "source": "美人鷹匠",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "通巻画図京水　　岩瀬百鶴　筆　北越雪譜二編　四巻大尾註解＊１　「許鹿君」古河の城主土井大炊頭｜利位の号、利位は下総古河藩第十世の藩主である。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "通巻画図京水　　岩瀬百鶴　筆　北越雪譜二編　四巻大尾",
              "citation": {
                "source": "北越雪譜",
                "author": "北越雪譜二編",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の新国字の数と種とは、今正確に分類出来ないけれども、新井白石の同文通巻によれば「峠」の如きも、当にその時代に造らしめられた国字の一つに相違ない。",
              "citation": {
                "source": "「峠」という字",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが「大菩薩峠」も通巻無慮九千三百二頁、四百七十万字、悪金子の口吻によりてこれを前人に比較すれば、すでに源氏物語の六倍、八犬伝の約三倍強の紙筆を費してなお且つ未完。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "訳注一、底本では、本文開始前に初出紙「早稲田文学」（明治28年(1885) 5月刊、通巻87）の記者による次の紹介文が掲載されている：「本篇は故湖泊子が病中其の友と探題して咄嗟作せるもの。",
              "citation": {
                "source": "戦争",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "13）「早稲田文学」通巻58「俳諧七首」明27/02刊。",
              "citation": {
                "source": "藤野古白句集",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "通巻59「俳諧六首」明27/03刊。",
              "citation": {
                "source": "藤野古白句集",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "通巻72「俳句七首」藤野古白、明27/09刊（コード「早文」）。",
              "citation": {
                "source": "藤野古白句集",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "▼「早稲田文学」に掲載された句：　・608，631，653，※654　「早文」通巻58（明27-2）「俳諧七首」。",
              "citation": {
                "source": "藤野古白句集",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "・622，627，※662　「早文」通巻59（明27-3）「俳諧六首」。",
              "citation": {
                "source": "藤野古白句集",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "・667，671，700，※707　「早文」通巻72（明27-9）「俳句七首」。",
              "citation": {
                "source": "藤野古白句集",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "・平尾圭吾（2009）「私が福田恒存訳「老人と海」に感動できない理由」、『正論』平成21年11月号（通巻452号）所収。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "・雑誌『pen』2011年4/15号（第15巻7号・通巻288号）。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして夢みながら、自分の幼年時代や青年時代の思い出が、いま頭のなかに渦巻いている暗い錯雑した考えの深淵の上の花の小島のように、穏やかな静かな喜々たる姿で一つ一つうかんでくる。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の手ひとつで、とにもかくにも一家の生活を支えて、野良仕事はもちろん、機織から、近所の養蚕の手つだいまでやって、かいがいしく働いているおのぶの顔は浅黒く陽にやけてはいたが、三十五の今日にいたるまで小皺ひとつうかんでいない。",
              "citation": {
                "source": "本所松坂町",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
