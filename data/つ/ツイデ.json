[
  {
    "uuid": "cc38f399-ce95-5b8c-84f9-5cfae631b57d",
    "entry": "次いで",
    "reading": {
      "primary": "ついで",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "接続詞"
      ],
