        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "奪い返して白倉が、おしまを突き倒す。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はすなおにも彼女を突き倒すほどの意気込みで歩きだした。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『一昨日の晩、葛飾は、泣いて詫びるわたくしをまるで突き倒すようにして外へ飛び出して行きました。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは周章てゝ、「あら、人のアラを見ちゃ嫌よ」　と言って押え隠しますのを追って突き倒すような語気で、「ばか、自分の膚なんか、ひとに見せるもんじゃない」　と言ったかと思うと、ちらりと庭の柴の橋詰の方を見ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たいへんだ、たいへんだ、何人か来てくれ」「広巳、広巳、そ、そんな」「あれ、あれ」「何人か来てくれ」　岡本は玄関の方へ逃げる隙がないので、奥との境になった襖を突き倒すように啓けて逃げた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の室へ入った岡本は、今度は縁側の障子をこれも突き倒すように啓けて裏庭へ出た。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒りくるった女房は、カメが外へにげると、益々気勢があがって、追いつめては、なぐりつけ、追いせまっては、突き倒す。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "神伝魚心流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "人家へヒンパンにとびこんで戸障子を破壊し置物をひっくり返し人々を突き倒すが、ガラス戸を破ってくぐりぬけても担いでいる十六人だけは怪我をしたことがないそうだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "立っているにんじんを突き倒す。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃこうしていわせてやる」　花の背を突いて俯伏せに突き倒すと、馬乗りになり、「花ちゃん、すまないが裸にするわよ」　遠慮会釈もなく帯をとき始める。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "425これらを棄てゝ猶進み＊ヒパソスの息カロプスを――高き素生のソーコスの義弟を槍に突き倒す。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手に打振る金剛杖で思うままに彼等を打ち倒し、突き倒すことは寧ろ面白いほどでありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "慢心和尚の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、近藤勇ほどのものが、ついにこの傍若無人な坊主を突き倒す隙を見出すことができませんでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "慢心和尚の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍を取れば、宇治山田の米友の眼中に人はなくなるのだから、驚いた後は小癪に触ってただ一突きに突き倒す気合で来たのを、中段につけていた兵馬はスーとそれを引いて、撞木返りに米友の咽喉元へ槍が行く。",
              "citation": {
                "source": "大菩薩峠",
                "author": "間の山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "向う様もさぞ待っておいでなさるでしょうけれども、わたしというものがあってみれば、そうも参りませんでお気の毒さま、ほんとにお気の毒さま」と言ってお角は、口惜しがりながらがんりきを横の方から突き倒す。",
              "citation": {
                "source": "大菩薩峠",
                "author": "市中騒動の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "孫は、あーッ駄目だッと思うと、西蔵犬に噛みつかれたまま、デューランに跳りかかって、頭で彼を突き倒すと、左に匕首をとって相手の顔を滅多斬りにしてしまった。",
              "citation": {
                "source": "雲南守備兵",
                "author": "木村荘十",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それ、それッ、突き倒すぞ」　日吉はまた、蹌めいた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "体中をもって狂いまわる血の奴めが思う御人の前にその体をつきたおすのじゃ。",
              "citation": {
                "source": "葦笛（一幕）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして老探偵をその場へつきたおすと自分は素早くばたばたと逃げ出した。",
              "citation": {
                "source": "断層顔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
