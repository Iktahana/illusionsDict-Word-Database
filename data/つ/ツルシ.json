    "definitions": [
      {
        "index": 1,
        "gloss": "ready-made clothing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
