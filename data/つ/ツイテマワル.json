[
  {
    "uuid": "0f732226-44d8-5965-801c-cdd08d8787b4",
    "entry": "ついて回る",
    "reading": {
      "primary": "ついてまわる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
