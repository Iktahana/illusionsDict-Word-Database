        "examples": {
          "standard": [
            {
              "text": "故障したトラックから代わりの車両へ、急いで積み荷を積み替えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "船から降ろした物資を、山岳地帯へ運ぶために小型車に積み替える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "より効率的なルートで運ぶため、中継地点で荷物を別の便に積み替えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "更に羽田空港に待機していたオートバイが――何故か、私にはオートバイに違いないように思われる――その注射薬を積み替えるや、否や、爆音高く、疾走して来る光景を想像する。",
              "citation": {
                "source": "落日の光景",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "この船の積荷は専らエジプトの木乃伊で、引き渡し先は「船員Ａ. Ｂ. Ｃ.」であり、ナンキット岬の先の所で艀に積み替えることになっていた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑貨をセメントにつみかえることが、なぜ非常時なんですか。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
