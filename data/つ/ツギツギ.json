    "definitions": [
      {
        "index": 1,
        "gloss": "in succession",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その間にも断えず皆が卓の下で次々に品物を渡しているような真似をしている、その人の環のどこかを実際に品物が移動しているのである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの線が一度はどこかの郵便局へ束になって集められ、そこで選り分けられて、幾筋かの鉄道線路に流れ込み、それが途中で次々に分派して国の隅々まで拡がってゆく。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実というものは、切れ端は与えるが、全部はいつも眼の前にちらつかせて次々と人間を釣って行くものではなかろうか。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　月あかりの中にまっすぐに立った電信柱が、次々に何本も何本も走って行き、けむりの影は黒く雪の上を滑りました。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから先生の次々話されたあらますはこうである。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの問題に悩んでいる自分の前に、問題が次々と山のように積まれてくる。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば一個のポリプを二つにちぎって、それぞれに独立の生命を持たせ、そうしてあとでそれを次々に接枝して行って一つの群体を作ったというふうにも見られなくはない。",
              "citation": {
                "source": "俳句の型式とその進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまたの手を経るまにまに、さきざきの考えの上をなおよく考えきわむるからに、次々にくわしくなりもて行くわざなれば、師の説なりとて必ずなずみ守るべきにもあらず。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの部屋を区切った扉は、次々に、バタン、バタンと突きあけられた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "村には娘達がＳ町やＫ市へ吸い取られるように、次々に家を出て、丁度いゝ年恰好の女は二三人しかいなかった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語の記号と、番号のはいった四角の杭が次々に、麦畑の中へ打たれて行った。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次々うつるひるのたくさんの青い山々の姿や、きらきら光るもやの奥を誰かが高く歌を歌いながら通ったと思ったら富沢はまた弱く呼びさまされた。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "莊之助が出て行つてから彼は堪らない場面をとうとうやり過したといふ氣がしたが、次々に盛り上つて來る嫌惡の感じにゐたたまらなくなつた。",
              "citation": {
                "source": "奎吉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその音も、次々小さく、然も段々質が固く冷くなつて來た。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のひとからは次々と手紙が来る。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おひる近くなって、重大なニュウスが次々と聞えて来るので、たまらなくなって、園子を抱いて外に出て、お隣りの紅葉の木の下に立って、お隣りのラジオに耳をすました。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから戦闘艦隊が三十二隻、次々に出発し、その次に大監督の大艦長が厳かに舞いあがりました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "却ってそのつやつやした緑色の葉の上に次々せわしくあらわれては又消えて行く紫色のあやしい文字を読みました。",
              "citation": {
                "source": "若い木霊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）そのとき次々に雁が地面に落ちて来て燃えました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがちょうど俳諧連句の句々の連珠のようなモンタージュによって次々に展開進行して行くのである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上は短かく次々と少しずつ長くなって、最後の盤はペリカンの嘴のように長い。",
              "citation": {
                "source": "噴水物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お涌自身の家は下町の洋服業組合の副頭取をしていて、家中が事務所のように開放され、忙しく機敏な人たちが、次々と来て笑い声や冗談を絶さなかった。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その六十里の海岸を町から町へ、岬から岬へ、岩礁から岩礁へ、海藻を押葉にしたり、岩石の標本をとったり、古い洞穴や模型的な地形を写真やスケッチにとったり、そしてそれを次々に荷造りして役所へ送りながら、二十幾日の間にだんだん南へ移って行きました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから戦闘艦隊が三十二隻、次々に出発し、その次に大監督の大艦長が厳かに舞ひあがりました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　次々に――特選、精選、改良、別改、また稀……がある。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こういう情緒も一度味っとくがいい」　小郷は反省とか自制とか潔癖とかいうものが、まるで欠けた男だったから、君勇を見れば君勇を、鈴子を見れば鈴子を、弓子を見れば弓子をと、次々と食指が移っていたのだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通なら、彼は復員直後の無気力な虚脱状態のまま、一種、根こぎにされた人となって、ぼんやり日を送ったところだろうが、深夜雨の四ツ辻で、裸の娘を拾ったという偶然は、次々に偶然を呼んで、まるで欠伸をする暇もないくらい、目まぐるしい一昼夜を過したのだ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はその銭湯屋には五人娘があり、この八年間に四人の娘が次々とかたづいた。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月二日、五月三日、五月四日と紀念祭あけの三日、同じ円山公園の桜の木の下で、その美貌の順によって女専の生徒を次々と接吻した。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと、そのＭ・Ｔという人は、用心深く、妹からお友達の名前をたくさん聞いて置いて、つぎつぎとその数ある名前を用いて手紙を寄こしていたのでございましょう。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
