[
  {
    "uuid": "97626210-9901-5626-8b45-157bc149657f",
    "entry": "艶っぽい",
    "reading": {
      "primary": "つやっぽい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
