    "definitions": [
      {
        "index": 1,
        "gloss": "always",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "草野君の感覚は非常に正確なものである。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つには非常に寡作のせゐもあるのだが、『そつとしておいてくれ』といふ気持の強い男だといふことがその主な理由だと思ふ。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術不振の原因を社会の事情に在りとする見方は、常に十分なものではない。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、俳聖芭蕉は、みだりに作らないといふ覚悟を非常に持つてゐたさうであるが、その事は、私には此の場合特に重要な事と考へられる。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉は、一物と他物との合体の瞬間に於ける妙といふことを、非常に大切にしたのであるが、そして恐らく此の事こそ俳句の最高眼目たるものでもあらうが、その眼目が射当てられるためには、蓋し情理的であるよりもおのづと感覚的である方が適切であるに相違ない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　叫びたいことが直接形を採るためには非常に熱烈である必要があるのだが、その熱度の聊低い者は叫ぶ者の容態を描くことになる。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば茲に一農学士があり、非常に立派な耕作法を学び、百姓に教へに行く任務を帯びるとする。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、私は常に全身像を製作しろといふやうなことを云つてゐるのではなく、トルソも結構、手だけでも結構だが、トルソならトルソで、それが全一的な感じを与へるものではなければならぬと云ふのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち五名は非常に重く、学校をも欠席してゐました。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私思ひますに、我が国人の素質は非常によく、開化の段階は猶低いのであります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も心で尊敬するわけではないが、非常にジャーナリスチックな交遊をしたりするから、何か仲間の足溜りの役をなす。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまれ私は今書きながらフトその忠魂塔の模型をだつて思ひ出したのだが、それが現に在つたといふことは非常に慥かなのだが、また却つて夢のやうでさへある。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の船は小さかつたであらうし、船はまた非常に揺れて、母も吐き出したのださうだが、不思議に祖母が元気で助かつたのださうである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して私は常に夢みてゐる。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人は立派な文明を持っていながら好んで野蛮人の真似をしたがると、彼は常に不満を述べていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は学生に向っても、常に奢侈を戒めて質素を説き、生活を簡易化することの利得を説いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンは常に散歩を好み、学校の帰途などには、まだ知らない町の隅々を徘徊したが、新しい興味の対象を見出すごとに、必ず妻を連れてそこへ再度案内した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時は下宿をしたり、ある時は間借りをしたり、ある時は借家をしたりして、常に住居を転々としていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の手の某所に住んでるある華族の老婦人が、非常に極端な西洋嫌いで、何でも舶来のものやハイカラなものは、一切『西洋｜臭い』と言って使用しない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたヘルンの小泉八雲が、常に最も好んだ散歩区域は、寺院の閑静な境内だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそうした八雲の悲しい心は、常に最も夫人の心を痛ましめた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただあなたの話、あなたの言葉、あなたの考でなければいけません』と常にいった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は田舎の程度の低い学校を出たばかりで、充分の高等教育を受けなかったので、常に自分の無学を悲しみ、良人に対して満足な奉仕ができないことを嘆き詫びた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの趣味はすべてにおいて庶民的で、儀式ばったことが嫌いなので、フロックコートなどの礼服を非常に嫌い、常に野蛮人の服と称し『なんぼ野蛮の物』と言っていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故彼は、動物を始め植物に至るまで、すべて生物を虐めたり殺したりすることを非常に叱った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの机の座右には、常に日本の煙草盆と煙管がそなえてあった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川君の性格には、一面社交的の素質があつたので、友人が非常に多かつた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）一方また室生君の方では、自分で深くその野性を羞恥して居り、常に「教養ある紳士」といふやうなことをイデアにして居たので、教養や趣味性の上で文化的にレフアインされた芥川君が、世にも珍しく理想の人物に思はれたのである。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の多くの友人に對して、芥川君は常に都會人的な洒落や笑談を言つたらしい。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ汝の肖像、われらおよばぬ至上にあり、金屬の中にそが性の祕密はかくさる、よしわれ祈らば、よしやきみを殺さんとても、つねにねがはくば、われが樂欲の墓場をうかがふなかれ、手はましろき死體にのび、光る風景のそがひにかくる。",
              "citation": {
                "source": "光る風景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
