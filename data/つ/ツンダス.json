        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は不満そうに、唇を突ん出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ボールペンをカバンから突ん出すと、すぐに書き始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "猫が尻尾をぴんと突ん出して歩いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それから一升買いに十円札を突ん出す柄じゃ御座んせんで……どう考えましても……ヘエ。",
              "citation": {
                "source": "骸骨の黒穂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、親分、なおりしだい引っくくって恐れながらと突ん出すおつもりでがしょう。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうだこと云あねえで、そら來たつとかう手つんだすもんだ、倦怠くつて仕やうねえ此等がな」先刻の爺さんは又一｜杯をぐつと干して呶鳴つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "……芸もねえ事に可愛くもねえ面つんだすなてば」　仁右衛門はまた笠井のてかてかした顔に唾をはきかけたい衝動にさいなまれたが、我慢してそれを板の間にはき捨てた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いってい、てめえなんざ、御府内へつんだす面じゃねえ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "ねずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつてはエディ・アーノルドのマネージをしていたこともある男で、興行の世界で厳しい体験をつんだすぐれたマネジャーだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
