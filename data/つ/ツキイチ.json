    "definitions": [
      {
        "index": 1,
        "gloss": "(at a rate of) once a month",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "トリスタン・コルビエールは、千八百四十五年、七月十九日、午前八時、モルレーに於て汽船会社の社長の息子として生れ、千八百七十五年、三月一日午後十時同所で死んでゐるから三十年に足らぬ生涯であつた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "無趣味太宰治　この、三鷹の奧に移り住んだのは、昨年の九月一日である。",
              "citation": {
                "source": "無趣味",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月一日　（土曜）　朝はしけ模様で時々暴雨が襲って来た。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年九月一日『東京朝日新聞』）",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十月一日『東京朝日新聞』）",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "渝らぬ契りの誰れなれや千年の松風颯々として血汐は殘らぬ草葉の緑と枯れわたる霜の色かなしく照らし出だす月一片何の恨みや吊ふらん此處鴛鴦の塚の上に。",
              "citation": {
                "source": "別れ霜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十八年十二月六日夜十二時｜記〔『馬酔木』明治三十九年一月一日〕",
              "citation": {
                "source": "絶対的人格",
                "author": "正岡先生論",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔『中央公論』「正岡子規論」明治四十年九月一日〕",
              "citation": {
                "source": "子規と和歌",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月一日長子が週末で帰省したときに、自分はもう永くはないが、ただ一つ二つ仕上げておきたいことがあると云った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月一日の朝、最後の筆を加えた後に、これを状袋に入れて、本誌に送るつもりで服のかくしに入れて外出した。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ筆法で行けば弘安四年六月三十日から七月一日へかけて玄界灘を通過した低気圧は我邦の存亡に多大の影響があったのである。",
              "citation": {
                "source": "戦争と気象学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸暑さが丁度大正十二年九月一日の二科招待日を想い出させた。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年十月一日『東京朝日新聞』）　　　　　　　　　八　　　　　　火桶、火鉢　金属や陶器のは火を入れると周囲が熱くて触れなくなるが、木製のだとそんな事はない。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十月一日『東京朝日新聞』）　　　　　　　　　十一　　　　　　磁力起重機　強い電磁石を使って重い鉄片などを吸い付けて吊し上げ、汽車や汽船の荷上げや荷積みをする器械が近来｜処々で用いられる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十一月一日『東京朝日新聞』）　　　　　　　　　三十二　　　　　　有益な鼠　北米に産する地鼠の一種に尻尾の短いのがある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十二月一日『東京朝日新聞』）　　　　　　　　　四十九　　　　　　宝石の人造法　近頃仏国のポルダという人が鋼玉石の粉を変じて種々の宝石とする方法を発見した。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年一月一日『東京朝日新聞』）　　　　　　　　　五十九　　　　　　結核病と食物　結核菌を接種した動物に種々の食物を与えて病の経過を試験した結果によると、脂肪分を主に与えたものは四十日くらいで死し、含水炭素殊に砂糖を多く与えたものは八十七日くらいで死んだ。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年五月一日『東京朝日新聞』）　　　　　　　　　七十六　　　　　　空中の巡査　近刊の某地学雑誌に上のような表題を掲げて鳥類の保護を論じている人がある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから去る四月一日付をもって山中伍長は軍曹に進級しとるからそのつもりで。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた、この金をこの月一杯で一万五千円にすることはできない。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸軍病院で――彼は、そこに勤務していた――毎月一円ずつ強制的に貯金をさせられている。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月一日に農村であったことである。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月一日の朝のことである。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月一日に入営する。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年九月一日｜被服廠跡で起った火焔の渦巻を支配したと同じ方則がここにも支配しているのだろうと思って、一生懸命に眺めていたが、この模糊とした煙の中から、そう手取早く要領を得た方則を読取る事は容易な仕事ではないのであった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃の相場では、妾奉公をしても月一両の給金はむずかしいのに、別になにをするでも無しに、美しい着物を着せられて、旨いものを食わされて、一日一両の手間賃になる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二五、四月一日　火曜日　晴今日から新らしい一｜学期だ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東震災に踵を次いで起こった大正十二年九月一日から三日にわたる大火災は明暦の大火に肩を比べるものであった。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月一日は帝都の防空演習で丸の内などは仮想敵軍の空襲の焦点となったことと思われる。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さわやかな九月一日の朝でした。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
