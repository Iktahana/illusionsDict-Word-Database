        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何うして蜻蛉に釣られるやうでも、馬車だと然うは呼吸が續かぬ。",
              "citation": {
                "source": "麥搗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蛸を釣られる」のだろうと、度胸を決めて、しかしさすがに蒼い顔をして行くと、校長は、「君に相談があるのや。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその途方もない握り飯に釣られると、一円三十銭だけ、一昼夜でもらえるのであった！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷吉は傷が釣られるやうに障るので、目を閉つては開けて、すべての容子を納得するために、そろり／＼順々にあたりを見た。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな連中が、こんな品物に釣られる程度に東京慣れしない田舎者で、しかも、懐具合いは割り合いにいい事が推測されるであろう。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "９欝金色の月に釣られる　盲目の　ただよへる薔薇。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎者が春画を見てては釣られるのです。",
              "citation": {
                "source": "江戸か東京か",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "當今思ひつき專門の雜誌が、有島兄弟號谷崎兄弟號長田兄弟號を出し、物好きな世間がそれに釣られる心持を、自分は自分自身持つてゐる事を拒め無い。",
              "citation": {
                "source": "貝殼追放",
                "author": "「八千代集」を讀む",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣られる衆愚も悪いが、こういう事を平気でやる日本出版協会は果たして出版界の利益や将来を考えているものといえるだろうか。",
              "citation": {
                "source": "日本出版協会論",
                "author": "嶋中雄作",
                "note": "青空文庫"
              }
            },
            {
              "text": "養蚕時が来れば、寺の本堂の側に蚕の棚が釣られる。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな横好きで下手な連中に釣られる岩魚がいるだろうかとおかしくなる。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人は二人に支えられながら、釣られるように、利かない足を運ばして、窓の方へ近寄ってくる。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まず女が同距離に釣られると仮定します。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すると、下手人は無いことになるぢやないか、――誰が一體綱を切つたんだ」　平次も釣られるともなく、斯んなことを言ふ外はありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美しき鎌いたち",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しあつたとしたら、小名木川の鱚位のもので」「何んだえ、それは」「番毎仲間が釣られるから」「下らない事を言やがる」　二人は無駄の掛け合ひでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "釣針の鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　平次はツイ釣られるともなく口を容れました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "兵庫の眼玉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「筒井、筒井、」　筒井は愕然として髪の根を釣られるような緊迫した一瞬の中にあった。",
              "citation": {
                "source": "津の国人",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "さア」「刀の手前、この儘引込むわけには行かぬな」　井崎八郎と白狗の勘次は、平次の僞手紙に釣られるとも知らず、宵闇の中を相生町から深川の方へ向ひました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "濡れた千兩箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりの評判に釣られるともなく、半日の春を小屋の中の空氣に浸つた、捕物の名人で『錢形』と異名を取つた御用聞きの平次。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "振袖源太",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりの評判に釣られるともなく、半日の春を小屋の中の空気に浸った、捕物の名人で「銭形」と異名を取った御用聞の平次、夕景から界隈の小料理屋で一杯引っかけて、両国橋の上にかかったのはもう宵の口。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "振袖源太",
                "note": "青空文庫"
              }
            },
            {
              "text": "人面白くもねえ、大夕立の中で立廻りまでさせやがって、三千両の手間にたった一両とは何だ」「俺のせいではないぞ」「だから、怒鳴り込んでやりましょう、さア」「刀の手前、このまま引っ込むわけにはいかぬな」　井崎八郎と白狗の勘次は、平次の偽手紙に釣られるとも知らず、宵闇の中を相生町から深川の方へ向いました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "濡れた千両箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の大名方のお使者や、家中お歴々とても同じことだ」「そう言えばそうですが、易々と御金蔵へ入るのは、係り役人の外には出来ないはずじゃございませんか」　平次も釣られるともなく言い募りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "忍術指南",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　平次は釣られるように膝をすすめました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "忍術指南",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ツイ釣られるともなく、およつも縁先へ泳ぎ出しました。",
              "citation": {
                "source": "芳年写生帖",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその日もふらふらと釣られるように彼女の家の前までくると、家の内部は寂然として、気のせいか女の声らしい話しごえがしているようであった。",
              "citation": {
                "source": "性に眼覚める頃",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣は釣る人の心を統一すると共に、釣られる魚の心を集中しなければならぬ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ、おい、またか」半三郎は一尾の鮠を握って云った、「おまえさっき放してやったばかりじゃないか、ばかだね、いま釣られたばかりでまた釣られるなんてまぬけなやつがあるかい、おい、しっかりしてくれ」　彼はその鮠を放してやった。",
              "citation": {
                "source": "鵜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "内藤なんかに釣られる魚はりこうではないにきまっている」　と照彦様がくやしがった。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世の見おさめに、したい放題な事をして――と、そッちこッちで、手出しをしてみるけれど、十年も島暮しをしていたせいか、むかしのように勘も働かないし、体もしなやかに動けないので、稼ぎはさッぱり上がらないし、厚化粧して、盛り場を歩いても、もうこんな年増には、釣られるような男もない。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その宝物は、伊豆志の大神という名まえの神さまにしてまつられることになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
