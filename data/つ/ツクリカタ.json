    "definitions": [
      {
        "index": 1,
        "gloss": "style of building",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その兜の作り方が三通りぐらゐあつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の冬それを作つてみようとしたがその何の作り方も覚えてはゐなかつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に変った作り方でもなかったが、炊き立ての麦飯の香ばしい湯気に神仙の土のような匂いのする自然薯は落ち付いたおいしさがあった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きわめて卑近の一例を引いてみれば、庭園の作り方でも一方では幾何学的の設計図によって草木花卉を配列するのに、他方では天然の山水の姿を身辺に招致しようとする。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し作り方なり材料なりを親切に研究したのなら、これほどもろくできるはずはないだろうと思われた。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君の菊の花の作り方には、なんだか秘密があるやうだ。",
              "citation": {
                "source": "清貧譚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、子｜供向きに寫眞の沿革から撮影、現像、燒｜付の法、それに簡單な暗箱の作り方までを説明してある。",
              "citation": {
                "source": "寫眞と思ひ出",
                "author": "――私の寫眞修行――",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは老女中のお島からその作り方を聞き、何という残忍な料理法だろう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その作り方は、土龍、井守、蝮蛇の血に、天鼠、百足、白檀、丁香、水銀郎の細末をまぜて……」　そんな陰謀があるとは、知らぬが仏の奈良の都へ、一足飛びに飛んだ佐助は、その夜は大仏殿の大毘盧遮那仏の掌の上で夜を明かした。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり長くなりそうだから、手紙はよして、小包だけにすることにしたがしかし、時計を送る小包というのはどうも作り方がむずかしい。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「種に佳くないという種はないのですが、作るのは人にあるのですから」　そこでいっしょに菊の作り方を話しあった。",
              "citation": {
                "source": "黄英",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬はひどく不思議に思って、「ぜひ、その作り方を教えてください」　と言ってしきりに頼んだ。",
              "citation": {
                "source": "黄英",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど運動場にひどく木の葉が散らかっているから、これを掻き集めて堆肥の作り方を練習……」　生徒たちが、わっ！",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動場の落ち葉を掻き集めて堆肥を作ると、第一に運動場が奇麗になるし、第二には材料費がいらないし、堆肥ができて、堆肥の作り方が覚えられて……」　生徒たちは一度に笑いだした。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僕も、あの手紙の作り方は知っているつもりです。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした成果を踏まえて、同社は今、新しい本の〈作り方〉を示そうとする。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば牛肉を使った料理ならこんなもの、中華料理ならこれと、いろいろな角度からリストを出させ、そこで選んだ料理の作り方を画面で見ていこうという狙いでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＷＷＷのホームページは、作り方に約束事があります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この電子本の作り方なら、しっかり頭に入っている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "一品生産的なハードの作り方はここでも変わっていなかったし、価格も技術屋連中が「どうやって上司をだまそうか」と頭を捻るレベルだった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸のままのＭＳ―ＤＯＳでは、インターフェースの作り方は全面的にアプリケーションの書き手に任されてしまう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子の高弟七十二人、樊遅がその中に在るかどうか確かでないが、樊遅かつて穀物の作り方について教えを請い、次に野菜作りについて教えを求めた『論語（子路四）』。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いろんな歌の手引き草とか、歌に使う名所の名とかの集めてあるのを始終見ていて、その中にある言葉を抜き出して使う習慣のついている人は、それよりほかの作り方ができないものと見える。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一顔の作り方一つ知らねえ』とかそれはそれはひどい悪口ばかり云っていました。",
              "citation": {
                "source": "ある恋の話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が八歳の冬まで生きておいでになりましたお祖母様や、オセキ婆さんや、人様のお話によりますと、お母様は井ノ口家のたった一粒種で御座いましたが、七歳の時に御自分の初のお節句にお貰いになった押絵の人形をこわして見て、それを又作り直してひとり手に押絵の作り方をお覚えになったのだそうです。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この薬の作り方は誰も知っているものはありません。",
              "citation": {
                "source": "若返り薬",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の作り方、ことに商店の看牌や店飾りのたぐいが、今と昔とはほとんど比較にならないほどに華やかになった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "家のうしろには葡萄園があるそうですが、表構えは茶店のような作り方で、ここでは登山者に無代で梅酒というのを飲ませます。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその刷る繪の線により面によつて、バレンの作り方も違つてゐるのださうだ。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "作意派の筆法を稽古すると、古來から相傳の筆を用ひ、相傳の法に檢束される必要があるけれども、率意派によると云ふことになると、總てのものを廢して、さうして勝手に自分で適當なる方法と考へた所で、其の筆の用ひ方、筆の作り方も總て自由にやることが出來るから、それで一時大に行はれるに至つた。",
              "citation": {
                "source": "北派の書論",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
