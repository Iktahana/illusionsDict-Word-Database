          "literary": [
            {
              "text": "下賤なもののけんかはけんかする同志がつかみ合う、蹴る、なぐる、やがてどちらか一方が鼻血でも出せば事がすみますがのう。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで世間無知の輩は、早くもいっさい万事これ金なりと心得、義理も人情も打ち捨てて互いに金をつかみ合うさま、飢えたる獣の腐肉を争うがごときに至る。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "里にいる女の話まで出て、まるで獣物みたいにつかみ合う者さえある。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらがたがいに飛びついてつかみ合う。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "つかみ合うのは、双方とも黒い洋服姿。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
