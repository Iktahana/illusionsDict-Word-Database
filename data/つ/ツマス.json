        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "将棋の対局で、プロ棋士は相手の王を鮮やかに詰ました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの手を使えば、確実に相手を詰ますことができるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は冷静に相手の弱点を見抜き、じわじわと王を詰ましていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "よもぎ苗あかずつますと。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼女のいわゆる盲目と醜悪とを、ますます重ねしめかつますます増さしめて行くのだ。",
              "citation": {
                "source": "男女関係について",
                "author": "女房に与えて彼女に対する一情婦の心情を語る文",
                "note": "青空文庫"
              }
            },
            {
              "text": "法螺はただ一つますます高く月の下を鳴り続けた。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方には南方の大きい入道雲がいつの間にか消えて、北東の高い入道雲がやや東方に移りつつますます大きくなった。",
              "citation": {
                "source": "地異印象記",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
