    "definitions": [
      {
        "index": 1,
        "gloss": "(way of) literary composition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
