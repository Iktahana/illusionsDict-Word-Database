        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "動物園で珍しい土豚が、長い鼻で地面を掘り返しているのを見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「土豚は夜行性で、主にアリやシロアリを食べるんですよ」とガイドが解説した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "アフリカのサバンナでは、土豚が作る巣穴が他の動物たちの隠れ家にもなることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "アフリカの蘆原に穴居する蘆鼠は、アウラコズス属の鼠で肉味豚に似るから土豚の称あり。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "……正義は土豚のやうに盲目なのか？",
              "citation": {
                "source": "澄江堂雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四回　昨日は富家の門を守りて、頸に真鍮の輪を掛し身の、今日は喪家の狗となり果て、寝るに※なく食するに肉なく、夜は辻堂の床下に雨露を凌いで、無躾なる土豚に驚かされ。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "其｜守庭吏と爲るや、庭中に土豚を設けて、掃除を事とせず。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台には役者を要し、土豚には力士を要す。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "土豚に役者の不恰当なるは、なお力士の舞台に不恰当なるが如し。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
