[
  {
    "uuid": "26c0b027-94a5-56bf-961c-cc739ab3d860",
    "entry": "追従",
    "reading": {
      "primary": "ついしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "flattery",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして「失礼でございませうが、私は日本の酒は飲めないんで……」と言つて、「イヒヽヽヽ」と追従笑ひをした。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し詳しく立止まって見たいと思う者があっても、大勢に追従して素通りをしてしまわなければならない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことによると、実は自分自身の中にも、そういうふうに外国人に追従を売るようなさもしい情け無い弱点があるのを、平素は自分で無理にごまかし押しかくしている。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "にこにこ卑しい追従笑いを浮べて、無心そうに首を振り、ゆっくり、ゆっくり、内心、背中に毛虫が十匹｜這っているような窒息せんばかりの悪寒にやられながらも、ゆっくりゆっくり通るのである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "野蛮ですねえ」　と言わんばかり、ひたすら私の気に入られようと上品ぶって、ぶるっと胴震いさせたり、相手の犬を、しかたのないやつだね、とさもさも憐れむように流し目で見て、そうして、私の顔色を伺い、へっへっへっと卑しい追従笑いするかのごとく、その様子のいやらしいったらなかった。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前と違って、矢鱈に私にお追従ばかりおっしゃるので、私は、まごついて、それから苦しくなりました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖書辞典に拠ると、「悪鬼とは、サタンに追従して共に堕落し霊物にして、人を怨み之を汚さんとする心つよく、其数多し」とある。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "サタンにお追従を言うところなぞ、そっくりじゃないか。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "追従にいってるんでねえぞ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と溶解けんばかりの顔色を、銀平は覗きて追従笑い、「ひひひひ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　槌で庭掃く追従ならで、手をもて畳を掃くは真実。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい、はい、いえ、御坊様の前で申しましては、お追従のようでござりますが、仏様は御方便、難有いことでござります。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰命頂礼、賽ころ明神の兀天窓、光る光る、と追従云うて、あか柄杓へまた一杯、煽るほどに飲むほどに、櫓拍子が乱になって、船はぐらぐら大揺れ小揺れじゃ、こりゃならぬ、賽が据らぬ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫も杓子もこれに追従するか、もしくはこれを楯に取る。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも初枝女史は、実に筆者の実姉にあたり、かつまた、筆者のフランス語の教師なのでありますから、筆者は、つねにその御識見にそむかざるよう、鞠躬如として、もっぱらお追従に之努めなければなりませぬ。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤高だなんて、あなたは、お取巻きのかたのお追従の中でだけ生きているのにお気が附かれないのですか。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "オフィリヤの親爺のご機嫌をそこねたくないばかりに、それはいい考えだなんてお追従を言って、ホレーショーにも賛成を強要し、三人で朗読の稽古をはじめたのは、きょうの昼過ぎだ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」僕は、ちょっとお追従笑いをしてしまった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私はまた下手なお追従を言った。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」お追従笑いなどをして、有原の美しい顔を、ほれぼれと見上げる。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、えへへ、と実に卑しいお追従笑いをしたようです。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と熊本君にまで卑しいお追従を言ったのである。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一点にごらぬ清らかの生活を営み、友にも厚き好学の青年、創作に於いては秀抜の技量を有し、その日その日の暮しに困らぬほどの財産さえあったのに、サラリイマンを尊び、あこがれ、ついには恐れて、おのが知れる限りのサラリイマンに、阿諛、追従、見るにしのびざるものがあったのである。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソノ所以ハ」「サレバ、友ヲ選ベバ悪人、交レバ阿諛追従ノ徒ニ若クハナシトハ、下界人間共ノ以テ金言ト成ス所ナリ。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿ニ似テ非ナル猿面冠者ハオノガ立身出世ノタメニハ、主人ヨリ猿々ト呼ビ捨テラレルモ、ヘイヘイト追従笑ヒナド泛ベタルハ、即チ羞恥ヲ知ラザル者ト言フガ如シ。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、顧みて日本の文壇を考えると、今なお無気力なオルソドックスが最高権威を持っていて、老大家は旧式の定跡から一歩も出ず、新人もまたこそこそとこの定跡に追従しているのである。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "年内に江戸表へ送金せねば、家中一同年も越せぬというありさま故、満右衛門はほとほと困って、平野屋の手代へ、品々追従賄賂して、頼み込んだが、聞き入れようともせず、挙句に何を言うかときけば、「――頼み方が悪いから、用達出来ぬ」　との挨拶だった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日本ラインという名称は感心しないね、卑下と追従と生ハイカラは止してもらいたいな。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、彼は、上級生の一寸した冗談をさも面白そうに笑ったりする私達の態度の中に「卑屈な追従」を見出して、それを苦々しく思っているに違いないのだ。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり現在の人間がやっているおべっかやお追従は、人間が動物から進化して純愛の一大団結たるべき下稽古――霊的文化の世界を組織すべき手習いをやっているものと見るが至当でありましょう。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
