        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "立止って気をつけて見ると、頭に突き出た大きな眼は、怪しいまなざしに何物かを呪うているかと思われた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を始めて気づいて驚いている私の鼻の先に突き出た楓の小枝の一つ一つの先端には、ルビーやガーネットのように輝く新芽がもうだいぶ芽らしい形をしてふくらんでいた。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "裾野の草が、人の軒下にはみ出るさびしい町外れとなって、板びさしの突き出た、まん幕の張りめぐらされた木造｜小舎に、扶桑本社と標札がある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔面に対してかなり大きな角度をして突き出た三角形の大きな鼻が眼に付く。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊予の西の端に指のように突き出た佐田岬半島と豊後の佐賀の関半島とは、大昔には四国から九州につながった一つの山脈であったのが、海峡の辺の大地が落ち込んだためにあのような半島とこの豊後海峡が出来たという事です。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の重い籠を壁の突き出たところに置いて憩うてゐる老婆もありました（ほんたうに小さな老婆で、彼女の眼は沼のやうに干上つてゐました）。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が見付けた時にはそれがもうほとんど毛虫だか何だか分らないような団塊になっていたが、ただその囲りから突き出た毛束によってそう考えられたのである。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、突き出た岩で頭を打たないように用心しながら、その斜坑を這い上った。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンテラを突き出た岩に引っかけると、いきなり無言で、彼女をたくましい腕×××××。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "突き出た大きな岩の手前まで来ると、その声はいよいよ鮮になった。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "不精者らしいことは、その大きく突き出た顎のじじむさいひげが物語っている。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "早生れの安子は七つで小学校に入ったが、安子は色が白く鼻筋がツンと通り口許は下唇が少し突き出たまま緊り、眼許のいくらか上り気味なのも難にならないくらいの器量よしだったから、三年生になると、もう男の子が眼をつけた。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「‥‥」渠はそれには答へず、弟が唐ばさみを持つて來たのを受け取つて、先づ二三ヶ所の途方もなく突き出た青い枝を切つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "餘分に突き出たひさしの下からじツとこちらを見詰めるところは底意地が惡いのを表するのか、さうでなければ、豫想通り目かけにでもなつてやらうかと云ふ意味だ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "東の縁がはから見える八幡山の樹木から漏れる光りが、隣りの庭から突き出た二三葉の芭蕉のひろ葉に當つて、その葉の青い色が明るいつやを帶びてゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈の光りに、突き出た髮のひさしが大きく義雄の向つてゐるふすまの裾の方は寫つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "長寿の印しといわれる、長くぴんと突き出た眉の下に、大きい眼がくぼんでいる。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "参詣者はその背中に突き出た瘤のようなものの上で椰子の殻を割って、その白い粉を額へ塗るのだそうな。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭に臨んだ座敷のはずれに三畳敷きばかりの突き出た小室があって、しゃれた丸窓があった。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ婆様、ひどく弱ったでねえが……」　弥平は、頬骨の突き出た白髪の頭をお婆さん方へ寄せた。",
              "citation": {
                "source": "蜜柑",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "短刀はわずかに突っ立ったばかりで、柄が蔦代の掌の中から突き出た。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうかなりの年輩の、鼻は細くて高く突き出た、額は高くて禿げ上った、そして大きな灰色の髭のある男、――。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼瞼の皮肉に垂れ下がった、狂暴な青い目、鋭い圧倒的に突き出た鼻、威嚇するような太い線の刻まれた額、――と云うものは、何と云っても驚くべき、先天的な兇激性の具象であった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "勉強のしすぎから撫で肩で、そして前に突き出た顔面は、物珍しい爬虫類さながらゆらゆらと左右に絶えず揺れている。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の居間ときめられた離宅は海の中に突き出た樣な位置に建てられ、三方が海に面してゐた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "程なく右手に突き出た岬のはなの沖合に何やら大きな旗をたてた一艘の發動機船の姿が見えた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く、遠く突き出た岬のはな、右も、左も、まん前もすべて浪、浪、僅かに自分のしりへに陸が續く。",
              "citation": {
                "source": "樹木とその葉",
                "author": "空想と願望",
                "note": "青空文庫"
              }
            },
            {
              "text": "右を見ても左を見ても眼のとどくかぎり、恐ろしいくらいに黒い突き出た絶壁が、この世界の城壁のように長くつらなっている。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が前に言ったとおり、もしも理性が真実なものを探して進むのならば、常套なものの面から突き出たものを手がかりにすることによってであって、また、こういった事件についての正しい質問は、『どんなことが起ったか？",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に、一方の壁には、穴蔵の他のところと同じようにしてある、見せかけだけの煙突か暖炉のためにできた、突き出た一カ所があった。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
