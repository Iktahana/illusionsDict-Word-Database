    },
    "definitions": [
      {
        "index": 1,
        "gloss": "worn-out (as opposed to sleepy)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「お腹を拵へないことには、手伝つても貰へまいから、まづお午御飯だが、あの七輪にタンと火を起こして頂戴」「あゝ疲れた疲れた」と云つてパツタリ坐る。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れ既に生活して、長く既に疲れたれども、軍務の歸すべき港を知らず。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会の夏の夜月は空にメダルのやうに、街角に建物はオルガンのやうに、遊び疲れた男どち唱ひながらに帰つてゆく。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は疲れた顔を、帯の輪の間に突っ込んで、深い眠りに眠りこけていた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "今行くよ」「お前、又長くなるのじゃあるまいね」　病み疲れた、老い衰えた母は、そう訊ねることさえ気兼ねしていたのだが、辛抱し切れなくなって、囁くように言った。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋の中で、ビチビチ撥ね疲れた鰌だった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は自分などのやうに、うるさく騷がしい都を離れて、しばらく疲れた頭を休める爲にかういふ山中の自然を索ねて來るものゝある一方では又、東京では斷ち切れない色々の窮屈を束縛をふりちぎつて、一日だけ、はめを外づして暴れ※はる爲にわざ／＼かういふ土地を選んで來る人もあるのである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "餘りに強い日常の刺戟に疲れたものゝ眼には此のやうな眺めが又なく有難い。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "リゼットの疲れた胃袋に葡萄酒がだぶついて意地の悪い吐気が胴を逆にしごいた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼冷　俺等の心は、一諸に出会はう　俺は畑を耕し終へたとき、疲れた眼を挙げて、遠い南の土耳古玉の天末を望まう。",
              "citation": {
                "source": "〔蒼冷と純黒〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもどこかその光に青い油の疲れたようなものがありましたし、また、時々、冷たい風が紐のようにどこからか流れては来ましたが、まだ仲々暑いのでした。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく人の途絶えたときに、仏になった老人の未亡人が椅子に腰かけて看護に疲れたからだを休めていた。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論疲れた眠い顔や、中にはずいぶん緊張した顔もあるにはあったろうが、別にそれがために今のように不愉快な心持はしなかった。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈々子は大きい下駄に疲れたらしく、「お児ちゃんのかんこ、お児ちゃんのかんこ」　といい出した。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱で渇いた口に薫りの高い振出しをのませ、腹のへったものの前に気の利いた膳をすえ、仕事に疲れたものに一夕の軽妙なレビューを見せてこそ利き目はあるであろう。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "町には平凡な商家が並び、どこの田舎にも見かけるような、疲れた埃っぽい人たちが、白昼の乾いた街を歩いていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして生活といふものと正面からぶつかつて、私はすぐに疲れた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（疲れたる如く、手を額に翳す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "一羽の燕が迷ひ込んでゐて、疲れた翼を振つて、出口を捜してゐるのであつた。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんでも疲れた人、病気な人は内にいるに限りますよ。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "死骸のように疲れた佐野の衣裳に殺気が漲っています。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は空中滑走する、戦い疲れた陳独秀とビクトリア・カップよりセント・ジョウジ・プレースに至る山頂火車のなかで彼等は力なく握手して、空中の鏡の上にモーニング姿の印度人のイサックを発見するのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後の靜かな時など、よくその眼のさめるやうな青芝の上には、白い服をそよ風にひるがへした看護婦達の二人三人が、低い、けれど透き通るやうな聲で歌を口ずさみながら往き來してゐるのを、私は病み疲れた眼でぢつと眺めてゐる事があつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白粉で塗り隱した荒んだ肌、左の頬に拵へたわざとらしいほくろ、眉墨で縁取つた疲れたやうな眼の光、受け口のまつ赤な唇、まづい顏ではあつたが、相當の教育も受けたらしく、愛想交りにも日本の事を色色問ひ尋ねたりする女だつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一わたり話し終つた女は、やがて疲れたやうに沈默してしまつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「然し、演習地の雨は閉口するな‥‥」と、彼はまた疲れたやうな聲で云つた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷役に忙しい樺太や釧路通ひの汽船や、白いペンキの醜く剥げ落ちた帆船の中には、舷の低い捕鯨船の疲れたやうな姿が横はつてゐる。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また其處には病み疲れた不健康な、醜い欲望に穢されきつた肉體があつた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、駈けていた積りであったのに、後から登って行く小林に追いつかれた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙よ、わたしの心はお前から遠くはなれて居ない、わたしは手に燈灯をもつて、くらい庭の面を眺めて居た、雨にしほるる草木の葉を、つかれた心もちで眺めて居た。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
