[
  {
    "uuid": "94093f1a-4062-57e3-a326-237b03e17c11",
    "entry": "疲れた",
    "reading": {
      "primary": "つかれた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
