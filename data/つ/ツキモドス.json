        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうすると、今度は川越の屋敷から本人を突き戻すと云って来ました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "川越次郎兵衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうだナ――」頤髯男は、どッと、ぶつかってくる避難民の一人を、ウンと突き戻すと、クルリと後を向いて、夜光時計の文字盤を眼鏡にスレスレに近づけた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、いやだ」と妻君は顔をしかめて、主人の手を突き戻す。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "賣つた人間へ突き戻すだけでは胸が治らなかつたんだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "茶碗割り",
                "note": "青空文庫"
              }
            },
            {
              "text": "売った人間へ突き戻すだけでは胸が治まらなかったんだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "茶碗割り",
                "note": "青空文庫"
              }
            },
            {
              "text": "十さじばかりも茶をすすると、彼はふいに頭を振り放して、気まぐれな様子でさじを突き戻すと、また枕の上へ身を倒した。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
