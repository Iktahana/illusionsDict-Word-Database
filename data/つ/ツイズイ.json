    "definitions": [
      {
        "index": 1,
        "gloss": "following (in the footsteps of)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
