        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その力を知られると牛は必ず用いられて、その筋骨は疲れ果てる。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れ果てるまで跳びまはり升たあとで、フト思ひつき、母に貰ふた甲斐絹の切で三ツの袋を拵らへに取り掛り升た。",
              "citation": {
                "source": "黄金機会",
                "author": "若松賤子",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れ果てるほどの旅程でもない。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい疲れ果てるくらい緊張していたとしても、四日間とはあまりに少なすぎる。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもであれば、一日の仕事で疲れ果てるので、夜一〇時過ぎには床に就くのだが、いま午前三時過ぎ。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ未婚女の仕事に疲れ果てる。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
