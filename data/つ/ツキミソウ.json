    "definitions": [
      {
        "index": 1,
        "gloss": "fourwing evening primrose (Oenothera tetraptera)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "月見草の花が白い、カケス畑を知らぬ間に過ぎて、自動車はスケッチ帳入りの小嚢を手に下げた茨木君と私と長男隼太郎外、強力一人を大野原に吐き出して、見送りのため同乗せられた大山さんと、梅月の主人をさらって、影を没してしまう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰度月見草が一時に開くころである。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "咲いた月見草の花を取って嗅いでみてもそんな匂いはしない。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "月見草が幻よりは少し明るくその辺一面浮んで咲いてゐる。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもやがて月が頭の上に出て月見草の花がほのかな夢をたゞよはしフィーマスの土の水たまりにも象牙細工の紫がかった月がうつりどこかで小さな羽虫がふるふ。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "虹の脚にも月見草が咲き又こゝらにもそのバタの花。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "草がくれの艫に、月見草の咲いた、苫掛船が、つい手の屆くばかりの處、白砂に上つて居て、やがて蟋蟀の閨と思はるゝのが、數百一群の赤蜻蛉の、羅の羽をすいと伸し、すつと舞ふにつれて、サ、サ、サと音が聞こえて、うつゝに蘆間の漣へ動いて行くやうである。",
              "citation": {
                "source": "十和田の夏霧",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふの岸には月見草も咲いてゐました。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "堤には月見草が処まだらに生えて居た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもまもなくお日さまがあすこをお通りになって、山へおはいりになりますと、あすこは月見草の花びらのようになります。",
              "citation": {
                "source": "めくらぶどうと虹",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "行水の花の夕顏、納涼臺、縁臺の月見草。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しをらしいのは、あちこちに、月見草のはら／＼と、露が風を待つ姿であつた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝを通拔けつゝ見た一軒の低い屋根は、一叢高く茂つた月見草に蔽はれたが、やゝ遠ざかつて振返ると、その一叢の葉の雲で、薄黄色な圓い月を抱くやうに見えた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "椹野川にそうて散歩した、月見草の花ざかりである、途上数句拾うた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は散歩と云うと大抵町｜端れの月見草が一っぱい生えている丘へ行った。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "月見ヶ丘には恰度月見草がさかりであった。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷦鷯のやうに敏捷に身を飜して、楊柳や月見草の叢を潜り、魚を漁つてゐる漁師たちに訪ね合はしてゐる直助の紺の姿と確かりした声が、すぐ真下の矢草の青い河原に見出された。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい庭下駄をはいて、團扇をもつて、月見草を眺めてゐる少女は、いかにも弟と似つかはしく思はれた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい庭下駄をはいて、団扇をもつて、月見草を眺めてゐる少女は、いかにも弟と似つかはしく思はれた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また夜會草や月見草の如く暮に及んで張るものもあるが、要するに朝より晝に及んで氣の張るものは多い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、一夏縁日で、月見草を買って来て、萩の傍へ植えた事がある。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏瓜、夕顔などは分けても知己だろうのに、はじめて咲いた月見草の黄色な花が可恐いらしい……可哀相だから植替えようかと、言ううちに、四日めの夕暮頃から、漸っと出て来た。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "前年の月見草で心得て、この時は澄ましていた。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、これは、桜貝、蘇芳貝、いろいろの貝を蕊にして、花の波が白く咲きます、その渚を、青い山、緑の小松に包まれて、大陸の婦たちが、夏の頃、百合、桔梗、月見草、夕顔の雪の装などして、旭の光、月影に、遥に（高濶なる碧瑠璃の天井を、髪｜艶やかに打仰ぐ）姿を映します。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、どてら着て山を歩きまはつて、月見草の種を両の手のひらに一ぱいとつて来て、それを茶店の背戸に播いてやつて、「いいかい、これは僕の月見草だからね、来年また来て見るのだからね、ここへお洗濯の水なんか捨てちやいけないよ。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことさらに、月見草を選んだわけは、富士には月見草がよく似合ふと、思ひ込んだ事情があつたからである。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆も何かしら、私に安心してゐたところがあつたのだらう、ぼんやりひとこと、「おや、月見草。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつと、バスは過ぎてゆき、私の目には、いま、ちらとひとめ見た黄金色の月見草の花ひとつ、花弁もあざやかに消えず残つた。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いてしらん、ぎしぎし、たちあおい、かわほね、のいばら、つきみそう、てっせん、かなめ、せきちくなどが咲き、裏の畑の桐の花は高く薫った。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
