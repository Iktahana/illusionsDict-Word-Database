    "definitions": [
      {
        "index": 1,
        "gloss": "to push up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "寝転んで、始め鼻を当てると突き上げるやうな蕊のにほひ、それにも徐々に馴れて来る。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、ある苛酷な夢の記憶が私の胸の底から突き上げる。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "こら昔何とか大夫ちう浄瑠璃のお師匠はんがひらいた店でな、一杯｜山盛にするより、ちょっとずつ二杯にする方が沢山はいってるように見えるやろ、そこをうまいこと考えよったのや」蝶子は「一人より女夫の方がええいうことでっしゃろ」ぽんと襟を突き上げると肩が大きく揺れた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、暑いの、暑くないのって、ほんまにやり切れんかった」鼻を抜ける声で言って、眼鏡を突き上げると、「さあ、馬力を掛けて行こか。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして開いた鋏の刃の間に虫の袋の口に近い所を食い込ませておいてそっと下から突き上げると案外にうまくちぎれるのであった。",
              "citation": {
                "source": "簔虫と蜘蛛",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レスパネエ夫人の力では、娘の死体をあんなふうに煙突のなかに突き上げるなんてことはとてもできまいし、また彼女自身の体についている傷の性質から言っても、自殺などという考えをぜんぜん許さないものなんだからね。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "死体を煙突へ突き上げるというやり方には、なにかひどく異様なところ――たとえそれをやった奴が人間のなかでもっとも凶悪な奴と想像してみても、なにか人間業という普通の考え方とはまるで相容れないもの――があることを、君は認めるだろう。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが焼け跡に燃え盛る練炭の山を見つけた途端、冷水でも浴びせられたように失ったものの大きさにうたれ、突き上げる悔しさに胸を焼かれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅々として進まないヴィデオの導入を会社に突き上げる一方で、パイオニアがレーザーディスクという新しい映像技術に取り組んでいると聞くと、興味が募りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠の氷に掩われている地極の底にも、火山を突き上げる猛火は燃えている。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "見せ槍が済むと、今度はほんとうに右と左の腋の下から何遍となく、ずぶりずぶりと突き上げるのだ。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、何かしら心臓へぐっと、突き上げるものを感じた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本は、小学校三年生で並三ラジオを完成させたときの突き上げるような喜びを思い起こし、この主張に完全に同意した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか、胸を突き上げる気持ちだった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か、胸がズンと突き上げる気持ち、口の飯が古綿のように拡がって、火のように涙が噴きこぼれた。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "南支那海の三角波というのは、チョウド風呂敷を下から突き上げるような恰好に動くものだそうで、船首に落ちかかる波の頭だけでも大きいのは十｜噸ぐらいの力がある。",
              "citation": {
                "source": "幽霊と推進機",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾度も／＼上厠するのを、深夜に氣づかはれまいとするうちに、弱い胃は下から刺戟されて、突き上げるやうになる。",
              "citation": {
                "source": "煎藥",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ほっと、安心し、呼吸をついだ時「馬鹿がっ」　それは、大きく、鋭く、月丸の肚の中を、拳で突き上げるように、響いた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際その夥しい木賊はＮさんの言葉に従えば、「胡麻竹を打った濡れ縁さえ突き上げるように」茂っていた。",
              "citation": {
                "source": "春の夜",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "池田良斎はそれを聞いて、「とにかく、熊の下腹まで行って槍を突き上げるとは非常な冒険だ、へたに運命を見届けているより、獲物は外れても、逃げて帰ったのが何よりだ」と言いましたけれども、猟師は、なかなか諦めきれないらしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井板をずばりずばり鎗で突き上げる。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人はぐっと目の底から突き上げる熱いものを抑え、出ぬ声をしぼり出して夫の笑い声に合わせて笑った。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと一緒に、肩で、相手の頤の下を突き上げるやうに押す。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょいと斜めに小襟を突き上げると、　はあくしゃん！",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "男がカツとなつたところへ、頭の上の羽目板へ矢文を結んだ矢が突つ立つた、――こいつが邪魔をするのだ、と思ふと、前後の見境もなく、その矢を拔いて下から突き上げるやうにお駒の喉を突いた」「――」　二人は固唾を呑みました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "――女の胸を下から突き上げるのは、子供か、一寸法師か――」「犬だろうよ」　三輪の万七はニヤリニヤリと笑います。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "男がカッとなったところへ、頭の上の羽目板へ矢文を結んだ矢が突っ立った、――こいつが邪魔をするのだ、と思うと、前後の見境なく、その矢を抜いて下から突き上げるようにお駒の喉を突いた」「…………」　二人は固唾を呑みました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「欄干に凭れた人間を、刃物で突き上げる工夫があるか」「そいつは無理ですよ、親分、あっしの腕が二間以上も伸びなきゃ」「其処に踏留っては居られるだろう」「この通りで」　八五郎は両手を遊ばして、千番に一番の兼合いみたいな格好になりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人違い殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡は、ゆき子の手についてゐる血を見て、急に瞼につきあげる熱い涙にむせた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は肩をつきあげるようにして云った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
