[
  {
    "uuid": "9a2a3f33-bb7e-5fa2-aab1-83390a255d1d",
    "entry": "追及",
    "reading": {
      "primary": "ついきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
