    "definitions": [
      {
        "index": 1,
        "gloss": "life as evanescent as the dew",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
