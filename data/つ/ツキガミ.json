    "definitions": [
      {
        "index": 1,
        "gloss": "deity of the Moon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」とありますが、生※の産地は、宮城県玉造郡一栗村字池月の池月神社附近の方が、本当のようであります。",
              "citation": {
                "source": "文学に現れたる東北地方の地方色",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝釈かかる美婦を仙人などに添わせ置くは気が利かぬと謀叛を起し、月神チャンドラを従え雄鶏に化けて瞿曇の不在を覘い、月神を門外に立たせ、自ら瞿曇に化け、入りてその妻と通じた処へ瞿曇帰り来れど月神これを知らず、瞿曇現場へ踏み込み、呵して帝釈を石に化し千の子宮を付けて水底に沈めた。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの猴を月神の使者としその社に飼った。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "諏訪大神遊猟の跡というので毎年九月神事があるそうだ。",
              "citation": {
                "source": "女子霧ヶ峰登山記",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、シン（月神）の神よ、汝のみひとり高きよりの光を汝こそ光を人の世に恵み給わめ、………………………………………汝が光は、汝の初めの御子なるシャマシュ（太陽）の輝きのごとく麗わしく、汝が御前には神々も塵の中に横たわる。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "この死体が越えて六ヵ月目に浮き上って、何者とも知れない自殺死体となって埋葬せられ、それから三年目の大正六年二月神楽坂署の手で発掘せられたのである。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（中略）又飯山寺社記には伊弉諾伊弉册の二神日神月神蛭兒素盞嗚等を生給ふ地なるゆへに産生といふと作れり。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年三月神奈川條約が成つたが、幕府もいろいろと難儀した。",
              "citation": {
                "source": "愛國歌小觀",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は、由来記を信じれば、月神が穀物の神とせられてゐる例は、各国に例のあること故、御月の御前に宛てゝ考へることが出来さうである。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此月読神は恐らく山城綴城郡の月神で、帰化漢人の祀つたものゝ事であらうと言ふ推定から、此変若水の思想は、其等帰化人の将来した信仰が拡つたものであらうと言ふ仮説を立てゝゐた。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "月神の出現を示すのである。",
              "citation": {
                "source": "「ほ」・「うら」から「ほがひ」へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚オガミに就ては両神山の条に述べてある）、及真壁郡下郷谷字八竜神の竜神社、新治郡中村の竜神社等は、すべて※神崇拝の民族が住まっていたことを示している一方に於て、農業の神である月神即ち月読尊を奉洞した民族のいたことも疑いなく、前者はモン・クメール、後者はチアム民族である。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角彼等は東京湾の沿岸に久良岐という地名と共に※蛇崇拝の跡を止めたこと、恰も少し後れて渡来したらしいチアム民族が都筑という地名に月神崇拝の跡を残したのと同様である。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此より後、日神と月神と、一日一夜隔て離れて、住むに至れりと。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本神話に於ては、素盞嗚尊は其性質の或部分に於て、月神たる月読神と融化したり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "月神は男性にして、日神は女性なり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "南太洋の或地方に於ても、同じく月神は男にして日神は女なりと云い、「メキシコ」の或旧記も同じく、月を男神とす。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エスキモー」人の間に於ては、日月は兄弟にして、日神は男性とせられ、月神は女性とせらる。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日神と月神とに就ては、既に述べたり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一所は忌火、是れ十一月新嘗、六月神今食祭に仕奉る神なりとある、即ち是なり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "五、伊弉諾神の左眼を洗いし時に、日神化生し、右眼を洗いし時に、月神化生し、其気息よりして、風神化生す。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「來月神戸へ行く時には、外國航路の汽船に乘つて行くことにしようね。",
              "citation": {
                "source": "新婚旅行",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一商人として欧州へ　国際状態も甚だしく変化しているので昭和三年三月神戸を出帆。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときは十月神無月、出雲大社に日本全国の神々が集まって縁結びをする。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「―――今月は菊五郎あれへなんだけど、来月はありまっせ」「菊五郎は先月神戸の松竹へ来たよって見に行ったけど、東京や大阪で見るようなことあれへなんだ。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「正月二十日の棚さがし」という諺は、ずいぶん広い区域に亙って聞くことだが、これは必ずしも食えるものを掻集めるというだけでなく、この日正月神の年棚の飾りものを、いっさい取卸して始末することらしい。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "七人の正月神　しかしなお気を付けて見ると、かつてはこの正月二十四日にも、やはり伊豆七島と同じように、遠く訪れたまう神があるといい、それをまた夜話の話題としていたかと思われる形跡がある。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがずっと隔たった徳島県の祖谷山という奥まった山村では、七人の正月神という話があって、これは正月二十五日の出来事となっている。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、一般の狐つきがみな、かように説明することができるということは難しい。",
              "citation": {
                "source": "妖怪談",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
