[
  {
    "uuid": "c3fcb587-070f-5e3d-bf0c-1982e24634c3",
    "entry": "つまみ食い",
    "reading": {
      "primary": "つまみぐい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
