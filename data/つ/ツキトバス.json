    "definitions": [
      {
        "index": 1,
        "gloss": "to thrust away",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「突く」というのは投槍のように網を突き飛ばす操作をそう云ったものではないかと思う。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（重兵衛を突き飛ばす。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白い糸のような身体に、髪毛をバラバラとふり乱して、眼の玉を真白に剥き出して、歯をギリギリと噛んで、まるで般若のようにスゴイ顔つきであったが、慌てて抱き止めようとする西村さんを突き飛ばすと、踊りを止めてボンヤリ突立っているハイカラ美人に、ヨロヨロとよろめきかかった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして鼻血をポタポタと滴らしながらグッタリとなった身体を、力一パイ向うの方へ突き飛ばすと、深夜の廊下に夥しい音を立てて……ドターン……と長くなった。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、おい、休め、休め、俺が代ってやる」　木客の一人は、壮い木客を突き飛ばすようにしておいて、自分で代って、「おうウイ」　をはじめた。",
              "citation": {
                "source": "死んでいた狒狒",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の頭には乗っかる、突き飛ばす、赤銅色の漁師の腕はすり抜ける、嚊衆の洗濯物はばたつかす。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを突き飛ばすやうに振り放すと、むつくり彼女は立ちあがつた。",
              "citation": {
                "source": "神童の死",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "……屹度、その刹那に彼は、明るければ明るい程不気味な夢の中で若少し続けづには居られない何かしら弁解風な言葉を誰かに向つて放つてゐる途中が多かつた――決して、その儘では手のとゞかない隅棚の上で労働向きの真新しい目醒時計が、人を突き飛ばすかのやうに鳴り出した。",
              "citation": {
                "source": "Ｆ村での春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君、あの宮子を君は突き飛ばすことは出来ないのか。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　甲谷は宮子を芝生の上へ突き飛ばすと、立ち上った。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとも私が傍まで行つて突き飛ばすか引き戻すかしてやれば、あの男も助かつてゐたと思ひますが、何分そのときはもう度胆がぬかれてをりましたし、それに、あの貨物の音を真近で聞きますと、それやもう変な気になつて了ふのです。",
              "citation": {
                "source": "マルクスの審判",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちぼけを食ったと怒ってしまった夫は、私の背をはげしく突き飛ばすと閉ざした家へはいってしまった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このまま立ちあがると、野村さんは私の躯を足で突き飛ばすに違いないので身動きもならない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と非常な勢で私の胸を突き飛ばすのだつた。",
              "citation": {
                "source": "戯画",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝「何を突き飛ばすのだね」源「いつまでも云わずにいちゃア己が迷惑する、云いなよ」　と又突飛ばす。",
              "citation": {
                "source": "怪談牡丹灯籠",
                "author": "怪談牡丹灯籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様は不愉快だ、wachchchchch ……」　小男は金属性の響きをたてて、やにわに私を突き飛ばすやうにし、坂道の一方へ、まつしぐらに走り去つてしまふのである。",
              "citation": {
                "source": "蝉",
                "author": "――あるミザントロープの話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏天青を拾っちゃいけないよォ」　金蓮は、彼をはげしく突き飛ばすと、駅の入口の方へ走り出した。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の仲仕が戸を突き飛ばす様にして入つて来る。",
              "citation": {
                "source": "疵だらけのお秋（四幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄哥、勘弁してくんな」　身体を捻った平次、よろめく利助の後ろから、力任せに突き飛ばすと、一とたまりもなく道端の濠の中へ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "復讐鬼の姿",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、若旦那」　聲を掛ける庄八を突き飛ばすやうに、「庄八、甚助、お前達は、寄つてたかつてお糸を泥棒にする氣かい」　屹となつたのは、二十一二の、典型的な大店の若旦那です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "蝉丸の香爐",
                "note": "青空文庫"
              }
            },
            {
              "text": "「手の付けやうがねえ、――今晩は是が非でも奧の一と間を見るんだ、いゝか、八」「へエ――」「娘が側を離れなきや、假病を使ふとか、調子が出なきや横つ腹を突き飛ばすとか――」「誰ので？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "捕物仁義",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分」「手前のを、手前の拳骨でやるんだ、遠慮することはねえ」「驚いたね」「面喰つて娘の横つ腹などを突き飛ばすんぢやないぞ、馬鹿野郎ツ」「ウ、へエ――、今日は馬鹿野郎の食傷だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "捕物仁義",
                "note": "青空文庫"
              }
            },
            {
              "text": "めたん子の兄は家業の手傳ひをしてゐるが、この兄もまためたん子の顏さへ見れば、呶鳴りちらすか、突き飛ばすかして對手にしない、そんな仕打ちにも、おやぢは兄をたしなめるといふ事はなく、見て見ぬふうをしてゐる。",
              "citation": {
                "source": "めたん子傳",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次は向って来る一人の大男を突き飛ばすと、身をかわして道具裏の闇へ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幽霊にされた女",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなり水の中へ突き飛ばすに限る」「やつて見ませう」　八五郎と平次は、別々に三味線堀に向ひました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "掏られた遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チェッ、忌々しい野郎だ」　金六は突き飛ばすように、文次を放してやりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お藤は解く",
                "note": "青空文庫"
              }
            },
            {
              "text": "「手の付けようがねえ、――今晩は是が非でも奥の一と間を見るんだ、いいか、八」「ヘエ――」「娘が側を離れなきゃ、仮病を使うとか、調子が出なきゃ横っ腹を突き飛ばすとか――」「誰ので？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "捕物仁義",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分」「手前のを、手前の拳骨でやるんだ、遠慮することはねえ」「驚いたね」「面喰らって娘の横っ腹などを突き飛ばすんじゃないぞ、馬鹿野郎ッ」「ウ、ヘエ――、今日は馬鹿野郎の食傷だ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "捕物仁義",
                "note": "青空文庫"
              }
            },
            {
              "text": "（突き飛ばす）おさん　あれ。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おなかを突き飛ばす）徳之助　（おなかを庇い）何をするんだ、怪我でもしたらどうするのだ。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
