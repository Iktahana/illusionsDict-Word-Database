          "literary": [
            {
              "text": "「いや、待てよ」　それを置いて、帳面を繰返しながら、「そうそう、麹町の取立てを、元利とも払い下げの買地の方へ廻したのが付け落ちている。",
              "citation": {
                "source": "雲霧閻魔帳",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜も眠れない、疲れてはゐるが興奮してゐる、おい山頭火しつかりしろ、おちつけおちつけ！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "身心沈静、だが、まだ／＼本物ではない、おちつけおちつけ、おちつかなければ、ほんたうの句は出て来ない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "おちつけおちつけ、来ない来ない、待つてゐるもの来ないけれどおちついてゐなければなりません。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「忍ぶものは救はるべし」、おちつけおちつけ、落ちついて堪へ忍べ。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
