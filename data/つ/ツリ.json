[
  {
    "uuid": "cc2b3ed2-2a21-5e40-aaac-e68743c9317d",
    "entry": "釣り",
    "reading": {
      "primary": "つり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fishing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "魚釣幾度か釣り損ねてようやく得たる一尾に笑靨傾くる少年帰ってオッカサンに何をはなすか。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "草花に処々釣り下げたる短冊既に面白からぬにその裏を見れば鬼ころしの広告ずり嘔吐を催すばかりなり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰻釣りや小海老釣りでも同様であった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五円で御釣りが三円なにがし。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉島のあたりははらかた釣りが夥しいが、女子供が大半を占めている。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が此夏、鮎釣りに泳ぎ渡つた際、大きな蟻に臍を食ひつかれて愕いた、竜宮岩も紅葉の間に浮んで、静もりかへつてゐる。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏中釣りをしたため、今年は私の健康はいゝ。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこかで雨を避けておいで」　と返事をしたまま、私は魚を釣り続けてゐたのだが、堤には小さな胡桃の木以外には生えてゐなかつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の方が、釣り竿を堤防の石垣の穴にさし込んどいて、「かうして屋根を葺くんだよ」　と云つて、堤の上に乾してあつた乾草を胡桃の枝に渡して、屋根を葺いてやつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は頭の中に湧き起つて来る、様々の懸念や妄想を、釣りをする、と云ふ事で追つ払ふ為になるべく人の居ない――たとひ魚は釣れなくとも――処を選んで、来るのが慣はしであつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は昼食を食つてから、私たち親子三人は、私と息子は釣りをする為に、娘は蝗を捕るために、家を出たのだつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、釣りも駄目になつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の釣り兼蝗取りも、その催しの一つだつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それよりも、釣りをすることを子供たちが、果して喜んだかどうかなのだつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "このだらしのない、子等に対して申し訳なく、相済まなく思つてゐる父の心が、そんな釣りの半日で子供の心に通じるかどうか、これは寧ろ逆効果でありはしないか。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜、私は釣りの帰りに、硝子のない硝子戸から、その家の有様を通りすがりに眺めた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚釣りも、蝗取りも、米櫃の空なことを忘れさせなかつたのだ。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それであたしはこの辺を散歩すると云って寮を出るし、男はまた鯉釣りに化けて、この土手下の合歓の並木の陰に船を繋って、そこでいまいうランデブウをしたものさね」　夕方になって合歓の花がつぼみかかり、船大工の槌の音がいつの間にか消えると、青白い河｜靄がうっすり漂う。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「家は腰高の塗骨障子を境にして居間と台所との二間のみなれど竹の濡縁の外には聊かなる小庭ありと覚しく、手水鉢のほとりより竹の板目には蔦をからませ、高く釣りたる棚の上には植木鉢を置きたるに、猶表側の見付を見れば入口の庇、戸袋、板目なぞも狭き処を皆それぞれに意匠して網代、船板、洒竹などを用ゐ云々」。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の能力を計らないで六かしい学問に志していっぱしの騎士になったつもりで武者修行に出かけて、そうしてつまらない問題ととっ組み合って怪物のつもりでただの羊を仕とめてみたり、風車に突きかかって空中に釣り上げられるような目に会ったことはなかったかどうか、そんなことを考えない訳にはゆかなかった。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとドイツ語の分らない人でも皆釣り込まれて笑い出す。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る人にとっても釣り込まれるような感興が起ろうはずはない。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「釣り合はねえ」　川端を去って行く八百屋。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "湊の対応ぶりに有頂天になった相手客が、なお繰り返して湊に盃をさし、湊も釣り込まれて少し笑声さえたて乍らその盃の遣り取りを始め出したと見るときは、ともよはつかつかと寄って行って「お酒、あんまり呑んじゃ体にいけないって云ってるくせに、もう、よしなさい」　と湊の手から盃をひったくる。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "借家はもう半月もして水泳場が閉鎖すると同時にたちまち二人に必要になるのだが、価値の釣り合などで敬蔵はなかなか見つけかねた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "数珠子釣りに行って来るかな」　そういって、道具を乗せて田舟を漕ぎ出して行った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はあまり遠くない蘆の中で、カンテラを燃して数珠子釣りをやっている。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いづこぞ夢の序樂のぽろねえず、會社は河岸に涙をひたし、花店の飾窓つゆにぬれたり、しばしまたつりがね鳴らむ、あさまだきにほふ葉影に、しろじろとかざし泳がせ、この列をなす少女らあゆむ。",
              "citation": {
                "source": "若き尼たちの歩む路",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔つめたき朝の真鍮に〕宮沢賢治つめたき朝の真鍮に胸をくるしと盛りまつりこゝろさびしくをろがめばおん舎利ゆゑにあをじろく燐光をこそはなちたまへり",
              "citation": {
                "source": "〔つめたき朝の真鍮に〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼黒い両頬が桃の実のようにむっつりふくれた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
