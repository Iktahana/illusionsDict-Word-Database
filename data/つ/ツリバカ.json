        "examples": {
          "standard": [
            {
              "text": "私の叔父は本物の釣りバカで、機会があれば毎週末出かけます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "毎年恒例の釣り大会には、全国から多くの釣りバカが集まります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は釣り雑誌を何時間も読みふけっており、まさに釣りバカです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "鯉は、「三日に一本」と、相場の極ツてる通り、溢れることも多いし、鱚、小鱸、黒鯛、小鰡、何れも、餌つきの期間が短いとか、合せが六ヶしいとか、船で無ければやれないとか、多少おツくうの特点有るですが、鮒つりばかりは、それが無いです。",
              "citation": {
                "source": "元日の釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけてもくれても、魚つりばかりしていました。",
              "citation": {
                "source": "漁師とそのおかみさんの話",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            }
          ]
        }
