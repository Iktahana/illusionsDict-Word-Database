        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それが引っ切りなしだから、町内の小火で提燈が露路に行列するようだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うさ降りだらそれっ切りだったぞ。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の夏｜築地小劇場のプロ芝居を見物に行ったときには、四十恰好のおばさんが引っ切りなしにチューインガムを噛んでいるのを発見して不思議な感じがしたのであった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっ切り二っつだな。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふさ降りだらそれっ切りだったぞ。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こうさ降りだら馬も人もそれっ切りだったぞ。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へい、全く、虫でしめっ切りですからやりきれませんや。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども家が家だけに鼓の音は朝から晩まで引っ切りなしにきこえた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで昔はあれほど想い焦れた浄土も吾が手のものとなったにつけて、浄土へ行きっ切りとなろう気はなく、自然と娑婆へ往来しても化他の業を執ろうという心が湧上ったに疑無く、言語の端にもおのずから其意が漏れて、それから或人の夢や世間の噂も出たのであろう。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "照吉さんも家業があるでしょう、だもんですから、ちょいとの隙も、夜の目も寝ないで、附っ切りに看病して、それでもちっとも快くならずに、段々｜塩梅が悪くなって、花が散る頃だったわ、お医者様もね、もうね。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見れば、豆板屋、金米糖、ぶっ切り飴もガラスの蓋の下にはいっており、その隣は鯛焼屋、尻尾まで餡がはいっている焼きたてで、新聞紙に包んでも持てぬくらい熱い。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは僕の尻から出たサナダ虫をば並べたとたい」　菊地市長は「ウワアッ」と叫んで襖の蔭に転がり込んで行ったが、それっ切り出て来なかった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその青年は、それっ切りパッタリと来なくなりました。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "艫のほうでは引っ切りなしに測深機を投げて船あしをさぐっている。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲板の寝台に仰向きにねて奏楽を聞いていると煙突からモクモクと引っ切りなしに出て来る黒い煙も、舷に見える波も、みんな音楽に拍子を合わせて動いているような気がする。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子のガラス越しに見える秋晴れの空を蜻蛉の群れが引っ切りなしにだいたい南から北の方向に飛んで行く。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺さんは引っ切りなしに、煙草を燻らしていた。",
              "citation": {
                "source": "喫煙癖",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビール箱の蔭には女が寝ていたし、その外には私と、蛞蝓と二人っ切りであった。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか何かの折があるだろう、と云う空頼みが俺たちを引っ張っているんだよ」　私は全っ切り誤解していたんだ。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「痛いな」「ああ草臥れた」「ああ飲みたい」「眠いな」と感じたら、それっ切りで、打ち切ってしまえ。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、そんなことはまるっ切り考えなかったのであろう。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ寒い頃の事であったが、前の日、小さな棺を、極く少人数で送って来て焼いていたが、その翌日、朝早くから、その小さな棺の母親らしいのが来て、夕方まで、ほとんど、その穴の中に入りっ切りだったことがあった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるっ切りやつは感じないんだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれっ切りで先が出なくなってしまったのだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、生まれてから、すぐにその生の母親に死に分かれて、それっ切り、人間に愛があるということはおろか、子供に乳があるということすらも知らずに育ったのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから順序として、その点からまずあやまるべきだろうよ」　藤原は、まるっ切りおれとは違った見方をしてる。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だれが船長に打っつかるんだい」彼は、まるっ切り黙ってるわけにも行かない場合にしゃべるような、それと同じ気持ちで、同じようなことをそこへ吐き出した。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは、自分たちのやっていたことと、藤原のやっていたこととがまるっ切り違ったことであって、そのくせ一つものを目あてにしていたのだと言うことをさとった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱりあれっ切りにして置けばよかったのですわね。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗称｜白縫のお芳、窃盗きんちゃっ切りの罪重なるをもって四月三日死罪に処せられしうえ梟首獄門。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            }
          ]
        }
