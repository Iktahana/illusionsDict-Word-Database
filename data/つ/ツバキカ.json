        "examples": {
          "standard": [
            {
              "text": "茶の木もツバキ科に属していると知って、意外な共通点に驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "植物図鑑を開いて、庭に咲いている山茶花がツバキ科であることを確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ツバキ科の植物は、光沢のある厚い葉が特徴の一つとして挙げられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "マサカキは繁つた常緑木で、今いうツバキ科の樹名サカキに限らない。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの沢山な品種は皆、その原は前に記した単純なヤマツバキから出たもので、永い歳月の間人手にかかりて栽培せられて居るうちに変り品が一つ出来二つ出来、それから段々に種々新しい変り品が殖え遂に今日の様な多数の品に成ったものです。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
