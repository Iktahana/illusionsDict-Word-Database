        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "換言すれば勉めて旋毛を曲げてかかる事である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この旋毛曲りの性質がなかったら科学の進歩は如何なったであろうか。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スコラ学派時代に科学の進歩が長い間全く停滞したのは、全くこの旋毛曲りが出なかったために外ならない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レネサンスはすなわち偉大な旋毛曲りの輩出した時代である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガリレーはその執拗な旋毛曲りのために縄目の苦しみを受けなければならなかった。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "エネルギー保存説の開祖ロベルト・マイヤーは、当時の物理の世界から見ればむしろ旋毛曲りの頑固な田舎親爺であったに相違無い。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "助手は根元で無造作に結へてある元結を切つて、兩耳の後ろと旋毛の邊にかけて前頭部と後頭部の髮を二束に分けた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "倅が鶏に目玉を突かれて、放浪性に富んだ旋毛曲りとなつたといふ迷信からかも知れない。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『根本説一切有部毘奈耶』に、仏の弟子｜陀夷曰く姑の過ちでない、彼の両乳の間および隠密処に黒黶と赤黶と旋毛、この三の暴悪相があるからだと教え食を受けて去った。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『甲陽軍鑑』一六に、馬に薬を与うるに、上戸の馬には酒、下戸の馬には水で飼うべし、馬の上戸は旋毛下り、下戸は旋毛上るとあり。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、あのいこぢな、旋毛まがりの、善とか美とかによく反撥する性質を持つたトルストイから、あの人間の愛に満ちた作が生れた。",
              "citation": {
                "source": "自他の融合",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう旋毛曲りの「アマノジャク」は始終であって、一々記憶していないほど珍らしくなかった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来椿岳というような旋毛曲りが今なら帝展に等しい博覧会へ出品して賞牌を貰うというは少し滑稽の感があるが、これについて面白い咄がある。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三唖も旋毛の少々曲った変梃な男だから嫌気がさして復た暫らく足を遠のくと、今度は他の家へはマメに出掛けるくせに社のものの方へはまるきり鼬の道てのは余まり義理を知らなさ過ぎるぜと、一々不義理を数え立てられてネチネチと油を搾られた。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――餘つ程｜旋毛曲りだと見える。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一草亭が思ひついたやうに、この二人が無事に顔を合はせたところで、あの通り旋毛曲りの人達だけに、二人はまさか小説の話や俳諧の噂もすまい。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "考へは結構だが、自体学者や芸術家などいふ連中には旋毛の曲つたのが多いから、英霊塔を建てたからといつて、その儘成仏はしなからう。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、旋毛曲りのゴリキイは顔を顰めてそれを受取つた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅多に他人の言ふ事を肯かなかつたあの旋毛曲りの漱石氏も滝田氏に懸つては手も脚も出なかつたらしく、書、画、扇面、額、軸物……と相手の言ふが儘に手当り任せに書かせられてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日の事、都路華香氏を訪ねて、例のやうにそろそろ拝み倒しにかゝつたが、旋毛曲りの華香氏を動かすには何でも画家仲間の悪口を言はねばならぬと思つたらしかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "加福の師匠は繍の名家としてまた「旋毛曲り」として業界から折り紙をつけられている。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "業界では「賞めない人」として加福の師匠は通っているし、その烈しいまでの潔癖な眼識を「旋毛曲り」としてみていた。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頑なさ、その片意地な程の潔癖さを世間の眼は「旋毛曲り」とみていた。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとは事かわりますが、世の中には、誉めたいのだが、他人があんまり感心するから嫌だといったふうな旋毛曲りがかなりにあります。",
              "citation": {
                "source": "平塚明子（らいてう）",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度僕は或る編纂物のために誰かに手傳つてもらはうと思つてゐたところだつたので、丁度いいと思ひましたが、コッテエヂの一件ですこし旋毛を曲げてゐたので、いい復讐が出來ると思つて、面白半分に道造君をからかひ出しました。",
              "citation": {
                "source": "緑葉歎",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてが寂しうなるから歸つたらいかんいふのに、歸るいふやうな旋毛まがりの根性を直してやる。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすが代稽古をするだけに腕前は勝れてはいたものの、その腕前を鼻にかけ、且つ旋毛の曲がった男、こんな挨拶もするのであった。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "側より妹が「モシ兄さんお汁が冷めるといけませんから早く召上りまし」○豚の生肉には肉類の寄生物中最も恐ろしき旋毛虫および嚢虫あり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "人もし半熟の豚肉を食すれば旋毛虫体内に発育して大害を招く。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "外を歩いてゐると、いつの間にか曇り出し小さいつむじ風が舗道の散らしビラを漏斗型に捲き上げる。",
              "citation": {
                "source": "風と裾",
                "author": "――何人か良案はないか？――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
