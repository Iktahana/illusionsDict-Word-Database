  {
    "uuid": "6790490e-293a-53fc-878f-c340acdac90c",
    "entry": "雀鷂",
    "reading": {
      "primary": "つみ",
      "alternatives": [
        "ツミ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
