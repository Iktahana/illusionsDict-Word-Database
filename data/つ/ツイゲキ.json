    "definitions": [
      {
        "index": 1,
        "gloss": "pursuit (of a fleeing enemy)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本軍に追撃されたパルチザンが逃げのびてきたのだ。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢軍これを追撃して虜首を挙げること数千。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "匈奴騎兵の追撃である。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕虜の言が偽りでなければ、これで胡軍は追撃を打切るはずである。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしすぐに敵の騎馬兵の追撃に遭った。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵の追撃をふり切って夜目にもぼっと白い平沙の上を、のがれ去った部下の数を数えて、確かに百に余ることを確かめうると、李陵はまた峡谷の入口の修羅場にとって返した。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マターファは投降し、同時に、追撃して来たラウペパ軍のためにマノノは焼かれ掠奪された。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川勢之に乗じて追撃したので、朝倉軍｜狼狽して川を渡って退かんとし、大将孫三郎景健さえ乱軍の中に取り巻かれた。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇将弘中三河守は同｜中務と共に主君晴賢の退却を援護せんが為に、厳島神社の西方、滝小路（現在の滝町）を後に当て、五百騎ばかりにて吉川元春の追撃を迎え撃った。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ吉川勢に代った小早川隆景が精鋭を率いて追撃して来た。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎義信も軍をととのえて謙信の旗本を追撃した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "謙信は諸隊の退却をみとどけて最後に退いたが、甲軍の追撃猛烈のため犀川に退却するのが困難になったので、東方に血路を開き三牧畠の瀬を渡って退いたといわれる。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この犀川をわたるに当って甲軍の新手の追撃をうけて或は討死し或は溺れる者が続出した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ追撃を決して本軍（近衛一大隊、第十四連隊の一大隊、山砲臼砲各二門）は木葉を通って植木へ、別軍（近衛三中隊鎮台兵三中隊、山砲二、臼砲一）は高瀬から伊倉、吉次越を越して熊本を目指すこととなった。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "官軍の追撃急であり、若しこの一戦に破れれば、熊本包囲の事も水泡に帰するので薩軍は余軍のうち二千余をもって衝背軍に当り、八百余をして熊本城を攻め、其余の兵力は悉くこの守線に動員した。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度十時頃になって居たが、全軍直ちに追撃して、植木の営を衝いた。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵浮足立ったりと見ると、織田徳川の両軍は柵外に出でて追撃戦に移った。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "織田徳川勢の追撃急な上に、勝頼主従の退却も、しかも滝川に橋が沢山ないのであるから頗る危かった。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "先に長秀の応援でいい加減気を腐らして居た盛政の軍は、今また秀吉の追撃があるとなると、もう浮足立つ計りである。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一日の午前二時には秀吉の軍田上山を降り、黒田村を経て観音坂を上り、先鋒二千の追撃は次第に急である。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に明将｜李如松が日本軍を追撃して此処を過ぎた時、申※の無策を嘆じたと云う。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さしもの明軍も少しく退いたので、宗茂八百を後に固め、あとの軍勢は追撃に移らせたが、此時には既に明軍の後属部隊も到着したから戦は簡単には行かない。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "追撃して高陽附近に至る頃明将楊元新手を率いて来り援った。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "激戦の高潮に達したのは正午頃であるが、間もなく明軍の総退却となり、日本軍は之を恵陰嶺まで追撃した。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "島子の一戦に寺沢勢を敗走せしめ、本戸まで追撃して、ついに大将藤兵衛を、乱軍の中に自刃せしめた。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "和成った後、兇報を知らして、かくの次第だが追撃をするかどうかと訊いた。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨守は「今こそ攻めるべし、遅るれば必ず後より追撃されん」と忠直卿に言上した。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも執拗に追撃の手をゆるめなかったが、突然敵方に強弓の一壮漢が現れた。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂの飛行機とＣ、Ｄ、……が盛んに追撃をやつてゐる。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃子は追撃するように云った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
