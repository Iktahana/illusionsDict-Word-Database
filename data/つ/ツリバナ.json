        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この生け花のスタイルでは、そのアレンジメントは「吊り花」として知られています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "巨匠は、低い位置に吊るされた花器を使った繊細な「吊り花」の技術を実演しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の「吊り花」のアレンジメントは、優雅に下方に伸びる枝が特徴でした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "別の古い杉板（図196）の一隅には竹の吊り花生けがあり、金属製に相違ない葡萄の蔓が一本出ていた。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "サヤサヤと壁の紙銭の吊り花が灯影にうごいた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
