      {
        "index": 1,
        "gloss": "arranging flowers in vessels hanging from the ceiling (in ikebana)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
