          "literary": [
            {
              "text": "勿論、月曜日には飲み過ごしの後、銀座の酒場で、乱暴を致し、その翌日は心佗しく、独りでゐるに絶えられず、而もその銀座の酒場に一緒に行つた、津濃といふ友人の所へどうも行つてゐたく、勝手なこととは承知しながら、出掛けて行つて、ぐづぐづしてゐた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がいかにその妻を熱愛していたかは、焼津の旅先から、留守居の妻に送った手紙によく現われている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼津　八月十七日パパカラ可愛イ子ニ、ソレカラ皆ノ人ニヨロシク。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼津　八月十八日小泉八雲　この情緒纏綿たる手紙は、新婚当時の手紙ではない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯一の例外は、二児を連れて焼津へ行った時だけだった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "早ク見タイモノデス』という焼津の手紙でも解るように、妻と同伴することなしには、どんな旅行も楽しくないほど、夫人を熱愛していたからだった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の知ってた日本文字は、片仮名のイロハと僅少の漢字にすぎず、彼の語る日本語は、焼津からの手紙にある通り、不思議な文法によって独創された、子供の片言のような日本語である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "松江に居た時も焼津に居た時も、道に捨猫さえ見れば拾って帰り、幾疋でも飼って育てた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎者太宰治　私は、青森県北津軽郡というところで、生れました。",
              "citation": {
                "source": "田舎者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は津軽平野のまんなかに生れたので、海を見ることがおそく、十歳くらいの時に、はじめて海を見たのである。",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは甲府から、津軽の生家に向って出発した。",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろはがるたや、川柳や、論語などに現わされている日常倫理の戒津だけでは、どうも生き難い。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "会津の藩士でございます。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "会津の国の方言なのかも知れないが、どうも私には気味わるく思われた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思慮分別の深い結納のお使者は、ひどく酔いました、これは、ひどく酔いました、と言いながら、紋附羽織と白足袋をまた風呂敷に包んで持って、どうやら無事に、会津藩士の邸宅から脱れ出ることが出来たのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は此の頃、道を歩いてゐて秋津が自分の近くに飛んで来ると、それが親戚の人か何かのやうに思はれるのだつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、停車場の驛札等に於て見る國府津の「かふづ」は、よろしく「こうづ」または「こーづ」とすべきである。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし「國府津」の正しい發音は、驛札通り KAHUZU であつて KOZU でない。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春水や四条五条の橋の下　この句を読んで聯想するのは、唐詩選にある劉廷芝の詩「天津橋下陽春水。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見て、梅津の君は、あやめも知らぬ戀人は、このわたりにはあらじかし。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "車に乘らばや、といふを、梅津の君は冷笑ひて、風にも堪へぬ御細腰は、さもこそ、といへば、おんみこそといふ。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅津の君も今は物もいはで彳めるを、玉枝の君と妾とは目見合せてをり、さすがに恐しからぬにもあらず。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅津玉枝の御二方は、西施の顰をみそかに開かせ給ひぬらん。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ほれ喧嘩だ』と、云ふとドツと一時に動搖めいて一崩れ、ばたばたと男の後を追うて、津浪が押し寄せた樣、逸早く合點した連中は、聲を擧げて突貫した。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "根津辺の汚い下宿屋で極めて不規則な生活を送っている。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰気な根津辺に燻ぶっていて、時たま此処らの明るい町の明るい店先へ立つと全く別世界へ出たような心持になって何となく愉快である。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎を立って時津に向かう途中でロシア人専門の遊廓だというところを通ったら二階から女どもが見下ろして何かしら分らないことを云って呼びかけた。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時津の宿で何とかいう珍しい貝の吸物を喰わされた。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時津から早岐まで、哀れげな小蒸気船に乗っての大村湾縦走はただうすら寒い佗しい物憂さの単調なる連続としてしか記憶に残っていない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一日は物部川を渡って野市村の従姉の家で泊まって、次の晩は加領郷泊り、そうして三晩目に室津の町に辿り付いたように思う。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
