    "definitions": [
      {
        "index": 1,
        "gloss": "reserve (fund)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
