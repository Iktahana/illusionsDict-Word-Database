    "definitions": [
      {
        "index": 1,
        "gloss": "hanger (e.g. for mosquito net)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「十時二十分過ぎでございます」「暫く世話になるから――冬子と言ったね」「はい」　この部屋と簀戸越しの次の室にこの時｜蚊帳を吊る吊り手の金環の触れ合う音や畳摺れの音が聞えた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "手の匕首が、無意識に、蚊帳の吊り手をばらッと切って落した。",
              "citation": {
                "source": "雲霧閻魔帳",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊帳の吊り手が落ちる、今戸焼の釜が砕ける。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは、相変らずヒッソリとしていて、奥をのぞくと、昼だのに、萌黄の色あせた蚊帳の吊り手が一所はずれたまま、ダラリと陰気な姿をしている。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴後の茶漬も快く、窓によれば驟雨沛然としてトタン屋根を伝う点滴の音すゞしく、電燈の光地上にうつりて電車の往きかう音も騒がしからず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬は多く北風吹き、火のあやまちは冬多きものなれば、怪むべくもあらぬ事ながら、東京の大火を叙せんとて、心も無く、北へ行く雲に火の色うつりて天は紅霞のわたれるが如し、など別の故も無きに筆を舞はして記さば、如何に見苦しきものに老いたる人などの見なさん。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いで御陵のありと聞く白峯といふに明日は着き、御墓の草をもはらひ、心の及ばむほどの御手向けをもたてまつりて、いさゝか後世御安楽の御祈りをもつかまつるべきか。",
              "citation": {
                "source": "二日物語",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れよりさき、軒につりて干したる大根を臺所に曳きて澤庵に壓すを言ふ。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すばやくも手にさばく檜の縄のはらはらに、時の間よ、ゆく水のかぎりなき燈ににほへば、香魚を追ふ鵜の数のつぎつぎと目にうつりて。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "（本論は次号にうつりて、我が畏敬する天知子と愛山生の両兄によりて評論界を騒がしたる「遊侠」の問題に入り、更に「粋」といふ題目に進みて卑見を吐露すべし。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十　わが幻住のほとりに、情しらぬもの多く住むにやあらむ、わがうつりてより未だ月の数も多からぬに三度までも猫を捨てたるものあり。",
              "citation": {
                "source": "秋窓雑記",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの地に住みし時この文を作らず、却つて今の菴にうつりて之を書くは、わが悲悼の念のかしこにては余りに強かりければなり。",
              "citation": {
                "source": "鬼心非鬼心",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "上に對したてまつりて、不意撃の狼藉なんど、いかで、いかで……。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫はこれより一身をミネルワの神（藝術の神）に捧げまつりて、その始て桂冠を戴きしはナポリにての催しなりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "しおがまにてただの一銭となりければ、そを神にたてまつりて、からからとからき浮世の塩釜で　　　せんじつめたりふところの中　はらの町にて、宮城野の萩の餅さえくえぬ身の　　　はらのへるのを何と仙台　二十日、朝、曇り。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝる騷の中に、裏口の農家の主人、きゝつけて來りて曰く、これ迄、鰻をつりて來て、桶に入れ置きけるに、この猫にとられたること、幾回なるを知らず。",
              "citation": {
                "source": "猫征伐",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "折しも夕日は對岸にのみ及びて、紅葉ひとしほ鮮かに、黒檜山と共に水にうつりて、孰れか眞、孰れか影と疑はるゝばかりに明か也。",
              "citation": {
                "source": "赤城山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗気なき人と碁をかこみて、黄昏に至りて、碁の目見えわかねば、しばし子を下す手をとゞめて、浮世の外のこと語らふほどに、眉目いつしかあきらかになれるに、顧みれば梅が枝まるまどにうつりて、さながら一幅の墨画の如し。",
              "citation": {
                "source": "月譜",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "上に対したてまつりて、不意撃ちの狼藉なんど、いかで、いかで……。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "都にのぼりて大行天皇の御はふりの御わざはてにけるまたの日、泉涌寺に詣たりけるに、きのふの御わざのなごりなべて仏さまに物したまへる御ありさまにうち見奉られけるを畏けれどうれはしく思ひまつりてゆゆしくも仏の道にひき入るる大御車のうしや世の中　曙覧は王政維新の名を聞きて、その実を見るに及ばざりしなり。",
              "citation": {
                "source": "曙覧の歌",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の鏡にうつりて花の大きく白く旅の或る日の鼻毛ぬくことも四月二日　雨、仏通寺（豊田郡高坂村）。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのゆへは、自余の行もはげみて、仏になるべかりける身が念仏をまうして、地獄におちてさふらはばこそ、すかされたてまつりてといふ後悔もさふらはめ、いづれの行もおよびがたき身なれば、とても地獄は一定すみかぞかし。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま日野山の奧にあとをかくして後、南にかりの日がくしをさし出して、竹のすのこを敷き、その西に閼伽棚を作り、うちには西の垣に添へて、阿彌陀の畫像を安置したてまつりて、落日をうけて、眉間のひかりとす。",
              "citation": {
                "source": "方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "その初は、榊原芳野君とともに、編輯のおほせをかうむりたりしに、幾ほどなくて、榊原君は他にうつりて、おのれひとりの業とはなりぬ。",
              "citation": {
                "source": "ことばのうみのおくがき",
                "author": "大槻文彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われら身をきよめ御身を敬いまつることを人に弘め、歓びに心とどろき、僕たる身を貴しと思い、御身を讃めたたえまつりて、その大いさを説き示し、み保護のもと歓び行いて、御宿りのいかばかり美しきかを人に教えまつらんことを希う。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼けしうへ一雨そそぐゆふだちのしめり涼しく土の香の立つゆふだちに濡れし鴉の羽たたきに桐の花ちる夕あかりかな枕つく妻屋もささで夏の月入るまでを見ん夜の涼しさに明治二十六年の夏、子等の集ひきて、祖先を初め、無縁となれる身内の亡き魂をまつりて供養しけるうれしさに。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此よりも、前の歌と思はれるのに、大御政、古き大御世のすがたに立かへりゆくべき御いきほひと成ぬるを、賤ノ夫の何わきまへぬ物から、いさましう思ひまつりて百千歳　との曇りのみしつる空　きよく晴ゆく時　片まけぬあたらしくなる天地を　思ひきや。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "都にのぼりて、大行天皇の御はふりの御わざ果てにけるまたの日、泉涌寺に詣でたりけるに、きのふの御わざのなごり、なべて、仏ざまにものし給へる御ありさまに、うち見奉られけるを、畏けれど、憂はしく思ひまつりてゆゝしくも　ほとけの道にひき入るゝ大御車の　うしや。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "硯といふも、山の石くづ※福寿艸　補遺大御政、古き大御世のすがたに立ちかへりゆくべき御いきほひと成りぬるを、賤夫の何わきまへぬものから、いさましう思ひまつりて百千歳　との曇りのみしつる空　きよく晴れゆく時　片まけぬ○あたらしくなる天地を　思ひきや。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本紀の一書にも、ほのすせりの命が、ほゝでみの命に「我当に汝に事へまつりて奴僕たらむ。",
              "citation": {
                "source": "「ほ」・「うら」から「ほがひ」へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
