    "definitions": [
      {
        "index": 1,
        "gloss": "wet with dew",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "バ……妖怪が……」　まだ薄暗い方丈の、朝露に濡れた沓脱石まで転けつまろびつ走って来た一人の老婆が、疎らな歯をパクパクと噛み合わせて喘いだ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪｜艶かに姿白く、袖もなえて、露に濡れたような風情。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅客は洋杖を持った手を拡げて、案外、と瞻ったが、露に濡れたら清めてやろう、と心で支度をする体に、片手を衣兜に、手巾を。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その冷く快かった入口の、立看板の白く冴えて寂しいのも、再び見る、露に濡れた一叢の卯の花の水の栞をすると思うのも、いまは谷底のように遠く、深い。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "掻い撫ずる掌を、吸い取るばかり、袖、袂、太く夜露に濡れたり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "石垣に沿うて、露に濡れた、老緑の広葉を茂らせている八角全盛が、所々に白い茎を、枝のある燭台のように抽き出して、白い花を咲かせている上に、薄曇の空から日光が少し漏れて、雀が二三羽鳴きながら飛び交わしている。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "露に濡れた草原を踏みわけて、お寺の方へ来ました。",
              "citation": {
                "source": "ルルとミミ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに鐘撞き堂の石段に、ミミの露に濡れた小さな足あとが、月の光りに照されているのが見つかりました。",
              "citation": {
                "source": "ルルとミミ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰度朝の事で、冷え冷えとした陸橋の上にも、露に濡れた線路の上にも、もう附近の弥次馬達が、夥しい黒山を作っていました。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側に朝の日がさし、それが露に濡れた青い菜つぱと小鳥の黄色い胸毛に透きとほり、箱の底に敷いてやる新聞紙も清潔だつた。",
              "citation": {
                "source": "小さな庭",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべすべした、大きな、円つこい頭のてつぺんは、まだべつとりと朝露に濡れたまんまで……　大空のドンキホオテ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お定は水汲から歸ると直ぐ朝草刈に平田野へ行つたが、莫迦に氣がそは／＼して、朝露に濡れた利鎌が、兎角休み勝になる。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お定は、水汲から帰ると直ぐ朝草刈に平田野へ行つたが、莫迦に気がそは／＼して、朝露に濡れた利鎌が、兎角休み勝になる。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "露に濡れた葡萄の房が朝の空の中で克明な陰影を振りかざし、一粒づつ滿腔の光りを放つて靜まつてゐた。",
              "citation": {
                "source": "妻",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "露に濡れた芭蕉の葉からすゞしい朝の雫の滴り落ちるやうな時もやつて來た。",
              "citation": {
                "source": "短夜の頃",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "門燈の光で露に濡れた小さい蜘蛛の巣が見える。",
              "citation": {
                "source": "未開な風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "野良へ――　露に濡れた玉蜀黍の葉ばかり、夜會服の貴婦人みたいに、さらさらさら‥‥‥とそよぐ。",
              "citation": {
                "source": "梁上の足",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜露に濡れた草が、地上に盛り溢れさうな勢ひで、野を埋めてゐた。",
              "citation": {
                "source": "彼女こゝに眠る",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しツとりと夜露に濡れた柿の實の風味は、また格別であつた。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」と、重吉は首を傾げ／＼、急出來の床の上から廊下へ飛び下りて、上草履のまゝしツとりと夜露に濡れた土を踏んで行つた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の中には露に濡れた野菜がうずたかく積んであった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　船の中は露に濡れた野菜がうずたかく積んであった。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから鼻息の露に濡れた胡麻塩髯を撫でまわして、歪みかけた釣鐘マントの襟をゆすり直すと、又も、スタスタと学校の方へ線路を伝い初めた。",
              "citation": {
                "source": "木魂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜露に濡れたトタンが月に照らされている、平らに沈んだその光のひろがりが、ひろ子の目をとらえた。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝露に濡れた平石の上に石菖の大きな鉢がおいてあって、細く茂りあった葉もまだ露を含んでいる。",
              "citation": {
                "source": "朝の風",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう、二｜粁もあるゴルフ場まで、ついて来て、朝露に濡れた芝生の上を、口笛吹き吹き、探してくれました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう、二粁もあるゴルフ場まで、ついて来て、朝露に濡れた芝生の上を、口笛吹き吹き、探してくれました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "白は昔の犬小屋の前に、露に濡れた体を休めました。",
              "citation": {
                "source": "白",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いづこぞ夢の序樂のぽろねえず、會社は河岸に涙をひたし、花店の飾窓つゆにぬれたり、しばしまたつりがね鳴らむ、あさまだきにほふ葉影に、しろじろとかざし泳がせ、この列をなす少女らあゆむ。",
              "citation": {
                "source": "若き尼たちの歩む路",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
