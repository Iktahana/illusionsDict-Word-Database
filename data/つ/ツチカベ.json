        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本では、土壁の外側に羽目板を張ったくらいが防寒防暑と湿度調節とを両立させるという点から見てもほぼ適度な妥協点をねらったものではないかという気がする。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青黒く地並になった漆喰の床と白い古びた土壁が向うに見える。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い屋根の下には仕事場の土間と土壁で土間を仕切った二間ばかりの座敷があった。",
              "citation": {
                "source": "鍛冶の母",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　翁の家の門は槙の生垣の間に在る、小さな土壁の屋形門であった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "本式な床なら格別、普通の略式なお座敷であったら、まず一間の床があって、その隣にはからかみ二本の押し入れでもが設けられてあるのがあたりまえですが、しかるに、それなる茶の間の奥の座敷を見ると、床は床であってもその床の隣の押し入れであるべきところが、妙なことに出っ張った土壁なのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "こころみにそれなるポチを押してみると、果然土壁は、からくり仕掛けの龕燈返しに、くるりと大きな口をあけました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "但しこちらが大勢で、相手が少ないときには、押えつけ縛りあげて土壁に倚りかからせ、四方から土をかけて塗り固めて、その上に燈台を置けば、ふたたび祟りをなさないと言い伝えられている。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "復た土壁づたひにいそ／＼と隣の勝手口の方へ戻つて行つた。",
              "citation": {
                "source": "突貫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "最早山の上でもすっかり雪が溶けて、春らしい温暖な日の光が青い苔の生えた草屋根や、毎年大根を掛けて干す土壁のところに映っていた。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥様が花やかな御風俗で御通りになる時は、土壁の窓から眺め、障子の穴から覗き、目と目を見合せて冷な笑いかたを為るのです。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗く煤けた土壁の隅に寄せて、二つ並べたは漬物の桶。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、ウネウネと続いた草屋根、土壁、柿の梢、石垣の多い桑畑などは汽車の窓から消えた。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "薩摩日向の家屋は板壁であるのを不思議に思つてゐたが宿の主人の話で、その謎が解けた、旧藩時代、真宗は御法度であるのに、庶民が壁に塗り込んでまで阿弥陀如来を礼拝するので、土壁を禁止したからだと。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "前といわず、横といわず、大門に赤や青のペンキを塗りたくった、いずれも土壁が今にも崩れ出しそうな家ばかりである。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "土壁の傍で土遊びをしていた二三の子供達が手を叩きながらはやしたてた。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "土壁のないバラックで、昔は物置であったのかもしれない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となく、しみじみとするね」　ゆき子は、御所の土壁の塀を呆んやり見上げた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡い土壁の匂ひがした。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その右側は土壁で、左側に部屋が並んでいる。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……かと思うと、それから二三日のうちに、三十里も距たった新開農場の一軒家に押入って、ちょうど泣き出した嬰児の両足を掴むと、面白そうに笑いながら土壁にタタキ付けた。",
              "citation": {
                "source": "白菊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "両眼をカッと見開いて、寝台の向側の混凝土壁を凝視した。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その混凝土壁の向側から、奇妙な声が聞えて来たからであった。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが深夜の混凝土壁の向うから私？",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声のあたりと思われる青黒い混凝土壁に縋り付いた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨音を立てている前の家のトタン葺の屋根のはずれと、そのとなりの家の、燃火のけむりが低く雨の中に流れ出している土壁との間にある空地ごしに扇形にひらいた引込線に、石炭をつんだ無蓋貨車が何輌もつながったまま雨に打たれている。",
              "citation": {
                "source": "無題（十二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
