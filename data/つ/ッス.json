        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は、まっすぐに走りだした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀が来てそれを食うと間もなく酔を発して好い気持になり、やがてその柿の葉を有合わせの蒲団にしてぐっすり寝込んでしまう。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "植物園の門をはいってまっすぐに広いたらたら坂を上って左に折れる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄れ明るむ雲の垂れ幕とたそがれる宵闇の力とあらがう気象の摩擦から福慈岳の巨体は、巨体さながらに雲の帳の表にうっすり浮出で、または帳の奥に潜って見えたりする。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "獣の血臭いにおいがして翁の唇の端から血の色がうっすりにじんだ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "果樹園や畑の見えるだらだら下りの裾野平の果に、小唄で名高いＹ――山の山裾が見え、夏霞がうっすり籠めている中に浪がきらりきらり光った。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それであたしはこの辺を散歩すると云って寮を出るし、男はまた鯉釣りに化けて、この土手下の合歓の並木の陰に船を繋って、そこでいまいうランデブウをしたものさね」　夕方になって合歓の花がつぼみかかり、船大工の槌の音がいつの間にか消えると、青白い河｜靄がうっすり漂う。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけ人々は却てそれを欲っするのかも知れない。",
              "citation": {
                "source": "時代色",
                "author": "――歪んだポーズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからにわかによだかは口を大きくひらいて、はねをまっすぐに張って、まるで矢のようにそらをよこぎりました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よだかはまっすぐに、弟の川せみの所へ飛んで行きました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして思い切って西のそらのあの美しいオリオンの星の方に、まっすぐに飛びながら叫びました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、南の大犬座の方へまっすぐに飛びながら叫びました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又思い切って北の大熊星の方へまっすぐに飛びながら叫びました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜だかは、どこまでも、どこまでも、まっすぐに空へのぼって行きました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瘠せてオーバアコートを着てわらじを穿いた男が青光りのさるとりいばらの中にまっすぐに立ってゐた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジョバンニはまっすぐに立ってまた叫びました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま新らしく灼いたばかりの青い鋼の板のやうな、そらの野原に、まっすぐにすきっと立ったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふりかへって見ると、車室の中の旅人たちは、みなまっすぐにきもののひだを垂れ、黒いバイブルを胸にあてたり、水晶の珠数をかけたり、どの人もつつましく指を組み合せて、そっちに祈ってゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
