    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to spend",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "云うまでもなく、朝顔を見たことのないエスキモー土人に朝顔を説明するに百万言を費やすよりも写真か映画で一分間を費やした方が早分りである。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間と労力と金とを費やすだけでは十分でない。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがためには、しばらく絵筆をすてて物に親しむ事に多くの時を費やす必要がある。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう教案の作成に費やす時間があれば、むしろその時間に先生が、先生自身の題目の研究をした方がよいと思う。",
              "citation": {
                "source": "雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "談話に費やす労力　人間が談話をしたり、歌ったり、演説したりする時には、肺の中の空気を若干の圧力で押し出しているが、このために要する器械的の仕事はどれだけであるか、平たく云えば一時間しゃべるにはどれだけの労力をするかという事を測定した人がある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "約一年余の時日を費やす予定で、その費用として一万六千ルーブル（約一万三千円）を国庫より支出することとなったそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "営利に急なる財界の闘士が、早朝忘我の一時間を菊の手入れに費やすは一種の「さび」でないとは言われない。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからあちらこちらの往復に電車で費やす時間を利用してともかくも一度読了した。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今ルクレチウスを紹介せんとするに当たってまずこの点に誤解のないように、わざわざ贅言を費やす必要を感じる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに要する作業費が二三千円であるが、地形図の基礎になる三角測量の経費をも入れて勘定すると、一枚分約一万円ぐらいを使わなければならない、そのほかにまだ計算、整理、製図、製版等の作業費を費やすことはもちろんである。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "波の峰から谷まで待つために費やす時間は短い時で数十秒、長くて一分か二分を越ゆる事はまれなくらいである。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことについては「我等」の三月号にのせた「雑信一束」（「片信」と改題）にもいってあるので、ここには多言を費やすことを避けよう。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は親もあらず、同胞もあらず、情夫とてもあらざれば、一切の収入はことごとくこれをわが身ひとつに費やすべく、加うるに、豁達豪放の気は、この余裕あるがためにますます膨張して、十金を獲れば二十金を散ずべき勢いをもって、得るままに撒き散らせり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして家へ歸ると直に、澤山の原書を取ツ散かした書齋に引籠ツて、書を讀むとか、思索に耽るとか、設五分の時間でも空に費やすといふことが無い。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし余が徹頭徹尾「満韓ところどころ」のうちで、長塚君の気に入らない一回を以て終始するならば、到底長塚君の「土」の為に是程言辞を費やす事は出来ない理窟だからである。",
              "citation": {
                "source": "『土』に就て",
                "author": "――長塚節著『土』序――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五年を労作に費し、他の二十五年を逸楽に費やすとせば、極めて面白き方寸なるべし、人間の多数は斯の如き夢を見て、消光するなり、然れども実際世界は決して斯の如き夢想を容るゝの余地を備へず。",
              "citation": {
                "source": "内部生命論",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども人間の霊魂を建築せんとするの技師に至りては、其費やすところの労力は直ちに有形の楼閣となりて、ニコライの高塔の如く衆目を引くべきにあらず。",
              "citation": {
                "source": "人生に相渉るとは何の謂ぞ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は参拝や祭礼にいかに多銭を費やすも、みなその大字民の手に落ちたるに、今は然らず、一文失うも永くこの大字に帰らず、他村他大字の得となる。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "千百年を経てようやく長ぜし神林巨樹は、一度伐らば億万金を費やすもたちまち再生せず。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してその一漲一落必ず六時間を費やす。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし余が徹頭徹尾「滿韓ところ／″＼」のうちで、長塚君の氣に入らない一囘を以て終始するならば、到底長塚君の「土」の爲に是程言辭を費やす事は出來ない理窟だからである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしのために一行は日程を変へて、上井出村に二、三日を費やすことになり、叔母の家に来て見ると、案の条わたしの描いた画は離室の欄間にかゝつてゐた。",
              "citation": {
                "source": "湖の夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども考えてみると、僕がここまで辿り着くのには、やはりこれだけの長い年月を費やす必要があったのだ。",
              "citation": {
                "source": "片信",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "市九郎はそのために、托鉢に費やすべき時間を、更に絶壁に向うことができた。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上のごとき推理に基づいて、私は田端事件の犯人は既にこの世にいないことを主張し、したがって当局者が、この上、この事件の捜査に貴重な時間と労力とを費やすは無益であることを信じて、捜査の打ち切りを切に当局に勧告するものである。",
              "citation": {
                "source": "誰が何故彼を殺したか",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことで時間を費やす位なら、夜業でもした方がよほど増しだ、と思い出すと、もう、とても大儀で、其所へ坐っていることが出来ず、とうとう中途で、挨拶もせず、こそこそとその部屋を逃げ出して帰って来て、ホッとしたことがありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "遊芸には縁のなかったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "況してそれが、朝は未明から朝讀、夜は夜で十一時過ぎまでも小兒等と一緒に居て、出來るだけ多くの時間を小兒等のために費やすのが滿足だと謂ふのだから、宛然僕の平生の理想が君によつて實行された樣な氣がしたよ。",
              "citation": {
                "source": "漂泊",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、こんな前置きに時間を費やすよりも、早く事件の本筋に入りましょう。",
              "citation": {
                "source": "深夜の電話",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたち日本の実直な市民として、一生の大部分を家事についやす主婦として、日常の生活に、教育に、読書や娯楽に、どういう文化を求めているかということを、はっきり自分で知らなければならないと思う。",
              "citation": {
                "source": "偽りのない文化を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに女の身で処女時代であつた君は、秋川駿三を悪魔と呪つたところで、彼を一生の敵として自分の一生をついやす気にならなかつたのは無理もない。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            }
          ]
        }
