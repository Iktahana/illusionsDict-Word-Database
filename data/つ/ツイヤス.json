[
  {
    "uuid": "67536a3a-a5e9-5ee6-b8d9-4897d63361e7",
    "entry": "費やす",
    "reading": {
      "primary": "ついやす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
