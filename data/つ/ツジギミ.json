        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "天野君が和辻君にその由を伝えると和辻君はアナゴではなくてアマゴであることを説明した。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の辻君たちが通りかかったが、恋人同志だと気付くと、エヘン！",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは糸盾を抱えた辻君姿の壮い女であった。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな遅くまで、父さんは何をしていらっしゃることやら」　小提燈を点けた女が走って来たが、よほどあわてていると見えて、辻君姿の女にどたりと突きあたった。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻君姿の女は其の顔に眼をつけた。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたは姉さん」　辻君姿の女はお岩で、小提燈の女はお袖であった。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたは、まあ、あさましい、辻君などに」　お岩はお袖の顔をきっと見た。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "和辻君の『応酬』といふ文は、思ひ切つていろいろなことが言つてあつて面白い。",
              "citation": {
                "source": "孤独と法身",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "和辻君などは、もう少し謙譲の徳を養ふ方が好いだらうと思ふ。",
              "citation": {
                "source": "孤独と法身",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "上は芳町、柳橋の芸者から松の位の太夫職、下は宿場の飯盛から湯屋女、辻君、夜鷹に到るまで、あらゆる階級の要求に応ずる設備が整っていた。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小さな旅には家内を連れて來て、若王寺にある和辻君の家族を訪ねるといふたのしみがあつた。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "晝すこし前に、和辻君に案内されて君の書齋を見、眺望のある二階の部屋へも上つて見た。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、和辻君は紫野の大徳寺へ案内しようと言つて呉れた。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "家内は晝過ぎから和辻君の家へ行つて、夕景に戻つて來た。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "和辻君の周旋で、午前に二條城のあとを見ることが出來た。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後に、和辻君等に別れを告げた。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時近くなって、約の如く、大勢来庵、澄君、井君、高君、藤君、そして辻君。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも些かの悪心をもって路上に「鶴」――辻君のこと。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒塗りの床柱へ凭れかかって、家老の、碇山将曹が「何んと――京で辻君、大阪で惣嫁、江戸で夜鷹と、夕化粧――かの。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツンテレ、ツンテレ、京でえ、辻君――」「トン、シャン」　小藤次が、扇で、膝を叩いた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、又、坐って「操を破ったって――ねえ、何んな、ぼろを下げたって、仮令、夜鷹、辻君になったって、惚れた女は、惚れた女――として、ねえ、惚れた上は、鼻が欠けても、盲になっても、惚れ止めねえのが、本当の、男の、恋ってもんだ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "といっても、日本のように一地域を限ってそういう女が集まっているわけではなく、女自身が単独ですることだから、一見普通の町筋となんらの変わりもないのだが、いわば辻君の多く出没する場所で、女たちは、芝居や寄席のはじまる八時半ごろから、この付近の大通りや横町を遊弋して、街上に男を物色する。",
              "citation": {
                "source": "女肉を料理する男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、こうして屍体にばかり気を取られていた発見者の横を、影のようにするりと抜け出たであろう「斬り裂くジャック」は、すぐその足でアルドゲイトのミルト広場へ立ちまわり、四十五分後には、また一人キャザリン・エドウスという辻君を殺害し、やはり陰部から下腹を斬り裂いて、子宮を取っている。",
              "citation": {
                "source": "女肉を料理する男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い区域内で、連続的に街上で辻君を虐殺という言葉は足らない。",
              "citation": {
                "source": "女肉を料理する男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "エセル・ライオンスといって、その服装態度からブラウンが一眼で鑑別したとおり、彼女はイースト・エンドを縄張りにする辻君の一人だった。",
              "citation": {
                "source": "女肉を料理する男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画と芝居との違ひといふやうなことは、専門的に言ふと種々喧しいことがありますけれども、辻君が言はれましたやうに、日本の現代の智識階級は、劇に求めてゐるものを外国トーキーに求めてゐる、それによつて満足してゐると言つてよいのであります。",
              "citation": {
                "source": "芝居と生活",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "和辻君は、此の部屋の障子に腰のないのは、此の日影の效果を豫想しての小堀遠州の考案ではあるまいか、と云つた。",
              "citation": {
                "source": "桂離宮",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処でちょいとばかり通を云いますが、上海に於ける辻君には、大体二種類あるのです。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩のいた証拠「オイ大辻君。",
              "citation": {
                "source": "地中魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
