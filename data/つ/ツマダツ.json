[
  {
    "uuid": "272934e3-0289-54fb-9592-67d7a4d136ff",
    "entry": "爪立つ",
    "reading": {
      "primary": "つまだつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "Godan verb with 'tsu' ending"
      ],
      "ctype": null,
