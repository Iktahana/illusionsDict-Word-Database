        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（Ｆ・Ｏ）Ｔ　その夜　深更――Ｓ＝荒れ果てた辻堂　辺りは古い杉の木が茂った深山幽谷である。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛籠の傍へ寄って人影なしと見て天狗の面を取って辻堂の縁に置く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻堂の中から手が出て、縁に置かれた天狗の面をそッと掴んだ。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、　辻堂の扉がバタンと勢いよく開いた。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「こーら」　タハッと驚く山賊が振り返ると、　真黒な辻堂の中に天狗の顔が物凄く光って居る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻堂の天狗が（団九郎）、Ｔ「吾こそは　此の仙境に　棲む天狗なり」　そら出たと山賊達、腰を抜かす。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎、辻堂へ逃げこむと入れ違いに、　武蔵現れて、　三人を斬り捨てる。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「我が慈悲道得の刀を　受けよと言うより早く」　と話す武蔵「スラリとばかりＴ「両刀抜き放ちて　飛びかかり」　身振り手振りも面白くＴ「この時妖雲　谷を覆い　山は轟々　と鳴り響く」Ｓ＝辻堂　猛々と立ちこめた白煙。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……病院下の三ツ角は、遺失すくらゐか、路傍に手紙をのせて來ても、戀の宛名に屆きさうな、塚、辻堂、賽の神、道陸神のあとらしい所である。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わきへ引込んだ、あの、辻堂の小さく見える処まで、昨日、午ごろ夫婦で歩行いた、――かえってそこに、欣七郎の中折帽が眺められるようである。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻堂の中で三々九度の杯をするように一杯飲もう、と言った。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして目算もなく、計畫もなく、偶然の※合のみを祈りながら、追剥の出る街道や、辻堂や笹原のある景色の中を、悲しく寂しげに漂泊して居る。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひるまは歩いてゆき、夜は辻堂の中や、家の軒端や、藁づみのかげで眠つた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで良寛さんは、辻堂の傍に腰をおろして憩んだ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「辻堂のとこで手毬をついてゐられたで、こりやどうも可怪しい。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきの辻堂の傍を通りかかつたとき、良寛さんは、きよろきよろと、あたりを眺めまはした。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、子供達がよく遊んでゐる辻堂の見える角まで来たとき、良寛さんは、自分がうつかりしてゐたことに気づいた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう肚をきめながら、良寛さんは辻堂のそばへいつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、辻堂の縁の上で遊んでゐた五、六人の女の子が、いつものやうに、「良寛さん、一貫。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくれんぼのつづきで、まだあの子供がどこかにかくれているかも知れないというので、盗人たちは、みみずの鳴いている辻堂の縁の下や柿の木の上や、物置の中や、いい匂いのする蜜柑の木のかげを探してみたのでした。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "向う角の女郎屋の三階の隅に、真暗な空へ、切って嵌めて、裾をぼかしたように部屋へ蚊帳を釣って、寂然と寝ているのが、野原の辻堂に紙帳でも掛けた風で、恐しくさびれたものだ、と言ったっけ。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、此処からが目差す御山というまでに、辻堂で二晩寝ました。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "行く先々の庄屋のもの置、村はずれの辻堂などを仮の住居として、昼は村の註文を集めて仕事をする、傍ら夜は村里の人々に時々の流行唄、浪花節などをも唄って聞かせる。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくては、一城の姫か、うつくしい腰元の――敗軍には違いない――落人となって、辻堂にった伝説を目のあたり、見るものの目に、幽窈、玄麗の趣があって、娑婆近い事のようには思われぬ。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い月は、野末に一つ、あるけれど、もと末も分らない、雲を落ちた水のような畝った道を、とぼついて、堪らなくなって――辻堂へ、路傍の芒を分けても、手に露もかかりません。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小家でも可、辻堂、祠でも構はん、何でも人の居ない空屋が望みだ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速さあ、人の居ない小家、辻堂、祠、何でも構はん、其処へ行かう。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、山路を往ってその日の午比、小さな辻堂のある処へ往った。",
              "citation": {
                "source": "山姑の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚九郎は女とその辻堂の縁に腰をかけて、腰にしていた弁当を開いた。",
              "citation": {
                "source": "山姑の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
