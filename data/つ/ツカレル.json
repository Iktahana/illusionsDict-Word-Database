      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to get tired",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "実に、疲れるのである。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい加減、たきぎ拾ひに疲れると、岩上に大あぐらをかき、えへん！",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は仕事に疲れると、この縁へ出て仰向けに寝転び、都会の少し淀んだ青空を眺めながら、いろいろの空想をまどろみの夢に移し入れた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は、もう私たちはすっかり川の心持ちになれたつもりで、どんどん上流の瀬の荒い処から飛び込み、すっかり疲れるまで下流の方へ泳ぎました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "従て夜もおちついてはねむれない　眠てもすぐさめる　疲れるから眠ることはねむるが一時間もたつともう目がさめる。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それに深く疲れる時いつも頭を休めに行つたのは、家から寂しい草原の小徑を五六町｜辿る海岸の砂丘の上へであつた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日も午前から午後へかけて少し頭の疲れる難読の書を読んだ後であった。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "下駄よりも五倍も疲れるようである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は仕事が終えるとずいぶん疲れるだろうな」　といってやった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想地獄、あまりに去来の速かな思想群に疲れる地獄であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがひどく疲れるんだよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日迄幸に防禦線は突破されずに戦つては来たものの、俺は疲れる。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、昼間はひとの分まで仕事を引き受けて、よほど疲れるのだろうか、すぐ横になって、寝入ってしまうのでした。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「頭を使ふと、體まで疲れるもんですかね。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "お玉はお腹は減るし足は疲れるし只情無さに「お母さん／＼」と泣き叫び乍ら何処を当ども無く広野原を歩いて行きましたが其中に泣き疲れて只ある叢の中に倒れて眠つてしまひました。",
              "citation": {
                "source": "金銀の衣裳",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一知の掌が僅かの間に石のように固くなっている事や、娘のマユミが一知と二人ならば疲れる事を知らずに働く事なぞを繰返し繰返し喋舌って廻るので村の人々は相当に悩まされた。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その墓地はたかいポプラの繁みで圍まれてゐて、はしり疲れると私はそこの卒堵婆の文字などを讀み讀みしながらぶらついた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北さんはこれからまた汽車に乗ってどんなに疲れる事だろうと思ったら、私は、つらくてかなわなかった。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むだに疲れるのである。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土曜と日曜の終日ストックホルム警察廳は犯人の捕縛に必死となつたが、いろいろな手掛りも空に歸して、警察官や探偵達もただ疲れるばかり、すると、モルトナス島の慘劇發見からわづか五日目の三月七日の月曜の夕方午後五時といふに主任警部室の電話の鈴がけたたましく鳴り響いた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれじゃあ疲れることだろう。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、伊藤先生と二人で向かい合っていると、とても疲れる。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "両者共に、相手の顔を意識せず、ソファに並んで坐って一つの煖炉の火を見つめながら、その火焔に向って交互に話し掛けるような形式を執るならば、諸君は、低能のマダムと三時間話し合っても、疲れる事は無いであろう。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩けば疲れる、という話と同じ事だ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶えず空咳をし、疲れる。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "物言へば疲れるとでも思つてゐるやうに言葉は少かつた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『斯う疲れると、もう何も彼も要らない。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪くすると、腋の下や、のどに喰いつかれるのだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　神経のふるえているお蝶はとても安々と寝つかれる筈はなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねむらないとあしたつかれるぞ。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
