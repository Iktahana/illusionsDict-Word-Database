[
  {
    "uuid": "e53e9e53-3e2a-5224-a88f-0f6a5b1c1ca2",
    "entry": "疲れる",
    "reading": {
      "primary": "つかれる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-自動詞"
      ],
