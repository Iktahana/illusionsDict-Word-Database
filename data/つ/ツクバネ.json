          "literary": [
            {
              "text": "丈なす薔薇、色鮮やかな衝羽根朝顔、小さな淡紅色の花をつけた見上げるような莨の叢立ち、薄荷、孔雀草、凌霄葉蓮、それから罌粟。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            },
            {
              "text": "つくばねの峰より落つるみなの川恋ぞつもりて負けてやる私たち二人は腹をかかへて笑つた。",
              "citation": {
                "source": "海阪",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭を採つたり、つくばねの実を採つたり、山毛欅茸を採つたり、路草くふことも多かりしかば、斯く五時間も長くかゝりたる也。",
              "citation": {
                "source": "秋の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
