    "definitions": [
      {
        "index": 1,
        "gloss": "toothpick",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は仕方なく銀杏の実を爪楊枝でつついて食べたりしていた。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は年中、「俺は爪楊枝けずりの職人の息子だ」　と、昂然と言っていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれは爪楊枝けずりの職人の息子や。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪楊枝けずりの息子が……」　と、思うが、鋭く迫って来る剃刀の光はヒヤリと冴えすぎていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪楊枝職人の息子は、侮辱されたと、誇張して考えた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この爪楊枝けずりの息子は、爪楊枝の先ほどの情熱も感じていなかった陽子に、はじめて情熱を動かされた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪楊枝がマッチの軸を焼き亡ぼしてしまうのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪楊枝けずり職人の家に生れたのは、偶然だ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸運に恵まれた男だというわけだが、しかし、例えば爪楊枝職人の家に生れたという偶然を、結局幸運な偶然にしてしまうまでには、絶えず偶然の襟首を掴んで、それに自分を賭けるというスリルがくりかえされて来たのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴子が貴族に憧れるのは、結局卑賤に生れたことが原因しているが、それと同じ理由で、爪楊枝けずりの職人の家に生れた章三は、貴族というものに敵意を感じていたのである。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、爪楊枝けずりの職人の息子だということが、章三の自尊心を人一倍傷つき易いものにしていたから、人一倍カッとなって、殆んど前後の見境もなくなるところだった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」越後も食事がすんだらしく爪楊枝を使いながら、にやにや笑って言った。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「滝口慶一君は、じぶんの爪楊枝みたいなものが、ときたま鉛筆のようになるのは、夜中にオシッコが漏れないようにする蓋だとばかり思いこんで、中学一年の夏休みを迎えてしまいました。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルバシュカは爪楊枝を使ひながら座に戻ると煙草盆を覗いて、「怪つたいだなあ、吸さしがみんななくなる、誰かさらへるのかな。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "普段もこんな調子で、爪楊枝一本無駄にはしない。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに関聯して、痩せた男にとっては余りどうも香ばしくない話が出た――そもそも痩せん坊などというものは、せいぜい爪楊枝かなんかに類するもので、人間じゃないというのだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "香のものは大根が二切、あとは魚ばかりで、爪楊枝をつかつても、氣持ちの惡いほどなまぐさい。",
              "citation": {
                "source": "旅人",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪楊枝を使う間もなく崩れ落ちるように睡くなった。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴だろうは酷かろう」紫錦は爪楊枝を噛みしめた。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の編物がその前にあったが、彼女はそれを下に置いて爪楊枝で歯をほじくっていた。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この咳払いは、彼女が爪楊枝を使いながら黒くくっきりとした眉毛をわずかばかり揚げることと共に、彼女の夫に、彼が路の向側まで行っていた間に誰か新しいお客が立寄っていないか、店を見※してお客の間を探した方がいいだろう、ということを暗示したのである。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな風に洗礼名★の交換がすんだ時、マダーム・ドファルジュは、爪楊枝で歯をほじくりながら、また一つ咳払いをし、また少し眉毛を揚げた。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして二度目にその洗礼名を交換している時に、マダーム・ドファルジュは、極めて落著き払ってやはり爪楊枝を使いながら、また一つ咳払いをし、また少し眉毛を揚げた。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この三度目の洗礼名の交換が終った瞬間に、マダーム・ドファルジュは爪楊枝をやめて、眉毛をきっと上げ、自分の座席で少しさらさら音をさせた。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう問答をしているうちにも、今は血刀を拭い終えて、陣十郎の横手に佇んで、爪楊枝を噛みながら、二人の問答を上の空のように、平然と聞き流している、女の姿を観察した。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手燭の光でみますと、カケガネはかかっていますが、釘がさしこんでないようですから、隙間から爪楊枝をさしこんで鐶をもちあげると、なんなく外れました。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二　密室大犯罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "血をふまないように用心に用心して、それを拾って逃げましたが、部屋をでるときにふと気がついて、もう一度隙間から爪楊枝をさしこんで鐶にかけて外からカケガネをかけてしまいました。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二　密室大犯罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "カケガネを爪楊枝で外したのはたしかに非常識ですが、そんなことには気がつかなかったぐらい夢心地で早く叔父にあやまりたい一心でした。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二　密室大犯罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "その魚肉の上には、つまようじにつけた小さな旗がそえてあった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど私のほうがフォークもつまようじも添えて出していなかった。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
