    "definitions": [
      {
        "index": 1,
        "gloss": "to seize",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "で、まづ我々詩人が、詩の生存態をハツキリと掴むことが問題であると思ふ。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕立や草葉を掴む群雀　急の夕立に打たれて、翼を濡らした雀たちが、飛ぼうとして飛び得ず、麦の穂や草の葉を掴んでまごついているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『やつちまへ』『疊ん仕舞へ』彌次馬の聲援、畢竟は我が味方と、芳は勇み立つて、無手と對手の襟髮を掴むや、馬手の下駄は宙を飛んで、その頬桁を見舞はんとす。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣竿を寄せ、竿頭からテグスを掴むと、私は力まかせに引つ張つた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場を張り守っていた河神は猶予なく姿を掴む。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "追って来た児分、駕籠の棒掴む。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "両方ですれ違った時、主膳お小夜の手をグッと掴む。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "主膳、近侍を呼び止めて、Ｔ「門前にふんぞり七兵衛と申す御用聞がうろうろ致して居る」　と言ってなりひらの方をジロリと睨んで、Ｔ「その七兵衛に斯う申せ」　と言って、Ｔ「お尋ね者のなりひら小僧が拙宅に忍び込んだ」　えッ、となりひら油断なく大刀を掴む。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（門人数名を供に連れている）　こらッと、その侍白倉源五左衛門、おしまの腕を掴む。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　武蔵の手が草叢の縄を掴む（縄である事をはっきり見せて下さい）。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの持っている血筋をここに新らしく立てる私の家の系図へちっとばかり注ぎ入れて頂きたいのです」　貝原の平顔は両顎がやや張って来て、利を掴むときのような狡猾な相を現わして来た。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "憲兵が取調べる際にも、やはり、その弱点を掴むことに伍長と上等兵の眼は向けられた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがまた喧嘩のはじまりで、気の早い富蔵は相手の横っ面をぽかりとなぐりつけると、藤吉はかっとなって富蔵の胸倉を引っ掴むと、そのはずみに喉を強く絞めたとみえて、富蔵はそのままぱったり倒れてしまったので、藤吉はびっくりして逃げ出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰の力で、アメリカの秘密を具体的に掴むことが出来たんだ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今にも襟髪を掴むか、今にも崖から突き落とすか、そんな恐怖で息も止まりそうになっているんです。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉛の錘かとおもう心持、何か木の実ででもあるかしらんと、二三度振ってみたが附着いていてそのままには取れないから、何心なく手をやって掴むと、滑らかに冷りと来た。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けたたましき跫音して鷲掴に襟を掴むものあり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして金を掴めば掴むほど、そうした堕落層の裏面に深入りして行った。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "両君はその「０」を掴むべく夢中になって御座るようだから……。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてただ裸一箇の自分となり独力、座禅思惟の一法によってかの解脱を掴むか掴まえぬか、面と向った真剣の勝負に驀地に突き進むこととなった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにはいろいろ手段がありますが結局、本当の確信を掴むことです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「上へ五｜本めの、一つ消え殘つた瓦斯燈の所に、怪しいものの姿が見える……其は、凡て人間の影を捉る、影を掴む、影法師を啖ふ魔ものぢや。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちたる鉄槌を奪うと斉しく、お沢の肩を掴む。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も、妖物が出るの、魔が掴むのということは、目の前にあるとも思わないが、昔からまるで手も足も入れない処じゃあ、人の知らない毒虫が居て刺そうも知れず、地の工合で蹈むと崩れるようなことがないとも限らないから。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　藁草履を蹴立てて飛着いて、多磨太が暗まぎれに掻掴む、鉄拳に握らせて、自若として、少しも騒がず、「色男！",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂を掴む、小砂利を投げる、溝泥を掻廻す、喧嘩はするが誰も味方をするものはない。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒鷲には襲わるる、少年の身に添えて守っていたと覚ゆるのを、掴むがごとく引出して、やにわに手を懸けて※り棄てようとした趣であった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水を掴むようなもので、捜ればはらはらとただ貝が出る。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊太利の繁華なる港といへば、此處は國中隨一の名港子ープルス、埠頭から海岸通りへかけて商館の數も幾百千、もしや濱島は此港で、其商會とやらを營んで居るのではあるまいかと思ひ浮んだので、實に雲を掴むやうな話だが、萬が一もと旅亭の主人を呼んで聽いて見ると、果然！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "と驚きの余り八蔵は、思わず声を立てけるにぞ、婦人は少し枕を上げて、窓をあおぎ見たる時、八蔵ぬっと顔差出し、拳に婦人を掴む真似して、「汝、これだぞ、と睨めつくれば、連理引きに引かれたらむように、婦人は跳ね起きて打戦き、諸袖に顔を隠し、俯伏になりて、「あれえ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
