    "definitions": [
      {
        "index": 1,
        "gloss": "commuting to school",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "普通学校で第一に仕立てるべきものは未来の官吏、学者、教員、著述家でなくて「人」である。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "演習なり実習なりである講義を理解する下地の出来たものは自由に入れてやって、普通学の素養などは強要しない。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "合格すると無理やりに通学しだした。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸い、中学へやるくらいの金はあるから、市で傘屋をしている従弟に世話をして貰って、安くで通学させるつもりだった。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "強て何か話が無いかとお尋ねならば、仕方がありません、わたくしが少時の間――左様です、十六七の頃に通学した事のある漢学や数学の私塾の有様や、其の頃の雑事や、同じ学舎に通った朋友等の状態に就いてのお話でも仕て見ましょう。",
              "citation": {
                "source": "学生時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともそのころでもモダーンなハイカラな人もたくさんあって、たとえば当時通学していた番町小学校の同級生の中には昼の弁当としてパンとバタを常用していた小公子もあった。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲府は遠いので通学には困難である。",
              "citation": {
                "source": "律子と貞子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　さて、次の朝、久助君はまた、通学団の集合時間におくれてしまつた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで栄蔵は、少し離れた地蔵堂町狭川の子陽といふ先生が開いてゐる塾に通学をはじめる。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校は正則と変則とに別れて居て、正則の方は一般の普通学をやり、変則の方では英語を重にやった。",
              "citation": {
                "source": "落第",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "正則というのは日本語｜許りで、普通学の総てを教授されたものであるが、その代り英語は更にやらなかった。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、予科三年修了者と、その頃の中学卒業生とを比べて見ると、実際は予科の方が同じ普通学でも遙に進んでいたように思われた。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、そこは、べつの通学団の遊び場所だったから。",
              "citation": {
                "source": "久助君の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日毎日通学するのだがネ。",
              "citation": {
                "source": "ねじくり博士",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "南町の邸は、祖母さんが監督に附いて、英吉が主人で、三人の妹が、それぞれ学校に通っているので、すでに縁組みした令嬢たちも、皆そこから通学した。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々（いらっしゃい、）と怒鳴って、下足に札を通して通学生を驚かす、とんだ愛敬もので、小使さん、小使さんと、有名な島山夫人をはじめ、近頃流行のようになって、独逸語をその横町に学ぶ貴婦人連が、大分｜御贔屓である、と云う雑報の意味であった。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりながらはじめの内は十幾人の塾生ありて、教場太く賑ひしも、二人三人と去りて、果は一人もあらずなりて、後にはたゞ昼の間通学生の来るのみにて、塾生は我一人なりき。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは興醒めた気持になって、これでは葛岡のことを相談しても駄目だと思い、たださり気なく、日々通学する学園の生活のはなしをして、そこには丘の陽当りに果樹園があったり、花畑があったりして学課の間には土いじりもする。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし大久保が躑躅の名所であった時分に中どころの植木屋であった葛岡の家も、大久保が町中となり、父がリウマチスを重らして床に就き、間も無く死んでしまってから、頽齢の祖母と、老齢に近い母を背負って葛岡は園芸学校へ通学しなければならなかった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学園に勤めていれば月給は僅かでも、教職員の舎宅や住家の庭の面倒を見ても心付けは貰えたし、裕福な家からの通学生は馴染の学園の園芸手を自宅に呼び招いて仕事をさして呉れた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女の安宅先生は、通学の途中、よく子供たちに石を投げられた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学生の時分より着ているよれよれの絣の着物で通学した。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は生れつき特権というものを毛嫌いしていたので、私の学校が天下の秀才の集るところだという理由で、生徒たちは土地で一番もてる人種であり、それ故生徒たちは銭湯へ行くのにも制服制帽を着用しているのを滑稽だと思ったので、制服制帽は質に入れて、和服無帽で長髪を風に靡かせながら通学した。",
              "citation": {
                "source": "髪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "世田ヶ谷若林　馬込から越したのは、子供たちの成城への通学の便宜を思つたからである。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の透はこの近所の植木屋の座敷を借りて、そこから通学している。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二回目に先生を訪問したのは四月の末で、その日は平日であったので通学中の多代子さんは見えなかった。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は同時に小学校を出、同時に京城の中学校に入学し、毎朝一緒に龍山から電車で通学することになった。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
