        "examples": {
          "standard": [
            {
              "text": "このスーパーでは、毎週土曜日に野菜の詰め放題セールを開催している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちは、お菓子詰め放題のイベントに目を輝かせ、夢中で袋に詰め込んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "旅行のお土産に、地元の特産品を詰め放題の箱にぎっしり詰め込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
