        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『郷土研究』巻四と『日本及日本人』去る春季拡大号へ出した拙文に大概説き置いたから、なるべく重出を省いて約やかに述べよう。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "母なきを、つづまやかに暮らす親一人子一人の京の住居に、盂蘭盆の灯籠を掛けてより五遍になる。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "公子　つづまやかな美しさが、その一人娘の彳んだ姿を装飾っていたでござりましょう。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "閉められた板戸の隅々から、弱い電燈の光がそれ等の家々のつづまやかさを洩らしていた。",
              "citation": {
                "source": "地図にない街",
                "author": "橋本五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、そういう賢明な婦人は別として、一般の婦人は天性つづまやかであるため、それが一つの欠点になっている場合が少なくないのであります。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
