    "definitions": [
      {
        "index": 1,
        "gloss": "vehicle waiting to be hired",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "辻待ちの車夫の溜りで車屋が手をねじ合いしている。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十年十月十日）　　　　　　　＊　辻待ちの円タク、たとえば曙町まで五十銭で行かないかというと、返事をしないでいきなりそっぽを向いてしまうのがある。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子はわざと宿で車を頼んでもらわずに、煉瓦通りに出てからきれいそうな辻待ちを傭ってそれに乗った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時女はそのへんに辻待ちをしている車に乗ろうとする所だった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次はタキシーだの何かいう貸自動車と辻待ち自動車で、福岡のメートル自動車と同様なものである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、辻待ちは殆ど東京市の目抜の通りにしか居ないので、ちょっとオックウな場合が多い。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻待ちの駕籠へポンと乗った。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日今日からメッキリ寒気が身にしみやがると、モーロー車夫の捨吉は毛布をひっかぶって上野広小路にちかい小路の角で辻待ちをしていた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "お駕籠を、と老爺が言うのを、「なに、九段で辻待ちをつかまえる」　と、したくもそこそこに、多門は徹馬とつれ立って屋敷を走り出た……。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が気でない与吉は、辻待ちの駕籠に左膳を押しこんで、自分はわきを走りながら、まっしぐらに本郷へ……。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこのところに、辻待ちの駕籠屋が、戸板をめぐらして、股火をしていた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいにくモスク※では、辻待ちの橇も露天商人も、素子のその癖を刺戟する場合が多かった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑色の円い韃靼帽をかぶった辻待ち橇の馭者が、その人だかりを白髯のなかからながめている。",
              "citation": {
                "source": "モスクワ印象記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那、駕籠はいかが」　とある柳の木の下、これは辻待ちの駕籠屋ですから、喫驚するには当りません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十六　これより先、代官屋敷からは程遠からぬ三本松の辻に辻待ちをしていた二梃の駕籠、都合四人の雲助が、客を待ちあぐみながら、こんな話をしていました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関さきには夜稼ぎの辻待ち馬車屋が、粗ラシャの百姓外套を着て、たった一人しょんぼり客待ちをしていた。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "まわりで辻待ちの馭者が兵隊たちとしゃべりながら、そんな話をしていたっけ。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった今、どこかの辻待ち馭者が鞭を一本くらわしたからだ。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは京橋の北詰で辻待ちをした。",
              "citation": {
                "source": "秋の駕籠",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は運転台で、背を丸くし、鳥打帽をまぶかにして、うらぶれた辻待ちタクシーの運転手を装った。",
              "citation": {
                "source": "蟲",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いうまでもなく、柾木の偽瞞が効を奏して、彼女はその車を、辻待ちタクシーと思い込んでいたのである。",
              "citation": {
                "source": "蟲",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "追い追い改良、つやのよい黒塗り金紋、ひき子も黒の法被に大黒帽などと進歩したが、辻待ちなどには随分小汚ない古車も多く、心棒にわらじが一足ぶら下って鉄の輪を二つ、これが走りだすとジリンジリン鳴る。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
