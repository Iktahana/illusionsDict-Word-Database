        "examples": {
          "standard": [
            {
              "text": "彼は相当な旋毛曲がりで、みんなが右と言えば必ず左と言い張る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "せっかくの親切を素直に受け取らないなんて、本当に旋毛曲がりな性格だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "旋毛曲がりの彼を説得するには、真正面からぶつかるよりもお世辞を言う方が効果的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "では老師先生」　金博士は、日頃のつむじまがりもどこへやら、まるで人がちがったように師の前には従順となり、庭園へ出た。",
              "citation": {
                "source": "大使館の始末機関",
                "author": "――金博士シリーズ・７――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、教えてやろうかと思ったが、やっぱり教えないでおくか」　博士は、どこまでも意地悪で、つむじまがりであった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年にたいする祖母の盲目的な偏愛は、祖母と母との衝突のほとんど唯一の原因だつたが、そのたびに少年は母のきびしい躾けを内心怨みながらも、その一ぱう母のためにかなり強い義憤を覚えずにゐられぬ程度には、つむじまがりの早熟な少年であつた。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　すね者というと、変につむじまがりか、さもなければ卑屈な人間が多いけれど、この蒲生泰軒先生のように、とてもほがらかに世の中をすねちゃった人物は、ちょっとほかに類がないであろう。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "（注）あちらでは、つむじまがりのことを背骨まがりと申します。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしい頑固なつむじまがりの、高慢で癲癇持ちで人の気嫌なぞを些とも気にかけない、撲ぐられてもひいひい泣いても涙を見せないやうな子であつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしかすると世間の人々の好みに合ふことがつむじまがりのわたくしの好みに合はないのではあるまいか。",
              "citation": {
                "source": "谷崎文学の代表作「細雪」",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
