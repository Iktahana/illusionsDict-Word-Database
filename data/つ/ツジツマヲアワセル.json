    "definitions": [
      {
        "index": 1,
        "gloss": "to make one's story to seem coherent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
