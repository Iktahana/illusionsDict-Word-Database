    "definitions": [
      {
        "index": 1,
        "gloss": "(ceremony of) driving out evil spirits",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
