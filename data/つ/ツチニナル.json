    "definitions": [
      {
        "index": 1,
        "gloss": "to die",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けだし、風病にかかって土になることはけだしすべて吾人に免かれないことですから。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京に行つて、知らぬ土地の土になるのは厭だ！",
              "citation": {
                "source": "朝",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "（前略）あゝ腐葉土のない土に種まく日本の女詩人よ自分自身が腐葉土になるしかない女詩人よなれよ立派な腐葉土に。",
              "citation": {
                "source": "『静かなる愛』と『諸国の天女』",
                "author": "――竹内てるよ氏と永瀬清子氏の詩集――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうやってトドの究りは、どこかの果の土になるんだ。",
              "citation": {
                "source": "世間師",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは、隊長の僕の日本の領土になる。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "所詮人界が浄土になるには、御仏の御天下を待つほかはあるまい。",
              "citation": {
                "source": "俊寛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京市なんか、敵国の爆撃機が飛んできて、たった五｜噸の爆弾を墜せば、それでもう、大震災のときのような焼土になるんです。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "農我父は農夫なり　　約翰伝第十五章一節一　土の上に生れ、土の生むものを食うて生き、而して死んで土になる。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水却て魚棲まず、草一本もない土は見るに気もちがよくとも、或は生命なき瘠土になるかも知れぬ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土から生れて土に働く土の精、土の化物とも云うべき農家の人は、死んで土になる事を自然の約束として少しも怪むことを為ない。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土から生れて土を食い土を耕して終に土になる土の獣の農が、土を奪われ土から追われた時の心は如何であろう！",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私共もいよ／＼粕谷の土になる事にきめました。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよ／＼私共も粕谷の土になるにきめました。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすれば、あの虫ばんだ不浄の死体――土になるばかりになっている死体のために、あなたの魂を失うようなことはありますまい。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "クラリモンド",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは果してよくケーベル先生やハーン先生のように一生涯他郷に住み晏如としてその国の土になることができるであろうか。",
              "citation": {
                "source": "西瓜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョホールの土になる気でさえあったら、智恵子を死ぬほど苦しめるような事もなかったでしょうし、弟をあんな悪者につくり上げずともすんだのでしょう。",
              "citation": {
                "source": "鉄の処女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くともそれが科学者を作る培養土になることは決してない。",
              "citation": {
                "source": "科学と文化",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「水上氏は、アメリカの土になることを望んでいられました」「サト子はお祖父ちゃん子なので、ショックを受けると困るから、死んだことは、まだ話さずにありますが、そんなことを聞いたら、さぞ嘆くこってしょう。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日は、もう、運ぶだけのものを馬に積んで、乳母と子供は駕籠に乗せ、お松はあるところまで馬で――七兵衛は途中のいずれかで待合わせるということにして、幾多の村人や、教え子に送られて、この地の土になるのかと思われていたお松は、綺麗にこの地を立ってしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしらの住む所、みな浄土になる」と人々はいったが、「いや、わしらというのは、誇りがましい、念仏の声のわく所――じゃ」こんなひどい茅ら屋と食物とに生きながら、夏も一人の病人も出なかった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何百年、何千年、今夜のような業火をくり返して、ここの土が、ほんとに、禍いなく安楽に住める土になることやら？",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらあお城の土になるそうな。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――他へお急ぎの儀もござりましょうが、せめて一夜お泊り下さいますわけには行きますまいか」「これは――」　と会釈を返して、「ありがたいお言葉ですが、船島の土になるやも知れぬ身に、一夜二夜の宿縁を、ここかしこに残しては、去る身も、後の人々も、かえって煩わしいと思われますれば」「ご斟酌が過ぎまする。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣山に行きついて、剣山の土になるのは、いわゆる、木乃伊とりの木乃伊になるの類で、弦之丞がここまでの苦艱も、結果は、無意味なものに帰してしまう。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "剣山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三国峠を越え、浅貝、三俣から神立村へ下りると、もう越後新田党の領土になる。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人ぽつちになることは、どうしても彼には出来ないことである。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「もうＹは一人ぼつちになるんだわ。",
              "citation": {
                "source": "蛾はどこにでもゐる",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "どつちになるものやら分らんが、どつちになつたかてわしには大差ないこつちや。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "答　それはどつちになるかわからない。",
              "citation": {
                "source": "東西問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども鼻唄まじりに頂上を目指してるラランも、ひとりぼつちになると、やつと疲れが出てきた。",
              "citation": {
                "source": "火を喰つた鴉",
                "author": "逸見猶吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
