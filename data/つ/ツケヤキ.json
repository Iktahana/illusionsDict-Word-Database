          "literary": [
            {
              "text": "つけやき刃なら、それがはがれる時になっていたとも見られよう。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そのつけやきばの平気は、すぐに裏切られるやうな運命を持つてゐた。",
              "citation": {
                "source": "世之助の話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "地には天に向つて立つけやきがある。",
              "citation": {
                "source": "暗い時間に",
                "author": "片山敏彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土と天候とは沈黙のうちに教えています、俄づくりやつけやきばは役立ちませんよ、と。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
