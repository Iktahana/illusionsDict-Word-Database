    "definitions": [
      {
        "index": 1,
        "gloss": "mud wall with a roof",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
