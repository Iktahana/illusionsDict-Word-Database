[
  {
    "uuid": "acca5d95-6219-5406-993b-3a2453aee898",
    "entry": "痛切",
    "reading": {
      "primary": "つうせつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
