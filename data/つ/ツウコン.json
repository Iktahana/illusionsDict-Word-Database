[
  {
    "uuid": "3778432a-750f-58f1-ad0d-82f890f7e243",
    "entry": "痛恨",
    "reading": {
      "primary": "つうこん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
