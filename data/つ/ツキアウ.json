[
  {
    "uuid": "c679a00a-a5b1-57d2-b67b-d5340fbd2244",
    "entry": "付き合う",
    "reading": {
      "primary": "つきあう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
