        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人見は軽い機智の使いどころがなくなって蔭に廻った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこが心眼の使いどころだよ」　虎之介は花廼屋を睨みつけた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二　密室大犯罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず初代は、幾多の困難に打ち勝って漸く一家を成したのですから、金銭に対してもその価値を知っていて、同じ使うにも使いどころをわきまえている。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、こまごましたことをやらせて見ると、使いどころがあるものである。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、この中へしのびこんで、にせ黄金塔にもまよわされず、ほんものの宝物をぬすむことができるとすれば、二十面相は、もう魔法使いどころではありません。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "不馴れのものは、自分たちの権利のつかいどころを知らない。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
