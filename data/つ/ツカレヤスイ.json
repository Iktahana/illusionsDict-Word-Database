        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "疲れやすいこと欠伸をしたいことなどは、むしろ男より女の方がよけいかもしれない。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから私はまだ疲れやすいので少し話しては休み休みして幾度にも切って話をせねばなるまいと思います。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭はしかしまだすこし疲れやすい。",
              "citation": {
                "source": "日記",
                "author": "一九四七年（昭和二十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、何せ、疲れやすい私の事だから、先ず一番楽なコオスをと思って、野尻湖に来た。",
              "citation": {
                "source": "晩夏",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――海は疲れやすいのね。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "迚も疲れやすい子でしたから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し暑熱に対していい脂肪絶無の食事ですから疲れやすいのでしょう）　そちらいかがお暮しでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
