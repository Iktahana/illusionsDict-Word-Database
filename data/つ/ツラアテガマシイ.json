        "examples": {
          "standard": [
            {
              "text": "彼の面当てがましい態度のせいで、職場の空気が一気に悪くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女の面当てがましいSNSの投稿を見て、正直うんざりした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "誰に言っているのかわからない面当てがましい発言は、周りを困惑させる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "まるで面当てがましいような素振りさえするのでございます」「どんなふうにだね」「今日のお昼に、わたくしが、親身のような愛情を示そうと、試しに娘の食べかけの残したお菜に箸をつけようとしますと、娘はその皿を急に引ったくりまして、お母様、これは私の食べかけでございます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に権兵衛が自分に面当てがましい所行をしたのが不快である。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんど何か自分の面当てがましいことをいったら、躍り立って、壇にいる善信の襟がみを引っ掴んでやろうと心に企んでいるらしく、じっと、聞き耳を欹てて、善信のことばを聞いていた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　至極もっともなことをいいながら、しきりとつらあてがましい声援を始めました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            }
          ]
        }
