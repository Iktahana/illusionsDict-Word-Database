    "definitions": [
      {
        "index": 1,
        "gloss": "leaving (on, open, unfinished, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども観衆の大半は、ひょっとしたら、やっぱり侘びしい人たちばかりなのではあるまいか。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、やっぱり、言葉でなければいけないか。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と断じて、悠然と引上げ、「ああ、やっぱり、ヒットラーに限る！",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も、ごぞんじ無いのだ、と私は苦しさを胸一つにおさめて、けれども、その事実を知ってしまってからは、なおのこと妹が可哀そうで、いろいろ奇怪な空想も浮んで、私自身、胸がうずくような、甘酸っぱい、それは、いやな切ない思いで、あのような苦しみは、年ごろの女のひとでなければ、わからない、生地獄でございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、やっぱり神さまのお恵みでございましょう。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日一日をいっぱいに生きている」　それ以後、私は馬場へ肉親のように馴れて甘えて、生れてはじめて友だちを得たような気さえしていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな姿はやっぱり好いな。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それから、――ＡはやっぱりＢを信じている。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うむ、とりきんで足袋を引っぱったら、私はからだの重心を失い、醜くよろめいた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私も若い時には、大酒を飲んだものですが、いまはもう、さっぱり駄目になりました。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」やっぱり、その事が先生にとっても、まず第一に気がかりになる様子であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供等は何か無性に面白がって餅を握りながらバタバタと縁側を追い廻る、小さいのは父上の膝で口鬚をひっぱる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルのポルチエーが自分を小蔭へ引っぱって行って何かしら談判を始める。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南向きの高い四つの窓から、東京の空の光がいっぱいに流れ込む。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い丸髷の下町式マダムが弁慶縞の上っぱりで、和装令嬢式近代娘を相手に、あでやかにつややかに活躍している。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴫はやっぱり見えぬらしい。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "に朱罫、十八行二十四字）いっぱいに画いた附近の略地図である。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規常用の唐紙に朱罫を劃した二十四字十八行詰の原稿紙いっぱいにかいたものである。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りにはやっぱり御院殿の坂が見付かった。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室へ入ろうとするといつの間にか商人｜体の男二人その連れらしき娘一人室へいっぱいになって『風俗画報』か何か見ているので、また甲板をあちこち。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また左舷へ帰って室へはいって革鞄から『桂花集』を引っぱり出して欄へもたれて高く音読すると、艫で誰れか浮かれ節をやり出したので皆が其方を見る。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸田露伴にも『枕頭山水』の名作があり、キビキビした筆致で、自然でも、人間でも、片っぱしからきめつけるような犀利な文章を書いている。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「武士は食わねど高楊子」主義で突っぱった当時の青年文士は、いいかげんシビレを切らしても、原稿料の催促はしたくなかった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから尾根を伝わって、下り気味になる、ちょいちょい小さく尖った山稜は、大波の間に、さざ波をだぶだぶ打ち寄せたようで、爪先が上ったり下ったりする、石の皺には、黄花の石楠花が、ちらほら咲いている、この花の弁で承けた霧の雫を吸ったときは、甘酸っぱい香気で、胸が透いた。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが遂にアブばかりでなかった、石楠花の甘ずっぱい香気は私を包み、アブを包み、森に漂って、樹々の心髄までしみ透るかのように、私までがアブの眷属になったかのように。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、この野郎白っぱくれて、網を張ってやがるんじゃねえかな。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何が何だかさっぱり訳が分らねえ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私にはこのアステーア、ロジャースの踊りのデュエットは見ていてやっぱりおもしろい。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけがわからないくせにやっぱりおもしろいのが不思議である。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、またやっぱり腹と意気がなくては芸はできないものではないかと思うのである。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
