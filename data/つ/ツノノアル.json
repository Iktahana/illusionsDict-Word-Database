    "definitions": [
      {
        "index": 1,
        "gloss": "horned (of an animal)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」肥った、眼に角のある、村会議員は太い声で云った。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、霧がはれましたので、角のある石は、空を向いて、てんでに勝手なことを考へはじめました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、霧がはれましたので、角のある石は、空を向いて、てんでに勝手なことを考えはじめました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し妻は容易に寝そうもないので、「早くお寝みというに」　自分はこれまで、これほど角のある言葉すら妻に向って発したことはないのである。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "木尻座の筵に、ゆたかに、角のある小判形にこしらへて積んであつた餅を、一枚、もろ手、前脚で抱込むと、ひよいと飜して、頭に乘せて、一つ輕く蜿つて、伸びざまにもとの障子の穴へ消える。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｗ・Ｃへ通りがかりに、上から蔽かぶさるやうに來た時は、角のあるだけ、青鬼の方がましだと思つた。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "角のある人魂めかして、ぶらりと風呂敷包を提げながら、小川べりの草の上。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには角のある鬼や、口の尖っている狐などの影は決して見られなかった。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、額に太い二本の角のある大きな牛であった。",
              "citation": {
                "source": "赤い牛",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆牛の頭のように角のある顔の恐ろしい、それで体の青い紺色の髪の毛の、頭にも手足にももじゃもじゃと生えた者で、それがそれぞれ戟のような物を持っていた。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "門口にいた守衛のような角のある体の青い夜叉が、どこからくるともなしに刀を持って出てきて、男の方に近寄るなり、いきなりその刀を男の腹に突込んで切り裂いた。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは額に二本の角のある青い体をした夜叉であった。",
              "citation": {
                "source": "太虚司法伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "額の左右に角のある赤い髪の者、青い髪をして翼の生えた者、鳥の喙のような口をしての体をして、口から火のような焔を吐いていた。",
              "citation": {
                "source": "太虚司法伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　金平はとうとう角のある語調で言い出した。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊ちやんも、白糸でつないだ固い角のある黒い虫の荷馬を持つて、後から上つてお出でになつた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには角のある鬼や、口の尖つてゐる狐などの影は決して見られなかつた。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "――「近代異妖編」",
                "note": "青空文庫"
              }
            },
            {
              "text": "円い葉のつぎに三角の葉が出て、やがて茎の端に、触角のある蕾を持ちはじめました。",
              "citation": {
                "source": "日輪草",
                "author": "日輪草は何故枯れたか",
                "note": "青空文庫"
              }
            },
            {
              "text": "角のあるものは、ドアーと三角形のレントゲン室と、病人だけだ。",
              "citation": {
                "source": "寢たらぬ日記",
                "author": "湘南サナトリウムの病院にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "角のある龍や、乾魚のやうに痩せた学校教師や、白鳥のお嫁になつたお姫様や、そんな面白い話を幾つとなく聴かせたが、娘は黙つて聴いてゐて、時々「はい」とか、「いゝえ」とか応答をするに過ぎなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがまた、それを受けとらうものなら、次ぎの晩には頭に角のある、そいつの仲間が沼地からお客に押しかけて来るのぢや。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、あの戸の後では、山羊のやうな角のある先生が、因辺留濃の夢でも見てゐるのだと思ふと、折角、はりつめた勇気も、意気地なく、くじけてしまふ。",
              "citation": {
                "source": "煙草と悪魔",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこの三角定木、自分の体にわ、三方に尖った角のあるのを、大層自慢に致し、世間に品も多いが、乃公ほど角のあるものわあるまい、角にかけてわ乃公が一番だと、たった三つよりない角を、酷く鼻にかけておりました。",
              "citation": {
                "source": "三角と四角",
                "author": "巖谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　最初から角のある言い方だ。",
              "citation": {
                "source": "早春",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "するうちにその霧の中から、ねじ曲がった二本の角のある頭が出て、それがほえると、続いてたくさんの頭が現われ出て、だんだん近づいて来ました。",
              "citation": {
                "source": "真夏の夢",
                "author": "ストリンドベルヒ　August Strindberg",
                "note": "青空文庫"
              }
            },
            {
              "text": "刺鮫というのは相当に大きな奴で、夜、海の中を行くと、白い光が潮に透って見える、こいつは舟をくつがえしたり、人を食ったりする怖るべき奴で、舟乗りはこいつにでっくわすと鰹を投げてやって逃げるのだが、この刺鮫も頭に角のあるというのを聞かない――一角魚の角は角というよりは嘴だ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来、良寛様は相当圭角のある人であるようである。",
              "citation": {
                "source": "良寛様の書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで広く平かな面は別状はないが、縁まはりだとか、口づくりだとか、角のある角作りだとか言つた処に於て化粧土が素地を離れて少しづつ浮び上る。",
              "citation": {
                "source": "「明の古染付」観",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついにわたしは両手でたぐって頭につののあるパウトをおもむろに引きあげる――それはキュウというような音をたてて、うごめきつつ水をはなれるのである。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
