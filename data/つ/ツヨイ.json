        "examples": {
          "standard": [
            {
              "text": "この生地は摩擦に強いので、アウトドア用品に最適だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はプレッシャーに強い性格で、本番でも実力を発揮できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "砂漠の植物は、乾燥した過酷な環境にも強い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "good (at)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
