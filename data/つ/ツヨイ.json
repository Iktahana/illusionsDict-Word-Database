        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はチームにとって非常に強い味方であり、いつも支えてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ピンチの時に彼が来てくれたのは、何よりも強い心の支えになった。",
              "citation": {
