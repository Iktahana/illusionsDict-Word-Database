    "definitions": [
      {
        "index": 1,
        "gloss": "tuna (esp. canned)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
