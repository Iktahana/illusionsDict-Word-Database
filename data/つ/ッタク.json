        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ちょっと僕にも、などと、ひとりで弱っている姿を見ると、聞き手のほうでも、いい加減じれったくなって来る。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ複雑にくすぐったく、私は、恥ずかしい思いである。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、あんな有様でしかもなお日本が勝ったら、日本は神の国ではなくて、魔の国でしょう。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮膚は、大仰な言いかたをすれば、鶯の羽のような汚い青さで、まったく光沢がなかった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が異国人と夜のまったく明けはなれるまで談じ合うほど語学ができるかどうか、そういうことからして怪しいもんだと私は思っている。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宰は瞬間まったくの小児のような泣きべそを掻いたが、すぐ、どす黒い唇を引きしめて、傲然と頭をもたげた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭髪は、以前より少し濃くなったくらいであった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空の気味の悪いほど、奥まで隙いて光っているだけに、富士山は繻子でも衣たように、厚ぼったくふやけている、いつもの、洗われたように浄い姿ではない、重々しい、鼠ッぽい色といったらない。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "レールに近く養蚕広告のペンキ塗の看板が、鉛のような鉱物性の色をして、硬く平ったく烈しい日の光に向って立っていたが、汽車と擦れ違いさまに、仆れそうになって、辛くも踏み止まった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは瓦が数枚落ちたのと壁に亀裂が入ったくらいのものであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくその中に、白くあらはされた天の川の左の岸に沿って一条の鉄道線路が、南へ南へとたどって行くのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」カムパネルラが、不思議さうに立ちどまって、岩から黒い細長いさきの尖ったくるみの実のやうなものをひろひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっ白な、あのさっきの北の十字架のやうに光る鷺のからだが、十ばかり、少しひらべったくなって、黒い脚をちぢめて、浮彫のやうにならんでゐたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると黄と青じろとまだらになって、なにかのあかりのやうにひかる雁が、ちゃうどさっきの鷺のやうに、くちばしを揃へて、少し扁べったくなって、ならんでゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく河原の青じろいあかりの上に、黒い鳥がたくさんたくさんいっぱいに列になってとまってぢっと川の微光を受けてゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくインデアンは半分は踊ってゐるやうでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく向ふ岸の野原に大きなまっ赤な火が燃されその黒いけむりは高く桔梗いろのつめたさうな天をも焦がしさうでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジョバンニはまったくその大きな火の向ふに三つの三角標がちゃうどさそりの腕のやうにこっちに五つの三角標がさそりの尾やかぎのやうにならんでゐるのを見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とったくらい与るぞ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "平ったくてまるで潰れた蕈のようです。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども壺穴の標本を見せるつもりだったが思ったくらいはっきりはしていないな。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "定性分析のコースを一学期やらせてもらったくらいのものであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の会など、見ているうちに何だか少しむっとするような気がして来てとうとう碌に見ないで帰って来て、それきりもう二度とは入場しなかったくらいである。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このガキ」　と紙入れを引ったくって遙かの方へ投げ捨てる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹が、Ｔ「今の旦那のお腰の物」　三次「馬鹿」と叱って、その十手をひったくって捨てる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かとおもうとまたそれは人間というより木石の如く、はたの神経とはまったく無交渉な様子で黙々といくつかの鮨をつまんで、さっさと帰って行く客もある。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "湊の対応ぶりに有頂天になった相手客が、なお繰り返して湊に盃をさし、湊も釣り込まれて少し笑声さえたて乍らその盃の遣り取りを始め出したと見るときは、ともよはつかつかと寄って行って「お酒、あんまり呑んじゃ体にいけないって云ってるくせに、もう、よしなさい」　と湊の手から盃をひったくる。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、まったく翡翠が杭の上から魚影を覗う敏捷でしかも瀟洒な姿態である。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まったくですわ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "国際連盟の持つイデオロギイからも、満州の階級性からも、シャンハイをまったく取巻いた赤色プロレタリアの××からも、第二、世界経済恐慌の襲撃からも、……しだいにかの女の吹鳴らすラッパの音韻の沈衰して行くままに。",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
