        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "空がツンツンと光ってゐる。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはツンツン、ツンツンと鳴いて、枝中はねあるく小さなみそさゞいで一杯でした。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひるはカンカン日のひかり　よるはツンツン月あかり、　たとえからだを、さかれても　狐の生徒はうそ云うな。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひるはカンカン日のひかり　よるはツンツン月あかり　たとえこごえて倒れても　狐の生徒はぬすまない。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひるはカンカン日のひかり　よるはツンツン月あかり　たとえからだがちぎれても　狐の生徒はそねまない。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "外では谷川がごうごうと流れ鳥がツンツン鳴きました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すがすがしい松脂のにほひがして鳥もツンツン啼きました。",
              "citation": {
                "source": "車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お空のひかり、おてんとさまは、カンカンカン、月のあかりは、ツンツンツン、ほしのひかりの、ピッカリコ。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはツンツン、ツンツンと鳴いて、枝中はねあるく小さなみそさざいで一杯でした。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひるはカンカン日のひかり　　よるはツンツン月あかり、　　たとへからだを、さかれても　　狐の生徒はうそ云ふな。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひるはカンカン日のひかり　　よるはツンツン月あかり　　たとへこゞえて倒れても　　狐の生徒はぬすまない。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひるはカンカン日のひかり　　よるはツンツン月あかり　　たとへからだがちぎれても　　狐の生徒はそねまない。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ぶらぶら歩行き出すと、ツンツンテンレン、ツンツンテンレン。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人連　　　　　　　十　午後、宮ヶ崎町の方から、ツンツンとあちこちの二階で綿を打つ音を、時ならぬ砧の合方にして、浅間の社の南口、裏門にかかった、島山夫人、早瀬の二人は、花道へ出たようである。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その客を斜に見おろすやうにしてうつとりとなり、右の手の指で軽くかはるがはるツンツンとテーブルの上を打つた。",
              "citation": {
                "source": "蛾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……前に、あなたが、まだ、先生のお玄関にいらっしゃる時分、私が時々うかがう毎に、駒下駄を直さして、ああ、勿体ない、そう思う、思う心は、口へは出ず、手も足も固くなるから、突張って、ツンツンして、さぞ高慢に見えたでしょう。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそのおもちゃでは満足が出来なかったと見えて、後にはお隣りから本物を借りて来て、二人でツンツン言わせていたこともある。",
              "citation": {
                "source": "私の母",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして素破という場合にはいつ何時でも、手と身とツンツンで飛出しさえすればこっちのものになるというわけである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が何時でもツンツンしているので、何んだ此奴と思って、健は嫌いな女だった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "一緒に仕事をしているうちに、健は「ツンツンした」女にひきつけられてきた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "小徳利のやうに下ぶくれの鼻からは鼻毛がツンツンと突出て土堤のやうに盛上つた上唇を衝き、そして下唇は上唇に覆はれて縮みあがつてゐるのを無理矢理に武張らうとして絶間なくゴムのやうに伸したがつてゐた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "小徳利のように下ぶくれの鼻からは鼻毛がツンツンと突出て土堤のように盛上った上唇を衝き、そして下唇は上唇に覆われて縮みあがっているのを無理矢理に武張ろうとして絶間なくゴムのように伸したがっていた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "水引の花などもさゝやかなくれなゐをそこに見せて、これでも花だといふやうにツンツン草の中に雜つて見えた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "藺のツンツン生えてゐるその尖頭に黒いヤンマが留つてゐて、その羽に日影の当つてゐるのが、何とも言へず沼の静けさを私に思はせた。",
              "citation": {
                "source": "ある日の印旛沼",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
