    "definitions": [
      {
        "index": 1,
        "gloss": "town-watches from the Edo period",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
