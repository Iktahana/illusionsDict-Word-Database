    },
    "definitions": [
      {
        "index": 1,
        "gloss": "navigation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "上り下りはなるべく人目を避くべし、川中の通航は遠慮の事、他船の往来を妨げざるよう心して川岸を通るべし、という御布令書の掟を重んじて、その川岸伝いに遠道の永代橋口へさしかかって行くと、酔狂といえば酔狂でした。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからぼくらは洞穴のなかで冬をこして、その間にここへ旗を立てておけば、通航の船が見つけて助けてくれるかもしれんじゃないか」　ゴルドンは両者のあいだにはいってなだめるようにいった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "海路はもう内海通いの汽船があったけれども、凡てが中国沿岸から、九州方面へ通航するばかりで、四国路は多度津の金比羅詣りに便する外どこへも寄らない。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "当夕八時、汽船の五、六丁離れたる所を通航するに会し、船客互いに呼応して過ぐ。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "世が世ならば、この船を自分の思うままに大手を振って、いずれのところへでも廻航するが、今は世を忍ぶ身の上で、公然たる通航の自由を持っていない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "家康は通航免許状を与え、また商館の設置を許した。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
