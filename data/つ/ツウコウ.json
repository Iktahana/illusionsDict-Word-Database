  {
    "uuid": "2eec64b8-bfab-5caa-819c-cc067a833255",
    "entry": "通航",
    "reading": {
      "primary": "つうこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
