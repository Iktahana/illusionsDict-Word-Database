    "definitions": [
      {
        "index": 1,
        "gloss": "artificial product",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これは全然作り物のペンネームであつたが、字面から受ける印象が、ぴつたりとその詩風の特色と一致し、いかにもよく「名は性を現はす」といふ感じがした。",
              "citation": {
                "source": "名前の話",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此篇の大缺點はどうしても作り物であるといふ疑を起す點にあり。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろ鼻というものは舞台の中心に置かれた作り物と見るべきが至当で、その場面の表現は他の役者が遣るからその作り物にも意義が出て来るのと同じわけのものではないか」　この二つの疑問や反駁は詰るところ同じ意味で、誠に御尤も至極な理屈と申し上げなければなりませぬ。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、左の路には作り物のほかに、本当の幽霊がまじっている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見ればこの岩は作り物であった。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "よい形をした五葉の枝に作り物の鶯が止まらせてあって、それに手紙が付けられてある。",
              "citation": {
                "source": "源氏物語",
                "author": "初音",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は清姫の話は何か拠るべき事実があったので、他の話に拠って建立された丸切の作り物と思わぬが、もし仏徒が基づく所あって多少附会した所もあろうといえば、その基づく所は釈尊の従弟で、天眼第一たりし阿那律尊者の伝だろう。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝶蜂は形を問わず、己が好む花の色したよい加減な作り物に付き纏う事あり。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まるで作り物のようでござりまする。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "權次　まるで作り物のやうでござりまする。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "このマストに、作り物の恐龍の首をとりつけるのだ。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐龍艇のりだす　それから十日の後に、ぼくたちは、恐龍の頭部の作り物の荷物を受け取った。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、作り物の恐龍でないことは、一目で分かった。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜといって、ぼくらの作り物の恐龍のそばまで行っても、まだ本物かどうか分かりかねていたからね」「じゃあ行ってみよう」「ぼくも行く」　ぼくたちは、足音を忍びつつおそるおそる湾の見えるところまで行った。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "奉納の生人形や細工物もいろいろありましたが、その中でも漆喰細工の牛や兎の作り物が評判になって、女子供は争って見物に行きました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "河豚太鼓",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中庭は光沢のある緑の芝生をもって蔽われ、ところどころにさまざまの形をした花壇が出来て居り、作り物ならぬ天然の芳香を持つ春の草花が美しく咲き並んでいた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の女の指というのは、何んなのか知らないが、兎に角、先の次第に細い、恐しく長い、作り物のような綺麗な指だった。",
              "citation": {
                "source": "土から手が",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは粉の作り物を何でも思ひ思ひにこしらへて置くのぢやさうな。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは首からうえの作り物であった。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もしもその蜘蛛が、作り物の蜘蛛であって、その蜘蛛の中に、小さな高声器と、そして小さなマイクとが入っていたとすると、本人は遠くにいながら、その蜘蛛のいる附近の話ごえを、盗みぎきすることもできるであろうし、また、遠くから、その蜘蛛の体の中にある高声器を通じて、こえを送ることもできるであろう。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "木津のだいがくのだしも、五十年以前のものには、薄に銀月・稲穂に鳴子などの作り物を取り付けてゐたといふ。",
              "citation": {
                "source": "盆踊りと祭屋台と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚構が問題になるといふ事は、いかにも作り物らしい生活が詠まれる爲に、起つて來ることであつて、完全な段階に達すれば、虚構が虚構だといふ曇りを拂拭して、そんな問題を起さぬところにしづまる訣だ。",
              "citation": {
                "source": "文學に於ける虚構",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳島の端午に作るやねこじき又は、だしと言はれてゐる作り物は、江戸の顔見世のとうろうなる屋根飾りと同様に、屋上に出すもので、依代が竿頭から屋根に降りて来た時機を記念するものである。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日浜松近傍でいふだしは、各地の祭礼・地蔵盆の作り物、大阪西横堀の作り物などゝ同じ物を謂ふので、此は既に屋内まで降りて居るのである。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は依代の本意を忘れると共に、大規模の作り物を立てるに足る広い平面を要したからである。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際真の燈籠を見せるのではなくて、顔見世のとうろうと同じく、盆燈籠の立つ頃に、衆人に公開した作り物に過ぎなかつたので、更に佐伯燈籠に到つては祭礼の渡御の前に行く人形であつた。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて此様に、竿頭の依代から屋上の作り物、屋内の飾り人形或は旗竿尾の装飾にまで拡がつてゐるだしの用語例は、直ちに、江戸の祭りの山車の起原に導いてくれる。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も其上の飾り物は、神を迎へる標の作り物である。",
              "citation": {
                "source": "まれびとの歴史",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里名料理店の一つ「蝸牛」の軒にはつくりものの大蝸牛がほこりにまみれて二疋、左右へ角を振り分けている。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にぶッぶッぶッぶッと喇叭ばかり鳴すのは、――これはどこかの新聞でも見た――自動車のつくりものを、腰にはめて行くのである。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
