[
  {
    "uuid": "9bd14bd3-619d-510d-bab0-9b9e49201cc2",
    "entry": "努める",
    "reading": {
      "primary": "つとめる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
