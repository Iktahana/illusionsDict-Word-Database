    "definitions": [
      {
        "index": 1,
        "gloss": "(facial) expression (esp. fierce, fearless, sinister, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分で一冊か二冊、つまらない別の本を裸で抱えて、如何にも有閑学生か、有閑インテリらしい気分と面構えで飄然と往来から這入って来るんですね。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大酒飲みと見えて顔色が赤ぼったく垂弛んで、両眼の下瞼がベッカンコーをしたように赤く涙ぐんでいる上に、鼻の頭がテラテラと赤熟れになっている処は、何がかなしに人を馬鹿にした面構えである。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "下※の大きな、顴骨の高い、耳と額との勝れて小さい、譬えて見れば、古道具屋の店頭の様な感じのする、調和の外ずれた面構えであるが、それが不思議にも一種の吸引力を持って居る。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度私が其の不調和なヤコフ・イリイッチの面構えから眼を外らして、手近な海を見下しながら、草の緑の水が徐ろに高くなり低くなり、黒ペンキの半分剥げた吃水を嘗めて、ちゃぶりちゃぶりとやるのが、何かエジプト人でも奏で相な、階律の単調な音楽を聞く様だと思って居ると、睡いのか。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はあれほど世話になった花子夫人の玄関へ御礼の言葉一ついい掛けるでもなく、それこそ不敵な面構えをして、さっさと歩き去りました。",
              "citation": {
                "source": "おせっかい夫人",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、大抵の場合、人殺しや、強盗は凶悪な面構えをしているし、かたりやすりは、ずるそうな顔をしている。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　爺さんは、むっつりと、苦虫を噛みつぶしたような面構えで、炉傍に煙草を燻かしていた。",
              "citation": {
                "source": "駈落",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　爺さんは、初めて無愛想な面構えをほどいた。",
              "citation": {
                "source": "駈落",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "威勢のよい面構えをした人間もたくさんいたが、これはあらゆる大都会に横行しているあのしゃれた掏摸の輩に属する連中だということが、私にはたやすくわかった。",
              "citation": {
                "source": "群集の人",
                "author": "THE MAN OF THE CROWD",
                "note": "青空文庫"
              }
            },
            {
              "text": "六尺に近い大男で、眉毛の太い一癖あるような面構えであったが、もう六十に手が届いていたろう。",
              "citation": {
                "source": "出世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう御勘弁なすって、どこかそこらの隅へ拾い込んで下せえまし」「ちとそれだけの言いわけでは、そちの風体と言い、面構えと言い、主水之介あまりぞっとしないが、窮鳥ふところに入らば猟師も何とやらじゃ。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに貴様は、ちかごろここへ現れたばっかりだが、その面構えは本国政府からチャンと注意人物報告書として本官のところへ知らせてきてあるのだ。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "みなラ・サンテの監獄で見た泥棒や詐偽と同じような、あるいはそれ以上の面構えをしている。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その僕が、しかも同志の間ではちょうどピストル強盗といったような形で赤い着物がよく似合うとからかわれていたほどの物騒な面構えなのにもかかわらず、危く監獄でこの犠牲になろうとしたことがあった。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに暇さえあると、誰れの話にも割り込もうとはせずに、無口な面構えで寝転んでばかりいた。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「頼めれば頼む」　精悍という文字を面構えに変えたような浜田の肩が、古山はそのとき、少し落ちているように感じた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察に命じて容赦なく引っ括らせて、貴様の口を塞いで見せるぞ……という威嚇も、その兇悪な面構えの中に含んでいるようだ。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリイブ色の声なんかどこを押したって出そうな面構えじゃない。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程、掛矢でブンなぐっても潰れそうもない面構えだ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかにまだ試験の中らしい面構えをしてケツカルんだ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもどこか極めて風俗の悪い村から来ているらしく、万事心得た面構えをしているが、しかし遺憾ながら、まだ二人の関係については突詰めた事を一つも掴んでいないので、ああした年頃の未婚の女にあり勝ちな悩みをこの問題一つに集中しているらしいんだね。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るからに丸柿庄六と名乗りそうな面構えで、手に草箒を一本｜提げていたが、万平を見ると胡乱臭そうにジロリと睨んで立止まって、ガッチリとした渋柿面をして見せた。",
              "citation": {
                "source": "芝居狂冒険",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのもっとも大にして年経たものはすさまじき酋長の面構えで、多くの女鹿をしたがえて威張っている。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてけたゝましい音を立てゝ、電車は石子の前を通り過ぎたがその時に一人の面構えの獰猛な男が電車の戸口から一杯人の詰っている車掌台へ出ようとあせっている姿が眼についた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、扉をノックして入って来たのは、背の高い、見るから獰猛な面構えをした外国人でした。",
              "citation": {
                "source": "計略二重戦",
                "author": "少年密偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "八ツざきにしても飽き足りぬのは、オロシャの陸軍少佐と称したデフレ何とかウイッチの、むささびのような面構えであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手の面構え、体構えに、本気で刀を抜こうとする気合が、籠っていないのは勿論――よしんば、斬りつけて来たにしろ、たかの知れた、腕前なのも見抜いている。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "抜けあがった大たぶさを、ぎゅっと藁でしばった変相妖異のつらがまえ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリスはこの生き物のつらがまえがそこまで気に入ったわけではないんだけど、考え合わせてみると、ここにいても、あのぷんすかクイーンについていくのも、どっちでもあぶないのは変わりなさそうだから、じっとしてたんだ。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリスはこの生き物のつらがまえがそこまで気に入ったわけではないんだけど、考え合わせてみると、そいつとここにいても、あのぷんすかクイーンについていくのも、どっちでもあぶないのはどうも変わりなさそうだから、じっとしてたんだ。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
