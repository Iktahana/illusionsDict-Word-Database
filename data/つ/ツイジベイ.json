    "definitions": [
      {
        "index": 1,
        "gloss": "mud wall with a roof",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "左は紀州邸の築地塀、右は濠。",
              "citation": {
                "source": "狢",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ぱッと土を蹴って、片手｜支えに、五尺の築地塀上におどり上がりながら、ふと、足元の門奥に目をおとしたとき！",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ぱッと土を蹴って、片手支えに、五尺の築地塀上におどり上がりながら、ふと、足元の門奥に目をおとしたとき！",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽうっとなるようなところ見せつけらても、鳴っちゃいけねえぜ」　ぐるりと築地塀を回って表山門からはいってみると、門には額がない。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　対馬守は、いかめしい築地塀を打ち睨むようにし乍ら卒然として言った。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その空地の隣りに低い築地塀をめぐらした家がある。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外から見れば屋根と築地塀だけのやうな家の前で、三人の男が立つてしきりと話してゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは河原町の旧家に多い築地塀を真似たものだつたが、様式は京都や大阪にありさうな塗壁の塀であつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前には築地塀がほの黒く横切つてゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その塗りの色の落ちついた外まはりの築地塀、よく拭きこまれた廊下、塵一つ落ちてゐない部屋々々、渋い雅致のある床の置物だの掛軸、これらすべての上に現れてゐるどこか神経質でさへあるよい趣味と堅固さ――さういふ外見にかかはらず、大石医院では年来をかしなごたごたが繰り返されてゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "角から角まで、ずっと築地塀がつづいている。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸士の出入りする通用門につづく築地塀の陰。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘酒屋のお爺さんが、赤塗りの荷箱をおっぽりだして、塀のかげへ走りこんだかと思うと、すぐその顔が築地塀の上に現われた。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "築地塀に似た屋根つきの土のへいをめぐらした広い敷地の中に、うっそうたる大樹に囲まれて、純日本ふうの二階家が、あたりを睥睨するようにそびえていた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲にかくれた朧ろの月明りで、築地塀の延びている道はかなり遠くまで見えるが、人の来るようすはなかった。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは栗林荘の築地塀に沿って、南のはずれまでゆき、そこから道を左へ折れた。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは北向きなので枯草の根にもまだ青みはみえない、前方はなだらかな斜面になっており、低くなってゆく松林の向うに栂ノ庄村の一部と、小高い丘の上にある茂庭家の築地塀が、白く、城館のように堂々と眺められた。",
              "citation": {
                "source": "月の松山",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一町四方に及ぶ築地塀、楼閣を有する邸宅、数寄屋、三棟の土蔵、厩、家僕長屋、そして贅を尽くした庭園、といったぐあいであるが、人々を驚倒せしめたのはその構えよりも、その壮大な構えを二十余日で完成した事実にあった。",
              "citation": {
                "source": "艶妖記",
                "author": "忍術千一夜　第一話",
                "note": "青空文庫"
              }
            },
            {
              "text": "敷地は五千坪ばかりだろうか、三方に築地塀をめぐらし北側は柵になっていて、そのうしろは深い森がそのまま山へと続いている。",
              "citation": {
                "source": "菊千代抄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこが屋敷境で、高い築地塀の向うは黒いような森の茂みだった。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「済まないがおれを独りにして呉れ、……二、三日したら、たぶん、訪ねてゆくよ」　そして千久馬の返辞は待たずに、泉亭の長い築地塀に沿って、伊※川のほうへ大股に去っていった。",
              "citation": {
                "source": "はたし状",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い築地塀を三方にまわして、森々たる樹立のあいだに、三層楼の附いた御殿造りの屋根が見える。",
              "citation": {
                "source": "半之助祝言",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "築地塀は三方だけで、南側は野茨を絡ませた四つ目垣になっていた。",
              "citation": {
                "source": "半之助祝言",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "という音と、切れて飛ぶ棒の半分が見え、築地塀の武者窓の下へ、幹太郎の追い詰められるのが見えた。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎は棒の半分を青眼に構え、背中は殆んど築地塀にふれていた。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして幹太郎は脇へとびのき、その侍はがくんと頭を仰向けに振り、築地塀へのめりかかったが、そのままずるずると塀に凭れたまま横に倒れた。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "築地塀には（突き刺さって）折れた刀が残って、冷たい光を放っていた。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし堀のほうは築地塀があり、外は高い石垣になっているから、そっちへ舟を着け、塀を乗り越えて出れば、さしたる危険なしに脱出できる成算があった。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「築地塀のところへまいりまして、乗り越えるために用意してあるものが、みつからずにあるかどうか調べておりました、――これは毎晩欠かさず調べにまいるのですが、そのとき海手のほうで水門のあく音が致しました」四「夜半のそんな時刻に」　と八重は続けた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
