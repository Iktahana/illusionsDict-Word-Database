    "definitions": [
      {
        "index": 1,
        "gloss": "sound when stopping the blade of a sword with the guard",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "右門はなつかしむようにややしばしうち見守っていましたが、にんめりとぶきみに微笑しながら、ぱちりと鍔音もろとも鞘へ納めると、例のごとく伝六に早｜駕籠を命じて、用意のできるや同時に、先を急ぐもののごとく少年僧黙山を促しながら、自分の駕籠に共乗りさせると、ただちに息づえをあげさせました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "是はとばかり眼を閉ぢ、氣を取り直し、鍔音高く刃を鞘に納むれば、跡には燈の影ほの暗く、障子に映る影さびし。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その拍子に手もとが狂って、思わず鋭い鍔音を響かせてしまったのではございませんか。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチンと鍔音高く立て、刀を納めた小一郎、「お別れ致す」と云いすてると、町の方へスタスタ歩き出した。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し間を置いてパチンと鍔音。",
              "citation": {
                "source": "染吉の朱盆",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "祟りのほどがうるさいからなあ」　で、抜いた太刀を鞘へ納め、パチンと鍔音を小高く立てたが、改めて娘の様子を見た。",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが辻斬の先生よほどの達人とみえて、男の方はチャリンといふ鍔音をきいたが、首を切られた感じがないし、首も元通り身体の上に乗つかつてゐる。",
              "citation": {
                "source": "五月の詩",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたんにパチッと鍔音がした。",
              "citation": {
                "source": "善悪両面鼠小僧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士によって鳴らされた鍔音が、神魂に徹ったからであった。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "斜めに映っていた刀の影が消え、やがて鍔音がした。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐにささやかな鍔音がした。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやどうも驚いたなあ」　チャリンと鍔音高く立て、刀を納めたものである。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、腰のところへ手をあてがって、いわゆる居合腰になったかと見ると、スラリと水の出るように三尺五寸の長い刀を抜き出して、そうして、それを役人の目の前へ持って来て、ピカピカ二三べん閃めかしたと思うと、スラリとまた鞘の中へ叩き込んで、多少の鍔音もさせませんでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃、城下をうろついている犬みたいな浪人が、わしの留守へも、忍んでくると言っていたが、おのれ、何しにここへ――」　と、鐺を上げて、ぶるぶると、右手の拳に、鍔音をさせた。",
              "citation": {
                "source": "無宿人国記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "休之助は持っていた刀で、ぱちんとするどく鍔音をさせた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お誂えの黒いでだち、ばすッと、鍔音を感じたので、梅渓は、『おいでなすッた』　と、呶鳴って、抜き打ちに後ろを撲った。",
              "citation": {
                "source": "田崎草雲とその子",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "刀の血糊を拭いてとると、チーンと鳴りのいい鍔音をさせて、金右衛門と肩をならべて石段を一歩、一歩、と降りかけます。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
