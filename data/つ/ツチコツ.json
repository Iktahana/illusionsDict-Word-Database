    "definitions": [
      {
        "index": 1,
        "gloss": "malleus (bone of the ear)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
