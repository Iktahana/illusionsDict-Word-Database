    "definitions": [
      {
        "index": 1,
        "gloss": "horn (instrument; made of animal horn)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "高だかと角笛が鳴りひびいた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして中庭で、息のつまつたやうな角笛が、しきりに吃つてゐた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くで角笛の音がする。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び遠くから角笛の音、犬の遠吠えが聞えて来る。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "車掌が豆腐屋のような角笛を吹いていたように思うが、それはガタ馬車の記憶が混同しているのかもしれない。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし角笛であったような気がするというわけはこの馬車の記憶に結びついて離れることのできない妙な連想があるからである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、この絵の中のロンドン、リーディング間の郵便馬車の馬丁がシルクハットをかぶってそうしてやはり角笛を吹いている。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の角笛新美南吉月が角笛夜ふけにふいたぽうぽうぽうよ、ぽうぽうぽうよ。",
              "citation": {
                "source": "月の角笛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "月が角笛とほくにふいた。",
              "citation": {
                "source": "月の角笛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車の角笛が鳴りわたりました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "――やがて、角笛のひびきはだんだん弱くなっていきました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "狩りの角笛がひびきわたり、イヌがワンワンほえたてました。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "かりゅうどたちが、山の中で吹いている角笛のひびきも、聞えてきました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "角笛、これ代えたげる冠りなさい」　うねって来る色テープの浪。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むす子は軽く角笛に唇を宛て、かの女を見守っていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水車はそのにぶい音をやめ、馬車屋は村のはずれで、角笛をふくのをやめるのでした。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代に娘が急に結婚を思い立ち、求婚の角笛を無垢嚠喨と吹いたところが直ぐおいそれと世間の男たちがその笛に乗って躍るものではない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの黄臘の腐れたる絶間なき痙攣と、※オロンの三の絃を擦る嗅覚と、曇硝子にうち噎ぶウヰスキイの鋭き神経と、人間の脳髄の色したる毒艸の匂深きためいきと、官能の魔睡の中に疲れ歌ふ鶯の哀愁もさることながら、仄かなる角笛の音に逃れ入る緋の天鵞絨の手触の棄て難さよ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白い月光に染まった透明な水の世界の中で、単調な歌声は、風に消えていく狩りの角笛の音のように、ほそぼそといつまでもひびいていた。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日さまは、さわやかに晴れた青空の上からあたたかく照りかがやいて、峰と峰とのあいだから、りょうしの吹く角笛が、いかにもおもしろく、たのしくきこえました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、ひとこえ角笛のひびきが、海の水をわたって来ました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのベンチも濡れてゐる、森もすつかり霜枯れて、トントン、トンテンと、もう角笛も鳴つて了つた。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "角笛が頻に呼んでゐる、歸れ……歸れと呼んでゐる。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "角笛が、角笛が――悲しい……角笛が悲しい……消えて行く音色の變化、調と音色の變化、トントン、トンテン、トントン……角笛が、角笛が北風に消えてゆく。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳につく角笛の音、なんとまあ餘韻の深い音だらう……冬だ、冬だ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
