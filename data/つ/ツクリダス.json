[
  {
    "uuid": "92bc32ba-c0c7-5c5d-beed-7ccfbf98e8dc",
    "entry": "作り出す",
    "reading": {
      "primary": "つくりだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
