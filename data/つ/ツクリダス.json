    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to manufacture",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "結局環境といふも結局｜各々の作り出すもんだ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に、芸術とは、興味が、笑ひといふ自然的作品よりも、作品といふ人力の息吹きのかゝつたものを作り出すためには、興味そのものの内部に、生活人よりも格段と広い世界を有さねばならぬ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽殿の傍には、周囲六丈四尺、根廻りは二丈八尺、と測られた神代杉がそそり立って、割合に背丈は高くないけれど、一つ一つの年輪に、山の歴史の秘密をこめて、年代の威厳が作り出す色づけと輪廓づけを、神さびた境内の空気に行わたらせている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり私のように古くからの恋愛にあまんじた男は貴女のように、知り合うと直に知ってしまう恋の形式は、それからどうして恋愛を作り出すのかが私にはわからないのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、畢竟それもまた名人上手とかいふ風な古來の形｜式主｜義が當｜然作り出す型に捉はれた觀念と見られぬ事もない。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　文学のことは年齢によってのみはかることは出来ないが、しかし、文学がその作家の置かれた環境と切り離して考えられない関係がある限り、環境は時間によって変化するので年齢はその作家の人間にも、またその作家の作り出す文学にも変化を与えるのは否まれないように思われる。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧州のどこかの寄席で或るイタリア人の手先で作り出す影法師を見たことがある。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その世界では「作り出す」「生み出す」ということだけが意義があり、それが唯一の生きて行く道であるように見えた。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピクニックよりもダンスよりも、婦人何々会で駆け回るよりもこのほうがはるかに身にしみてほんとうにおもしろいであろうということは、「物を作り出すことの喜び」を解する人には現代でもいくらか想像ができそうである。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉藏ほどの男が、汗みどろになつて作り出すのであるから、きつとただならぬものにちがひない。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して拙劣なるモンタージュは、動的な画像の単調無味なる堆積によってかえって観客のあくびを促すような静的なものを作り出すことも可能である。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この偶然を作り出す運を、信吉は信じているのだ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し一個の藝術的洞察者があるならばロダンの依つて名聲を博した所のものを又日本の材料から作り出す事が出來るのは勿論である。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し夫れ是等の雜沓中で、いやに通を振り※す氣のきかない一大阪人を巧みに描寫したならば、確かに、膝栗毛以上のニユアンスの藝術を作り出す事が出來るだらう。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってその発表するところの論文は皆、最も実際的な探偵趣味の発露であり、その作り出すところの薬品と器械は皆、神と自然とを破壊し嘲罵するところの犯罪用具そのものであった。",
              "citation": {
                "source": "甲賀三郎氏に答う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アントニオに才藻の萌芽ありしをば、嘗て我生徒たりしとき認め得たりしに、惜いかな、其芽は枯れて、今の作り出すところは畸形の詩のみ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして多くの労働者は、それを作り出すために、各、危険と鼻面を突き合わせて、凍え、飢え、さまよいながら、労働すべきであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴェニス人プラガジニは有名な方士で、魔の力を借りて黄金を作り出すと誇り、一五九五年バイエルンで刑せらる。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族に供する日常の食膳と、衣服とは女性が作り出すことが出来よう。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半農と云つてもそれは殆んど蜜柑の栽培が重でそのほかに椎茸木炭などを作り出すと云つた風の山爲事なのです。",
              "citation": {
                "source": "樹木とその葉",
                "author": "海邊八月",
                "note": "青空文庫"
              }
            },
            {
              "text": "文人も亦生活の鞭に引叩かれる為め千篇一律の著述をする事はするが、本来手の仕事でも足の仕事でも眼の仕事でも口の仕事でもなく、一つ／＼が尽く頭脳の中枢から産出す仕事であるから、他の職業のように全く同一のものを作り出す事は決して無い。",
              "citation": {
                "source": "駆逐されんとする文人",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もこういう痼癖がしばしば大きな詩や哲学を作り出すのであるが、二葉亭もまたこの通有癖に累いされ、直線に屈曲を見出し平面に凹凸を捜し出して苦んだり悶いたりした。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺もちらりと、――いいや、ちらりと見たという奴が目のせい、気のせい、みんなこっちの心で作り出すまぼろしさ、今御繁昌のお江戸に幽霊なんかまごまごしておってたまるかよ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まわり燈籠、組みあげ燈籠、虫籠、蚊いぶしの煙り、西瓜の截ち売り、こうしたものが都会の夏の夜らしい気分を作り出すとすれば、子供たちの打ち揚げる小さい花火もたしかにその一部を担任していなければならない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかには年々歳々おなじ版をかさねているような、例のいろは短歌や道中｜双六のたぐいもあるが、何か工夫して新しいものを作り出すことになっているので、武者絵双六、名所双六、お化け双六、歌舞伎双六のたぐい、主題はおなじでも画面の違ったものを撰んで作る。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "東海道五十三次をかいた広重が今生きていたらば、こうした駅々の停車場の姿をいちいち写生して、おそらく好個の風景画を作り出すであろう。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自己の意識内の現象とても、我々は新に観念を作り出す自由も持たず、また一度経験した事をいつでも呼び起す自由すらも持たない。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それも学者のようなペダンチックな読み方で、純粋戯曲の理論というものをつくりだすためにのみ読んでいたようである。",
              "citation": {
                "source": "わが文学修業",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの世紀が、このような大理石の神々をつくりだす日まで、さらにさらにまわりつづけていくのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえがね、その形をつくりだすことができたら、おまえを自由にしてあげるよ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
