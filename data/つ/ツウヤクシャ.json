    "definitions": [
      {
        "index": 1,
        "gloss": "interpreter (person who translates orally)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
