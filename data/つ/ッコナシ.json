        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "無線電信――六〇六――石碑――W.C　――じゃ、間違いっこなし、明朝、練兵場よ。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをしも社会が渠等に与うるに無形の桂冠をもってする爾き慈善事業というべきか、と皮肉なことはいいっこなし。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "峰の白雪、麓の氷――　旦那、顔を見っこなし……極が悪い……何と、もし、これで別嬪の姉さんを引寄せようという腹だ、おかしな腹だ、狸の腹だね。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「省さん、今日はきっと負かしてやります」「ばかいえ、手前なんかに片手だって負けっこなしだ」「そっだらかけっこにせよう」「うん、やろ」　おはまはハハハッと笑って水をくむ。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうで死ぬもんだからなんて薄情なことはしっこなしですぜ」　林之助はだまってうなずいた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、もうそんなこといいっこなし、仲よくしましょうね。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどのう」「ちぇッ、変なところで感心しっこなしにしましょうぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふざけっこなしにしようじゃねえか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "変な言いがかりはつけっこなしにしてもらいましょうぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、今では木地師の娘、で、だんだんと劫を経て、私たち仲間と同じように、お駕籠なんかに乗りっこなし。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな古いことは言っこなし。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日はまた、これは旅客機ではないが、この�T・Ａの飛行機がＢＵＭＰと落ちて、ちょっと Joy-ride としゃれていた会社の女タイピストと事務員の一行を飛行家とともに全部恨みっこなしに殺している。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "女もつられてちらと私の方を眺めたが、私に対しても、男の話に対しても大した興味はなさそうな眼つきで、「大変だねエ、やすみっこなしでさ」と、口の先だけしんみり応答している。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "変なことを云いっこなしだ」「しかし貴方はどうして二十九日の夜の事件や、銀行を訪ねてまわって今の話のようなことを知りたがるのですか」「知りたがるのは、儂の道楽なのじゃ。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の事件の現場で、君が拾って来た時計から算出したんだから、間違いっこなしです」　と、科学者だけに、算出値の信用できることを力説した。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "怨みっこなしに誰も彼もな」　にわかに憤りの声となった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論お互いに前は知りっこなし。",
              "citation": {
                "source": "ニッケルの文鎮",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし位かって、冗談いいっこなしよ。",
              "citation": {
                "source": "ニッケルの文鎮",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……組合に入っていないにしろ、ストライキのときはあなたの要求だってみんなと同じだったからこそ闘ったんだから、今更誰が組合に入ってたなんて余計なことは云いっこなしだわね。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "但しみんなたべちまいっこなし」「亮さん相変らずなのかしら」　下の兄が、そこへ赴任しているのであった。",
              "citation": {
                "source": "夜の若葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた、もうなんにもおっしゃりっこなしよ。",
              "citation": {
                "source": "辻馬車",
                "author": "モルナール・フェレンツ　Molnar Ferenc",
                "note": "青空文庫"
              }
            },
            {
              "text": "化石した様にだまって突立って居た男は、押し出される様に「じょうだんは云いっこなし……」男はどうぞこれより私を驚かせる事は云わないでネと云う様な目をして彼の女を見つめながら云った。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "親父にはどんな事があってもなりっこなしにするのさ――どじょうっぴげを気にしながら小供のお守をして居る親父殿を見るとすぐ斯う思われた。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マア、そんな事は云っこなしに御し、困るもの」　小さい声で云ってぽっと頬を赤くした。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方さまも其の中の御一人でいらっしゃいましょう」「そんなことはきっとない、だけれ共ネ……マア好い、もうそんな事は云いっこなしさ」　光君は居たたまれないようにクルクルと巻物を巻いてわざと、机のわきにすわって、思い出したように墨をすって手習をはじめた。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい兄貴」「なんだラルサン」「あれはいいな、金の卵もいいが、卵よりあの方が高く売れるぜ」「うん、俺も今、それを考えたところだ」「どうだい、ちょうど二匹ずつに分けようじゃないか、恨みっこなしとゆこう」「うん」　二人がそんな相談をしている間に、モレロはあたりをかぎまわすように探しものをしていた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、地獄から、閻魔の使者として大入道が迎えに来たのかと思いました」「ははは、なにをいうですか、おどかしっこなしですよ」　補助官は、二人にかつがれているんだと思って、笑ってしまった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
