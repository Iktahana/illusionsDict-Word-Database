  {
    "uuid": "eb1582d0-8ef2-5583-a09a-64c685fc8391",
    "entry": "使える",
    "reading": {
      "primary": "つかえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段"
      ],
