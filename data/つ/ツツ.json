    "definitions": [
      {
        "index": 1,
        "gloss": "while",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "全集が弘く読まれる事を希望しつつ、広告の一助にもと一寸一言申述べます。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は想起される印象を、刻々新しい概念に、翻訳しつつあつたのです。",
              "citation": {
                "source": "宮沢賢治の詩",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにふるへ、かくれつつうかがひのぞく榎あり、いのりつつ、一心に幹をけづりしに、樹樹はつめたく去り行けり。",
              "citation": {
                "source": "黎明と樹木",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等利根川の岸邊に立てば、さらさらと洋紙は水にすべり落ち、いろあかき魚のひとむれ、しねりつつ友が手に泳ぐを見たり。",
              "citation": {
                "source": "利根川の岸邊より",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の名声は今では日に月に高まりつつあるのだが、つまり『死後の名声』といふやつなのである。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、さうした事態を脱がれようとするものの如く、後から後から新しい主義主張が簇出しつつあることも事実である。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は現実を素直に吸収しつつある。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "『虱や、ご生だからたからないでおくれ、私にしつつこくしないでおくれ、おまへはほんとに不愉快だ』そして痒いところへ手をやらうともしなかつた。",
              "citation": {
                "source": "諷詩",
                "author": "―人魚詩社の人たちに與ふ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "耶蘇教の家の羨ましく風琴の唱歌する聲をききつつ冬の夜幼なき眼に涙ながしぬ。",
              "citation": {
                "source": "クリスマス",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい、つつましい家庭にこそ仕合せがありますよ。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いノオトのちりを吹き払って、カントやヘエゲルやマルクスを、もういちど読み直して、それから、酒をつつしんで新しい本も買いたい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ち待ちて　ことし咲きけり　桃の花　白と聞きつつ　花は紅なり　僕は勉強しています。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれ、嬉しや、たすけを求めて叫ぼうとして、窓の内を見ると、今しも燈台守の夫婦とその幼き女児とが、つつましくも仕合せな夕食の最中である。",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそれが、やがて大隅君のあの鬱然たる風格の要因にさえなった様子であったが、思いやりの深い山田勇吉君は、或る時、見かねて、松葉を束にしてそれでもって禿げた部分をつついて刺戟すると毛髪が再生して来るそうです、と真顔で進言して、かえって大隅君にぎょろりと睨まれた事があった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当の実業家らしいのですが、財産やら地位やらを一言も広告しないばかりか、名誉の家だって事さえ素振りにあらわさず、つつましく涼しく笑って暮しているのですからね。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し、「生きるとは感覚すること（ルッソオ）」であり、感覚されつつあれば折にふれて、それらは魂によつて織物とされる。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "甞て彼――一近代病者は、「情けぞ人の命なる」といふヴェルレーヌが一詩に不図心惹かれ、惹かれた迄はつつましやかであつたが、惹かれ終つて彼はそはそはしはじめた。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に、芸術家たる芸術家が、芸術作用を営みつつある時間内にある限りに於て、芸術家は他に敵対的ではなく、天使に近い。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨、芸術家は名辞以前の世界に呼吸してゐればよいとして、「生活」は絶えず彼に向つて「怠け者」よといふ声を放つと考へることが出来るが、その声が耳に入らない程名辞以前の世界で彼独特の心的作業が営まれつつあるその濃度に比例してやがて生ずる作品は客観的存在物たるを得る。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今や漸く実施はウダつて来つつある。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち前代プランが漸く陳腐に感じられつつある。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、連れ出した男を此の世に於ける唯一の寄すがり者のやうに思へる心に浮々した足取で、そのフェルトをペタペタ夜道に打つつけながら、解雇された仲間で一番給料も多かつた男の下宿の方に歩んだ。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽炎や名も知らぬ虫の白き飛ぶ更衣野路の人はつかに白し絶頂の城たのもしき若葉かな鮒鮓や彦根の城に雲かかる愁ひつつ岡に登れば花いばら甲斐ヶ嶺や穂蓼の上を塩車　俳句というものを全く知らず、いわんや枯淡とか、洒脱とか、風流とかいう特殊な俳句心境を全く理解しない人。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "愁ひつつ丘に登れば花｜茨「愁ひつつ」という言葉に、無限の詩情がふくまれている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前出の「愁ひつつ丘に登れば花｜茨」や、春の句の「陽炎や名も知らぬ虫の白き飛ぶ」などと共に、西欧詩の香気を強く持った蕪村独特の句の一つである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花｜茨故郷の道に似たる哉「愁ひつつ丘に登れば花茨」と類想であって、如何にも蕪村らしい、抒情味に溢れた作品である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前出の「愁ひつつ丘に登れば花茨」や、この「小鳥来る」の句などは、日本の俳句の範疇している伝統的詩境、即ち俳人のいわゆる「俳味」とは別の情趣に属し、むしろ西欧詩のリリカルな詩情に類似している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その同じ心は白梅や誰が昔より垣の外　という句にも現れ小鳥来る音うれしさよ板庇愁ひつつ丘に登れば花｜茨　などのロセッチ風な英国抒情詩にも現われている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
