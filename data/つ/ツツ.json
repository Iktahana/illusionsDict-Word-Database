        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "南京陷落の日に萩原朔太郎歳まさに暮れんとして兵士の銃劍は白く光れり。",
              "citation": {
                "source": "南京陷落の日に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長三代太宰治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）捧げ銃をして。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふ號令がかかつて、私たちは捧げ銃をして、みると、校長は、秋の日ざしを眞正面に受けて、滿面これ含羞の有樣で、甚だ落ちつきがなかつた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖先達の習慣が私の中で、精巧な銃があれば好いにと言ふ。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば西洋の惡魔が、日本では鬼や天狗の類となるし、昔の童話に出る武者修業の豪傑が、今日の新しい童話では、飛行機に乘つて機關銃を撃つたりするところの、科學的武裝をした日の丸太郎の類に變るのである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くもない労働者が、機関銃の前の決死隊のように、死へ追いやられた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドーン、バーン、ドドーンー　発破は機関銃のように続いて、又は速射砲のようにチョット間を置いて、鳴り続けた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "小銃弾の速度は毎秒九百メートルほどである。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "銃殺された男が、夢のなかで息をふきかへしたときに、空にはさみしいなみだがながれてゐた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（装具をとッてはいけない）銃を側へ置く事。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "偵察すればロシヤ、グロンボイ、リュウリックの三巡洋艦にして此の時既に我が友船泉丸は撃破せられ左渡又同じ運命に陥入らんとしつつあり」　突然に機関銃の音、　一同はッとなる。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "（移動）　又見た眼、男行く、又切れる　女、次の銃眼へ。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "（機関銃の音）　男、出て来ない風景　女、up　　Cut Back「オーデがね」「オーデッて何だ」「俺の事支那語でオーデッて云うんだ」「あ、そうか」「おい、オーデ上等兵」「オーデ上等兵？",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "木陰に短銃を手にしたなりひらが立って居た。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝元の森　なりひらは主膳に短銃を突き付けて、Ｔ「連判状を出せッ※」　と迫る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーテンの引かれなかった窓ガラスには、影絵のように狂暴な黄の顔がうつし出され、私の驚愕に無関心なように黄の手にした挙銃の引金がマリの寝姿に向って引かれた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親のアンナ・スラビナがセルビア戦争をモスクワで洗濯していたころ、可憐なニコロは機関銃と義足とスラビナの涙のうちに生長した、そのころ既に彼女には天分がめぐまれていたのだ。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "レムブルグの電信室の受信器には女に変装して上海に逃れた重慶共産主領｜楊闇公の銃殺を暗号電報は報ずるのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "市内に行われていた全ての過去から続く催し物に喪が発せられ、結婚式の美しい半裸体の夜半の女の背中に機関銃の弾で穴だらけになったソビエットの赤い旗が迫って、宣伝隊の装甲自動車が租界内に侵入して宣伝ビラを配付した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾組かの拳銃隊が街の要所々々を発砲し、欧米人によって築かれた南京路のペーブメントは要撃された。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関銃の音が静寂を破って響き渡るたびに人々は黙々として家屋の囲壁のなかに自己を守護するのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳独秀は虹のように地面に這入った彼の腕から拳銃をとると、虚空に一発打ち放して花火のように彼方に舞下りる弾丸を見つめながら、――何故死なねばならないのだ！",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が漸く国民党内部で一仕事しようとした過去の迷夢からさめたときは、有力な同志は銃殺され、軍閥と資本主義の治下のもとに幽閉されていたのだ。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明前には奥漢鉄路で捕えられた二百名からの党員が銃殺されて、珠江に投げ棄てられた死体が河畔の摩天楼の下に櫛比して河底に埋もれ、蛋民によって水葬されたのだ。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "レムブルグの電信室の受信器には女に変装して上海に逃れた重慶共産主領楊闇公の銃殺を暗号電報は報ずるのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳独秀は虹のように地面に這入った彼の腕から拳銃をとると、虚空に一発打ち放して花火のように彼方に舞い下りる弾丸を見つめながら、――何故死なねばならないのだ！",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "全集が弘く読まれる事を希望しつつ、広告の一助にもと一寸一言申述べます。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は想起される印象を、刻々新しい概念に、翻訳しつつあつたのです。",
              "citation": {
                "source": "宮沢賢治の詩",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにふるへ、かくれつつうかがひのぞく榎あり、いのりつつ、一心に幹をけづりしに、樹樹はつめたく去り行けり。",
              "citation": {
                "source": "黎明と樹木",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等利根川の岸邊に立てば、さらさらと洋紙は水にすべり落ち、いろあかき魚のひとむれ、しねりつつ友が手に泳ぐを見たり。",
              "citation": {
                "source": "利根川の岸邊より",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
