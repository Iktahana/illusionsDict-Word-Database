          "literary": [
            {
              "text": "いつもなら、ここでヘッドロックか、コブラツイストでもかけにいくところだが、体力を使い果たしたところに不安が重なったので、完全に力が抜けて、慶一は教壇に腰をおろしてしまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミネリア国大使は極貧のオリバー・ツイストよろしく、もっと金を求めた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ティーンエージャーたちの踊りは、ツイストとして、大人たちの世界でも、流行になった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五九年にハンク・バラッドとミッドナイターズというグループが『ザ・ツイスト』を出し、あくる年、黒人のチャビー・チェッカーが白人的なカヴァーをつくり、六一年の一〇月、エド・サリヴァン・ショーに出て、ツイストは大人の流行になった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラッキー・ミリンダー、アイヴォリー・ジョー・ハンター、ブルムース・ジャクスン、ザ・ドミノスのクライド・マクファター、あとでツイストのスタートをつくった、ミッドナイターズのリーダー、ハンク・バラード。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
