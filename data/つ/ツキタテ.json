[
  {
    "uuid": "7e14bd8e-fcf1-5877-bdcf-9f3b480f41e3",
    "entry": "搗きたて",
    "reading": {
      "primary": "つきたて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
