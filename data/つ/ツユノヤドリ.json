        "examples": {
          "standard": [
            {
              "text": "山小屋は、夜露に濡れてまるで露の宿りのようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古びた東屋は、風雨に晒され露の宿りの風情を漂わせている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は戦乱の中、露の宿りのような仮の住まいで日々を過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "うれしさにほくそ笑みして読み了へし、我が睫毛には、何しかも露の宿りき。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "あさぢふの露の宿りに君を置きて四方の嵐ぞしづ心なき　という歌もある情のこもったものであったから紫夫人も読んで泣いた。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "色変はる袖をば露の宿りにてわが身ぞさらに置き所なき　はずるる糸は（侘び人の涙の玉の緒とぞなりぬる）とだけ、あとの声は消えたまま非常に悲しくなったふうで奥へはいったことが感じられた。",
              "citation": {
                "source": "源氏物語",
                "author": "椎が本",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
