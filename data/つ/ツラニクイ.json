        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "欲張りの田舎者ほど面憎いものはない。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あの面憎い秋山男爵。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "その言い草が面憎い！",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの幾千の人びとはいずれも額に汗をにじませながら、白く灼けている空を不安らしく眺めていたが、空は面憎いほど鎮まり返って、鳥一羽の飛ぶ影すらも見えなかった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "内儀さん気取りでいたとか、お客分のつもりでいるのが小面憎いとか、あれはただの女じゃあるまいなどと言い出した。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「常々小面憎い葉茶屋の亭主」は「つねずねこずら憎い葉じや屋の亭主」と書かざるべからず。",
              "citation": {
                "source": "文部省の仮名遣改定案について",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうしてお桐が面憎いといふ印象が子供の時分から平三の胸に深く刻まれて居た。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "末の妹のお夏の様に優しい女らしい所は少しもなく何となくすれて居る、小面憎いといふ気持が絶えず平三の胸にひそんで居た。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると泰さんは面憎いほど落着いた顔をして、「何、訣はありゃしない。",
              "citation": {
                "source": "妖婆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時に相手の苦笑が、面憎いような心もちにもなった。",
              "citation": {
                "source": "将軍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして又｜些と酒が廻つて来ると湯村の手を握つて、「憎い奴だ、君のやうな面憎い男は無い。",
              "citation": {
                "source": "茗荷畠",
                "author": "眞山青果",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと来て下さらない、池のところまでですの」　春部はこれまでいつも面憎いほど取澄していたが、このときばかりは若い女子動員のように騒ぎ立てた。",
              "citation": {
                "source": "千早館の迷路",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふん、チョビスケの近藤め、出鼻から赤恥をかかされおって」　しかし一方若侍どもは悠々｜逼らざる葉之助の態度を面憎いものに思い出した。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とかくわしの裏を掻いて、計画｜齟齬させ後手へ後手へと廻す、小面憎いが好敵手でもある彼奴を、今度こそはどうやら取り詰めたらしいぞ。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうとは見えぬ」　するともう一人の浪人が、「ちと変じゃ、駈け落ち者らしいぞ」　するともう一人の浪人が、「食うや食わずの百姓があるに、色の恋の駈け落ちのと、幸福すぎて面憎い。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸を下りる三吉　怪盗「岩」は、少年探偵三吉のためにうまく一杯喰わされ、逆さに梁に釣り下げられている癖に、「いまに日本国中の人間どもが泣面をかくぞ、ざまア見やがれ」と大きなことをいっているのは、怪盗とはいえ、なんと面憎いことではないか。",
              "citation": {
                "source": "地中魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "面憎いことは、この時分になって雨の歇んだ空の一角が破れて、幾日の月か知らないけれども月の光がそこから洩れて、強盗提灯ほどに水の面を照らしていることであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにかと面憎い薩摩屋敷へ、仕返しに行くのではない、見届けに行くのだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒鉄は磔木に掛けられてさんざんに打たれたが、泰文の後楯があると思っているのか、いっこう平気な顔で「ほとほとに（女洞の掛言葉）舟は渚に揺るなり、あしの下ねの夢ぞよしあし」などと猥がわしい和歌を詠み、面憎いようすだった。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその時一男をひきずり倒して殴りつけたい程じりじりすると同時に、また一方では、その面憎いまで落ちつきはらった胆っ玉の太さに、思うさま拍手を送りたくなったのだった。",
              "citation": {
                "source": "秋空晴れて",
                "author": "吉田甲子太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（可愛らしいお方）と主税に対しては思い、（小面憎い奴）と覚兵衛に対しては感じ、この二つの心持から、あやめは悪戯をしてしまったのである。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には小面憎いほど羨ましいと思うこともあるが、時には如何かしてやりたい様な気のすることもある。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんという面憎い……！",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "精々七時までに切り上げて貰はな、な』その云ひ方が面憎い。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分の空腹に比べて、先生の胃の腑の病的な飽満状態が、羨ましいような、面憎いような気がした。",
              "citation": {
                "source": "蘿洞先生",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒鉄は磔木に掛けられて打たれたが、泰文の後楯があると思うのか、「ほとほとに（女洞に掛けた言葉）舟は渚に揺るるなり、あしの下ねの夢ぞよしあし」　などと空うそぶいてみだらな和歌を詠み、面憎いようすだった。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはご存知ないかもしれないが、僕の方はよく知っています」　怪青年矢部は、つらにくいほど、ゆっくりした語調でいって、無遠慮に宮川の横にかけた。",
              "citation": {
                "source": "脳の中の麗人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
