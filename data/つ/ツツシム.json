[
  {
    "uuid": "d971f0bd-edc7-5b36-a6a8-8b50dd5c4dda",
    "entry": "慎む",
    "reading": {
      "primary": "つつしむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
