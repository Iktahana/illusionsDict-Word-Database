        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なにしろ、つなぎ目が三カ所もある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "たんに四本のテープをつないだだけでなく、娯楽室のステレオにリヴァーブがついている（なんだって、ステレオにリヴァーブなどつけたのかは、メーカーにきいてほしい）のを利用して、これを通して深いリヴァーブをかけ、つなぎ目をごまかし、同時に、妙に迫力のある音をつくりだしている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、つなぎ目が多少ギクシャクするのは、しかたない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "つなぎ目なども見えない、バラバラの美しい団扇か楯により他見えなかつた。",
              "citation": {
                "source": "鱗雲",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しそれでも、度々、圧力が平等に調節されないで、つなぎ目が口を開き、あっという間に出血して家兎を死なせました。",
              "citation": {
                "source": "人工心臓",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これでどうして、あんなに大きな規模のＯＳを組み上げることができるのか」と胸に浮かび上がってきた疑問は、全体の構成と個々のモジュールのつなぎ目だけを定義する担当がまた別に存在するのだと知ってはじめて氷解した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷却管のいい材料がなくて、仕方なしに、つなぎ目に、ゴム管を使ってある。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただに巻きつけたのみならず、一枚の皮で被い、つなぎ目を組み合せる手法へと進んだ。",
              "citation": {
                "source": "樺細工の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "構築には巨石を用い、つなぎ目は密着してナイフの刃も入らぬ。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が現在とよぶところは未来と過去とのつなぎ目にすぎない」と言った。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその後の圓いところと、前の四角なところとのつなぎめのところの兩側に、小さい圓い丘がついてゐることがあります。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸頭のまわる人間は要するに、そのつなぎめのところでいろいろうまく立ちまわるのね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "よいことも醜悪なことも何かそのつなぎめのところに発生いたしますね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
