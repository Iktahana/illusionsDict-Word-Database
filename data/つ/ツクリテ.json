        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自作農で破産をする人間、誰れもかれも街へ出て作り手がなく売りに出す人間、伊三郎が、又、息子の学資に畠の一部を売る場合――秋に入ると一と雨ごとに涼しくなる、そんな風に、地価は、一つの売出し毎に、相場がだん／＼さがった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一から新しい環境を用意する困難に加え、作り手である祝田さんのあくまで自らの美意識に沿おうとするこだわりがあって、Ｔ※の開発は大幅な遅れを余儀なくされました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブースに設けられたステージに立つと、横丁に作品を寄せた何人かの作り手も、私の話に耳を貸してくれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに誕生した数十人の横丁作家、これから生まれるであろう数百人の作り手の、自分自身が一人であることを、私はこの時になってはじめてつくづく腹におさめたのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブックが出来上がるとたいていの作り手たちは、読んでくれそうな人にコピーして配り、続いてニフティーサーブなどのネットワークに登録することを考えます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "作り手から送ってもらったブックの十ページ程度を、立ち読み可能な形式で表示し、簡単な解説を付ける。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "購読者からの代金の受け取りや、作り手への決済に対応できないため、当面は無料のものと利用者の自主的な代金支払いを期待するブックに限るけれど、将来的には販売も進めていく。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらかじめ作り手から、十〜二十部程度のパッケージを預かり、十頁分を立ち読み用に仕立てておきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "代金の支払いには同封した郵便振替用紙を使ってもらい、手数料を差し引いて作り手と決済します。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに関しては、従来通り作り手にも登録料を求めません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはこれまで、自らをパーソナルコンピューターの作り手として位置づけてきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕様をどう形に仕上げるかは自由で、そこで作り手が大いに知恵を絞り、健全な競争をどんどんやっていこうではないかという方針である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "▼農民小説や、戦争小説は、取つ付き易く、組み敷き難いものの最大なもので、これらをテーマに扱ふ作家は、幾多の難問題を控へて、よほどハッキリした頭の持主でなければ、所謂農民の家常茶飯事的物語りの作り手以外になることは不可能だらう。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "その作り手の人形師がね――」「わかったのかい」「いいえ、それがちっともだれだかわからねえんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪枝は内弟子に住みこませることを快く引き受けてくれたが、詩も作り手蹟も流麗で、文学にも熱意をもっているので、葉子も古い昵みのように話しがはずんだ。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "作り手の思惑を超えて、個人で所有できるコンピューターとしてとらえていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その歴史の作り手たちがたどった思考の跡を網羅的にすくい取った本書を、監訳者の村井純氏は「歴史的な知的財産」と評しているが、筆者もまったく同感である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、無料もしくは非常に安いソフトウエアがつぎつぎと生み出されるようになれば、ソフトウエアの作り手と使い手が互いを泥棒呼ばわりして非難しあう事態は避けられるだろうと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "標準搭載には踏み切らなかったものの、ＩＢＭがＯＳの使用を前提としたＰＣで市場に乗り込んできた時期、ハードウエアとソフトウエアの作り手は意識するか否かにかかわらず、この問いに直面させられていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "スティーブン・ジョブズがアップルというハードウエアメーカーのトップであったのに対し、複数のマシンの作り手たちに基本ソフトを売り込むマイクロソフトの副社長という立場にあった西は、対価を支払ってくれれば誰もが利用できるソフトウエアのモジュールによって、アルトの子供の環境を実現しようと考えていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダイナウェアの竹松昇は、自らのコンピューターへの傾斜を決定的なものとした手作りシステムの製作記事の書き手が、自分のために用意されたとした思えなかったＰＣ―１００の作り手であることを知らなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その心の安んずるよう、強いて顔つくりてニッコと笑うて見せぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と渋面つくりて銀平の顔を視め、「銀平、遅かったわやい。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山吹の垣根つくりてある夕、少女すむ家と仲へだてけり。",
              "citation": {
                "source": "短歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その心の安んずるやう、強ひて顔つくりてニツコと笑うて見せぬ。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "麗かなる空をば一群の鳩輪をつくりて舞うが、姉上とわれと対いあえるに馴れて、恐気なく、此方の軒、彼方の屋根に颯と下しては翼を休めて、廂にも居たり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この塔は園に向きたるかたに、窪みたる階をつくりてその顛を平にしたれば、階段をのぼりおりする人も、顔に立ちたる人も下より明に見ゆべければ、イイダ姫が事もなくみづから案内せむといひしも、深く怪むに足らず。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この塔は園に向きたるかたに、くぼみたる階をつくりてそのいただきを平らかにしたれば、階段をのぼりおりする人も、いただきに立ちたる人も下よりあきらかに見ゆべければ、イイダ姫がこともなくみずから案内せんといいしも、深く怪しむに足らず。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は歌をつくりてこれを秀眞がもとにおくる。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきに買ひたる鮨の箱を見すれば、『それは、こちらでつくりて、今朝ほど持たしてやりたるなり』といふ。",
              "citation": {
                "source": "足柄の山水",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            }
          ]
        }
