        "examples": {
          "standard": [
            {
              "text": "「刺身のつまとして添えられている紅色の海藻は、角叉という種類だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「浜辺に打ち上げられた角叉を拾って、自宅で寒天の材料にしてみた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「角叉は、古くから糊の原料としても利用されてきた有用な海藻だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "このシュール・リアリズムにいたる途として一つのまた興味のある考えかたがある。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――女優を使うということが一つのまたうりものになっているんだから。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蝶はその三つ四つのまたたきのなかに、乳母のお咲がともした明りもあるのだろうと考えこみます。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
