[
  {
    "uuid": "99fb5ce7-2b59-54f9-9950-92f87286ec4a",
    "entry": "繋ぐ",
    "reading": {
      "primary": "つなぐ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ガ行",
        "動詞-他動詞"
      ],
