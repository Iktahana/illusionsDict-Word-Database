      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to connect",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しからばこの意味の想起の可能性を何によって繋ぐことができるか。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "纜を繋ぐや徳二郎も續いて石段に上り、先に立つてずん／＼登つて行く、其後から僕も無言で從て登つた。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして科学者として立とうとしている以上、今後は文学などに未練を繋ぐ姑息を自分に許すまいと決心したのだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてが埃に塗れて汚らしく、肉慾で人を繋ぐグロテスクで残忍な獄屋の正体をありありと見せ付けられる感じがした。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、此のものどもの寄つた方は、木の根ぐるみ地壓への杭も露顯に、泥の崩れた切立てで、上には樹立が參差と骨を繋ぐ。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "命を繋ぐためとは申せ、因業な活計でござりまして、前世の罪が思い遣られまする。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――きらずだ、繋ぐ、見得がいいぞ、吉左右！",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "挙止侠にして、人を怯れざる気色は、世磨れ、場慣れて、一条縄の繋ぐべからざる魂を表わせり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが結局崖邸の親子に利用されることになるのか――さもあらばあれ、それが到底自分にとって思い切れ無い真佐子の喜びともなれば、その喜びが真佐子と自分を共通に繋ぐ……。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五燭の灯の下にぼんやり照し出される憐れな狼藉の有様は、何か動物が生命を繋ぐことのために僅かなものを必死と食い貪る途中を闖入者のために追い退けられた跡とも見える。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は彼の紛らし易い性分から、彼の愛の慾求を何かに振り撒き、繋ぐことによつて、彼自身だけの始末をつけてゐた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボア・ド・ブウロニュ街の薔薇いろの大理石の館、人知れぬロアル河べりの蘆の中の城、ニースの浪に繋ぐ快走船、縞の外套を着た競馬の馬、その他の数々の芸術品を彼女とわたしとはいのちを消費する享楽の道づれとして用意した。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はあれ関勝蔵の一隊を境にして、前の諸隊は一揆勢に向い、後の三与は政宗に備えながら、そして全軍が木村父子救援の為に佐沼の城を志して、差当りは高清水の敵城を屠らんと進行したのは稀有な陣法で、氏郷｜雄毅深沈とは云え、十死一生、危きこと一髪を以て千鈞を繋ぐものである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "釜貞は他の不幸に際会して目的の無心も云へず、といふて明日の命を繋ぐ糧さへ無い我家を想ふと矢も楯もあらず、男を枉げ心を殺して幾許かの金を才覚して、大阪の家へ細※と認めた手紙に添へて送つてやり、自分は他の職を見つけるべく尚京都の縁者の許に身を置くのであつた。",
              "citation": {
                "source": "名工出世譚",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "禁断の智慧の果実と斉しく、今も神の試みで、棄てて手に取らぬ者は神の児となるし、取って繋ぐものは悪魔の眷属となり、畜生の浅猿しさとなる。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "疾く白媼が家へ行かっしゃい、借がなくば、此処へ馬を繋ぐではないと、馬士は腰の胴乱に煙管をぐっと突込んだ。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "数十年の前まで、一葉の扁舟さへ見難かりし太平洋は、今や万国商業の湊合する一港湾となり、横浜の埠頭と桑港の金門を繋ぐ一線は、実に世界の公路となれり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "人と人とをつなぐものも愛なり、神と人とを繋ぐものも愛なり、社会が受けたる害を酬ゆるは、社会自らも之を為す能はず、神も亦た社会に対して復讐の意味を以て、害を加ふると云ふ事は全然｜之あるまじき事なり。",
              "citation": {
                "source": "復讐・戦争・自殺",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "余はこれに未来の望みを繋ぐことには、神も知るらん、絶えて想いいたらざりき。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "全軍の信頼を繋ぐに足る将帥としては、わずかに先年｜大宛を遠征して武名を挙げた弐師将軍｜李広利があるにすぎない。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次々に何十という紙芝居の舞台面が、其等を繋ぐ物語を伴って頭の中に現れ、目前にありありと見える其等の一つ一つを順々に描写し続けることによって、彼の物語は誠に楽しく出来上るのだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "公道と私の家とを繋ぐ道路を作ろうというのである。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "韋固がそれは何かと云って聞くと、男女の結婚の事を書いたもので、袋の中には赤い縄があるが、その縄で男と女の魂を繋ぐと、どうしても夫婦になるといった。",
              "citation": {
                "source": "怪譚小説の話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺が、山茶花を大切にし、それに自分の慰めを繋ぐようになったのは、それからのことであった。",
              "citation": {
                "source": "山茶花",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "厭がってヒンヒンと鳴いては後去りする豚を無理矢理に枠の中に引っ張り込んで繋ぐ……、尚も悲鳴を上げて泣き続けているのに、大きな薪割様の刃物で、ガンと額に一撃を喰わせる……、するとその額から鮮血が、弾かれたように迸り出て、四辺のものが紅に染められる。",
              "citation": {
                "source": "首を失った蜻蛉",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅馬の牧のまことの若駒を轅に繋ぐ快さよ、とぞ叫びける。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はあんまりひどく急いでいたので、ボートを繋ぐなどということはしなかったろう。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、テレビと繋ぐためのインターフェイス回路を付け足すと、画面にも表示を出せました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがその直ぐの瞬間に、「あれは命をつなぐものだ」といふ考へが彼の頭を占領した。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような切れ切れの絵と絵をつなぐ詞書きがなかったら、これがただ一人の自分の事だとは自分自身にさえ分らないかもしれない。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
