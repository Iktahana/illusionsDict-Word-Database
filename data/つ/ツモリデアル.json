    "definitions": [
      {
        "index": 1,
        "gloss": "to intend",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "具体的なことがらについては、君と相談のうえできめるつもりであるが、僕のプランとしては、輸出むきの雑誌にしたい。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し、よく了解してさへ貰へれば、勿論色んな場合への適用も予想出来るやうには、書くつもりである。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ダメ」と云ったようなことを云ってやったつもりである。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "年少虚名の害に就いては、私だとて、よく知つてゐるつもりである。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "就中高山植物の美麗は熱帯の壮大華麗なる花を凌ぐのであるが、高山植物の美観は他日題を改めて説くつもりである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "アインシュタイン自身の言葉として出ている部分はなるべく忠実に訳するつもりである。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事については『ローマ字世界』の十二月号に詳しく述べるつもりであるから御参照を願いたい。",
              "citation": {
                "source": "戦争と気象学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついに父は荒川放水を逃路の限りとして背水の陣を敷き、青海流水泳の最後の道場を死守するつもりである。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上きわめて概括的に日本の自然の特異性について考察したつもりである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私はそういう学者の犠牲的精神に尊敬を払う事を忘れないつもりである。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "舊作の五篇も、カビが生えてはゐないつもりである。",
              "citation": {
                "source": "『女神』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "具体的の例はこの序論においては省略するつもりであるが、ただ自分の意味を明らかにするために、試みに若干の例をあげると、たとえば、最も縁の遠そうな英語ですらも、しいてこじつけようと思えばかなりにこじつけられない事はない。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はできるだけ根拠なき臆断と推理を無視する空想を避けたつもりである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれらの空想にも、自分としては相当な物理学的実証の根拠は持っているつもりであるが、ここではこれについて詳説することのできないのを遺憾とする。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいいつまでこのおさだまりの記事をつづけるつもりであるのかその根気のよさにはだれも感心するばかりであろう。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また大陸塊の縁辺のちぎれの上に乗っかって前には深い海溝を控えているおかげで、地震や火山の多いことはまず世界じゅうの大概の地方にひけは取らないつもりである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくそういう人たちの参考になるかもしれないと思ったのでできるだけ忠実にこのひと朝の夢の現象を記録したつもりである。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人にものを教えたり強いたりする気ははじめからないつもりである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」家内は、ねばるつもりである。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの不潔な虱と、私の胸の奥の白絹に書かれてある蟻の足跡のような文字とは、本質に於いて全く異るものであるという事には、私も確信を持っているつもりであるが、しかし、その説明は出来ない。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの原稿を書上げ次第、雑誌社に居る友人に郵送するつもりである。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "運命の魔女が織り成す夢幻劇の最後の幕の閉じる幔幕としてこの刺繍の壁掛けを垂下したつもりであるかもしれない。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ自分の主観の世界における先生のおもかげを、自分としてはできるだけ忠実に書いてみたつもりであるが、学者として、作家として、また人間としての先生の面影を紹介するものとしては、あまりにも零細な枝葉の断片に過ぎないものである。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前業の養鶏奨励の方法は、だんだん詳しく述べるつもりであるが、まあその模範として一例を示そう。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "轡川には愛情は感じ得ず、今度彼女が白浜へ来たのは、轡川と絶交する目的で来たのでその話がつけば直ぐ田辺に帰えるつもりである。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまだ『あなたまかせ』にまで帰納しきっていないことを恥じるが、与えられるものは、たとえそれがパンであろうと、石であろうと、何であろうとありがたく戴くだけの心がまえは持っているつもりである。",
              "citation": {
                "source": "独慎〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私一個人の感想も、批評も、自らその中に溶け込ませているつもりである。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七百頁の「葛原勾当日記」のわずかに四十分の一、青春二十六歳、多感の一年間だけを、抜き書きした形であるが、内容に於て、四十余年間の日記の全生命を伝え得たつもりである。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つねに故人の、一流芸者としての精神を、尊重して来たつもりである。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明朝は、相川へ行ってみるつもりである。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
