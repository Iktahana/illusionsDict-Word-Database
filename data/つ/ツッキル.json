    "definitions": [
      {
        "index": 1,
        "gloss": "to cross",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "農家の垣には梨の花と八重桜、畠には豌豆と蚕豆、麦笛を鳴らす音が時々聞こえて、燕が街道を斜めに突っ切るように飛びちがった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにしろ悪く寒いね」「この二、三日は冴え返りました」「これから田圃を突っ切るのは楽じゃあねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "春の雪解",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鳥は花屋敷前の暗い木立ちのなかを脱けて、露店の出ている通りを突っ切ると、やがて浅黄色の旗の出ている、板塀囲いの小体な家の前まで来てお庄を振り顧った。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを突っ切ると杉の小山。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく、五羽の鰹鳥はその籠をひいて、底をかすかに水面に触れながら、まっしぐらに突っ切るだろう。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルッと血顫いした葉之助、そのまま前庭を突っ切ると、正面に立っている古代造り、久田の姥の住む館へ、飛燕のように飛び込んで行った。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出た所が富島町で、それを突っ切ると亀島橋、それを渡れば日本橋の区域、霊岸島から出ることが出来る。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金精峠の麓、菅沼湖畔の山の家の所から、小舟に乗って湖を突っ切る。",
              "citation": {
                "source": "山吹の花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は一本か二本の索を用意して一番幅の広い場所を突っ切る時にはそれを頼りにした。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "東へ抜けると板倉家、西へ突っ切ると賀州殿、これはどっちも行き止まりだ。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空地を突っ切ると本邸で、戸にさわると戸が開いた。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを突っ切るのが目的じゃ！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊りの庭を出外れると、森と寂しい空地であったが、その空地を突っ切ると巨然たる館の前へ出た。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをさかのぼると盆の沢、そこを突っ切ると一本松、太い松の木が生えてるのさ。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "斜めに突っ切るつもりだね。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬術は大坪、常心流、随心流など繁昌とか、せめて我らが行列を、突っ切る者はござらぬかな！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしも、門前町を突っ切るのですからそこまでごいっしょに参りましょうよ」「ええ、ぜひごいっしょに参りましょう」　町が物騒なので、一空さまが、金剛寺門前町を通りすぎるところまで送って行くことになった。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "東仲町が大川橋にかかろうとするその袂を突っ切ると材木町、それを小一町も行った右手茶屋町の裏側に、四軒長屋が二棟掘抜井戸を中にして面い合っている。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "霙橋辻斬夜話",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　身体を斜に風の当りを弱めながら小笠原｜長門守様前を突っ切ると、次の一廓が松平修理太夫と和気行蔵の二構え、お長屋門の傍から松が一本往来へ枝を張っている。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "無明の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の死骸の側で、涙と共に掻き口説いて居たお峰は、不意を喰った狐のように、一足飛に隣の八畳を突っ切ると、梯子段に飛付いて、逆落しに階下へ降りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "春宵",
                "note": "青空文庫"
              }
            },
            {
              "text": "――自分だけ一足先に抜けたり、街路を突っ切るなどということはとても不可能なことであった。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしゼエハアゼ氏は、幾度となく謝罪の辞を述べ述べ、客をまた案内して玄関を突っ切ると、二匹の獅子の間を抜けて、馬車の所まで見送った上、客の乗ったあと、うやうやしいものごしで、自分で馬車の扉を閉じた。",
              "citation": {
                "source": "トニオ・クレエゲル",
                "author": "TONIO KROGER",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな調子で二人は、音なく青む海を背景に、トニオ・クレエゲルの眼の前を通りすぎて、食堂を縦に端から端まで突っ切ると、反対側の扉口からピアノの室に姿を消してしまった。",
              "citation": {
                "source": "トニオ・クレエゲル",
                "author": "TONIO KROGER",
                "note": "青空文庫"
              }
            },
            {
              "text": "首を垂れたまま、右も左も見ずに、ルドウィヒ街を突っ切ると、寺院の階段を昇って行った。",
              "citation": {
                "source": "神の剣",
                "author": "GLADIUS DEI",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを突っ切ることが目的地に達するに近路だと考えれば、必ずその通りに進んで行くに相違ない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも敵対部族を突っ切る。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　ジョニ・ウォーカが森を突っ切る旅の最終準備をしているのを見ながら、ドレントン・デンが言った。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙の中を突っ切るよ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、両手を胸の上で重ねて、おさかなが水のなかをつういとつっきるように、いやらしいさんご虫どもが、くなくなした指と腕とをのばそうとしているなかをつっきって行きました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "寮と校舎をつなぐ道は、明示的には二本ある（グラウンドをつっきる方法は数パターンあるので、勘定に入れない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
