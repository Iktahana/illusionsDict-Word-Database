[
  {
    "uuid": "7fe946b5-1a9b-523b-a6b2-02bfc776152f",
    "entry": "痛快",
    "reading": {
      "primary": "つうかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
