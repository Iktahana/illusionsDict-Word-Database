    "definitions": [
      {
        "index": 1,
        "gloss": "leaving (on, open, unfinished, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山の宿屋というものを、思わせる「糸屋」と看板を出した旅籠屋には、椽側に紡車を置きっ放しにして、ひっそりかんとしている、馬車はここで停まった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、いやに明けっ放しでいやがる。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　暑苦しいために明けっ放した表から、誰かが呼んだ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ特に私が宇都野さんに望む所は、時々はもう少し不用意な、読みっ放しの云わばもっとそつのある歌をよんで見せて頂きたいと思う事である。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めのうちはただ読みっ放しにしていたが、あまり面白いから途中からは時々手帳へ覚え書きに書き止めておいた。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云って、如何に単純でたくらみがないとは云え、窃んだ物を台所に置きっ放しにして平気でいられようとは思われなかった。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自分の飲みっ放しを日なたのなかへ置いておく。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしたまには笑いっ放しに笑わせてしまうのもあってはどうかと思われた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいてい、こんな、机の引出しなんかへ容れっ放しにして置くので、大掃除や転居の度毎に少しずつ散逸して、残っているのは、ごくわずかになってしまいました。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きなお世話でサア……文科の生徒さんなんかは、試験前にチョイチョイ来て、アノ棚の上の大きなウエブスターの辞書だの大英百科全書を抱え下して、入り用な字を引いちゃってから、そのまま置きっ放しぐらいは構いませんが、ノートに控えるのが面倒臭いんでしょう。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "点けっ放しの百｜燭光に照らされたインキの文字がまだ青々していた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと気が着いて見ると、箪笥を入た押込の襖が開けっ放して、例の秘密の抽斗が半分開いていた。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度法令が変わると他人の家へうっかり黙ってはいって来るものにはピストルを向けてぶっ放してもいいことになるという話である。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくらい新井田の夫人は渡瀬に対して開けっ放しに振舞ったし、渡瀬は心の中で、ありえない誘惑に誘惑されていたのだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "星野に対してはあの近づきがたいような頭の良さと、色の青白い華車な姿とに興味をそそられているらしいし、俺を見ると、遠慮っ気のない、開けっ放しな頑強さにつけ入ろうとしている。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の奴をイフヒムの前に突っ放して、勝手にしろと云ってくれようか。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、床の間や置戸棚の上は勿論畳の上まで、書きつぶし、原稿用紙や新聞や雑誌や手紙がまるで紙屑屋の家のように、置きっ放しにしたまま、うず高く積まれているし、蒲団はしきっぱなしだし、足の踏み場もない。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも東京へ来てからは若い奥さんか何かに化けて、乳母車を押しながら逃げまわっていたらしいんですが、そのうちにその筋の手がだんだん詰って来たもんだから、あの横町で洋装の令嬢に変装して、ぬけ殻の着物や下駄を隠した乳母車をこの男に押っつけて、こっちの方角へ突っ放したまんま、行方を晦ましたらしいんです。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピストルを自分の耳にぶっ放したい発作とよく似た発作におそわれたのであった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにも私のほうだけが、いつもごちそうのなりっ放しになっているわけではない。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして私は相変らずの、のほほん顔で、ただ世話に成りっ放し、身のまわりの些細の事さえ、自分で仕様とはしないのだ。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日に四冊も五冊も、次々と読みっ放しである。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいお天気で、からりと日が照っていたから、この間中の湿気払いだと見えて、本堂も廊下も明っ放し……で誰も居ない。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしのかけた色っぽい電気は普通の性根の男なら、なおも相手の胸の中に浸み入って、そこで好悪の心秤にかゝり、粘り返すなり蔑み除けるなりとにかく心理的な手応えがあるほか、人によっては性の相対の火花を所作の上にまで撥いて何等かこっちに手応えを得さすものですが、文吉はそれっ放しでございます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一緒に象ヶ鼻まで遊びに行ってみないか」あっさり言いっ放しで強いて勧めるでもなく首は畑越しに弟の後姿の方に向けて眺めやりました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはおまえに惚れっ放しで、そしてわたしはおまえから何の返しも要求しなかったのだから、やはりおじさんの恋なのだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君も撲られっ放しでは気が済まないだろうから、一つ懲しめのために訴えてやるか。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日は明日の風が吹くよ」　と、突っ放して、やがて陽子のアパートを探して歩いた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ズドンと大砲をぶっぱなしたら、陰気くさい支那人が『デモだ』なんて云ってるのよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の一層高くなっている麓に据えつけられた狙撃砲は、その砲さきへ弾丸をつめこんで、村をめがけてぶっぱなした。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
