        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "概算の計算過程で四捨五入の積み過ぎが発生し、最終的な数値がズレてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "各項目の端数を切り上げた結果、合計値に積み過ぎによる誤差が生じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "精密なシミュレーションを行う際は、計算上の積み過ぎを防ぐアルゴリズムが必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
