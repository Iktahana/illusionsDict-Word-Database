    "definitions": [
      {
        "index": 1,
        "gloss": "swallow (bird of the Hirundinidae family)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ぢや燕麦を十リットルばかり持つて来て頂戴。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大した骨折をした揚句、ともあれ十リットルの燕麦を運んだ。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、燕麦の用意はいいよ。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃この界隈に噂が立ちかけて来た、老妓の若い燕というそんな気配はもちろん、老妓は自分に対して現わさない。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤シャツの農夫は炉のそばの土間に燕麦の稈を一束敷いて、その上に足を投げ出して座り、小さな手帳に何か書き込んでいました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番面白いのは、三艘の大飛行船が船首を並べて断雲の間を飛行している、その上空に追い迫った一隊の爆撃機が急速なダイヴィングで礫のごとく落下して来て、飛行船の横腹と横腹との間の狭い空間を電光のごとくかすめては滝壷の燕のごとく舞上がる光景である。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "感傷の手わが性のせんちめんたる、あまたある手をかなしむ、手はつねに頭上にをどり、また胸にひかりさびしみしが、しだいに夏おとろへ、かへれば燕はや巣を立ち、おほ麦はつめたくひやさる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その癖腰を卸すとたんに、燕尾服の長い裾を丁寧に左右に開くことは忘れなかつたのである。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで燕尾服にも及ばないといって来た位です。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "一羽の燕が迷ひ込んでゐて、疲れた翼を振つて、出口を捜してゐるのであつた。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕尾服をつけた給仕が、銀盆に一枚の名刺を置いて、ものものしく妾達の卓子の前で、黒い尾を折りました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして母屋の入口の軒陰から燕が出たり入つたりして居る。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まであの店の部屋の古風な装飾なり、また燕尾服を着たボーイなりが、すべて前の世紀の残りものであったのが、火事で焼けたこの機会に、一足飛びに現代式に変ってしまったのだというような気がした。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木蓋の上へは燕麦の這入った袋を持ってきて積み重ね、穴倉があることを分らなくした。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰来した燕は、その麦の上を、青葉に腹をすらんばかりに低く飛び交うた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺三郎なんかまるで立派な燕尾服を着て水仙の花を胸につけてまっ白なはんけちでしきりにその尖ったお口を拭いているのです。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕のいなくなった街道の家の軒には藁で編んだ唐がらしが下っていた。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "射干にも似、菖蒲にも似たる葉のさま、燕子花に似たる花のかたち、取り出でゝ云ふべきものにもあらねど、さて捨てがたき風情あり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十年も前であつたらう、桃川燕林が上野広小路の吹ぬきといふ寄席で次郎長の伝を演じた。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪んで之を質して見ると、夫れは次郎長の子分共で、若し少しでも間違つた事を云つたなら、直ぐ高座へ躍り上つて燕林を責め糺す気であつたらしいが、燕林の調査が行届いて居て余り間違ひの無いのに感服して帰つて行つたといふ事があつた位である。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "くりくり坊主の桃川如燕が張り扇で元亀天正の武将の勇姿をたたき出している間に、手ぬぐい浴衣に三尺帯の遊び人が肱枕で寝そべって、小さな桶形の容器の中から鮓をつまんでいたりした。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、燕尾服を着た仁丹の鬚のある太夫が、お客に彼女のあらましの來歴を告げて、それから、ケルリ、ケルリ、と檻に向つて二聲叫び、右手のむちを小粹に振つた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、燕尾服を着た仁丹の鬚のある太夫が、お客に彼女のあらましの来歴を告げて、それから、ケルリ、ケルリ、と檻に向って二声叫び、右手のむちを小粋に振った。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもいやいや日に二つ三つはやってましたが、そのやり方もごく大ざっぱになって来て、茶いろと白と黒とで、細いぶちぶちにして呉れと頼んでも、黒は抜いてしまったり、赤と黒とで縞にして呉れと頼んでも、燕のやうにごく雑作なく染めてしまったり、実際なまけ出したのでした。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤シャツの農夫は炉のそばの土間に燕麦の稈を一束敷いて、その上に足を投げ出して座り、小さな手帳に何か書き込んでゐました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽根がむらさきのような黒でお腹が白で、のどの所に赤い首巻きをしておとう様のおめしになる燕尾服の後部みたような、尾のある雀よりよほど大きな鳥が目まぐるしいほど活発に飛び回っています。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁やつばめの去来は昔の農夫には一種の暦の役目をもつとめたものであろう。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その氷塊の上では海豹がまどろみ、海つばめはその上を飛びこえて行くのです」第十夜「わたしはひとりの老嬢を知っていました」と、月が言いました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ステンド・グラスはすすけ、天上のキリスト降誕の壁画のそばには、古いつばめのすが、へばりついていました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、からだはつばめのようにかるかった。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
