    "definitions": [
      {
        "index": 1,
        "gloss": "someone with a liking or characteristic",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ヘッ、毛も生えないような、雛っ子じゃあるめえし、未だ、おいら泣き死にはしねえよ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だい、馬鹿にしてやがら、未だ小僧っ子じゃないか。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もそう云やあ、此小僧っ子の云う事がほんとには、ほんとなんだがな。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゃ、俺のものでもねえし、又此小僧っ子のでもねえんだ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "（あの小僧奴、俺の子供位に雛っ子の癖してやがって！",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "）それでいて、その小僧っ子の見てい、感じてい、思ってい、言う言葉が、（親位な俺に解らねえなんて）　彼は車室を見廻した。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな小僧っ子の事で、何だ、グズグズ気をとられてるなんて、他事じゃねえや、こちとらの事だ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の、先天的に鋭い理智と、感情とは、小僧っ子の事で一杯になっていた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、警官の密集を利用しようとする、本能的な且つ職業的な彼一流の計画を忘れて、その小僧っ子に、いつか全幅の考えを奪われてしまった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの映画「影なき男」に現われた夫婦愛のソフィスティケーションの中にわれわれは江戸っ子の粋の反映のようなものを認めることはできないであろうか。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この美少年は不良を衒っているが根が都会っ子のお人好しだった。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、傍で砂いじりしている子はおいたさんと呼ばれるほどの一くせありげないたずらっ子の男児だ。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "血気な連中のうちの一人の江戸っ子が、「それじゃインキがどれだけ多くついてもやはり同じ事か」と聞いた。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の高輪の方に位したその屋敷町の往還は常から人通りが少なかったが、風がだんだん吹き募りながら夜に入ってからは人っ子一人通らなかった。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしはよくよく子供に運がない」　おまきはいつも愚痴をこぼしていたが、それでも末っ子の七之助だけは無事に家に残っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよという時にゃあ、俺だって馴染み甲斐に魚っ子の一尾も持ってお祝いに行こうと思っているんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると印度人は自分の手を引き込めて、観客の方を向き、その男の手振を醜く真似て見せ、首根っ子を縮めて、嘲笑って見せた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ少数な江戸っ子の敗残者がわざわざ竹仙の染め物や伊勢由のはき物を求めることにはかない誇りを感ずるだけであろう。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一方ではまた、自分の田舎では人間の食うものと思われていない蝗の佃煮をうまそうに食っている江戸っ子の児童もあって、これにもまたちがった意味での驚異の目を見張ったのであった。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ言葉はわかっても結局パリっ子でない日本人が見たパリっ子はどうしてもパリっ子の見たパリっ子とは同じではないからである。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一声高く咆哮しておどり上がりおどり上がると、だだっ子の兵児帯がほどけるように大蛇の巻き線がゆるみほぐれてしまう。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋人なら乞食でも尊敬しようといったような日本人の多い中に、こういう純粋な日本人の江戸っ子が、一人でもまだ存在するということが当時の自分にはうれしかったのである。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらはやりっ子のプレジアンでも、相手がいつも同じ相手役では、結局同じ穴のまわりをぐるぐる回ることになるであろう。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐吉さんの兄さんは沼津で大きい造酒屋を営み、佐吉さんは其の家の末っ子で、私とふとした事から知合いになり、私も同様に末弟であるし、また同様に早くから父に死なれている身の上なので、佐吉さんとは、何かと話が合うのでした。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次はラクシャン第三子やさしい眼をせはしくまたたきいちばん左はラクシャンの第｜四子、末っ子だ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風の神の子っ子だぞ。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次はラクシャン第三子やさしい眼をせわしくまたたきいちばん左はラクシャンの第｜四子、末っ子だ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく僕は、僕自身にうまくひっこみをつけたいのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで麻酔なしでこの出血のはなはだしし手術を遂行したが、おしまいまでいっこうに平気で苦痛の顔色を示さなかった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分七、八歳くらいの自分と五、六歳くらいの丑尾さんとが門前のたたきの斜面で日向ぼっこをしていた。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
