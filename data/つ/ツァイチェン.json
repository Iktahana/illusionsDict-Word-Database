        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "死は永遠の死にして、再見の機あらざるべき実を知りたり。",
              "citation": {
                "source": "心機妙変を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年の春の初め、森の中には未だ所々に雪が殘つてる時分お里は再見えなくなつた。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は温顏もて我を迎へ、我身を囘抱して、再見の喜を述べたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「グッドバイ」の意味する如く、神を傍らに持たず、中国語の、さよなら「再見」の意味する、愛する人たちとの再会の希望もない軍隊は、相手の人間をいたずらに傷つけ殺し軽蔑し憎悪することで、自分たちの高貴な人間性も不知不識に失なっていた。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ぜなら如何に長慶太神宮祕藏の文書とはいへ、書手が再見出來ない筈もなし、又最初書終つた時にも校讀もしたであらう。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "国頭の山の緋桜のやうに、寂しいけれど、ぽつかりとのどかに匂うて居た沖縄の音楽・舞踊・演劇を綜合した組踊りも、今は再見られぬ夢と消えてしまつたのであらう。",
              "citation": {
                "source": "沖縄を憶ふ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、再見ることもなからうと言ふほどの痛苦の感激を覚えて、呆としてゐた。",
              "citation": {
                "source": "実川延若讃",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで信二の家に到着したときには、親しい家へついたようにホッとしたばかりでなく、明るい電燈の下で再見した信二には今までとは別人の親友のようななつかしさも感じたのである。",
              "citation": {
                "source": "文化祭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "尼総持は「慶喜の阿※仏国を見、一見更に再見せざるが如し」と答える。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一〇、太平洋帰航日記（付世界周遊再見）八五、ハワイ航路所見　明治四十四年十二月十六日、メキシコ・マンサニヨ港を出航し、六千マイル以上の太平洋を横断して、帰行の途に就く。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが詩人よ、汝は御神の子供にして、汝のみが喜びの眼で以て夕映えのむこうの国を再見し得るであろうし、かの王女のかんばせを目にすることが叶うであろう。",
              "citation": {
                "source": "夕映えのむこうの国",
                "author": "時代を超えた童話",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝さんに見ることをすゝめた、「秘めたる情事」有楽座初日へ、僕、大感激篇だから、再見。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "故｜近衛文麿の父｜篤麿のごときは、「一見すれば高貴、再見すれば平凡、三見すれば信頼不可能。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "-------------------------------------------------------「グッドバイ」「オォルボァル」「アヂュウ」「アウフビタゼエヘン」「ツァイチェン」「アロハ」等々――。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            }
          ]
        }
