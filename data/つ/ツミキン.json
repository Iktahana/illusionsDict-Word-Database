        "examples": {
          "standard": [
            {
              "text": "毎月の給料から一定額を積み金に回し、将来の結婚資金に充てる予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "マンションの修繕積み金の値上げが、理事会で大きな議論になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "会社は不測の事態に備えて、内部留保としての積み金を厚くしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "源右衞門は講の積み金を持つて出たのだけれど、それは今までの旅籠賃と、御師への禮物と、太神樂の奉納とに、あらかた使ひはたして、幾らも殘つてはゐない。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはお役所からも神明講永代講の積み金からも、中津川の商人からも、あるいは岩村の御用達からも借り入れたもので、その中には馬籠の桝田屋の主人や上の伏見屋の金兵衛が立て替えたものもある。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
