        "examples": {
          "standard": [
            {
              "text": "大型トラックの荷台での積み降ろし作業には、フォークリフトの操作が欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "狭い路地での積み降ろしは、周囲の交通を妨げないよう迅速に行う必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "腰を痛めないように、重量物の積み降ろしには細心の注意を払っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "次の寄港地は都合によってどんなふうにでも変更になるし、碇泊日数も荷物の積み降ろしや天候によって、自由に変わる。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その貨車は、矢倉駅でつみおろしをすることになっていたのです。",
              "citation": {
                "source": "天空の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、列車が九時に矢倉駅について、いざ、つみおろしをしようとすると、その封印つきの貨物車が、一両だけ、消えうせていました。",
              "citation": {
                "source": "天空の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
