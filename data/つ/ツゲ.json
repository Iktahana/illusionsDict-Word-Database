    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese box tree (Buxus microphylla var. japonica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "片手でも押し倒せそうな小さい仮家で、柊や柘植などの下枝に掩われながら、南向きに寂しく立っていた。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば今日｜丈の厄介になりましょうと尻を炬燵に居て、退屈を輪に吹く煙草のけぶり、ぼんやりとして其辺見回せば端なく眼につく柘植のさし櫛。",
              "citation": {
                "source": "風流仏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "柘植氏のもとを訪ねたのは祭の提灯が飾つてある日であつた。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "柘植氏は余を案内してあるきながら或角の菓子屋の店へはいつた。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "柘植氏は家へ戻つてそれを更に冷たい水へひたした。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "柘植氏は大垣の水が自慢なのである。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "養老はあんなものではないあれは秣が瀧といふのだと柘植氏は語る。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "柘植氏は稍得意である。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "柘植氏はそこへ腰を掛ける。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "柘植氏は其四阿へ衣物を脱ぐ。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀧へかゝるにはふどうオ／＼と尻を引いて呶鳴りながらかゝるのだと柘植氏が教へる。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "余も柘植氏のあとから呶鳴りながら打たれはじめた。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると柘植氏の皮膚が赤くなつて居る。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩年大河内子爵のお伴をして俗に柘植黙で通ってる千家の茶人と、同気相求める三人の変物｜揃いで東海道を膝栗毛の気散じな旅をした。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "石灯籠の下にある草柘植を少し離れて、名も知らない小さな菌が二かたまり生えているのが眼についた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "立っていたのは、同じ番町で屋敷を隣り合わせて、水馬のときにも同じ二組で轡を並べて、旗本｜柔弱なりと一緒に叱られた仲間の柘植新兵衛だった。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その義歯は柘植の木で作られていたように記憶している。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "治安維持法時代から特高として働いてきたツゲ事務官（柘植）は、尾崎秀実の例をひいて「彼は遂に刑場の露と消えた。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて私がランプを見たのは、六つの時、雪の降る夜、紫色の縮緬のお高祖頭巾を冠った母につれられて、東京から伊賀の山中の柘植という田舎町へ帰ったときであった。",
              "citation": {
                "source": "洋灯",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び私は母と姉と三人で母の里の柘植へ移らねばならなかった。",
              "citation": {
                "source": "洋灯",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは各自がいつか前に身に覚えのある悲しみを追想しているようでもあれば、また俄に感じた自分の生を噛みしめ直して味わい愉しんでいるようにも見え、矢代もひとり柘植の緑の葉に見入った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と矢代は柘植の新芽から眼を放して千鶴子を見た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　摘み取った柘植の葉を掌の上に乗せ、極まり悪げに身を左右に廻して、そういう千鶴子を矢代は何んとなく見て笑った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫色のぱっちりした矢絣の膝のよく伸びた姿勢で、柘植の木の横から段を降りるのが沼の水面に映っていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人は伊賀の柘植の人だから、おれと同じ村だ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "眺め飽かぬ鈴鹿山脈の溪谷を横斷して汽車が伊賀の國境を踰えると、すぐ柘植の驛がある。",
              "citation": {
                "source": "伊賀國",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "今電車の窓から日曜の街の人通りをのどかに見下ろしている刻下の心持はただ自分が一通りの義務を果してしまった、この間中からの仕事が一段落をつげたと云うだけの単純な満足が心の底に動いているので、過去の憂苦も行末の心配も吉野紙を距てた絵ぐらいに思われて、ただ何となく寛ろいだ心持になっている。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺ゃまだ銃がかつげないんです！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごつげな、いい金モール服を着てやがって、どこの馬の骨だい！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "虹吉は、去年あたりから、やっと四斗俵がかつげるようになったばッかしじゃもん。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
