    "definitions": [
      {
        "index": 1,
        "gloss": "treaty of commerce",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
