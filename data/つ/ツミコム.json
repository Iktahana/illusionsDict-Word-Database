[
  {
    "uuid": "574f7b8f-0d36-520e-857b-e301e7146477",
    "entry": "積み込む",
    "reading": {
      "primary": "つみこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
