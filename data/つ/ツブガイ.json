        "examples": {
          "standard": [
            {
              "text": "日本海で獲れた新鮮なつぶ貝は、刺身で食べるととても美味しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "居酒屋でつぶ貝の串焼きを見つけ、思わず注文してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "潮干狩りではアサリだけでなく、時々つぶ貝も見つかることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ある晩は料亭で、つぶ貝などを食べながら、多勢の美人の踊る音頭を見せられ、ある時はまた川向いにある彼女の叔母の縁づき先であった町長の新築の屋敷に招かれて、広大な酒蔵へ案内されたり、勾欄の下を繞って流れる水に浮いている鯉を眺めながら、彼の舌にも適うような酒を呑んだりした。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
