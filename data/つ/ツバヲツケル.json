        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「このケーキ、私が食べるから唾をつけておくね」と、妹は冗談めかして言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は気に入った物件があったらしく、他の人に取られないよう早めに不動産屋で唾をつけてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "誰にも文句を言わせないように、あらかじめ自分が担当する仕事に唾をつけておいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「わんわんして、火がつきゃ燃えつきそうな頭じゃ」　櫛の歯をハーモニカのように口にこすって、唾をつけると、母は私の額の上の捲毛をなでつけて云った。",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "血のにじんだ所へ唾をつけると、ひりひりと痛んだ。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「眉毛に唾をつける」「何故？",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学問や世才は兎に角、人間としては君が一番出来上っている」「これだ／＼」　と安達君は又眉毛に唾をつける真似をした。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、読もうとする前に、眉に唾をつけるくらいな戒心で、「こいつあ、あぶねえ」　と小首をかしげた。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
