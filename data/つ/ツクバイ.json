    "definitions": [
      {
        "index": 1,
        "gloss": "stone wash basin found in Japanese gardens",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
