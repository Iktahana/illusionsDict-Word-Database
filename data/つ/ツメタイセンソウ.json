        "examples": {
          "standard": [
            {
              "text": "あの二人の間には、一言も口を利かない冷たい戦争がもう一週間も続いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "派閥争いが激化し、社内はまるで冷たい戦争のような張り詰めた空気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夫婦喧嘩のあとの冷たい戦争を終わらせるために、彼から謝ることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "コールド・ウオー冷たい戦争――武器をとらぬイクサ――それは既にはじまっていると新聞などに書いてありますね？",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
