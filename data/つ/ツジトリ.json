      {
        "index": 1,
        "gloss": "taking a wife by kidnapping a woman passing by on the road",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
