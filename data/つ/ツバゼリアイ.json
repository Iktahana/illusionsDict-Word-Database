        "examples": {
          "standard": [
            {
              "text": "二人の侍は互いに譲らず、火花を散らしながら激しくつばぜり合いを演じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "剣道の試合で、つばぜり合いの状態からどう抜け出すかが勝負の分かれ目となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "時代劇のクライマックスシーンで、主役と宿敵が顔を寄せ合ってつばぜり合いをする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "渡辺との激しいつばぜり合いの末にＰＣ―９８０１を立ち上げた浜田俊三は、ＰＣ―９８０１のアーキテクチャーを完成させるＶＭ★の発表の直前、一九八五（昭和六十）年七月にＶＡＮ販売推進本部本部長に異動となった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "と合して、人の字形に静止――つばぜりあいだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
