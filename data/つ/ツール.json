    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tool",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今月｜一ぱいで店を畳んで、はあ、ツール在の土となるまでの巣を見つけて買い取りましたよ。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "道は小店を並べた横町を貫いてツールノンの大通りに出る。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家鴨料理ツール・ダルジャン　家鴨の番号数二万――八。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツール・ダルジャンの酒倉は世界の食通の一度は見学すべき博物館になっている。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家鴨料理のツール・ダルジャンでゆっくりした晩餐をとった後、新吉とリサとは直ぐ前のセーヌ河の河岸に沿って河下へ歩き出した。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういった、アマツール的な気持からは、ただ、太宰治のくるしみを、肉体的に感じてくるばかりで、傍観者として呆然としているばかりである。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里から西南へ三時間程汽車に乗って行くとロアール河の都ツール市へ着きます、其処から汽車を乗り換えて二十分｜許りで此のモントリシヤへ到着します。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツール市からモントリシヤへかけて沢山の城や宮殿が建って居ります。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この Expanded Book によってコンピューターで読むという世界を開きはじめたボイジャーが新たに打ち出したのが、この電子本を作るためのオーサリングツールである。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちなみに同社では Expanded Book の日本語名を「エキスパンドブック」とするそうで、これにしたがって本稿でも以下は「エキスパンドブック・ツールキット」と書く。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語バージョンでも日本語の本が作れる　エキスパンドブック・ツールキットのソフトウエアは、四つの要素からなっている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一は電子本作成のためのツールキットの本体。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このうち The Library と Notebook は、ツールキットによって作られたエキスパンドブックと共に、読者に配付される。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ツールキット本体は読む際には必要なく、ボイジャーはこれをコピーしたり配付したりすることを禁じている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツールキットを用いて作った電子本が、商業ベースによらない無料のものであるかぎり、ソフトウエアの購入費用以外、ボイジャーへの追加の支払は必要ない。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校や図書館、博物館がツールキットによる成果物を無料で配付する際には、求められるのはエキスパンドブックと The Library に対するボイジャーの著作権表示を行なうことだけだ。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "まがりなりにも筆者には書きためた原稿が売りたいほどあるので、この作業は省略することができたが、ここにはご存じのとおり頭をひねる要素が山ほどある）加えてツールキットには、かなり本格的な編集作業上の要請に答える機能が用意されている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今回ツールキットのマニュアルを読んで初めて知ったが、英語の編集の世界にもこうした審美の物差しがある。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれを救うために、ツールキットにはパラグラフの文字と文字の間のスペースをわずかに伸ばしたり縮めたりして、オーファンやウィドウを避ける機能が組み込まれている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘッダの書名と章名が文字化けするといった明らかな問題点の解消に加えて、ツールキット日本語版が我が国の組み版のルールにどこまで対応してくれるかに、大いに期待したい。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はツールキットを知ってから、これを使って作りたい本、復活したい本のアイデアがふつふつと湧いてきて、悠長に人の本など読んでいられない心境なのだ」暗い日に見つけたもの　ツールキットに対するこの評価記事は、一九九三（平成五）年の一月十五日に書きました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い文書ファイルを引っ張り出して読み返したとき、このツールキットの評価記事には明るい調子を感じました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "青空のリスタート・ボタンは、押そうと思えばオレにもあなたにも押せるのだ」ボタンを押したツールキット　後書きにそう書いた本は、一九九二（平成四）年の九月末に出しました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツールキットの評価記事は、正月八日が締め切りでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやくツールキットの原稿を仕上げて一か月ほどで、マッキントッシュのフェアーが、例年通り幕張で開かれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには「本年四月発売予定でツールキットの日本語化を進めており、日本オリジナルの出版企画も準備中です」とありました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当面の課題としてツールキットの日本語化を挙げた萩野さんは、「本来なら売れないような本も、これで出版が可能になる。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "エキスパンドブックを読み、ツールキットを使ってみて自分が感じた可能性を、いち早く確信した人がいる。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるがままの自分が書き、まとめて人に手渡そうとするとき、ツールキットは力を貸してくれるだろう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
