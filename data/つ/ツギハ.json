    "definitions": [
      {
        "index": 1,
        "gloss": "opportunity to continue a conversation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さあ、そのつぎはどうだ。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御神輿かつぎは、人の氣競がもの凄い。",
              "citation": {
                "source": "祭のこと",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは、見るもかわいらしいアラセイトウとカーネーションです。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "おうい、つぎは四ばん、四ばん！",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ、詩人ハンスであった銅像は、医者のヘンデル先生にかわり、つぎは軍人のペテロにかわり、つぎには、おそろしい強盗にかわり、ついには、とけて七つの鐘になりました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎは、くまのクロが出る番になっていました。",
              "citation": {
                "source": "正坊とクロ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "津軽に於いては、浅虫温泉は最も有名で、つぎは大鰐温泉といふ事になるのかも知れない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は女学校時代のつぎはぎだらけのスカートに、それからやはり昔スキーの時に着た黄色いジャケツ。",
              "citation": {
                "source": "恥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺のスカートは、つぎはぎだらけだ。",
              "citation": {
                "source": "恥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は食事道具を潮が下げ加減になって来た川の水で洗い、器用に始末してから、何処で貰って来たのかつぎはぎだらけの子供の昼寝の畳｜蚊帳を拡げて、うす縁畳の上へころりと寝ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前はあれでも耻しいとも何とも思つてはゐなかつたのか」とどもり吃り、つぎはぎだらけの仕返しをして、ほつと呼吸をつきました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　貧乏な荷かつぎは、びっくりしました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "片すみには繩を張って、つぎはぎのせんたく物が干してある。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時もこれからだとは言へ、理智のつぎはぎ、感情のこねくり、そんなものには目もくれないのだ。",
              "citation": {
                "source": "風は草木にささやいた",
                "author": "風は草木にささやいた",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは竈の下から火のついてる麁朶を一つとつて手ランプを點けて上り框の柱へ懸けた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「寒かあんめえな」おつぎは事もなげにいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは默つて草履を脱棄てゝ座敷へ駈けあがつて、戸棚から小さな古い新聞紙の袋を探し出して、自分の手の平へ少し砂糖をつまみ出して「そら／＼」といひながら、手を出して待つて居る與吉へ遺つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは砂糖の附いた自分の手を嘗めた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは粘り氣のない麥の勝つたぽろ／＼な飯を鍋へ入れた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは鍋を卸して茶釜を懸けた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほうつと白く蒸氣の立つ鍋の中をお玉杓子で二三｜度掻き立てゝおつぎは又葢をした。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは戸棚から膳を出して上り框へ置いた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱に點けてある手ランプの光が屆かぬのでおつぎは手探りでして居る。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは冷たくなつた時鍋のと換てやつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは庭先の井戸端へ出て鍋へ一｜杯釣瓶の水をあけた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは默つて俵の側の手桶へ手を掛けて「此へも水入て置かなくつちやなんめえな」「さうすればえゝが大變だらえゝぞ」　お品がいひ切らぬうちにおつぎは庭へ出た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "お品の後へは下女が這入つたので、おつぎは其間待たねばならなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
