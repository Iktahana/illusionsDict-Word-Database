          "standard": [
            {
              "text": "キッチンをリフォームして、よく使うスパイスや小物を置ける便利な釣り棚を取り付けてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "狭い部屋の収納スペースを確保するために、壁の高い位置に自作の釣り棚を設置することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地震の揺れで釣り棚に置いていたグラスが落ちそうになり、慌ててキャッチした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あん子は押入の隅の方に入れてみたが、思ひ直して、釣り棚の新聞紙の下敷につき込んでみても、新聞は折々の包紙に用ひるので危ないと思ひ、さらに疊を起して床に入れようとしたが、母親が平常此處にお金を匿してゐるので見付かる心配があつた。",
              "citation": {
                "source": "神のない子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
