        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "閾に躓いて、も少しで見苦しく這いつくばうところだった。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "己に金を儲けさせてくれるものの前には這いつくばう。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "河野はそのまま土の上につくばうようにした。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七等官あたりなら、まだしも彼と相識になってくれるかも知れないが、もう勅任官の位を贏ち得たほどの人物だったら、おそらく、誰でも自分の足許に這いつくばうものに向って傲然として投げつける、あの侮蔑に充ちた眼差をなげることだろう。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "その紙の上に、つくばうような恰好で坂口の爺さんはかがみかかった。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "石田氏は窓框に両手をつき、這いつくばうような恰好で、火の燃えているほうを見あげ、「空襲でやられないで、いまごろになって焼けるのか。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは天を往く列車であり、それにくらべれば地上を這いつくばうちっぽけな列車は槍の穂の芒にすぎない。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
