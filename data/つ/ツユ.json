  {
    "uuid": "62636a7c-145b-5924-afae-8adcdc567465",
    "entry": "梅雨",
    "reading": {
      "primary": "つゆ",
      "alternatives": [
        "ばいう"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(East Asian) rainy season (in Japan, usu. from early June to mid-July)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "戸外は――地面は半ば乾いてあつたかい、空を風は、目標ありげにとぶ、梅雨期の或る一日だ。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは非常に憂鬱で陰惨な、何か梅雨時のやうにジメジメした感じの唄である。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い妻の機嫌を取り、女房の尻に敷かれ、猥褻な性的遊戯をして日を暮す以外に、人生に向つて意欲する何の理想もなく野心もなく、無為劣等な動物的人生をすごすことが、現代大衆やサラリイマンの理想とすれば、これほど陰鬱な梅雨時の社会はない。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙燭して廊下通るや五月雨　降り続く梅雨季節。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の夏に特有な、梅雨時の暗い天気と、畳の上にカビが生えるような、じめじめした湿気と、そうした季節に、そうした薄暗い家の中で、陰影深く生活している人間の心境とが、句の表象する言葉の外周に書きこまれている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（すべての日本的な物は梅雨臭いのである）特に就中、自然と人生を一元的に見て、季節を詩の主題とする俳句の如き文学では、この影響が著しい。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気は梅雨で重たくしめり、地上は一面の桑畑である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうこうするうち日も移って、梅雨もすっかり明けた真夏の頃となりました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "空梅雨に代表的な天気で、今にも降り出しそうな空が不得要領に晴れ、太陽が照りつけるというよりはむしろ空気自身が白っぽく光り輝いているような天候であった。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃からもう梅雨だつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅雨時分になりますと、切花は駄目でございますわね……」と、武井さんは答へながら花立に※さつてゐた古い花を窓外に投げ捨てた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰氣だつた梅雨の日も忘れたやうに過ぎて、緑の深くなつた桐の葉に照る日光が急にギラギラと夏めいて來た、病室の中は暑苦しくなつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夜の雨が晴て空は薄雲の隙間から日影が洩ては居るものゝ梅雨季は爭はれず、天際は重い雨雲が被り重なつて居た。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅雨晴れのから風の強い日であって、番町へんいったいの木立ちの青葉が悩ましく揺れ騒いで白い葉裏をかえしていたのを覚えている。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨は暁方から又ひとしきり止んで、梅雨とは云っても夏の夜は早く白んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいにく少し降って来ました」「梅雨前ですからね」と、半七老人は欝陶しそうに空を見あげた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅雨が私を弱くしているのを知りました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体椎という樹は梅雨期に葉が赤くなるものなのでしょうか。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しなんと云っても堪らないのは梅雨期です。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際こんなときにこそ鬱陶しい梅雨の響きも面白さを添えるのだと思いました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああああ本道じゃ、何ね、この間の梅雨に水が出て、とてつもない川さ出来たでがすよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五｜月の上旬……とは言ふが、まだ梅雨には入らない。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いづこぞ夢の序樂のぽろねえず、會社は河岸に涙をひたし、花店の飾窓つゆにぬれたり、しばしまたつりがね鳴らむ、あさまだきにほふ葉影に、しろじろとかざし泳がせ、この列をなす少女らあゆむ。",
              "citation": {
                "source": "若き尼たちの歩む路",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "祕佛萩原朔太郎つゆしものうれひはきえず、わづかなるつちをふむとて、あなうらをやぶらせたまふ。",
              "citation": {
                "source": "祕佛",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレ御つゆがこぼれますよ」と云う一方では年かさの姪が小さいのにオッキイ御口をさせている。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日影うらうらと霞みて朝つゆ花びらに重く、風もがな蝴蝶の睡り覺ましたきほど、靜かなる朝の景色、甚之助子供ごヽろにも浮き立て、何時より早く庭にかけ下りれば、若樣、と隙かさず呼びて、笑顏をまづ見する庭男に、其まヽ縋りて箒木の手を動かせず、吾助お前は畫がかけるかと突然に問ふ可笑しさ。",
              "citation": {
                "source": "曉月夜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "腋よりは蟋蟀の足めきたる肱現われつ、わなわなと戦慄いつつゆけり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリオンは高く　うたい　つゆとしもとを　おとす、　アンドロメダの　くもは　さかなのくちの　かたち。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふとその鼻頭をねらいて手をふれしに空を捻りて、うつくしき人は雛のごとく顔の筋ひとつゆるみもせざりき。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨は大きいからだをひとつゆすつた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
