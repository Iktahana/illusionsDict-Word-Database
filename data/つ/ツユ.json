[
  {
    "uuid": "4281ba1e-d681-5c99-b02e-d976d2e6af0e",
    "entry": "露",
    "reading": {
      "primary": "つゆ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
