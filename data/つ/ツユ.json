      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dew",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔このみちの醸すがごとく〕宮沢賢治このみちの醸すがごとく粟葉などひかりいでしはひがしなる山彙の上に黄なる月いざよへるなり夏の草山とになひてやうやくに人ら帰るをなにをかもわがかなしまんすゝきの葉露をおとせり",
              "citation": {
                "source": "〔このみちの醸すがごとく〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "感情といふ語の内容も色々であらうが、「独り居て怡しむ」底の感情、対人的に発露するに非ざる、そこはかとなき欣怡の情である。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "東郷提督の命令一下で、露国のバルチック艦隊を一挙に撃滅なさるための、大激戦の最中だったのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "郊外の道が、シツトリ夜露に湿つてゐた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正九年、露細亜詩人ベールィの作を雑誌で見かけて破格語法なぞといふことは、随分先から行はれてゐることなんだなと安心す。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏草が生ひ茂つて、出たばかりの朝日は露にキラキラ光つてゐた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その裏の高くなつて赫土の露き出しになつてゐる所は、削け方まで昔のまゝであるのにはなんだか異様な気持がした。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして祖母の表情が余り露骨だから父もそれを知つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろこの二つの文学は、彼のあらゆる作品的欠点を無恥に曝露したものだと思ふ。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「侏儒の言葉」は、言はば頭脳の機智だけで――しかも機智を誇るために――書いた文学で才人としての彼の病所と欠点とを、露骨に出したやうな文学であつたが、同じやうにまた彼の俳句も、その末梢神経的の凝り性と趣味性とを、文学的ヂレツタンチズムの衒気で露出したやうなものであつた。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "人目を忍び、露見を恐れ、絶えずびくびくとして逃げ回っている犯罪者の心理は、早く既に、子供の時の僕が経験して居た。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかつき覺めにけり菊の露",
              "citation": {
                "source": "秋の日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の露国海軍のブルータルな勢力の圧迫が若い頭に何かしら強い印銘を与えていたかもしれない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "露伴の妹などは一時評判であったがやはり駄目だと云う事だ。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空よく晴れて朝風やゝ肌寒く露の小萩のみだれを吹いて葉鶏頭の色鮮やかに穂先おおかた黄ばみたる田面を見渡す。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉の家で普請をしていた時に、田舎から呼寄せられて離屋に宿泊していた大工の杢さんからも色々の話を聞かされたがこれにはずいぶん露骨な性的描写が入交じっていたが、重兵衛さんの場合には、聴衆の大部分が自分の子供であったためにそういう材料はことさらに用心して避けたものと思われる。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の初節句、結婚の披露、還暦の祝い、そういう機会はすべて村のバッカスにささげられる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝はこの椎茸が恐ろしく長くて、露にしめった道傍の草の上を大蛇のようにうねって行く。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜露にしめつた秋草の葉は月の光で青白くキラキラ光つて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬は、それぞれ、その飼ひ主の氣質を餘すところなく暴露してゐるものでありますが、ご近所の惡口は言ひますまい。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか、その何某先生が鬼のやうな醜惡の才能を持つてゐるといふ事實を暴露し、以て世人に警告を發するつもりで、その案内欄に鬼才などといふ怪しむべき奇妙な言葉を使用したのでもあるまい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それもまた乙姫の尊嚴を維持するために作られたもので、雨露を防ぐためのものではありません。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞音曲も別段客をもてなさうといふ露骨な意圖でもつて行はれるのではない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとも、この娘の「可哀想」は、このごろの彼女の一つ覺えで、何を見ても「可哀想」を連發し、以て子に甘い母の稱讚を得ようといふ下心が露骨に見え透いてゐるのであるから、格別おどろくには當らない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山頂では狸と兎が朝露を全身に浴びながら、せつせと柴を刈つてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸は素早くそれを顏に塗らうとしたので兎は驚き、そんな事でこの藥の正體が暴露してはかなはぬと、狸の手を遮り、「あ、それはいけません。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と兎は言ひ、ひどく露骨にいやな顏をした。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」などと言へば、少し大袈裟で、中學生のセンチメンタルな露惡趣味になつてしまふが、私が旅に出て風景にも人情にも、あまり動かされたことのないのは、その土地の人間の生活が、すぐに、わかつてしまふからであらう。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時あたかも日露大戰の最中であります。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いづこぞ夢の序樂のぽろねえず、會社は河岸に涙をひたし、花店の飾窓つゆにぬれたり、しばしまたつりがね鳴らむ、あさまだきにほふ葉影に、しろじろとかざし泳がせ、この列をなす少女らあゆむ。",
              "citation": {
                "source": "若き尼たちの歩む路",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
