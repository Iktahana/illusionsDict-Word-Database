          "literary": [
            {
              "text": "」　鉄橋のこっち岸の石垣を積み直すのだ。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、網をすつかり順序よく舟に積み直すと、源吉は自分で舟を漕いで、勝に、網を下してもらふことにした。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ卯女も、今しがた睡りから覚めた幼児が崩れた積木を積み直すやうに、自分の世界を組み立ててをりますとだけ申上げませう。",
              "citation": {
                "source": "恢復期",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちはそれをまた下から積み直す。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
