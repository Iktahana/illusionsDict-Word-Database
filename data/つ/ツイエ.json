    "definitions": [
      {
        "index": 1,
        "gloss": "wasteful expenses",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……無駄と知りながら出て来ます、へい、油費えでさ。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしむかし棄老国と号ばれたる国ありて、其国に住めるものは、自己が父母の老い衰へて物の役にも立たずなれば、老人は国の費えなりとて遠き山の奥野の末なんどに駆り棄つるを恒例とし、また一国の常法となしゐけるが、ここに一人の孝心深き大臣ありけり。",
              "citation": {
                "source": "印度の古話",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……菜大根、茄子などは料理に醤油が費え、だという倹約で、葱、韮、大蒜、辣薤と申す五｜薀の類を、空地中に、植え込んで、塩で弁ずるのでございまして。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにて魯西亜より帰り来んまでの費えをば支えつべし。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんややたらに養嗣系図買いなどの行わるる国と来ては、いわゆるゆかりばかりの末の藤原で、日本人の子孫に相違ないと言い張り得れば足り、猿田彦の子孫鷺坂伴内の後裔と議論したって真の詞費えじゃ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう貴公なぞと相手するのも役儀の費えじゃッ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "乞食などは国土の費えである。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、日の短けえのに手間費えをさせて済みません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三河万歳",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛を春買つて秋賣るといふのは、牛耕を必要としない冬から春の間、牛をただ遊ばせて食はして置くその費えを省くためといふよりは、一に現金を得たいがためにすることにほかならなかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし松枝が来て手伝うとしても、いろいろ面倒なことの生ずるのを避けるため、少しぐらいの費えはあってもその方がよかろう。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から思えば実に残念なわけですが、当時一方には自暴自棄になり、一方若いのに少しばかり自由に金が費えるようになつたものですから、私は日夜酒色に耽るようになつてしまいました。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うにこの一句、これを各戸の食堂の壁に題することを得ば、恐らく天下無用の費えを節する少なからざるべし。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言ったところで大して時間も場所も費えることではない。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私がそれを買い取って、面倒や費えを無くして差しあげようと言ってるんですよ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、貧民救済のために慈善団体の設立をもくろみ、相当巨額の金を集めると、さっそく我々はこうした美挙を記念するために、市の高位高官連を残らず午餐会に招待する、無論それで集めた拠金の大半は費えてしまい、残りの半分では、取りあえず委員会用に、暖房装置と守衛のついた堂々たる家を借りる。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "この商売をなすには莫大の費えなれども、政府には米もなく金もなきゆえ、百姓・町人より年貢・運上を出だして政府の勝手方を賄わんと、双方一致のうえ相談を取り極めたり。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "学塾に入りて修業するには一年の費え百円に過ぎず、三年の間に三百円の元入れを卸し、すなわち一月に五、七十円の利益を得るは、洋学生の商売なり。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに幼少な子たちさえおありになるあなたの御家庭が、なかなか費えのある事を思わず、またそうした苦悩をしのんでも、志した道に精進して、婦人の覚醒に力をつくされる、社会的な、広義な愛を――新人の味わう悲痛を知ろうとしないのに、憎らしささえ覚えました。",
              "citation": {
                "source": "平塚明子（らいてう）",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人や園子が自分事のようにおしもを世話しているのも不快なことだったし、何にもまして、無駄な費えが気にいらないのだった。",
              "citation": {
                "source": "女心拾遺",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、幕府は間もなく喫煙をもって無益の費えとなし、失火の原因となり、煙草の植附けは田畑を荒すなど種々の弊害あるものとして、これを禁止するに至った。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに其俸給は一番高い、幾千と云ふ年俸を取つて居るさうだが、隨分無駄な話で、國の費えでは無いか』と言つた。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにその俸給は一番高い、幾千という年俸を取っているそうだが、随分無駄な話で、国の費えではないか」と言った。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガスの不経済ばかりでなく、湯わかしがいたむばかりでなく、手間もそれだけ費えるわけになります。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しく仕立てればそれだけ費え、無駄な費用はかけない方がよろしい。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いやいやそんな段ではございません、その公方さま花の御所の御造営には甍に珠玉を飾り金銀をちりばめ、その費え六十万｜緡と申し伝えておりますし、また義政公御母君｜御台所の住まいなされる高倉の御所の腰障子は、一間の値い二万｜銭とやら申します。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、五山の衆徒に申し下されて、四条五条の橋の上にて大｜施餓鬼を執行せしめられましたところ、公儀よりは一紙半銭の御喜捨もなく、費えは悉く僧徒衆の肩にかかり、相国寺のみにても二百貫文を背負い込んだとやら。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いやいやそんな段ではございません、その公方さま花の御所の御造営には甍に珠玉を飾り金銀をちりばめ、その費え六十万｜緡と申し伝へてをりますし、また義政公御母君｜御台所の住まひなされる高倉の御所の腰障子は、一間の値ひ二万｜銭とやら申します。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "生の母ならで定に知るものあらんや、哀れとおぼさずや」翁は老夫婦が連れし七歳ばかりの孫とも思わるる児を見かえりつついえり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどそはかならずよく燃ゆとこの群の年かさなる子、己のが力にあまるほどの太き丸太を置きつついえり。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "有難迷惑の好意についても一ついえば、某外国に一百六十歳近い長寿者がありました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
