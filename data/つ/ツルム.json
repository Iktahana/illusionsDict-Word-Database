    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to copulate (animals)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鰌は一時に相つるむ、如何なる波も狂へる彼らを離すことなし、歓楽あまらば彼らはおのづと解けむ。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "西日して潮満つるまの夕干潟営み長く蟹ぞつぶやく夕凪の干潟まぶしみ生貝や弥勒むく子の額髪にして西日には蟶むきて居るならし後姿気ぶかき四五の女童女童や我は思へば額髪のかぐろき瞳｜此方見あげつ潮くさき突堤に沁むる夏西日音あわて落つるむつごろ影あり註、沖端にては突堤をうろこと云ふ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
