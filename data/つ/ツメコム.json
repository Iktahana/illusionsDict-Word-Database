    "definitions": [
      {
        "index": 1,
        "gloss": "to cram",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また片方の尖っている方が親鳥の腹の下へ沢山詰め込むのに都合がよいからだという説もある。",
              "citation": {
                "source": "卵の形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "試験さえすめば数カ月後には大丈夫綺麗に忘れてしまうような、また忘れて然るべきような事を、何年もかかって詰め込む必要はない。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際に大汗をかいて長い時間を費やした後に、やっと無理やりに詰め込む事が出来たのであった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "事がらによってはかえって一時に詰め込むよりも適当に小切ったほうが理解にも記憶にも有効であるという事は実験心理学者の認めるところである。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわれわれ初心の者が連句を作る際に往々一句の長句あるいは短句の内にあまりたくさんの材料を詰め込むためにかえって連句の体を失し、その結果付け句を困難ならしめることがあるのは、畢竟俳句と連句との区別を忘れるためであると感じることがしばしばある。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスマスの用意に鵞鳥をつかまえてひざの間にはさんで首っ玉をつかまえて無理に開かせた嘴の中へ五穀をぎゅうぎゅう詰め込む。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場合にはいやがる書物をぎゅうぎゅう詰め込むのもまたやむを得ないことであろう。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十人十色の才能を見分ける事をせずに、一列一体の学課を詰め込む主義の今の教育法は、一層この悩みを深刻にする。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙袋へ詰め込む者もある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはどういふことであるかといふと、兩方の耳に大きな綿を出來るだけ固く詰め込むのである。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり科學的にいつて、船醉は船の中に於て發するところの特別の振動音によつて起るのだといふ見解に基き、この振動音を内耳の或る器官に達せしめない爲に、耳の中に今述べた通り固く綿を詰め込むのである。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、今夜は出来るだけ詰め込むんだぞ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしても私は、色々な学説を頭の中に詰め込むことの煩雑さに堪えかねて、大学を卒業したならば、一日も早く人工心臓の発明を完成したいと思いました。",
              "citation": {
                "source": "人工心臓",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "）、とかく貧乏人の胃袋は大きい、ルンペンは殆んど例外なしに胃拡張的だ、私は自分でも驚くほど大食だ、白飯をぞんぶんに詰め込むと年寄にはもたれ気味になるが、大麦飯（米麦半々）ならば腹いつぱい食べてもあまり徹へないのである、あゝ食べることはあまりに痛切だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば白なら白と云う属性の概念があって、白墨、白紙、白旗、雪などという出来上ったもののうちから白と云う属性だけを引き抜いてこの概念の下に詰め込むのが至当でありましょう。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋人はいい加減に誤魔化してしまうが、日本人は、日本人らしい丹念さから、細かい隙間まで利用して実に能率的に詰め込む。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーリキイは主人が家具、敷物、鏡その他に執着し、こせこせとそれらを自分の家の中に詰め込むのが厭わしかった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　先づ必要なことは、哲學に關する種々の知識を詰め込むことではなくて、哲學的精神に觸れることである。",
              "citation": {
                "source": "哲學はどう學んでゆくか",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭がグラグラして来らあ……腸詰でもなけれあ、扁平麺麭でもねえ、生きた人間を袋へ詰め込むなんて！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "千鶴子の送別会も昼間の疲れでお流れになったままドームへよると、ここはいつもより人が立て込んでいて、どの部屋も満員だったがようやく詰め込む席を探してお茶を飲んだ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に交わっても、その短所のみを見、ここが心に叶わぬとか、あの風が気にくわぬとかいう、弱点のみを心の奥にある葛籠に詰め込むか、あるいは善良なる観察と思想を入るるかは、精神の持ちよういかんによってできるものと信ずる。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は斯うして新らしい所へ行つて、新らしい物に接するのが、用向の成否に關はらず、今迄眼に付かずに過ぎた活きた世界の斷片を頭へ詰め込む樣な氣がして何となく愉快であつた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "小山も深く感激しけん「お登和さん、私は学校にいた時分から他の人よりも余計に色々な智識を蓄える事が好きで、歴史上の智識でも文学上の智識でも科学上の智識でも何でも頭へ詰め込む方でしたが今になってみるとまだまだ実用の智識は一向蓄えてない事を悟ります。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "プデン型へバターを塗って先ず今のパンを一側並べてその上へ菓物を一側置いてまたパンを並べて菓物を置いて三段か四段にして一番上にパンを並べて固く詰め込むようにします。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの大きい軸がモートルに接がるベルトで廻されると、廻転が次の軸に移って、また別のベルトが廻り、そのベルトは又更に次の機構を動かして、それが板を切るべきは切り、釘をうつべきはうち、ビールを詰め込むべきは詰めこんで、一番出口に近いところにすっかり納ったビールの大箱が現われるのだった。",
              "citation": {
                "source": "地獄街道",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、出来るだけ僅かの宅の中に子供等を詰め込む事が必要だつた。",
              "citation": {
                "source": "子供の保護",
                "author": "エマ・ゴオルドマン",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、やってみると、土をいじるとか、絵を描くとか、窯に詰め込むとかいう技法上のことは案ずるより産むが易かった。",
              "citation": {
                "source": "なぜ作陶を志したか",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノートル・ダムや藁まみれの聖人像の近傍にたとへ異様な聖物はごろごろし過ぎてゐようとも、蠅は旅籠屋や牛小舎に結構な匂ひを漂はし日の当つた床からは蝋を鱈腹詰め込むのだ。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しかし、彼女が腹に詰め込むのは、脂肪にはならないで、みんな乳になる。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄貴のフェリックスは、しこたま草を引き抜いて、そいつを頭の上に被り、さかんに口の中へ詰め込むふりをする。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
