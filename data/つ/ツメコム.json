[
  {
    "uuid": "fdf483de-a301-57b9-ab24-46585f10beb9",
    "entry": "詰め込む",
    "reading": {
      "primary": "つめこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
