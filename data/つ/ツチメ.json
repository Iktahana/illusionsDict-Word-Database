        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「よし、とつちめてやらう。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とつちめるつもりはないのである。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺屹度停車場でとつちめて見せるから」　けれどもおんつぁんはたうとう勃凸をまいて東京に出て来てしまつたのだ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑ぢや逃げ出す、追つかけて取つちめろ、お婆も好きだよ、お若いの。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おつぎみんなでも嘗めさせろ、さうして汝も嘗めつちめえ、おとつゝあ稼えで來たから汝等も此れからよかんべえ」卯平はいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「持つてたら、やつちめえ」「厭だよう、おとつゝあに打ん擲られつから、おとつゝあ勘辨してくろよう」と歔欷くやうな假聲が更に聞えた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「其げよこしつちめえ」おつぎは小さな聲でいつて尻目に掛けた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さう云つちめえばさうだがなよ、そんだつて同胞に一噺もねえなんて後で文句云はれても、默つてちやおめえ口が開けめえな、そんだから俺らおめえげ耳打して置くべと思つたんだな」「俺ら何も不服いふ席はねえな」勘次は少し安心したらしく、恁う輕くいひ退けた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあに辛抱しらんねえやうな女ならわしうつちやつちめえまさあ」「それでは私がお安を使つておすがを呼び出すやうにしてやるから其の時今いつたやうな手筈にしたがいゝ。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな晩に東京から、飛び出して来て、旦那をとつちめるなんて、理窟のねえ事をするのだから、始末に了へねえや。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ひとつ探し出して、取つちめてやりてえな。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　子供は狸をとつちめるやうな積りで、強く尻つ辺を叩きつけた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "会つて何とかとつちめるつもりなのだろう。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの角度からながめても、林田をとつちめる方法が見つからない。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故郷の家の傾斜の急な高い茅葺屋根から、三尺餘も積んだ雪のかたまりがドーツと轟然とした地響を立てて頽れ落ちる物恐ろしい光景が、そして子供が下敷になつた怖ろしい幻影に取つちめられて、無意識に叫び聲をあげた。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、明日はどんなことがあつてもズヴェルコフの持家へ出向いて、フィデリをとつちめて、まんがよければ、メッヂイの書いた手紙を殘らず押收してこまさにやならん。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうだい、今夜はひとつ、あの村長をうまく取つちめてやらうと思ふんだが？",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　さつきから机には向つてゐるものの、しやうがないので、二三日前に買つてきた Insel 版のゲエテ詩集をあつちこつちめくつてゐる許りである。",
              "citation": {
                "source": "「浴泉記」など",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポン公は、お爺さんがターマンをとつちめないのが、しやくにさはりました。",
              "citation": {
                "source": "シロ・クロ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつがどんなに用心してゐようと、とつちめずには置きません。",
              "citation": {
                "source": "帽子箱の話",
                "author": "スティーヴンスン",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは、七段二人腕を揃へて都合十四段のおいでからに、強豪犬養をとつちめに来よつたかと思つた。",
              "citation": {
                "source": "呉清源",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "声はだいたい覚えてゐるから、いつかとつちめてやらうと思つてるがね。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらお父つアんも何處サでも行つちめえ。",
              "citation": {
                "source": "旱天實景",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めのうちは気がつかなかつたが、やがてみんなが変だと思ひだして、そつちを振り向いて見た頃には、砂利場へ下りる坂の上に、真黒に焼けた半裸体をてらてらさせた台湾人の子供が、十二三人もずらりと並んで、朱い唇できいきい叫びながら、歯をむき出して、盛んにこつちめがけて石を投げてゐるのだつた。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云ふのは、ちやうど此の二三日小鰺の二杯酢の一件が福子の胸につかへてゐて、一遍亭主を取つちめてやらうと考へてゐた矢先だつたのである。",
              "citation": {
                "source": "猫と庄造と二人のをんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お玉――殺されたに違ひない、あの美しいお玉の兄の清三郎が斯んな氣になつては、武家の『斬捨御免』を、とつちめる氣で來た平次も、陣の立て直しやうはありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "蹄の跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前にとつちめられたのは、飛んだ罪亡しかも知れまいよ、――ところで、蘭法のお醫者はどうした」「それなら、奧に居ますよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "花見の留守",
                "note": "青空文庫"
              }
            },
            {
              "text": "田代屋の若旦那が錢形の親分にお願ひして、親父の片腕を無くさせた相手を取つちめて下さいつて、拜むやうに言ひましたぜ」「多寡が子供の玩具の吹矢なら、洗ひ立てして、反つて氣の毒なことになりはしないか」　錢形の平次は、容易に動く樣子もありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "南蠻祕法箋",
                "note": "青空文庫"
              }
            },
            {
              "text": "惡戯者を取つちめて、キユウキユウ言はせなきや、この平次の心持が納まりません」「では、平次殿」「參りませう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "紅筆願文",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
