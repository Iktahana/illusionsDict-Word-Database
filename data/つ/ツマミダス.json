        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それが懐へ手を入れたかと思ふと、甘栗を一つつまみ出して、割るが早いか口へ入れる、口へ入れたと思ふと、又懐へ手を入れて、つまみ出すが早いか割つて食ふ。",
              "citation": {
                "source": "あの頃の自分の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほほう、これはどこにあった」「現場附近の笹木邸の塀の下です」「待て待て、これが弾丸に合うかどうか」と警部はやおら立って傍らの硝子函から弾丸をつまみ出すと薬莢に合わせてみた。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "チヨツキのカクシに指を突つ込んで、小銭をつまみ出す。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "消さないと、つまみ出すぞ」　人気は荒かった。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の命をつまみ出すやうにとらへてみせた手腕はさすがである、と私ならさうあつさりと見ておきたい。",
              "citation": {
                "source": "ケシの花",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの東風と云うのを音で読まれると大変気にするので」「はてね」と迷亭先生は金唐皮の煙草入から煙草をつまみ出す。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "迢空の身の動きの些細な事にも、私が煙草の箱からつまみ出すかさかさいう音の中にも、お互いの無言を知り尽したくらいである。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し今云った性格上の動機は、以下、少なくとも田辺哲学の内部的な論理構造の要領をつまみ出すのに有効だと信じる。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "寢轉んで讀書してゐる枕頭にお行儀よくおちんをしてゐる、叱つても逃げない、庭へつまみ出す、また這入つてくる、汚物をたれ流す、下女が怒る。",
              "citation": {
                "source": "ねこ",
                "author": "北村兼子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは内懐中から一枚の銀貨をつまみ出すと、やはり低い声で、「お困りでしょうに――これだけあるから使って下さい。",
              "citation": {
                "source": "幻影の都市",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその中の小箱から、音のしないように十銭白銅三枚をつまみ出すと、すぐまたこそこそと家を出て、肉屋のいるところへ走って来た。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして人差指と親指とで物をつまみ出す様に静かに器用に徐々と函の中をかき廻してスッと抜き出した指先にキラリと光るものがあった。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は片手を挙げるだけで大勢が僕をつまみ出す。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔭の者　初めは、つまみ出すつもりで来たものの、お袖も、お島と似たり寄ったりの、はぐれた女の生涯を歩いている。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまみ出すぞ」「おもしろい、私が、つまみ出されるかどうか、トム公、そこで見物しておいで」「あ。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "邪魔をすると承知しねえぞ」「ふざけた真似をおしでない、丹頂のお粂の家で埃を立てると、つまみ出すからそう思ッておいで」「生意気なことを！",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをつまみだすと、まだ缶の中に入っているものがある。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "昇龍丸が発見した海底の真珠貝は、貝殻も巨大であるが、真珠の含有率も甚だ良好であったのみならず、良質の真珠が多く、畑中の指が銀白色の真珠をつまみだすたびに、期せずして一同の口から歓声があがった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人だけであってくれればこれに越したことはないが、三人も四人もいると、いるだけの子供を候補者に指定して五歳になるのを待ち、子供の名を書いた紙を繭玉に封じこんで金ピカの甕に入れ、督弁政務使が象牙の箸で繭玉を一つつまみだす。",
              "citation": {
                "source": "新西遊記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人はいかにもコックらしく、白い上っ張りに前掛、頭にも白い茸形のコック帽をかぶっているし、二人の若い女給もきちんとエプロンをはおっているというふうで、客が酔って騒いだりすると、主人のコックが出て来てつまみだすといわれ、そのためかどうか、若い衆といわれる人たちは殆んどよりつかなかった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまでお玄関に立ちはだかっていると、つまみだすからそのつもりでおれ」「ちぇッ、ばかにしやがら」「こいつめ、まだでて失せぬかッ」「いまいましい！",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
