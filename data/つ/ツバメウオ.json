        "examples": {
          "standard": [
            {
              "text": "燕魚は成長するにつれて背鰭と尻鰭が長く伸び、独特の優雅な姿へと変化する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ダイビング中に、サンゴ礁の周りをゆっくりと泳ぐ燕魚の群れに遭遇した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "水族館の円柱水槽で、燕魚が縦長になって泳ぐ姿は来場者の目を引く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "flying fish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
