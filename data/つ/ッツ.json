        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども私は、そのころすべてにだらしなくなっていて、ほとんど私の身にくっついてしまったかのようにも思われていたその賢明な、怪我の少い身構えの法をさえ持ち堪えることができず、謂わば手放しで、節度のない恋をした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼黒い両頬が桃の実のようにむっつりふくれた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、本でも出して借金を全部かえしてしまって、それから三日三晩くらいぶっつづけにこんこんと眠りたいのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとも手むかいせずに、こっちの殴った手へべっとりくっついて来る」急に真剣そうに声をひそめて、「あいつ、菊の手を平気で握りしめたんだよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉毛を描いて眼鼻をくっつけ、そうして知らんふりをしていやがる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方を思い出すと必ず他方がくっついて一緒に出て来るのである。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然向うの家の板塀へ何か打っつけた音がしたと思うと一斉に駆け出してそれきり何処かへ行ってしまった。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その余威を駆って、と言っては不穏かもしれないが、自然派以外の作者たちは、たいていこの一派でやっつけられた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "俎上に載せられたのは、麗水、桂月、天随、花袋、孤雁及び私であったが、一番ほめられたのが花袋と桂月で、当たらずさわらずのところが麗水、孤雁、最も手ひどくやっつけられたのが天随と私で、ことに私はひどく攻撃せられた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっつけてやる、俺だけの苦しみじゃない、何十、何百、何万、何億の苦しみだ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "浚渫船の胴っ腹にくっついていた胴船の、船頭夫婦が、デッキの上で、朝飯を食っているのが見えた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は彼一流の方法で、やっつけるだけであった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてとりたての林檎のように張り切った小さな頬に、ハムマーのようにキッスを立て続けにぶっつけた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、世界中の「正義なる国家」が連盟して、ただ一つの「不正なる軍国主義的国家」を、やっつけている、船舶好況時代であったから、彼女は立ち上ったのだった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルッ、と手で顔を撫でると、全で凍傷の薬でも塗ったように、マシン油がベタベタ顔にくっついた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見ていたとき、私のすぐ右側の席にいた四十男がずっと居眠りをつづけて、なんべんとなくその汗臭い頭を私の右肩にぶっつけようぶっつけようとしていた。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから三味を弾く時には裏の皮を身体にくっつけては駄目な訳であろう。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに雪片がくっつき合っているのはつまり寒気がさほどひどくなくて雪片が温まっているからなので、ごくごく寒い摂氏零度以下二十余度にもなるともはや雪片に湿り気がなく従ってみんなバラバラに粉のようになってしまう。",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づいてよく見ると作り花がくっつけてあった。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも当人は平気でくっついて来る。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとうさん、大きなどんぐり、こいも／＼／＼／＼／＼みんな大きなどんぐり」と小さい泥だらけの指先で帽子の中に累々としたどんぐりの頭を一つ一つ突っつく。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中の島の岸杭がちょっと虫ばんだように腐ったところへ渡り鳥のふんらしい斑がぽっつり光る。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか島が又もとの岸とくっついてゐた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは書くのが面倒なのと、もひとつは現場ですぐ工作をする誰かの式を気取ったのと、さう二っつがおれを仕事着のまゝ支那の将軍のやうにその病院の二つの棟にはさまれた緑いろした中庭にテープを持って立たせたのだ。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だかわたしが、たった一人、居ずまゐ正してこゝに座り、やつらの仲間がかはるがはる、その二っつの小窓から、わたしを覗いてゐるやうだ。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもたしかに流れてゐたことは、二人の手首の、水にひたったとこが、少し水銀いろに浮いたやうに見え、その手首にぶっつかってできた波は、うつくしい燐光をあげて、ちらちらと燃えるやうに見えたのでもわかりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いえ、氷山にぶっつかって船が沈みましてね、わたしたちはこちらのお父さんが急な用で二ヶ月前一足さきに本国へお帰りになったのであとから発ったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがちゃうど十二日目、今日か昨日のあたりです、船が氷山にぶっつかって一ぺんに傾きもう沈みかけました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それからばらっばらっと栗の実が栗の木の幹にぶっつかったりはね落ちたりする音がしばらくしました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
