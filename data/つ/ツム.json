      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to become fine (of fabric)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "燃えるやうなる、二つの眼が光ってわれを見詰むるぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "燃えるようなる、二つの眼が光ってわれを見詰むるじゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「近う來い、申聞かすことあり、皆の者もこれへ參れ」と御聲懸に、御次に控へし面々も殘らず左右に相詰むる。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幅狭き布子の上掻を引張り合せて、膝小僧を押包み、煮染めたような手拭にて、汗を拭き拭き畏り、手をつきて美人の顔、じっと見詰むる眼に涙。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "欣弥　一別以来、三年、一千有余日、欣弥、身体、髪膚、食あり生命あるも、一にもって、貴女の御恩……白糸　（耳にも入らず、撫子を見詰む。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "分けて見詰むるばかり、現に見ゆるまで美しきは紫陽花なり。",
              "citation": {
                "source": "森の紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に／＼と問ひ詰むるに、黙然として答無し。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂木は投落されて横になつたが、死を極めて起返るより先に、これを見たか婦人の念力、袖の折目の正しきまで、下着は起きて、何となく、我を見詰むる風情である。",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "王手、王手で、そうして詰むにきまっている将棋である。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何なのでございますよ」　勢ひて問詰むれば、極めて事も無げに、「忘れません」　満枝は彼の面を絶に怨視て瞬も為ず、その時人声して闥は徐に啓きぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……唖々然々たる私はキヨトンとＫ君の顔を視詰むるより他は無かつた。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを充分見詰むることによつて多少とも今後によき文章が書けたならば難有いと思ふのである。",
              "citation": {
                "source": "樹木とその葉",
                "author": "跋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と何となく媚びるやうな瞳附で私の眼もとを見詰むる。",
              "citation": {
                "source": "姉妹",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤十郎、しばらく後姿を見詰むる）四郎五郎　（藤十郎の立ち出でたるを見て）今も、そなた様の噂をしてじゃ。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "只、程度が高いか低いかだけの違いで、煎じ詰むれば人間性の低級な表現に過ぎぬという事は誰しも認むるところであろう。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱時鐘を見詰むれば、針のコムパス、身の搾木。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づいて見ると、五分位に延びた漆黒の鬚髯が殆んど其平たい顔の全面を埋めて、空を見詰むる目は物凄くもギラ／＼する巨大なる洞穴の様だ。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "後の日を約して小走りに歸り行く男の影をつく／″＼見送りて、瀧口は枯木の如く立ちすくみ、何處ともなく見詰むる眼の光｜徒ならず。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "指に挟む筆は鉄の重味、書きさして見詰むる紙に水の光流る。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と決心せる如く機より立ち離れ、場の中央に立ちて下手の口の堅き鉄の扉を見詰む。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇の子に胎を裂かるる蛇の母そを冷くも「時」の見詰むる。",
              "citation": {
                "source": "産褥の記",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（乙、甲を物珍らしげに見詰む。",
              "citation": {
                "source": "一人舞台",
                "author": "ストリンドベルヒ　August Strindberg",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して其香気は梅花梨花の高淡なるにあらず、丁香薔薇の清凉なるにもあらず、将又百合の香の重く悩ましきにも似ざれば、人或はこれを以て隣家の厨に林檎を焼き蜂蜜を煮詰むる匂の漏来るものとなすべし。",
              "citation": {
                "source": "来青花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれ馬鹿女め、今に見よと、両の拳には、一心に青雲を握り詰むれど、これとて雲を握む話と、嘲られてはそれまでと、恥を忍び垢を含む一郎が無念無言を。",
              "citation": {
                "source": "誰が罪",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、北条氏の王将の府「鎌倉」だけが、いま詰むか詰まないかの境にある。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "空のもと林の中に、たゆけくも　仰ざまに眼をつむり、白き雲、汝が胸の上を流れもゆけば、　はてもなき平和の、汝がものとなるにあらずや",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつむいて、自分の靴の先のあたりを、じつと見つめてゐた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」笑って、そうして、美事に禿げて光っているおつむを、つるりと撫でた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして頭を屈めた際につむつた眼を、云ふことの出来ない表情で開くと、閉つた口をムニヤムニヤとさせた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "欅の並木をつつむ真昼の寒い霧。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
