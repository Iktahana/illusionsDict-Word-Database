        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "此の兄哥さん達が石松の女房の家を教えろって言うから連れて来たんだ」　と鶴吉、手先どもに、　「此処だよ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一緒に来いって言うから、こうして来ると、どこへ行っているんだか、まるで帰って来やしないじゃないか。",
              "citation": {
                "source": "街底の熔鉱炉",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一緒に来いって言うから、こうして一緒に来ると、どこへ行っているんだか、いつまで経ったっても帰って来やしないんだもの、全く呆れてしまう。",
              "citation": {
                "source": "街底の熔鉱炉",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、何かとそんな小理窟を並べたって、なあに、もともと遊びが好きなのさ、なまけ者の、助平の、身勝手な快楽児なのさ、とれいの牛太郎がせせら笑って言うかも知れません。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ　何だい、うまい物うまい物って言うから何を食うのかと思ったら、一膳飯屋へ行くのか。",
              "citation": {
                "source": "一利己主義者と友人との対話",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』って言うか『これでもくらえ』みたいな感じで非常にソウ快であった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "諺にも靴屋みたいな酔っぱらいって言うからなあ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さんの形見にって、うちの祖母さんが私に持って行けって言うから私持って行ったのよ」　たみちゃんの裁縫箱！",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――貞操を置き忘れたカメレオンのように、陽気で憂鬱で、……　すると、シイカがきゅうに、ちょうど食べていたネーブルを指さして、どうしてこれネーブルって言うか知ってて？",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百年の後ち、誰か或は私に代って言うかも知れぬ、孰れにしても死刑其者はなんでもない。",
              "citation": {
                "source": "死生",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "５「例のトランクを海へ捨てる心算だったって言うからね。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼飯の時に、池田は係長の鈴木に、「押野の方で、旧坑を掘り始めたって言うから見て来たいと思うんだけれど」と、言った。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やりはじめたって言うから、見に行こうじゃないか。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "池田は振り返えってみると、追いかけて来た別の坑夫が、「今わしの山の現場の衆が来て、一寸あなたに会いたいって言うから、来ておくんなさい」と言った。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "真紀　梅雨三十日って言うから。",
              "citation": {
                "source": "みごとな女",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "風邪は馬鹿にできないって言うからね。",
              "citation": {
                "source": "渡鳥いつかへる",
                "author": "軽演劇一幕四場",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、あの男の食事をするのを見ていたって言うかな。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "知り合いの百姓から買ったんですがね、大麦でふとらしたんだって言うから」「明日、天気が好けりゃいいがなあ」「風が北にまわりましたね」――フィリップは言う――「降るこたありません。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "本田　はばかりに行くからって言うから、まさかと信用して此方は待っていりゃ……あんまり遅いから出て来て見ると、このザマだ！",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「詳しいにもザツにも話しようがねえ、久し振りで湯に入りたいって言うから、湯銭だけ持たしてやると、フラリと出かけたっきり、今日で二日二た晩も帰らねえ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "江戸阿呆宮",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日も行かなきゃ、師匠の小唄お政が、迎えをよこすほどだって言うから、ワケだって大ありだろうよ」「嫌だね。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "小唄お政",
                "note": "青空文庫"
              }
            },
            {
              "text": "「痛いよ、何をするだよ」「菓子をどこへやった、それを言え」「坊っちゃんが中てられた菓子だって言うから、裏の埃溜へ捨ててしまっただよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "頓死か、怪我か」「それが怪しいんで――、昼飯の後で、大変な苦しみようだったと言うし、身体が斑になって、舌も眼も引釣ったって言うから、ことによればやられたかも知れません」「そいつは大変だ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "謎の鍵穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お神さんの殺された場所で、何か見るか聞くかしなかったかい」「旦那が大きな声で、灯を持って来いって言うから、棚の上の手燭へ灯を移して、大急ぎで飛んで行っただよ、何を聞くもんか」　これでは取り付く島もありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の精",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の身持は八百徳の主人が引受けるって言うから、差し当りそれを信用するとして、手前はソッと嫁入りの行列に蹤いて行って、一と晩見張っていさえすりゃいいんだ」「なるほど、こいつは、嫌な役目だ」「何だと、八」「智恵も銭も要らねえ代り大した辛抱役だ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "七人の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "（みんなで泊っていけって言うか知らん。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「五段や六段残したって仕様がないし、先方でも、出来るだけまとまった方がいいって言うからね。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "母さんが行かないって言うから、僕も行かないようっ。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "地べたを見るのは無礼だって言うから、顔を見てたんです。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十円だっていうから、俺、安いと思って買って来たのだ。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
