[
  {
    "uuid": "79d9ef49-16d5-52eb-aede-e5c565a66e77",
    "entry": "継ぎ足し",
    "reading": {
      "primary": "つぎたし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "addition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二十くらいもあろうかと思う六角の蜂窩の一つの管に継ぎ足しをしている最中であった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝋の継ぎ足しはあるにして、一時に燃すと翌方までの便がないので、手分けをするわけには行きません。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "外の人が一尺で継ぎ易える所を、あなたは僅か一寸か二寸の長さで細かに調子よく継ぎ足しては前へ進んで行くとしか形容出来ません。",
              "citation": {
                "source": "木下杢太郎著『唐草表紙』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいはいと寝惚け声で答えて、あたふた逸子が出て行く足音を聞きながら、鼈四郎は焜炉に炭を継ぎ足した。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "軌条は既に、石炭の積載に便利なように坑のほとんど入口まで引込んであった、それだから坑のすぐ縁まで線路を導くためには、我々は二三本の軌条を継ぎ足しさえすれば事が足りたようなわけである。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "継ぎ足しの軌条は剥取って遠くへ運び去った。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわく、最も不埒なるは、神殿、拝殿等、訓令の制限に合わぬ点を杉丸太で継ぎ足し、亜鉛葺き等一時｜弥縫をなし、いずれ改造する見込みなり、当分御看過を乞う等で、そのまま放置する。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "先の見通しもないまま、一方が継ぎ足し継ぎ足しでしかし実に元気良く増殖を続けてきたのに対し、もう一方は端正で優秀であるけれど何が飛び出してくるかわからない面白味には欠ける。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家はもとどんな人が建てたのだか、元来は矢張り百姓家らしいが、それから何代かの間を経てあちらに継ぎ足しこちらを造作して今日に及んでゐるらしい。",
              "citation": {
                "source": "村住居の秋",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かが篝りを継ぎ足したので、遠くの空が薄明るく見える。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく、注意して見ると、それは普通の婦人がするように、ネルの上に白木綿を継ぎ足してあるのですが、その白木綿が、鼠色に黒くなっているところへ、迸った血がかかったため、白木綿のところまでが、ネルの部分と同じように、汚れた桃色に見えていたのです。",
              "citation": {
                "source": "島原心中",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二の七　食事が済んでから、主客は又応接｜間に戻つて、話を始めたが、蝋燭を継ぎ足した様に、新らしい方へは急に火が移りさうにも見えなかつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五年もの長いあいだ、同じ軌道を走りつづけていた結婚生活を、不自然にもさらに他の女性で継ぎ足して行くことの煩わしさは解っていたが、加世子の位牌を取り片着けて間もなく、彼は檻の扉を開けたような気もしたのであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "あと二寸も余地があれば、縮図が纒まるのに残念なことやと思いますと、そのままでやめてしまうのが大変心残りに思われ出しまして、その晩帰宅して紙を継ぎ足して又その翌日その続きを写しにいったりしたことがあります。",
              "citation": {
                "source": "座右第一品",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、一人が扉のところへ近づいて更に薪を継ぎ足した。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "家では父の吐物がもう片付けられ、蒲団から乗り出した父の頭の下に別の蒲団も継ぎ足して敷いてあった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして改めて、少年の異様な贅沢な身装を見上げ見下していると、少年は暫く躊躇しているようであったが、やがて言葉を継ぎ足しながら低頭れた。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事が済んでから、主客は又応接間に戻って、話を始めたが、蝋燭を継ぎ足した様に、新らしい方へは急に火が移りそうにも見えなかった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのそら求友亭の横町にいらしってね、……」と亭主はまた言葉を継ぎ足した。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――小夜も喜んでいる」と後から継ぎ足したように一句を付け添えた。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二階は須永の書斎にするため、後から継ぎ足したので、風が強く吹く日には少し揺れる気味はあるが、ほかにこれと云って非の打ちようのない綺麗に明かな四畳六畳｜二間つづきの室であった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "御坊は「今出しましょう」と断って、レールを二本前の方に継ぎ足しておいて、鉄の環に似たものを二つ棺台の端にかけたかと思うと、いきなりがらがらという音と共に、かの形を成さない一塊の焼残が四人の立っている鼻の下へ出て来た。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "おイ、老爺や、探して来てくれないか、ちょッと往ッて」　自分が唐突に前後不揃いの言葉で頼んだのを、娘が継ぎ足して、始終を話して、「お気の毒だが見て来て」と丁寧に頼んだ。",
              "citation": {
                "source": "初恋",
                "author": "矢崎嵯峨の舎",
                "note": "青空文庫"
              }
            },
            {
              "text": "池部は俺が乗気なのを見て、また五十銭銀貨を取出して、酒の継ぎ足しをお久に頼んだ。",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　子供たちは、かってな理屈をつけて、さおにさおを継ぎ足して、どうかして高い木の枝までとどくようにしたいと苦心していました。",
              "citation": {
                "source": "おばあさんと黒ねこ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこの写真は色々細工がしてあって、不完全な結晶は継ぎ足したり、また乾板上で目的とする結晶の縁に沿って膜面を切り取って、印画紙に焼くと黒地に白く結晶が焼き出されるようにしたりしてある。",
              "citation": {
                "source": "雪の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　傍から首を出した妹を見てお世辞をつぎたした。",
              "citation": {
                "source": "木魚の配偶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒れ果てた家でどの硝子にも細いテープでつぎたしてあつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉ねぎさんと大根さんはすつかり困つてしまつて、にかわを買つて来て一本一本つぎたしました。",
              "citation": {
                "source": "髪床やの大根さん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれヒマの折にお経をつぎたしてあげるから、ゆっくり亡魂と語り合うのがよろしかろう」「ふざけやがんな。",
              "citation": {
                "source": "行雲流水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
