[
  {
    "uuid": "774d625a-f3e0-565c-828c-4d09bf17da3a",
    "entry": "強め",
    "reading": {
      "primary": "つよめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
