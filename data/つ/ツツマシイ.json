[
  {
    "uuid": "169e0665-9dce-5234-91da-2331832d8b63",
    "entry": "慎ましい",
    "reading": {
      "primary": "つつましい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
