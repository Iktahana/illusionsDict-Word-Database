    "definitions": [
      {
        "index": 1,
        "gloss": "monthly shift or duty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
