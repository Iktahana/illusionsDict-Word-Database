    "definitions": [
      {
        "index": 1,
        "gloss": "fertile shoot of field horsetail",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
