        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかもその魚籠のなかには四、五匹の大きい魚が月明かりに光っていた。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "白樺の林が月明かりに見えた。",
              "citation": {
                "source": "秋の暈",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて月明かりでもあるといいのだが、あいにくに今夜は闇だ。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "カールスルーエからはもうすっかり暗くなって、月明かりはあったが景色は見えなかった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前二時頃、私は窓際に腰掛けていて、外は月明かり以外まったく光がありません。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　言いながらよく見ると、女は色の丸顔の小作りで、まぶしそうに月明かりから顔をそむけた睫毛には白い露が光っていた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はまだ被衣を深くしているのを、千枝太郎は月明かりで覗きながら訊いた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "千枝太郎は玉藻のたましいを宿したその石を月明かりでしばらく眺めていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はいつも手拭を深くかぶっているので、一体どんな女だかよくわからなかったんですが、今夜こそはよく見とどけてやろうと思って、月明かりで手拭のなかを覗いてみると、いやどうもおどろきました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "月明かりにすかして見ると、赤黒いものが一すじ、汗ににじんで、左の小鬢から流れている。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "町をめぐる山々も、日中のほとぼりを返しているのであろう、おのずから頂きをおぼろげな月明かりにぼかしながら、どの峰も、じっと物を思ってでもいるように、うすい靄の上から、静かに荒廃した町を見おろしている――と、その中で、かすかに凌霄花のにおいがした。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一町二町月明かりの小路は、太郎の足の下で、急湍のように後ろへ流れた。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃてひっつかんで、月明かりにかざして見ると、このとおり生まれたばかりの赤子じゃ。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "月明かりに見れば、又しても例の変ったユニフォームを着た刑事だった。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十日あまりの月明かりであった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから先のことは、春木少年がお稲荷さんの崖の上から月明かりに見ていたとおりだった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "月明かりで　きらめく　切り分けナイフや　パイざら、　そして　よごれた　ゆかの　おくに　むかって　光の道が　できていました。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には、村の客間で家族がみんな引っこむまで居のこったあとで、森にかえり、翌日の食事にしようという気もあって、月明かりの深夜の数時間をボートで魚釣りをすることにすごした。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "月明かりで見ると、土蔵に穴が明いている。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人肌地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "話が一段落と見るや、平次はツイと座を立って、縁側の雨戸を一枚引あけ、水の如く入って来る月明かりの中に、ホッと太息を漏らしたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなりロープが月明かりの中、ひゅうっと飛んできて、その先についていたわっかがサンタクロースのからだにすっぽりはまって、ぎゅっとしめあげてしまいました。",
              "citation": {
                "source": "サンタクロースがさらわれちゃった！",
                "author": "A KIDNAPPED SANTA CLAUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "人通りのない月明かりをホテルへ帰る道すがら、噂のエロス・ポスターを横目に、奇妙な笑いを浮かべ、つぶやいた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲冑、絵画、鈍く光るオーク材に収まる姿見、曇り空の月明かり、値の付けられないお宝の数々、なかでもあちこちほっつき歩く暗く沈んだ人物は別格だった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "シルエットになっているユウカリプタスの並木の向こうに、牧草が月明かりに濡れていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハワイの夜の、青い月明かりについての歌を、彼らは演奏し始めた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その丸い張りぐあいを、月明かりのなかに強調させずにはおかないポーズだった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
