[
  {
    "uuid": "df20910f-5ad8-5c34-8132-494e29415eac",
    "entry": "つまみ上げる",
    "reading": {
      "primary": "つまみあげる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段"
      ],
      "ctype": null,
