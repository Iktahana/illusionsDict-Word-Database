        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "膚の細い、黄い石や、黒い石の上を辷ると、思いなしか、沈んだ、冴えた声をして、ついと通る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶺鴒が、もの忘れから気が注いたといった風に、石の上から、ついと飛ぶ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "土用が明けてまだ間もない秋の朝日はきらきらと大溝の水に映って、大きい麦藁とんぼが半七の鼻さきを掠めて低い練塀のなかへ流れるようについと飛び込んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいつだけは、いくら共産党狩りをやったって、どこまでもだにのように喰いついとるという話だな。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）剣は、切れるように、刃がついとんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや／＼、そこで、この際、皆が一ツにかたく結びついとくことが必要なんだ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろへ腰掛けてこぼこぼはっていく温い水へ足を入れていてついとろっとしたらなんだかぼくが稲になったような気がした。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光の棒もそのけむりのために青く見え、またそのけむりはいろいろなかたちになってついついとその光の棒の中を通って行くのでした。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、小さなすきとおる渦巻きのようなものが、ついついと、のぼったりおりたりしているのでした。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（世話が焼けることねえ、）　婦人は投げるようにいって草履を突かけて土間へついと出る。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つかまえようとするとついと逃げる。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花園の側に行くとその受持ちをしているファニーが花の中からついと出てきて私たちをさしまねいた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "慧鶴は堪らなくなって、ついと立ち上った。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれえ、」　と叫んで、ついと退く、ト脛が白く、横町の暗に消えた。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "拙が、と拔衣紋に成つて、オホン、と膝をついと撫でて、反る。",
              "citation": {
                "source": "麥搗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりたけまあ大事にして、ものを見ないようにする方が可いっていうもんだから、ここはちょうど人通の少い処、密と目を塞いで探って来たので、ついとんだ羂に蹈込んださ、意気地はないな、忌々しい。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白川をここまで誘びきよせておいて、ついと引つ離してしまつては彼の立場は全然失はれるであらう。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はそれをまぎらす為に、ついと立つて縁端へ出た。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はそれをまぎらす爲に、ついと立つて縁端へ出た。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と釣込まれたように、片袖を頬に当てて、取戻そうと差出す手から、ついと、あとじさりに離れた客は、手拭を人質のごとく、しかと取って、「気味の悪かったのは只今でしたな――この夜ふけに、しかも、ここから、唐突だろう。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と雫を切って、ついと出すと、他愛なさもあんまりな、目の色の変りよう、眦も屹となったれば、女房は気を打たれ、黙然でただ目を※る。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と膝を割って衝と手を突ッ込む、と水がさらさらと腕に搦んで、一来法師、さしつらりで、ついと退いた、影も溜らず。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「待てよ」　獲物を、と立って橋の詰へ寄って行く、とふわふわと着いて来て、板と蘆の根の行き逢った隅へ、足近く、ついと来たが、蟹の穴か、蘆の根か、ぶくぶく白泡が立ったのを、ひょい、と気なしに被ったらしい。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音楽は、この広間を大きな永遠の国からへだてている、まっ黒な、あついとばりのむこうから、ひびいてくるのでした。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　国仙和尚はそれだけいふと、ついと立つて奥へ行かうとした。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙がついついと頬をつたつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かしらが何もいわないさきに、子供はそういって、ついとそばに来て、赤い手綱をかしらの手にあずけました。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏は又箙を叩いてどよめきけり」と法師の節おもしろく語るのを皆まで聞かず、ついとお座をお立ちになつてしまひました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤皮縅は忠綱さまの御鎧、またその葦毛の馬は、相州さまから拝領の片淵と号する忠綱さま御自慢の名馬に相違ないのでございますから、もはや争論の余地も無く、将軍家は、興覚め顔に何事もおつしやらず、ついとお座を立つておしまひになりました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞおかまいなく、お引き取りを、と言うまでもなし……ついと尻を見せて、すたすたと廊下を行くのを、継児のような目つきで見ながら、抱き込むばかりに蓋を取ると、なるほど、二ぜんもり込みだけに汁がぽっちり、饂飩は白く乾いていた。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
