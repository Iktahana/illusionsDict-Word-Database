    "definitions": [
      {
        "index": 1,
        "gloss": "(bowel) movement",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もし相手がやはり詩人である場合は、随分容易に話が通じ、又互ひに利するのかも知れませんが、今の所私は、詩論といふものは殆んど無益だと諦め切つてゐる有様です。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに、とまれ、芸術が世界を通じて昨今衰微してゐることは争はれない所であらう。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "とは言へ、私たちが始めて会遇した主なる動機は、もちろん人間としての交りでなく、ただその芸術を通じての交歓であつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく、彼はその生涯を通じて、叙情詩以外の何物をも書かないであらう。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬や小鳥やの動物は、単に鼻を嗅ぎ合うとか、尾を振り合うとか、目をちょっと見合すとかいうだけで、相互の意志が完全に疎通するのに、人間は廻りくどく長たらしい会話をして、しかもなお容易に意志を通じ得ない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての物語は、夫人自身の主観的の感情や解釈を通じて、実感的に話されねばならなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近尾崎君は、私を通じて芥川君の人格につき知る所が多かつたのである。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども尚、自分は作品を通じて「眞の芥川君」「詩人としての芥川君」を見ようと努めた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に藤村氏の文學は、彼が詩を書かなくなつてからも、そのすべての小説作品を通じて、旺盛な詩的情熱で一貫して居る。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "意の在るところの一端は、諸兄にも通じたように思う。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "名辞の方が世間に通じよく、気が利いてみえればみえるだけ、芸術家は危期に在る。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの少数の作品を通じて、大体の趣味、傾向、句風等、及び俳句に対する氏の主観態度が、朧げながらも解らないことはない。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "塚も動け我が泣く声は秋の風　芭蕉の悲哀は、宇宙の無限大なコスモスに通じている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "してみればかうした翻訳を通じて、外国人の俳句から受け取る印象は、不可解以上に想像が出来ないと結論してゐる。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代女の「蜻蛉つり今日は何所まで行つたやら」「身に沁みる風や障子に指の跡」「朝顔につるべ取られて貰ひ水」等の句は、言葉のイメーヂやヴィジョンから来る詩趣でなくして、人情的な内容からくる興味を主としたものであるから、この種の句ならば、翻訳を通じて外人に理解させることが出来るのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや日本に居住することなく、日本の文学を全く読まず、日本に就いて知る所の殆んどない一般の欧米人が、宮森氏の訳を通じて、芭蕉等の俳句が解り得る道理はない。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく彼等が、翻訳を通じて「古池や」等の俳句から感ずるものは、「花の雲」の句を葬式の詩として感心した外国人と同じく、原句の詩趣とは全くちがつた別のヴィジョンに、彼等自身の主観した東洋的エキゾチシズムの幻像を画いたものであるだらう。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとも詩の特質は、各の主観的幻想をあたへることに存するのだから、訳詩を通じて、外国人が外国流に勝手なヴィジョンを構成し、勝手な主観的解釈をしたところで、一向に何の差支へもないわけであり、むしろ訳詩の本来の目的がそこに有るとも言へるのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故にボードレエルの訳を通じて、ポオの詩を読んでる人たちは、実にはボードレエルの詩を読んでるので、ポオを読んではないのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルマンは古典に通じていて、気象の講義にも色々古典の引用が出て来た。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルマン教授には三学期通じてずっと世話になって特別の優遇を受けたような気がしていた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地理のコロキウムはここで行われ、次の二学年を通じて聴いたペンクの一般地理学の講義もここの講堂で授けられた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芒の蓬々たるあれば萩の道に溢れんとする、さては芙蓉の白き紅なる、紫苑、女郎花、藤袴、釣鐘花、虎の尾、鶏頭、鳳仙花、水引の花さま／″＼に咲き乱れて、径その間に通じ、道傍に何々塚の立つなどあり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いにドイツ語はこの席の誰にも通じなかったのである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲んでみると名状の出来ぬ芳烈な香気が鼻と咽喉を通じて全身に漲るのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういうところが相通じているかは分析出来ませんが、何となくそう思われました。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "檀君の近業について太宰治　檀君の仕事の性格は、あまり人々に通じてゐない。",
              "citation": {
                "source": "檀君の近業について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに私は、自身が非力のせゐか、弱者の心理にはいささか通じてゐるつもりだが、どうも、強者の心理は、あまりつまびらかに知つてゐない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし直接に文通したのは、少しく金の入用があったので、白峰の紀行文を、花袋を通じて『太陽』に寄せたときが初めてであった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故逆廻りをしたかといえば、御中道は、前にも廻っているんだが、小御岳から御庭を通じて、大宮道へ出遇うまでの、森林の石楠花を見たかったのだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
