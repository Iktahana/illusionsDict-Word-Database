        "examples": {
          "standard": [
            {
              "text": "ダイビング中に、美しいサンゴ礁の周りをツマグロが泳いでいるのを見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "水族館の大きな水槽には、ツマグロが悠々と泳ぎ回っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ツマグロは比較的おとなしいサメで、人を襲うことは稀だと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "石畳の路上を横にそれようとする途端黒い人がつきあたった。",
              "citation": {
                "source": "小さき良心",
