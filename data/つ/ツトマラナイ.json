    "definitions": [
      {
        "index": 1,
        "gloss": "unfit for",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしまた同じ理由によって文字では到底勤まらない役目を映画によって仕遂げることが出来るのである。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへ外貌はどうあらうとも、性格氣質の底に西洋風なキリスト教や、ギリシャ思潮を傾向した人種でなければ、詩の輸入飜案者たる詩人の役目は勤まらない。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前さんは何にも知るまいけれど、どうせ、どうせ、姉の役ッきゃあ勤まらない私だけれど、姉だッて、よ、姉だッて、人に後指さされたり、ちっとでも、お前さんとこうやっていることの、邪魔になるような人が私に有っては厭だから、そりゃ随分出来にくい苦労もしたもの。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は自分が煮え切らないのをみて、もう自分や蝶子のいる学園には勤まらないから辞職をするとさえ無茶を言い出した。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しどう我慢をして見ても後幾年も勤まらないといふことを周圍の人も見て居るのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "益田の宿に着くから、今またこの停車場を辭し去るまで、こゝの驛長龜井君も暇さへあれば私達のやうな旅人を見に來てくれたが、これでなければ地方の驛長は勤まらないものかと感心した。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体これでは御用が勤まらないといっても好い。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし本当のことばかりを不作法にいう批評家があって、命をかけて抱いているその赤ん坊を一々おや鯛だね、おや狐でいらっしゃいます、お化けかと思ったというて歩いたら、まったくそれは一日も勤まらないところの仕事であるかも知れない。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "お化けかと思ったと申して歩いたら、全くそれは一日も勤まらない処の仕事であるかも知れない。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしたちの習った外国語じゃ家庭教師も勤まらないし、あたしたちの習った編物じゃ下宿代も満足に払われはしないわ。",
              "citation": {
                "source": "文放古",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が良いばかりでは勤まらない、食えない代物には相違あるまい。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、端役しか勤まらない俳優であつてもいゝ。",
              "citation": {
                "source": "端役",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一方に、探偵小説家というものは、こんなにまで科学的でなければ勤まらないものかと、或る種の疑惑が湧いてこないでもないのだった。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでないと折角のお役目が勤まらないから……」　艇長は、にっこり笑って肯いた。",
              "citation": {
                "source": "宇宙尖兵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな話に驚いてたら、この会社に勤まらないわ。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾て学校の窓で想像した種々の高尚な事を左様いつ迄も考へて、俗悪な趣味を嫌ひ避けるやうでは、一日たりとも地方の学校の校長は勤まらない。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "学問は好きだったから出来る方の組で、副級長などもやったことがあるが、何しろ欠席が多かったから、十分には勤まらない。",
              "citation": {
                "source": "こんにゃく売り",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "「默つて居ろ、醫者や易者の心得もなきや御用は勤まらないぞ」「へ――ツ」　八五郎は引つ込みのつかない樣子で突つ立ちました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "槍の折れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もその方は二年くらゐしか居なかつたやうで」「此家は番頭が長く勤まらないのだね」　平次は妙なところに氣が付きました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "十萬兩の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は師匠が勤まらないよ」「飛んでもない」「学があるだろう。",
              "citation": {
                "source": "心のアンテナ",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上の御用を勤めてゐる身體には、何時どんな用事があるかも知れないのに、一々嫉妬がましい事を言はれちや、御用が勤まらないといふものだ」「あれ、そんな積りぢや」「默つてお袋のところへ歸つてくれ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "平次女難",
                "note": "青空文庫"
              }
            },
            {
              "text": "「黙っていろ、医者や易者の心得もなきゃ御用は勤まらないぞ」「へ――ッ」　八五郎は引っ込みのつかない様子で突っ立ちました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "槍の折れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「解らねえ聟ぢやないか、三々九度は僞首ぢや勤まらないよ」　ガラツ八は後ろから抱きすくめるやうに、早桶の傍の座に錦太郎を引据ゑました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "ガラツ八祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上の御用を勤めている身体には、いつどんな用事があるかも知れないのに、いちいち嫉妬がましい事を言われちゃ、御用が勤まらないというものだ」「あれ、そんなつもりじゃ」「黙ってお袋のところへ帰ってくれ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次女難",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い新聞記者であった私はフトその部屋に居合わせて、あまりのことに腹を立て「お言葉だが、新聞記者は無学で不勉強かはしらないが馬鹿じゃ勤まらない、それより先に、代議士の資格試験をしたらどうだ」とやった。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "平次読む人読まぬ人――三人の政治家――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「解らねえ聟じゃないか、三三九度は偽首じゃ勤まらないよ」　ガラッ八は後ろから抱きすくめるように、早桶の傍の座に錦太郎を引据えました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "ガラッ八祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともその方は二年くらいしか居なかったようで」「この家は番頭が長く勤まらないのだね」　平次は妙なところに気が付きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "十万両の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二十五、六歳になって卒業の出来ないようなやくざ者は家禄の十分の八を除いて、生涯藩の役人が勤まらないことにしてあった。",
              "citation": {
                "source": "青年の天下",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の小節を幾つか歌った時から早くも、彼女にはその役が勤まらないことが明らかにわかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御しんさんに嫌われたらこの店には勤まらない」という風がどこかにある。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
