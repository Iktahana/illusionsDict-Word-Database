    "definitions": [
      {
        "index": 1,
        "gloss": "leather or cloth wrapped around the handle of a sword",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この薄ぎたない鮫の皮が玉のように白く美しい柄巻になろうとは、素人にちょっと思い付かないことであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて引っ返して来て、それはみな磨きの白い皮で、露月町の柄巻師から質に取ったものだと報告した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの手足がすこやかになったら、太刀の柄巻きしても、雀弓の矢を矧いでも、親子ふたりの口すぎには事欠くまい。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の日常の携帯品といえば、鍔無柄巻の小刀一本（一尺足らずのものである。",
              "citation": {
                "source": "五右衛門と新左",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長いもの、短いもの、黒、白、朱、螺鈿、いろいろな鞘と、柄巻、鍔――二百四五十本もあるであろうか。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "白鞘なので、斬り人は、仮鍔を入れ、白布で柄巻して、揮り被った。",
              "citation": {
                "source": "山浦清麿",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "床場の内では、弓の弦師、具足の修理、くさずりの縫工、研師、塗師、革裁ち、柄巻き、あらゆる部門の職人が見える。",
              "citation": {
                "source": "私本太平記",
                "author": "筑紫帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
