          "literary": [
            {
              "text": "此春より來慣れたる道なればにや、思はぬ方に迷ひ來しものかなと、無情かりし人に通ひたる昔忍ばれて、築垣の下に我知らず彳みける。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "立上りつゝ築垣の那方を見やれば、琴の音微かに聞ゆ。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "燒け殘りたる築垣の蔭より、屋方の跡を眺むれば、朱塗の中門のみ半殘りて、門もる人もなし。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
