    "definitions": [
      {
        "index": 1,
        "gloss": "pursuit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "婦人はとにもかくにも遣過せしが、又何とか思直しけん、遽に追行きて呼止めたり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、日本中心説も、陽根本位論も心熱を刹那主義的に追行しさへすれば、義雄の立脚地にぴツたり合致して來るのである。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "強烈孤獨の悲痛生活を自覺するものは、刹那の自己を、いつも、たとへば、「男女間の關係を最も極度に追行した時」の如く適切に感得してゐるといふこと。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕から見れば不自然な性格追行と時處の統一とは、之に拘束される文藝を導いて、客觀的枯空の状態に落入らしめるのである。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから司令艇クロガネ号へ連絡をとって、アシビキ号は修理完了、ただちに本隊に追行することを報告しろ」　噴行艇アシビキ号は、すぐ様、猛然と出発をした。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は娘の身の上を心配するについての曾ての焦立たしい気持ちに、再び取りつかれ、ついこういってしまった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗匠を張る時は紋着で巻莨、色と点取発句が一斉に出来るのであるから、ついこう下駄を懐に入れるような事にもなる。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが段々嬉しくなって、可愛らしくもなり、ついこういうことにもなったんだが、他愛なさも、仇気なさも、お肚を……可いかい、政府へ知れりゃ罪人だぜ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、うちへの手前、この着物は絶対に必要であるような気持ちがして、言っていいのか悪いか判然わからないうちに、ついこう口ばしってしまったのだ。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の平生からあまり小説を愛読しないのは、僕に小説中の人物になる資格が乏しいので、資格が乏しいのは、考え考えしてぐずつくせいだろうとかねがね思っていたから、僕はついこういう質問がかけて見たくなったのである。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の『釣り女』は面白かった、気球ロボット先生の天女釣りと一ついこうじゃないか、なんかと、千代次とふく子の手を執って立上りながら、踊りの真似ごとをやりだそうとする。",
              "citation": {
                "source": "慾",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じつはね、僕も酒さえ禁めると、田舎へ帰ったらまだ活きて行く余地もあろうかと思ってね……」　耕吉はついこうつけ加えたが、さすがに顔の赤くなるのを感じた。",
              "citation": {
                "source": "贋物",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやじさん、威勢よくひとついこう。",
              "citation": {
                "source": "在学理由",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ぼくは、いままで兄の泣いたのを見たことがなかったのと、もし出征すれば、おそらくふたたび見られないだろうと思っていたので、ついこうききました。",
              "citation": {
                "source": "兄の声",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ま、ひとついこう」　よっぽどの酒好きと見えて、伯水は高座着を着替える間も惜しいらしく、先ず膳の前へ座った。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "で正直に、「ヘイ」　ついこういうと、「……たべてえとおもったら……」　顎で二度三度肯いておいて、「早くお前、真打になんなよ」　だって――。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついこう呟かずにはいられなかった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "残念な事に名前を知らないのでついこう長くかいてしまった。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前｜直の性質が解ったかい」「解りません」　自分は兄の問の余りに厳格なため、ついこう簡単に答えてしまった。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前直の性質が解ったかい」「解りません」　自分は兄の問の余りに厳格なため、ついこう簡単に答えてしまった。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "誘き出されると知りながら、彼女はついこういって訊き返さなければならなかった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい僕は金持の家庭へ入った事もないし、またそんな人と交際った例もない男だから、ついこういう機会に、ちょっとでもいいから、会っておきたくなるのさ」「見世物じゃあるまいし」「いや単なる好奇心だ。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分のぞべぞべした絹の着物と青年の粗末な着物の対照からも、ついこう意識せずにはいられなかった。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この頃はね、外は寒いし、家にいても気分が捗々しくないので、ついこうやって炬燵にずくんだままで随分いろいろなことを考えて見ました。",
              "citation": {
                "source": "加護",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちらにゆかない日は、ついこうして話したくなります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしは知らない」　お銀様は、またしても、ついついこうあしらわねばならなくされました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにもそんなに固くなっていることはないじゃないか、さあ一ついこう、但し今夜は介抱はごめんだぜ」　こうして客のほうからしぜんと酒をすすめる。",
              "citation": {
                "source": "契りきぬ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九「どうしたの」と女が云った、「ちっともあがらないじゃないの、お口に合わないんですか」「おめえに一ついこう」「あたしだめなの」と女が云った、「このうちはやかましいのよ」　繁次は盃を出し、女は酌をした。",
              "citation": {
                "source": "落葉の隣り",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実は昨日の昼過に来る積りでホテルから電話をかけたんだが、京都へ往診に出て帰宅は晩いというもんだから、ついこう出発間際になったのさ」　とお父さんは弁解した。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里は、総見の切符殻と、帳面とを机において、算盤へ首をかしげていたが、額ごしに、露八の足を見て、「お坐りなさいな」「立っていたっていいだろう」　ついこう云いたくなるのであった。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
