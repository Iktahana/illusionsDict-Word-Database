    "definitions": [
      {
        "index": 1,
        "gloss": "to meet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "園に達すれば門前に集う車数知れず。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しぐれ降る頃には、裳羽服の津の上で少女男が往き集う歌垣が催された。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "受附にもどの口にも他に立集う人は一人もなかった。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この市に集うもの、すべて、むさぼりくらうこと豚のごとく、さかんなること狒狒のごとく、凡そわれに益するところあらむと願望するの情、この市に住むものたちより強きはない。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に踏み迷っても、ひとたび国難到来すれば、雛の親鳥の周囲に馳せ集うが如く、一切を捨てて皇室に帰一し奉る。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アグリパイナには乳房が無い、と宮廷に集う伊達男たちが囁き合った。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "緋の長襦袢が※と燃える、片身を火に焼いたように衝と汽車を出たその姿は、かえって露の滴るごとく、おめき集う群集は黒煙に似たのである。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "活計にせわしきにや、夜ごとに集う客の数も思い較ぶればいと少し。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "パラドールの間のこと、大家具屋の地下室に集う素人乞食団なる一流倶楽部のこと、英国帆船ソフィ・アンダソン号難破に関する真相のこと、ウーファー島のグライス・パタソン一味の奇譚のこと、〆はキャンバウェル毒殺事件のこと。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾多の星霜を経てはいるけれども、かしこの柳、ここの松、湯屋も古くからあるというし、寺の門前のは今もあたりの女の子が、打集うては遊んでいる、鞠唄も唄うている、廂、軒、土の色も有の儘。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニフティーサーブのボイジャーサロン（go smss1）に集う皆さん。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『易経（兌為沢卦・象伝）』の言葉で兌の卦を解くと、まず兌は志を同じくする朋が相集うことで、内卦の兌と外卦の兌とは志望風格共に相同じ、即ちこれ同志の朋友である。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀州田辺の紀の世和志と戯号した人が天保五年に書いた『弥生の磯』ちゅう写本に、厳島の社内は更なり、町内に鹿夥しく人馴れて遊ぶ、猴も屋根に来りて集う。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれに寄り集うた眼白鳥が非常に多い。",
              "citation": {
                "source": "樹木とその葉",
                "author": "伊豆西海岸の湯",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小山の上にも、麓にも、芝生の上にも、泉水の畔りにも、数奇を凝らした四阿の中にも、モーニングやフロックを着た紳士や、華美な裾模様を着た夫人や令嬢が、三々伍々打ち集うているのだった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "町もまたここから急に広く、繁華もまた城下第一と見え、随って旅人の群も虫の灯に集るごとくに自ずと集うらしく、両側は殆んど軒並と言っていい程の旅籠屋ばかりです。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "みなの衆にもその用意して社殿の裏に集うて貰うたのじゃ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブロッケンの山麓を目ざして群れ集うて行く長蛇である。",
              "citation": {
                "source": "変装綺譚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小山の上にも、麓にも、芝生の上にも、泉水の畔りにも、数奇を凝らした四阿の中にも、モーニングやフロックを着た紳士や、華美な裾模様を着た夫人や令嬢が、三々伍々打ち集うてゐるのだつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い空地に集うている子守の哀れな声で謳う唄の節が、胸に染みるようであった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "相場師の臨終の枕元に集うた甥や姪や縁者の人たちは、相場師が息を引き取つた後で貰つて行くべき、物品を、貪狼の如き眼をかゞやかして刻一刻と切迫して來る今際の餘喘の漂ふ室内の隅々までも見渡してゐた。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "西は服装も姿形もてんでばらばらな老若男女が集う会場の熱気の中で、あらためて趣味のおもちゃとしてではなく、人間の可能性を拡大する知恵の道具としてのパーソナルコンピューターに確信を強くした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二部　第六章　魂の兄弟、日電版アルト開発計画に集う一九八三　ＰＣ-１００の早すぎた誕生と死　一九八二（昭和五十七）年五月、西和彦が持ち込んだ二つの未来志向のプロジェクトを、日本電気は六月に入ってすぐに正式に受け入れた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二部　エピローグ　魂の兄弟、再び集う一九八三　Ｗｉｎｄｏｗｓの約束が果たされた日　スポットライトを浴びて闇の中から歩み出た西和彦は、聴衆の中のただ一人を求め、目を細めて視線を遊ばせた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、型の如く煤けた天井と、同じく煤けたシャンデリアで、それにはカットグラスが沢山ぶらさがっていて、給仕が型の如く、海辺に集う鳥の数ほど夥しい茶碗を載せた盆を、大胆に振り廻しながら擦りきれた油布の上を駈けまわるたんびに、跳ねあがったり、ちりんちりん音を立てたりする。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "場内はしんとして、夜間開場の設備はないので、広い会場の天井に只二ヶ所、うす暗い電燈が、鈍い光りを眠むそうに投げて、昼間満都の人気を集めて、看客の群れ集うだけ、それだけ人気のない会場は一層静かなものであった。",
              "citation": {
                "source": "真珠塔の秘密",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五城目の市日」といえば、昔から、この近郷の人々が寄り集う慣わしであった。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し人間は弱いものであるから、自分の労を多としまいと思つてゐても傲慢になり易いものであるから、そこで何か一つどうしても宗教に入るといふことが必要であると思つた。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人が道ばたの花園の青芝の縁に杖を垂直に立てて考えることには、「ヒヤシンスはとても喫むまいが、チュリップというやつはこいつどうも煙草を喫みそうな花だ。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「『カ』ちうとこへ行くの」「かつどうや」「活動や、活動やあ」と二三人の女の子がはやした。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
