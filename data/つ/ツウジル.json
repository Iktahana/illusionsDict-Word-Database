    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be open (to traffic)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これは、ブルジョアジーと、プロレタリアートとの間にも通じる。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "このだらしのない、子等に対して申し訳なく、相済まなく思つてゐる父の心が、そんな釣りの半日で子供の心に通じるかどうか、これは寧ろ逆効果でありはしないか。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると水銀が蒸発して管の中はこの蒸気が充ちその中を電流が通じるようになるから管を旧位置になおし水銀を一端に返しても電流は続いて通る、この時に水銀の蒸気は強い蒼い光を出す。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あざ笑ふ」の「あさ」は「あさみ笑ふ」の「あさ」かと思うがこれは (Skt.)√has に通じる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔ha_sita〕 は笑うべき事で「はしたない」に通じる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あさましい」はまた (Skt.)vismayas で「驚く」ほうにも通じるが、それよりも元の smi, smaya で微笑にもなる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに 〔(Skt.)ullasita_〕 が「うれしい」で (L.)jocus が「茶化す」に通じるのもおもしろい。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じわりじわり」に通じる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語の gnarl は「うなる」に通じる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「がなる」にも通じる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ｈは往々ｋｈまたｋに通じるから uehere と uokoru とはそれほど遠く離れていないのである。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "vah は「負う」に通じる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシアで剃るのは xurein でわが suri に通じる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪を切る意味の cheirein は「切る」「刈る」に通じる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬（フユ）は「冷ゆ」に通じ「氷」に通じ χι※ν（雪）にも通じる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ語の屋根 Dach は上記の dagh に通じる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「シリ」が梵語の山「ギリ」に通じる可能性がある。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たま」は top に通じる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒙古カルカ語の tologai はタミール語の 〔tala:i〕 に通じる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きてから私が一言も口をきかないので、照れかくしに私の胸にボクシングで穴をあける真似をして片足を私の鼻につきだしてがらがらとした声でおしゃべりを始めようとするので、私が扇風機に電流を通じる。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「普通の會話が出來ないとすると、どうして相互の意志を通じるんですか。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも原子から微晶、微晶から多晶金属の組成、あるいはまたコロイドから有機体の生成等の機巧と相通じる考えである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば風の音は衣ずれの音に似通い、ため息の声にも通じる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その同情感は、一般勤労者である男性にも通じるものであろう。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "永瀬の今まで手がけたのは、大抵養女か、分けのれっきとした芸者で、丸同然の七三などは銀子が初めなので、格別の面白味もない代りに座敷ぶりも神妙で、外国の話をして聞かせても、一応通じるような感じがあり、何か心を惹かれた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉は長い間に、私と姉との仲だけに通じるようになった。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後新道が開け、今では自動車が通じるやうになり、熱海伊東間は一時間半で走ります。",
              "citation": {
                "source": "伊豆伊東",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あー　あー」　するとご新造は苦笑して、張合のない手を振りましたが、わたくしが更にねつく訊ね進むのに動かされ、「おまえさん、耳の方はいくらか通じるのかい。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遜は自分のあとからつかつか門内に入って来た供の者を一寸手で制して、尚よく家の中のけはいをうかがって居ると、裏庭に通じる潜り扉が開いて荘子の妻の田氏が手帛で濡れ手を拭き乍ら出て来た。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "口がへたなうえに、ぶっきらぼうな話しかたであるが、子供たちには却って気持がつうじるようであった。",
              "citation": {
                "source": "ちいさこべ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
