[
  {
    "uuid": "9dfd6b2e-4643-5775-9201-8b2d568a0ea4",
    "entry": "通じる",
    "reading": {
      "primary": "つうじる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-自動詞"
      ],
