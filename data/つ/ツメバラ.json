    "definitions": [
      {
        "index": 1,
        "gloss": "being forced to commit seppuku",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "刃傷事件に座して、親族立ち会いの上で詰め腹を切らされた十九歳の少年の祖母になる人が、愁傷の余りに失心しようとした。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は初めに甥を説得して詰め腹を切らせようかとも考えたが、もし不承知で四の五のいうと却って面倒である。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お手討ちも詰め腹も真平御免だとことわった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠密なぞと軽はずみな事呼ばわり立てなば、あとにて面々詰め腹切らずばなるまいぞ。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それはなりません、非人乞食を御屋敷に呼び入れるなどは以ての外で」　こうなると、多勢の家来の方が強く、まごまごしたら伊予守忠弘、詰め腹を切らされるかもわからない情勢だったのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "乞食志願",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川時代も此頃になると、忠義とか家とかの観念はすっかり変って、お家が立ち行かなくなると、随分主君に詰め腹を切らせ兼ねない忠臣があったものです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "暴君の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "詰め腹を切らされたのだ。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
