    "definitions": [
      {
        "index": 1,
        "gloss": "extension leg (apparatus, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
