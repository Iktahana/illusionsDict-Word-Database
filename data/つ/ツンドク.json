        "examples": {
          "standard": [
            {
              "text": "彼は本が好きでよく買うが、積ん読の本が山のようにある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "休日につんどくを解消しようと、意気込んで本を開いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「また新しい本買っちゃったの？つんどくが増える一方だね。」",
              "citation": {
