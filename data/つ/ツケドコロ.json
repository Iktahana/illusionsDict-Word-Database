    },
    "definitions": [
      {
        "index": 1,
        "gloss": "focus of one's attention",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蝶の舌ゼンマイに似る暑さかな暖かや蕊に臘ぬる造り花臘梅や雪うち透かす枝のたけ「蝶の舌」の句は、ゼンマイに似ているといふ目付け所が山であり、比喩の奇警にして観察の細かいところに作者の味噌があるのだらうが、結果はそれだけの機智であつて、本質的に何の俳味も詩情もない、単なる才気だけの作品である。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉を換えて云うと同様の経験について、眼の付け所が違う、注意の向け方が違っている。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の付け所も大分変って来ます。",
              "citation": {
                "source": "料理一夕話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "土から解放する儀式を与えようとしている相手が、粗野、過激、怒涛のルースじゃなくて、華麗、軽薄、米国娘、シカゴの跡取り娘であり、その娘の目の付け所が通貨問題と現実主義ときている。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "速水御舟の「家」の絵は見つけどころに共鳴する。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉と妹が、母親から同じ分量の松毬を与へられ、これでもつて、ごはんとおみおつけを作つて見よと言ひつけられ、ケチで用心深い妹は、松毬を大事にして一個づつ竈にはふり込んで燃やし、おみおつけどころか、ごはんさへ満足に煮ることが出来なかつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「汚のうございますよ」　平べったくて眼鼻のつけどころが大まかな、そして顎だけしゃくれている顔が母親そっくりですが、こどもの顔にすると愛嬌がありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "読み終ってから、わたくしは、これが今まで自分に交渉して来た男たちとどう違うか、何か新しい見つけどころはあるのかと、手紙を胸に当てゝ考えてみました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる訓練は面倒かもしれないが、ひいては観察能力をとぎすませ、目のつけどころを教えてくれることとなる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆どなんの手がかりも無いので、さすがの半七も眼のつけどころに困った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "その弟子の弥七郎は、どけえいったのかい」　えッ――というように、不意を打たれて、ギョッとなりながら見上げたふたりを、じろり見すくめた名人の目のつけどころはまた、おのずから伝六なぞと格が違うのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "話やこれからが聞きどころ、眼のつけどころなんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "手のつけどころがない、かかりどころがない。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんなの目のつけどころは、いつも人と違うからね」「それに、あの生島屋のおやじが、二度も三度もおれに右門だかどうだか念を押したのが、ちっと気に入らねえじゃねえか」「いかにもさよう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "目のつけどころが凝ってらあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "目のでき、眼のつけどころ、慈悲の用意も人とは違うおいらですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "御深慮さすがにござります」　まことにさすがは退屈男、趣向も直参らしく豪奢きわまりない趣向であるが、人の選み方もまた巧みに人情の急所を衝いて、目のつけどころが違うのです。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かあな（事件）が降ってわいて、その大役仰せつけられたにちげえねえから、とち狂っていずと、ひとっ走りお番所へいってきな」　まことに、名人の目のつけどころ、その眼のさえはこわいくらいです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ブルジョア婦人雑誌が一見実に陳腐でありながらしかも永年の間婦人大衆をとらえつづけている種々な編輯上の技術、目のつけどころというようなものまで『働く婦人』は、それを奪って逆用すべき敵の武器として研究しようとする積極性を示しているのである。",
              "citation": {
                "source": "婦人雑誌の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "合唱こそしているが群集の男女の気分もバラバラ、眼のつけどころもバラバラ、いかにも、はい、わたしの役割はこうして歌うだけです、という風だった。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、茶碗の捧げようが、高いとか、低いとか、摺り足で歩いても、そんなに畳の音をさせてはいけないとか、眼のつけどころが――脣の結びようが――深雪は、自分さえ正しければ、自分の学んだ礼法は、武家作法だし――少しも、間違っていないと、思っていたが、老女達は、そういうことを問題にしていなかった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしらとは、眼のつけどころが、ちがうのう」「ただ、頭が下るだけでござりまするな。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "男性の句に比してやはり女性らしいみつけどころを捉えている。",
              "citation": {
                "source": "大正女流俳句の近代的特色",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "外から刃物があたったんじゃないです」　さすがに警部だけあって、目のつけどころが正しい。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして左東左平が手をつけたところは、まず、安全だと思っていいし、ヤリウスがやったままの部屋などに対して、十分注意したほうがいいと思うね」　四本は、さすがに目のつけどころがよかった。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりや、子供たちに「眼のつけどころ」を教へたり、「太陽」のお話をしてやつたりするのは、誠に立派なことであり、またこれが子供たちへの愛情であり誠意であらう。",
              "citation": {
                "source": "書けない原稿",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学を出たばかりの岸本には、それがまた余りに自由主義的で、律義な両親のことなどを比べ考えては、心の落ちつけどころが分らなくなるのだった。",
              "citation": {
                "source": "田舎者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の日本の俳優が西洋劇をどの程度までやりこなせるか、　そのための訓練と指導が、どの程度まで行はれてゐるか、まづ、これが目のつけどころだ。",
              "citation": {
                "source": "芝居と僕",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、課長は、はじめて頬杖をやめて体を立てなおすと、一同の顔を見まわし、「どうだ管下において、少年がかどわかされていくのを見た者はないか」「さあ、そういう報告はどうも……」「それとも、なにか少年に関係した事件はなかったろうか」「そうですねえ――」　さすがに、大江山課長は、目のつけどころがちがう。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも昨日の今日のことだからね」　船長は、さすがに眼のつけどころがちがっていた。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
