    "definitions": [
      {
        "index": 1,
        "gloss": "continuation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「いいかオイ……」と突然三田村はその重さうな頭をハネ上げて続きを始めるのだつた、「俺がついててやるから安心しいろい」「うん、うん」と私は相変らず吊り込まれて承知するのだつた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院は庭続きだつたもんだから。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中が二人、書生が一人、老僕が一人、他に抱車夫が一人という大家族であったので、家も相当に広く、間数がいくつもあって廊下続きになっていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "交番へ行って応急米の手続きもして置いたのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それの表現手続きの中に生起するのである。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活は破産し切つて、ただしようことのない生存の一日一日が続き、如何なる行為らしい行為も最早見られないとしても猶、『無償の行為』は在つて存するのである。",
              "citation": {
                "source": "アンドレ・ジイド管見",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "根岸派では、饗庭篁村が先達で、八文字舎風の軽妙洒脱な紀行文を書き『東京朝日』の続きものとして明日を楽しませた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政六年版の玉蘭斎貞秀画、富士登山三枚続きの錦絵には、「小御岳、花ばたけ、しゃくなぎ多し」とあるから、昔から多かったものと見える。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "邸宅の後ろは常磐木の密林へ塀一つで、庭の続きになっていた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "生けるものにはここしばらく住み具合のよい釣合いのとれた時期の続きであるだろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの身体の続きの上で同じく火を吐く幾つかの眷属。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みち子はその行動をまだ彼の冗談半分の権柄ずくの続きかと思って、ふざけて軽蔑するように眺めていたが、だいぶ模様が違うので途中から急に恐ろしくなった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "根気も続きそうだ」　車が迎えに来て、老妓は出て行った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなもそれに続きましたので列は一つの環になりました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にこの高原の続きこそは、東の海の側からと、西の方からとの風や湿気のお定まりのぶっつかり場所でしたから、雲や雨や雷や霧は、いつでももうすぐ起ってくるのでした。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてもっと甚だしい、もっと永続きのする断水や停電の可能性がいつでも目前にある事は考えない。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一七年一月二十八日、ロダンさんは自分の死期をお知りになったのか、オテル・ド・ロンに観覧者の列が続きました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "地質時代に朝鮮と陸続きになっていたころに入り込んでいた象や犀などはたぶん気候の変化のために絶滅して今ではただ若干の化石を残している。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホワイトナイルの岸べに生まれたある黒んぼ少年の数奇な冒険生涯を物語る続きものの映画を中学校の某先生が黄色い声で説明したものである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともそれにしたところで、広瀬中佐の銅像を見ていたという事が、どういう機縁になってこれが呼び出される手続きになったのか、これに関する筋の立った説明はなかなか簡単でないように思われる。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "名前だけ聞いたところではたいそういかめしいお役所のような気がして、書類の山の中で事務や手続きや規則の研究をしている所かと想像していたのであるが、事実はまるで反対で、それは立派な応用科学研究所であって多数の実験室にはそれぞれ有為な学者が居て色々有益で興味のある研究をしているのであった。",
              "citation": {
                "source": "鉛をかじる虫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小祠宮沢賢治赤き鳥居はあせたれど杉のうれ行く冬の雲野は殿堂の続きかなよくすかれたる日本紙は一年風に完けきと雪の反射に知りぬべしかしこは一の篩にてひとまづそこに香を浄み入り来るなりと云ひ伝ふ雪の堆のなかにしてりゝと軋れる井戸車野は楽の音に充つるかな",
              "citation": {
                "source": "小祠",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」音は続き、それからバァッと表の方が鳴って何か石ころのやうなものが一散に降って来たやうすです。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ほどの処の地続きは平にならされてテニスコートになっている。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間、子供達が板を尻に当てて棒で揖をとりながら、行列して滑る有様を信子が話していたが、その切り通し坂はその傾斜の地続きになっていた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その続きを彼は心待ちに寝ていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し調和的な気持は永く続きませんでした。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と聞く身には他事をいううちが牴牾しく、膠もなく続きを促した。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "教会の附近の黄色い土塀つづきの、夕方はしづかり下りて来る彼処へ、ではまた落付いたな、あゝあゝと、僕は思ふのだつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "笠島はいづこ五月の泥濘道　芭蕉の行く旅の空には、いつも長雨が降りつづき、道は泥濘にぬかっていた。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
