    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tambour (drum)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "イスタンブールで恋人はその身を果敢なんで、死んでしまったのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば笛のピパに対して弦楽器のピパすなわちビワがあり、弦楽器のタンブールに対して太鼓のタンブールがあるような類である。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルコ駐在のドイツ大使フォン・パーペンがドイツに帰る途中、イスタンブールで新聞記者にドイツの戦争目的如何という質問を受けた。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうそう、今イスタンブールを廻っているよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この取引がすむと、王様だけがすぐ熱海を発って神戸へ飛び、三日正午出帆のＰ・Ｏ汽船のサマリ号でペナンへ行き、そこから旅客機でイスタンブールへ亡命される手筈に決まった。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "イスタンブールの秋は、実によい陽気で、九月一ぱい病室の窓をあけ放したまま寝ていたが、昼夜温度は二十二度に釘付けされ、晴天がつづき、近くはボスフォラス海峡を往来する諸外国の汽船、遠くは対岸アジヤ大陸のスクータリ市を一眸のうちに収められる。",
              "citation": {
                "source": "ブイヨン・ドンゾール",
                "author": "――十一時の肉の煮出し――",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗世の音楽書にあるアムール（愛）という音は、修道院の中にはいって行くとタンブール（太鼓）もしくはパンドゥール（略奪者）と代えられていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああタンブールとはどんなにか楽しいことでしょう！",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしコゼットはまだごく若いうちに修道院を出たので、「タンブール」なんかにあまり頭を悩まさなかった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "tambour (circular frame for embroidery)",
        "register": "standard",
