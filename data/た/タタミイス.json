          "literary": [
            {
              "text": "折たたみ椅子をもって。",
              "citation": {
                "source": "日記",
                "author": "一九四七年（昭和二十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは折たたみ椅子でのばすと長椅子にして寝られ背の勾配も加減できるのです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "“同時代”の部室には珍しくＯＢの武藤春彦が来ていて折りたたみ椅子に坐ってテレビを見ていた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな殺風景な部屋で、ピアノやステージがあって、バンド演奏も出来るのですが、いつもはいくつものテーブルをスティール・パイプの折りたたみ椅子が囲んでいるという、そんな部屋です。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "片隅の折りたたみ椅子に体を落としこみ、沢田がよこした紙きれを、ぼくは見なおした。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "つなぎに着替え、ぼくは折りたたみ椅子にすわった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
