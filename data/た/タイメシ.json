        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鮨、お辨當、鯛めしの聲々勇ましく、名古屋にて夜は全く明けて、室内も聊か寛ぎ、暖かに窓輝く。",
              "citation": {
                "source": "大阪まで",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小笠原章二郎の招待、まなかつをと白いさしみ、かぶらむし等々ウンと食って、若竹で鯛めし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "母上と三越本店へ行き、ソフトと靴、鯛めしの折詰など買って、食事して、座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月十八日（土曜）　十一時起き、ビクターの森田氏の招待で、徳山と二人、広小路の鯛めしや呑兵衛へ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯛めしの水たきはまだよかったが、売ものゝ鯛茶のまづいことお話にならず。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぜんたいめしいと申すものは、ひといちばいかんのよいものでござります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
