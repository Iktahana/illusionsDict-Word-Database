        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "凧揚げのあとは酒宴である。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月の遊戯で盛に行われたのは凧揚げであった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "藩邸の凧揚げは右の通りの有様であったが、なお町家でも凧揚げをした。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然、凧揚げも下手ではなかった。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒くはあつたが、風のある良い凧揚げ日和だつたよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "敵の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は暮れかゝつて居るのに、子供達はまだ凧揚げに夢中です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "敵の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お諏訪さんのお祭典とお盆と凧揚げに馬鹿々々しい金を使うので、これを三馬鹿と申します」「何、三馬鹿だって？",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「坊ちゃん、此処は凧揚げが名物です。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "切られては買い切られては買い後を引くものと見えて、凧揚げのことをつぶらかしというくらいだ」「身上を潰すのかい？",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "凧揚げをほんのすこし手伝っただけで彼と別れた自分は、なんという馬鹿なことをしたのだろうかと、邦子は自分のうかつさを口惜しく思った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "代役を相手に、あのときの凧揚げをいまこうして再現している自分にとって、すさまじいまでの胸のときめきをともなった、ひと目惚れによるほんの数分間の初恋は、もはや永遠に失われたのだと、邦子は結論していた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "自転車もなく、たまに年始客の人力車が通るくらい、どこの往来も娘や若衆の追羽子、子供の凧揚げで一杯、これらは江戸時代そのままの風景。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後追い追い山高帽子や洋服の礼者も殖え、足取りも大分せわしく、二十五、六年代には電信電話の線もゆきわたり、交通も繁しくなって、追羽子や凧揚げは横町か空地に限られ、娘子供は大不服。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父を手古摺らせた私の内気も、三年生になって級長を勤めるようになってからはそれほどでもなくなって、凧揚げやとんぼ採りの仲間入りも一人前に出来るようになるばかりか、大川へ水泳ぎにさえ出かけるようになった。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「風がなくなったら、たこあげができない」　と善金が心配そうにいった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "たこあげ天へ上りたかネオルガンの鳴っとる如たる凧の踊っとるもん天へ上りたかネ　　注上りたか…………上りたいごたる……………ようだハタ………………たこ踊っとるもん……踊っているから完全な幸福　真実孤児の道はさみしい。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
