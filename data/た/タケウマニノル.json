          "literary": [
            {
              "text": "「松公、汝は放生の亀の話を知っておるか」　獅子鼻の右横になった松の浮根に竹馬に乗るようにしていた小供が、獅子鼻に向って云った。",
              "citation": {
                "source": "放生津物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹馬に乗ることが大好きで、毎日、外へ出て竹馬に乗って遊んでいました。",
              "citation": {
                "source": "竹馬の太郎",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "道化役者になる一つの修練としては、高い竹馬に乗る必要があるそうで、高等学校時代に大いに竹馬に乗る勉強をしたという。",
              "citation": {
                "source": "科学は役に立つか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「竹馬に乗るのも十何年目だ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の足跡",
                "note": "青空文庫"
              }
            }
