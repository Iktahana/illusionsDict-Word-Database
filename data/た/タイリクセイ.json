          "literary": [
            {
              "text": "『月刊文章』（29日）「文学における大陸性について」11枚十月二日　実業の日本、三千だったが発送でもう千刷るという話が出ている由。",
              "citation": {
                "source": "日記",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "大陸性その他のこともわかります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学における大陸性のこと、又チャイコフスキーのこと。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "大陸性気候と言うんでしょうな。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
