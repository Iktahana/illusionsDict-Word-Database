[
  {
    "uuid": "43895510-099d-587a-83e3-3bd4dc5bcc3d",
    "entry": "大半",
    "reading": {
      "primary": "たいはん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
