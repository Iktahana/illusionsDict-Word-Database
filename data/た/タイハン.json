    },
    "definitions": [
      {
        "index": 1,
        "gloss": "majority",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども観衆の大半は、ひょっとしたら、やっぱり侘びしい人たちばかりなのではあるまいか。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "博覧会の跡は大半取り崩されているが、もとの一号館から四号館の辺は、閉鎖したままで残っている。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉島のあたりははらかた釣りが夥しいが、女子供が大半を占めている。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同人の大半は、私の知らぬ人ばかりである。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "連句では一景から次の景またその次の景への推移と連絡の必然性によって呼び出される暗示の世界に興味の大半がつながれているが、レビューではそういう連鎖の必然性はほとんど閑却されているようである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人の説によれば、鳥類が農作物の害虫を駆除する功は非常なもので、もし鳥類濫殺の結果有益な鳥が絶滅に近づく暁には、地上の植物は大半滅亡するに至るであろうというている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその小説には、君の過去の生活の大半が書き盡されてる。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "島崎藤村……全詩集中の詩大半薄田泣菫……暮笛集・ゆく春蒲原有明……春鳥集・獨絃哀歌三木露風……廢園・白き手の獵人北原白秋……邪宗門・思ひ出（二重圈點◎を附したのは、特に名詩集たるもの。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "召使たちの大半は、その部屋の外の、内よりは明るい、眞白な廊下に立つてゐた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎には住むこと七年、小學校課程の大半をこゝで過し、少年時代の追想の懷しい町である。",
              "citation": {
                "source": "自分のこと",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作品の出版當時、これに對する文壇の評論の大半は、クローヂヤスのこの新型の惡を見のがし、正宗白鳥氏なども、このクローヂヤスに作者が同情してゐるとさへ解されてゐたやうである。",
              "citation": {
                "source": "『猿面冠者』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "突発した事件の目撃者から、その直後に聞き取ったいわゆる証言でも大半は間違っている。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでなくても乏しかった衣類の、大半を、戦火で焼いてしまったので、こんど生れる子供の産衣やら蒲団やら、おしめやら、全くやりくりの方法がつかず、母は呆然として溜息ばかりついている様子であるが、父はそれに気附かぬ振りしてそそくさと外出する。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の部屋へ来る女中の大半は、私に、「書けますでしょうか。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車の歌志内の炭山に分るゝ某停車場に着くや、車中の大半は其処で乗換へたので残るは余の外に二人あるのみ。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、もしもすべての人が絶対必要として争って購買するものならば何も高い広告料を払って大新聞の第一ページの大半を占有する必要は少しもないであろう。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや死んでしまったんだ」　大半の生徒は拍子木の声に勇みを覚えたように、机の蓋をばたんばたんと音させて風呂敷包を作りはじめる。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち山岳鳴動し、黒烟朦朧と立昇る、其黒烟の絶間に眺めると、猛狒は三頭共微塵になつて碎け死んだ、獅子も大半は打斃れた、途端に水兵が『あれ／＼、あの醜態よう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤ腹の中へ飲んだのならまだいいが、奴さん一口でも多く飲んでやろうと周章てたため、水汲み隊が汗水流して汲んで来た大事な水をば、大半ゴボゴボと溢して地面に飲ませてしまったのだ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに」電車会社の謝罪金は何故か百円にも足らぬ僅少の金一封で、その大半は、暇をとることになった見習弟子に呉れてやる腹であった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "現にそこを引き払う時、払った金が所持金の大半で、残ったのは回漕店を止める時貰った十円にも足らぬ金だった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙崎の宿はよかつた、設備（部屋も夜具も便所も湯殿も井戸も）待遇（その大半はおかみさんのサービス如何にある）共によかつた、木賃料は一昨夜の宿とおなじく三十銭だが、その倍の値打はある、相客三人、屋号は寺田屋。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "抱えの大半が東京産まれだったが、そのころは世界戦後の好況がまだ後を引き、四時が鳴ると芸者は全部出払い、入れば入ったきり一つ座敷で後口もなく、十二時にもなると揃って引き揚げ、月に一度もあるかなしの泊りは、町はずれの遊廓へしけ込む時に限るのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の父は、東京に用事の多いひとでしたので、上野の桜木町に別荘を持っていて、月の大半は東京のその別荘で暮していました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ彼等は、絶えずごろごろと怠けて居り、塵の積つた原稿紙を机上にして、一生の大半を無爲に寢そべつてゐるのである。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――自由詩は全般のものでなくして、或る一部の詩人に属するもので、爾余の大半の詩人たちは、今日尚規則的なる、韻文の形式を捨てないのである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの作に就いて情調とか、ムードとか云うものを挙げて、それを具合好く説明すれば、既に大半の批評は出来上ったように考えられるのですが、其ムードを作り上げるために、河岸の寿司屋とか、通りの丸花とか、乃至は坊間の音曲など丈が道具になっているという意味では決してないのです。",
              "citation": {
                "source": "木下杢太郎著『唐草表紙』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "川幅の大半を埋めている小石の大河原にも若草の叢の色が和みかけている。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
