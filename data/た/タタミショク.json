        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新銀町は大工、屋根職、左官、畳職など職人が多く、掘割の荷揚場のほかにすぐ鼻の先に青物市場があり、同じ下町でも日本橋や浅草と一風違い、いかにも神田らしい土地であった。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一人の畳職人を知っている。",
              "citation": {
                "source": "ジャングル頭",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥「フヽヽ「ヒヂ」は道具商より畳職の方がつよいで。",
              "citation": {
                "source": "にゆう",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｆさんの家には、畳職人である息子の夫婦と、小さな子供が四人いた。",
              "citation": {
                "source": "山吹の花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は大工と畳職の棟梁であるが、書をよくし、雲介舎弥太夫と号していた。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
