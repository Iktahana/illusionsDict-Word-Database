    "definitions": [
      {
        "index": 1,
        "gloss": "bound hands and arms",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そを懸命に踏み堪へて、左褄高々と紮げ、脛白き右足を擡げて、踏絵の面に乗せむとせし一刹那、「エイツ……」　と一声、足軽の棒に遮り止められ、瞬く間に裲襠を剥ぎ取られて高手小手に縄をかけられつ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、検非違使のお役所へ、高手小手に縛られた多能丸が、連れられて来ました。",
              "citation": {
                "source": "三人兄弟",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "声が飛び、人が飛んで、訴人はたちまち近侍の者たちが高手小手。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "その十四人の駕籠かきどもが、ひとり残らず厳重なさるぐつわをかまされて、高手小手にくくされながら、まるで芋虫のようにごろごろと投げ込まれてあるのでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂上与一郎もその娘の鈴江も、舞台裏にいるにはいましたが、まことに奇怪、いま清正と妓生に扮したはずの親子が、それぞれじゅばん一つのみじめな姿で、厳重なさるぐつわをはめられながら、高手小手にくくしあげられていたのでしたから、血相変えて駆け込んでいった一同は等しく目をみはりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう燃えたれかかったろうそくの鬼気あたりに迫るようなぶきみに薄暗いあかりの下に、右手のない一個の死体が、からだじゅうを高手小手にいましめられながら、やせ細った芋虫のようになって、ころがされてあったからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その死骸のそばに、不憫というか、笑止というか、それとも憫然のいたりというか、同じく高手小手にくくしあげられて、げっそり落ちくぼんだ目ばかりピカピカ光らせていた者は、だれでもない、あのあばたの敬四郎でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "松子はウトウトしたかと思うと高手小手に縛り上げられて病院を引摺り出される姫草ユリ子の姿をアリアリと見たりしてゾッとして眼が醒めたという。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく二匹の見知らぬ鼠が高手小手に縛られて王様の面前に引き出されました。",
              "citation": {
                "source": "船の中の鼠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ警官連中が上から折重って怪漢をひきはなし、高手小手に縛りあげてしまった。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "高手小手に縛り上げて、裏の中二階に転がし放しにして、其｜傍でお鉄はやけからの茶碗酒を呷りながら、さも口惜しそうに口を切った。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　始め、花輪支庁から足にはカセを打たれ、高手小手に縛められ、五十里の山路を四日、牢籠に封じられたるまゝ、江刺県の本庁へ護送された時、その中間に上下八里の七時雨峠と云ふがある。",
              "citation": {
                "source": "臨終の田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれどもその夜は珍陀の酔に前後も不覚の体ぢやによつて、しばしがほどこそ多勢を相手に、組んづほぐれつ、揉み合うても居つたが、やがて足をふみすべらいて、思はずどうとまろんだれば、えたりやおうと侍だちは、いやが上にも折り重つて、怒り狂ふ「れぷろぼす」を高手小手に括り上げた。",
              "citation": {
                "source": "きりしとほろ上人伝",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "数人の武士がその中にいたが、何と高手小手に縛られているではないか。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高手小手に縛された私、矢来をお取り払いくだされたとてとうてい逃げることは出来ませぬ」「警護の者も沢山いる。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍、竹槍、長脇差、大鎌、鋤の類を、日光にギラギラ光らせた、浪人と百姓との群であり、高手小手に縛めた三人の男を、中に囲んで走って来た。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また砂利の上に莚を敷きまして、其の上に高手小手に縛されて森山勘八が居りますお目付が席を進みて。",
              "citation": {
                "source": "菊模様皿山奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつ奴が――」　素早く飛びこんだ警官に、逆手をとられ、あわれ酔払いの帆村は、高手小手に縛りあげられてしまった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "此謀が早速成就して、怒つた清平は、若を高手小手に縛つて、桜の木に吊り上げて置く。",
              "citation": {
                "source": "愛護若",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、孔子の弟子の子路がやってきて、師の身辺を脅かすとは怪しからん奴、とばかりその大男を庭へ引き摺りだし、組打ちをはじめ、とうとう子路が勝って大地へ組み伏せ、高手小手に縛りあげてみたところ、こはそもいかにこれ大鰓魚也とあった。",
              "citation": {
                "source": "鯰",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の武士が高く叫ぶと押っ取り刀で五、六人の逞しい武士が馳せつけ、佐々木彦三郎を取り巻き、高手小手に縛り上げてしまった。",
              "citation": {
                "source": "純情狸",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "討手の大将は椎名金之丞と云って、情を知らぬ武士であったが、手向いもしない郷左衛門を高手小手に縛めると磔柱へ縛り付けた。",
              "citation": {
                "source": "郷介法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たといどのように苦しくともこの苦しさはただ一時、後に残った兄さんが、謀反の企てすぐにも解って部落中の人に恥ずかしめられ、山藤の蔓の高手小手、大木の幹につながれて、十人の射手の矢先にかかり嬲り殺しにされる時の、その苦しさに比べたら、軽い軽い苦しみでござんす。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何より三人の驚いたのは、殺されたと思った市之丞が多少の衰弱は見せながらも端然と円座に坐っていたことであるが、もう一つ三人を驚かせたのは、兇悪無惨の鬼王丸が、白虎、青竜、玄武、朱雀の、四天王もろとも高手小手に縛められていることであった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは、芳男を高手小手にいましめて、自分らのまんなかにはさんで、引ったててきた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二　密室大犯罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "高手小手にいましめられている芳男の縄をとかせて、「一晩つらかったろう。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二　密室大犯罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺達は知っている　俺達の破れを修繕い　傷を手当し　がさつに抱き上げる腕が　高手小手に縛り上げられたのを！",
              "citation": {
                "source": "犬にされたカスペルの話しかけ",
                "author": "佐藤武夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと高手小手に、がんじがらめに縛り上げてしまえ。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "半裸の肢体は荒縄でたかてこてにしばられ、髪をみだし、そのうえさるぐつわをかまされているので人相はよくわからなかったが、じいとみつめているうちに思わずあっとでかかる息を力まかせにおさえつけた。",
              "citation": {
                "source": "放浪作家の冒険",
                "author": "西尾正",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
