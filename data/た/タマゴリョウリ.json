        "examples": {
          "standard": [
            {
              "text": "オムレツやエッグベネディクトなど、ホテルの朝食バイキングには多彩な卵料理が並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "卵料理は火加減が難しく、プロのような滑らかな質感に仕上げるには修行が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "卵一個でバリエーション豊かな卵料理が作れるので、冷蔵庫にあると本当に助かる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "Ｂ中尉やＰとは乗艦以来何等かの交渉があったが、卵料理をした水兵とは、この時はじめて口をきいた。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "食べものも、おいもとか、じねんいもとか、卵料理とかが好きだった。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
