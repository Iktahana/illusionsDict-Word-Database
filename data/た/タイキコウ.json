        "examples": {
          "standard": [
            {
              "text": "夜空で観測される微かな光は、大気光と呼ばれる現象だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "科学者たちは、大気光の発生メカニズムを研究するために、特別な観測装置を開発した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「条件が良ければ、大気光の神秘的な輝きを見ることができる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "不可思議な大気光学現象に何度も魅了され、その中でも蜃気楼――こんなのは初めて見た――には驚くほど生き生きとしたものがあり、そこでは遠くの山塊が想像すら及ばぬ宇宙的城郭の頂銃眼と化していた。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
