[
  {
    "uuid": "448c086e-8c30-5073-af98-dd7112002913",
    "entry": "例がない",
    "reading": {
      "primary": "ためしがない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "形容詞"
      ],
      "ctype": null,
