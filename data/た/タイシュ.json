      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "viceroy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "勇將　同じ時、賈雍將軍は蒼梧の人、豫章の太守として國の境を出で、夷賊の寇するを討じて戰に勝たず。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の書の体たるや、水滸伝平妖伝等に同じと雖も、立言の旨は、綱常を扶植し、忠烈を顕揚するに在りというを以て、南安の郡守｜陳香泉の序、江西の廉使劉在園の評、江西の学使｜楊念亭の論、広州の太守｜葉南田の跋を得て世に行わる。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし、秋田何代かの太守が郊外に逍遥した。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "太守は人麿の声を聞こうとしたのである。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほのぼのと……」　太守は門口を衝と引いた。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき途中で雲中の北方を戍る衛兵らに会い、彼らの口から、近ごろ漢の辺境では太守以下｜吏民が皆白服をつけていることを聞いた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、珊珊を伴れて赴任したが、非常に成績があがったので、翌年には銭塘の太守となった。",
              "citation": {
                "source": "虎媛",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾の子の任は平陽の太守であったが、もう人をやって吟味をさしてあった。",
              "citation": {
                "source": "続黄梁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また北狄が漢地を犯せし時、太守宋梟、涼州学術少なし、故にしばしば反す、急に『孝経』を多く写させ家々習読せしめば乱たちまち止みなん、と言えり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳は後に予章の太守に栄進して、久しぶりで黄家をたずねた時、まずかの子供のことを訊くと、かれは鑿に打たれたというのである。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "螻蛄　廬陵の太守｜※企の家では螻蛄を祭ることになっている。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "頴川の太守、史祈という人がそれを聞いて、彼は妖法をおこなう者であると認め、役所へよび寄せて成敗しようと思った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "召されて劉が出頭すると、太守はおごそかに言い渡した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが出来なければ刑戮を加えるから覚悟しなさい」「それは訳もないことです」　劉は太守の前にある筆や硯を借りて、なにかの御符をかいた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼は二人の囚人を縛って来たので、太守は眼を据えてよく視ると、その囚人は自分の父と母であった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "先祖に光栄をあたえる事が出来ないばかりか、かえって神仙に対して無礼の罪をかさね、生みの親にまでこんな難儀をかけるのか」　太守は実におどろいた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "州の太守も彼を認めて、将来は大いに登庸しようとも思っていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "深州の太守も王を恐れている一人であるので、その子の士真に対しても出来るだけの敬意を表して歓待した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし迂闊な者を酒宴の席に侍らせて、酒の上から彼の感情を害すような事があってはならないという遠慮から、すべての者を遠ざけて、酒席の取持ちは太守一人が受持つことにした。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが士真の気にかなって、さすがに用意至れり尽くせりと喜んでいたが、昼から夜まで飲み続けているうちに、太守ひとりでは持ち切れなくなって来た。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か相客を呼んで下さらんか」「何分にもこの通りの偏土でござりまして……」と、太守は答えた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "太守も不思議に思って、ひそかに李の方をみかえると、彼も色蒼ざめて、杯を執ることも出来ないほどに顫えているのである。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "太守はそれで先ずほっとしたが、一体どういうわけであるのか、それがちっとも判らないので、獄中に人をつかわしてひそかに李にたずねさせた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "王君がむかしの罪を覚えていられるかどうかは知りませんが、わたくしとしては王君に殺されるのが当然のことで、自分も覚悟しています」　太守はその報告を聞いて驚嘆していると、士真は酒の酔いが醒めて、すぐに李の首を斬って来いと命令した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "太守は命乞いをするすべもなくて、その言うがままに李の首を渡すと、彼はその首をみてこころよげに笑っていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分の部下にかような罪人をいだしましたのは、わたくしが重々の不行き届きでございますが、一体かれはどういうことで御機嫌を損じたのでございましょうか」と、太守はさぐるように訊いてみた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "太守はさらに士真の年を訊くと、彼はあたかも三十七歳であることが判ったので、李の懺悔の嘘ではないのがいよいよ確かめられた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "主簿と云へば、刺史とか太守とか云ふと同じ官である。",
              "citation": {
                "source": "寒山拾得",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "州には刺史と云ひ、郡には太守と云ふ。",
              "citation": {
                "source": "寒山拾得",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "商人は、金らんや、かたいしゅすや、おもたいにしきや、ピカピカしたビロードや、うすいヴェールや、クモの巣のようにすきとおったレースなどをひろげていました。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
