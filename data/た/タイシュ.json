[
  {
    "uuid": "37e8aabc-8e7f-5575-882a-ea0416170b07",
    "entry": "太守",
    "reading": {
      "primary": "たいしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
