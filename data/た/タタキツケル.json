[
  {
    "uuid": "7db462f4-9126-5fa2-931e-323c3ff20b5a",
    "entry": "叩きつける",
    "reading": {
      "primary": "たたきつける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
