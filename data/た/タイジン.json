    "definitions": [
      {
        "index": 1,
        "gloss": "resignation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "他のお客は、このあわれなる敗北者の退陣を目送し、ばかな優越感でぞくぞくして来るらしく、「ああ、きょうは食った。",
              "citation": {
                "source": "禁酒の心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "処に伯父水野信元が浅井道忠を使として敗報をもたらしたので、元康は部下をしてその真実であることを確めた後、十九日の午後十一時すぎ月の出を待って道忠を案内として三河に退陣したが、土寇に苦められながらやっと岡崎に着いた。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "非戦論者達は、では長篠城を抜いて勝頼を入れ、一門の武将は後陣となり、我等三名は川を越えて対陣し、持久の策を採らば、我軍の兵糧に心配ないのに対して、敵軍は事を欠いて自ら退陣するであろう、と云った。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "力と頼む各部隊の驍将等が悉く討死して指揮を仰ぐに由ない上に、総大将の退陣と聞いては、さしもの武田勢も乱軍である。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の金ヶ崎の退陣で、さんざんな目に会った。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "予しばしば観しところ斥候は始終番し続け少しも自ら集めず、因って退陣事終って一同の所獲を頒つと察す。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅か数年ではあったとしても、過去の云うところの教養を身につけていない新鮮さを寧ろ文学の世代としてのよりどころとして発足しようとしていた若い作家たちにとって、退陣の形としてあらわれた過去の教養の尊重の流行は、多くの混迷をわきおこした。",
              "citation": {
                "source": "作家と教養の諸相",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森市では、記載もれの市民大会が開かれ、市長以下責任者が退陣しなければならなくなった。",
              "citation": {
                "source": "春遠し",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "委員会は官僚的な独占事業である放送事業を民主化するために、第一に必要な機構改革に着手し、従来の戦犯の会長と旧首脳部が退陣したのちに、新しい会長高野岩三郎博士を選んだ。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "放送委員会は、新会長の選出にひきつづきプログラム編成上の改善、放送技術の向上および協会内に巣喰う情実のくもの巣をはらって、放送現状の各機構が民主化されることを希望したが、協会内の旧勢力は、表面上退陣したのちもさまざまな形に変ってその影響を新首脳部の日和見的な打算と結合させた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "退陣だそうな」晴信は顔を顰めたものだ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アキリュウスが退陣したのでトロイア軍は進出した。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "小磯内閣の退陣に当たり印象に残ったのは、米内海軍大臣の朗々たる声と率直な物の言い方、杉山陸軍大臣の年齢に似ぬ元気な、そして円い物の言い方、町田ノンキナトウサン無任相のぼんやりした顔、前田運通相の悪相、緒方国務相の疲れた顔、まずそんなところなり。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "出発、退陣、引くも進むもただ一瞬にとり行う！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カン、カン、カンとそのおりから、退陣の鉦が鳴り渡った。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……正成、今宵陣を引く所存じゃ」「ご退陣？",
              "citation": {
                "source": "赤坂城の謀略",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大将公綱を初めとし、紀清両党の郎党たちも、追々｜惰気を催して来、しかも思い切って心を許し、眠に入ることが出来なかったので、身心次第に疲労れ衰弱えて、戦意｜頓に失われ、退陣したいものと思うようになった。",
              "citation": {
                "source": "赤坂城の謀略",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「公綱明朝陣を引き、京都へ帰って行くからじゃ」「ははあ、公綱退陣しましょうか？",
              "citation": {
                "source": "赤坂城の謀略",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あの篝火の衰え様では、明日退陣と見てよかろう」「…………」「一戦も交えず正成をして、退かせましてござりますと、これを功にして京に帰らば、公綱の面目は立つからのう」「これは御意にござります」「公綱としてはわしを追い討ち、この陣を破りたく思ってはいようが、それにしては兵が少なすぎる。",
              "citation": {
                "source": "赤坂城の謀略",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、結局、帰って行くのじゃ」「さよう予めご計画あそばして、天王寺をご退陣あそばしましたので？",
              "citation": {
                "source": "赤坂城の謀略",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍を引くにさいして、エセックスは、それらの城門の一つへ自分の槍を突っ込みながら、退陣の身ぶりを示して声高らかに叫んだものである。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の明るさが、政府放送のたよりなさと拙劣さとを、ひとしおしみじみと感じさせるような雰囲気のうちに鈴木貫太郎内閣が退陣した。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "トロイア軍退陣して評議の席を開く。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳さんの苦しさもわかり、歌子さんがそういう本質的退陣を決心したのもいい気でやっているのではなかろうし。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月二十日の各新聞によれば「内閣即時退陣せよ」と進歩党をのぞく四党代表者会議の決定が首相に示された。",
              "citation": {
                "source": "一票の教訓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあいだに家康はしゅびよく退陣し、旗本の人びとも追躡する敵を撃退しつつ浜松城下までひきしりぞいた。",
              "citation": {
                "source": "死處",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついで十一月二日に進歩党出身のものの総退陣となり、六日には大隈自身の辞職となった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対派の新聞は犬猿夫婦などと揶揄したが、伊藤内閣はこれに怯えるもののようにあわただしく退陣した。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "これよりさき、政友会内閣は予算問題をめぐって閣内に内訌を生じ、五月五日にまず総理大臣伊藤が骸骨を乞うて、すでに総退陣していた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二には、日本の完全独立と平和確保のためにその退陣を要求するものであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
