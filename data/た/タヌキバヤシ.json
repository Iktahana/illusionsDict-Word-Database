    "definitions": [
      {
        "index": 1,
        "gloss": "tanuki drumming on their stomachs",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「狸囃子と云うんだよ、昔から本所の名物さ。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ舞台がこんな所で、ふくろの鳴き声や狸囃子の鳴物じゃあ、しんみりしたお芝居にゃあなりませんけれど、漫才の掛合だと思えばいいでしょう。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中に聞いて、狸囃子と言うのも至極でございます。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "本所の狸囃子と、遠き縁者と聞く。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "書生達の唄は響いて一種の狸囃子であった。",
              "citation": {
                "source": "黒い驢馬と白い山羊",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "福村は気をつけていたけれども、その晩は狸の足音は聞えない代りに、遠からぬところで狸囃子の音が起るのを聞きました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏庭をへだてた離れ座敷では、今宵も酒宴があると見えて、楽器の音色や笑い声や女達の囃す仇めいた声が、狸囃子のそれのように怪しくも凄じく聞こえて来た。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨で湿けた、生乾きに似た壁の匂いがムッと鼻を衝いて、また小銃が、砲声が、ワッワッワーッというような何とも分らない大ぜり合いのような声々が、近まってきてはまた遠のいていった、狸囃子のそれのように。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう渡って来たのか、蝦夷から来た『えぞたぬき』という変った狸がこの原へ住みつき、毎夜奇妙な狸囃子をするというのでたいへんな評判。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "初春狸合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、そろそろと陽が暮れかかると、草のあいだでテコメン舞か正殿鎌倉によく似たなんともおもしろい狸囃子がテンテテンテケレツとはじまる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "初春狸合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それがネ親分、昨夜は狸囃子がひどくて、どうしても寢付かれなくつて弱つた位ですから、曉方になつてぐつすり寢込んだので御座いませう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「え、本所七不思議の一つの狸囃子で御座いますよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸囃子といふものは一體かうしたものなんださうで、大概の方は狸退治どころか、ヘトヘトになつて歸つて了ひます」「いよ／＼面白いな、泥棒が狸だとすると、フン捉まへると狸汁が出來るだらう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿、世の中には、どんな狸が居るか、手前なんかに解つてたまるものか」「さうですかねえ、親分」「ところで番頭さん、その狸囃子は、何刻ほど續くんだネ」「宵から始まつて、夜中まで、いやどうかしたら、曉方まで續くでせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "庫裏の雨戸の鋸目から、狸囃子が宵から聞えたことまで型の通りです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前は旗本、瀬川｜壹岐、松倉町の大きい屋敷ですが、身分に耻ぢて屆出もしなかつたといふことで、平次も入つて見るわけにも行きませんが、手口にも狸囃子にも變りがなかつたことは、近所の人が證明してをります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相變らず狸囃子は、何處からともなく、人を馬鹿にしたやうな長閑さで聞えて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本所を荒し廻つた大泥棒、――井筒屋の主人まで殺した曲者は、言ふまでもなくお紺とその手代の嘉七で、狸囃子は、世人を惑はして、嘉七お紺の仕事を助ける、笛辰と三吉の仕事だつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸囃子を使つたのは、本所の七不思議をもじつたに相違ありませんが、實は貸本の「繪本太閤記」から思ひついたことで、日吉丸が、蜂須賀小六のところから、刀を盜み出すのに、三晩も續けて笠を雨落に置き、小六の心を疲らせて、曉方ウトウトとしたところへ入つて首尾よく取つたといふ術を用ゐたので御座います。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨落の笠代りに狸囃子を使つたまでで御座いますが、もう一つ、狸囃子を聞かせたわけは、あの囃子の音に合せて、鋸を引く上、目の覺めて居るものでも、一寸氣が付かないからで御座います」　と言つて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も彼もお品から聞いたが、狸囃子の曲者を擧げさせた指金は、兄哥がやつてくれたんだつてネ」　日頃面白くない仲だけに、利助も我慢の角を折つて、疊に手を突きたい心持になります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれは大失策さ、晝は鋸目にばかり氣を取られたので、夜もう一度狸囃子をやつた場所を探しに行つたんだが、暗くて何にも判らなかつたんだ」「狸狩りは？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それがネ親分、昨夜は狸囃子がひどくて、どうしても寝付かれなくって弱ったくらいですから、暁方になってぐっすり寝込んだのでございましょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「え、本所七不思議の一つの狸囃子でございますよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸囃子というものは一体こうしたものなんだそうで、大概の方は狸退治どころか、ヘトヘトになって帰ってしまいます」「いよいよ面白いな、泥棒が狸だとすると、フン捉まえると狸汁が出来るだろう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿、世の中には、どんな狸がいるか、手前なんかに解ってたまるものか」「そうですかねえ、親分」「ところで番頭さん、その狸囃子は、何刻ほど続くんだネ」「宵から始まって、夜中まで、いやどうかしたら、暁方まで続くでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "井筒屋の前に入られたのは、原庭の物持ち後家で、お紺という四十年配の金貸し、これは幸い怪我はありませんが、用箪笥ごと庭に持出されて、有金三十両ばかり盗られたのを、夢にも知らなかったという話、手口は井筒屋と同じこと、雨戸を切り開いた鋸目から、宵のうちから、狸囃子が聞えたことまで、そっくりその通りです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "庫裡の雨戸の鋸目から、狸囃子が宵から聞えたことまで型の通りです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前は旗本、瀬川壱岐、松倉町の大きい屋敷ですが、身分に恥じて届出もしなかったということで、平次も入って見るわけには行きませんが、手口にも狸囃子にも変りがなかったことは、近所の人が証明しております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
