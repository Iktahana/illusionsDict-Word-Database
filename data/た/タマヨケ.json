        "examples": {
          "standard": [
            {
              "text": "彼は部下を守るために自分が弾除けとなって、上司からの叱責を一身に受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "戦場では、土嚢を高く積み上げて臨時の弾除けの壁を作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「俺を弾除けに使うなんていい度胸だな」と、彼は不敵な笑みを浮かべた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」「ひょっとするとお前は、弾除けのまじないでも受けていて、それでピストルを怖れんのではないかな。",
              "citation": {
                "source": "かもじの美術家",
                "author": "TUPEJNYJ HUDOZHNIK",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまよけの御守りがあるそうで。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっぽうに、たまよけの高い土手がつづいて、その前に白い砂が山のようにつんであり、その砂の中ほどに、三つのまとが立っているのです。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
