  {
    "uuid": "51c0e6db-2130-5b68-a421-b1e0af8b16d0",
    "entry": "胎嚢",
    "reading": {
      "primary": "たいのう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fetal sac",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "はっきりした事を聞きたいのう。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉の順礼　ああ、わしも一目見たいのう。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もったいない、もったいない、こんなもったいない目にあっては、この老人の命を、たった今召されても惜しくはありません、神様もったいのうございます」　為作の感激に充ちた詞は忽ち遮られた。",
              "citation": {
                "source": "放生津物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お諏訪様、もったいのうございます、誠に何とも申しようがございません、お諏訪様、どうかお引とりを願います」　林田は伴れて来ている二人の男を見て嘲笑った。",
              "citation": {
                "source": "放生津物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若太夫　めでたいのう。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "四郎五郎　（相手の源次を失うて、ぼんやり立っていたが）江戸の少長に、この大入りの様子が見せたいのう。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども本来が性質のいい運動だから、三四郎もだいたいのうえにおいて賛成の意を表した。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの妓、この妓があれば見せたいのう。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿の顔が見たいのう。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "御定紋なるかな、御紋なるかなじゃ、馬鹿の顔が見たいのう。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どなたさまやら、なんとおっしゃるだんなさまやら、年寄りの目には……この老婆の目には、生き如来様のように見えまするでござります」「もったいのうござんすよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度服をきた鳩つかいに手をとられて、ミドリは、そのぶたいのうえにあがりましたから、兄の高一はなんだか、胸さわぎがしてなりません。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "早う、京へ入って、人を斬らんと、短銃で、やり損じて、胸につかえた形だ」「斬りたいのう」　伊牟田は、こう云って、刀の鯉口を、一寸くつろげてみた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲り角の所で女はちょっと会釈して、「先生に送っていただいてはもったいのうございます」と云った。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "このだしはたいのうしおなどの時はぜひなくてはならない。",
              "citation": {
                "source": "だしの取り方",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうに、たいのうろこは、一つ一つ、紅い貝がらのように、ぬれて光っています。",
              "citation": {
                "source": "女の魚売り",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもこの歌うたいのうたって歩いた歌を覚えている。",
              "citation": {
                "source": "日没の幻影",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "合爾合姫　そんなにおっしゃって下すって、ほんとうに、もったいのうございます。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くゆっくりと談合して改めて頼むつもりでおる」「頼むなどとは、殿様、もったいのうございます！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればっかりは――それでは、あんまりもったいのうございます」「では、その茶坊主のことなりと、いますこし聞かせてくれぬかな」「はい」「さしつかえあるまい」「なんのさしつかえが――それは、それは、見得坊な、とんと締まりのない男でございました。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは動かず臥ています、「臥ているのも辛うあります、お父さん大抵えらかったいのう」と云っている。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今宵のはたらきあっぱれであった、か弱い少女の身でよく大任をはたしてくれたな、――さすがは菊池伝四郎の妹、まんぞくに思うぞ」「――もったいのうございます」　若菜は悲しげにひれふしていった。",
              "citation": {
                "source": "伝四郎兄妹",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「信次、そのほうの父は、家康にかわってみごとに死んだぞ」「は……」「吉信なくば生きては帰れなかった、吉信こそ家康の命の恩人だぞ」「もったいのうござります」　信次はしずかに拝揖しながら云った。",
              "citation": {
                "source": "死處",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もったいのうござります」　彼には父の顔がみえるように思えた。",
              "citation": {
                "source": "死處",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡き頭殿にも見せたいのう。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
