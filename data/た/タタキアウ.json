    "definitions": [
      {
        "index": 1,
        "gloss": "to strike each other",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "剣道部の練習で、二人は激しく竹刀を叩き合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "試合が終われば、昨日まで拳を叩き合っていたライバルとも固い握手を交わした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "激しい攻防の中、互いの盾を叩き合う鈍い音が響き渡った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "刀と刀でチャンチャンと叩き合うのもあんまり新しいともいえねえぜ。",
              "citation": {
                "source": "銀河まつり",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "グッとほして、お互の肩を叩き合う。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの町内の風呂というのはなんとなく気ぶっせいなもので、無駄口をたたきあう知った顔もないから、濡手拭いを頭へのせてだんまりで湯につかっていると、ふと、こんなモソモソ話が聞えてきた。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蠑※",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「仲よく戒めあい、仲よく尻をたたきあうということは、決してなまやさしいことではない。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋装婦人たちは、なにがそんなにおかしいのか、肩をたたきあうようにして、笑いころげている。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to say (useless things, facetious remarks, etc.) to each other",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "同期同士、酒を飲みながらくだらない軽口を叩き合うのが一番の息抜きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "会議の前だというのに、彼らは相変わらず冗談を叩き合って笑っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "久しぶりに会った友人と、昔のように憎まれ口を叩き合えるのは嬉しいことだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
