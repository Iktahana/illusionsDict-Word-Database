    "definitions": [
      {
        "index": 1,
        "gloss": "pile",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "するとその翌朝になって帳場のそばの溜まりで、ガルソンから、けさ一人の支那人が宿から程遠からぬ所を流れている黄浦江の河岸に惨殺されていた、と云う話を聞かされたのです。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅の花の一輪二輪と綻びるころの朝夕は、空気がまだ本当に冷えびえとしていて、路傍には白刃のような霜柱が立ち並び、水溜まりには薄い氷がはっています。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歳を取ったどすぐろい汚水、死に馬の眼のような水溜まりだった。",
              "citation": {
                "source": "汽笛",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗合自動車は停留所ごとに人溜まりを呑んで、身じろぎも出来ないほど詰め込んだ胃袋を揺す振りながら、ごとごと走った。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべの風の名残りで、仲の町には桜が一面に散って、立花屋の店先には白い花の吹き溜まりがうずたかく積もっていた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は花の吹き溜まりを爪先で軽くなぶりながら、なるべく女の顔を見ないように眼をそらしていた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、背後は池の半分｜跳ね出しだから、池の中へ群衆はひと溜まりもなく陥ち込んでしまった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "熊手を拵えて売ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七と松吉は荒物屋の店を足溜まりにして、かの空地のあたりを見張っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし死体の発見された当時に捜査することができて、もし本人が咳嗽によって血液を排泄したものであるならば血は大きな飛沫となってたくさんあたりに飛び散り、もしまた人事不省あるいは死体となって落ちた場合には血液は口から流れて、街路上に血溜まりとなっていることが発見されたわけです。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "壺に涙が溜まりました。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、巨大な幼児の脳にすり込まれた「ここに生きよ」との神の声は、再び眠りに落ちることも、ぬくもりを求めて仲間たちが肌を寄せ合う溜まりに這い入ることも彼に許さなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この死体の納まっていたトランクは、貨車に逆さまに積まれて来たものらしく、頭部の弾孔から自由に血が溢れ出て、トランクの底に夥しく溜まり、途中ずっと顔全体血液に漬かって来たので、その為めに、ちょっと人相が判らない程崩れかけていた。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が今年はじめてその前を通つて見ると、その木の下はいまはもう公然と便利屋の荷車の溜まりになつてゐて、その車の上に、匂のいい白い花がぽたりぽたりと落ちてゐた。",
              "citation": {
                "source": "四葉の苜蓿",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "足もとの血溜まりに延びている死骸――手代風の男の死骸にも、月光は同じように射していた。",
              "citation": {
                "source": "一枚絵の女",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をいさかっているのか分からないが、ときおり母が溜まりかねたように声を鋭くする。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハーグ den Haag という名前――正しくいえば、S Graven Hage（伯爵の囲い地）――が示す如く、昔は領主（伯爵）の狩猟の足溜まりの場所だったのが、近代に至って政治・外交の中心地となっても、その色彩はずっと褪せなかったものと見える。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸には砂が溜まり、小さい砂丘の如き形をなしたところもあり、増水のときに水に浸つたのが未だ乾ききれずに、自分の穿いたゴム靴が度々ぬかつた。",
              "citation": {
                "source": "支流",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉛の中毒を受けては溜まりません。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "取り尽せないまでも取って御覧なさらなければ気味が悪くって溜まりますまい。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "家にいて例の塩から料理ばかり食べさせられては溜まりませんからね」と思わず出でし愚痴の言葉を門外の人は如何に聴きけん。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉子のような物と共に食べれば玉子の方へ混って胃から腸へ下るため吸収される分量も少くその力も段々弱くなりますがもしもそれだけの唐辛ばかりを空腹時に食べたら溜まりますまい。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは平生の場合であるから汽車の腰掛に行儀好く腰掛けていれば口の辺まで沢山は舞って来ませんけれども箒でパッパッと掃き立てられては溜まりません。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって不潔物を掃除しなくってもなお溜まりませんからよく注意して幾度も掃かなければなりませんが、先日も申上げた通り先ず塩を沢山床の上へ振り撒いて塵や細菌の舞い上らないようにしてそれから掃くとこれほど清潔になる事はありません。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "盲腸の皮の薄い処へその骨が刺さっては溜まりません。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "口へ入れると軽くっていくつ召上ってもお腹へ溜まりません。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……「そう仰ゃられるのをこうして聞いておりますと、只もう胸が一ぱいになってきて溜まりませぬ」そう言って、頭の君はとうとう身もだえするようにその場に顔を伏せた。",
              "citation": {
                "source": "ほととぎす",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主の住居は、浜松町だそうだから、丁度都合のいい足溜まりだ。",
              "citation": {
                "source": "乳を刺す",
                "author": "黒門町伝七捕物帳",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼には涙が溜まり唇は震え、頬の色は蒼褪め果て、まるで全体が怨みと悲しみとで、塗り潰されているようであった。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "２「どうしたら金が溜まりましょう？",
              "citation": {
                "source": "岷山の隠士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくのあいだ、および疫病流行の1832年に、運河のボートや平底船の船溜まりからも取水していた。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            }
          ]
        }
