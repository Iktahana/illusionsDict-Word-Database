        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "家の門のところに、フロック着たへんなおじいさん立っています。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大異はまたへんな奴がきやがったが、今度はどんなことをするだろうと思って、またたきもせずに見ていた。",
              "citation": {
                "source": "太虚司法伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねいあなた、わたしの体はまたへんですよ」　僕は、ウムと答える元気もなかった。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな調子に前夜は空気炎をはいておおいに来客をへこませ、すこぶる元気よく寝についた僕も、けさは思いがけない「またへんですよ」の一言に血液のあたたかみもにわかに消えたような心地になってしまった。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "見てもまた逢ふ夜｜稀なる夢の中にやがてまぎるるわが身ともがな　涙にむせ返って言う源氏の様子を見ると、さすがに宮も悲しくて、世語りに人やつたへん類ひなく憂き身をさめぬ夢になしても　とお言いになった。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことに加宮や菅が鈍感であつたと云ふことは、その鈍感の質が實に下品で露骨で、見るにたへん。",
              "citation": {
                "source": "書翰",
                "author": "大正十三年十一月四日　川端康成宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぞべらも、その撞木娘もともに多く美装した娘であるが、これがまたへんに凄い不思議な謎の味を持っていると思う。",
              "citation": {
                "source": "ばけものばなし",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぬきはまたへんに思って、「うさぎさん、うさぎさん、ぼうぼういうのは何だろう。",
              "citation": {
                "source": "かちかち山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだそんなに経たへんのに、お父つあんが見たら吃驚しやはるやろ。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……母者人がわたへんとこの田ア何處だツしやろちうて、水の引いたごろた石の川原を、泣き泣き探してたがなア。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しんによた、よたア、……」　平七は低い聲で唱ひ出したが、やつと膝の下の煙管を見付け出して一服吸ふと、「旦那、例の件は早速話付けて來まツさかい、わたへんとこへも、まア一遍來とくなはれ。",
              "citation": {
                "source": "父の婚禮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいで、其の投げ足がわたへんとこへ來たんだすかいな。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "……わたへんとこへ町の質屋から流れの知らせが來たら、郵便局で面白がつて、葉書や印紙買ひに來た人に皆見せて笑うてはりましたてな。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二三年一月十四日生田長江月をわび身を佗びつたなきをわびてわぶとこたへんとすれど問ふ人もなし。",
              "citation": {
                "source": "我が一九二二年",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか『骸骨の一』から『骸骨の八』までの箱がならんでいたそうですが、あの中にあったへんな試作物こそ、金属Ｑの兄弟だったんじゃないですかね」「ふーン」　検事は、天じょうのすみを見あげて、ため息ともうなり声ともつかない声を発した。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "角の生えたへんな動物が、この中に入っている。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何分にも、早くこれを使わないと、火星兵団のため、崩壊前の地球を、すっかり占領されてしまうことになるからのう」　と、博士はささやくように低い声で言って、持っていた荷物を開くと、中からピストルに似たへんな器具を取出した。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、腹這ひになり、沖の方に向ひ、小声で唱ふ）波の底に呼ぶ声あり（すると、此の歌の後を受けて、遥かに、女の声が）われあらずば誰かこたへん男　　（恐る恐る半身を起して、此の声に聴き入る）その間に――幕――",
              "citation": {
                "source": "恋愛恐怖病（二場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と信じて、舊をさげすんで新をたたへんとしてゐる。",
              "citation": {
                "source": "新しくもならぬ人生",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "上方の寒暖計はいっぺんに昇華してきて、その暑さがまたへんにねちねちと仮借ない。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "その吉田屋さんで起こったへんなことてえのは何だ」　　　　　　三「あっ、そのこと。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは、へんろ装束に身をやつすことによつて、現実を空想化した……　□浅野仏具店でとゝのへたへんろ装束のうち、手ッ甲だけ間に合はなかつたのを、徳島の宿屋でわけなく縫つてくれた。",
              "citation": {
                "source": "にはかへんろ記",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧しき子らにあたへんものをと人を馳せいまは皆わかちあたへ終りぬ。",
              "citation": {
                "source": "忘春詩集",
                "author": "忘春詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもあたし帰る気にはなれなかった、どんな苦労をしてもいいから、紀州という処までいって、半ちゃんに会うつもりだったの、その話を聞かれたのね、こっちは気がつかなかったけれど、あたしとお爺さんが話しているとき、そばにいたへんなお婆さんが、急にこっちへ話しかけたのよ。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしも兄さんとは一面識だけあるんですがね、今度はまたへんな役廻りを命ぜられたわけです」　その男の言葉は、わざとらしい穏かさを含んでいたためにその一つ一つがわたしの胸を突き刺すように響いてきた。",
              "citation": {
                "source": "三等郵便局",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明智探偵の門前、ちょうど、きのう紙芝居が立っていたへんに、きょうはひとりの乞食がすわりこんで、ほんの時たま通りかかる人に、何か口の中でモグモグいいながら、おじぎをしております。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　またへんな声がひびくと、まるで自動装置のように、こうし戸が音もなくひらきました。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だか知らないが白い衣を著たへんな人が丑の刻参りをして、私に象った人形に呪いと共に瞋恚の釘を打ち込んでいるのではあるまいかという妄想に襲われたりした。",
              "citation": {
                "source": "西隣塾記",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
