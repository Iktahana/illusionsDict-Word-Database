    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to occur repeatedly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それも最初のうちはあやまって堪忍されたのであるが、あまりにそれが度重なるので、ほかの芸人がすべて彼女と一座するのを嫌うようになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンチが度重なるに従って、工人の挙動がおとなしくなってきた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三度行ったら四度、五度、六度と度重なるだろう。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "打下す刃の度重なるほど、刃は遂に水に溶け潰ゆるは必定じゃ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことが度重なるうちに、栄蔵は上目使ひをする癖がついてしまつたのだらう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その変異が、あまり度重なるので、或る日、自分は事務所の人に二階ではどのような騒動が演じられているのかと尋ねたらその事務所の日本人のじいさんは苦笑しながら、あれは学生さんたちがダンスの稽古をしていらっしゃるのですと教えてくれた。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "度重なるうち、下腹が引きつるような痛みに驚いたが、お婆は脱腸の気だとは感付かなかった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "度重なる内、下腹が引きつるような痛みに驚いたが、お婆は脱腸の気だとは感付かなかった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度話をしたい（一同舌をしたい）と柳吉だけが判読出来るその手紙が、いつの間にか病人のところへ洩れてしまって、枕元へ呼び寄せての度重なる意見もかねがね効目なしと諦めていた父親も、今度ばかりは、打つ、撲るの体の自由が利かぬのが残念だと涙すら浮べて腹を立てた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "度重なるに連れて、お茶仲間からは羨ましがられるばかりでなく、お茶の勲爵士としての無上の尊敬を受けるようになる。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は金をいたぶっていたんですが、度重なるうちに色気にころんで来る。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう云ふ問答が度重なる。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも、同じような役に扮して、舌たるい傾城を相手の台詞を云うことが、彼の心の中に、ぼんやりとした不快を起すことが度重なるようになっていた。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには子供はなかったが、夫婦の間に母娘の食客がもとで、いさかいが始まることも度重なるようになった。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤の体は度重なる拷問で青黒いアザだらけになっていた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "で二人共最初の内はそんな恐怖など互いにオクビにも出さない様にしていたんですが、そうした余り気持のよくない事故が度重なるに従って、追々にやり切れなくなって来たんです。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、かようなことが度重なるにつれ、一日も早く都会を去って、自分の良心の命ずるままに、自由に活動の出来る身になりたいものだと思うようになりました。",
              "citation": {
                "source": "安死術",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙なもので、そうしたことが度重なると、「あの先生にかかると、誠に楽な往生が出来る」という評判が立ち、却って玄関が賑かになると云う有様になって参りました。",
              "citation": {
                "source": "安死術",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三度までのお願にはお偉いお方じゃ程に陛下もおだやかに「ならぬ」とばかり仰せられていらせられたが度重なる毎にはお二人のお心が荒立って、力ずくでも　と法王様がついお洩しになったのをお気のつかぬ間に陛下がお伝え知りなされたのが事の始りで今ではもう火をかけた爆薬の様にまことにはや危い御様子じゃとな……。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "度重なる夜々の冒険が、僕の心をひき緊めたのでもあろうか。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "がらくたといっても、度重なる移動のためにあんな風になったので、彼女が結婚する時まだ生きていた母親がみたててくれた記念の品であった。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "がらくたといつても、度重なる移動のためにあんな風になつたので、彼女が結婚する時まだ生きてゐた母親がみたててくれた記念の品であつた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "圭一郎の心の底から深い憐れさが沁み出して來るのであつたが、彼女の涙も度重なると、時には自分達の存在が根柢から覆へされるやうな憤りさへ覺えた。",
              "citation": {
                "source": "業苦",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "數日の後、ルバシュカは無心が度重なるといふので、二人の子供と臨月の妻とを抱へてゐる身の上で馘首になり、圭一郎は後釜へ据ゑられた。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の度重なる怨みはたわいなく釈然とし、晴々として翼でも生えてひら／＼とそこら中を舞ひ歩きたいほど軽い気持であつた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした類の経験が度重なるにつれ、それは次第に私をこの画家から遠ざけた。",
              "citation": {
                "source": "御萩と七種粥",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな隠し事が度重なるにつれて内儀さんと種の仲は一そう親密に結ばれていく。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その見当らない事が度重なるに従って、内供の心は次第にまた不快になった。",
              "citation": {
                "source": "鼻",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "鄭成功は努めて四方の豪傑を招いている際であったので、礼を厚うして彼を※待したが、日を経るにしたがって彼はだんだんに増長して、傲慢無礼の振舞いがたびかさなるので、鄭成功もしまいには堪えられなくなって来た。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "閲微草堂筆記（清）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが第三回、第四回とたびかさなるにつれて、庭園におけるベアトリーチェとの会合は、もはやジョヴァンニの日常生活における偶然の出来事ではなくなって、その生活の全部であった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "ラッパチーニの娘　アウペパンの作から",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
