    },
    "definitions": [
      {
        "index": 1,
        "gloss": "manager (theatrical company)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お目通りに控えさせましたるは、当座の太夫元滝の白糸にござりまする。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんまり異りすぎてるわね」「見世物の三味線でも弾いているのかい」「これでも太夫元さ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、一座の座頭にもわけを話して、座頭と太夫元の二人から六三郎にむかってくれぐれも意見をしました。",
              "citation": {
                "source": "子供役者の死",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "太夫元はまた、万一親分が我慢しても子分たちが承知する筈がない。",
              "citation": {
                "source": "子供役者の死",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の方では六三郎が連れて行かれたというのを聞いて、太夫元は勿論、一座の者も色を変えて心配していたのですが、ともかくも無事に帰されて来たので、みんなも先ずほっと息をつきました。",
              "citation": {
                "source": "子供役者の死",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "太夫元からは鶴ちゃんの病状が病状故若し避病院へでもやられては興行をさし止められるから、とて医者にかけるのを拒まれたり、そのつらさといったら申し様もございません。",
              "citation": {
                "source": "旅役者の妻より",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず町の盛り場に一｜軒見世物小屋をこしらえて、文福茶がまの綱渡りと浮かれ踊りの絵をかいた大看板を上げ、太夫元と木戸番と口上言いを自分一人で兼ねました。",
              "citation": {
                "source": "文福茶がま",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは太夫元がふと恐しい密謀を洩れ聞いたので、前途のある玉之助のために、実入りのよい興行を閉場てしまったのであった。",
              "citation": {
                "source": "竹本綾之助",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年増の女、お銀様にはまだ知己のない人でしたけれども、これはお君のもとの太夫元、女軽業の親方のお角であります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お松さん自身は委員長としてのほかに、太夫元、狂言作者、舞台監督等のすべてを背負って立たなければならないが、事と次第によっては、舞台上の一役をさえ買って出なければならない都合になるかも知れぬ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "山岸｜主税は両国広小路の、例の曲独楽の定席小屋の、裏木戸口に佇んで、太夫元の勘兵衛という四十五六の男と、当惑しながら話していた。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやめが行方不明となった、勘兵衛という太夫元が、何者かに頓死させられた、この二つの意外な事件によって、さすがの彼も心を痛め、この時まであてなく江戸の市中を、さまよい歩いていたのであった。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが裏木戸の辺りまで行って見ると、太夫元の勘兵衛と山岸主税とが、自分のことについて話しているではないか。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにもその男は、両国広小路の曲独楽の定席の、太夫元をしていた勘兵衛であった。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あやめをお八重と間違えたらしく、こう叫んで大手を拡げたのは、太夫元の勘兵衛であった。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時は主馬之進の若党となり、ある時は見世物の太夫元となり、ある時は荏原屋敷の僕となり、又ある時は松浦頼母の用心棒めいた家来となって、悪事をつくした執念深い、一面道化た勘兵衛も、今度こそ本当に殺されたのであった。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは今度の太夫元の見かけのいかめしいにもかかわらず、ヘイコラヘイコラ皆の御機嫌をうかがっては、いくらでも言う通りに大金を貸してくれるところから、まったく岡村を甘く見てしまっていた。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者で駈落ちしたようなものはいなかったか」「ご承知のように、ゆうべは、三座の新狂言名題読みの日で、猿若町は上方役者の乗りこみで、夜っぴてひっくりかえるような騒ぎ、市村座でも、太夫元から役者、狂言方、下廻りまで全部三階にあつまって寄始めの酒宴をしておりましたが、ひとりも欠けたものがございませんでした。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "御代参の乗物",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっこうおもしろくないので、立合いの衆は肝腎の蛇と蟇の喧嘩よりも、太夫元の美しい女をじろじろ見つめているのだが、この女、いずれ後から怪しからぬ薬でも取り出して売りつけようの魂胆と見える。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに江戸で有名な顔役の木甚が太夫元なのだし、それに、日本橋の磯五が力こぶを入れている。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれも無論結構ですが、私ならこうしますな」　思いついた考案を語ったので、仙辰も太夫元も色を消して驚いた。",
              "citation": {
                "source": "奇術考案業",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく、由良は、日本橋｜中洲の芝居の太夫元と結んでそこを自分の定小屋にした。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは一座の太夫元、木戸に居る大年増の亭主で藤六といふ男、無人の一座で、女房は木戸番を、亭主は下座を勤めて居るのだと、後で判りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "人魚の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "四「誰も外へ出た者はあるめえな」「へエ」　太夫元の藤六は、米櫃のお松に死なれた上、うんと儲かつてゐた小屋にケチが付くのを心配して、すつかり萎れ返つて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "人魚の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "太夫元の藤六夫婦は相模のもの、小才の利いた番頭の清次の入智慧で、水心のある美女を二人雇ひ入れ、讃州志度の海女といふ觸れ込みで、この見世物を始めたのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "人魚の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑町の藤六の家といふのは、一種の合宿所で、太夫元の藤六夫婦を始め、一座のお村、番頭の清次、木戸番の百松、それに、死んだお松が一時に、小女を使つて暮して居る家でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "人魚の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうでないと、水へ入つてからマゴマゴして間違ひを起しますから」　とこれは太夫元の藤六です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "人魚の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "一體誰がお松を殺したんでせう」　太夫元の藤六は、少し長い顏を引延して、皆んなの顏を代表します。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "人魚の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "その聲に應じて、ゾロゾロと出て來たのは、太夫元の權次郎、竹乘りの倉松、囃方の喜助、それに女が二三人、朝といつても、かなり陽が高くなつてゐるのに、思ひ切つて自墜落な風を、ズラリと裏木戸に並べたものです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "八五郎の戀",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは一座の太夫元、木戸に居る大年増の亭主で藤六という男、無人の一座で、女房は木戸番を、亭主は下座を勤めているのだと、後で判りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人魚の死",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
