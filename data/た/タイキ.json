[
  {
    "uuid": "687a8df2-401f-56df-8e8c-fc590375e91d",
    "entry": "待機",
    "reading": {
      "primary": "たいき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
