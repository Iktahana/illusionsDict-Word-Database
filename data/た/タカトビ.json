[
  {
    "uuid": "e18d4eec-ea18-5c23-9f34-cf514f08d12e",
    "entry": "高飛び",
    "reading": {
      "primary": "たかとび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
