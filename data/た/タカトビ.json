    "definitions": [
      {
        "index": 1,
        "gloss": "fleeing (to a distant place to avoid arrest, capture, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "高飛びをさせろって態々教えて下すった。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「畜生、風を食らって高飛びしやあがったな。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんと二人で砂浜へ裸足で飛んで出て、かけっこをしたり、相撲をとったり、高飛びをしたり、三段飛びをしたり、ひるすぎからは、ゴルフなるものをはじめた。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「高飛びします、ホームズさん。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの雌雉が危ないので主任に命じて高飛びを助けて落ちないようにしろ。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "危ないので高飛びをしろ。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、白脛か、前脚か、緋縮緬を蹴て、高飛びに追かけたお転婆な若いのが、「のばした、叶わぬ。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "棒高飛びの離れ業を演じて、決して私に面会しようとしない或る慾深屋敷の塀を飛び越えて、何度私の借金申込みの代弁を果したことか！",
              "citation": {
                "source": "三田に来て",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは詮議がだんだんに厳しくなって来たのを覚って、どこへか高飛びをする積りであるらしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄太はまだ帰って来ず、わたくし一人では手に余るかと思ったのですが、うかうかしていて高飛びをされると困るので、まあどうにかなるだろうと、多寡をくくって、わたくし一人でむかいました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は高飛びの身構えをしました。",
              "citation": {
                "source": "僕の帽子のお話",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「高飛びよ」とよし子が言う。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎は高飛びに口を出すのをいさぎよしとしないつもりである。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "高飛びしたものであったら、あとへわざわざ下帯などを洗いすすいで宵干ししておく酔狂者はないはずでしたので、ちゅうちょなく中へ押し入りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんもののむっつり右門にかかっちゃ、おめえたちの下司の知恵ぐれえで、とてもたち打ちできねえんだから、すっぱりどろを吐いてしまいねえな」　ふたりして高飛びしようとした現場を押えられましたものでしたから、ついに強情娘も口を割ってしまいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "高飛びすりゃしたで顔がきいているからすぐにわかるし、また江戸っ子のちゃきちゃきが、そんなぶざまなまねもしめえじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういわれりゃそれにちげえねえが、野郎めまたなんだって、千両もの大金がいるんだろうね」「路銀をこしれえて、どこか遠いところへ高飛びするつもりなんだよ」「えッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "親の金を千両いたぶったのは、むろん高飛びの路銀。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対にまた、これらの品々を未練なく捨てておいて、たいせつな晴れ着だけ着用しながら、二度とここへ舞いもどらぬ決心のもとに高飛びしたかとも判定されるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "下男だか若党だか知らねえが、その七造が判じ絵文の書き手、おくにの誘い手、ふたりでいち早く巡礼に化けてからどこかへ高飛びしようと来てみたのが、道行き相手のおくにめがまだ姿を見せねえので、あの笠を目じるしに掛けておきながら、浅草へでも捜しがてら迎えに行ったんだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "高飛び、素早い逃走、共犯者なし、貴族趣味――こういったやり口が、ミスター・ヴァレンタインを罪からうまく逃れる男として、有名にさせたのだ。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "女ひとりに大勢が出張るほどの事もあるめえが、もし仕損じて高飛びでもされると、旦那のお目玉だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "妖狐伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは才兵衛のふところから相当のまとまった金をうばって、それを路用に高飛びをしたのでは無いかとも思われた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは江戸に恨みのある奴があるから、そいつに意趣返しをした上でなけりゃあ高飛びは出来ねえと……」「意趣返しをする」「それがね、親分」と、松吉はささやいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢抜けをする以上、どうで命はねえに決まっているから、恨みのある三甚を殺らして置いて、それから高飛びをする料簡じゃあねえかと思うのですが……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ、誰の考えも同じことで、藤吉は上方の奴だから京大阪へ高飛びしたものと見て、その方へ手をまわして詮議する。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それは僕の想像にすぎません」「これから君は、どういう風に捜索の歩をすすめてゆくのか」「まず、美容術師の近藤つね方を訪ねようと思います」「その間に、犯人たちは高飛びしやしないだろうか」「大丈夫です。",
              "citation": {
                "source": "深夜の電話",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊夫君はきっと取りかえしてくれるでしょう」「けれど俊夫さんは私や竹内ばかりにかまっていて、あんなエックス光線のようなむだ骨折りをさせたのですから、あの間に犯人はもう遠い所へ高飛びしてしまったにちがいないです」　私は、どう言って木村さんを慰めてよいかに迷ってしまって、黙ったままじっと考えこみました。",
              "citation": {
                "source": "暗夜の格闘",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "走り高飛びは五呎三吋を飛んだ。",
              "citation": {
                "source": "自慢山ほど",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚さんもしばらく会わぬ間に、こうも衰弱したかとびっくりした。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
