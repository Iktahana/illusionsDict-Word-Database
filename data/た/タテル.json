      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to build",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "液體力學を持出す迄もなく、かういふ處へ家を建てるのは考へものである。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾があの土地を買収したのも、妾はこの土地にポール商会のビルデングを建てるつもりなのよ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「で、建てるとなると、やつぱり郊外ね。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「修道院は出來るだけ不毛荒廢の地に建てるのが主義ださうですね。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西欧科学を輸入した現代日本人は西洋と日本とで自然の環境に著しい相違のあることを無視し、従って伝来の相地の学を蔑視して建てるべからざる所に人工を建設した。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画の使命は単に大衆のスター崇拝の礼拝堂を建てるのみではないであろう。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと隅ッこの人目につかんところへ建てるとか、お屋敷からまる見えだし、景色を損じて仕様がない！",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空地では家を建てるのか人びとが働いていた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだよくわからないのだからお墓を建てるのおよしよ」　と止めましたが、花子さんはただシクシク泣いて拝んでいました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "液体力学を持ち出すまでもなく、こういう所へ家を建てるのは考えものである。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "農民達はそんなことに満足してはゐないのですが、家らしい家を建てるまでの運びに行かないのです。",
              "citation": {
                "source": "私有農場から共産農団へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "籔蔭に早咲きの梅の匂う浜田圃の畦を散歩しながら、私は良人が延ばしていた前の妻の墓標を建てることや、珪次の学費の補助のことや、感傷や遠慮を抜いた実質的な相談をしました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年勤労に酬いるのに、何か記念の品をと望まれて、悟も徳もなくていながら、ただ仏体を建てるのが、おもしろい、工合のいい感じがするで、石地蔵を願いました。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "取れもしないところにどうして工場なんか建てるんだ。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言ひかけて櫻木大佐に眼を轉じ『大佐閣下、好機會です、例の一件、此島に紀念塔を建てる事を依頼しては如何でせう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、第一に、其樣危險な深山へ如何して紀念塔を建てるか、外國人の行かれぬ程危險な處へは、吾等だつて行かれぬ筈では無いかと、隙さず一本切込むと、武村兵曹ちつとも驚かない。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "てぐすも飼えないところにどうして工場なんか建てるんだ。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらは比較的に大邸宅が多いので、慌ててバラックなどを建てるものはなく、区劃整理の決定するまでは皆そのままに打捨ててあるので、そこもここも一面の芒原である。",
              "citation": {
                "source": "九月四日",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大工の弟子僕は都會に行き家を建てる術を學ばう。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに夜陰に及び、汝が邪淫の臥床にさへ下馬札を建てるところの聖徒である。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よいとまけ――それは、田舎の人達が、家を建てる前、地かためをするとき、重い大きい槌を上げ下ろしするのに力をあはせるため、声をあはせてとなへる音頭です。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は其頃ピラミッドでも建てる様な心算で居たのであるが、米山は中々盛んなことを云うて、君は建築をやると云うが、今の日本の有様では君の思って居る様な美術的の建築をして後代に遺すなどと云うことは迚も不可能な話だ、それよりも文学をやれ、文学ならば勉強次第で幾百年幾千年の後に伝える可き大作も出来るじゃないか。",
              "citation": {
                "source": "落第",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は家を建てる事が一生の目的でも何でも無いが、やがて金でも出来るなら、家を作って見たいと思って居る。",
              "citation": {
                "source": "文士の生活",
                "author": "夏目漱石氏−収入−衣食住−娯楽−趣味−愛憎−日常生活−執筆の前後",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ茶店を建てるときにも、ずいぶん烈しい競争があったと聞いている。",
              "citation": {
                "source": "富士に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人逢うと、葛西善蔵氏の碑を、郷里に建てる事に就いて、内談する。",
              "citation": {
                "source": "パウロの混乱",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい大きい沼を掻乾して、その沼の底に、畑を作り家を建てると、それが盆地だ。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やあ覚えて居よ此のつそりめ、他の情の分らぬ奴、其様の事云へた義理か、よし／＼汝に口は利かぬ、一生｜溝でもいぢつて暮せ、五重塔は気の毒ながら汝に指もさゝせまい、源太一人で立派に建てる、成らば手柄に批点でも打て。",
              "citation": {
                "source": "五重塔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢さんのお志、私、私なんざ、今頂いた御祝儀を資本にして、銀行を建てるんです。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しそれにしても、現在に於て、谷君が歌といふものを自己表現の唯一若くは最良の方法と信じてゐること、及びその作つた歌を輯めてこの集を出版するといふことを自分自身の家を新しく建てる人の熱心を以て計畫してゐるといふことは、事實である。",
              "citation": {
                "source": "歌集「嘲笑」序文",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと九尺二間を建てるにしても、場所がいまの田畝ではどうにもならず。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
