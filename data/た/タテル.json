[
  {
    "uuid": "2056dcd1-cfa2-5566-a319-808627ea4b6e",
    "entry": "建てる",
    "reading": {
      "primary": "たてる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
