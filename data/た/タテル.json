  {
    "uuid": "a55bcbad-21e5-5342-9bf0-b7661e9573a2",
    "entry": "閉てる",
    "reading": {
      "primary": "たてる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to shut",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "障子を閉てる音に母親が眼を覚まして、「清三かえ？",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗助は弟に夕方になつたら、ちと洋燈を點けるとか、戸を閉てるとかして、忙しい姉の手傳でもしたら好からうと注意したかつたが、昨今引き移つた許のものに、氣まづい事を云ふのも惡からうと思つて已めた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "晝も留守を置かずに濟む山寺は、夜に入つても戸を閉てる音を聞かなかつたのである。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "襖を閉てるとき、どうもこの部屋の寒い事と云った。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "まアよし……ア、今夜も戸を閉てるのを忘れて居た。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "『恁那に遅くまで鶴子は何をして居るのだらう』と思つたが、こちらの戸を閉てる音に鶴子も障子開いて閉て始める。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓を閉てる前に自分はちょっと頭を下げて、飯場へ引返した。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ閉てるごとに、行く人と、送る人の距離はますます遠くなる。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗助は弟に夕方になったら、ちと洋灯を点けるとか、戸を閉てるとかして、忙しい姉の手伝でもしたら好かろうと注意したかったが、昨今引き移ったばかりのものに、気まずい事を云うのも悪かろうと思ってやめた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼も留守を置かずに済む山寺は、夜に入っても戸を閉てる音を聞かなかったのである。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "返事をしないとしたらあの男はひどく残念がるのだし、しまひには腹をたてる。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹をたてるのは勝手だとしても、彼に腹を立てられると方々で事が面倒になるのだ。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "音をたてると私の心が揺れる、目が薄明るい地平線を逐ふ……黒々と山がのぞきかかるばつかりだ――失はれたものはかへつて来ない。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞬きは怨めしさうにながれながら、パチンと音をたてるだらう。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにかかわらずそういう計画をたてるというのは現代の為政の要路にある人達が地を相することを完全に忘れている証拠である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と書きたてるほど大げさなことでもないのに、それをそれほど有名にしたのは、まつたく、その男の――つまり、その歴史の時間での先生である溝口文学士の性格によるのでした。",
              "citation": {
                "source": "ある男の死",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、早くしろ、早く」　と急きたてる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かが私を追ひたてる。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからともよは湊がいつまでもよそばかり見ているときは土間の隅の湯沸しの前で、絽ざしの手をとめて、たとえば、作り咳をするとか耳に立つものの音をたてるかして、自分ながらしらずしらず湊の注意を自分に振り向ける所作をした。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段、万国の男女が酔いどれてはやしたてる。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんまり追いたてるから、なお分らなくなっちまったんだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の野路をガタ馬車が走る、野は菜の花が咲き亂れて居る、フワリ／＼と生温い風が吹ゐて花の香が狹い窓から人の面を掠める、此時御者が陽氣な調子で喇叭を吹きたてる。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母と、だぶ／＼の詰襟の支那人が、咎めたてる巡警をつきのけて、いきなり事務室へとびこんで来た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と杜氏は与助を追いたてるようにした。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなその葉がチラチラ光ってゆすれ互いにぶっつかり合って微妙な音をたてるのでした。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（お前達は一切の音をたてるな。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼女達のたてる物音が即ちその存在であつた、夫なる者の生命も同時に消えてしまつたのである。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "原作に於て、この部分は、實に霹靂を聞く如き大音響をたてる所である。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「シラノが月へ行く方法を並べたてるところがありますね。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ夜中になって変てこな物音をたてる生物になってしまったのである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
