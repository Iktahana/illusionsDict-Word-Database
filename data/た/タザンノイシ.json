    "definitions": [
      {
        "index": 1,
        "gloss": "lesson learned from someone's else mistake",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
