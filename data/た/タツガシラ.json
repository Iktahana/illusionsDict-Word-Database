[
  {
    "uuid": "5ec1379d-bac1-5749-9611-cf6abb9b6afc",
    "entry": "龍頭",
    "reading": {
      "primary": "たつがしら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "something in the shape of a dragon's head (esp. a helmet crest)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "部屋の隅の瀬戸物の洗槽に水道の龍頭から滴る水音だけがさやかに聞えた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "助手の一人は解剖臺に取りつけてある龍頭をひねると、水は氷柱でもつるしたやうに音もなく磁器製の解剖臺に落ちて、小さな幾條かの溝を傳つて、中央の孔から床の下に流れて行つた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の關係もない物質がごつたかへして秩序もなくころがつてゐる間に、龍頭から絶えず流れ出る水道の水だけが、たゞ一つすがすがしい感じを彼れに與へて音も輕く涼しかつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音と、龍頭を流れ下る水の音とが、森閑とした眞夏の暑い沈默を靜かに破つた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "太綱の一端を前齒に銜へてする／＼と竿を上りて直に龍頭に至る。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍頭また鷁首にして、碧丹、藍紅を彩れる樓船なす御神輿の方が、います靈とともに、人の波を思ふまゝ釣るのである。",
              "citation": {
                "source": "祭のこと",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "莊惠觀魚の談このかた、魚を觀るのは長閑な好い情趣のものに定つてゐるが、やがて割愛して、今度は艇を捨て、自動車で龍頭の瀧へと向つた。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍頭の瀧もまた別趣を有してゐる好い瀧である。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんまりで演れば丁々発止の龍闘虎争の息使いも渋い写実で凄かったろうに、下手に鳴り物沢山入れて、野暮な駄洒落の啖呵に風流を気取ったばかしに、龍頭蛇尾に終ってしまったとは、いかにもオッチョコチョイめいて、思えばはしたない。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "横濱までは汽車に乘り、龍頭より小舟に乘りて、屏風ヶ浦をわたる。",
              "citation": {
                "source": "杉田の一夜",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "一里四方の戰場ヶ原將に盡きむとする頃、右側に龍頭瀑を見る。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は奈良興福寺にある名高い木彫の天灯鬼が、左肩に載せた灯を左手で支えて、ぐっと身体をひねっている姿や、その相手の龍頭鬼が龍を首に巻きつかせたまま、灯を頭に載せ、両手を組み、白い眼をむいているのを見るのが好きだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉をちりばむる金の冠、龍頭を彫りたる劍太刀の花いろ衣を透きて見ゆるあてなる姿を君や戀ふる。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面の水草が取付いてそよいでおりますので、その大きさは確かに判りませぬが、鐘は横さまに倒れているらしく、薄暗いなかに龍頭が光っておりました。",
              "citation": {
                "source": "鐘ヶ淵",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "藻のなかに龍頭が光っていたなどというが、あいつも貴公とおなじように魚の眼の光るのでも見たのではないかな。",
              "citation": {
                "source": "鐘ヶ淵",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす暗いなかで、その頭を龍頭と見ちがえるのはありそうなことだぞ。",
              "citation": {
                "source": "鐘ヶ淵",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍頭の瀑、つづいてさびしい戰場ヶ原、そこには草花が多く、夏は一面美しい毛氈を敷いたやうに見えた。",
              "citation": {
                "source": "日光",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、いつもしまいには自分の弱味で、初め反対したことにも賛成し、馬鹿を利口と言い、果ては他人の笛につれて、この上もなく上手におどりだす――要するに、龍頭蛇尾におわるのである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "壺にしても龍頭壺など稱するものにはいろ／＼の裝飾がしてある、型で押した文樣を貼付けた上から釉をかけたものもある、青、飴、白、コバルト、いろ／＼の釉がいろ／＼の手法に依つて裝飾されてゐる。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "折田がそれでも十二時すぎるで」　母親のその顔付から目をそらして腕時計の龍頭をまきながら源一が立ち上るにつれて、お茂登も包みをひきよせた。",
              "citation": {
                "source": "その年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "行く事里許、榛莽の中遙に一瀑の龍頭を爲したる奇岩より落下するあり。",
              "citation": {
                "source": "日光山の奧",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処はどの店を覗いて見ても、銅の香炉だの、埴輪の馬だの、七宝の鉢だの、龍頭瓶だの、玉の文鎮だの、青貝の戸棚だの、大理石の硯屏だの、剥製の雉だの、恐るべき仇英だのが、雑然とあたりを塞いだ中に、水煙管を啣えた支那服の主人が、気楽そうに客を待ち受けている。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたまはかたへに避きて、『信』の井の龍頭より、なほ、噴く水にうるほひ享けて跣足、踵、洗ひ淨むれ。",
              "citation": {
                "source": "春鳥集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鐘の龍頭に、紅白だんだらの綱が付けてございまして、その端は、しっとりと、舞台に垂れ下り、さきほども申しました、桜の木の幹に結いつけてあるのでございます。",
              "citation": {
                "source": "京鹿子娘道成寺",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、　※龍頭に手を掛け飛ぶよと見えしが、引きかずいてぞ失せにける　と、この文句で、白拍子の岩井半四郎さまは、鐘の中へお入りになったのでございます。",
              "citation": {
                "source": "京鹿子娘道成寺",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷徹な峡間は、湯滝の下に苔生した天然林を抜け出して、戦場ヶ原を幾曲がり、龍頭の滝を落ちて中禅寺湖へ注いでいるが、ここは渓流魚釣りの練習場として、まことに好適の流れである。",
              "citation": {
                "source": "雪代山女魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵南多摩郡元八王子村なる諏訪神社の獅子頭は、古来龍頭と呼ばれて二本の長い角が斜めに生えているので有名である。",
              "citation": {
                "source": "奥羽地方のシシ踊りと鹿供養",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕をのばすと釣鐘の龍頭、グッと掴んで引き下ろした。",
              "citation": {
                "source": "二人町奴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍頭を踏まえて突っ立ったが、左右を見比べると両手を拡げ、さてそれから云いだした。",
              "citation": {
                "source": "二人町奴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
