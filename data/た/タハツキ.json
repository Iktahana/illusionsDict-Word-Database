        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分の世界を忘れてゐた私は、時刻と云ふ聲にまたはつきりと我に歸つた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大きな影は、大氷塊の向うに隠れたり、あちこちが破れたり、またはつきり現はれたりして、後れずについてくる。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上のようなところまで、この考えかたはつき進んでいくのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから次には當然鼻すぢの通つた鼻孔の張つたはつきりした鼻が來る。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢繼早の質問が來てもあなたは落着いたはつきりした返辭をした。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
