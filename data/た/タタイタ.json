        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかたなく傍へ寄っていって、軽く肩をたたいた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、一番早く私の扉をたたいたのは、家主の娘さんでした。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行機や潜航艇の所在を探知する方法について絶えず軍務当局から相談を受け、また一方では国民科学研究所と航空研究顧問委員会の軍事的活動の舞台でも主役を勤めていたので、その頃の彼の書斎は机の上も床の上もタイプライターでたたいた報告書類などで埋まっていた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室の踊場のジャズ・バンドが気狂のように太鼓をたたいた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "空はリキュール酒のようなあまさで、夜の街を覆うと、絢爛な渦巻きがとおく去って、女の靴の踵が男の弛緩した神経をこつこつとたたいた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主は夜遅く帰って来て戸をたたいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "む茶くちゃにたたいたり走らしたりしちゃいけないぞ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日分の灸治を終わって、さて平手でぱたぱたと背中をたたいたあとで、灸穴へ一つ一つ墨を塗る。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「たたいたらいいんですよ。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　酔った女をつれて、夜おそく宿の門をたたいたとあれば、だいいち新進作家としての名誉はどうなる、死んでもそのようなさもしいことはできない。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした自分自身を淋しくアザミ笑いながらパチパチと眼をしばたたいた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "オイオイ」　と言うて耳を澄ますうちに、今たたいた雨戸が外側へバッタリと外れかかるのを、良助は慌てて両手で受止めながら小舎の中を覗き込んだ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は煙草をのんではしきりに吐月峰をたたいた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今年は何台卵を孵えすんだね」「知らねえ」　母がさすがに気をかねて、「知らねえはずはあるめえさ」　と口添えすると、純次は低能者に特有な殺気立った眼を母の額の辺に向けて、「知らねえよ」　と言いながら持ち合わせた箸で食卓を二度たたいた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあのセンダードの市の大きな西洋造りの並んだ通りに、電気が一つもなくて、並木のやなぎには、黄いろの大きなランプがつるされ、みちにはまっ赤な火がならび、そのけむりはやさしい深い夜の空にのぼって、カシオピイアもぐらぐらゆすれ、琴座も朧にまたたいたのです。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なげしの上の神棚の灯がちよつとまたたいた。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこであまがえるは、みんな走り寄って、とのさまがえるに水をやったり、曲った足をなおしてやったり、とんとんせなかをたたいたりいたしました。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　夫人は黙って聞くうちに、幾たびか目をしばたたいた。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と女中が向うを向く時、捻平も目をしばたたいたが、「ヤ、あの騒ぎわい。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七は再び木魚をたたいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "この安ちゃんが朝顔屋敷のお出入りなんですよ」と、お六はからかうように笑いながら、連れの女の背中をたたいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　小田は思わず、「あ、そうだった」　と、膝をたたいた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "消防も半鐘をたたいたので、近くの町や村々の消防や蒸気ポンプがわれもわれもと駈け付けましたが、何しろ騒ぎが大きいのと、どこの往来も人で一パイなので近寄ることが出来ません。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "文作が足萎え和尚の寝ている方丈の雨戸をたたいた時には、もう夜が明けはなれていたが、和尚が躄りながら雨戸を開けて「何事か」と声をかけると、文作は「ウーン」と云うなり霜の降ったお庭へ引っくり返ってしまった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所の人達や、警官や、医者みたいな連中が、みんな眼をしばたたいたり泣いたりしているらしいのに、私一人だけはツクネンと坐ったまま、呑気そうに口をポカンと開いた親父の口もとを眺めて「咳が出なくなったから楽だろう」なぞと思ったりしているのが何となくバツが悪かった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その新聞を持って、まだ薄暗いうちに飛び込んで来たのが悪魔の叔父で、親父の仏様の横に並んで寝ていた私を大きな声で「愛太郎愛太郎」と呼び起しながら、壊れかかった表の扉をたたいたのであった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "深夜、薬屋の戸をたたいた事もありました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」佐野君は、こぶしをかためて、テーブルをどんとたたいた。",
              "citation": {
                "source": "令嬢アユ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、まのわるい思いがして、なんの符号であろうか客車の横腹へしろいペンキで小さく書かれてあるスハフ 134273 という文字のあたりをこつこつと洋傘の柄でたたいたものだ。",
              "citation": {
                "source": "列車",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
