        "examples": {
          "standard": [
            {
              "text": "「この窓の縦幅、既製品のカーテンだと少し足りないみたい。オーダーメイドにする？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "Webサイトのデザイン案を確認したが、ヘッダーの縦幅をもう少し狭くした方がコンテンツが引き立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "荷物を送るために箱のサイズを測ったら、縦幅が規定を数センチ超えていて送料が上がってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "額縁の横幅約二尺八寸、縦幅一尺八寸はあろうと思われる。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "水のなかで体の方向がひっくり返ったかと思うと、その次の瞬間の彼女は、すでにプールの縦幅のなかばにさしかかっていた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
