        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祭りの出し物で、見事なたらい回しの技が披露された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は子供の頃からたらい回しの練習をして、大会で優勝した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "観客は、熟練のたらい回しの妙技に拍手喝采を送った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼が捕えられたのが真夜中であったとすれば、十字架につけられるまでわずかに九時間であり、この間、アンナス、カヤパ、ピラト、ヘロデ、またピラトとたらい回しにされて、不法の裁判を受け、侮辱と虐待の中に死んだ。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
