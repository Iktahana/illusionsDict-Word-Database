          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "資料は会議の参加者全員にたらい回しで確認された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この本は人気があるので、友人たちの間でたらい回しになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "回覧板は町内会でたらい回しにされ、重要な連絡事項が伝えられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
