    "definitions": [
      {
        "index": 1,
        "gloss": "dropping out of school",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「かやうな都会の私立中学にあつては、編入者や退学者が大変多いために、生徒の愛校心は至つて乏しいのである。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "退学処分に遇ふ生徒なども少くなかつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四歳のとき Harrow に入ったが、二年級になってから胸の病を得て退学した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が規則で縛って置きにくい性質なので、十五の時にとうとう幼年学校から退学してしまったそうです。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして姉も弟も初めのうちは小学校に出していたのが、二人とも何一つ学び得ず、いくら教師が骨を折ってもむだで、到底ほかの生徒といっしょに教えることはできず、いたずらに他の腕白生徒の嘲弄の道具になるばかりですから、かえって気の毒に思って退学をさしたのだそうです。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ退学にならずにいません。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、奴さんはその工場でたった一人の大学出だということも社長のお眼鏡に適ったらしいんだが、なに、奴さん大学は中途退学で、履歴書をごまかして書いたんですよ。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで鉄拳制裁をうけ、そしてそのことが教師に知れて諭旨退学を命ぜられた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "退学処分になったばかりに母親の肩身が急にせまくなったと思うのである。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一学期もすまぬ間に、彼は自ら進んで退学届を出した。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "化粧が終ると、エミ子は、親類中で爪弾きをされている従兄の、また従兄位に当る音楽学校を退学されて、今は銀座の蓄音器屋の嘱託しているピアニストの雄吉君のところへ電話をかけました。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の研究を論文にでも纏めれば世界的に金魚学者たちの参考になるんだからなあ――」　まだ未練気にそう云ってる不機嫌の教授に訣れを告げて、復一は中途退学の形で東京に帰った。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリア文学雑誌「種｜蒔く人」の同人で二十五歳、病弱な為めＷ大学中途退学の青年だが病身で小柄でも声が妙にかん高で元気に話す男だ。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄弟は父が現代教育の方針に不満といふ理由で、一人は中学を、一人は高等学校を、途中から退学させられて、通つて来る二三人の家庭教師に就かされてゐるが、実は父が家庭に於ける享楽生活に手不足を来すのを、父は極力嫌つたためでもあつた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、学校からの帰途、あっさり退学を決意した。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝大の経済科を中途退学して、そうして、何もしない。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝶子さん、君も、旨を諭して任意退学だろうが、君にはそんなことは大した苦痛でもあるまい。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく退学届を出した。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡田は卒業の期を待たずに洋行することに極まって、もう外務省から旅行券を受け取り、大学へ退学届を出してしまった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八九六（明治二十九）年　春、神経衰弱のために水戸中学校を四年で退学。",
              "citation": {
                "source": "長塚節句集",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「高等学校の制服はあるでしょうね」「はあ、しかし、もう学生じゃありませんから」「なぜ退学したのですか？",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた些かの未練も残さずに中途で退学してしまった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "中途退学だが、彼女は広島県のある女学校へ通っていたことがあり、その時可愛がってくれた先生はアララギ派の歌人だった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君は北浜の相場師の娘だったが、家が破産して女専を二年で退学し、芸者に出なければならぬ破目になっていたところを、世話する人があって天辰へ嫁いだのだった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一思いに退学しようと思ってもこんな事をいわれれば未練が残り候う。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "退学ということが両親兄弟を極端に失望せしめ、一家将来の生活上に困難を来たし、一方には自分の栄誉それにともなう希望などが、根底より破壊せらるるように考え来たり候えば、胸の痛みたえがたき思い致し候う。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と一喝された者や、あまりに愚かな質問を発して「君は今日限り退学した方が好いでせう。",
              "citation": {
                "source": "文学とは何ぞや",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の暮の試験に大｜淘汰があって、どの級からも退学になったものがあった。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わかんないかな、あたいの躯だよ」と栄子は動物的に張りきった胸を叩いてみせた、「そんなこと云えばあたいがくしゃっとまいってさ、くらがえしてでも三〇〇ぐらいのお金は拵えるだろう、って見当つけて来たんさ、子供｜騙しだよまったく」　そのときは栄子自身も不景気で、にっちもさっちもいかない状態だった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁寧な言葉遣いのときには、好ましい女性らしさで彼女のぜんたいがくるみ込まれる。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
