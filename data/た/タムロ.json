        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その後柳樹屯の衛戍病院とかに行つたさうだ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを左へ曲るとウンテルデンリンデンですぐ右側の角がツォイクハウス、次が番兵屯所、その次が大学である。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎坊附近の、黄紅朱樺の疎らな短木の中を、霧は幾筋にもなって、組んず、ほぐれつして、その尖端が愛鷹山の方向へと流れて行く、振り返れば、箱根｜火山彙には、雲が低く垂れて、乙女峠から金時山の腰へかけて、大河の逆流するばかり、山と山との間は、幾つにも朝雲が屯ろして、支流が虚空の方々に出来る。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "救護隊の屯所なども出来て白衣の天使や警官が往来し何となく物々しい気分が漂っていた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大戦中ターリングは軍隊の駐屯所となった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "片桐部隊の屯する○○に至る。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "中隊はラープの彼方に駐屯してゐた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの窓は、眞赤に燃えながら、その光に照らし出された廣野に屯してゐる敵陣のなかへ叫んでゐるのだ。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民党上海駐屯の武官、フ・ハン・パウはノラと恋愛の上昇のために自殺して死んでしまった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "聯隊が駐屯している町も、病院がある丘も、後方の山にさえぎられて見えなかった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、老人の眼つきと身振りとで、老人が、彼等の様子をさぐりにやってきたと疑っていることや、町に、今、日本兵がどれ位い駐屯しているか二人の口から訊こうとしていることが察しられた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵卒達は、パルチザンの出没や、鉄橋の破壊や、駐屯部隊の移動など、次から次へその注意を奪われて、老人のことは、間もなく忘れてしまった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、葬列が村の屯所の前にさしかゝった時、状態が急に変化した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小山の、軍隊の駐屯に対する感謝と、自分のやり方に対する、得意さは、一日々々顕著になっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "南軍の駐屯している区域にさしかゝると、かねて手に入れておいた、青天白日旗を自動車に立てる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、愉快な、幸福な気分を味わいながら駐屯地へ向って引き上げて行った。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜田たちの中隊は、※昂鉄道の沿線から、約一里半距った支那部落に屯していた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "砲兵観測隊（ばかばかしきよかの邑は、　　よべ屯せしクゾなるを）ましろき指はうちふるひ、　　　銀のモナドはひしめきぬ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "市場の辻の消防｜屯所夜でも昼でも火の見で見張りぐるぐる見回る　　北は………　　南は………　　西は………　　東は………どっかに煙はさて見えないか。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "且つ道庁の官吏は果して沿岸｜何れの辺に屯して居るか、札幌の知人｜何人も知らないのである、心細くも余は空知太を指して汽車に搭じた。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "バードが極飛行から無事に屯営に帰って来たのを皆が狂喜して迎え、機上から人々の肩の上にかつぎ上げて連れてくる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窟の前に屯していた警部等も、金の兜には驚いた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "登山してから三日目の夕刻、一同は唯ある大樹の下に屯して夕飯を焚く。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "よって瑛を逮捕し、都督｜宗忠をして兵三万を率い、及び燕王府の護衛の精鋭を忠の麾下に隷し、開平に屯して、名を辺に備うるに藉り、都督の耿謝貴に勅して、厳に北平の動揺を監視しせしむ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "都指揮使｜謝貴は七衛の兵、并びに屯田の軍士を率いて王城を囲み、木柵を以て端礼門等の路を断ちぬ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "景隆が大軍功無くして、退いて徳州に屯す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸｜乃ち呉傑、平安をして西の方｜定州を守らしめ、徐凱をして東の方｜滄州に屯せしめ、自ら徳州に駐まり、猗角の勢を為して漸く燕を蹙めんとす。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "王遂に臨清に至り、館陶に屯し、次で大名府を掠め、転じて※上に至り、済寧を掠めぬ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "将門は一人で、官職といへば別に大したものを有してゐるのでも無い、たゞ伊勢太神宮の御屯倉を預かつて相馬｜御厨の司であるに過ぎぬのであるに、父の余威を仮るとは言へ、多勢の敵に対抗して居られるといふものは、勇悍である故のみでは無い、蓋し人の同情を得てゐたからであつたらう。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "村のたむろ所には巡警のたまりがあった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
