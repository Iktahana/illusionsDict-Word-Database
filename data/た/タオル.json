[
  {
    "uuid": "48f2852e-2ea4-5706-b9a2-e91c4b13667f",
    "entry": "タオル",
    "reading": {
      "primary": "タオル",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "towel",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "色々の手拭やタオルの洗濯したのがその上に干し並べてある。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "発汗剤のききめか、漂うような満身の汗を、妻は乾いたタオルで拭うてくれた時、勝手の方から何も知らぬ子供がカタコトと唐紙をあけて半分顔を出してにこにこした。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "タオルや下帶の他に唐詩選、上下二卷をいれてやりました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾いたタオルがいる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして濡れたタオルを繰り返した。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人はまた「ほかの客にはタオルを持って来るのに、わしには持って来んじゃないか」とも言っているようである。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "媚びず怒らず詐らず、しかも鷹揚に食品定価の差等について説明する、一方ではあっさりとタオルの手落ちを謝しているようであった。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも今この眼前の老人の「七十銭」と「タオル」の事件に際して再び如実に思い出したのであった。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろもうアイスクリームの冷たくないのに屈辱の余味を帯びた憤懣を感じ、タオルの偶然な差別待遇にさえ世に捨てられでもしたような悲しみと憤りを覚えることの可能な年齢に近づきつつあるのかもしれない。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "リヤカアに、サイダアの空瓶を一ぱい積んで曳いて歩いている四十くらいの男のひとに、最後に、おたずねしたら、そのひとは淋しそうに笑って、立ちどまり、だくだく流れる顔の汗を鼠いろに汚れているタオルで拭きながら、春日町、春日町、と何度も呟いて考えて下さいました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青いタオルの寝巻に、銘仙の羽織をひっかけて、ベッドに腰かけて笑っていた。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらの方では、まるい銀の頭を、ぴかぴかにみがきあげられたタオルむしが、ひとりで、ジューン、ジューンと湯気をふいていました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔にのせられたのは、むしタオルでありました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小平さんはタオルをのけると、太い筆のようなもので、せっけんのあわを松吉の顔にぬり、かみそりで、ひたいぎわからそりはじめました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな主人に巻き添いなんぞ食いたくないから、みんなタオルやはんけちや、よごれたような白いようなものを、ぐるぐる腕に巻きつける。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから湯殿のタイルの上に落ちていた赤い古タオルを拾い上げてシッカリと絞り切ったのを片手に提げて、普通のお客のように落ちつきはらいながら廊下に出ると、ちょうど向うから来かかった新米らしい若い女中にニッコリして見せた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁寧なのになると、流しが終わってもいつまでもそばについていて、最後にタオルまですすいでくれる。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてタオルでポチのからだをすっかりふいてやった。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍはタオルを頭からかぶってどんどん飛んで行きました。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、妹に帽子を脱がせて、それを砂の上に仰向けにおいて、衣物やタオルをその中に丸めこむと私たち三人は手をつなぎ合せて水の中にはいってゆきました。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち三人は濡れたままで、衣物やタオルを小脇に抱えてお婆様と一緒に家の方に帰りました。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてわが親しき所有品は、タオル一本。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたいけなものが欲しいときもあの小魚の姿を見ると、どうやら切ない心も止まる」　老人は遂に懐からタオルのハンケチを取出して鼻を啜った。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ、ぢやぶ／＼、それ、ぢやぶ／＼、」と髯旦は傍で、タオルから湯をだぶり。",
              "citation": {
                "source": "錢湯",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "髯はタオルから湯をだぶり。",
              "citation": {
                "source": "錢湯",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――きみの前だが、その時タオルも棄てたから一糸も掛けない、浴後の立姿だ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ワイシャツを洗っちまうから」　小田は不器用な手つきで、ごしごしとワイシャツを洗っていたが、やがて、タオルを絞るように水を絞って、「――やもめは辛いや」　と言いながら、鶴雄をうながして六畳の部屋へ案内した。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の間に破れた靴下とタオルを一緒にまるめて置いてあるという始末で、鶴雄は顔まけしてしまった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯槽にタオルを浸けて、「えらい温るそうでんな」　馴々しく言った。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
