          "literary": [
            {
              "text": "将来モスリンの後を継ぐにしても、それまでは中央で叩き上げる方が宜いと言った。",
              "citation": {
                "source": "村一番早慶戦",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は月給五十円で店の見習から叩き上げることになった。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎安国をたたきあげるが早いか、そのまま振りかぶった稀剣乾雲、左腕、うなりを生じて真っ向から栄三郎の面上へ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "（巴里の魔窟に住むで亂倫不逞の生活をして、弱い性格をくろがねのやうにたたきあげるといふ言葉は、幾度か彼の口からでた。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
