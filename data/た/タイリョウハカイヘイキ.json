        "examples": {
          "standard": [
            {
              "text": "国連の査察団は、その国に隠された大量破壊兵器が存在しないか調査を続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "核兵器や生物兵器は、一瞬にして多くの命を奪う恐ろしい大量破壊兵器だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大量破壊兵器の拡散を防ぐことは、世界の平和と安全を守るための国際的責務である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「人間的な気持ちを持っていた人たちが、なぜあのような大量破壊兵器の開発に全力で取り組むことができたのか」　監督のジョン・エルスはそう問題を設定し、ねじ込むように対象に迫っている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
