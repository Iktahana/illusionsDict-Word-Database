[
  {
    "uuid": "848af1c8-26aa-55a4-bcd5-adb46ef1302b",
    "entry": "隊伍",
    "reading": {
      "primary": "たいご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rank (of troops)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "混亂が隊伍の中に起つた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、途切れに小隊の後を追つて漸くもとの隊伍に歸つた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "露西亜の兵隊が、隊伍を組んで歩いている。",
              "citation": {
                "source": "戦争について",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼等は、隊伍を直して城門にむかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王の軍は塹塁を為らず、たゞ隊伍を分布し、陣を列して門と為す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿崎隊は新手を入れかえ入れかえ無二無三につき進み切り立てたため、さしもの典厩隊も苦戦となり隊伍次第に乱れるにいたった。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "全隊辛うじて木葉川を渉って、川床で始めて隊伍を整える事が出来た。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大岩山襲撃の策が決ると、四月十九日夜盛政を始めとして、弟勝政、徳山五兵衛尉、不破彦三、山路将監、宿屋七左衛門、拝郷五左衛門以下八千騎、隊伍粛々として、余呉の湖に沿うて進んだ。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "隊伍をなせる兵士もこれに倣へり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "太都夫は右左に號令した隊伍を整へ、衆に對つて丹濃が使命のあらましを告げ、今私部主從三人は彼の木立の蔭に來り居る。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "就いて想い出すはベロアル・ド・ヴェルヴィルの『上達方』三十九章にアルサスのある地の婦女威儀を重んずる余り七日に一度しか小便せず、火曜日の朝ごとに各の身分に応じ隊伍を編み泉水に赴き各その定めの場について夥しく快げにかつ徐かにその膀胱を空くる。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に視力を失って単なる記憶に頼るほかなくなってからでも毫も混錯しないで、一々個々の筋道を分けておのおの結末を着けたのは、例えば名将の隊伍を整えて軍を収むるが如くである。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "イワノウィッチは、隊伍のうちに加わりながら、大きい良心の呵責を担っていた。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、岡山口から天王寺口にかけて、十五万に余る惣軍は、旗差物を初夏の風に翻し、兜の前立物を日に輝かし、隊伍を整え陣を堅めて、攻撃の令の下るのを今や遅しと待っていた。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この青年の隊伍に紛れ込んだ先生は、歩調においてすでに時代錯誤である。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち直る暇もなく、そのまま隊伍を潰して、横へそれると、実りかけている田の中へ、ドタドタと入り込んでしまった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、滝本達の一行が、そんな装ひで隊伍を組んで行くところを反つて意味あり気に打ち眺めて、「仲々、何うも御精が出ますな！",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "長槍兵の一隊が青、赤、黄、色とりどりの三角旗を翻して隊伍堂々と列を組んで行く。",
              "citation": {
                "source": "変装綺譚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日とか十五日とかの祝日に彼等一同が隊伍を組んで、村里を目がけておし寄せる光景は、恰も永い航海の後に港に着いた海賊船の隊員を目のあたりに見るが如く、全く血に飢えた猛獣に等しいものであつた。",
              "citation": {
                "source": "山男と男装の美女",
                "author": "ミツキイのジヨンニイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "観衆は声をからして自党の隊伍に向つて、あらん限りの声援と賞讚をおくつた。",
              "citation": {
                "source": "鱗雲",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし隊伍は二列縦隊で、おのずから規律がととのっていて、犯しがたく思われた。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで直ちに部隊は隊伍をととのえて、しゅくしゅくと行進をはじめた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "噛み合う歯車の面前を、隊伍を組んだ糸の大群が疾走した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "又たとい敵を撃退せる場合に於ても軽挙追撃して隊伍を紊る時は、敗者のなお所有する集結せる兵力のため反撃せらるる危険甚大で、追撃は通常行なわれず、徹底的な戦捷の効果は求め難かった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "琵琶歌は昔の支那の詩形によっているものであるが、今日、それは勇壮活溌なる日本文化の華として、廟行鎮の武勇歌などに奨励され、中国では世界及東洋文学史の上に一つの足跡をのこす「われらは鉄の隊伍」の歌となって出て来ている。",
              "citation": {
                "source": "ペンクラブのパリ大会",
                "author": "――議題の抜粋についての感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（この真理を）敗北した軍隊はよく学ぶ」（レーニン、同書）　この時期はいかによく隊伍をととのえて、来るべき闘争に備えるために退却すべきかを、革命的プロレタリアートが学んだ時期であった。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "隊伍堂々とプラカードをかかげて、パラパラおちる雨をものともせず歌いながら行進してくる。",
              "citation": {
                "source": "メーデーに歌う",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隊伍を一目見て、私は思わず囁き、涙を抑えかねた。",
              "citation": {
                "source": "メーデーに歌う",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮城前から首相官邸前にさしかかった行進は、隊伍の中から代表を官邸へ送りこみ、秩序正しく、前進しつづけた。",
              "citation": {
                "source": "メーデーに歌う",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隊伍をなした士卒も避ける。",
              "citation": {
                "source": "空車",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
