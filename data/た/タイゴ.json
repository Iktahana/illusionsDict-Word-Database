      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Taiwanese (language)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "奏者・使者等から出た口状の類の物言ひが舞台語としての慣用から、実際日常用語のやうに思はれて来た。",
              "citation": {
                "source": "「さうや　さかいに」",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで、気を練らして白雲が、夫婦を相手の会話の中から判断して、幾つかの仙台語のうちの単語を修得し、これを画帖の端へ、ちょいちょいと書きつけたものです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "北米合衆国の国語はあの通り出処が明らかで、仙台語と東京語とよりもはるかに距離は近いが、何人がこれを英語の方言と名づけようか。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、狸は自分の家で、例のとほりありがたいごきたうをしてゐますと、狼が籾を三升さげて来て、どうかお説教をねがひますと云ひました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、狸は自分の家で、例のとおりありがたいごきとうをしていますと、狼がお米を三｜升さげて来て、どうかお説教をねがいますと云いました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから金だらいを出して顔をぶるぶる洗うと、戸棚から冷たいごはんと味噌をだして、まるで夢中でざくざく食べました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、それもまた不吉な感じで、黙ってお座敷の灯を消して、隣りの間へ行き、隣りの間のスタンドに灯をつけ、たまらなく侘びしくなって、いそいで食堂へ行き、罐詰の鮭を冷たいごはんにのせて食べたら、ぽろぽろと涙が出た。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……早く死にたいごんだなあ」と訴えた。",
              "citation": {
                "source": "祖母のために",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひまな時たいくつな時などはいつでもごん平じいの家に行ってはいつものように長いくびをのばしたりちぢめたりしてかたいごみの多い土面をツッツいて居る。",
              "citation": {
                "source": "三年前",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかたいご決心と、ねん入りなご準備のことをうけたまわって、わたしもうれしいです」「じゃあ、その方針で進むことにしよう。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "たこあげ天へ上りたかネオルガンの鳴っとる如たる凧の踊っとるもん天へ上りたかネ　　注上りたか…………上りたいごたる……………ようだハタ………………たこ踊っとるもん……踊っているから完全な幸福　真実孤児の道はさみしい。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それは、おばさんのつめたいごつごつした足におどろいたねこが、目をあけたのだ。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつたいご病気といふのは、どこがわるいんですか」　ピッコロミリ夫人は、そこで訊ねた。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が行くならおらも行きたいごんだ」「私もいいわ。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人は長い間見なかった、白い、かたいご飯を、ごちそうになった。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいご存じなかったんですか？",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雪乃どのには、ちょっとでも、ご隠居さまとおふたりきりで、おはなし願いたいご容子に見えましたが」「惣左も、そういうたか」「はい。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、お綱を手に入れたいご一念、問うだけ野暮でござりますな。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいご辺は、劉璋に忠ならんとするのか、玄徳に仕えんとするのか」「良禽は木を撰ぶ。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もし首尾よく果せば、後日、恩賞の領土を加えて、六波羅の一員にも列せしめよう、というありがたいご内約だが……しかし、それにそむけば、やがてわが家の没落は知れている」「……で、あなたのお覚悟はどうなのでございますか」「迷うのだ。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
