        "examples": {
          "standard": [
            {
              "text": "自社の新機能を開発する際、まずは徹底的に他社製品の性能を調査した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「こちらの方が他社製品よりも耐久性に優れています」と営業担当が説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "他社製品との価格競争が激化し、利益を確保するのが難しくなっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "家電量販店もまた、他社製品と併売する形ではあったが、競ってＰＣ―８００１を扱ってくれるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしこの道を選んで最低限元をとろうとすれば、ＯＥＭ先の想定販売台数でソフトウエアの開発費を割った分をマシンの価格に上乗せし、しかも他社製品よりその分割高になったものを売り切ってもらわなければならなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
