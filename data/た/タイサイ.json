[
  {
    "uuid": "545e2b63-b5ea-50f3-986e-343f77e88f7a",
    "entry": "大祭",
    "reading": {
      "primary": "たいさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
