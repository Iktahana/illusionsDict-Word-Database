    "definitions": [
      {
        "index": 1,
        "gloss": "large or bulky book or volume",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "初編だけ刊行されたが八百頁の大冊である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂々七百頁ちかくの大冊である。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで先ず寄贈された大冊子の冒頭にある緒言だけを取り敢ず通覧した。",
              "citation": {
                "source": "マードック先生の『日本歴史』",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "棊の由つて来ること是の如く久しきを以て、若し棊に関するの文献を索めんには、厖然たる大冊を為すべし。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、その時はこんなに大冊の三部歌集にならうとは思ひもかけてゐなかつた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四六版アンカト、五二五頁、部厚で重く、兎も角尨然たる大冊となつた。",
              "citation": {
                "source": "文庫版『雀の卵』覚書",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とホームズは大冊を伏せ、「結社の突然の解体とオープンショウが書類を持ってアメリカから消えた年とが一致する。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ずその人は、大冊十六巻からなるその作品の量を見て、このバルザックという人はよくもこれだけ書けたものだと一驚しながら、手当り次第に、その一冊をとりあげ、疑いぶかそうな様子で、どこかの頁をあける。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "クロはいわゆる「科学的」社会主義の祖述者のごとくに、ことさらに、むずかしい文字と文章とを用いて、そして何だかわけの分らない弁証法などという論理法によって、数千ページの大冊の中にその矛盾背理の理論をごまかし去るの技倆を持たない。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "只寺院の側から観た煩瑣な註釈を加えた大冊の書物を、深く究めようともせずに、貯蔵しているばかりである。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同書は実に一千百七十余頁の大冊で、法律語をａｂｃの順に並べ、これに訳語または新語、新字を附し、本義、釈解、参照をも添えてあって、実に本邦法律史上無類の奇書である。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその夏のうちに読破しようと思って持って来たギブソンの「有史前に於ける生物発生論」という大冊の原書をひきよせて最初からおよそ三分の一の所を拡げて、読み耽っていたところであった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大冊（縦一尺六寸、横一尺二寸）の第一巻第一集が明治三十三年（1900）二月に出版せられて西洋諸国の大学、植物園などへも大学から寄贈せられた。",
              "citation": {
                "source": "私の信条",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大冊（縦一尺六寸、横一尺二寸）の第一巻第一集が明治三十三年（一九〇〇）二月に出版せられて西洋諸国の大学、植物園などへも大学から寄贈せられた。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッサルが医療のかたわら多数の商品を殆ど独力で分析した724ページの大冊である。",
              "citation": {
                "source": "食品とその混ぜ物処理",
                "author": "FOOD AND ITS ADULTERATIONS; ANALYTICAL SANITARY COMMISSION OF \"THE LANCET\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大冊子を机の上に置いて、たいていこれで分りますがねと河村さんが云い出した時は、さあ大変だと思った。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもまた恐ろしく分厚に書き上げた著作で、上下二巻を通じて千五百頁ほどある大冊子だから、四五日はおろか一週間かかっても楽に読みこなす事はでき悪い。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「講義録」は元来四十八号二十四冊より成りたるも、昨年これを合綴して六大冊にいたしました。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "再版は購読者の便をはかり、各部門につきてこれを合綴し、目録および付録を増加し、八大部門を合して六大冊となす。",
              "citation": {
                "source": "妖怪学講義",
                "author": "再版につきて一言を題す",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも絵の本か、建築のかそれとも地図と言いたい様子の大冊な本ばかりだった。",
              "citation": {
                "source": "西班牙犬の家",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでだが、それは家系的な病気と見なすべきものか（わたしには鬚を剃りながら眠ってしまい、起きていて安息日を守るために日曜日には地下室でジャガイモの芽を摘んでいなければならなかった伯父がいた）、それともチャーマーの『英詩集』の大冊を飛ばさずに読もうとくわだてた結果だか、どうも見当がつかないのだ。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大冊はほとんどわたしを降参させた。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "大冊三四百であるゆえに見る人が少なく少々虫が食べていてしかも複本がない。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "地名の多い郡では十三行の罫紙百枚以上の大冊が六七冊もあり、中には一箇村か二箇村で一巻をなす例もあった。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大冊子とは云えないから詳しい思想分析も社会事情の分析も不可能なわけだが、要点を指摘しているから今後の研究の要領を指導出来ると信じる。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "本としては宝石のような紙、印刷、図の価値ある揃いの豪華な大冊であり、医学図書館で名作としてこの２つ折りを自分で見ることができるであろう。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし彼がどこかに居るものとすれば、事実彼の名は教会名簿にも大冊の赤い華族名鑑にもまだ載っているのだ、だが誰にも彼れを太陽の下に見たと云うものがないのだ。",
              "citation": {
                "source": "作男・ゴーの名誉",
                "author": "THE HONOUR OF ISRAEL GOW",
                "note": "青空文庫"
              }
            },
            {
              "text": "勉強、十月十七日までには大冊完了でしょう、まさか。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
