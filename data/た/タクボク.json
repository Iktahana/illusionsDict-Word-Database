        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "薄命なりし明治の詩人啄木は、此の詩集の如き意味に於て作られた歌に依て、明かに後世に解せられるであらう。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、戦争に関する詩歌についても、与謝野晶子の「君死にたまふことなかれ」、石川啄木の「マカロフ提督追悼の詩」を始め戦争に際しては多くが簇出しているし、また日露戦争中、二葉亭がガルシンの「四日間」を訳出している。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁前のついその森に、朽木を啄む啄木鳥の、青げら、赤げらを二｜羽視ながら、寒いから浴衣の襲着で、朝酒を。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉が朽ちるのか、根が水を吸うのか、巻き葉が拡がるのか、虫がささやくのか、風が渡るのか、その静かな音、音ある静かさの間に啄木鳥とむささびがかっかっと聞こえ、ちちと聞こえる声を立てる。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何所かで啄木鳥が木をつゝいてゐる。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四隣は氣味の惡い程物靜で、たゞ車輪の輾る音と、折ふし寂寞とした森林の中から、啄木鳥がコト／＼と、樹の幹を叩く音とが際立つて聽ゆるのみであつたが、鐵車は進み進んで、今や唯ある深林の邊に差掛つた時、日出雄少年は急に私の袖を引いた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸の影に居て、啄木鳥のやうに叩くものはたれ？",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に啄木は歌って言う。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の求めたものは何だろうか――おそらくそれは啄木自身も知らなかった。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち人の知る如く、初期に於ける我が国の自然主義は、独歩、二葉亭、藤村、啄木等によって代表され、詩的精神の極めて強調されたものであった。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度我が石川｜啄木が、自分で詩人であることを自嘲しつつ、生涯慰められないで詩を書いていた。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その木の皮を石で叩きつぶすと、いい匂がしたので、大人たちが、ひるねをしてゐるひるさがりなど、三人で、まるで啄木鳥のやうに、木の幹をコツコツと叩いてゐたりしました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一で本を書いて、それが石川｜啄木という大天才の書いた本よりも、もっと上手で、それからまた十何冊だかの本を書いて、としは若いけれども、日本一の詩人、という事になっている。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうかいのう、小島のう、磯のう、と、啄木の歌をはじめたのだが、その声の荒々しく大きい事、外の風の音も、彼の声のために打消されてしまつたほどであつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人啄木の碑で知られている函館の立待岬から、某夜二人の男女が投身した。",
              "citation": {
                "source": "妖蛸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十三年十二月二十九日東京にて　　石川啄木",
              "citation": {
                "source": "歌集「嘲笑」序文",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一金五圓也　上原政之助氏一金一圓也　柏田蕗村氏（校了の日　印刷所の二階にて　啄木生）（明42・２「スバル」二）",
              "citation": {
                "source": "消息",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "選拔は哀果啄木二人の合議に據る。",
              "citation": {
                "source": "無題",
                "author": "月刊文藝雜誌　樹木と果實　初號三月一日發行",
                "note": "青空文庫"
              }
            },
            {
              "text": "啄木、永く都塵に埋もれて、旦暮身世の怱忙に追はれ、意ならずして故郷の風色にそむくうちに、身は塵臭に染み、吟心また労をおぼえぬ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ願くは詩人啄木をしてたゞ一箇の愛国の赤子たらしめよ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "あつまれるは残紅、花京、せつ子、みつ子、啄木の五人。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一、二の頃、そうだ、私が石川啄木に逢ってまだほんの二、三度目の時だったと思う。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あの頃も何かといえば反抗心の強い、負けずぎらいの少年だったな、啄木は。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて見たる小樽石川啄木-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）択び出ず。",
              "citation": {
                "source": "初めて見たる小樽",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "性急な思想石川啄木-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）性急にした。",
              "citation": {
                "source": "性急な思想",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞け、今、巷に喘げる塵の疾風よせ来て、若やぐ生命の森の精の聖きを攻むやと、終日、啄木鳥、巡りて警告夏樹の髄にきざむ。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十年九月二十三日　　　　　　　　　　　　　札幌にて　啄木拝並木兄　御侍史　　無題一年ばかりの間、いや一と月でも一週間でも、三日でもいい。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "古人、之を「啄木鳥の戦法」と云った。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち啄木鳥が、木中の虫を捕えるとき、穴と反対の側をコツコツと啄き、虫をおどろかして穴から出たところを喰べようと云うのである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことは、まったくぼくの頭にはなかった。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
