    "definitions": [
      {
        "index": 1,
        "gloss": "single pole",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "帰つたらゆつくり話す」といふ、簡単極まるハガキを、私の旅先きに寄越した。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "端書は、今日二時東京着、たゞちに表面へ投宿、取敢へず御報、明日午前｜会ひたし、と薄墨の走り書の簡単極るもので、表に裏神保町の宿屋の名と平岡常次郎といふ差出人の姓名が、表と同じ乱暴さ加減で書いてある。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事実は、時代を遡るに従って愈々甚だしく、且簡単極るのである。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "端書は、今日二時東京着、ただちに表面へ投宿、取敢えず御報、明日午前会いたし、と薄墨の走り書の簡単極るもので、表に裏｜神保町の宿屋の名と平岡常次郎という差出人の姓名が、表と同じ乱暴さ加減で書いてある。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等はカンザシと呼ばれ、この品で人は、布、金紙、こまかい螺旋、藁、ギラギラ物、赤い珊瑚といったような簡単極る材料で、非常に多種なものがつくられる巧な方法を見出す。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡単極まつてゐます。",
              "citation": {
                "source": "笑",
                "author": "アルチバシェッフ・ミハイル・ペトローヴィチ　Artsybashev Mikhail Petrovich",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともそれがあるくらいなら専門史家が一大論文を書くであろうし、とにかく、ひとくちにいえば、簡単極まる記事しかないのである。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
