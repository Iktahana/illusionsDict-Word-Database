      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rice field",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ある豪家の老人が死んだ葬式の晩に、ある男は十二分の酒を飲んで帰る途中の田んぼ道で、連れの男の首玉にかじりついて、今夜ぐらい愉快に飲んだ事は近来にないという事をなんべんもなんべんも繰り返しながらよろけ歩いていた。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もういっそう悲惨なのは田んぼ道のそばの小みぞの中をじゃぶじゃぶ歩きながら枯れ木のような足に吸いついた蛭を取っては小さなもめんの袋へ入れているそういうばあさんであった。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "居眠りしながら歩いていたのでは国道でも田んぼへ落ちることなしに目的地へは行かれまい。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "友だちと連れ立って夜ふけた田んぼ道でも歩いているときだれの口からともなく「キーターヤーマー、ヤーケール、シシーガデゥヨ」と歌うと他のものがこれに和する。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時には珍しいボールドなタッチでかいた絵で、子供をおぶった婦人が田んぼ道を歩いている図であった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は徳二郎のあとについて田んぼにいで、稲の香高きあぜ道を走って川の堤に出た。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の家の門や庭の芭蕉などの精密な写生があるかと思うと、裏田んぼの印象風景などもある。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道のわきの田んぼに烏が二羽おりているのが、白い雪の上にくっきり浮かんで見えた。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中に田んぼ道を歩いているとどこからともなく小さな子供がやって来て、「おじさん、相撲取ろう」といどむ。",
              "citation": {
                "source": "相撲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "池はちょっとした中庭にいっぱいになっていて、門の小川の水が表から床下をくぐってこの池へ通い裏田んぼへぬけるようにしてある。",
              "citation": {
                "source": "竜舌蘭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けむる霧雨の田んぼ道をゆられて行く幌車の後ろ影を追うような気がして、なつかしいわが家の門の柳が胸にゆらぐ。",
              "citation": {
                "source": "竜舌蘭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲田には強烈な日光がまぶしいようにさして、田んぼは暑さに眠っているように見える。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "門の屋根裏に巣をしているつばめが田んぼから帰って来てまた出て行くのを、羅宇屋は煙管をくわえて感心したようにながめていたが「鳥でもつばめぐらい感心な鳥はまずないね」と前置きしてこんな話を始めた。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "予も子どもをつれて裏の田んぼへ出た。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし家におったころに毎日出あるいた田んぼ道、朝に晩にながめたこの景色、おもむきは昔の記憶に少しも変わらないが、あまたの子持ちとなった今のわが目には特別な意味を感ぜぬわけにゆかぬ。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのむこうは田んぼで、畦道をとおる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　寮のほうへもどる道と、むこう側の田んぼにくだる道の分岐点にくると、柾生がそう提案した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「沼って、田んぼのことだろ」　慶一が、以前、柾生にきいた話を思いだしていう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "台形をしているのだから、人工のものだろうし、たぶん、田んぼであることはまちがいない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただの死んだ田んぼじゃねえか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰ろうぜ」　死んだ田んぼ、ということばが、四人の心のなかで木霊した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに、山あいに細長く、ゆるやかな階段状に伸びる、不規則な形の田んぼにたどりついた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりは、その田んぼと小高い山にはさまれた、細い道をひろっていく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「たぶんな」　田んぼが終わるあたりに、ピリオドのように立っている、樫の木のごつい木肌が、笹や紫陽花のかげに見えかくれする。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえ、下の道が田んぼにむかって、途中で消えてるのは、なんでだと思ってたんだ」「なんでって、あそこで敷地が終わるからじゃない」「じゃあ、わざわざあっちまで舗装することはない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女にはなんの責任もないのは、はじめからちゃんとわかっていたが、駅からずっと、たかが数万の人間に寝床を与えるために、あの山と田んぼを失ったことにくすぶりつづけていた慶一の心は、瞬時に発火点に達してしまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここには田んぼと山しかなかったんでね。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そういや、この田んぼのあたりは、危ないっていわれてましたね、マムシが出るって」　だが、どこにもこの田んぼなんて、ありはしない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっと、この平たくて、日焼けで褪色したような風景をにらみ、裏山や田んぼが脳裏にうかぶのを待ってみたが、むだだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなすっかり雪のたんぼにならびました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
