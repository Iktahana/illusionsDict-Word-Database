[
  {
    "uuid": "21188254-f8af-5892-ae86-c9e11592c87c",
    "entry": "田んぼ",
    "reading": {
      "primary": "たんぼ",
      "alternatives": [
        "でんぽ",
        "でんぼ"
      ],
      "is_heteronym": true
    },
    "grammar": {
