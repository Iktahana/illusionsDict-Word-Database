[
  {
    "uuid": "6eab2846-9558-541d-85b9-b8acfacbc242",
    "entry": "多",
    "reading": {
      "primary": "た",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "接頭辞"
