    },
    "definitions": [
      {
        "index": 1,
        "gloss": "multi-",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さうあるべきがよかつたかも知れない多くの元気な顔たちの中に、私は容易におまへを見付ける。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしともかく、それらの音楽によつて多くの人々が、好い気持にされてゐるのだから文句はないのだが、然しもと／＼気分の暈縁なぞといふオボコイものを聴いて喜んでゐる連中が取引のこととなると俄然骨ばつてくるし、而も楽々骨ばれるやうに前以て備へてゐるので、「音楽と世態」なぞと今並べてみたくなるのである。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら詩性に乏しい現今は、兎角、あまりに貧弱なモチーフを取上げることから、多くの詩が妙な複雑に堕しがちである。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分世の中は観念を見失つてゐるのである。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分その何れかであり又、何れかの取合せの故でもあらう。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は多くを申しません。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "感想中原中也　地方の詩のグループも多いことだが、どういふものか、ずつと以前から大連と神戸にだけ面白いものが見られるのだつた。",
              "citation": {
                "source": "感想",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論これは、多かれ少かれ凡ゆる詩人について云へることで、私自身についても云へることである。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういふつもりで付けたのかまだ訊ねてみないが、僕が勝手に想像する所では、無口でそつとしておいて貰ひたい男が、誰でもが多かれ少なかれ感じてはゐても余りに底深い、流れだとして殆んど全く触れないで過ぎる態の非情を、人目にも立たず浚渫してゐるといつた風の心得であらうと思ふ。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "訓導宮沢賢治早くもひとり雪をけりはるかの吹雪をはせ行くは木鼠捕りの悦治なり三人ひとしくはせたちて多吉ぞわらひ軋るとき寅は溜りに倒れゐし赤き毛布にくるまりて風くるごとに足小刻むは十にたらざる児らなれや吹雪きたればあとなる児急ぎて前にすがりつゝ一列遠くうすれ行く",
              "citation": {
                "source": "訓導",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを道徳面に投射して考へてみると、すべて自分の労を多としないといふ謙譲な気持であると思ふ。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し人間は弱いものであるから、自分の労を多としまいと思つてゐても傲慢になり易いものであるから、そこで何か一つどうしても宗教に入るといふことが必要であると思つた。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに茲に、観念的な、或ひは宗教的な要求の達成といふことよりも、修辞的、心理的要求の達成といふことの方が、遥かに多くの人の歯に合ふといふことがある。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、私はさう思ふと同時に、多くの躊躇をも感ずるものだ。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――多分、事実であらうと私は思ふ。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはつまり、偶然の介入する余地が、多いといふことである。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分三十才前後といふ頃に、人は余り死なないものなのであらう。",
              "citation": {
                "source": "逝ける辻野君",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは夢多かりし幼時を過ごしたフランドルの哀愁にも因るのであらう。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "呑気にブラブラすることか、あゝそれならば楽だよと、云はれる人が多ければ、私なぞが亦何をか云はんやである。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般生活はいざ知らず、由来芸術とは、芸術家自身の統一夥多がなさしめるわざではないか。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "統一への途上に於て小主観的作品の物されることが多ければこそ、問題は錯雑を極め、作品よりも批評の方に真実の見られ易いが如き事態ともなつてゐるのではあるまいか。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くのカマはその条に似てゐる。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「予想」が現今大概の人の場合に稀薄なのであるし、これは多分「人間像」を見失ふ、つまり「おのづと感じられる面白味」といふものの離散であらうし、それは意志だけの如き意志、謂はば周章狼狽の結果でもあらう。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろ斯かる場合には、直観が稀薄になるについては一定の時間内に吾人が熟視し得ざる程多量の物をみせられたからでもあらうことに思ひを到して、個人が個人外との関係から意識上では解放される、即ち肚据えて十分に出来ることだけをするやうに心懸けるに如くまい。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり我が国では、技術家も猶多分に政治家である場合に助かる。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論外国にしろ、多少とも此の世の中は左様なものではありますが、高い程度の技術ではともかく、凡そ常識の既に認める範囲にある技術では、我が国程に台所情実は場を占めてないやうであります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来自然を友とすることが多かつた我が国人は、感傷の綱の海を漕ぎゆくには余りに清廉であり、されば比較的清廉でなかつた人が用に与つて来たかも知れませぬ。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "開化の段階の低いことが、一朝一夕にして高まることはなく、多くの個人の不撓の努力を要することは勿論でありますが、何れにしろ事態打開の先づ第一歩は、「若い身空でイヤな病気」と感ずる前に、「病気の軽重と処分の軽重」が判明に頭なり良心なりに来ること、それに違ひはないと思ふのであります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その世界といふのは、誰しもが多かれ少かれ有してゐるものではあるが、未だ猶、十分に認識対象とされたことはないのであつた。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "三造の多くの友は、三造が外で無口だから家では可なり話すのだらうと思つてゐる。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
