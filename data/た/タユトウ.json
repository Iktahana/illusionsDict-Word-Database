    "definitions": [
      {
        "index": 1,
        "gloss": "to sway to and fro",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
