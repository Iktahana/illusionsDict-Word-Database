    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to exterminate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いくら革命を起して人間の首を切つても、金持と天才との種を絶やすことは六かしい。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり私は臆病であったおかげでこの臆病の根を絶やすことが出来たような気がする。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その兄貴の怨みはきょうまでも消えず、お前の家の跡を絶やすつもりで、お前の女房に祟っているのでナ……出て来たものを丁寧に祭れと云うたのはここの事ジャ……エーカナ。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（中略）　私はいまペンを置いて「その火絶やすな」という歌を、この学校に一つしかない小さいオルガンで歌いたいと思います。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」鶴村が此処で一寸言葉を絶やすと、安価な感情の持主であるところの彼は、もう、一寸浮ついた心持に変つて有りがたさうに、腕組をした。",
              "citation": {
                "source": "眠い一日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の感化院が科学の教養のない道学先生に経営され、今日の監獄が牛頭馬頭に等しい無智なる司獄官に一任される間は百年｜河清を待つも悪人や罪人の根を絶やす事は決して出来ない。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことのまじりけなさの故にこそ、私たちが血縁をもって結ばれているという事実も人間史の鏡に映って云うに云えない味いに満ち、愛着の新鮮な泉をも絶やすことがないのであると思われる。",
              "citation": {
                "source": "白藤",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無後爲大」とありまして、親に對する不孝の一番大きいのは相續人がなくて祖先の後を絶やすと云ふことであると云はれて居ります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "孟子も不孝無後爲大と云つて、自分の祖先の祀を絶やすと云ふことが不孝中の不孝として居りまして、儒教の考へでは後の無いと云ふことほど重大問題はないのであります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "日々鸚鵡を話相手同様にして其の日／＼を送って居りましたが、何分にも島には虫が多く居りまして、少しも火を絶やすことが出来ませぬ、昼夜とも焚火をして其の側に寝起して居りまする。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、こうしてこれまでやって来たのだし、このままあとを絶やすのも惜しいと思ってね。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから日高の婆さんが椎茸を送ってよこすので、椎茸は年中絶やすことが無いのですって。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "草を絶やすと地力を尽すと云う。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "深夜まで客をもてなすための火を絶やすことができなかった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と辞儀をしながらお園はなお何やら傍にいて尽きせぬ身の上の話でもしたいような様子であったが、言葉を絶やすと共にそのまま腕を組む種彦の様子に、女は所在なげにその後姿もしょんぼりと再び静かな跫音を梯子段の下に消してしまった。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "汁粉屋に雑煮餅なく鰻屋に鰌を絶やす事あり。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "名家のあとを絶やすのは、余の本意ではない」　お縁の天井を仰いで、長大息した吉宗のことばに、愚楽老人は、わが意を得たりといったふうに、にやりと微笑し、「すると、私の手において別働隊を組織し、柳生に加勢して、壺を奪還いたしますかな？",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "市長になった彼は一日三度の夜と二度の日の出のある大阪から煙を絶やすために努力した。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　ある日のこと、それはちようど秋の末で僅かな耕地の名ばかりの収獲もすみ、早霜がすでにいくどか降り、炬燵には火を絶やすことのできぬ頃であつた。",
              "citation": {
                "source": "この握りめし",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が戻って来るまで、火ば絶やすな。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "サミュエル・レイングはいっている、「ラプランド人は皮の着物を着、頭から肩にかけて皮の頭巾をかぶって幾晩も雪のうえで寝る――どんな毛織物を着こんでもそれにさらされた者の命を絶やすほどの寒気のなかで。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはわたしの殻のさらに奥に引っこみ、家のなかにも胸のなかにも赤い火を絶やすまいとつとめた。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "草を絶やすと地力を尽すと云ふ。",
              "citation": {
                "source": "草とり",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くして兩者眞近くに互に迫り來る時、　850敵の生命絶やすべき一念切にアレースは、軛手綱の上こして黄銅の槍投げ飛ばす、その槍宙に手に握る藍光の目のアテーネー、かくて空しく飛び來る槍を戰車の外に投ぐ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人だもわれらの手より蒙らす無慘の破滅避けしめな、まだ胎内にある子すら免るべからず、悉く皆絶やすべし、一片の墳墓も跡もトロイアの空に留めず絶やすべし。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "されども彼を恐るれば其殺害を敢てせず、計りて彼をリキエーに送り、たためる帖の中、其殺害の命令を＊記せるものを齎らして、岳父の許に致さしむ、彼の一命絶やすため。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の軍勢は戰を續け雄叫び鳴りやまず、　540カレートールの産める息アパリュウスの向へるに、アイネーアース飛びかゝり、鋭き槍に喉を突く、突かれて頭傾きて倒れて盾と兜とはこれに續きつ、息絶やす死滅は彼をおほひ去る。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "55愛兒よ、汝城壘の中に歸りてトロイアの男女を救へ、恐るべきアキルリュウスに、大いなる譽與へて、貴重なる一命絶やすこと勿れ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に両人ともまだ琉球のことばを忘れて居ないで、たやすく思ふまゝに言ふことが出来て居たといふことは謝源をムシヤウに嬉しがらせた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学的の知識はそうそうたやすく終局に達せらるるものではない事を呑み込ませて欲しいものである。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
