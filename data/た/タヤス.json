[
  {
    "uuid": "44d92c3b-96c5-5aff-a50e-f4047c3497ef",
    "entry": "絶やす",
    "reading": {
      "primary": "たやす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
