          "literary": [
            {
              "text": "三根夫が撮影録音してきたフィルムによって、天蓋の堅牢さが、想像していたいじょうにすごいものであることがわかったのだ。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の耳にも入って、なにしろ店の者の評判が大きいから、聞いたいじょう捨ててもおけない。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "海へ帰る女",
                "note": "青空文庫"
              }
            },
            {
              "text": "役人がきわめをつけたいじょう、この女の作る小判はにせではなくてほん物なのだ！",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "浮世芝居女看板",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども新しい生活にふみだしたいじょうは、いやでもやりぬくほかはないんだ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
