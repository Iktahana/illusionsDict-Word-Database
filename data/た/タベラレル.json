    "definitions": [
      {
        "index": 1,
        "gloss": "to be able to eat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」○チョコレートを食べられる暇さえある職業だったら職業というものは何という好もしいものでしょう。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝸牛はどれでもこれでも食べられるのではなくて、レストラン・エスカルゴ等で食べさせるのはブルゴーニュという地方で産するものである。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る養殖家の話では巴里で一年に食べられる蝸牛の数は約七千万匹で、それを積み重ねると巴里の凱旋門よりも高くなるというから大したものである。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからアウグステをばさんは、かう云ふ会食のある度に、三日前からと三日後までとを併せて、七日分の腹を拵へて置かうとしてゐるので、どうしたら、なる丈沢山｜饒舌つて、同時になる丈沢山食べられるだらうかと云ふ研究に汲々としてゐる。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それを食い逃がしたら、又、いつ飯を食べられるかわからない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみちは朝から畑にあるもので食べられるものを集めていろいろに取り合せてみた。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても僕たちだけで食べられるもんか。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "食べられるんですもの」と言って母は媚かしく笑った。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小雨のかゝるやうに、水筋が立つほど、幾らでも、といふ……半から、緑蝶夫人は気を籠めて、瞳を寄せ、もう一人は掌をひら／＼動かし、じり／＼と卓子台に詰寄ると、第一｜番に食意地の張つてる家内が、もう、襷を掛けたさうに、「食べられるの。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私なら、いくらでも、食べられるわよ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　カラスミ、こんなにたくさん、とても食べられるものでない。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皆さん、私共のつとめは、第一に傘をひろげて種子を撒き散らして子孫を殖やすこと、その次は人間に食べられることですが、人間は何故だか私共がまだ傘を開かないうちを喜んで持って行ってしまいます。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "Pokeweed の芽生えはアスパラガスの代わりに食べられるけれども根は毒だから食べてはいけない。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぐみなら人に食べられるか鷹にとられるかどっちかだ。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき鰯もつぐみもまっ黒な鯨やくちばしの尖ったキスも出来ないような鷹に食べられるよりも仁慈あるビジテリアン諸氏に泪をほろほろそそがれて喰べられた方がいいと云わないだろうか。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗と水に漬けて、ぐいと絞つて、醤油で掻※せば直ぐに食べられる。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金さえ持って闇市場へ行けば、いつでも、たとえ夜中でも、どこかで米の飯が食べられるし、煙草が買えるのである。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり日本は哀れな国になってしまったのか……」　外で米の飯が食べられる余裕があったのかという咄嗟の安心感は、簡単に消えて、恥も外聞も見栄ももうこの国の人間は失ってしまったのかと情けない――というよりむしろ腹が立った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――いつでも美味いもんは食べられるし……。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "△漬物は日本人にはなくてはならぬ食物である、私は今日、大根を間引いて漬けた、明日は食べられる、おいしからうぞ。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "行乞が私に与へた恩恵一、何でもおいしく食べられる一、ほとんど腹が立たないやうになつた飯のうまさ、水のうまさ（モチ酒のうまさも）、食べるもの飲むもののうまさは行乞してからほんとうに解つた。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "食べられるだけ食べて、いや、そのまへに飲めるだけ飲んで、さてこれから寝られるだけ寝ればよい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これからは、アヒルの卵も食べられるってわけだもの。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうすれば、まだまだおいしく食べられるのです。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "独占慾の強い蛍雪は、鼈四郎夫妻に住宅を与え僅に食べられるだけの扶養を与えて他家への職仕を断らせた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節をさまで先走らない、そして実質的に食べられるものを親切に選んであった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし津田式調理法を習得してから、どうにか、食べられるようになりました。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙に乗せて、握飯を突込んでくれたけれど、それが食べられるもんですか。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは食べられるよ、知つてゐるか。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年以來はこの乏しい知識に、時節柄、實用性を與へようと思ひ、食べられる野草の實驗に指を染めて見た。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
