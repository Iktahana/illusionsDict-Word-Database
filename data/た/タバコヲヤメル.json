        "examples": {
          "standard": [
            {
              "text": "医者から肺の状態が良くないと忠告されたのを機に、彼はきっぱりとタバコを止める決心をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「何度もタバコを止めようとしたけど、結局一週間も持たなかったよ」と彼は苦笑いしながら話した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "禁煙外来に通い始めてから三ヶ月、ようやくタバコを止められたことで、ご飯が美味しく感じられるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ふとるにはタバコをやめるに限る、と云うと、ハア、では、ただ今からやめます、と云った。",
              "citation": {
                "source": "太宰治情死考",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "メドヴェージェンコ　ソーリンさんは、タバコをやめるべきでしょうな。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            }
          ]
        }
