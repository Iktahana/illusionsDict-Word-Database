        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "と大声が出て、立って居られずぺたんと草原に坐って、思い切って泣いてしまいました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィンの射た矢は、まさに放たんとするエーナールの弓のただ中にあたって弓は両断する。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所に杯盤の音、戸口に見送りの人声、はや出立たんと吸物の前にすわれば床の間の三宝に枳殻飾りし親の情先ず有難く、この枳殻誤って足にかけたれば取りかえてよと云う人の情もうれし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "楠公へでも行くべしとて出立たんとせしがまてしばし余は名古屋にて一泊すれども岡崎氏は直行なれば手荷物はやはり別にすべしとて再び切符の切り換えを求む。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸褄の下から加茂川染の襦袢を見せるというので「派手娘江戸の下より京を見せ」という句があるが、調和も統一も考えないで単に華美濃艶を衒う「派手娘」の心事と、「つやなし結城の五ほんて縞、花色裏のふきさへも、たんとはださぬ」粋者の意中とには著しい隔りがある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七日にいでたたんと長塚に約す。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "古袴など取り出でて十年昔の書生にいでたたんと支度ととのえなどす。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "本能と良心と、わかちがたき一つの心をふたつにわかたんとする大人の心のうらさびしさよ、力をこめて引きはなされた二つの影は、糸のやうにもつれあひつつ、ほのぐらき明窓のあたりをさまようた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばたんばたんという足踏みの音、怒号や潮罵が烈しく起りました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たんと朝寐を遊ばしても鐘は聞えず、鶏も鳴きません、犬だっておりませんからお心安うござんしょう。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下へ出てうしろの扉をばたんとしめたときに考えた。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう飲まない」「たんと、たんと、からかいなさい」「おや、僕は、僕は、ほんとうに飲んでいるのだよ」　あらためて娘の瞳を凝視した。",
              "citation": {
                "source": "あさましきもの",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車呼びとめて、それに乗ってドアをばたんと閉じ、一目散に逃げ去りたい気持なのである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "せきをしたり溜息ついたり、それからばたんばたんと亂暴に寢返りをうつたりした。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はびっくりして、互によりそって、扉をがたんと開けて、次の室へ入って行きました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とつぜん、右手のシグナルばしらが、がたんとからだをゆすぶって、上の白い横木を斜めに下の方へぶらさげました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "象はのそのそ鍛冶場へ行って、べたんと肢を折って座り、ふいごの代りに半日炭を吹いたのだ。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は治子の事を思い絶たんともがきぬ、ついに思い絶ち得たりと自ら欺きぬ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆を走らして、おりおり嘆息つきつつ、『われ君を思い断たんともがきしはげに愚かの至りなりき。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "純次は博文館の日記を開いて鉛筆で何か書いているらしかったが、もぞもぞと十四五字も書いたと思う間もなく、ぱたんとそれを伏せて、吐きだすごとく、「かったいぼう」　とほざいて立ちあがった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや死んでしまったんだ」　大半の生徒は拍子木の声に勇みを覚えたように、机の蓋をばたんばたんと音させて風呂敷包を作りはじめる。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人のかたわ者はかたわがなおりかけたと気がつくと、ぺたんと地びたに尻もちをついてしまいました。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と叫んで、飛上ると、蜜柑の空箱を見事に一個、がた、がたんと引転覆して、松小僧は帳場口へどんと退って、「女房さん！",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りがけの霞の空の、真中を蔽う雲を抜けて、かんてらの前へ、飛出したお千世の姿は、爺さんの目には、背後の蔵から昨夜の雛が抜出したように見えて、あっと腰を抜いて、ぺたんと胡坐を掻いて、ものを言うより莞爾々々としていたのである。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どたんと襖に打つかる音。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "薩摩訛に、あれえ、と云うと、飛上るやら、くるくる舞うやら、ぺたんと坐って動けぬやら。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
