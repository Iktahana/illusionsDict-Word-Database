        "examples": {
          "standard": [
            {
              "text": "単弓類は、石炭紀後半に爬虫類から分かれて進化した系統である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "私たちの遠い祖先を辿っていくと、ペルム紀に繁栄した単弓類にたどり着く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "単弓類の中には、背中に大きな「帆」を持つことで体温調節をしていた種もいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "mammal-like reptiles",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
