        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長年愛用している銅製の卵焼きは、熱伝導が良くてふっくらとした卵焼きが焼ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新生活を始めるにあたって、焦げ付きにくいフッ素加工の卵焼きを新調した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "卵焼きが古くなって柄がガタついてきたので、修理に出すか買い換えるか悩んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
