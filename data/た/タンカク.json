        "examples": {
          "standard": [
            {
              "text": "伝説上の生き物であるユニコーンは、額に一本の角を持つ単角の馬だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "稀に突然変異で、単角の状態で生まれてくる鹿がいるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "博物館で、古代の単角獣をモチーフにした石像が展示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "然らば万一、被告が法律上無罪になったとしたら彼は救われるかというと、一たんかくも無惨に破壊された人間の生活というものは容易に繕われるものではない。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "一たんかくれても、許された範圍内ならばどこへなりとかくれ直していいことになっていた。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったんかくと決めた心は、もはや微塵の身動ぎだにもせず、何らの躊躇をも感じていたわけではなかったが、同時に、また別段より緻密なる犯行を考えていたわけでもない。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
