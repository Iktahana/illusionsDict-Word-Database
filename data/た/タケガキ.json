    "definitions": [
      {
        "index": 1,
        "gloss": "bamboo fence (hedge)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
