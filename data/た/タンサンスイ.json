    "definitions": [
      {
        "index": 1,
        "gloss": "carbonated water",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ボーイが炭酸水とウイスキーを籐の卓子に置いて去ると、恋は異なものね、と云うような顔附をして炭酸水にウイスキーを入れたコップを涼しげにのむのであった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、わたしたちはね、酒は呑まないんだから炭酸水でもおくれ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「炭酸水はありません。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所の医者の処へ石炭酸水を貰いに遣れと云う人がある。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「炭酸水をもらおうかな。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "前川は、ウィスキイと炭酸水とを別々に、口に運びながら、「君達二人とも、初めて？",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生は料理屋へ大晦日の晩から行っていまして、ボオレと云って、シャンパンに葡萄酒に砂糖に炭酸水と云うように、いろいろ交ぜて温めて、レモンを輪切にして入れた酒を拵えて夜なかになるのを待っています。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コップと炭酸水を持って来い」　用を聞きに来た女中にこういいつけておいて、激しく葉子をまともに見た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子ども用のシャンペンと称する、ただの甘い炭酸水をグラスに注いで、寮長の音頭で乾杯をした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女は冷い炭酸水を摂りながら、意外なる出来ごとについて、僕に話して聞かせるのだった。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活力があふれ、人生の現実に充ち各行が何かを語り、紛糾の深味が次々へと、新鮮な炭酸水のように活気横溢してみなぎっている。",
              "citation": {
                "source": "バルザックについてのノート",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも喉の渇いたため、炭酸水か何か飲みにはひつたのである。",
              "citation": {
                "source": "谷崎潤一郎氏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "女給は何も僕等の為に炭酸水を運んだばかりではない。",
              "citation": {
                "source": "谷崎潤一郎氏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある蒸し暑い雨もよいの夜、舞台監督のＴ君は、帝劇の露台に佇みながら、炭酸水のコップを片手に詩人のダンチェンコと話していた。",
              "citation": {
                "source": "カルメン",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "）サイフォンといわれている家庭用炭酸水製造器に、拇指よりも小さいボンベに液状となって使用されている。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼に、布引炭酸水の泉源地を買ひ与へた擁護者があつたことは、古くから聞いてゐる。",
              "citation": {
                "source": "戞々たり　車上の優人",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが私は炭酸水はあんまり好かず、どうしてもお水がないと困るのです。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は酒場へ入って店台の前の丸椅子に腰をかけながら、炭酸水を交ぜたウイスキーをチビチビと飲んでいた。",
              "citation": {
                "source": "Ｐ丘の殺人事件",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは四本の洋酒の壜に、炭酸水の入ったサイフォン一壜。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本酒をはじめ、葡萄酒、ジン、ウイスキー、炭酸水も用意してある。",
              "citation": {
                "source": "或る作家の厄日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくベルを押して水を取り寄せ、人の分前の少くならぬやうに氣を遣ひながら顏と手を洗ひ、それから炭酸水にウィスキをまぜて飮んだり、熱いコオヒを啜つたりした。",
              "citation": {
                "source": "湖水めぐり",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ飲物の方は、老酒に炭酸水に冷湯だけでありました。",
              "citation": {
                "source": "白塔の歌",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "辛い物を食べる時は側に必ず炭酸水か冷水を置くのはもしや口へ入れて辛過ぎたらそれを飲んで辛味を消すためです。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでおなじベンチに奥様とおきくさんと三人で腰をおろしてしばらくやすみ、奥様は一円二十銭出して三人分の炭酸水と蜜豆をとって下さいました。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭酸水は苺ので、真赤な色の水がこっぷ一ぱいになってゐて箸の様な「かや」の棒がついてゐるのです。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "連のおきくさんは、むしばで蜜豆はよくたべられないし、炭酸水はむねが悪くなってのまれないといふのにひきかへ、私の方は御馳走になるものは何でもよろこんでいたゞく。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "）フィールスが燕尾服すがたで、炭酸水を盆にのせて持って出る。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "また硬度が石灰の重炭酸塩＝炭酸水素塩の存在だけによるとき（＊一時硬水）は、単に沸騰によって非常に良くすることができる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに吹き込むと可溶性の炭酸水素カルシウムになる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
