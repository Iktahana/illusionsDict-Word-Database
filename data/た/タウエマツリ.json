    "definitions": [
      {
        "index": 1,
        "gloss": "shrine ritual held with the first two months of the year to forecast (or pray for) a successful harvest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その地域では、豊作を祈願して、毎年春に田植え祭りが盛大に開催される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "田植え祭りの神事は、一年の農作物の豊凶を占う意味合いもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "伝統的な田植え祭りに参加し、地域の文化に触れることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "seasonal planting of rice on a field affiliated with a shrine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
