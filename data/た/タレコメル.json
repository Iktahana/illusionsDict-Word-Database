        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ばっくれて、暗雲垂れ込める下で暮らさねばならなかった。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく林をぬけだしたのはもう日は没して、闇がたれこめる七時ごろであった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう厳寒の夜に低くたれこめる靄は、地上のすべてのものを凍らしてしまうような靄である。",
              "citation": {
                "source": "雪後記",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり、やっぱりおりましてございます」　と、汗をふきながら佐平治が息せききってかえってきたのは、もうかれこれ夕闇のたれこめるころおいでした。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
