  {
    "uuid": "3810a75e-5571-5438-9a4e-859fe9c3bfe2",
    "entry": "大海",
    "reading": {
      "primary": "たいかい",
      "alternatives": [
        "おおうみ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
