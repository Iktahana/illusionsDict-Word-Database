[
  {
    "uuid": "4d817177-a913-5c56-b848-99f576f838a0",
    "entry": "対訳",
    "reading": {
      "primary": "たいやく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "original text with its translation printed side by side or on opposite page",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ジャン・ヴェヴェーの「銭投げ」を見れば感情と姿勢の対訳を教えられる。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "語学の勉強と称して、和文対訳のドイルのものを買って来て、和文のところばかり読んでいる。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この本と南江堂で買ったロシア、ドイツの対訳辞書とがあったので、私は満州にいる間、少なからぬ便利を感じた。",
              "citation": {
                "source": "二人の友",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭和対訳の二冊物で、大きい厚い和本である。",
              "citation": {
                "source": "サフラン",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れは昔長崎の出島に在留して居た和蘭のドクトル・ヅーフと云う人が、ハルマと云う独逸和蘭対訳の原書の字引を飜訳したもので、蘭学社会唯一の宝書と崇められ、夫れを日本人が伝写して、緒方の塾中にもたった一部しかないから、三人も四人もヅーフの周囲に寄合て見て居た。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "英蘭対訳の字書があれば先生なしで自分｜一人で解することが出来るから、どうか字書を欲いものだと云た所で横浜に字書などを売る処はない。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "直に拝借を願うて、英蘭対訳の字書を手に請取て、通学生の居る部屋があるから其処で暫く見て、夫れから懐中の風呂敷を出してその字書を包で帰ろうとすると、ソレはならぬ、此処で見るならば許して苦しくないが、家に持帰ることは出来ませぬと、その係の者が云う。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か英蘭対訳の字書はないかと頼んで置た所が、ホルトロツプと云う英蘭対訳発音付の辞書一部二冊物がある。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "読めないから便る所は英蘭対訳の字書のみ。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "加藤弘之先生の直話に拠れば「自由」という訳字は、幕府の外国方英語通辞の頭をしていた森山多吉郎という人が案出したのが最初であるという事であるが、文久二年初版慶応三年正月再版訳了の「英和対訳辞書」（堀達三郎著）には、既に自由という訳字を用いている。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう言ふ風に琉球語の古典的なものと、日本語とをつき合せれば、一とほり対訳の上で訣る語群である。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "書籍の一冊はヒイタ・サントルムといふ天草学林刊行の羅甸語と日本語の対訳本で、他の一冊は日本語の辞典であつた。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために辞書も作つたし、対訳本も出版した。",
              "citation": {
                "source": "ラムネ氏のこと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そは支那の洋語対訳辞書の前々のものには一向にその語が見当らないからである。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度その号には、銭稻孫氏による志賀さんの『転生』の和漢対訳も載っていた。",
              "citation": {
                "source": "硯と墨",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "突厥文字と漢語との対訳、それから満州語との対訳、蒙古語との対訳を刻んだ碑文が出てきたので、それをきいて、じっとしておられなくなり、北京へ出かけてゆき、ロシア本国の老学者を助けて調査した。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘラルド社の本は和英対訳で、部分訳であり、元出た本のように只訳したのではなくて、もっと本の筆者の側から紹介したり何かしている本です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はパリ、セーヌ河岸の古本屋で各国語対訳聖書をちょろまかしたのが露見して二年間の禁錮に服さねばならなかった。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅学で誤訳の恐れがあるのでまず英語原文のファイルを作り対訳した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "対訳を終了したあとでインターネット・アーカイヴに全原文の PDF ファイルがあることを知った。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "原著が2008年末でパブリック・ドメインになったこともあり原文も加えて対訳の形式にした。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "対訳版の英文は独自に作ったものであり翻訳しながら校正に努力した。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "・林原耕三＆坂本和男訳註（1972）『対訳ヘミングウェイ２老人と海』（南雲堂）。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "正しい対訳が下しにくい故に、列挙もまた容易でないが、先ず誰でも知っていると思うのは、遠い処から何かあぶないことがあって遁げて来る場合、これは一語ずつ引離して、かなりはっきりと発音するので、いかにも我々の「やれうれしや」に似た感じを与える。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンドリヨンは、妖女に、けっして夜なかすぎまで、ぶとう会にはいませんという、かたいやくそくをしました。",
              "citation": {
                "source": "灰だらけ姫",
                "author": "またの名「ガラスの上ぐつ」",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
