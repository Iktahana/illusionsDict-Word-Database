[
  {
    "uuid": "2c4bdccb-e39b-5242-8d76-a8adefd02ddd",
    "entry": "托卵",
    "reading": {
      "primary": "たくらん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "brood parasitism (planting one's eggs in another bird's nest, as demonstrated by the cuckoo, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お前は私を龍宮へ連れて行くなどと大法螺を吹いて、私と對等の附合ひをしようとたくらんでゐるらしいが、もういい、私には何もかもよくわかつてゐるのだから、あまり惡あがきしないでさつさと海の底のお前の住居へ歸れ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたに龍宮行きをそそのかして墮落させようなんて、たくらんでゐるんぢやねえのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆汁なんかをたくらんだのは大いに惡いが、しかし、このごろの繪本のやうに、逃げるついでに婆さんを引掻いて怪我させたくらゐの事は、狸もその時は必死の努力で、謂はば正當防衞のために無我夢中であがいて、意識せずに婆さんに怪我を與へたのかも知れないし、それはそんなに憎むべき罪でも無いやうに思はれる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに依つて桃太郎の鬼征伐も大いに讀者諸君の共鳴を呼び起し、而してその戰鬪も讀む者の手に汗を握らせるほどの眞に危機一髮のものたらしめようとたくらんでゐた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　スパイは、三人が集ったのを、何かたくらんでいると睨んでいた。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "理由は、親爺が、ほかの子供達のお父さんである村会議員を、確証がないのに、涜職罪として罪人に落そうとたくらんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが本当に確証がなかったか、本当に、親爺がほかの村会議員を罪に落そうとたくらんだか！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからひいて、この物資の豊かな山東地方をブルジョアジーは、わが物に確保しようとたくらんでいる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "特曹は、支那の共産党員と、何か共謀して事をたくらんでいると、重大視していた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「愛」の美名に依って、卑猥感を隠蔽せんとたくらんでいるのではなかろうかとさえ思われるのである。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、時々そんな思い切った出鱈目な芝居をしては『敵兵の暴虐』とか何とかタイトルをつけて、しこたま興行価値を上げようとたくらんだんだ」「つまんねえなあ」と、そこで娘は口を尖らすと、紅棒を出してその唇を染めながら、ハンドバッグの鏡を横目で睨みました。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……自分でたくらんだ浅ましい芝居だったのだ！",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時にあたり、僕たちは、実によからぬ一つの悪計をたくらんだのである。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしい、それならば、と僕たちはこの不人情のおでんやに対して、或る種の悪計をたくらんだのだった。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は私を竜宮へ連れて行くなどと大法螺を吹いて、私と対等の附合ひをしようとたくらんでゐるらしいが、もういい、私には何もかもよくわかつてゐるのだから、あまり悪あがきしないでさつさと海の底のお前の住居へ帰れ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたに竜宮行きをそそのかして堕落させようなんて、たくらんでゐるんぢやねえのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆汁なんかをたくらんだのは大いに悪いが、しかし、このごろの絵本のやうに、逃げるついでに婆さんを引掻いて怪我させたくらゐの事は、狸もその時は必死の努力で、謂はば正当防衛のために無我夢中であがいて、意識せずに婆さんに怪我を与へたのかも知れないし、それはそんなに憎むべき罪でも無いやうに思はれる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに依つて桃太郎の鬼征伐も大いに読者諸君の共鳴を呼び起し、而してその戦闘も読む者の手に汗を握らせるほどの真に危機一髪のものたらしめようとたくらんでゐた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "万事窮して、とうとう悪事をたくらんだ。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は、あんなふざけた事をしてわしたちを、おどかし、自分の娘の失態を、容赦させようとたくらんでいるのでしょう？",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と呟き、何か兄さんから事件の情報を得ようと、たくらんだが、見破られた。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕と菊代さんは、お前たちに叛逆をたくらんだが、お前たちは意外に強くて、僕たちは惨敗を喫したんだ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとしたら、これはあの浅田とやらいうのっぺりした顔の人足が、何かたくらんだのかも知れぬ、と感附いた。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のかのと近所に寄合いをこしらえさせてお祭り騒ぎをしようとたくらんでばかりいるんだもの。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私があの人を売ろうとたくらんでいた寸刻以前までの暗い気持を見抜いていたのだ。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに、その茶店の床几に、私は、この少年を連れていって、さっきの悪罵の返礼をしようと、たくらんでいたのである。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそこの国造が、命をお殺し申そうとたくらんで、「あすこの野中に大きな沼がございます。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりは近江屋の娘を生贄にして、自分の都合のよいことをたくらんだのである。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "キチガイ病院から抜け出して……」「ハハハ……何とでも云え……今度の事件は皆、貴様がたくらんだ事じゃ。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはどう見ても、やばん人どもが、何かたくらんでいるのにちがいないと思いました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
