        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "外出する前に、ガスコンロの種火が消えていることを確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「給湯器の種火がつかなくて、お湯が出ないんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ボイラー室では、常に青白い種火がひっそりと灯り続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "水を口から注ぎ込むとたちまち湯になって栓口から出るギザーや、煙管の先で圧すと、すぐ種火が点じて煙草に燃えつく電気｜莨盆や、それらを使いながら、彼女の心は新鮮に慄えるのだった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのような予防策を用いても、醜聞の種火が大きくなり、ヨーロッパのさる王室の名誉を毀損することを防がねばならぬ。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "live coals (for firelighting)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
