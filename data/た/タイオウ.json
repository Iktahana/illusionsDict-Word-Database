[
  {
    "uuid": "6b2e0d08-0956-5338-aa30-7b0539027275",
    "entry": "対応",
    "reading": {
      "primary": "たいおう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
