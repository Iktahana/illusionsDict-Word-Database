          "standard": [
            {
              "text": "貿易摩擦の影響で、一部の輸入品に対して高いタリフが課されることが決定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "航空会社各社は、燃油サーチャージを含む最新のタリフ（料金表）をウェブサイトに掲載している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "関税率の交渉において、どの品目のタリフを下げるかが大きな争点となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "元の賃銀率（タリフ）システムには、熟練工と不熟練工、過労な労働と軽い労働との間の差が具体的に区別出来ない欠点があった。",
              "citation": {
                "source": "反動ジャーナリズムのチェーン・ストア",
                "author": "――森鶴子君に答える――",
                "note": "青空文庫"
              }
            }
          ]
        }
