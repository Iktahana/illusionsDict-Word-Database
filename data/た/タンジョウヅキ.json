          "literary": [
            {
              "text": "作品数が一〇〇〇を越えたのは二〇〇〇年六月、〇三年九月には三〇〇〇を越え、青空文庫満七歳の誕生月にあたる〇四年七月には四〇〇〇を越えた。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　誕生月が過ぎても、まだ歯がでなかったばかりでなく、這うこともしなかった。",
              "citation": {
                "source": "童子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "誕生月が同じ、斑点も同じ、みんな同じ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
