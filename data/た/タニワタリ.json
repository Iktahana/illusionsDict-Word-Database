    "definitions": [
      {
        "index": 1,
        "gloss": "traveling from valley to valley",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "山岳ガイドの先導で、険しい岩肌を伝いながらの谷渡りを体験した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おっと、あそこは足場が悪いから谷渡りの際は慎重に進んでくださいね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "修験者たちは、修行の一環として命がけの谷渡りを行うという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "鶯は「谷渡り」を始める。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストーヴの近くに籠を置き、室の隅にあつたゴムの木と谷渡りの鉢をその傍に竝べた。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯の谷渡りの聲、絶えてはまた續く。",
              "citation": {
                "source": "阿武隈川水源の仙境",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛と虎の吠えッこをやっているかと思うと、そのお隣の部屋では鴬の谷渡りのような発声練習が聴こえて来ます。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "其ももう今になると、谷渡りなどは、あまり高音を揚げることが出来なくなっている様だ。",
              "citation": {
                "source": "山の湯雑記",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "山では殊に谷渡りがすばらしい。",
              "citation": {
                "source": "山の春",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ鶯の谷渡りでも、達磨のでんぐり返しでも何でも出来るね。",
              "citation": {
                "source": "渡鳥いつかへる",
                "author": "軽演劇一幕四場",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "singing of the Japanese bush warbler",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "静かな森の中に、ウグイスの美しい谷渡りが響き渡っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ほう、今の谷渡りは実に見事だ。春の訪れを感じるね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ホーホケキョという鳴き声の合間に聞こえるのが、いわゆる谷渡りだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
