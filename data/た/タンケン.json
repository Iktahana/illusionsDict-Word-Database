    "definitions": [
      {
        "index": 1,
        "gloss": "short sword",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "心臓に短剣を刺された屍体が、私の名前を叫び立てでもしない限り……。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……よしッ……殺してやろう……」　といううちに私は、短剣を逆手に振り翳しながら、寝台の上に仰臥している未亡人の方へ、よろめきかかって行った。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "醜い死骸になって、浴槽から半身を乗りだしたまま、その胸は短剣に貫かれて横わっている。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（盗人決心して懐中より短剣を抜き放ち、蓮月の前にすっくと立つ。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（盗人の短剣の先が少し慄う。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無名の青年は置いた短剣を取り上げて立上ろうとする。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（蓮月、短剣を拾い取り身構える。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』ジムはそう云いながら幾度も短剣をつき刺すような恰好をしてみせた。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドリアン・グレイは絶望のあまり曾てベエシル・ハルワアドを刺した同じ短剣でその絵姿を刺し貫いた。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "『その証拠は――』西村はそう云いながら、立って部屋の一隅に置かれた典雅な書棚の抽斗を開けて、しばらくゴソゴソやっていたが、※て、ひとふりの抜き身の支那型の短剣を取り出して来た。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきほどからの不埒の雑言、これも自分の娘｜可愛さのあまりに逆上したのだ、不憫の老人と思い怺えて聞いていたのだが、いよいよ図に乗り、ついには全く気が狂ったか、奇怪な恐ろしい事までわめき散らすので、前後のわきまえも無く短剣引き抜き、突き刺した。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "短剣引き抜き、振りかざすと見るより早く、自分自身の左の頬を切り裂いた。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて叡智に輝やける眉間には、短剣で切り込まれたような無慙に深い立皺がきざまれ、細く小さい二つの眼には狐疑の焔が青く燃え、侍女たちのそよ風ほどの失笑にも、将卒たちの高すぎる廊下の足音にも、許すことなく苛酷の刑罰を課した。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は、死刑の宣告書を持ち、一人は、宝石ちりばめたる毒杯を、一人は短剣の鞘を払って。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの冷徹氷のような理智の短剣、独創の矢羽が風を切る自我の鏑矢、この二つでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "理智の短剣をもって、自我の鏑矢をもって死の世界のあの冷厳な意志の逞しさをもって。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "短剣を以て自ら加ふるは極めて易し、然れども人は之を為すよりも寧ろ自らの受けたる害に対して復讐し、而して復た其の復讐の復讐として自ら殺さるゝを喜ぶなり。",
              "citation": {
                "source": "復讐・戦争・自殺",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "海軍へはいった一人は戦死しなかった代わりに酒をのんでけんかをして短剣で人を突いてから辞職して船乗りになり、シンガポールへ行って行くえがわからなくなり、結局なくなったらしい。",
              "citation": {
                "source": "相撲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋤を一、二度打ちこむと、大きなスペイン短剣の刀身がひっくり返って出た。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "調べられて、メロスの懐中からは短剣が出て来たので、騒ぎが大きくなってしまった。",
              "citation": {
                "source": "走れメロス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻はふと思ひついたやうに、奥の部屋に入つて行き、自分の家の宝物にしてゐた立派な短剣を手にして出て来ました、夫にそれを手渡しながら『これは私の記念としておもちになつて下さい――』と言ひました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして妻の眼は『もしをりがあつたら、この短剣で、たゞ一突に小男を突殺して、帰つて来て下さい』と、言葉には出さず、心の中をかたる眼つきをしながら、妻は刀を夫に渡しました、酋長はうなづきながら、怪しい小男と連れだつて戸外に出ました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "崔を救った女も一種の女侠であることは、美人の繊手で捕吏ふたりを投げ倒したのや、役人の枕もとへ忍び込んで短剣と手紙を置いて来たのや、それらの活動をみても容易に想像されるではないか。",
              "citation": {
                "source": "女侠伝",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮田からだと思って、裏を返すと村川生とかいてある字が、鋭い短剣のように、京子の眼を突き刺した。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "而もそれは金で象眼された小さい短剣の柄に当っていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは希臘風の短剣の形だった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "復讐の女神ネメシスが、逆手に掴んでいるような、短剣の形だった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此女性の美しいけれども颯爽たる容姿が、あの返すべき時計に鏤刻されている、鋭い短剣の形を想い起さしめた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、たんけん家じゃな。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、たんけん家ではない。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
