    "definitions": [
      {
        "index": 1,
        "gloss": "clear-cut and straightforward",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
