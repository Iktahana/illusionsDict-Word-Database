          "standard": [],
          "literary": [
            {
              "text": "少しナフタリン臭くなっているかも知れませんけど、ね、」と私のほうに向き直って言って、「うちのひとには、もう、なんにも要らないのです。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲団についたナフタリンの匂いが何か勝手の違った想いで母親の側に居ない空虚さを一層しみ／″＼と感じさせ、そんな笑い声に寂しく耳を傾けていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八になって、向島の待合の下女をつとめ、そこの常客である新派の爺さん役者をだまそうとして、かえってだまされ、恥ずかしさのあまり、ナフタリンを食べて、死んだふりをして見せた。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "樟脳とナフタリンの匂いのするスカートと花模様の袂がごちゃごちゃに玄関で賑わって六日目の朝、妹たちが到着した。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲団についたナフタリンの匂いが母親のいない淋しさをしみじみ感じさせ、泣くまいとこらえる努力でよけい涙が出た。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "入れ忘れたままナフタリン臭くなってね」「そうだ。",
              "citation": {
                "source": "鬼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲団についたナフタリンの匂いが何か勝手が違って、母親のいない淋しさをしみじみ感じさせた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は鋸でその首を切断して、その首が楽に這入るほどの大きな瓶にナフタリンと一緒に詰込み、更に白木の小さな箱棺に納め、女房の墓と並べて葬ったのであった。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに上に引いたコラン・ド・プランチーの『評彙』から数例を採らんに、ローマにキリストの臍帯および陰前皮と、キリストがカタリン女尊者に忍び通うた窓附の一室、またアレキシス尊者登天の梯あり。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ＫＷＴＳケイタリング・サーヴィスです。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノータリンどもが」「おい、待て。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も数多い図書館の管理者には、書棚に樟脳や、ナフタリンをちよつぴり包んで、それで結構消毒の目的は達せられてゐるやうに思つてゐる向もあるが、そんな事では消毒にも何にもならない。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この樟材の支那箱は絶えず内部に樟脳の香が満ちていて、ナフタリンなんか入れなくても虫を防ぐから、毛織物類を仕舞って置くには、家庭用として特に便利である。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "西は内山や中里と共に頻りにイブセンやメタリンクやストリンドベルヒの脚本を批評し合つてゐた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "安宿といふものは面白いところだ、按摩さん、ナフタリン売、土方のワタリ、へぼ画家、お遍路さん、坊主、鮮人、等、等、そして彼等の話の、何とみじめで、そして興ふかいことよ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューター用の本格的なキーボードは、キーを押したり放したりする際に生じるチャタリングと呼ばれる信号のノイズをきれいに取ってやるために、いろいろな工夫を凝らしていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方厳しいコストの切り下げを求められる電卓では、ちゃちなキーボードが生じさせるチャタリングを、ソフトウエアで判定してキャンセルしてしまう工夫が進められていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十世紀の衣魚はことによると、樟脳やナフタリンも食ふかも知れない。",
              "citation": {
                "source": "変遷その他",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "水中花、ナフタリンの花、サスペンダー、ロシヤパン、万能大根刻み、玉子の泡立器、古本屋の赤い表紙のクロポトキン、青い表紙の人形の家。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女衆がナフタリンを入れといたとみえて、ナフタリンの香りがぷんぷん匂つてゐる。",
              "citation": {
                "source": "雨",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、まだそのまま、トランクの底にフランスの匂いと、ナフタリンの香気と共に安眠していますので、やや心安んじている次第であります。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋を開けるとナフタリンと何か毛織物の持つ特殊な外国風の匂いとが交ってパリの下宿にいた時の空気が今なおなつかしく立ち昇って来るのを感じる。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい近頃も私は洋行当時の古トランクを開けて、そのナフタリンと西洋の下宿屋にいた時の香気とをなつかしみながら嗅いでいたら、その中からピカソ画集が出て来た。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり森閑としてるからお留守なのかと思っちゃった」　片手で頭からベレーをぬぎながら、宏子はナフタリンのきつい匂いと古い下着類の散らかされている縁側よりのところへ坐った。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろは、ナフタリンだの何のと、種々様々な駆虫剤が便利に手に入ることが出来るので、蚤なども殆どいなくなったけれども、そのころは蚤が多くて毎夜苦しめられた。",
              "citation": {
                "source": "三筋町界隈",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この春ナフタリンを入れなかつたし、虫も五六匹眼に見えたのだが、面倒なのでほつたらかしてあつたら、セルにも毛のシャツにも穴が幾つもあいてしまつた。",
              "citation": {
                "source": "続重病室日誌",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "テコヘンな店ができたよ、とか、脳タリンスの店だよ、なんてね。",
              "citation": {
                "source": "ニューフェイス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかく御婦人というものは、テコヘンなところや、オッチョコチョイの脳タリンスをひやかしてみたくなるものなんです。",
              "citation": {
                "source": "ニューフェイス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ていてごらんなさい、脳タリンスのシルコの味を見てみましょうてんで、千客万来疑いなしですから。",
              "citation": {
                "source": "ニューフェイス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
