    "definitions": [
      {
        "index": 1,
        "gloss": "Taishō period (1912-1926)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
