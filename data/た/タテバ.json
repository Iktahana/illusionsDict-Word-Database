[
  {
    "uuid": "e0751d75-34ef-53ba-9867-d91d5eda630f",
    "entry": "経てば",
    "reading": {
      "primary": "たてば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "after",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "とにかく一つの社会的風潮は十五年経てば一先づ決算期に入るものださうであるから。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに、私は女に逃げられるや、その後一日々々と日が経てば経つ程、私はたゞもう口惜しくなるのだつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄情冷酷と云うではないが、苦い思いや鋭い悲しみも一日経てば一日だけの霞がかかる。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かような音の変化はいつ頃起ったかと申しますと、無論確かには解りませぬけれども、「エ」の二つの区別のなくなったのは徐々ではありましょうけれども、平安朝に入って百年くらい経てば大抵一緒になった。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてあと何年経てば死ぬとは言わないのだろう。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四と云へば、二三年経てばお嫁に行く齢だ。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間が万物の霊長だなんて威張っていても、たかだか七、八十年経てば、すっかり跡形もなくなってしまうのでしょうか。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間とても年が経てば、ないがしろにする約束を、一呼吸早く私が破るに、何に憚る事がある！",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　三年経てば、妹の道子は東京の女子専門学校を卒業する、乾いた雑布を絞るような学資の仕送りの苦しさも、三年の辛抱で済むのだと、喜美子は自分に言いきかせるのであった。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十何年、」と言ひかけて、あたりをぎよろりと見廻し、「何を隠さう、おれあことし三十七さ、へへん、わるいか、もう三年経てば四十だ、わかり切つた事だ、理の当然といふものだ、見ればわかるぢやないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな工合ひなら五日も経てば容易く何ともなくなるだらうと思つた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新劇の運動に参加しても、すぐに、これでいいのか、という疑問が生じて、それこそ三日経てば、いやになったほうです。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう十日くらい経てば、花が開くのではないかと存じます。",
              "citation": {
                "source": "三月三十日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上方一と言われた女も、手活の花として眺めると、三日｜経てば萎れる。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう四日出勤して五日も経てば、ぼくは腐りの絶頂でしょう。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気技師になるとのお話で、もう二年経てば、私はこのお友達のところへお嫁にまいります。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今少し経てば、己の中の人間の心は、獣としての習慣の中にすっかり埋れて消えて了うだろう。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時が経てば経つだけ、それだけお浦の帰る望みが無くなると言つた勘定。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんの僅かの時が経てば、私も、英国も、英語も、わが子孫の骨も、みんな記憶から消えて了うだろうに。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、二人の間は美しいひもに結ばれているように遠慮のない交際ぶりから、ちょっといさかいをしても、一週間も経てば、元通りになり、しばらく手紙も書かず、会いもしないでも、常にお互に快く思い起していた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば豹一が見たのは頭髪をむやみに伸ばして眼鏡を掛けたところだったが、一月経てば、丸坊主になり、眼鏡を外してしまっていないとは保証出来ないのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こういう事件というものは時間が経てば経つほど、当事者の利益なんだ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し経てば、私はこの事件によって受けた衝動に打ち克つことが出来よう。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今日からのち数千年ないし数万年数十万年を経てば、今の勢いで変化する以上は終に我等人類の生息に適さなくなることは予測できる。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日｜経てば一日だけ話が運ぶのだから、本当にどうとも確然極めなくては可けないよ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その追悼号も七十五日経てば忘れられて了ふ。",
              "citation": {
                "source": "心理の縦断",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角あと十年なり十五年経てば、当然いやでも死んで行くのである。",
              "citation": {
                "source": "墓の上に墓",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時はちよつと分らなくつても、少し経てば、一番公平な判断を作者自身がすることが出来るのである。",
              "citation": {
                "source": "墓の上に墓",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し経てば、さういふことも出来ますが、今では――」「お子さんがあるんでせう？",
              "citation": {
                "source": "犬",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者が三月と宣告したんだから、力んでも踏反り返っても三月経てばゴロゴロッと痰が咽喉へ引からんでのお陀仏様――とこう覚悟して置かにゃ虚偽だよ、」と片頬に笑を含みつつ力の抜けた空元気で、「そこは大悟徹底している。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
