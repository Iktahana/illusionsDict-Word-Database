        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "桑の葉を食べて立派に育った蚕が、真っ白で綺麗な玉繭を完成させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "出来立ての玉繭を手に取ると、驚くほど軽くて繊細な手触りがした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供の頃、学校の授業で玉繭を茹でて、中から糸を引き出す体験をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
