    "definitions": [
      {
        "index": 1,
        "gloss": "Takasaki (city in Gunma)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "上野發七時十分、小山行高崎※り。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花を切つて高崎へでも賣りに出すのかと聞くと、唯々お客さんに自由に進呈するためだといふ。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃日聞く――當時、唯一の交通機關、江戸三度と稱へた加賀藩の飛脚の規定は、高岡、富山、泊、親不知、五智、高田、長野、碓氷峠を越えて、松井田、高崎、江戸の板橋まで下街道、百二十里半――丁數四千三十八を、早飛脚は滿五日、冬の短日に於てさへこれに加ふること僅に一日二時であつた。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小春｜凪のほかほかとした可い日和の、午前十一時半頃、汽車が高崎に着いた時、彼は向側を立って来て、弁当を買った。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この高崎では、大分旅客の出入りがあった。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯部桜といえば上州の一つの名所になっていて、春は長野や高崎前橋から、見物に来る人が多いと、土地の人は誇っている。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も穿鑿をするのではないけれど、実は日数の少ないのに、汽車の遊びを貪った旅行で、行途は上野から高崎、妙義山を見つつ、横川、熊の平、浅間を眺め、軽井沢、追分をすぎ、篠の井線に乗り替えて、姨捨田毎を窓から覗いて、泊りはそこで松本が予定であった。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「梅園拾遺」には、「ちかく慶長元年七月、大地震速見高崎山なども石崩れ落ち、火出たるよし、府内の記事に見えたり。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "車外には御寮を迎の人数が満ちて、汽車は高崎に留まろうとしたのであるから……　既に死灰のごとく席に復して瞑目した技師がその時再び立った。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、お一方――一昨日から、上州高崎の方だそうだけれど、東京にも少かろう、品のいい美しい、お嬢さんだか、夫人だか、少い方がお一方……」「お一方？",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あの時、その窈窕たる御寮が、汽車を棄てたのは、かしこで、その高崎であった。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、私と云うものは……若奥様には内証だが、その高崎の旦那に、頼まれまして、技師の方が可い、とさえと一言云えば、すぐに合鍵を拵えるように、道中お抱えだったので。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "高崎中学を終えてから、各地の医専の入学試験を受けている最中、リョウマチにかゝり、少青年期の大事な部分を実家で療養に暮すうち中学生上りともつかず田舎紳士ともつかない鵺の青年になったらしい弟は、せめて生活の業にもと近頃では鍼灸師の資格試験の準備中なのでありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家は烏川の上流にある室田の旧家で、その家から山の薬草を蒐めて出す取引先の高崎の薬種問屋に青年は預けられていました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高崎あたりで眠りだしたが、急にぞっとする涼気に、眼をさました。",
              "citation": {
                "source": "秋の暈",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "高崎あたりから、うすぐもりの空となり、熊の平では、かしこの峰、ここの谷に、うす白い霧がまい下りて、ひんやりと浮世ばなれのした風が、窓から出した頬を吹きわたるのだった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど妾の学校はその翌日、時の県令｜高崎某より、「詮議の次第有之停止候事」、との命を蒙りたり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後二時というに上野を出でて高崎におもむく汽車に便りて熊谷まで行かんとするなれば、夏の日の真盛りの頃を歩むこととて、市中の塵埃の※い、馬車の騒ぎあえるなど、見る眼あつげならざるはなし。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野驛にて一時間餘も待ち、高崎驛の乘換にも、一時間待ち、松井田驛に下車し、一里餘を徒歩して、日くるゝ頃、妙義町につきて、東雲館にやどりぬ。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "高崎あたりよりは、わづかに端山の上に頭角をあらはせるが、磯部に近づくに從ひて、妙義の三山、漸くあらはる。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "高崎驛にて電車に乘換へて、澁川町に著きしは、夜の八時半也。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「長野からづつと此の辺を歩いて、高崎から又た汽車に乗つたのさ。",
              "citation": {
                "source": "芭蕉と歯朶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで思つたのだが恐らくこれは高崎の停車場あたりで書かれたものだらう。",
              "citation": {
                "source": "樹木とその葉",
                "author": "地震日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め岩村田の歌會に出て直ぐ汽車で高崎まで引返し、其處で東京から一緒に來た兩人に別れて私だけ沼田の方へ入り込む、それから片品川に沿うて下野の方へ越えて行く、とさういふのであつたが、斯うして久しぶりの友だちと逢つて一緒にのんびりした氣持に浸つてゐて見ると、なんだかそれだけでは濟まされなくなつて來た。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねヱＫ―君、君一緒に行かないか、今日この汽車で嬬戀まで行つて、明日川原湯泊り、それから關東耶馬溪に沿うて中之條に下つて、澁川高崎と出ればいゝぢやないか、僅か二日餘分になるだけだ。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め岩村田の歌会に出て直ぐ汽車で高崎まで引返し、其処で東京から一緒に来た両人に別れて私だけ沼田の方へ入り込む。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねエＫ―君、君一緒に行かないか、今日この汽車で嬬恋まで行って、明日川原湯泊り、それから関東耶馬渓に沿うて中之条に下って渋川高崎と出ればいいじゃアないか、僅か二日余分になるだけだ」　みなＫ―君の顔を見た。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯部桜といえば上州の一つの名所になっていて、春は長野や高崎、前橋から見物に来る人が多いと、土地の人は誇っている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは高崎のやはり糸商人で、小間使のように見えた若い女は彼の妾であったようだ。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は高崎の家へ帰ってからそれを発見して、すぐに警察へ告訴すればいいものを、狸の皮が下車した駅を知っているので、そのあとを追って温泉場へ探しに来た。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
