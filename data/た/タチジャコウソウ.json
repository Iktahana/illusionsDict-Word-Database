        "examples": {
          "standard": [
            {
              "text": "肉料理の臭みを消すために、庭から摘んだ立麝香草を添えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "立麝香草の爽やかな香りは、ハーブティーにしても非常に美味しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女はアロマテラピーのために、立麝香草から精油を抽出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "快き静けさよ、かなたの梢に小鳥の高音……近き涼風の中に立麝香草の香り……わが心は宮の中に見たるルイ王とナポレオン皇帝との華麗と豪奢とに酔ひつつあり。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そこで、何時間も同じ所の草の中に寢ころんで、地面から立麝香草をむしっている彼の姿がよく見うけられた。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
