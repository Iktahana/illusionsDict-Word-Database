    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to amuse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "結局、私は私の全収入を浪費して、ひとりの人間をも楽しませる事が出来ず、しかも女房が七輪一つ買っても、これはいくらだ、ぜいたくだ、とこごとを言う自分勝手の亭主なのである。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この都会の風景は、いつも無限に私の心を楽しませる。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑るような床張りの中央に、古物らしいイタリイ製の水盤が置かれて、低いゆったりしたソファに椅子が、木製の美術的な小卓をかこんで巧みに配置され、白い壁にとりつけてある目を楽しませるだけの飾棚や、壁にかかっている見事な織物や金属製の飾物、どの一つにも豊かな詩趣と、驚くばかりの贅が、こらされていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドラン張りの面と線の交錯が非常に効果をあげて観者を楽しませる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務長がその場にいない時は、子供たちをあやし楽しませる熱意さえ薄らぐのを覚えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして葉子が家の中をいやが上にも整頓して、倉地のために住み心地のいい巣を造る間に、倉地は天気さえよければ庭に出て、葉子の逍遙を楽しませるために精魂を尽くした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、社会が一定度の複雑な組織になつて来ると、読者を楽しませるといふ目的が、これに明白に加はつて来る。",
              "citation": {
                "source": "文学の本質について（一）",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に自分が楽しむだけではなくて、読むものを楽しませるといふ役割を文学がもつて来るに至るのは、けだし、最も自然な発展の径路でもあらう。",
              "citation": {
                "source": "文学の本質について（一）",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは鉄道会社経営のホテルや、公園の休憩所のところどころに、この熊の彫刻をかざりつけておいたなら、どんなにか人目を楽しませるだらうといふことだつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十五（一九二六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言えば、長く都会に住んで見るほどのもので、町中に来る夏の親しみを覚えないものはなかろうが、夏はわたしも好きで、種々な景物や情趣がわたしの心を楽しませる上に、暑くても何でも一年のうちで一番よく働ける書入れ時のように思い、これまで殆んど避暑の旅に出たこともない。",
              "citation": {
                "source": "秋草",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、変化に富んだ楽しませる舞台効果によって商業的にも成功した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "聡明な人たちが他と競争するつもりで作りととのえた物であるから、皆目と心を楽しませる物ばかりであった。",
              "citation": {
                "source": "源氏物語",
                "author": "行幸",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞き手たちは良人の話からまだ知らぬ味わいをいろいろに引き出しては、こっそりと空想の中で舌を楽しませる。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもまた、漸く死の到来が、正面に廻って来たのでもあったが、そうとは知りようもなく、ただ家の事につき、母を楽しませる事についても、一層気掛りの度合が増したものと見え、彼女は相場をして見ようかとさえ思ったのだ。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "福引その他、実に一年中を一日に楽しませるので、近所の子供らも皆女中小僧をつれて遊びにゆき、羽根をつくやら、鞠なげ、楊弓もあり踊りもあれば、三味線もあり、いろいろと楽しませ夕方帰りには、山ほど土産をそれぞれにくれました。",
              "citation": {
                "source": "大丸呉服店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は人も行かず、ゆつくり秋の心を楽しませることが出来た。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "真似ることの興味も善い意味に使われた場合には人を楽しませるものですが、これが悪用されると大変迷惑を与えます。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、現在、河北平野にある村落が、塵埃をかぶって地面にもぐってるに比べて、中支平野の村落は、ずっと地上に背を伸しているし、その屋背の曲線の美で人の目を楽しませるものも多い。",
              "citation": {
                "source": "北京・青島・村落",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を楽しませるものの少い広漠たる平原の中の車中で、それらの歌にじっと耳を傾けるのは、日支人にとって嬉しいことである。",
              "citation": {
                "source": "北支点描",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂戴した小切手で七百人の囚人に次の日曜から三度、日曜ごとにアイスクリームを楽しませることにした、といって大変に喜んで下さいました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "お能や歌舞伎だって日本に来る外国人は、御馳走に見物させられるので、社交の上手な外国人は「ワンダフル」とか、「素晴らしい」とかお世辞には褒めるがあれをそっくり西洋にもって行って、世界の人々を心から楽しませることが出来るかどうかは甚だ疑わしい。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを眺めているうちに、いつか自分の呼吸で白く曇り出している硝子に、字とも絵ともつかないような、それでいて充分に描き手を楽しませる模様を描いては、それを拭わずにそのままにして、又ほかの硝子戸にいって雨を眺めていた。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば彼等は、たゞ、単にプロレタリアを楽しませるだけでなく、恐らくブウルジュアの男女をも等しく感動させるであらうから。",
              "citation": {
                "source": "梅雨期の饒舌",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は、成程、精神に働きかけることは働きかけるのですが、精神を楽しませるといふよりは、寧ろ精神を疲労させるといふことの方が多いのであります。",
              "citation": {
                "source": "芝居と生活",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じドイツの都市にしても、ハイデルベルヒとかフランクフルト・アム・マインとかニュルンベルヒとかになると、十分に旅行者を楽しませるものがあるけれども。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "オランダも大体において旅行者を楽しませるものを持っている。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ東京だけについて、主なる商業劇場の出し物を調べてみると、「近代の教養ある人々」を楽しませるやうな戯曲を上演してゐることは先づ例外といつてよろしく、これを演ずる俳優のうち、高等教育を受けたといへるほどの者は一人ゐるかゐないかである。",
              "citation": {
                "source": "芝居と見物",
                "author": "売笑的舞台への攻撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一は、純粋に人を楽しませる目的、即ち、社交的な精神がそれを生み出します。",
              "citation": {
                "source": "笑について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二は、人を楽しませることは同じですけれども職業的な必要から人を楽しませて、そして自分が何か利益を得ようとする。",
              "citation": {
                "source": "笑について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "小人はおのれを売っても、なおかつ、人をたのしませることができない。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
