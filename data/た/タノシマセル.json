[
  {
    "uuid": "493addd3-45f5-5593-9694-e2681c15d0a5",
    "entry": "楽しませる",
    "reading": {
      "primary": "たのしませる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
