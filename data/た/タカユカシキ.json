        "examples": {
          "standard": [
            {
              "text": "小学校の歴史の授業で、弥生時代の代表的な遺構として高床式倉庫を習った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この地域に伝わる高床式の民家は、洪水対策としての知恵が詰まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "キャンプ場で、地面から浮かせて設営できる高床式のテントを見かけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "本国への帰還船を待ちながら、赤十字の図書館として使われていた竹作りの高床式の小屋で一人雑誌を読んでいたエンゲルバートは、『ライフ』に転載された「思考のおもむくままに」と出合った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "別棟のダイニング・ルームは建物の裏にあり、海岸に向けて高床式で突き出ていた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "家のまわりに雑然といろんなものが置いてあり、高床式のフロアの下は犬や猫、ニワトリの小屋であると同時にありとあらゆるガラクタをつめこんだ物置きだった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "高床式のポーチをあがり、スクリーン・ドアを開いてなかに入った。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "床は高床式のまねごとみたいに高くなっていて、ポーチへは階段を五段あがる。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
