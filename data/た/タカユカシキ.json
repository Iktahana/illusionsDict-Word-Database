        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "本国への帰還船を待ちながら、赤十字の図書館として使われていた竹作りの高床式の小屋で一人雑誌を読んでいたエンゲルバートは、『ライフ』に転載された「思考のおもむくままに」と出合った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "別棟のダイニング・ルームは建物の裏にあり、海岸に向けて高床式で突き出ていた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "家のまわりに雑然といろんなものが置いてあり、高床式のフロアの下は犬や猫、ニワトリの小屋であると同時にありとあらゆるガラクタをつめこんだ物置きだった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "高床式のポーチをあがり、スクリーン・ドアを開いてなかに入った。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "床は高床式のまねごとみたいに高くなっていて、ポーチへは階段を五段あがる。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
