    "definitions": [
      {
        "index": 1,
        "gloss": "to fold (clothes, umbrella)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十時頃、私は私の蒲団だけさきに畳む事にした。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内記に「四壁｜屋蓋畳むに石をもってし」とある通りで、奥宮を中心とする山の町である。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "光ったり陰ったり、幾重にも畳む丘々の向うに、北上の野原が夢のように碧くまばゆく湛えています。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い親方はプログラムを畳む。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またときには露店が店を畳む時刻まで街角のレストランに腰をかけていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "光ったり陰ったり、幾重にも畳む丘丘の向ふに、北上の野原が夢のやうに碧くまばゆく湛へてゐます。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「医者だか、学者だか知らねえけれど、畳むに仔細はねえんだが。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう捻平に声懸けられて、わずかに顔を振上げながら、きりきりと一まず閉じると、その扇を畳むに連れて、今まで、濶と瞳を張って見据えていた眼を、次第に塞いだ弥次郎兵衛は、ものも言わず、火鉢のふちに、ぶるぶると震う指を、と支えた態の、巻莨から、音もしないで、ほろほろと灰がこぼれる。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、何だ、それで家を畳むんじゃねえ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを取って、すらりと扱いて、綺麗に畳む。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……御存じはございますまい、三組の食籠で、畳むと入子に重るやつでね。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その娘は、いかにも律義にわたくしに挨拶したのち、すぐ池上のインバネスを畳むやら、お茶をいれ替えてわたくしに出すやら、全く忠実な小間使の仕事振りです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ畳む入江、岬波、漣。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "袖を畳むとこう思う。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "標札屋「新ぼん、今頃どないしとるかな」鶴三「一生懸命働いとるに決っとる、新坊も今は少年工だ」標札屋「お父つぁんのお前は棒鱈だが、息子はお国の役に立っとるわけや」鶴三「おれが棒鱈なら、お前は鯡だ、どら風呂へでも行って来るかな」鶴三、新聞を畳んで懐へ入れて、歩きかけ、鶴三「おや、やんだようだ」傘を畳む。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」初枝「はあ、でも、もう雨はあがってますから」庄平（済ました顔で）「あ、そうですか」庄平、傘を畳む。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "万年筆屋が銭湯へ呶鳴り込んで来たが、安二郎は、「あんた、人の金ただ借りれると思たはりまんのか」と頭にのせた手拭をとってもう一つ小さく畳むと、また頭の上にのせた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にそれを小さく畳む。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹一は新聞を畳む仕事をやらされたが、八頁のものを折目を正しくつけて小さく畳むのには、かなり力が要った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "百部畳むと、床の上に積んで、斜めに崩し、折目をスリッパで踏むのだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は店を畳むときに、飼い残りの鶏をどこへか売ったのであろうと察せられた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてが思う通りに運んで、お六は鳥屋の店を畳む、勇二は屋敷から暇を取る。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は非常に煩わしく思うものであるが馴れればそれ程でもないもので、例えば朝起きる、衣服を更える、夜具を畳む、雨戸を繰り開ける、灯を消す、室内を掃除する、洗面をする、というように、着々と一事々々をキチンと取り行ってゆく、訳も造作もない事である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が夜具を丸めて畳むような遣り口で秀吉が仕事をしたならば、信長は決して秀吉を抜擢しなかったろうと思われる。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は障子の穴から強い視線をプーリの動作に注いだ、犬は一通り新聞を読み終ると、もとのやうにそれを畳みだした、実に上手に畳むのであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "富坂に住んだのはたッた一年かそこらで、眉山は終に債務のために世帯を畳むべく余儀なくされ、僅かばかりの身の廻りのものを友の家に預けて飄然として放浪の旅に上った。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "棲みなれた千葉の借家を畳むと、彼は広島の兄の家に寄寓することにした。",
              "citation": {
                "source": "遥かな旅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ死ぬるのだつたら、せめて死様だけは立派にしたいものだと、起き上つて蒲団を四つに畳むだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "家を畳むで神戸に引越さうとする段になると、江戸ツ子の夫人が承知しなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐ眼の下は裏庭にてこの時深き叢に彳める人ありければ、（これ泰助なり）浴衣の裳を引裂きて、小指の血にて文字したため、かかる用にもたたむかとて道にて拾いし礫に包み、丁と投ぐればあたかも可し。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
