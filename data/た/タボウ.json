    },
    "definitions": [
      {
        "index": 1,
        "gloss": "being very busy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それに局に出て多忙い間だけでも苦労を忘れますよ」とお富は真面目にすすめた。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "多忙と微恙に煩わされてはなはだまとまりの悪い随筆になってしまったのは遺憾である。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい病身な児だから余程気をつけないと不可ませんよ」と云いつつ今度は自分の方を向いて、「学校の方はどうだね」「どうも多忙しくって困ります。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りましょう、私も多忙しい身体だからね。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かように理想を採り上げることは、体育においてもいろいろの方法手段がありますから、私たちの日常多忙の生活上にも自由にその適当なものを見付けて、健康になられることを祈ります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "追々彼の実業界に於ける声望が高くなり、交際範囲が広くなるにつれ、彼は多忙の身となつた。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "引続いての多忙と、引続いての寝不足とが、彼の顔色を蒼ざめさせ、生際のあたりにいくらかの雲脂さへ見える。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、党員が出て来ていうのには、「野坂氏は多忙で誰とも会いません。",
              "citation": {
                "source": "民主主義",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕例の如く多忙長い手紙をかく餘暇なし。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷淡な世間と多忙な余は其後久しく「土」の事を忘れていた。",
              "citation": {
                "source": "『土』に就て",
                "author": "――長塚節著『土』序――",
                "note": "青空文庫"
              }
            },
            {
              "text": "無聊に苦んで居た子規は余の書翰を見て大に面白かったと見えて、多忙の所を気の毒だが、もう一度何か書いてくれまいかとの依頼をよこした。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し多忙で思う様に之を利用する事が出来なかったのは残念｜至極である。",
              "citation": {
                "source": "入社の辞",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "余の如き自家の職業上、文芸の諸雑誌に一応眼を通すべき義務を感じていてさえ、多忙のため果さざる月が多い。",
              "citation": {
                "source": "長塚節氏の小説「土」",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "型に入った批評家のために閑却され、多忙のため不公平を甘んずる批評家のために閑却されては、作家（ことに新進作家）は気の毒である。",
              "citation": {
                "source": "長塚節氏の小説「土」",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "御存じの通り私は英文學出身のものですから、高等學校在學の頃から歐洲文學の根柢に横はる二つの寶庫（聖書と希臘神話）をいつか機會を見て思ふまゝ熟覽して置きたいといふ希望を抱いてゐましたが、御恥づかしい事に、此機會は永久に多忙な自分の眼前に遂に出現せずに濟んで仕舞ひました。",
              "citation": {
                "source": "『傳説の時代』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家たるもの、なかなか多忙である。",
              "citation": {
                "source": "思案の敗北",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、そんなに多忙な男でもないのである。",
              "citation": {
                "source": "困惑の弁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の際、本県出身の芸術方面に関係ある皆様にお集り願って、一夜ゆっくり東京のこと、郷里の津軽、南部のことなどお話ねがいたいと存じますので御多忙中ご迷惑でしょうが是非御出席、云々という優しい招待の言葉が、その往復葉書に印刷されて在り、日時と場所とが指定されていた。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩年の氏は、予が貧困多忙でおちついて遊ぶ暇が少くなつたために不知不識訪問して閑談を樂むの機會が乏しくなり、又住所も遠ざかつたので、傳聞に其無事なのを知つて居た位に過ぎなかつたから、よくは知らぬが、矢張り例に依つて例の如くおとなしく面白く世を送つてゐられた事とおもふ。",
              "citation": {
                "source": "淡島寒月氏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "趣味の古代論者、多忙の生活人に叱咤せらる。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は、先生の山椒魚事件の顛末であるが、こんなばかばかしい失敗は、先生に於いてもあまり例の無い事であって、山椒魚の毒気にやられたものと私は単純に解したいのであるが、「趣味の古代論者、多忙の生活人に叱咤せらる。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて今回本紙に左の題材にて貴下の御寄稿をお願い致したく御多忙中恐縮ながら左記条項お含みの上｜何卒御承引のほどお願い申上げます。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御多忙中を大変恐縮に存じますが、本紙新年号文芸面のために左の玉稿たまわりたく、よろしくお願いいたします。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度、君の病床に訪ねて、いろいろ話したいと思っているのだけれど、僕も大変多忙な上に、少々神経衰弱気味で参っているのだ。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大榎の婆さんには、さっき逢ったし、本家は昨日団子をくれたばかりじゃから、また今日くれることもなかろう、それではむこうの馬吉の家か）　むこう隣の小作人の家らしくもあったが、其処は多忙で餅などをこしらえている余裕のないことを知っている老婆は、どうも其処と思うこともできなかった。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、時々目がさめたように、パッと羽を光らせるが、またぼうとなって、暖かに霞んで飛交う。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "正坊は、白い鳥のはねのついたぼうしをかぶり、金ピカのおもちゃのけんをこしにつるして、将軍になりすまして、クロのせなかにのっかりました。",
              "citation": {
                "source": "正坊とクロ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　彼女は、そばであはたゞしく大声で話しかけられたので目覚めかけたやうな頭が、またぼうとなって来た。",
              "citation": {
                "source": "かなしみの日より",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "またぼうとなって、居心が据らず、四畳半を燈火の前後、障子に凭懸ると、透間からふっと蛇の臭が来そうで、驚いて摺って出る。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々じつと、長いあひだひとつ場所に坐つてゐると、いかにも何もかもが初めから脳裡に浮かびあがつて来さうな気がするのぢや……が、やはりまたぼうつとしてしまふのぢや。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
