[
  {
    "uuid": "e35246bb-1fad-5e4e-9c37-697764f4c79b",
    "entry": "給う",
    "reading": {
      "primary": "たまう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-他動詞"
