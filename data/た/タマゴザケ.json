    "definitions": [
      {
        "index": 1,
        "gloss": "hot sake with beaten egg and sugar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
