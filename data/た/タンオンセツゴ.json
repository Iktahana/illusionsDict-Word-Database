        "examples": {
          "standard": [
            {
              "text": "俳句や短歌を作る際、音数を調整するために単音節語を効果的に使う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "言語学の比較研究で、単音節語の割合が言語の進化にどう影響するかを調べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "辞書で引いてみると、この短い単音節語には意外と多くの意味があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこには漢語のような単音節語特有の困難な事情がある。",
              "citation": {
                "source": "露伴先生の思い出",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本語は単音節語ではないのであるから、右のような困難を背負い込む必要はなかったのである。",
              "citation": {
                "source": "露伴先生の思い出",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
