        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は冬になると毎日雪かきに追われる、厳しい多雪地帯で育った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この多雪地帯では、家の作りが雪の重みに耐えられるよう工夫されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "多雪地帯への移住を検討しているが、除雪作業の大変さが心配だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "羊蹄山麓のような多雪地帯では、雪の消えるのは四月の末か、五月の初めである。",
              "citation": {
                "source": "雪三題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多雪地帯における農村の人々は、いつまでも畑を蓋っている雪を眺めて、四月の日をすごす。",
              "citation": {
                "source": "雪三題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
