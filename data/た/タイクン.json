        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "われわれ軍人は、あく迄も抗戦をつづけ、最後には皆ひとり残らず自決して、以て大君におわびを申し上げる。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後から、我が大君に召されえたあるう、と実に調子のはずれた歌をうたいながら、乱暴な足どりで歩いて来る男がある。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたじけなくも御親書を賜り百雷一時に落ちる以上の強い衝動を覚えられ、その素直なる御返答として、大君への純乎たる絶対の恭順のお心をお歌におよみになつたのでございますから、御書の御内容もおのづから推量できる筈でございます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大君への忠義の赤心に、理由はございません。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家に於いても、ただ二念なく大君の御鴻恩に感泣し、ひたすら忠義の赤誠を披瀝し奉らん純真無垢のお心から、このやうなお歌をお作りになつたので、なんの御他意も無かつたものと私どもには信ぜられるのでございます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大君の辺にこそ、とは日本のひと全部の、ひそかな祈願の筈である。",
              "citation": {
                "source": "一燈",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はろばろや大海原、涯なしや青水沫、揺りとよめ大き国民、大君に、この神に、讃へ言、寿詞申せや。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が海と大君宣らす、我が空と皇孫領らす。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "見はるかし大君宣らす、四方つ海｜皇孫領らす。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が国と大君宣らす、我が土と皇孫領らす。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "見はるかし、大君宣らす、四方つ国｜皇孫領らす。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなおほら、大君宣らす、あなをかし目翳しおはす。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五段日の本は一天万乗の大君にましまして、我が御代をかかる乱れのあさましや、神に御願をかけまくも、忝くもおん命召させたまはむ、代らめと歎かせたまふ畏こさよ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "はろばろや大海原、涯なしや青水沫、搖りとよめ大き國民、大君に、この神に、讚へ言、壽詞申せや。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が國と大君宣らす、我が土と皇孫領らす。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "見はるかし、大君宣らす、四方つ國｜皇孫領らす。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大君は神にし坐す、大御稜威神とし坐す。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "※・月に飛ぶ雪言祝大君、日の本の若き大君、神ながら朗らけき現人神。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大君、道の大君、大稜威。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大君、我が大君、現つ神、神ゆゑに、雲の上の照る日の光　釆りてますかも。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和四年　暮春白秋竹と我　序歌眺めても眺めあきずよ　親しめば親しむがまま　幽けきもありのさながら　かかはらず　またさまたげず　竹は竹　我は我ゆゑ　竹がうれしも言祝言祝大君。",
              "citation": {
                "source": "篁",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
