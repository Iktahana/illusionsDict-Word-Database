        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（数枝）（すこし躊躇して、それから、はっきりと）胆嚢炎、かも知れないって。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "胆嚢炎らしいです　いよいよ病名がわかった。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二九年（昭和四年）正月から四月いっぱい、猛烈な胆嚢炎でモスクワ〔大学〕第一附属病院に入院した。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "油がひどかったりして私はあんな胆嚢炎をやりましたから、油には大いに注意するつもりです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "胆嚢炎のため商売をやめ、まだ寝たり起きたりの母と、三十三歳の未婚の姉、二十五歳の妹。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "名称不明の男が急性虫垂炎または胆嚢炎と思われる病気で死亡した。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
