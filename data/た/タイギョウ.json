    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sabotage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "工人達は怠業状態に這入った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも拘らず、軍隊が到着した、その日から、工人の怠業状態は、鞭を見せられた馬のように、もとの道へ引き戻されてしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の言葉にすら五日目の風、十日目の雨、めぐり来ればその月日には変化の捌きが振り向いて来るのが順当、巡って来なかったらおてんとさまが暫時怠業してるのだと思えと言っております。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "予が本誌へ書き掛けた羊の話も例の生活問題など騒々しさに打ち紛れて当世流行の怠業中、未の歳も傾いて申の年が迫るにつき、猴の話を書けと博文館からも読者からも勧めらるるまま今度は怠業の起らぬよう手短く読切として差し上ぐる。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その都度樫の実などを少々賞与せぬと、労働は神聖なりと知らぬかちゅう顔してたちまちそのトルーフルを食いおわり、甚だしきは怠業してまた働かぬそうだ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "千名から居る職工が怠業に入りかけたということが、岸野を充分に打ちのめしてしまった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴は怠業しているんだ。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は怠業から始めた。",
              "citation": {
                "source": "反逆の呂律",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働者の同盟罷工や怠業が如何に起ろうとも、信友会の印刷女工たちが如何に炊き出しをして組合の同盟罷工に活動していようとも、それらの事件に対して全く同情も声援を与えられません。",
              "citation": {
                "source": "婦人指導者への抗議",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にいじめられ、望みを奪われ、金が無くとも、ただ絵が描き度いという猛烈な本能に引ずられて、我々は仕事をしているために、決して画家は如何に条件が悪くとも、怠業をしたり示威的な行動を起したりはしない。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてまた画家の絵を作りたがる根性はまたいじらしいもので、如何にいじめられ望みを奪われ、金が無くともただ絵が描きたいという猛烈な本能の強さに引きずられて、われわれは仕事をしているために、決して画家はいかに条件が悪くとも、怠業したり示威的な行動を起こしたりはしない。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の日付け込んで車掌の怠業する時節は近づけり。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃の暑さで、江戸の惡者共も大怠業をきめて居るらしく、珍らしく御用の方も閑だつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "歩く死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた何故、これほど必需品生産は、企業家たちによって怠業の状態におかれているのだろうか。",
              "citation": {
                "source": "みのりを豊かに",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そして、上層の実例の痛ましい反響として、下層には怠業が起こっていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "怠業やいい加減の仕事や主義にまでもち上げられた怠惰などこそ、もっとも自分の嫌悪してるものであると答えた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "怠業の気分が、部隊一般にかすかにただよっていた。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十七日、争議本部で開かれた小頭組合総会で、遂に、怠業を行うことが決議された。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんた方が一致して下さりゃあ、この争議は勝ちです」　翌十八日から、怠業が実施されることになった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "当然の結果として、荷主は、協定を無視して、仕事を、続々と、怠業しない共働組へ持って行く傾向を示した。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に、この数日、怠業の失敗のために、土壇場に近い苦境に立っている筈だ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに市電従業員｜怠業のことが出ていたので、ストライキの話になったのだった。",
              "citation": {
                "source": "嫁取婿取",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｆ３号の一団は、重要軍需工場に触手をのばして、工員の怠業を挑発しております。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "比較的おとなしい人夫までを、何かにつけて、煽動し、怠業の仲間にひき入れ、故意に予定を支障させて、表には出し得ない卑屈な反抗を、当事者の狼狽と、秀吉軍の敗北という結果に見て、故意に満足しようとしている始末のわるい人間群であった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
