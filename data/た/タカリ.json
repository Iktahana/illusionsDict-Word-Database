        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから二※月くらゐして、やつぱりその同人の集りのあとで、谷君他三人ばかりが、円タクの中からオイデオイデをするから行つてみると、これから牧野さんを誘ひ出しに行くから乗れといふのである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "文士の集りに於て、いかに相手にうまく取入るかといふこと以外に、果して何があるか？",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな下層民の寄り集りぢやあないか。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一分間の閑も惜しく、タイムイズマネーで忙がしく市中を馳け廻つてる大阪人が、かうした東京の喫茶店風景を見て、いかにも閑人の寄り集りのやうに思ひ、むしろ不可思議に思ふのは当然である。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は彼岸にや本堂に人｜数多集りて和尚の称名の声いつもよりは高らかなるなど寺の内も今日は何となく賑やかなり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或日、例のサン・ドニの門の裏町のキャフェで彼等の集りがあった。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると渡月橋上下六町の間、殺生禁断になっている川中では、平常から集り棲んでいた魚類が寄って来て生飯を喰べます。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "またすぐ眼の下のまちまでがやっぱりぼんやりしたたくさんの星の集りか一つの大きなけむりかのやうに見えるやうに思ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原のいちばん下流の方へ洲のやうになって出たところに人の集りがくっきりまっ黒に立ってゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内に人々皆奥へ集りお祖母さんが話し出した。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青空」は遊戲氣分のない、融通の利かないほど生眞面目なものを持つた人達の集りであつた。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は彼のまはりに集り、私にその餘のものを見ないやうにさせてくれた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまじき晴れて来ますわよ」　小初が赤い小旗を振って先に歩き出すと、雨で集りの悪い生徒達の団体がいつもの大勢の時より、もっと陽気に噪ぎ出した。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無産政党　いまだに、無産政党とか、労農党とかいうと危険な理窟ばかりを並べたて、遊んで食って行く不良分子の集りとでも思っている百姓がだいぶある。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この団体がここを引上げるという前夜のお別れの集りで色々の余興の催しがあったらしい。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　群集は、再び緊張して、その女の周囲に集りだした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "-------------------------------------------------------　　　　　　　一　牛乳色の靄が山の麓へ流れ集りだした。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔吹雪かゞやくなかにして〕吹雪かゞやくなかにして、　　まことに犬の吠え集りし。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またすぐ眼の下のまちまでがやっぱりぼんやりしたたくさんの星の集りか一つの大きなけむりかのように見えるように思いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原のいちばん下流の方へ州のようになって出たところに人の集りがくっきりまっ黒に立っていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日朝から、いろいろ大小の与太者が佐吉さんの家に集ります。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長兄が来て、すぐに看護婦を雇い、お友だちもだんだん集り、私も心強くなりましたが、長兄が見えるまでの二晩は、いま思っても地獄のような気がいたします。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなもまはりに集りました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原のいちばん下流の方へ、洲のやうになつて出たところに人の集りがくつきり、まつ黒に立つてゐました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなもまわりに集りました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽を専門にやっているぼくらがあの金沓鍛冶だの砂糖屋の丁稚なんかの寄り集りに負けてしまったらいったいわれわれの面目はどうなるんだ。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが導火線、類を以て集り、終には酒、歌、軍歌、日本帝国万々歳！",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "粉はひかにゃならず、稲にゃ雀がたかりよるのに！",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるに町方の者としいえば、かたいなる児ども尊び敬いて、しばらくもともに遊ばんことを希うや、親しく、優しく勉めてすなれど、不断は此方より遠ざかりしが、その時は先にあまり淋しくて、友欲しき念の堪えがたかりしその心のまだ失せざると、恐しかりしあとの楽しきとに、われは拒まずして頷きぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近く寄れ、喰さきなむと思うのみ、歯がみして睨まえたる、眼の色こそ怪しくなりたれ、逆つりたる眦は憑きもののわざよとて、寄りたかりて口々にののしるぞ無念なりける。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
