        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "俳句を修業するということは、以上の見地から考えると、退嬰的な無常観への逃避でもなければ、消極的なあきらめの哲学の演習でもなく、またひとりよがりの自慰的お座敷芸でもない。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この甲型の人の目から見ると乙型の人間は消極的｜退嬰的な利己主義者に見える。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし本来の風雅の道は決して人を退嬰的にするためのものではなかったと思う。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文芸に対するこのような解釈は、私には少しも退嬰的なものとは考えられない。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワルトンに先手を次ぎ次ぎに打たれて勢いジョーンは退嬰的にばかりなった。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面より人生の痛苦と相対して堂々の戦をなさんとせず、これを逃避して他の娯楽を以てわが鬱を慰めると言うのはまことに浅い、弱い、退嬰的な態度である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は商売に退嬰的な甥を勇気づけた。",
              "citation": {
                "source": "芭蕉と歯朶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう考えると、今日のように保守的といわんよりは退嬰的な、そして勉強の足りない編集方針を延長していったのでは、必ず早晩大きな破綻を生ずるにちがいない。",
              "citation": {
                "source": "『十八時の音楽浴』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代日本のブルジョア文学において、常に綯いまぜられて来た退嬰的な妥協的な封建的戯作者風の残りものとの関係においては、進歩的面のバトンの運び手であった自我の探求は今日、未開のまま外ならぬ生みの親のブルジョア文学者の手で※られるというめぐり合わせに置かれている如く見える。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "△こゝにかうして寝てゐる私にも時代の風波はひし／＼と押し寄せてくる、私は私があまりに退嬰的隠遁的であることを恥ぢる、時としてはぢつとしてゐるに堪へないことがある、そして……あゝ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "その欲望は、男にのこされている生涯がそう永いものではないという見透しや、男一生の思い出にという熱情の爆発やによって甚しく強烈であり、過去の全生活に対して今や負担と退嬰的な要素しか見出せない状態に陥ったとする。",
              "citation": {
                "source": "もう少しの親切を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も退嬰的であると考えられていた教員、全逓・官公庁の職員も婦人をこめて今は前線に進んでいます。",
              "citation": {
                "source": "国際民婦連へのメッセージ",
                "author": "――「女性を守る会」から――",
                "note": "青空文庫"
              }
            },
            {
              "text": "情実批評の例として、対人関係から来る阿諛的批評や反感的批評、評家が創作家でもある場合に於ける自己標準の退嬰的批評や他日を予想する下心的批評、それらの卑屈なものを私は茲に持ち出すまい。",
              "citation": {
                "source": "月評をして",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、萎縮し涸渇した形象は、萎縮し涸渇した創造であり、退嬰的な非建設的な形象は、退嬰的な非建設的な創造である。",
              "citation": {
                "source": "神話と青春との復活",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "保守的　退嬰的　非進歩的　非理知的　偏狭固陋であればある程、それだけ正しいのである。",
              "citation": {
                "source": "ツワイク「三人の巨匠」",
                "author": "――ドストイェフスキーの部（偉大な統一の破壊者、永遠の分裂者としての）――",
                "note": "青空文庫"
              }
            },
            {
              "text": "珠太郎は名古屋という退嬰的の都会の、老舗の丸田屋の箱入り息子なので、初心で純情で信じ易かった。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方から見、退嬰的と云われるのは主として此点にある。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "散々、貧乏をし、苦労をし、少し生活も楽になったかと思うと退嬰的な退屈、妙に脂じみた物うさを持ちまわすところ鼻持ちならず。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "農民は退嬰的で非科学的で、お話になりません。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代主義の立場から真に敵視すべきは、昨日の芸術に恋々たる保守的、退嬰的、微温的官学主義者であります。",
              "citation": {
                "source": "演劇一般講話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう意味で、「科学に無理解」な日本の政治家や実業家の方が、少なくも過去においては、日本の進展に、相当大きい役割を演じてきたのかもしれない、というきわめて退嬰的な考えも、一応吟味してみる必要がある。",
              "citation": {
                "source": "動力革命と日本の科学者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑寂をもとめ平淡を愛しながら、なお決して世を離れるような退嬰的な態度をとらしめるに至らなかった所以はここにあると私は思う。",
              "citation": {
                "source": "左千夫先生への追憶",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばある官庁などのように十年、十五年とだんだん恩給を増す式を、我が店員の場合に当てはめて見ると、明らかに彼らの気持を退嬰的にすることは事実である。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が平次、八五郎を書くと、回顧的だとか退嬰的だとかいわれるが、それは間違いで、江戸のもつたしなみとか、江戸の所作とか、江戸の郷愁とか、これを忘れてはいけない。",
              "citation": {
                "source": "平次放談",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い上った、人を人とも思わぬらしい笑いを口辺に漂べながら、内心は、物に拘泥せずにはいられない、臆病な、退嬰的な彼は、絶えず、他人の言動に、関心の目標を置いている。",
              "citation": {
                "source": "渋谷家の始祖",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い世界の退嬰的な感傷の基盤となっているのであって、その種の感傷こそ進歩を妨げる恐るべき障害物なのであり、科学も未だもってこれを屈服させておりません。",
              "citation": {
                "source": "夕映えのむこうの国",
                "author": "時代を超えた童話",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きた魂は生命を要求する、生きた魂は機械学に従わない、生きた魂はうさんくさい、生きた魂は退嬰的だ！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "退嬰的ではあるけれど、それだって何もないよりはましに違いない。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "万事に旧弊で退嬰的な人ではあったが、近来上方舞が時勢に取り残されて行くのを見ては流石にじっとしていられず、機会があれば東京へ打って出ようと云う考が動いていたこと。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
