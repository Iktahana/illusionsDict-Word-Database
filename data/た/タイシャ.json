[
  {
    "uuid": "1bf94bf1-96d9-5e5a-949a-f7df3819114b",
    "entry": "退社",
    "reading": {
      "primary": "たいしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
