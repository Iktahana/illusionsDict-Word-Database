    },
    "definitions": [
      {
        "index": 1,
        "gloss": "resignation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "幸徳、堺は「万朝報」を退社し、「平民社」を創立した。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "退社時刻には、一建築の中に通勤する数万の人達が、先を争って帰途を切り開かんと、物凄い労力と苦心が行われます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の春、健康いよいよ害ねて、今は、明確に退社して居ります。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戰爭の前年（三十六年、一九〇三）十月、萬朝報社の非戰主義者の内村鑑三、幸徳傳次郎、堺枯川の三氏は社長黒岩周六の開戰不可避論を承認することが出來なくて連袂退社を決行した。",
              "citation": {
                "source": "小説「墓場」に現れたる著者木下氏の思想と平民社一派の消息",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは堂島が昨夜のうちに速達で退社届を送って寄こしたということであった。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "課長さんが見せて呉れた退社届に目下移転中としてあるからね」　と加奈江は山岸に相談しかけた。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、退社時刻の六時が来ると、いきなり眼覚し時計が鳴り出した。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "退社時刻に眼覚し時計を鳴らすのは、何かのあてこすりだろうということになったのだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "会計へ出頭して、先月の中頃に退社したものだが、半月だけはたしかに出勤した故、もしや規程でその日割勘定でもらえることになっているのだったら、いま受け取りたいのだがと、半泣きの顔で早口に言うと、会計係は名前をきいて、「あ、君のサラリーまだだったね。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "退社の時刻は、大抵六時――どんなに早くっても五時だったのですが、其日にかぎって、四時頃に社を出たように思います。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "退社する時は、月給と手当とで四十三円だつたと思ふ。",
              "citation": {
                "source": "世に出る前後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "山口君を送る　△山口君が病気の為に止むを得ず退社することになつた。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "思案は「この度某学校を退学し以来は専ら文庫の編輯に従事す」と披露し、前記の劇雅堂緑芽と紅葉とは「当号限り退社す」と広告して、編輯人尾崎徳太郎の名を除いた。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、尾崎徳太郎は退社しても紅葉山人は依然社幹の名を列ねて小説を続載していたので、裏面の消息はこの広告の中に明かに読まれた。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃｜村山龍平の『国会新聞』てのがあって、幸田露伴と石橋忍月とが文芸部を担任していたが、仔細あって忍月が退社するので、（あるいは既に退社していたのか、ドッチだか忘れてしまったが、）その後任として私を物色して、村山の内意を受けて私の人物見届け役に来たのだそうだ。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも、出社の時刻はおくれても、退社の時刻は一分間だっておまけをしないなまけ者だった。",
              "citation": {
                "source": "夏の夜の冒険",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹山は其時一週間許りも唯一人で新聞を出して見せたのが、社長に重んぜられる原因になつて、二度目の主筆が兎角竹山を邪魔にし出した時は、自分一人の爲に折角の社を騷がすのは本意で無いと云つて、誰が留めても應かずに到頭退社の辭を草した。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "好し、そんなら俺も彼奴の事を素破拔いてやらう、と氣が立つて來て、卑怯な奴等だ、何も然う狐鼠狐鼠相談せずと、退社しろなら退社しろと瞭り云つたら可いぢやないか、と自暴糞な考へを起したが、退社といふ辭が我ながらムカムカしてる胸に冷水を浴せた樣に心に響いた。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮世の戰ひに疲れて、一刻と雖ども安心と云ふ氣持を抱いた事のない野村は、適切長野を入れたのは、自分を退社させる準備だと推諒した。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹山は其時一週間許りも唯一人で新聞を出して見せたのが、社長に重んぜられる原因になつて、二度目の主筆が兎角竹山を邪魔にし出した時は、自分一人の為に折角の社を騒がすのは本意で無いと云つて、誰が留めても応かずに遂々退社の辞を草した。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "好し、そんなら俺も彼奴の事を素破抜いてやらう、と気が立つて来て、卑怯な奴等だ、何も然う狐鼠々々相談せずと、退社しろなら退社しろと瞭り云つたら可いぢやないか、と自暴糞な考へを起して見たが、退社といふ辞が我ながらムカムカしてる胸に冷水を浴せた様に心に響いた。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮世の戦ひに疲れて、一刻と雖ども安心と云ふ気持を抱いた事の無い野村は、適切長野を入れたのは自分を退社させる準備だと推諒した。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは松永が退社の決心をして、高橋に連れられて社に來た時である。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『それにしても、退社までしなくつたつて可いぢやないか？",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に聞いたが、編輯長は松永の退社に就いて、最初｜却々聞き入れなかつたさうだ。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "色石は粘土の固まったようなもので、赤・朱・黄・うす緑・たいしゃなどの色があり、みんな白っぽくはあったが、なかなかしぶい味を見せた。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場に及んでたいしゃくさまをどうしようとするのか、証人にでも呼び出そうというのかと思い惑った。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
