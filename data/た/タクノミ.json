        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「今週末、久しぶりに俺の家で宅飲みしない？つまみは各自持ち寄りでさ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "宅飲みなら終電を気にせずゆっくり話せるし、お酒代も安く済むのがいいよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "コンビニで限定のクラフトビールを買い込み、お気に入りの映画を見ながら宅飲みを楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "巳之助は、父母も兄弟もなく、親戚のものとて一人もない、まったくのみなしごであった。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも編笠で深く顔を隠したまま、眼をしばたたくのみで、互に一｜言も発しなかったが、急に何か思いだしたのであろう。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "粒々ありがたくのみこまなくてはならない次第です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
