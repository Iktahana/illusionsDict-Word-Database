    "definitions": [
      {
        "index": 1,
        "gloss": "to stick it out (until the end)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "厳しい冬の寒さを耐え抜き、梅のつぼみがようやくほころび始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "どんなに辛い練習でも、最後まで耐え抜いた者だけが勝利を掴める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "倒産の危機に直面したが、社員一丸となって苦境を耐え抜いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "自分たちもこんな試練にはおそらくわたしたちよりもよくは耐え抜くことができなかっただろう、ということを知っていました。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの老｜傷痍軍人は決してくたばらないし、間違いなく、陰謀や騒動を耐え抜くだろう。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは、朝暮に、御座ちかく奉仕しているので、まのあたりにそのおんなやみをみて、涙のたえぬくらいである。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
