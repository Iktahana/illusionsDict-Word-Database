[
  {
    "uuid": "44f24b51-cf02-5c5d-88f9-c13ba6ba87cb",
    "entry": "多種",
    "reading": {
      "primary": "たしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
