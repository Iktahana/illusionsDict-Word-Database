    "definitions": [
      {
        "index": 1,
        "gloss": "tau",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これはルキアノスの、シグマ〔Σ〕がタウ〔Τ〕を訴えた話＊＊よりはずっと重大なことだろう。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリガタウ存ジマス。",
              "citation": {
                "source": "先生三人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔四、〕ケンタウル祭の夜　ジョバンニは、口笛を吹いてゐるやうなさびしい口付きで、檜のまっ黒にならんだ町の坂を下りて来たのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子どもらは、みんな新らしい折のついた着物を着て、星めぐりの口笛を吹いたり、「ケンタウルス、露をふらせ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ケンタウル露をふらせ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あゝ、さうだ、今夜ケンタウル祭だねえ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あゝ、こゝはケンタウルの村だよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイヌの「ヌプリ」は「登り」に通じ、山頂を意味する「タプカ」も「峠（タウゲ）」に少し似ている。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "タウコギは末枯れて、水蕎麦蓼など一番多く繁っている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十一月八日『東京朝日新聞』）　　　　　　　　　三十三　　　　　　世界第一の巨船　現今世界で最大最速の汽船ルシタニア号は去る九月アイルランドのクイーンスタウンよりニューヨークまで二千七百八十二｜浬の航路を五昼夜と五十四分間に、すなわち一時間二十三浬〇一の速度で快走した。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在は、上海市、フランス・タウン、アルベーローに住む。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノラの棲むフランスタウンの瀟洒なバンガロウも白粉を落さなくてはならなかった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "四、ケンタウル祭の夜　ジョバンニは、口笛を吹いているようなさびしい口付きで、檜のまっ黒にならんだ町の坂を下りて来たのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、そうだ、今夜ケンタウル祭だねえ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、ここはケンタウルの村だよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間が何千円に当った訳だ、なぞと譏る者があるが、それは譏る方がケチな根性で、一生理屈地獄でノタウチ廻るよりほかの能のない、理屈をぬけた楽しい天地のあることを知らぬからの論だ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　ケンタウル祭の夜　ジョバンニは、口笛を吹いているようなさびしい口つきで、檜のまっ黒にならんだ町の坂をおりて来たのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子どもらは、みんな新しい折のついた着物を着て、星めぐりの口笛を吹いたり、「ケンタウルス、露をふらせ」と叫んで走ったり、青いマグネシヤの花火を燃したりして、たのしそうに遊んでいるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ケンタウル露をふらせ」いきなりいままで睡っていたジョバンニのとなりの男の子が向こうの窓を見ながら叫んでいました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、そうだ、今夜ケンタウル祭だねえ」「ああ、ここはケンタウルの村だよ」カムパネルラがすぐ言いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　ケンタウル祭の夜　ジヨバンニは、口笛を吹いてゐるやうなさびしい口付きで、檜のまつ黒にならんだ町の坂を下りて來たのでした。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ケンタウルス、露をふらせ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜ケンタウル祭だねえ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
