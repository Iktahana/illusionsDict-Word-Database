        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "リーダーの不在により、進めていた合併話が途中で立ち消えてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "熱烈に支持されていた法案だったが、解散総選挙の混乱の中で立ち消えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "あんなに大騒ぎしていた不祥事の噂も、新しいニュースが出るとすぐに立ち消えた。",
              "citation": {
