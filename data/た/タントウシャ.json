[
  {
    "uuid": "6faaa074-209f-5dc0-b2d7-0acaefe6d50c",
    "entry": "担当者",
    "reading": {
      "primary": "たんとうしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
