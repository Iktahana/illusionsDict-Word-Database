    "definitions": [
      {
        "index": 1,
        "gloss": "taste (in goods, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女の嗜みになる遊芸の道も仕込まれた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "南アメリカの一部では土人のみか白人までも病的に土を嗜み、子供などは夜中に壁の泥や漆喰を剥がして食うから、それを制するため仮面を着せて寝かせるそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがわずかに「わが青海流は都会人の嗜みにする泳ぎだ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつでもちゃんとした礼装をして、頭髪を綺麗に分けて、顔を剃り立てて、どこの国の一流のレストランのボーイにもひけを取らないだけの身嗜みをしていた。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "身嗜みが奇麗で、喬は女にそう言った。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ金と言い、お茶の湯と言い、全然｜嗜みのない本来無一物が、偶然中の偶然とも言うべき機会から、何も知らずに参室したのだから、一代の光栄どころでない。",
              "citation": {
                "source": "お茶の湯満腹談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　お聞き、島へ着くと、元船を乘棄てて、魔國とこゝを覺悟して、死裝束に、髮を撫着け、衣類を着換へ、羽織を着て、紐を結んで、てん／″＼が一腰づゝ嗜みの脇差をさして上陸つたけれど、飢渇ゑた上、毒に當つて、足腰も立たないものを何うしませう？",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『君は、屹度お洒落の若い衆のように身綺麗にし過ぎていたので、青い帽子迄が、女を誑すための嗜みのように思われたのですね。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤川の女将は、年のころ五十ばかりで、名古屋の料亭の娘といわれ、お茶の嗜みもあるだけに、挙動は嫻やかで、思いやりも深そうな人柄な女であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "其八　明日辰の刻頃までに自身当寺へ来るべし、予て其方工事仰せつけられたきむね願ひたる五重塔の儀につき、上人｜直接に御話示あるべきよしなれば、衣服等失礼なきやう心得て出頭せよと、厳格に口上を演ぶるは弁舌自慢の圓珍とて、唐辛子をむざと嗜み食へる祟り鼻の頭にあらはれたる滑稽納所。",
              "citation": {
                "source": "五重塔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "トトキ、ヤブカンザウ、ギバウシユ、ヨメナ、雪の下、オホバタネツケバナなどは雜草と云つても、昔から風流の意味で人が嗜み、世間の評價も既に定まつてゐる。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも、嗜みを知る作家なら、そうするだろう。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ急かずと聞かれいと云うに……こう云えば最早お解かりじゃろうが、武辺の嗜みというものは、ただ弓矢、太刀筋ばかりに限ったものではないけにのう……」「……ハ……ハイ……」「人間、人情の取々様々、世間風俗の移り変りまでも、及ぶ限り心得ているのが又、大きな武辺のたしなみの一つじゃ。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌道を嗜み礼儀に篤い翁が、一切をつくした名文ではなかったろうかと思われる。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第一貴女に、家庭教師としての嗜みを知って頂きたいんですよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しき娘の酌める酒をば、われ平生｜嗜みて飮めり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となく動作のはしっこいこと、それをほかにもっとよい言葉がないので事務机風７と名づけてもいいが、それを除いては、これらの人々の身嗜みは、約十二か月ないし十八か月前にはこの上なく上品であったものの正確な模写であるように、私には思われた。",
              "citation": {
                "source": "群集の人",
                "author": "THE MAN OF THE CROWD",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　お聞き、島へ着くと、元船を乗棄てて、魔国とこゝを覚悟して、死装束に、髪を撫着け、衣類を着換へ、羽織を着て、紐を結んで、てん／″＼が一腰づゝ嗜みの脇差をさして上陸つたけれど、飢渇ゑた上、毒に当つて、足腰も立たないものを何うしませう？",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで聞くと、お俊は身嗜みのいい女で、朝は暗いうちにお化粧を済ませて、自分の素顔を人に見せたことが無かったと云いますから、そのあばたを隠すためには本人もよほど苦心していたと見えます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをうけたまわった鉄次郎は絵筆の嗜みのあるのを幸いに、旅絵師に化けて奥州へ下ってくる途中で、偶然に房川の渡しでおげんを救ったのが縁となって、千倉屋伝兵衛と親しくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "其八　明日｜辰の刻ごろまでに自身当寺へ来たるべし、かねてその方工事仰せつけられたきむね願いたる五重塔の儀につき、上人｜直接にお話示あるべきよしなれば、衣服等失礼なきよう心得て出頭せよと、厳格に口上を演ぶるは弁舌自慢の円珍とて、唐辛子をむざと嗜み食える祟り鼻の頭にあらわれたる滑稽納所。",
              "citation": {
                "source": "五重塔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人は身嗜みとして、平常から食物の上にもこの位の細心な注意が要すること。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に啓吉は、その女が死後の嗜みとして、男用の股引を穿いているのを見た時に悲劇の第五幕目を見たような、深い感銘を受けずにはいなかった。",
              "citation": {
                "source": "死者を嗤う",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮流草は詳らかならぬが水流に浮かみ、特に馬が嗜み食う藻などであろう。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒙古人古来馬肉を食い、殊にその腐肉を嗜み、また馬乳で酒を作った事は支那人のほかにルブルキスやマルコ・ポロやプルシャワルスキ等の紀行に詳し。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他名僧名人に生前死後身より妙香を出した伝多きは、その人香道の嗜み深く、その用意をし置いたらしい。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "以て以前邦人が香の嗜み格別で、今日｜雪隠へ往って手を洗わなんだり、朝起きて顔を洗わずコーヒーを口に含んで、歯垢を嗽ぎ落して飲んでしまう西洋人と、大違いたるを知るべし。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "他猴と異なり果よりも葉を嗜み、牛羊同然複胃あり。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と風流人の浦島も、ついたしなみを忘れて、もつと掬つて食べようといふ氣勢を示した。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "善重氏は、文墨のたしなみがあり、菅原白竜山人のかけ幅や、板垣退助伯が清人霞錦如の絵に題字せられた幅物などを愛蔵せられて、私たちの見るに任せられた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
