  {
    "uuid": "2c4ddcc7-a7e5-5f14-be6c-c110c8c64727",
    "entry": "たろう",
    "reading": {
      "primary": "たろう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "助動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ought to have been",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それ故ある人々は、ヘルンがもし悪妻をめとり、意地悪の姑等と同居したら、彼の神国日本観は、おそらく顛倒した結果になったろうと言っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の仲の好い成人が、子供の片言のようなことをしゃべり合って、何時間もの長い間、笑ったり戯れたりしている風景こそ、おそらく真にフェアリイランド的であったろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際もし彼の妻がインテリ女性であったとすれば、日本の古い伝説や怪談やを、女の素直な心で率直に実感することはできなかったろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしヘルンのように神経質で気むずかしく、感情の変化が烈しい男に仕えるのは、普通のありふれた日本の女性では、容易に為し得ないことであったろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『吹くのが面白いものだから、自分でわざと火を消しては、やたらに吹いた』と、夫人が追想談で話しているが、おそらくそういう場合、ヘルンの筆が行き渋り、感興が中断した時であったろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "信仰とやらも少し薄らいでまいったのでございましょうか、あの口笛も、ひょっとしたら、父の仕業ではなかったろうかと、なんだかそんな疑いを持つこともございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、」と二番目の姉さんを小声で呼んで、「お前のところに、モオニングがあったろう。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その崇拝する芭蕉の庵を、初めて親しく訪ねた日は、おそらく感激無量であったろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "卑俗低調の下司趣味が流行して、詩魂のない末流俳句が歓迎された天明時代に、独り芭蕉の精神を持して孤独に世から超越した蕪村は、常に鬱勃たる不満と寂寥に耐えないものがあったろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽春の日に、蒲公英の咲く長堤を逍遥するのは、蕪村の最も好んだリリシズムであるが、しかも都会の旗亭につとめて、春情学び得たる浪花風流の少女と道連れになり、喃々戯語を交して春光の下を歩いた記憶は、蕪村にとって永く忘れられないイメージだったろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春風馬堤曲に歌われた藪入りの少女は、こうした蕪村の詩情において、蒲公英の咲く野景と共に、永く残ったイメージの恋人であったろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠の漂泊者である芭蕉が、雪近い冬の空を、鳴き叫んで飛び交いながら、町を指して羽ばたき行く鴉を見て、心に思ったことは、一つの「絶叫」に似た悲哀であったろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが血のように赤く鮮明に印象されることは、心の傷いた空虚の影に、悔恨の痛みを抱きながらも、悲壮な敗北の意気を感じさせずにいなかったろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父の家は富んで、奥座敷などは二十畳もあったろう。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "募集した絵をゆっくり一枚一枚点検しながら、不折や虚子や碧梧桐を相手に色々批評したり、また同時に自分の描いておいた絵を見せたりして閑談に耽るのがあの頃の子規の一つの楽しみであったろうということも想像される。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん今云う疫痢であったろうと思われる。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀さんは実際「行儀の悪い」子供であったろうし、また随分いたずらものでもあったらしい。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道に沿うた松並木の影の中をこの椎茸がニョキ／＼と飛んで行くのがドンナに可笑しかったろう。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方の切れた谷を隔てて、近くに古生層の源氏山を見る、去年は、どうしてこの山が、気が注かなかったろうと思う。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夜の小舎よりは、二里の余も来たろう。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺はことし六十五であるが、穂高山の主と言われるくらいな山男で、何でも二十五、六歳のころ、旧の師走であったが、三人連れで、この温泉の上まで、猟にやって来たとき、雪崩れに押し流されて、一里も下まで落っこち、左の脚を折ったということで、もし自分一人であったら、到底命は助からなかったろうと、物語った。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "正しく風に動力を借りるオランダ低地の風車は美でもあり、経済的でもあったろうが、レムブラントの名手に油絵、またはエッチングに取り入れられたあの風車の風景も、近来は電気工業に取って代られ、引き合わないために、風車はだんだん取り毀たれ、オランダ風物の代表は、全く失われんとしているとも聞いた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "すんだ空は息吹がかかったように、サッと曇って、今までどこにいたろうと思われる霧がかかる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺の農家の石垣は、氷河の推し流した堆石を使ったりしているのが、私たち富士山で、万年雪を物色したり、日本アルプスで、「カアル」の痕を、氷河時代の遺蹟か否かと、論じ合ったりしている手合いに、いかに珍しかったろうか。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘッヘッ、消防組、青年団、警官隊総出には、兎共は迷惑をしたこったろうな。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "偽物でも何でも捕えようと思って慌ててるこったろう。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "可哀相に、何も知らねえ奴が、棍棒を飲み込みでもしたように、叩き出されかけているこったろう。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが何人がこの女神の逞しい火の性、徹る氷の性に、また氷火相闘つ矛盾の性に承け応えられるものがあったろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、むかしあの宇津で君も会ったろう。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が、もしこれを性の欲望に関する変態のものだったろうと言うなら、或はそうかも知れないと答えよう。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
