        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "○オクツタ」ユイノウタノム」ケツコンシキノシタクセヨ」アスペキンタツ」オオスミチユウタロウ　同時に電報｜為替で百円送られて来たのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マサタロウシス」　私は自分の眼を疑いました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、なんど読み返しても「マサタロウシス」です。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "白茶天鵞絨の様に光る芝生では、犬のデカとピンと其子のタロウ、カメが遊んで居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の郷里の方ではガタロウ（河太郎）とよぶが、この区域は存外広くない。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪に河内屋太郎兵衛という豪奢な者が出て、通称河太郎といっていたので、それに気兼ねをしたため、ガタロウといいにくくなったものであろう。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都あたりでは何といっていたか、やはりガタロウといっていたのではないかと思う。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "明石のカワカムロ　京都はガタロウで通用するとして、丹波の由良川あたりでは何というか。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤタロウ　一旦鹽漬にしたものを出して、甘酒の中に酒粕を入れたものへ漬直すのを、どういふわけでかヤタロウといふ土地がある（富山市近在方言集）。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤタロウ　いったん塩漬にしたものを出して、甘酒の中に酒粕を入れたものへ漬け直すのを、どういうわけでかヤタロウという土地がある（富山市近在方言集）。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲーム得点は敵を倒すことによって与えられ、恐竜は10点、アルケリ星人を除く異星人は７点、アルケリ星人と魔女は５点、ミノタロウスは３点、宇宙船は20点、その他はすべて１点ずつになります。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや宇宙の大半はアトランティス帝国の植民地だが、大魔王ミノスの率いるミノタロウス軍団がテセウスの野望をなおも阻み続ける。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミノタロウス軍団の奇襲攻撃です」参謀長である金太郎がレーダーを見ながら叫んだ。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミノタロウス軍団の宇宙船が編隊を組んであちこちに爆撃をしかけ、周囲はまるで火の海だった。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大魔王ミノスの率いるミノタロウス軍団が地球連邦に宣戦布告しました」ディスプレイにうつった若いアナウンサーが声を震わせながらニュース記事を読み上げる。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とりあえず、火星基地に戻ることにしよう」　すると突然大魔王ミノスと二匹のミノタロウスが空から降りて来て三人を取り囲んだ。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミノタロウスは大魔王ミノスに仕える大量生産タイプのアンドロイドで、首から上が牛で首から下が人間という不気味な恰好をしている。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "“ソレヲ考エルコトハ許サレマセン”　不意に一匹のミノタロウスがしびれを切らしてアリアドネ姫に躍りかかる。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリアドネ姫はミノタロウスの槍の一撃を受け、胸を血に染めて砂漠に倒れる。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは反射的に黄金の剣を拾い、仇とばかりにミノタロウスに襲いかかる。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "両者はしばらく何回か切り結んでいたが、そのうちに隙をついたあなたの剣がミノタロウスの首をはねる。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはもう一匹のミノタロウスに戦いを挑み、すぐさま相手を倒してしまう。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大魔王ミノスとミノタロウスたちはこの球体に住んでいた。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大魔王様、申し上げます」一匹のミノタロウスが部屋に入って来て大魔王ミノスの前にひざまずいた。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした無数の存在のうちの一つが今の我々なのです」「いや、俺たちは存在していないんだ」　するとそこへもう一匹のミノタロウスが入って来て、大魔王ミノスの前にひざまずいた。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までいた方のミノタロウスは深々と大魔王ミノスに頭を下げ、その場を退いた。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ようやく完成しました」新しく入って来たミノタロウスはそう言って長い銀の棒を大魔王ミノスに献上した。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いかがでしょう」ミノタロウスは得意気に言った。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
