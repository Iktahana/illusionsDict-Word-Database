        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "平泳ぎ、背泳ぎ、両抜手、片抜手、競泳、立ち泳ぎ――等を悉く試みた。",
              "citation": {
                "source": "「或る日の運動」の続き",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ふりかえると、三メートルほどむこうで、高志がニヤニヤしながら、立ち泳ぎをしていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大原と肩をならべる水練の達者は、三上治太郎、福井文吾の二人で、去年の夏の水練御上覧の節には、大原は隅田川のまん中で立ち泳ぎをしながら短冊に歌をかいた。",
              "citation": {
                "source": "鐘ヶ淵",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三上はおなじく立ち泳ぎをしながら西瓜と真桑瓜の皮をむいた。",
              "citation": {
                "source": "鐘ヶ淵",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは立ち泳ぎをしながら、のみこんだ水をはきだすと、頭をめぐらして方角を見さだめた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "身がまえたといっても、風呂の中で立ち泳ぎをしているときのように、おかしいほど、お尻がふわりと浮きあがる気持だった。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっとのことで追いついたとき女は立ち泳ぎをしながら笑っていた。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ふたりは手をつないだまま、まっくらなつめたい水の中で、立ち泳ぎをはじめました。",
              "citation": {
                "source": "大金塊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "胴のない生首は、胴をかくして立ち泳ぎをしている人間のように、グルリとまわって、足軽のほうへ顔を向けた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
