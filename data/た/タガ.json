[
  {
    "uuid": "257b88ed-7c49-587c-aa89-a25ea6391bd9",
    "entry": "箍",
    "reading": {
      "primary": "タガ",
      "alternatives": [
        "たが"
      ],
      "is_heteronym": false
    },
    "grammar": {
