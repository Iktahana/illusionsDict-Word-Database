        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "目の前で美味しそうなケーキを食べられたら、一口もらわずには堪ったもんじゃない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ひどい裏切りをされて、あいつに一言文句を言わずには堪ったもんじゃない気分だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あんな奇跡を見せられて、驚かずにいろなんて堪ったもんじゃないよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
