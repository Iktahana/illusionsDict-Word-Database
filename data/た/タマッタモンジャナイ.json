        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "プロ野球選手の打球のスピードは、間近で見ると堪ったもんじゃない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の毒舌の鋭さは相変わらずで、標的にされた方は堪ったもんじゃないだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夏休みに入った途端の子供たちのエネルギーは、親にとっては堪ったもんじゃない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
