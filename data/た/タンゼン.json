[
  {
    "uuid": "5610a2fb-8acd-5ac7-ba64-294df39581a3",
    "entry": "丹前",
    "reading": {
      "primary": "たんぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "large padded kimono",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "家に在る時は、もっぱら丹前下の浴衣である。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れた浴衣は、汚れたままで倉庫にぶち込んでいたのだし、尻の破れた丹前も、そのまま丸めて倉庫に持参していたのだし、満足な品物は一つとして無いのだ。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十とはトテモ見えない襟化粧、引眉、口紅、パッチリと女だてらのお召の丹前に櫛巻頭。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は上衣と胴衣を脱いでワイシャツ一つのネクタイを緩めているし、眉香子も丹前を床の上に脱ぎ棄てて、派手な空色地の長｜襦袢に、五色ダンダラの博多織の伊達巻を無造作に巻きつけている。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛湯をつくったり、丹前を着せたりしてくれた。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹前を着て、その上に毛布を被ってもなお滲み透ってくるような寒さを冒して、清逸は「折焚く柴の記と新井白石」という論文をし上げようとした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだね、ここは」　良人は浴室で一風呂浴びて来た血色のいい肌へ浴衣に丹前を重ねたものを不器用に着て縁に立ちました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "客は河豚で温まり、てかてかした頬をして、丹前の上になにも羽織っていなかった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はどうぞとこちらを向いて、宿の丹前の膝をかき合わせた。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にかお辻が丹念に蓄へて置いた珊瑚の根掛けや珠珍の煙草入れ、大切に掛け惜んでゐた縞縮緬の丹前、娘達の別れがたみの人形、宗右衛門自身が江戸の或る大名家老から頂戴した羽二重の褥が紅白二枚、死出の旅路をひとりで辿るお辻の小さな足にも殊更に絹｜足袋を作つて穿かせ、穿きかへまでも一足添へた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして宿の丹前に羽織をひっかけ、こうなれば一つその地蔵様におまいりでもして、そうしてここを引き上げようと覚悟をきめた。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹前風呂とか羅馬の浴場とか云ふものは、蓋し爛熟せる文明の窮極である。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴食の癖なども殆ど失せたせいか、健康もずっと増し、二十｜貫目近い体に米琉の昼丹前を無造作に着て、日向の椽などに小さい眼をおとなしくしばたたいて居る所などの氏は丁度象かなどの様に見えます。",
              "citation": {
                "source": "岡本一平論",
                "author": "――親の前で祈祷",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまは、そこに在った丹前を父の寝姿の上にかけました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母だけが長火鉢の前に丹前を着てまだ起きていました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは嘉六が着ている丹前が母のものであると気付くと「成程ね」と、わたくしが半ヵ月ほど留守中のわが家の沿革をほゞ覚りました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人のうちの一人は四十四五で、素肌へ茶の縦縞の薄い丹前を被ていたが、面長の色の白い顔のどこかに凄味があった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それで、奴さん、何と云ったのだ」　丹前の前には円い食卓があった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹前は盃を持って飲みながら考えていた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、いい」丹前は気が注いたように揉あげの背後姿へ眼をやった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お時は丹前に愛想笑いをした。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おめえでも、風景が判るかい」「判るさ、俺はこれでも、漢詩の平仄を並べたことがあらあ、酔うて危欄に倚れば夜色幽なり、烟水蒼茫として舟を見ず、どうだい、今でも韻字の本がありゃ、詩ぐらいは作れるぞ」　丹前が口を入れた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「作る田がないから、東京へ来て強請をやってるだろう」「お互さまだよ」「お互さまじゃねえや、俺はもとからの破戸漢だ、おめえは学生から、おっこちて来たのだ、物が違わあ、いっしょにせられてたまるものかい」　丹前が笑いだした。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は品川大井大森方面を縄張にしている匪徒で、丹前は岡本と云う三百代言あがり、揉あげは松山と云って赤新聞の記者あがり、角刈は半ちゃんで通っている博徒であった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　眠つてゐるのかとばかり思はれた深井と友田が同時に叫んで起きあがると、毛布やら丹前やらをかむつて、ごろごろとしてゐた連中が、「否応はないよ。",
              "citation": {
                "source": "海路",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『嬉遊笑覧』に『犬筑波集』猿の尻木枯ししらぬ紅葉かな、『尤の草紙』赤き物猴の尻、『犬子集』昔々時雨や染めし猿の尻、また丹前能日高川の故事を物語るところになんぼう畏ろしき物語にて候、猿が尻は真赤なと語りぬとあり。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹前風呂でも女の杯は手にとったことがない。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん遠い昔には丹前風呂などの名があって、江戸でも風呂屋と呼んでいたらしいが、風呂屋の名はいつか廃れて、わずかに三馬の「浮世風呂」にその名残りを留めているに過ぎず、江戸の人は一般に湯屋とか銭湯と呼び慣わしていた。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "源吉はすぐ、押入れから、垢でベト／＼になつた丹前をとり出して、それを頭からかぶると、寢てしまつた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、隣り同志が、丹前の前を抑へながら、きゝ合つた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
