[
  {
    "uuid": "bb6209fd-db99-500b-a281-88664789a705",
    "entry": "叩き",
    "reading": {
      "primary": "たたき",
      "alternatives": [
        "タタキ"
      ],
      "is_heteronym": false
    },
    "grammar": {
