    "definitions": [
      {
        "index": 1,
        "gloss": "finely chopped fish or meat (sometimes seared first)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "汝の獲たるケチくさき名譽と希望と、汝の獲たる汗くさき錢を握つて勢ひ猛に走り行く自動車の後枯れたる街樹の幹に叩きつけよ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の屋蔭の苔むしたる井筒に、新調の洋服涼しげなる若人二人、巴里形の麥藁帽子見よげにかぶりて、細き櫻のステツキを手すさびに振り上げ、花もまだきなる紫陽花の葉を叩きつ、あやめを隔ててこなた、うちまもり給へるなりけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やくざな私を、無言のうちに叩きあげて下さるのも、すべて兄上のちからである。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と龜は鰭でもつて浦島の脊中を叩き、「王宮といふものは皆このやうに靜かなものだよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、唯一つのたのしみだ）たかだか五枚六枚の隨筆の中にも、私の思ふこと全部を叩き込みたいと力むのである。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の思ひ出摘み溜めしれんげの華を　　夕餉に帰る時刻となれば立迷ふ春の暮靄の　　　　土の上に叩きつけいまひとたびは未練で眺め　　さりげなく手を拍きつつ路の上を走りてくれば　　　　（暮れのこる空よ！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "猟師は、焼木杭に烟管をコツコツ叩きながら、　今がた雷鳥が何羽も出来やした。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾根の頂上へ出たときは、大斜線の岩壁が、深谷へ引き落されて、低くなったかとおもうと、また兀々とした石の筋骨が、投げ上げられて、空という空を突き抜いている、そうして深秘な碧色の大空に、粗鉱を幅広に叩き出したような岩石の軌道が、まっしぐらに走っている。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろ頭か、首筋に寒気でもするんかい」　私は又、実際、セコンドメイトが、私の眼の前に、眼の横ではいけない、眼の前に、奴のローラー見たいな首筋を見せたら、私の担いでいた行李で、その上に載っかっている、だらしのないマット見たいな、「どあたま」を、地面まで叩きつけてやろう！",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "可哀相に、何も知らねえ奴が、棍棒を飲み込みでもしたように、叩き出されかけているこったろう。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子を引き千切るようにとって、そいつを下に叩きつけた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "百貨店の大きな出庇の亀甲形の裏から金色の光線が頸の骨を叩き付けるほど浴せかける。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "運命に叩き伏せられたその絶望を支えにしてじりじり下から逆に扱き上げて行くもはや斬っても斬れない情熱の力を感じさせる。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京から遥々見送って来た安兵衛という男が、宿屋で毎日朝から酒ばかり飲んでいて、酔って来ると箸で皿を叩きながら「ノムダイシ、一升五合」（南無大師遍照金剛）というのを繰返し繰返し唱えたことも想い出す。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "素裸で村の川や溝へ這入っては、鮒鰌をすくったり、蛙を呑んでいる蛇などを見つけては、尻尾を手づかみにして叩き殺す位なことは、平凡ないたずらの方であった。",
              "citation": {
                "source": "井戸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画の頂点はヒロインが舞台で衣裳をかなぐり捨てブロンドのかつらを叩きつけて煩わしい虚偽の世界から自由な真実の天地に躍り出す場面であって、その前のすべてのストーリーはこの頂点へ導くための設計であるように見える。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時の酒飮仲間だつた歌人河野愼吾君は、幼ない婚約の妻をもつてゐるといふだけで、君の苛立たしき嫉妬を買ひ、幾度か本郷の街路に組み伏せられ、理由なく下駄で頭を叩き割られた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜おそく、東京市中の電燈を門竝に叩き壞し、交番の巡査に石を投げて留置所に入れられた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして素つ裸の腰に箒をさし、手に蠅叩きをもつて階上から獸のやうに叫んだ。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝ているのを叩き起していたもんですから。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "投げられた遊び人泡食って、Ｔ「ナッナッ何かの間違いですよ」　と言いわけするのも聞かず、さんざん叩きのめす。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉が、Ｔ「拙者、強い方を　叩き斬る」　面喰って居る旗本を尻目に大吉尚も、Ｔ「貴殿が御強よう　厶ったら、今頃　貴殿の其の首は　まさか胴には……」　「着いちゃいまいテ」と大笑する。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "急速に、（Ｆ・Ｏ）　叩き出された徳兵衛だ。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝附近　お小夜と半次がその侍の前方に立ちふさがり、遂に四人でその侍を叩き伏せ文箱を奪う。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎も角、団九郎、無茶苦茶に叩きのめされ逃げ廻っては又叩かれ、　（三枚目的な立廻りよろしく）　遂に、長うなってしまった。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し大時代に天狗退治をやって下さい）　遂に天狗を叩き斬ると、　苦しみもがく天狗。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵が「人違いじゃ」と言い乍ら一同を叩き付ける。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に、危い二人を救けて、　家臣共を尽く川へ投げ込み、又は打ちのめし、最後にお殿様をチャチャクチャに叩き付けてフラフラになったお殿様の首筋掴んで、Ｔ「仇討の熱病　患者奴！",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝町　例の立札が、大地に叩き付けられて居る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "服は着たるばかりなりと覚しく、手にて皺を熨すように撫で、埃を払うように叩きつつ、寝間の戸を開けて登場。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
