    "definitions": [
      {
        "index": 1,
        "gloss": "to beat back into shape",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
