    "definitions": [
      {
        "index": 1,
        "gloss": "watching while standing (e.g. a play)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "実山の高さが見るものの心積りの高さにかなりの相違があっても、全然見るものの心積りを根底から破却し去らない限り、そこに観念なるものと実在なるものと比較し得られる桟はしがあってその上に立ち見るものをして両端の距りを心測して愕きの妙味を味い得しめるよすががある。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "登り立ち見れど宜しみ。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "下り居立ち見れど宜しみ。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに名門の生れは何事にも際立ち見映ある振舞にものし給ふなど語れば、次に聞居たる少歳は堪へかねた面持にいざり出でゝ、手古奈のいろせ少歳も、此度の馬競には必ず恩賞の列に入るべく勵みある由若殿へ聞え給へといふ。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ト幕ばかり芝居の立ち見をして、家へ帰った時には、笹村の頭は前よりも一層｜攪き乱されたような状態にあった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸立ち見をしないこと」　私は、日本映画は嫌いなのだが、蜂雀を麻雀とこじつけた幼稚なおかしさや、澄子がどんなに真似をするのかという好奇心に釣られた。",
              "citation": {
                "source": "茶色っぽい町",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず時には不自然に巻煙草の箱へ手を出したり、立ち見をした芝居を吹聴したりした。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ君夫婦とその一族は会場内の茶室へ招待されている間、私は娘曲芸団の立ち見をしていた。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "一しょに歌舞伎座の立ち見をした事もある。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どんぶりこ」とか言ふそんな時分まで、文楽のきり見立ち見は、一銭であつた。",
              "citation": {
                "source": "鶴屋団十郎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝を立ち見送らしめては、行き敢へまじ。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "みるは「世話をする」「ねんごろにとりあつかふ」など言ふ内容を持つてゐて、うしろみる（後見る）・たちみる（立ち見る）、中へ入つて世話をやく＝仲裁すると言つた用語例の語＝とるは「手づからする」「扱ふ」、さう謂つた意義に使はれることが多い。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又円たくを見つけて浅草にゆき、春秋座というので夕食をすまし、阪妻の立ち見をした。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえりに前川、月、橋の工事、浅草の立ち見でシーホークを見る。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "道に立ち見てゐる人に早苗とる笠二つうなづき合ひて早苗とる六月五日　横浜キリスト教青年会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今からの入場は立ち見になるという内容の書かれたプラカードが下がっている受付で当日券を買い、赤い絨毯が敷かれた長く広い階段を小走りで上がって行く。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち見の客がドアのところに何人も群がっていて、中に入るにはラッシュ時の電車に乗る要領で自分を体ごと押し込めなければならなかった。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞伎座の狂言なども、出し物の変る度びに二三度立ち見に出かけ、直きに芝翫や八百蔵の声色を覚えて来ます。",
              "citation": {
                "source": "幇間",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから私は毎晩のようにこの仮装をつづけて、時とすると、宮戸座の立ち見や活動写真の見物の間へ、平気で割って入るようになった。",
              "citation": {
                "source": "秘密",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山ざくら花の下風吹きにけり木の下ごとの雪のむらぎえ　　　　（康資王母）山深み杉の群ら立ち見えぬまで尾の上の風に花の散るかな　　　（経信）木の下の苔の緑も見えぬまで八重散りしける山桜かな　　　　　（師頼）このような歌が出来はじめた。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにまた歌よみしたまひしく、波邇布坂　吾が立ち見れば、かぎろひの一〇　燃ゆる家｜群、妻が家のあたり。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホールの通路にも壁際にも立ち見の女たちがいた。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく古代では国君ならびにその輔佐の任に当たる大官たちみずからこれらの科学的な事がらにも深い思慮を費やしたのではないかと想像される。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちみんな、ずいぶん世話を焼かせましたからね。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はもうお前たちみんな罰しなければならない。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう一足でおまえたちみんな頭をばりばり食われるとこだった。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、こういうようなわけで、ぼくたちみたいな上の階級の人間が、こんな台所にやってきたんですよ』『ぼくは、そんなのとは、ずいぶんちがってるよ』と、マッチたちのそばにいた、鉄なべが言いました。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、ぼくたちみんなに、こんなに親切で、この世の中の、ありとあらゆる美しいものをくださったんですもの」　旅の仲間も、手をあわせて、立っていました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたりが暗くなってね、ぼくたちみんなが寝てしまうと、おもしろそうにとびまわるんだよ。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちみんなが、以前より一そう可哀想になるだけじゃないか。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
