[
  {
    "uuid": "9a224dc4-c95d-5682-87e8-9f787b9e9357",
    "entry": "鬣",
    "reading": {
      "primary": "たてがみ",
      "alternatives": [
        "タテガミ"
      ],
      "is_heteronym": false
    },
    "grammar": {
