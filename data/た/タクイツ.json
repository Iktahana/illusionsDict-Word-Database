[
  {
    "uuid": "1e9eadec-a502-540f-ac7b-ade4e0e2b054",
    "entry": "択一",
    "reading": {
      "primary": "たくいつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "choosing one from among several",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すると私の財源は底を尽き始め、そこで二者択一を迫られている現状にようやく気が付いたのである。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとたびこれを受けたる者は従前の意志を表立って捨てるか、その地を逃亡するかの二者択一なり。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジミィ・ヴァレンタインは突然、恋の炎に二者択一を迫られ、身を焦がして灰になった。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般に物体ＡＢの間に運動現象が行なわれつつある時、もしＡを運動すると考えるもＢを運動すると考えるも任意であるとすれば、この場合の判断は択一判断である。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って運動関係には択一的、選言的、分配的の三つの場合があるのである。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがアスキーから一〇〇パーセント流し続けるか、完全に切れるかの二者択一を迫られて、独立の道を選んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝統主義はまさにこの二者択一に対する我々の決意を要求しているのである。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や国民は国民の総意か一部の暴力かの、二者択一の分岐点に立ちつつある。",
              "citation": {
                "source": "二・二六事件に就て",
                "author": "河合栄治郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつき、客観的事実として「あれかこれか」と二者択一的に判定し得るものでないからには、「生か死か」と問われても、「生ともいわじ死ともいわじ」と答を拒む外ないのである。",
              "citation": {
                "source": "メメント　モリ",
                "author": "田辺元",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二者択一に押しつけられた后は、不得已、癩病の体の頂の瘡に、天平随一の朱唇を押しつけた。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "立会人として、シアトルから来た有江老人も」「オプションというのは、二者択一の入札のことですね。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが自然科学に於てもテーマの選択一つにも、理論の組み立て一つにも、科学的成果の解釈一つにも、又理論の発達条件にも、凡てイデオロギーが口を利いているのである。",
              "citation": {
                "source": "辞典",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃ彼女も、二者択一というわけだ」「それでさっきのメチルのことは――」　蟹江はすっかりどぎまぎして、こんなとんちんかんなことを言いました。",
              "citation": {
                "source": "Ｓの背中",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして奉行から次のような二者択一の返答を強要された。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは余りになまめかしい物語なので、著者はこの本を焼くか司教職をすてるか、二者択一を迫られ、ついに司教職を棒にふったと伝えられている。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の見解では、確信の本質は、次の二者択一が論理的に必然である。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十六章　二者択一「グレイ、私が分りますか」　グレイがよろよろ立ち上がった。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして仔細にその錯綜の跡を検すれば、二語は久しく併存し、その択一は単なる小区域の流行であったことが知れるからである。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくいつもとはどこも変った顔ではなかったが、内心彼は愕然としていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくいつもそんなことを考えては千鶴子に近づいていた報いが、やはり一度はこんな風に来なければならぬのかもしれぬと、矢代も瞑目する思いで静まるばかりだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その目にはドロンドロンと変な焔が吹きあげていて、まったくいつ六尺棒が襲いかかるかはかりがたい殺気がこもっている。",
              "citation": {
                "source": "餅のタタリ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまったくいつ死んでもよい状態にあった。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、君はまったくいつもと変らない顔や態度でいるじゃないか。",
              "citation": {
                "source": "あるドライブ",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、たとえば、理性を完全に保ちながら無意義を欲するのは、みすみす理性に逆らって自分の害になることを望む結果になるので、そんなことをする馬鹿はないからである……まったくいつかそのうちには、いわゆる自由意志の法則が発見されるだろうから、すべての意欲や理性判断が本当に細かく計上されるかもしれない。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "不断は賑やかに、大勢の奴隷たちが往き交っている本邸の中も、そこに奴隷たちの姿はありながら、そこはまったくいつもとは違って、何とも言えぬしめやかさ……常の日よりも一倍ざわめきながら、言わば満邸涙に打ち湿っているとでも言ったような調子だったのであります。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まったくですね、まったくいつもなにか落し物をしたような顔つきですよ」彼はくすくす笑う。",
              "citation": {
                "source": "半之助祝言",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「トゥーサンだったら、」とジャン・ヴァルジャンは考えの拠り所を求めて何でも手当たりしだいにつかもうとしてるかのように言った、「私にはまったくいつも自己一流のやり方があることを、一番に認めてくれるだろう。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「酔わいで何としましょう」　光秀はまったくいつにない酒気に染まった顔をしている。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
