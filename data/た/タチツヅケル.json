        "examples": {
          "standard": [
            {
              "text": "吹雪の中でも、彼は迎えが来るまでその場所に立ち続けるつもりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "演劇の舞台裏で出番を待ちながら、何時間も立ち続けるのは苦にならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "どんなに辛いことがあっても、マイクの前で歌い立ち続ける覚悟を決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私がじっと同じ場所に同じ姿勢で立ち続けるよりも、歩いて体を運動させた方が余計に私の体をうまく調節させて健かになれるので、無意識ではあれ、自然と歩き出したのです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はただひとり真夜中の暗やみの中にすすり上げながら、まっ白に積んだ雪の上にうずくまってしまった、立ち続ける力さえ失ってしまって。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして僕は、「そうなると僕は、スペインの牢にはいるか、フランスの牢にはいるか、それともスペインとフランスとの国境にまたがっていて、スペインの巡査が来たらその方の足を引っこまし、フランスの巡査が来たらその方の足を引っこまして、幾日でもそうしたまま立ち続けるようなことになるんだね。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
