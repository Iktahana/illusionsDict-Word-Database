    "definitions": [
      {
        "index": 1,
        "gloss": "Pacific War (1941-1945)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
