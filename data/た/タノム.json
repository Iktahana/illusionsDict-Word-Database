    "definitions": [
      {
        "index": 1,
        "gloss": "to request",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それ等の者が、彼が渡り廊下に掛かるや「頼むぞ」といふ眼差を一斉にさし向けた時に、彼の頭の中では「よろしい！",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてドンキホーテは、自分を「憂ひ顏の騎士」と呼んでくれと從者に頼む。",
              "citation": {
                "source": "郷愁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姐さん、頼むからもう止してよ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私はそう答えながら、ものごとを片付けるなら一番あとにして下さいと頼む。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「頑張れよ」「御大事に」「しっかり頼むよ」口々にこうした激励の言葉を投げた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さんは行ってもえい」　自分がそういうと、母はいろいろ頼むと云う様な事を云って立ちかける。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はしようことなしに、よろしく頼むといってはいるものの、ただ見る眠ってるように、花のごとく美しく寝ているこの子の前で、葬式の話をするのは情けなくてたまらなかった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が降って地面が柔らかくなり、ナポレオンが力と頼む砲兵の活動に不便なために戦闘開始を少し延ばしたばかりにブリュヘルが間に合って戦局が一変したと云うのである。",
              "citation": {
                "source": "戦争と気象学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "田中舘先生の肖像を頼む事に関して何かの用向きで、中村｜清二先生の御伴をして、谷中の奥にその仮寓を尋ねて行った。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎が、Ｔ「その印籠を所持致す奴こそ敵棚倉伝八郎」　聞いた三次が「よう御座います」と引受けて、Ｔ「三日もありゃきっと探し出してお見せします」　何分よろしくと三四郎が頼む。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲蔵「そう仰言らず」と一同と共に頼むが、　半次、断然啖呵切る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　仲蔵仰天した「そんな、無理な事」　大吉「あかんちゅうたら、駄目だ」　仲蔵「そう仰言らずに……」と必死に謝り頼む。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲蔵が尚も必死に頼むのを、大吉ニタニタ笑い乍ら聞き流して居たが暫時して、Ｔ「汝　それ程　舞台へ出たいか？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲蔵「はい出とう厶います」と涙見せて頼む。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "典六、命許りは……と頼む。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言ってお小夜に実はこれこれでと頼む。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "左衛門が、Ｔ「その連判状が老中の手に入らば」　と声を落して、Ｔ「身共は切腹モンじゃ」　其処で喃七兵衛、Ｔ「何とかしてその連判状を雲霧の手から奪い取って貰い度い」　と頼む。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「少しも早くお帰り下され」　と頼むのを、　冷笑浮べてなりひら、Ｔ「ところで」　俺も、　えッ、と左衛門。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（顫いつつ仰ぎ見て、頼むように。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンナが己に保護を頼むのだ。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "よほど欲しいときは、娘のともよにこっそり頼む。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうか頼むから、もっと、喰べるものを喰べて、肥ってお呉れ、そうして呉れないと、あたしは、朝晩、いたたまれない気がするから」　子供は自分の畸形な性質から、いずれは犯すであろうと予感した罪悪を、犯したような気がした。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外から頼むように扉を叩く。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の次第で徳さんの武もついに手をひいて半年余りもたつと、母はやっぱり気になると見えて、どうにかして石井さんを説き落としてくれろと頼む。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもお徳の不審はまだ晴れないので、旦那かおかみさんを起こしてくれと又頼むと、寅次は不承不承に奥へはいったが、やがて女房のお新を連れ出して来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃあ、なにしろ頼むよ」　云いかけてふと見かえると、家の前に立ってこわごわと覗いている大勢の群れから少し離れて、一人の若い男がこっちの話に聴き耳を立てているらしく、時々に偸むような眼をして二人の顔色を窺っているのが半七の眼についた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "別にむずかしいことじゃああるめえ」「ええ、どうにかこじつけて見ましょう」「しっかり頼むぜ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼りにしていた娘に別れて何分寂しくてならないから、お前さんを見込んで頼む、どうぞ養子になってくれと云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　Ｋのをぢさんは半七を信用して萬事を頼むと云つた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、昨年の秋、山田君から手紙が来て、小生は呼吸器をわるくしたので、これから一箇年、故郷に於いて静養して来るつもりだ、ついては大隅氏の縁談は貴君にたのむより他は無い、先方の御住所は左記のとおりであるから、よろしく聯絡せよ、という事であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
