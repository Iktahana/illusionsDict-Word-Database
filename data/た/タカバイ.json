        "examples": {
          "standard": [
            {
              "text": "ハイハイを始めたばかりの息子が、最近お尻を高く上げた高這いで移動するようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ズリバイから高這いへと進化する赤ちゃんの様子を見て、成長の早さに感動した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "高這いができるようになると、部屋の中の行動範囲が一気に広がって目が離せない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "猪熊の爺は、尻居に倒れて、とび出しそうに大きく目を見ひらいたが、急に恐怖と苦痛とに堪えられなくなったのであろう、あわてて高這いに這いのきながら声をふるわせて、わめき立てた。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛飼いの若者はその火に毛脛を焼かれながら、悲鳴を挙げて飛び起きると、無我夢中に高這いをして、裏手の方へ逃げ出そうとした。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は血にまみれながら、ほとんど高這いをしないばかりに、蹌踉と部落を逃れて行った。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
