    "definitions": [
      {
        "index": 1,
        "gloss": "inquisitive mind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
