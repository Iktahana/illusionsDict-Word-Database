    },
    "definitions": [
      {
        "index": 1,
        "gloss": "light (flavor, color, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "要するに「いき」な味とは、味覚のほかに嗅覚や触覚も共に働いて有機体に強い刺戟を与えるもの、しかも、あっさりした淡白なものである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種の淡白な味を味わってみる事は虚心な鑑賞家に取って困難ではないだろう。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たくらまない表現がそれを語つてゐるやうに、正直な淡白な人だ。",
              "citation": {
                "source": "青空同人印象記（大正十五年六月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しこんな稼業のものにはめづらしい正直な淡白した江戸兒風の男で、御用を嵩に着て弱い者を窘めるなどといふ惡い噂は曾て聞えたことがなかつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "尠くともお酒が這入つてゐれば、淡白といふか愚かといふか、人が体面を慮つて遠慮するていのことくらゐは、ても眼中にないのである。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを付け合せの茸の淡白の味が飄逸に取做す、山野の侘びとフランス人工の奢りとの取合せだ。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "武村兵曹は相變らず淡白で、慓輕で、其他三十｜有餘名の水兵等も一同元氣よく、大なる希望の日を待望みつゝ、勤勉に働いて居る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "杯次第にめぐりつゝ、いや、これは淡白して好い。",
              "citation": {
                "source": "九九九會小記",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、淡白なお菜のことを、「金魚の餌みたいなもん喰わしやがって」、商人の談合のことを、「いちゃ／＼と〇〇〇してけつかる」などは、彼でなくてはの感がある。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "辛子菜の香味、茄子の色彩、胡瓜の快活、糸菜の優美、――しかし私はどちらかといえば、粕漬の濃厚よりも浅漬の淡白を好いている。",
              "citation": {
                "source": "漬物の味〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "温雅淡白よりも豊艶爛熟を喜ぶ白秋氏。",
              "citation": {
                "source": "夜長ノート",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "『金銭に淡白になれないロマンティストなんて、鼻もちになったものではない…』そこで、私は到頭この高価な買物を余儀なくさせられた。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭はアツサリした束髪に白いリボンの淡白な好。",
              "citation": {
                "source": "虚弱",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子という女性は、時によっては非常に執念深く私情に駆られるが、時によってはまるで別人のように公平で淡白な性質も持って居る。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡白で快活な男ですがね」　社長はビールを啜ったり、ハンカチで鼻を擦ったりする動作を忙しくして、やや興奮の色を示し、「へえ、あの男がこういう美しいお嬢さんとそういうことがあるんですか。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄弟達は私の不服を淡白な笑ひに紛らしてしまひ、結局、山陰雜煮なるものを私達の家庭に紹介しやふと云ふのである。",
              "citation": {
                "source": "雜煮",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏は、金銭にもどちらかと云えば淡白な方でしょう。",
              "citation": {
                "source": "岡本一平論",
                "author": "――親の前で祈祷",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し西先生が何か道徳の極まつた箪笥を持つてをつて、物事を片附けてゐる人であつたならば、さう淡白にインキの小言も言はなかつたかと思ひます。",
              "citation": {
                "source": "混沌",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽い淡白な気もちを持っている小鳥のような女が、隻肱を突いて机の横に寄りかかってじっと耳を傾け、玄関の硝子戸の開く音を聞きながら、己の帰るのを待っている容が浮んで来た。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船賃は望み次第出すが……と尋ねてみると、淡白らしい船頭は、城ヶ島なら屈託する事はない。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁の嗜好は昔から淡白で、油濃いものが嫌いと老夫人がよく他人に吹聴して居られた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽い淡白な気持を持つてゐる小鳥のやうな女が、片肱を突いて机の横に寄りかかつてぢつと耳を傾け、玄関の硝子戸の開く音を聞きながら、自分の帰るのを待つてゐる容が浮んで来た。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、西洋料理、初夏の野菜、淡白な魚類。",
              "citation": {
                "source": "回答",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも淡白な彼等の怨恨は三｜人以上が聚つて口を開けば必ず笑聲を絶たぬ程のものであつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍人といふものはそこに到ると淡白である。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは牛肉に胡椒を振かけたものであつたが、脂肪がすつかりぬけてしまつてゐて、サラ／＼とした、淡白な味のものであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "流布される人気は何時の場合も、好感的なもので、作為のない彼の人柄がさうした好ましさを生むのであらう、この作家の初期の画面は神経をゆきわたらした、ねつとりとした粘液質のものだが、最近作では次第にそれが様式化され図式化されてきてゐて、淡白なものになつてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "事情いかんにかかわらず生命の物質的基礎はたんぱく質であるに相違ない。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
