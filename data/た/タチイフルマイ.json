        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女の洗練された立ち居振る舞いは、多くの人を魅了する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "茶道では、立ち居振る舞いの一つ一つに意味が込められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しい環境に慣れるまで、彼の立ち居振る舞いは少しぎこちなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それでいて立ち居振る舞いは軍人、人並みのほおひげもある。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時は一つ屋根の下で暮らしたこともある祖母でしたが、日常的な立ち居振る舞いの中で、なにを考え、なにを感じていたかはほとんど知りませんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "身のこなしとか、立ち居振る舞い、あるいは体の使いかた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "三ばんめの妖女は、王女のたちいふるまいの、やさしく、しとやかにありますように、といいました。",
              "citation": {
                "source": "眠る森のお姫さま",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔だちもまるくおっとりとしていたし、たちいふるまいものびやかで、彼女がとついで来てからは、きゅうに家のなかが春風のふきとおるようなにおやかな気分につつまれたものである。",
              "citation": {
                "source": "日本婦道記",
                "author": "松の花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
