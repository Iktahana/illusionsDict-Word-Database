    "definitions": [
      {
        "index": 1,
        "gloss": "Emperor Taishō (1879-1926, reigned 1912-1926)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
