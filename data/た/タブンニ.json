[
  {
    "uuid": "dc044666-6396-5e96-b3ea-0726ccfbb87b",
    "entry": "多分に",
    "reading": {
      "primary": "たぶんに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "in great amount",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つまり我が国では、技術家も猶多分に政治家である場合に助かる。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分僕の性格中にあるニヒリスチツクの傾向や、多分にアナアキスチツクの氣質やに、別の意味の關心を持つたのだらう。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川龍之介は一代の才人であり、琴棋書画のあらゆる文人芸に達した能士であつたが、その俳句は、やはり多分にもれず文人芸の上乗のものにしか過ぎなかつた。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生氏の場合も亦これと同じく、彼の句作の態度には、趣味性の遊離した享楽（ヂレツタンチズム）が多分にある。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に獨逸、佛蘭西等の如く、世界で最も科學の發達してゐる國の子供は、最もよくフアンタジイのお伽話を好む子供であり、したがつてまた秀れた童話作家を、多分に所有してゐる國なのである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに蕪村の俳句だけは、この時代の異例であって、そうした青春性を多分に持っていた。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "島崎藤村氏の名詩「千曲川旅情の歌」と、どこか共通した詩情であって、もっと感覚的の要素を多分に持っている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水仙や寒き都のここかしこ　京都に住んでいた蕪村は、他の一般的な俳人とちがって、こうした吾妻琴風な和歌情調を多分に持っていた。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉のイデアした哲学は、多分に仏教や老荘の思想を受けてる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし本來僕と人間的氣質を異にし、且つ生理的にも健康性を多分に持つてる二人の詩人が、僕と同じ仕方でドストイェフスキイを讀む筈が無かつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが即ち文化の余裕といふものであり、昔の日本の江戸や、今の仏蘭西の巴里などで、この種の閑人倶楽部が市中の至る所に設備されてるのは、文化が長い伝統によつて、余裕性を多分にもつてる証左である。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして色々の変った新しい様式が将来生れ得る可能性が多分にありそうにも思われます。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのきんとんには、サッカリンが多分に入っていることを、私は知っていた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "故人北原多作氏のごとき少数な篤学の官吏の終生の努力と熱心によってようやく水産に聯関した海洋調査がやや系統的に行われるようになりはしたが、自分の知る限りでは時々の政府の科学的理解のない官僚の気まぐれなその日その日の御都合による朝令暮改の嵐にこの調査の系統が吹き乱される憂いが多分にあった。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四郎馬鹿さんに見舞われた店は、どうも繁昌するようだ」　それには多分に迷信性と流行性があったかも知れない。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "してみると、これらの武家物は決してかくのごとき末世的武士道を礼讃し奨励するつもりではなく、反対にその馬鹿らしさを強調し諷諫するような心持が多分にあったのではないかとも想像される。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良朝においても、その結果だけが襲用されたもので多分に形式化したものであったろう。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "善用すればむしろ非常に好い効果をあげ得べき可能性を多分にもっているものである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の自然観人世観が始めから多分に俳句漢詩のそれと共通なものを含んでいた事は明らかであるが、しかしまた先生が俳句漢詩をやった事が先生の自然観人世観にかなりの反作用を及ぼしたであろうという事も当然な事であろう。",
              "citation": {
                "source": "夏目先生の俳句と漢詩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも晩年の作品の中に現われている色々のものの胚子がこの短い詩形の中に多分に含まれている事だけは確実である。",
              "citation": {
                "source": "夏目先生の俳句と漢詩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の性格氣質の中には、多分に東洋的のものが滲み渡つて居る。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、無｜論お互に胸中｜密に「なアに己の方が……」と思つてゐる事は、それが將棋をたしなむ者の癖で御多分に洩れざる所。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "元來｜私は少年時代から寫眞をやる、昆虫｜採集をやる、草花を作る將棋をさすといふ風で、少々｜趣味の多過ぎる方なのだが、そして、一時それぞれにかつと熱中する方なのだが、球突も御多分に洩れず、少し味が分り出すともう面白くてたまらなくなつて來た。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でもその感じはなお多分に残っているだろう。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然主義文学が、資本主義的生産関係を反映し、あるがまゝに現実を描こうと企図したのに対して、この写生派、余裕派、低徊派等は支配階級の中に根強く巣喰っている封建主義を多分に反映して逃避的唯美的傾向に走っていた。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人は西洋人のように自然と人間とを別々に切り離して対立させるという言わば物質科学的の態度をとる代わりに、人間と自然とをいっしょにしてそれを一つの全機的な有機体と見ようとする傾向を多分にもっているように見える。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ白猫の母は宅の飼猫で白に雉毛の斑点を多分にもっていたが、ことによると前の白猫と今度の「白」とは父親がおなじであるか、ことによると「白」が「ボーヤ」の子であるかもしれないと思われた。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物の着かたや、髪の結び方や、断片的な方言まじりの話しっ振りの中に、まだ、内地の匂いが多分に匂っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴動に移るけはいは多分に加わった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　エルンスト・トルレル――「独逸男ヒンケルマン」「変転」（独逸男ヒンケルマンは戦争で睾丸を失った男の悲痛な生活を書いたものであるが、多分に人道的である。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
