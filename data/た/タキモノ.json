        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜がふけて煖炉の火もだんだん衰えたらしく、堀部君は何だかぞくぞくして来たので、探りながら寝床を這い降りて、まん中の土間へ焚き物の高粱を取りに行った。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に二、三の問答を終って二人は庫裏の方へまわって見ると、納所の了哲と小坊主の智心があき地へ出て、焚き物にするらしい枯れ枝をたばねていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く刈込んで来なければ、たべ物ばかりか、焚き物にも困るじゃないか。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聞くと主人も伜たちの残酷を責める気にもなれなくなって、そんなら思い切って十分に焼いてしまえというので、自分も手伝って、焚き物をたくさんに入れて、哀れな旅びとふたりを火葬にしてしまったのです。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえさんはどこから来て、焚き物をしていなさるのだ」と、彼は訊いた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神後記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「焚き物はたくさん仕込んで置くがいい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "小女郎狐",
                "note": "青空文庫"
              }
            },
            {
              "text": "孫七の家には大きな囲炉裡に「お伽の焚き物」の火が燃えさかっている。",
              "citation": {
                "source": "おぎん",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母は焚き物に事を欠けば、立ち腐れになつた寝殿へ、板を剥ぎに出かける位だつた。",
              "citation": {
                "source": "六の宮の姫君",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭火などで、かっと、煎じては効がないと、義観様、いろいろと、焚き物のことを教えて下さいましたが――お師匠さん、お粥は、土鍋で、松の木で炊いたのが、一番おいしいそうでございますって。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の收穫が十月でをはり、日は一日毎にくらくなる頃、冬のための焚き物や食べ物の貯藏、家根や塀のための雪がこひの支度に取りかかる。",
              "citation": {
                "source": "地方主義篇",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、そこに蝋燭や焚き物があるかどうだか見てくれ。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "貸家",
                "note": "青空文庫"
              }
            },
            {
              "text": "爐の火も同様で、焚き物のひかりは吸い取られるように薄れて来て、部屋の中はまったく暗くなった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "貸家",
                "note": "青空文庫"
              }
            },
            {
              "text": "まわりはいちめんの叢林だから、焚き物にも困らない。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "オ、そのうしろに舟板がある」「こりゃ漁師の渡世道具、こいつを焚き物にされちゃ、さだめしあとで困るだろうが」「ふ……盗人の菩提心」「あまり後世の功徳にもなるめえな」「あたりめえだ。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……が、まあまあ白鳳期の御本尊、石川観音の御像が持ち出されて、焚き物にされなかっただけでも、目ッけものか」　堂守の一僧は、ぼやきながらも、やがて箒を手に、片づけはじめた。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "『おわあ、こんばんは』『おわあ、こんばんは』『おぎやあ、おぎやあ、おぎやあ』『おわああ、ここの家の主人は病気です』貝つめたきもの生れ、その歯はみづにながれ、その手はみづにながれ、潮さし行方もしらにながるるものを、浅瀬をふみてわが呼ばへば、貝は遠音にこたふ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "灼然として雲を駆って白日を見る如し、といふ語の駆雲の二字の如きは、我が邦の歌の中には見がたきものなるべし。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちこち陽炎や、糸遊がたきしめた濃いたきもののように靡くでしょう。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろのまっ黒なびろうどの幕が両方にさっと開いて顔の紺色な髪の火のようなきれいな女の子がまっ白なひらひらしたきものに宝石を一杯につけてまるで青や黄色のほのおのように踊って飛び出しました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人の霊性の、飄として捉へがたく、杳として目覩しがたきものは、其樹木の根の如し。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その面貌の無邪気なる、そのいふことの淡泊なる、要するに看護員は、他の誘惑に動かされて、胸中その是非に迷ふが如き、さる心弱きものにはあらず、何らか固き信仰ありて、譬ひその信仰の迷へるにもせよ、断々乎一種他の力の如何ともしがたきものありて存せるならむ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに冷たきもの、真珠、鏡、水銀のたま、二枚わかれし蛇の舌、華魁の眸。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽の多様は是非なし、ピアノを用ふることも風琴を用ふることも、我劇の古色を傷くる限りは出来ぬ相談なるが故に、我邦の楽にて推し通すは可也、然れども願くは、楽と動との関係を最少し緩るくして、演者の活溌なる動作を見ることを得たきものなり。",
              "citation": {
                "source": "劇詩の前途如何",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「否、誰のとも定らねど、われも愛でたきものにこそ思ひ侍れ。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「否、誰のとも定まらねど、われも愛でたきものにこそ思い侍れ。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると、光秀の軍は絶えず右翼を脅威せらるることになり、中央軍の奮戦に拘わらず、敗色既に掩いがたきものがあった。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて三重県に続いて和歌山県に合祀の励行始まり、何とも看過しがたきもの多きより、熊楠諸有志と合祀反対の陣を張り、地方および京阪の新聞紙をもってその説を主張すること年あり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "――廬を結ぶ古城の下、時に登る古城の上、古城｜疇昔に非ず、今人自ら来往す――一九三二年、秋ちかきころ、私はそんな古詩を愛誦しながら、愛国の詩をつくりたきものよ！",
              "citation": {
                "source": "私の万年筆",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の上京の節は健康をとり戻して、田舎弁いともさわやかに、大手をふるつて闖入したきもの――など、考へはぢめると、僕は、今、云ひやうもなく興奮して来て、ペンなども持つて居られなくなつた。",
              "citation": {
                "source": "久保田万太郎",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "人命は明日を期しがたきもの故、早く罪を定めんとするが第二の理由である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
