[
  {
    "uuid": "a0362f7c-59a7-5cca-a8d3-927503758b78",
    "entry": "平らげる",
    "reading": {
      "primary": "たいらげる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
