[
  {
    "uuid": "272143d6-4317-5c5d-9948-954c54aa429b",
    "entry": "体現",
    "reading": {
      "primary": "たいげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "personification",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "灰青色した緻密の熔岩と砂礫と互層をしているところを、筋違いに岩脈がほとばしって、白衣の道者たちが大沢で祈ったのと同じように、この岩脈を十二薬師の体現と信じて、崇拝するという話である。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ」「い」「う」「え」「お」に相当する諸音は、大体現代語と同じく、皆母音であってａｉｕｅｏの音であったらしい。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "処で、芥川氏の芸術に対して私が根本的に感じる不満は、それが全く人間的な体現だと云ふ気のしない事である。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "云ひ換へれば、智の境地以上の、全人間的体現を私は芸術家としての氏に求めたいのである。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち之を分類すれば、徳川初期のは強い圧迫に対する強い反抗の体現であつて、其の物の本当の意味からすれば、強い者に当る必要上真実に強きものたるを主とするは勿論であるが、真実に於ては寧ろ啻に強いことを見得として居る様な傾きのあつた、やゝ虚栄的衒耀的のものであつたらしい。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代のスポーツ流行はそうした進化の一階段に過ぎないので、喜多実氏がテニスのスタイルを能の中に体現し、松野奏風氏が素早くこれをスケッチしたのも、決して偶然の事ではない。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の個性みたいなものを、本当は、こっそり愛しているのだけれども、愛して行きたいとは思うのだけど、それをはっきり自分のものとして体現するのは、おっかないのだ。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "使命を自覚したる者は権威の体現者なり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――では、正体現すときもあると申すか。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛の芸術と云ふものは決して愛そのものの概念を蕪雑に演述したものでは無くて、愛そのものを芸術として真に体現したものに外ならぬ。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱情詩人、我がキヨルネルの如きは、この沈雄なる愛国の精神を体現して、其光輝｜長へに有情の人を照らすの偉人と被存候。",
              "citation": {
                "source": "渋民村より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本主義文化が体現するところの、虚無思想、唯物思想の機構の中に、血も涙も無い無良心な、獣性丸出しの優勝劣敗哲学と、功利道徳の行き止まり状態を発見したに違いない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『山びこ学校』の精神を体現する教え子、佐藤藤三郎との相克。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく結果的には、その後のパーソナルコンピューターの進む道を体現したマシンの先駆性にしびれ、この国のお調子者の何人かが飛び付いた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "良心を、余りに淫逸に耽溺させ、アルコールに麻痺させた資本家共の瘡蓋だらけの良心には、「人類の理想」や「地上に於ける民衆の結合」や、「神の意志の体現」などは、到底分りつこはないのである。",
              "citation": {
                "source": "工場の窓より",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "農業は植福の精神や行為を体現したかの観のあるものであるが、実にその種を播き苗を植える労苦は、福神が農民の姿を借りて世に現れて、その福の道を伝えようとしてする労苦と云っても良い程のものである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔先生は周末に生まれられたので、周の形式を手本として、これに基づき、これに学び、これを習い、そしてその精神を了解して、そしてこれを自分にも体現し、人にも教えられたのである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "御勘違いでござります」「申すなッ、娘に変り年増に変り、なかなか正体現さぬと聞いておるわ。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そんな事を体現したり、指導したりするような、物騒な教育家は居ないようである。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸ッ子という言葉の強みや、頼もしい感じをそのまま体現した『江戸ッ子』は一人も居ないんだよ。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこのバラックの中に居る人々の中に、大和民族の代表的性格を体現した、あの「江戸ッ子」が居ようとは、どうしても信じられないことを悲しむのである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし少しく反省して見ると、我々に最も直接である原始的事実は意識現象であって、物体現象ではない。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は意識現象と物体現象と二種の経験的事実があるように考えているが、その実はただ一種あるのみである。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "物体現象というのはその中で各人に共通で不変的関係を有する者を抽象したのにすぎない。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "余の真意では真実在とは意識現象とも物体現象とも名づけられない者である。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この統一的或者が物体現象ではこれを外界に存する物力となし、精神現象ではこれを意識の統一力に帰するのであるが、前にいったように、物体現象といい精神現象というも純粋経験の上においては同一であるから、この二種の統一作用は元来、同一種に属すべきものである。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神現象、物体現象の区別というのも決して二種の実在があるのではない。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
