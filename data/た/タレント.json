    "definitions": [
      {
        "index": 1,
        "gloss": "(TV or radio) entertainer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "タレント議員の売名行為といわば言え。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "右のパムフィロスは一タレント以下の謝金では画は教えず。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "明かに、二人の作家としてのタレントには何等の変化も起つてゐないであらう。",
              "citation": {
                "source": "諸家の芸術価値理論の批判",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに文学的タレントのすぐれたＡといふ作家と文学的タレントの劣つたＢといふ作家とが同時にマルキシストになつたとする。",
              "citation": {
                "source": "諸家の芸術価値理論の批判",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私たちは、マルクス主義作家をしてマルクス主義作家たらしむるものは、政治的なものであるが、彼をすぐれた作家たらしめたり、拙劣な作家たらしめたりするものは、芸術的なタレントであるといふ重要な結論に到達する。",
              "citation": {
                "source": "諸家の芸術価値理論の批判",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの年若さであなたほどのタレントに達し得た人は、失礼ですけれどまれだろうとおもわれます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど人間と人間との交わりの契機はタレントではなくて、愛だと思いますから、こうして交わっている間には少しはあなたによき Vertu を及ぼすこともできるかもしれないと思います。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世界の若いタレントの代表格として松本の話を聞きたいと、記者は取材の狙いを説明した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "記者は八月二十三日の夕刊にもう一人の若きタレントと松本を並べ、「コンピュータを常識の一部とする〈マイコン以降派（マイ後派）〉一期生の代表格」と紹介する記事を書いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "早稲田大学理工学部の四年で『ＡＳＣＩＩ』の発行人兼企画部長であるというもう一人のタレント、西和彦とは、二年ほど前に顔を合わせたことがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日新聞は、マイコン界の若きタレントとして二人を並べた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が大してタレントのない作家であるのは却って自分に気やすい。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドストイェフスキーのような素質は、文学的タレントの遺産として、所有者になかなか困難させるものだ。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し他人の内生に貫徹する能力を根本條件とする批評に於いては、特別なタレントのある人でなければこれを書く資格がないのであつた。",
              "citation": {
                "source": "三太郎の日記　第二",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の周圍には批評家のタレントを持つてゐる人が甚だ少かつた。",
              "citation": {
                "source": "三太郎の日記　第二",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして批評家のタレントの少い者ほど平氣で批評を書いてゐるのであつた。",
              "citation": {
                "source": "三太郎の日記　第二",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "デモケデスはクロトンに帰って厚遇されなかったので、アエギナ（現在のエイーナ）に行って医師となり、２年目にアエギナ政府は彼を１タレントの俸給で雇った。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "４年目にサモス島のポリュクラテスは２タレントにした。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "タレントゥム（現在のタラント：イタリアの南東部）から彼は故郷の市に逃げたが、ペルシア人は追いかけてきて彼は逃げるのに非常な苦労をした。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "下品なテレビ・タレントの真弓よ。",
              "citation": {
                "source": "一人ぼっちのプレゼント",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ方角にかえるタレントやスタッフたちを一まとめにして、それぞれに車の手配をする。",
              "citation": {
                "source": "赤い手帖",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵をかきます、全くタレントなしです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種の認識の意欲や野心、エネルギーやセンスやタレント、そうしたものが文学的なものと考えられる。",
              "citation": {
                "source": "認識論としての文芸学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、その夜出演する予定の私の番組のタレントの一人だった。",
              "citation": {
                "source": "演技の果て",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "高座や舞台で、ズウズウ弁をもてあそぶタレントは日本人の三分の二を笑わせるとともに三分の一のファンを失っていることに気がつかないのだろうか。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この学派のもう１人の医師クレオンブロトス（Cleombrotus）はアンティオコス（Antiochus）王の診察を行って100タレント（約１万5000ポンド）を受け取った。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　タレントゥムのヘラクレイデス（ほぼ75ＢＣ）　どちらが正しかったか？",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "タレントゥムのヘラクレイデスは以上のように考えた医師たちの代表者として有名であり彼らは自分たちを経験主義者と呼んだ。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "第５章図１　Heraclides of Tarentum (middle), Nigrus, and Mantias　タレントゥムのヘラクレイデス（中央）６　ブルサのアスクレピアデス（紀元前５世紀）　我々の古代医学の研究は新しい舞台に入る。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
