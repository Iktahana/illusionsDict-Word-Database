        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それはやはり、蛸坊主の秘密会合に似ている。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛸坊主の会合だから、さすがに腕もあり足もある。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛸坊主どもが如何にも色気たっぷりに、腕や足をさし伸べようと、その吸盤は、深遠な論理の声音が宙に消え失せると同様、宙に迷って何の手応えも得られない。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛸坊主からも脅かされず、沖繩の海からも誘なわれず、俺はうとうとと居眠る。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛸坊主め、気どっていやがら。",
              "citation": {
                "source": "行雲流水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
