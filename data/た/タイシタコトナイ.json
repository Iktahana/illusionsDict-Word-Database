        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「しかし知っているように、僕の生活は不規則だから、こんな芸当もたいていの人よりは大したことない。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の傷なんか大したことないのですが、先方のお客様と運転手さんとにひどい怪我をさせたことは何とも申し訳がございません。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では主任さんは何段ですか」と訊ねてみたところ「俺か……俺は大したことない。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大したことないんだろ？",
              "citation": {
                "source": "縫子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "がしかし清二は彼の顔に漾う苦悶の表情をみてとって、「なあに、どっちみち、今となっては、内地勤務だ、大したことないさ」と軽くうそぶいた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、しかし清二は彼の顔に漾ふ苦悶の表情をみてとつて、「なあに、どつちみち、今となつては、内地勤務だ、大したことないさ」と軽くうそぶいた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は遊び好きの金のかかる女だから」「諦められる」「仕方がねえさ」「諦められるなら、大したことないのでしょう。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ЦКВУ の診療所へ行ったがどうも大したことないらしい（つまりはっきり診断されず）　夜、メイエルホリド見物。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、どうも本ものの仕事の方は大したことない。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大したことない平凡だ）　ただこの時代の運動と民衆との関係を、観衆のイディオロギーによって理解するとき興味がある。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんの怪我は大したことないんだよ、心配しなくていいんだよ」「あら、そんなに軽いの。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "小父さんは大したことないつておつしやつたよ。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも九九なんて大したことないんだから――地理を試すの。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ九九なんて大したことないんだから。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こんなもの、ものは言いよう、大したことない。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝のお茶はどうせ大したことないんだから一緒にして、正餐は別。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……だがソヴェト同盟じゃ正月って云っても、大したことないよ。",
              "citation": {
                "source": "正月とソヴェト勤労婦人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の午後は七度一分で大したことないの」「そら、よかった。",
              "citation": {
                "source": "詩劇　水仙と木魚",
                "author": "――一少女の歌える――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、私は、ああ二日つづきの休み日なんて大したことない、実に大したことない。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは七・二ですから大したことない。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝は大したことないわけですが、夜のキューキュー加減と云ったら。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "直接、衣食住費は大したことないのです、うちは臨時費がかさむのです、いつも。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう『都』をみたら保田で稲ちゃんが急病で、鶴さん看病に行ったと出ています、何かしら、扁桃腺なら大したことないけれど。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞学科の僕に言わせれば、トランジスタだとかＩＣなんて単語は、聞いただけで拒絶反応を起こしかねないよ」「大したことないさ」「そうかなあ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもこれくらい大したことないよ」「そんなことないわ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、大したことない。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "「凡児」と「五郎」の脚本読んだ、大したことないが「凡児」の方に興味あり。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョンがいい歌をうたってさ、のこりのたいしたことない歌を、ポールがうたったんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピリニャークが私にフザケ、私、それをＹが怒ったとき Ничего〔たいしたことない〕と云ったと云って。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はまた例のかわいらしさで笑い、「わたしたちの食慾なんて、たいしたことないのにね。",
              "citation": {
                "source": "風",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
