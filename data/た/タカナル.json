    "definitions": [
      {
        "index": 1,
        "gloss": "to throb",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "五十鈴川五十鈴の宮の大前に、巨鈴なるごとわが詩高鳴る。",
              "citation": {
                "source": "短歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは時々立ち止って、何ものかを待ち受けながら、自分の心臓が早鐘のように高鳴るのに耳をすました。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその当時の苦しかったこと、楽しかったことを思うと、今でも胸の高鳴るのを覚えます。",
              "citation": {
                "source": "人工心臓",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸にも日本の男女は、これまでただの一度も、しんからファシズムに反対して自立たちの力で守りとおした平和というものの、高鳴るような歓喜とほこりとを経験していない。",
              "citation": {
                "source": "わたしたちは平和を手離さない",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてのすぐれた文学が、悲劇でさえも、その悲しみのうちに高鳴る一種微妙な美の感覚をつらぬかせていて、与えられるその感動で人が慰藉されるというのは、どういうことなのだろう。",
              "citation": {
                "source": "幸福の感覚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きつい眼に、やさしい眼、うっとりした眼、それから誰かが言ったように婀娜っぽい眼、婀娜っぽくはないが、婀娜っぽい以上にすごい眼――こいつが男の胸に触れたら、まるで琴線に弓が触れたように高鳴るのだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そうして一同は、高鳴る胸を押えて、凝視することしばしであった。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラスか釣りあげるかの瞬間には、いかな名人でも心臓が高鳴る。",
              "citation": {
                "source": "日本の釣技",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三節の「心の故郷……」の句を坪内教授は口を極めて稱揚されただけに今日我々がきいても胸が高鳴る。",
              "citation": {
                "source": "校歌「都の西北」と私",
                "author": "相馬御風",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鋭い白冷の光は、煤烟と騒音との真中に閉じ込められて、恐らく神経が痲痺するであろう都の山岳宗徒に取りても、高鳴る胸を押し鎮めながら、有りし日の懐しき憶い出――過去の登山――にのみ空しく陶酔しているには、余りに堪え難き刺戟でなければなるまい。",
              "citation": {
                "source": "冬の山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "互いに高鳴る血の音に身をゆだねてから……何刻たったろう。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この純情を察して、きょうこっそりと叔父の多門が、鳥越の栄三郎の実家へ養子の掛け合いに行ったことは、弥生もうすうす感づいているが――そのためか、この高鳴る胸はなんとしたものであろう？",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今やかれの前にお艶なく、われなく、世なく――在るはただ亡師の恩と高鳴る戦志の血のみ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「開けろ、開けろ」　八五郎はやけにこぶしを当てましたが、格子はお長屋中に高鳴るだけで、中からは何んの応えもありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "が平次は異常な緊張感に、自分の心臓の高鳴るのを何うすることも出来ませんでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは弱々しく、小さい音ではありましたが、その清らかな調は次第次第に力を加え、やがて深沢深の演奏する邪悪な呪いの曲を引き千切り、支離滅裂に押えつけて、天楽のように高鳴るのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "結婚ラプソディ",
                "note": "青空文庫"
              }
            },
            {
              "text": "御墨附は私が死ねば、何處にあるか知つてる者もない筈、せめて腹でも切つて、多勢の百姓の怨を思ひ知るがいゝ、ホ、ホ、ホ、ホ、ホ」　高鳴る嘲笑。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "名馬罪あり",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤左衞門は幾度か氣を變へて途中から止さうとしましたが、唇は笛の歌口に膠着して、不氣味な調べが劉喨と高鳴るばかり。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "禁制の賦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お墨付は私が死ねば、どこにあるか知ってる者もないはず、せめて腹でも切って、多勢の百姓の怨みを思い知るがいい、ホ、ホ、ホ、ホ、ホ」　高鳴る嘲笑。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "名馬罪あり",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤左衛門は幾度か気を変えて途中から止そうとしましたが、唇は笛の歌口に膠着して、不気味な調べが嚠喨と高鳴るばかり。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "禁制の賦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣町に住んで居て、銭形平次の顔も知って居り、その評判も心得て居りますが、名ある御用聞にこう声を掛けられると、十八娘の心臓が高鳴るらしく、道具の細々とした顔が引締って、可愛らしい唇がおののきます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "夕立の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "大して熱いとは思いませんが、高鳴る心臓の鼓動が、男の手に響きます。",
              "citation": {
                "source": "黄金を浴びる女",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「驚いたか、御浪人」　近々と高鳴る若い声、振り仰ぐとツイ頭の上、二十尺ばかりの屏風岩の上に、短筒を片手だめしにして、十三四――とも見える少年が笑って居るではありませんか。",
              "citation": {
                "source": "大江戸黄金狂",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは、ふだん仕事欲が高鳴る時なぞにそうするごとく、朝早くから起きた。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "君たちの無自覚ないとなみに直面していると、おれのうちには言語と諷刺との力が張り切ってきて、造作もなく君たちを模写した上、おれの芸術の光に照らして、君たちのおぞましい幸福を、世の感動にまかせたいという欲望と愉快な権力感とで、おれの心臓は高鳴るではないか。",
              "citation": {
                "source": "餓えた人々（習作）",
                "author": "DIE HUNGERNDEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯く彼れ至上の威を振ひ陣中めぐり令すれば、衆人即ち水陣と陸營とより叫び出で、集議の席に押し寄する、似たり高鳴る滄溟の狂瀾岸の岩拍ちて怒潮うづまき吠ゆるさま。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "七ペレトラの地をおほひ、倒れし彼は頭髮を塵にまみらし俯伏して、鎧あたりに高鳴るを笑ふパルラス・アテーネー、勝に誇りて翼ある言句を彼に宣んし曰ふ、『愚かなる者、汝まだ我の汝に優れるを　410悟り得ずして、いたづらに我の力に抗へる！",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミルミドネスの衆軍の中に脚｜疾きアキリュウス、激しく呻めき喘ぎつゝ、高鳴る海の岸の上、　60岸を洗へる潮流の淨めし場に横はる。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にとってつよくうてば、その羯鼓はよろこびに高鳴るでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人作家の歴史は、ここに到って、真に新鮮な、メロディーをもって高鳴ると思います。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
