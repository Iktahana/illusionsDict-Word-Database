[
  {
    "uuid": "fc900881-2f4e-5065-88c0-1fe4d6ae84b9",
    "entry": "互い",
    "reading": {
      "primary": "たがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
