[
  {
    "uuid": "a52b310a-0995-5d28-bbdd-c84f83919ded",
    "entry": "探勝",
    "reading": {
      "primary": "たんしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sightseeing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "我等は此地の探勝を他日の樂みにして復び車上の人となつた。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽衣の松竜華寺の探勝ともにまた清閑極りなし。",
              "citation": {
                "source": "海阪",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "果然雨天順延となって、私の旅行日程にもまた一日の狂いが生じて来たので、無聊に苦しむよりは雨の日本ラインの情趣でも探勝しようかとなった訳である。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、上流の福島や寝覚の床探勝の予定も中止すると、どうでも明十三日の朝には此処を立たねばならなくなった。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ豈探勝の上のみならむや。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、無聊に苦しむよりは雨の日本ラインの情趣でも探勝しようかとなつた訳である。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ之からが私の書かうとする利根水源の探勝記である。",
              "citation": {
                "source": "大利根八十里を溯る",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ以上水源の探勝は探勝家にゆだねたい。",
              "citation": {
                "source": "大利根八十里を溯る",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが、私が二年程前、彼女とあそこまで初めての探勝を試みた日は、アジロ通ひのガタ馬車が円かなラッパの音を撒きちらしながら戛々と走つてゐた麗らかな夏の朝であつた。",
              "citation": {
                "source": "環魚洞風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつともひつぱり出すほうではもつぱら奇景の探勝を目的としているのであろうから、八さん熊さんがタキシードを着こなして手さばきも鮮かに料理を食うことよりもむしろその反対の光景を期待しているかもしれない。",
              "citation": {
                "source": "雑文的雑文",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　向島は桜というよりもむしろ雪とか月とかで優れて面白く、三囲の雁木に船を繋いで、秋の紅葉を探勝することは特によろこばれていた。",
              "citation": {
                "source": "亡び行く江戸趣味",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロアル河の沿岸には数里に亘つて幾多の古城があつて、一城の探勝にも半日を費す丈けの価値は十分だと聞いたが、僕等は別荘地に成つて居る対岸の山の手を望んで架せられたツウルの大｜石橋が水に落した倒影を眺めた丈でも姑くは目を転ずる事が出来なかつた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は橋頭駅で下りて一日を此処の探勝に費す時間の無いのを惜んだ。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲仙探勝は小浜を根拠とするも悪くはない。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし私の記事によってこの渓を探勝せられるものがあるなら、希わくは自然の愛護を忘れぬようにして欲しい。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　中枢院参議金尚会氏という京城では有名な釣り人に案内されて、四月一日から開通された京慶線に乗って漢江の上流へ、探勝に行った。",
              "citation": {
                "source": "淡紫裳",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "県では尾白渓谷の御探勝を頻りに希望して、そこへ御歩を枉げさせ給うよう再三の願であったが、正午迄には台ヶ原の御休息所へ御到着の思召に加えて、手入したとはいえ新開にも等しい路では思の外に時間を要する御懸念もあらせられたので、県の人には気の毒であったが、普通の登路を竹宇へお下りになった。",
              "citation": {
                "source": "朝香宮殿下に侍して南アルプスの旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに、探勝春余泝澗流、瑞湖風色入吟眸、水清樹緑山如活、始見泰西日本州。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "火輪蹴波走波間、看過濠山気象雄、探勝何須曳吟杖、南球秋色映船※。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "背花四月去郷関、探勝何論華与蛮、梅雨送雷香港海、蕉風吹暑呂宋山、路踰熱帯涼初起、船入珊洲景漸斑、看到濠陽秋已老、紛紛黄葉落晴湾。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋山や※をはじき笹を分け昭和五年九月三十日　第二回武蔵野探勝会。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "菅の火は蘆の火よりもなほ弱し昭和六年一月十八日　武蔵野探勝会。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕影は流るる藻にも濃かりけり昭和六年七月十九日　武蔵野探勝会。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜘蛛の糸がんぴの花をしぼりたる昭和六年九月六日　武蔵野探勝会。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦安の子は裸なり蘆の花昭和六年十一月一日　武蔵野探勝会。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の水流れ／＼て又ここに昭和七年二月七日　武蔵野探勝会。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏草に黄色き魚を釣り上げし昭和七年六月五日　武蔵野探勝会。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "落花のむ鯉はしやれもの髭長し昭和七年九月四日　武蔵野探勝会。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "加藤洲の大百姓の夜長かな昭和八年十月一日　武蔵野探勝会。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そこには、モーターボートから、もちだしたたんしょうとうが、あかるい光をなげ、その中に、おおぜいのおまわりさんがたっているのが見えました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
