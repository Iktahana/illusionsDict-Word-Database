        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一八七五年から七六年にわたる冬の数箇月間ビーチャム・タワー（Beauchamp Tower）というエンジニアーを助手として水力学の実験をした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "タワーやマロックのような、自分で独立の研究の出来るような人は彼の助手としてはあまり適当でなかった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今晩は、タワーリシチ！",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その絶命寸前のオレの脳裏には、ミクロン・オーダーであるはずのウイルスが四十人の坊主頭の科学者による遺伝子操作で超巨大化し、東京タワーをはさんで「ウイルス退散」と大書したたすきをかけた正義のモスラと死闘を演じる様が浮かんだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "紆余曲折はあったもののＩＢＭは小型機の市場に地歩を築き、日本電気はスーパータワーをおっ建てた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "――このようにして、タワーリシチ！",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何々区コムソモール委員会代表タワーリシチ・イリンスカヤ。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、タワーリシチ！",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）「タワーリシチ・グレボフ。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――タワーリシチ、これで今夜私のところに記名表の来ているだけの演説は終りました。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "革命の規律を守れ※　――タワーリシチ！",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――タワーリシチ・クズニェツォー※が、私に何か話せといいました。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「タワーリシチ・グレチャニコフ！",
              "citation": {
                "source": "「インガ」",
                "author": "――ソヴェト文学に現れた婦人の生活――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「タワーリシチ、ニェムツェウィッチ！",
              "citation": {
                "source": "「インガ」",
                "author": "――ソヴェト文学に現れた婦人の生活――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえ、タワーリシチ、ミートシカ！",
              "citation": {
                "source": "「インガ」",
                "author": "――ソヴェト文学に現れた婦人の生活――",
                "note": "青空文庫"
              }
            },
            {
              "text": "タワーリシチ、ギーゼル！",
              "citation": {
                "source": "「インガ」",
                "author": "――ソヴェト文学に現れた婦人の生活――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが一〇〇〇ワットのライトでも、アスキーのある南青山から三キロメートル離れた東京タワーを照らすことはできない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "職場があった東京、青山のツインタワーに隣り合う東洋リンクスで、ＣＧのデモを見せてもらうと、この新しい表現に対する関心はいっそう深まった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うとタワーリシチー！",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと爪立つような恰好でテーブルへ手をかけ、「タワーリシチ！",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「タワーリシチ、兄弟！",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「政府だって、うまく管理してるとは云えねえ」「タワーリシチ！",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノーソフの奴、勢こんで、「タワーリシチ！",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だから、タワーリシチ！",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さア、タワーリシチ！",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "タワーリシチ、それを知らしてやるのはわるくないでしょう？",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四、若い女が、自分は第一のタワーリシチの話も結構と思うが、私はこうだ。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "タワーリシチ大蔵　ウム、秘書、だ。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、血縁としてのつながりとタワーリシチとしての結びつきは、何と一致せぬものかと、愕くのだ。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、中村その他、女をタワーリシチとして持った自分の経験がない。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
