        "examples": {
          "standard": [
            {
              "text": "デザートは全員がメインを「食べ終えて」から運んできてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "宿題をやる前に、まず夕飯を「食べ終えなさい」。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は一気にラーメンを「食べ終えると」、満足そうに店を出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ホットサンドを食べ終えるとテレビのスイッチを切り、急いで歯みがきを済ませてアパートを出た。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンバーガーを食べ終えるとモスバーガーを出て更に同じ方向へ進んで行く。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らが食べ終える頃、この店の朝食の時間は終わる。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食を食べ終えると、ちょうどいい時間となった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
