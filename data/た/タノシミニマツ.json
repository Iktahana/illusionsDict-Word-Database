        "examples": {
          "standard": [
            {
              "text": "注文していた限定版のフィギュアが届くのを、玄関で今か今かと楽しみに待つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "遠距離恋愛中の彼女は、週末に彼と会える時間をカレンダーを見ながら楽しみに待っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "焼き上がるパンの香りを楽しみながら、オーブンの前で家族が朝食をたのしみに待っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「車が回りはぢめさへすれば、明日にでも迎へに行くんだからそれを楽しみに待つてゐてお呉れよ。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時を楽しみに待つてたもれ。",
              "citation": {
                "source": "六の宮の姫君",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかまあ俺に恥をかゝせぬ様にして呉れや、これ見て呉れと言ふ様になつて呉れ、そればつかりを楽しみに待つて居る。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御墓のなかで坊つちやんの来るのを楽しみに待つて居りますと云つた。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者にみせても原因は分らないし、この節ではもう諦めて、ごっとん、ごっとんを、却って楽しみに待つのだった。",
              "citation": {
                "source": "怒りの虫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "奉行も随分楽しみに待つて居られますんで、とに角之を拝借して行く事は出来ますまいか。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "今からそれを楽しみに待つてゐたいと思ひます。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互ひにそれを楽しみに待つことが、唯今のわれ／＼として何よりのことです。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その会の句稿が私の所に廻つて来た時分に、選をして返すのを楽しみに待つてをるといふ手紙が来た。",
              "citation": {
                "source": "椿子物語",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は　楽しみに待つ　といってやった。",
              "citation": {
                "source": "島守",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽しみに待つがいい」　晩の牢内は、もう呪いの声もしなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
