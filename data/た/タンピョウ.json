    "definitions": [
      {
        "index": 1,
        "gloss": "brief comment or criticism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
