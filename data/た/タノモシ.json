    "definitions": [
      {
        "index": 1,
        "gloss": "mutual financing association",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんな考えから、親爺は、借金や、頼母子講を落した金で、ちびり／＼と田と畠を買い集めた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五六口の頼母子講は、すっかり粕になってしまっていた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼母子講は、一と口が一年に二回掛戻さなければならない。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、毎月、どっかの頼母子が、掛戻金持算の通知をよこして来る。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　信用組合からの利子の取立てと、頼母子講の掛戻と、女房と、息子の反対は、次第に親爺を苦るしくして行った。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田と畠を頼母子講の抵当に書きこみ、或は借金のかわりに差押えられようとしていた自作農は、親爺だけじゃなかった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "源作は、頼母子講を取った。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "媾和進行中に塙団右衛門が蜂須賀隊を夜襲するなどの事があって、大いに気勢を挙げ、大阪方可なり強気であったが、家康天守閣、千畳敷などを砲撃して、秀頼母子を威嚇し、結局の媾和条件は、次ぎの通りであった。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大野治長は千姫を脱出せしめて、秀頼母子の助命を請うたが、その効なく、東軍は秀頼の籠る山里｜曲輪を目がけて砲撃したから、翌五月八日、遂に秀頼淀君と共に自刃し、治長、速水守久、毛利勝永、大蔵卿等之に殉じた。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀頼母子を殺したのは、家康として政略上止むを得なかつたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の晩、部落の人々の頼母子講の寄合があり、そこへ太田が來て話しをする手筈になつてゐるその前の日の朝であつた。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで知友が胥謀つて、頼母子講様の社を結んで救つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一身一家経済の由来頼母子の金弐朱を返す是れから私が一身一家の経済の事を陳べましょう。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が福澤の頼母子に大阪屋五郎兵衛と云う廻船屋が一口二朱を掛棄にしたそうです。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "また士族の子弟の為に儒書及び舎密学を講じ、各村の公共事業費を作る為に頼母子講を設くるなど、施設する所すくなからず。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　師走の二日には、深川八幡前の一｜旗亭に、頼母子講の取立てと称して、一同集合することになっていた。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう風に相談が多端に亙ったために、頼母子講は夜に入ってようやく散会となった。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「其方儀、御勝手御仕法立てにつき、頼母子講御世話｜方格別に存じ入り、小前の諭し方も行き届き、その上、自身にも別段御奉公申し上げ、奇特の事に候。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは半蔵父子とも多年御奉公申し上げ、頼母子講お世話方も行き届き、その尽力の功績も没すべきものでないから、特別の憐憫を加えられたのであるとの申し渡しだ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度目に呼び出されて行った時にですね、お前たち親子は多年御奉公も申し上げたものだし、頼母子講のお世話方も行き届いて、その骨折りも認めないわけにいかないから、特別の憐憫をもってきっと叱り置く、特に手錠を免ずるなんて――それを言い渡された時は、御奉公もこれまでだと思って、わたしも我慢して来ました。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからお秀は自分が十三の時から淫売して居ることから、淫売をし出すと阿呆らしくて、外の仕事が手につかぬことから、『後悔せにやならぬことは知つて居ても、借金と頼母子講の懸け金とが無けりや、いつでも、淫売なんか止めるんですけれどもな、病気しまつしやろな、間に。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "折々頼母子講の掛け金に困つて借りに来た。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "物々交換の状態から貨幣経済に次第に進み、貸借の関係は複雑になって、頼母子のごときものも発達する。",
              "citation": {
                "source": "文化史上より見たる日本の数学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉時代の頃から頼母子などのことが現われ、利息計算のことからでも数学が発達してよさそうなものであるが、まだそれだけで発達するようにはならなかったらしい。",
              "citation": {
                "source": "文化史上より見たる日本の数学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼母子のこと　何代も学問をして来た家にしては不思議なことであるが、父はいつも風呂敷包みをさげて、本を借りて来ては読んでいた。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面は元のまま持ち続けていたのだし、毀れかかった旧屋は二束三文だろうし、結局どうも中産階級の金融方法であった頼母子に頼ったのではなかったかと想像している。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから十年後に、長兄がはじめて東京に出る時にも、この頼母子のお蔭で楽に出られたようであった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼母子のことを東京方面では無尽というが、これは単にいつまでもある、すなわち永久の意味で、助け合うとか恩恵とかいう意味はない。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼母子という言葉は非常にふるく、足利時代はもちろん、鎌倉時代でも探せばあるだろう。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は昔風の頼母子講を非常に面白いと思って、大学のころ研究してみるつもりでいたことがある。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
