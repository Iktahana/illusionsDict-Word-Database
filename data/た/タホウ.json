[
  {
    "uuid": "1e1ec943-c804-53ec-a636-03c9202cbdcf",
    "entry": "他方",
    "reading": {
      "primary": "たほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
