        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "年を重ねるにつれて、顎のラインの皮膚がたるたると緩んできたのが気になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "運動不足のせいで、お腹周りのお肉がたるたるになってしまいショックを受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "散歩中に見かけたブルドッグの、たるたるとした頬がとても可愛らしかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "春にだらけた人々の心も、一時ピンとひきしまり、溌溂たるたる」］元気をとりかえしたが一人寂しいのは平八老人で、この時までも鼓の音を、耳にすることが出来なかった。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
