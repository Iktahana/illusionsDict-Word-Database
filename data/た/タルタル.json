        "examples": {
          "standard": [
            {
              "text": "タルタルとは、肉や魚を細かく刻んで調味料と和えた料理の総称だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の先祖は中央アジアからヨーロッパへ侵攻したタルタル人だと聞かされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新鮮な馬肉を使ったタルタルに卵黄を落とし、バゲットに乗せて食べる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "午前中にタルタル港に入る。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
