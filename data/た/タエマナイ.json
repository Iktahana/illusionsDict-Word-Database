[
  {
    "uuid": "814c967c-cac1-5d5b-8b70-5d6af008d4ba",
    "entry": "絶え間ない",
    "reading": {
      "primary": "たえまない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
