          "standard": [
            {
              "text": "サーバーの応答が遅いため、ブラウザに「接続タイムアウト」のエラーメッセージが表示された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一定時間操作がない場合、セキュリティ保護のために自動的にタイムアウトしてログアウトされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "処理の中断を防ぐために、設定ファイルでタイムアウトの時間を少し長めに変更した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
