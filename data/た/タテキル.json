        "examples": {
          "standard": [
            {
              "text": "ドアを「立て切る」ように閉められ、中に閉じ込められてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "換気のために開けていた窓を、急に「立て切る」ように閉めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「立て切る」ほどの頑丈な扉なので、外からは開けられないだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "が、その部屋へ躍りこむと、平中は、遣戸を立て切るが早いか、手早く懸け金を下してしまつた。",
              "citation": {
                "source": "好色",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の間を立て切る二枚の唐紙は、洋紙に箔を置いて英吉利めいた葵の幾何模様を規則正しく数十個並べている。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その格子戸を立て切ると竜之助は、二箇所ほどピンと錠をおろしてしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時、二時、もはやと縁の戸をたてきる。",
              "citation": {
                "source": "おとづれ",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
