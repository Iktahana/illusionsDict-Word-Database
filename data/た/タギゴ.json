        "examples": {
          "standard": [
            {
              "text": "「はし」のように、箸・橋・端といった複数の意味を持つ多義語の習得は外国人にとって難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "辞書を引くと、その多義語にはページを跨ぐほど多くの語義が解説されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "日常会話でよく使う単語ほど、実は意外な意味を含んでいる多義語だったりする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "伸子は、腹のたつ気持を抑えたぎごちない低い声で、「お母様の世間だけが、世間のすべてでもなさそうよ」と云った。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正吉は手を振放そうとした、お美津はそうさせまいとした、おどおどしたぎごちない争いが起った、お美津がよろめいたので正吉が支えた、そのとたんに二人は、何方からともなく互いの体を抱き合った。",
              "citation": {
                "source": "お美津簪",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
