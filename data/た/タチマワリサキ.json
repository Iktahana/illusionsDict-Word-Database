        "examples": {
          "standard": [
            {
              "text": "警察は容疑者の立ち回り先を重点的に捜査し、潜伏場所を特定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「犯人が以前立ち寄った立ち回り先をしらみつぶしに調べろ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は失踪する直前、いくつかの立ち回り先で友人たちに別れを告げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "どこから来たか、ポートゥックストでは何が知られていたか、できうるものなら現在の立ち回り先はどこか。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとも残念なことに、彼らはブラーヴァ・トニー・ゴメスの居場所を突き止めようとして果たしておらず、アレン博士の出自も立ち回り先も全く判らなかった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
