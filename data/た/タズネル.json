[
  {
    "uuid": "c9ceb0e6-65c0-5a7a-8eda-88b3e0878cfa",
    "entry": "尋ねる",
    "reading": {
      "primary": "たずねる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to ask",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　私はまず車掌に尋ねる。",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と私が階下のストオヴにあたりに行くたんびに、さう尋ねる。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と眼をつぶつたまま龜に尋ねる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と浦島は小聲で尋ねる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお鈴さんはあわててお照さんに尋ねる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と老人が如何にももの軟らかに尋ねる。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｆ――町はちょうど講演にお廻りになる町でもこざいましょう」　私が尋ねるまでもなく私がＦ――町へ入ると、停車場へ出迎えた婦人連の中にお蘭を見出した。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その男になにか見覚えになる特徴はなかったか」と裁判長が夕刊売りに尋ねる。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもならば、家におればわずかの間見えなくとも、必ず子どもはどうしたと尋ねるのが常であるのに、その日の午後は、どういうものか数時間の間子どもをたずねなかった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この語は「シャ」というか「サ」と言うかと尋ねると、どちらも同じではないかと言う。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "と若しも誰かが尋ねることを思ひついたとしたら、その質問に對しては唯一つの答しかあるまい。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（どうかなさいましたか、）もうちゃんと法衣を着たから気丈夫に尋ねる。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と好奇の眼をかがやかして僕に尋ねる。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とおそるおそる尋ねるのだった。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と眼で尋ねると、女中は真剣そうに小さく二三度うなずきます。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と今は、おっかなびっくりで尋ねる。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、のんきに尋ねる。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「少し尋ねる者がございまして。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは役柄をもって相尋ねるが、その方は只今も申す通りズット以前は博多の荒物屋渡世。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならば相尋ねるが、その方は博多蔵元町、蔵元屋の一人娘、お熊というものを存じておるか。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで今一つ尋ねるが、あの娘……蔵元屋の娘お熊には別に疵はなかったか」「ヘエ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは在るどころでは御座いませんが」「申して見い……」「それが私の口からは申上げ兼ねまする名前で御座いまして……」「余が役目柄を以て相尋ねる事じゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも『お父さんは、何処で、どうして死んだか』と母親や私共に代る代る尋ねるので御座いますが、皆泣くばかりで返事が出来ません。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて――　もしお政が気の勝ている女ならば、自分がその夜三円持て母を尋ねると言えば、「質屋から持って来たお金なんか厭だと被仰ったのだから持て行かなくったって可う御座いますよ」と言い放って口惜し涙を流すところだが、お政にはそれが出来ない。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい近頃になって「Ｂ教授の追憶」を書くときにふとそのＢ教授の手紙を想い出すと同時にこの抽出しとＳ先生の手紙を想い出したのであったが、今ではもう昔の教室の建物はすっかり取毀されてしまって、昔の机などどうなったか行衛も分らず、ましてやその抽出しの中の古手紙など尋ねるよすがもなくなってしまった訳である。",
              "citation": {
                "source": "埋もれた漱石伝記資料",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも親のかたきのようなもので、私の尋ねる敵と他の人の敵とは別人であるように私の書物は私が尋ねるよりほかに道はない。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし園にあの最後の言葉を投げつけられたおぬいさんがそれを尋ねる余裕を持ちえられるかどうか。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはまだごぞんじないかも知れないが明後日、馬場と僕と、それから馬場が音楽学校の或る先輩に紹介されて識った太宰治とかいうわかい作家と、三人であなたの下宿をたずねることになっているのですよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくはいちばんはじめにあんずの王様のお城をたずねるよ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然パーシの夜の鶏が戸外で鳴き出すと、アダはいらいらして、その他に別に用事はないかと私にたずねる。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
