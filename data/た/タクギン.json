        "examples": {
          "standard": [
            {
              "text": "かつて北海道の経済を支えていた拓銀が破綻したニュースは、日本中に衝撃を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父の家には、今でも拓銀のロゴが入った古い貯金箱が残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "拓銀の経営破綻をきっかけに、金融業界の再編が加速した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "夜おそい札幌に出迎えて下さった人々のうち、たとえば北大の鳥山成人君は厳父が歩兵将校として札幌在任中にうまれた人、峯※君の亡父は長崎県人で拓銀の模範社員とうたわれた人、十幾年ぶりでおめにかかった母堂の生家は秋田藩士族の移住者であるといったふうなのだ。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくぎんは値切ることにかけては名人だった。",
              "citation": {
                "source": "鴻ノ巣女房",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
