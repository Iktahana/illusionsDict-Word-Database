    "definitions": [
      {
        "index": 1,
        "gloss": "to fight against",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "中身の知れた危険なら、口を結んで立ち向かうこともできる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕ひとりでこのことに立ち向かう羽目になったら、もう。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "本や雑誌作りに携わっていられるのはそれでも楽しく、何かあると連日の泊まり込みで仲間たちと仕事の山に立ち向かう日々には、手応えもありました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが何かをしないことの言い訳に使っても、国際紛争解決の武力によらざる解決に立ち向かうジャンピング・ボードとして憲法九条を掲げようとする政治家は一人としていないのだな。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことやこれこそ剣の奥義、抜きこそしないが、弓にむかって剣を得物に立ち向かうには、その右前、右前とはいるのが奥義中の奥義でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それと同時に、お芳は、最悪なものに立ち向かう勇気と強さ、それに狡猾さに対抗する英知が必要なことをすっかり認識したのだった。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、見てとった宮川茅野雄は、立ち向かうように足を止めた。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり自然に率直に朗らかに「求めよさらば与えられん」という態度で立ち向かうことをすすめたい。",
              "citation": {
                "source": "人生における離合について",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔武士が「尋常に勝負」といって立ち向かうが、あの真剣な態度が星岡だ。",
              "citation": {
                "source": "美味放談",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人の中年の逞しい武士が、目明しふうの壮漢と、若い武士とへ立ち向かうように、にわかに足を止めて振り返って、刀にソリを打たせたからであった。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は勇敢に立ち向かうが、直ぐ寝業に押えこまれる。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とおめいたが、妙なことには相手は立ち向かうようすもなく、落ちた連中を拾いあげると、こっちの舟へ一竿つっぱって倉皇として離れてゆく。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっそく、藩士の一隊が決死の勢いで、壺探索に江戸へ立ち向かう。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けれども、これは私が一人で立ち向かうべきものだから。",
              "citation": {
                "source": "長い部屋",
                "author": "O. H. ダンバー　O. H. Dunbar",
                "note": "青空文庫"
              }
            },
            {
              "text": "総督は声を大にして、いまはいかんとも方法のないこと、こちらから波止場を出てゆくことの不可能なこと、そして、実際彼はなにもかも不足で、敵に立ち向かう力のないことを声明した。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "避けられぬ運命に、勇気を持って立ち向かうほかはないのだった。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィレット医師は木曜日の一日を、過ぎた何事かから立ち直り、あるいは来るべき何事かに立ち向かう気力を養うために充てた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ここでは、いくらか軽率なやり方、ある種の緊張弛緩といったものが許されるのは、ただ役所に直接立ち向かうときだけであって、そのほかの場合にはいつでも大きな用心、つまり一歩踏み出す前に四方八方を見廻すということが必要だ、ということになるのだった。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、勇気を以てこの高地の亡霊と立ち向かうがよい。",
              "citation": {
                "source": "夕映えのむこうの国",
                "author": "時代を超えた童話",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがひとたび危険に直面すれば、決然と難事に立ち向かう。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "イードの立ち姿は、葉っぱのない朽ちた古木のようだが、大風に立ち向かう負けん気があった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの男にどうやって立ち向かうか、どうにも分らん」　ルースが大ホール扉を開けて中にはいった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "に立ち向かう方法は一つしかない。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは黄金の剣を振りかざし、敢然と恐竜に立ち向かう。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "積極的に、立ち向かう気がないので、逃げてばかりいる。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし厚い壁に立ち向かう強いアラマン族（西ゲルマン）の頭骨に我々は気がつき世界に挑戦する鍛え抜かれた男の特徴に気がつく。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の部屋に簡単な実験室を作り大きな仕事に立ち向かうことになった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしインフルエンザ、小児麻痺、脳炎のように効果的な防御方法がまだ発見されていない場合でも敵を決定しその戦法を知ることによって整然と立ち向かうことができるようになった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "史上で最大の将軍であるナポレオンですら流行病の戦術に立ち向かうと無力であった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その多くの試練にたちむかう、四人の姉妹の、それぞれちがった性格の描写は、まことに、明暗多彩、克明精細、しかも、この一篇にみなぎる愛と誠とは、いかなる読者の心をも魅了し、感激させずにはおきません。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
