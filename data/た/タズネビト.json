    "definitions": [
      {
        "index": 1,
        "gloss": "missing person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もとより当のない尋ね人。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、こいつこそ、尋ね人じゃないか。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「前の土曜のクロニクルに尋ね人の広告を。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "済まないが読み上げてくれないか、ホズマ・エインジェル氏の尋ね人広告とやらを。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "袴広太郎様の尋ね人、それも確か君尾といった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから杜は、ミチミと房子との二重の名のついた「尋ね人」の旆を担いで、避難民の固まっているバラックをそれからそれへと訪ねていった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼女はいわゆる狐使いのように、自分の狐を放して他人に憑かせるなどということはしないらしく、唯その狐の教えに依って、他人の吉凶禍福や失せ物、または尋ね人のありかを占うに過ぎないのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋ね人なんだ、つまり。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "幡随院がお尋ね人の平井権八をかくまふのも此の感です、芝居としては面白いが道徳の標準にはならぬ、従つて悪い場合も生じます。",
              "citation": {
                "source": "Ｓ先生に",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方が遅くお帰りでしたので、つい、申し上げるの忘れてゐましたけれど、今朝、ラジオの尋ね人で、ほていと云ふ名が出ましたので思ひ出しましたけど、ほてい商会つて、何の御商売なさる処なンですかしら……」　富岡は返事もしなかつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋ね人は七赤金星で、三碧木星とは相剋だから早く諦めないと大変な事になる。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（時刻から申せば、二人は、もうこの辺へ着かなくてはならんのに――途中で、悪雲助共に逢うたか、討手の奴等に手でも負わされたか――今夜小太に逢えぬとすれば、せめて、二人に逢いたいが――）「旦那、お泊りじゃござんせんか」「少し、尋ね人があって――」　益満は、そう答えて、街道へ出た。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来、まるで大混雑、立往生をして居る電車に一杯、尋ね人、被害地図、政府の告示等貼ってあった。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだんお前さんに運が向いてるらしいのは人相にも出ているから、ジッと証文を握って辛抱してるがいいや」　だが天心堂は三円の見料の手前があってか、易を立てて見てくれて、「尋ね人は西に居るが、だいぶ東京から離れているようだ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「尋ね人、六十歳の老人。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに運命の極めて奇なる因縁で、宇津木兵馬とお銀様とは、その翌日、行を共にして尋ね人のあとを追うことになりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "道庵先生、いかに神医なりといえども、いつどこで探し出されるか知れないものを、そのあてどのない尋ね人を探して来るまで、死ぬべきものを死なさずに置けとは、米友の注文が無理です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "山影さんの尋ね人、真っ先にその人を探しあて、山影さんへ知らせた者が、山影さんの奥様になれる。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山影さんなら宗さんだヨッ、宗さんなら尋ね人だヨ――ッ」「あッ、なるほど」と地廻りだけに、お仙が誰を探しているかは、とうに聞いて知っていたらしい。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お仙ちゃんの尋ね人！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗さんだから山影さん、真っ黒の女がグルグルグル、手が上がってヒラヒラヒラ、そこでお仙ちゃんの尋ね人が、キリキリキリとブン廻る、な、解ったか、助太刀助太刀！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山影さんだから宗さんだ、宗さんだから山影さん、山影さんなら尋ね人、お仙ちゃんのためだ。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「俺がその後を云ってやろう、山影さんなら尋ね人、うんそうだよお仙ちゃんの！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "用というのは、その人物を伝手にいたして、江戸で尋ね人をしようというのだ」　ははあ、仇敵討ちかな、とおやじは思ったが、あまり立ち入ったことをいうと、危険なような気がしたので、黙っていた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや私は尋ね人があって江戸じゅうの質屋を廻っているものだが、じつはね、こういう女があなたのところへ来ませんでしたか。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "浮世芝居女看板",
                "note": "青空文庫"
              }
            },
            {
              "text": "「尋ね人と言ったって、何も別にお上の筋じゃあないから、ひとつ包まず隠さず話してもらいたいんだが、この女ですがね――年は二十そこそこ、なかなかの美人だ。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "浮世芝居女看板",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日帰国をするドイツ人がゐて、帰国の上はラジオ放送の「尋ね人」できつと尋ね出してあげよう、西ドイツにゐるならきつと分るだらうといつてくれるのを、今は頼みの綱にしてゐるやうなことです、と守屋さんは話を結んだ。",
              "citation": {
                "source": "オルゴール",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白山の家へは姿も見せず、雲を掴むやうな尋ね人で、それつきりになつてしまつたよ、多分神隱しにでも逢つたことだらう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "白梅の精",
                "note": "青空文庫"
              }
            },
            {
              "text": "慾にころんで空葬まで出さしたくらいだから、金高次第では、娘を返す気になるかも知れない――」　物持の人の親らしい考えで、平次が止めるのも聴かず、役所の許しを得て、江戸の目抜きの辻々に、真新しい「尋ね人」の高札を建てさせました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幽霊にされた女",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人たちなら、尋ね人のことでできうる限り最も詳しい情報を教えてくれるでしょう、と。",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
