[
  {
    "uuid": "0b9c3983-29d4-5bf2-a1ea-fccb1c290018",
    "entry": "卓抜",
    "reading": {
      "primary": "たくばつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞",
