    "definitions": [
      {
        "index": 1,
        "gloss": "I'm home!",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その一つは端書で「今朝ハ失敬、今日午後四時頃夏目来訪只今（九時）帰申候。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日」とあるのは七月二十三日だろうと思われるのは消印が二十四日のイ便であるのに「只今（九時）帰申候」とあるからである。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そして只今、この大地は、四度目に来た冷い時期の、そのまた中に幾たてもこまかく冷温のきざみのある、ちょうどその二つ目の寒さの峠を下り降った根方の陽気の続いている時期にあるのでございます」　まめ桜はひと年の五月に一度咲き、同じその頃、三光鳥はこの裾野の麓へ来て鳴く。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくしは只今、最初から数えて八枚目の肋骨まで出来ております。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら彼等は、今日只今生れたばかりの、全く新鮮な自由の心で、一切の宇宙を見るからである。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら明治の評價は、すくなくとも大正（即ち只今）の評價よりも信がおける。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今、ごく◇最近に續出する詩集については、ただ一時の場當り的價値を言ひ得るのみで、その實の眞價は何人にも不明であるが、明治時代のものに就いては、多少いくぶん確實に近い評價をもち得るだらう。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍が、Ｔ「先生　只今御病気中に　御座れば」　ナニッ病気、と団九郎、　取次の侍、紙包を取り出して、Ｔ「誠に軽少に　御座るが　ホンの草鞋銭」　と団九郎の前に差し出す。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "源五左を呼び止めて、Ｔ「只今のは　小手調べ」　エッと源五左。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯島は只今病氣療養の爲逗子にゐる。",
              "citation": {
                "source": "講演會　其他（大正十五年二月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今弟と、あなたなんぞは旧思想の人だろうか、新思想の人だろうかと、お噂をいたしていたのでございます。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今は頂戴いたしますまい。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今のあなたの恐しくお思いあそばす、そのお心持が、丁度昨晩のわたくしの心持と同じなのでございますよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度只今のあなたのように、昨晩はわたくしが恐しく存じましたの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、私は只今巴里の晩春を見たいものだと願つて居ります、私は、歸り支度をしてゐるので御座いますから。",
              "citation": {
                "source": "リルケ書翰（ロダン宛）",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて只今から幻燈会をやります。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「兎も角遅いなァ」　言って居る時女中が、Ｔ「只今江戸から飛脚が」　二人飛び起きた。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいにく只今、細君も外出して、なに、すぐに帰る筈ですがね、困りました。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今、仕事をして居ります。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、知っているだけなり）只今、仕事をして居ります。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今、扇風機を運んで参ります。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今気絶をいたしました。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今報いを果しました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「只今、電燈を点けますからどうかそこからおはいり下さい。",
              "citation": {
                "source": "さるのこしかけ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし私の死にたいお願いが聖意にかないましたならば、只今すぐに私の生命を、燃ゆる閃電にお付し下さいませ。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をお隠し申しましょう……只今まで私がお話致しました事は、みんなヨタなんです。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいま友人、大隅忠太郎君から、結納ならびに華燭の典の次第に就き電報を以て至急の依頼を受けましたが、ただちに貴門を訪れ御相談申上げたく、ついては御都合よろしき日時、ならびに貴門に至る道筋の略図などをお示し下さらば幸甚に存じます、と私も異様に緊張して書き送ってやったのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（はい、ただいまあの爺様が、さよう申しましたように存じますが、夫人でございますか。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（ただいまではもう痛みますばかりになりました。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいまとても別にぶちょうほうのあったわけではござりませんが、股引きが破れまして、膝から下が露出しでござりますので、見苦しいと、こんなにおっしゃります、へい、御規則も心得ないではござりませんが、つい届きませんもんで、へい、だしぬけにこら！",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
