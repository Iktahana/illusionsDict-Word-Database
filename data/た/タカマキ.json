        "examples": {
          "standard": [
            {
              "text": "滝の直登は危険だと判断し、左岸から大きく高捲きして上流を目指した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "沢登りのルート図には、この場所で高捲きが必要だと記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "高捲きの最中に足元が崩れそうになり、冷や汗をかいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "三番目の大きい沢の所から大高捲き（高さ一〇〇メートル位）の新道がついていた。",
              "citation": {
                "source": "槍ガ岳",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見たかまきりは、一足しさって高く右手の鎌をふりあげた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
