          "literary": [
            {
              "text": "（合唱の群の一半に倒れ掛かる。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、ふらふらとたおれかかるのを、タクマ少年は僕の腰をささえてくれたので、幸いにたおれずにすんだ。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "独楽は竹童のふところに飛んでかえって、かれ自身もまた、アッ――と片手で顔をかくしたまま、あぶなくそこへたおれかかる。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
