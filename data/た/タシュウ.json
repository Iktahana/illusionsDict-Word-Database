[
  {
    "uuid": "47e0bc59-7646-5f72-a4a2-bc8eed585dda",
    "entry": "他宗",
    "reading": {
      "primary": "たしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
