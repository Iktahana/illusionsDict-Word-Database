    },
    "definitions": [
      {
        "index": 1,
        "gloss": "another sect",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "祭祀その他宗教的儀式と連関していろいろの巫術魔術といったようなものも民族の統治者の主権のもとに行なわれてそれが政治の重要な項目の一つになっていたように思われる。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神を試みるべからず」、これは他宗の言葉としても仏教にも立派にあてはまります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私の家では代々の法華宗で、殊にも私の代になりましてから、深く日蓮様に帰依仕って、朝夕｜南無妙法蓮華経のお題目を怠らず、娘にもそのように仕込んでありますので、いまさら他宗へ嫁にやるわけには行きません。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上人さま始め御門徒衆御一同、数ならぬ私どもまで他宗に対してどうして顔が立ちましょうか』蓮如『名誉、不名誉は言ってはいられぬ。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上は心よく、親鸞影像を戻し返してつかわすのみか、他宗ながら忰源兵衛の菩提も、こなたで弔い追善供養。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "心を安めよ仏子源右衛門』源右衛門（額ずきつつ）『老先短いこの年寄が、忰に代って生き永らえ、悲しいやら面目ないやら、心苦しゅうござりまするが、御門徒宗が他宗の智識に、これほどまでに褒められる手柄をしたと思えば、どうやら心が慰められます。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには「各々御存知の如く他宗の者を無理に切利支丹にして居る事は無い。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（１）十二世紀ごろから始まりその後数世紀にわたって、ローマ教会の教権擁護のために、異端その他宗教に関する罪悪を摘発撲滅するために行われた、歴史上有名な裁判。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう八十にもなっておいでだのに、法華経二十八巻を立読に遊ばして、お茶一ツあがらない御修行だと、他宗の人でも、何でも、あの尼様といやア拝むのさ。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも他宗の人はいふ、泥棒の念仏にはなほ不安の状態あるべしと。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたなんかのは長長と、他宗に聞かれちゃ困るようなことを、云わなくちゃならぬのでしょう。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その教化の広大なることかくのごとしといえども、上人の死後、その門徒なる者、宗教の事につき、あえて他宗の人を殺したることなくまた殺されたることもなきは、もっぱら宗徳をもって人を化したるものと言うべし。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この尼僧寺は、婦人の身で文学博士の肩書を持ち、自ら盤得沙婆と号する工藤みな子の建設に係わるものであって、あまねく高識な尼僧のみを集め、瑜伽大日経秘密一乗の法廓として、ひろく他宗に教論談義を挑みかけていた。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し他宗の人は兎角世間に輕侮せられて軍人の心を收るに足らざればなり。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから歐羅巴では八世紀の中頃即ち七百二十年頃東ローマのレオ・イソーリアンと云ふ法王が偶像を禁止する法令を發して、他宗を皆悉く滅してしまふと云ふ運動を起した。",
              "citation": {
                "source": "日本の眞の姿",
                "author": "竹越與三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧一　他宗の者どもは当流の繁盛をねたんで非難の口実を捜している時でございます。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "他宗を破折する彼の論拠にも、理論的には幾多の抗論を立てることができるであろう。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「今日以後永く他宗折伏を停めるならば、城西に愛染堂を建て、荘田千町を付けて衣鉢の資に充て、以て国家安泰、蒙古調伏の祈祷を願ひたいが、如何」とさそうた。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日蓮が大きな迫害を受けたのは、彼自らが他宗を非難したからであり、基督教の布教でも、仏僧に宗論を吹かけ、仏僧の堕落を難じ、事毎に異端に向つて敵対を示さなければ、彼等の受けた迫害も尠かつたに相違ない。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切経を披き閲すること数遍に及び、自宗他宗の書物眼に当てないというものはなかった。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "他宗の者から聴かされた智恵が、自宗で習い伝えた義理に立ち越えている」といって随喜感歎甚だしく、法談数刻の後、法然は特に乞うて華厳宗の血脉並に華厳宗の書籍などを渡された。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "天台は固よりのこと他宗の総てに亙って一代の宗となる程の学力を有していた。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は熱心に法華を説いて、他宗派を攻撃し、時に念仏とは全く反対の道を歩んだ。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "左すれば九品宗・時宗抔、踊念仏も修行する宗旨は、他宗と違ひ物貰に近きものと見えたり。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも引続きこの罪悪を犯したはずの彼らが、他宗の信徒の如く、もっとも忌むべき堕胎間引きの罪悪を犯すことが少かったというのは、なんという皮肉でありましょう。",
              "citation": {
                "source": "融和問題に関する歴史的考察",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺生を非常にやかましく言う他宗の信徒は、案外人間の子を殺すのが平気であったのです。",
              "citation": {
                "source": "融和問題に関する歴史的考察",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "以後修験道は当山及び本山の二派に分れて広く諸国に分布し、更に幾多の支派を分ち、苦行修法する他宗の者までも皆其行法に倣ったので、山開きの間は十六道具に身を固めた行者達が至る所の名山大岳に登り、振鈴の音は雲に入り法螺の響は山をどよもして鳴り亙ったのであった。",
              "citation": {
                "source": "山の今昔",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "政教子、一日その会堂に入りてこれを見るに、会場にはその宗の信徒と他宗よりの来観者はその席をわかち、酒とパンの供物は来観者に配与せず、賽銭も来観者より集めざるなり。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにお互に他宗だからどうのこうのというような、狭い考えは全然有っていないのです。",
              "citation": {
                "source": "むかでの跫音",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "代々松岡家は天台宗門で、他宗との結婚は許されないのであるが、自由結婚をして松岡家に入ったのである。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
