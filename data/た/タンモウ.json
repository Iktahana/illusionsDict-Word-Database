        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "短毛のシャムはよろしかろうが、純白はあまり見当らない。",
              "citation": {
                "source": "猫先生の弁",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "形は犀に似て、全身短毛をもって掩われ、尾は短く、鼻及び上唇は合して短き象鼻の如くサ。",
              "citation": {
                "source": "獏鸚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "子房には上部に短毛あり。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューファウンドランド犬が先ず参り、つづいて三頭の短毛のポインターが参り、二頭の雑種犬はもつとねばり強く生命にすがりついたが、これも結局参つてしまつた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただコリーの方は散毛でグレイハウンドの方は短毛なんだ。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬢の短毛が二、三本、風におののいて立っている。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
