    "definitions": [
      {
        "index": 1,
        "gloss": "traditional women's hair style, with hair worn up and arched back",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "見た事はたしかに見たが、在来の高島田ではなかったかのう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢がすりの銘仙に文金の高島田。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少いのは時々に髮が違ふ、銀杏返しの時もあつた、高島田の時もあつた、三輪と云ふのに結つても居た。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣の寄る時は、妙なもので……又此處へ女一連、これは丸顏の目のぱつちりした、二重瞼の愛嬌づいた、高島田で、あらい棒縞の銘仙の羽織、藍の勝つた。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おもちやさんも来てますよ、」と云つて、「あすこの土間で、お納戸色の羽織をきて、高島田に結つてませう。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "高島田の空に、夕立雲の蔽えるがごとく、銅像の覆掛った事は云うまでもない。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "高島田の前髮に冷き刃あり、窓を貫くは簾なす氷柱にこそ。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四にもなって高島田に厚化粧でもあるまい」　かくて白糸は水を聴き、月を望み、夜色の幽静を賞して、ようやく橋の半ばを過ぎぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その浴衣は所々引き裂け、帯は半ば解けて脛を露わし、高島田は面影を留めぬまでに打ち頽れたり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の垂りそうな、しかしその貞淑を思わせる初々しい、高等な高島田に、鼈甲を端正と堅く挿した風采は、桃の小道を駕籠で遣りたい。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真前の車が河野大夫人富子で、次のが島山夫人菅子、続いたのが福井県参事官の新夫人辰子、これが三番目の妹で、その次に高島田に結ったのが、この夏さる工学士とまた縁談のある四番の操子で、五ツ目の車が絹子と云う、三五の妙齢。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女は、丈長掛けて、銀の平打の後ざし、それ者も生粋と見える服装には似ない、お邸好みの、鬢水もたらたらと漆のように艶やかな高島田で、強くそれが目に着いたので、くすんだお召縮緬も、なぜか紫の俤立つ。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　紫の矢絣に箱迫の銀のぴらぴらというなら知らず、闇桜とか聞く、暗いなかにフト忘れたように薄紅のちらちらする凄い好みに、その高島田も似なければ、薄い駒下駄に紺蛇目傘も肖わない。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈がすらりと高島田で、並ぶと蛇目傘の下に対。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば上野なら上野で、清水の堂に、文金の高島田、紫の矢絣、と云つた美人が、銀地の扇か何か持つてゐるといふと、……奈何にも色彩が榮えて配合その宜しきを得てゐるが、これが今時のやうな風俗であると一寸弱る、前述のやうだとお花見らしい上野が見えると言ふもの。",
              "citation": {
                "source": "お花見雜感",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが高島田だったというからなお稀有である。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ええ、高島田で、紫色の衣ものを着た、美しい、気高い……十八九の。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まさか、巻込まれたのなら知らないこと――お婿さんをとるのに、間違ったら、高島田に結おうという娘の癖に。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おじさん、ひどい、間違ったら高島田じゃありません、やむを得ず洋髪なのよ。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さん、いま結立てと見える高島田の水の滴りそうなのに、対に照った鼈甲の花笄、花櫛――この拵じゃあ、白襟に相違ねえ。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "高島田に花笄の、盛装した嫁入姿の窈窕たる淑女が、その嫁御寮に似もつかぬ、卑しげな慳のある女親まじりに、七八人の附添とともに、深谷駅から同じ室に乗組んで、御寮はちょうど私たちの真向うの席に就いた。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツツとあとへ引いて、若い紳士が、卓子に、さきの席を取って、高島田の天人を、（縫子さん。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　返事を、引込めた舌の尖で丸めて、黙りのまま、若い女房が、すぐ店へ出ると……文金の高島田、銀の平打、高彫の菊簪。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お小姓がね、皺を伸してその白粉の着いた懐紙を見ていたが、何と思ったか、高島田に挿している銀の平打の簪、※が附いている、これは助高屋となった、沢村｜訥升の紋なんで、それをこのお小姓が、大層｜贔屓にしたんだっさ。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "高島田に笄が飴色に冴えているお京さん。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロダンは花子の小さい、締まった体を、無恰好に結った高島田の巓から、白足袋に千代田草履を穿いた足の尖まで、一目に領略するような見方をして、小さい巌畳な手を握った。",
              "citation": {
                "source": "花子",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま床の前の緞子の座布団にドッカと腰を下して、腕を組んでいると今度は、美しく身化粧した高島田の娘が、銚子を捧げて這入って来た。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "琴　学生時代には本郷へんの屋敷町を歩いているとあちらこちらの垣根の中や植え込みの奥から琴の音がもれ聞こえて、文金高島田でなくば桃割れ銀杏返しの美人を想像させたものであるが、昨今そういう山の手の住宅区域を歩いてみても琴の音を聞くことはほとんど皆無と言ってもいいくらいである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少いのは時々に髪が違う、銀杏返しの時もあった、高島田の時もあった、三輪と云うのに結ってもいた。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
