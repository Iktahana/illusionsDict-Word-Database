          "standard": [
            {
              "text": "現職の知事に対し、強力な対立候補が名乗りを上げたことで、選挙戦は一気に激しさを増した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "討論会では、対立候補の失言を逃さず追及する鋭い質問が飛び交った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "商店街のあちこちに、対立候補のポスターが競うようにして貼られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この転化を助けた契機に協調政治家阿部伊勢守の死による対立候補紀州｜慶福擁立派｜井伊大老の首相就任があり、基底に横たわるものにたんに、幕政参与権上の雄藩の不満だけでなくもっと根底的な幕府統制組織内の矛盾――深く当時の経済に根ざした幕府および諸藩の財政的矛盾があった。",
              "citation": {
                "source": "尊攘戦略史",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "金沢では永井の落選と、彼の反対の立場に立って、対立候補者である財閥の雄、中橋徳五郎を後援したＨ新聞社が暴徒によって焼打ちされた。",
              "citation": {
                "source": "叛骨・中野正剛",
                "author": "――主観的な覚え書き",
                "note": "青空文庫"
              }
            }
          ]
        }
