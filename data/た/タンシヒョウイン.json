          "standard": [
            {
              "text": "彼は豪華な食事には興味がなく、箪食瓢飲を旨として質素に暮らしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の賢人は、箪食瓢飲の生活の中で深い思想を育んだと言われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "忙しい日々に、たまには箪食瓢飲の慎ましい食事が心に染みる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "人皆｜原憲顔回たれというのでは無いが、蓬樞甕※箪食瓢飲でも幸福の存し得るものであることを会し得て的確ならば、貧もまた然のみ厭わねばならぬもので無いことは明らかである。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
