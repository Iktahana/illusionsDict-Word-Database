    "definitions": [
      {
        "index": 1,
        "gloss": "person in charge of beheading (concluding a seppuku)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "太刀取りは右衛門のそば近く寄って、「殿のお言葉を聞いたか。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "太刀取りの刀が閃くと、右衛門の手は鈴ヶ森の舞台で権八に切られた雲助の手のようになった。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "太刀取りは、「否か応か」と聞いた。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "太刀取りの声が再びかかると、彼の右の腕は血糊を引きながら三間ばかり向うに飛んだ。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "太刀取りは右衛門の耳に口を寄せて、「命が惜しいか」といった。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "太刀取りは四度太刀を振り直して、えいと首を刎ねた。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "太刀取りの武士が白刃を提げ、静かに背後へ寄り添った。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――普通の容貌をしている者への、強いにくしみ――それが、大次の眼光に、道場での木太刀取りに、突き刺すように感じられる。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならば、いったん、斬られて倒れた人間が、暗に紛れて這い出してまた鬘を冠り直し、太刀取りのべて、やあやあと向って来るからである。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "七「左内は刑場へ出て、定めの席へ就いた」甚十郎が口重く続けた、「太刀取りは某藩の士だった、それがうしろへ廻って大剣をあげ、よいかと声を掛けたとき、左内は振返って、　――暫く、暫く待て。",
              "citation": {
                "source": "城中の霜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云ったそうだ、是が事実だ」「事実だということがどうして分る」「慥かめて来た、太刀取りをした某藩の士、藩の名も姓名も約束だから云えぬ、その男に会って慥かめて来た、いまの事実に些かも相違なかったのだ」　誰も言葉を※む者はなかった。",
              "citation": {
                "source": "城中の霜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "太刀取りの民蔵が君命によってみ首はもうしうけた」「…………」　覚悟――それは伊那丸にとっていまさらのことではない。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、あさっての太刀取りは呂宋兵衛が役をおおせつかって、都田川の刑場で、その三人の首を斬ることになっている」「ああ、そうですか。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「太刀取りのお方――」　と、目くばせすると、それまで、小気味よげに三人をにらんでいた伴天連風の怪人は、「半助どのに、代理をお願いいたしたい。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの季節が、わたしたちとりわけエチエネットにとって、いちばん悪いときであった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
