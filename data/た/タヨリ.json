[
  {
    "uuid": "37a468f1-ca62-55fe-b075-0dd89db407e0",
    "entry": "便り",
    "reading": {
      "primary": "たより",
      "alternatives": [
        "だより"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
