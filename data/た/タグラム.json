        "examples": {
          "standard": [
            {
              "text": "キャッシュメモリの制御において、タグＲＡＭはデータのアドレスを管理する重要な役割を持つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "タグＲＡＭの読み出し速度が、システム全体のパフォーマンスに直接影響を与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プロセッサの設計図を見ながら、タグＲＡＭがどのように配置されているかを確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "・ペンタグラムの五個の頂点のうち、太陽と土星以外の三つは何だったのか、とても気になる。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "・ペンタグラムは古来より魔術の時の魔方陣や護符としてよく使われている。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
