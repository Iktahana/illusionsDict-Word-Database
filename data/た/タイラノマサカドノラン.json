        "examples": {
          "standard": [
            {
              "text": "平将門の乱は、平安時代中期に東国で起きた大規模な反乱であり、武士の台頭を象徴する出来事だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「歴史の授業で習った平将門の乱って、自分を『新皇』と称したんだよね。すごい野心家だな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "平将門の乱を鎮圧するために、朝廷からは藤原秀郷らが派遣され、激しい戦闘が繰り広げられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "柳生一族が、この土地に住みはじめたのは、平将門の乱があった承平、天慶の時代からであった。",
              "citation": {
                "source": "剣の四君子",
                "author": "柳生石舟斎",
                "note": "青空文庫"
              }
            }
          ]
        }
