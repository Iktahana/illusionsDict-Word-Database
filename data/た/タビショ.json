    "definitions": [
      {
        "index": 1,
        "gloss": "place where the sacred palanquin is lodged during a festival",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「そうして、その相手の二人侍は、何者だか判らねえのか」「ひとりは本所の御旅所の近所に屋敷を持っている平井善九郎というお旗本ですが、連れの一人は判りません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "お神輿は上の町のお旅所へ送られて、暗闇のなかで配膳の式があるのだそうで……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかみの少女見むとて街をゆく我ならなくに淋しきものを　　　　　　　　　○　祇園會の神興が御旅所に置かれてゐる間は、路へ向いた御旅所の軒にぎつしりと、高張提灯が掛けられる。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして神輿が御旅所にある一週間は、參詣人が引きもきらない、この一週間に無言詣でをしたものは、どんな願の筋でも叶へられるといふことで、家を出るから往復の道すがらどんなことがあらうとも物を言はないで、お詣りするよき人もある。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "御蔭森御旅所にて、音楽神供を観するもの有。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日には大神事として、八基の神輿が暗闇の中を御旅所に渡御とある。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "七基は二の鳥居前より甲州街道の大路を西に渡り、一基は随身門の前より左に別れ、本町宿の方から共に番場宿の角札辻の御旅所にと向うのであった。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い波のやうになつて道を通る人は皆南の方を向いて神輿のお旅所の方ヘ行くのである。",
              "citation": {
                "source": "住吉祭",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廣田村には前記の通り廣田八幡があり、廣田村字｜中條には同社の御旅所と向ひ合つて蛭子社がある。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祭りの行列がお旅所に這入ると、直ぐに接続してお旅所の儀式が初まるやうで、だいぶ時間が変つて来ている。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも私の一番失望したのは、御旅所の芝舞台が臨時祭記にはちやんとした舞台としてあつたらしいことである。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨時祭記の御旅所の舞台の図では、板の舞台でなければならないと思ふが、芝の様にも見える。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭りのお練り若宮を出てお旅所に這入るあのお練りは何であるか、と言ふと、同じく御神幸を中心とした行列と見えるが、実はあゝ言ふ風なのを私は近頃「招かれざる客」といつてゐる。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は八月十一日に御旅所を造り、九月に棟上を行つてゐるが、寺社雑事記時代は、原則としては、十一月廿七日だと思ふが、それさへ動揺がある。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月三十日（昔は大祓の日）には、堺の宿院の御旅所へ住吉の神輿の渡御がある。",
              "citation": {
                "source": "三郷巷談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其をり、神輿が堺の町に這入ると、本道の紀州海道は行かないで、わざ／＼海岸を迂回して、御旅所に達する。",
              "citation": {
                "source": "三郷巷談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大祓祭は摂津の住吉神社の神事の一つであることは、云ふまでもありませんが、その神輿の渡御が堺のお旅所へある八月一日の前日の、七月三十一日には、和泉の鳳村にある大鳥神社の神輿の渡御が、やはり堺のお旅所へありますから、誰もお祓と云ふことを、この二日にかけて云ふのです。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大道をまた一町南へ行きますと宿院と云ふ住吉神社のお旅所があります。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで或時私は、「ねえ加賀田さん、学校では好きぢやない方も交つて遊ぶのですから、私それよりもいゝことはないかと考へましたの、あのお午に帰りました時ね、学校の太鼓のなるまでお旅所の処の大きい燈籠へ上つて遊ばないこと。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は手を引き合つて住吉神社の宿院のお旅所の隣にある大燈籠の所へ行きました。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし五六丁離れて存在するオミコシの旅所が古墳だろうという説もある。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄兵衛は、せっかちに問いかけて、「どうだった、身許がわかったか」　ひょろ松は、汗を拭きながら、「いえ、それが妙なんで、下ッ引を総出にして江戸中の尼寺はもちろん、御旅所弁天や表櫓の比丘尼宿を洩れなく調べましたが、家出した者も駈落ちした者もおりません。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "都鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "８　オトラが居なくなると、君枝はふたたびしょんぼりした娘になってしまった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "六「銀ちゃん、あたしゃアもはや一滴も駄目でさア」　もう飲みまわるのはよしにしよう――と、坂野は眉毛まで濡れ下ったびしょ濡れの顔を、グッドモーニングの銀ちゃんの肩へより掛らせながら、ひょこひょこ歩いていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその時店の灯で佗びしく照らされたびしょ濡れの往来と、坂の上に小さく見える交番と、その左手にぼんやり黒くうつる木立とを見廻して、はたしてこれが今日の仕事の結末かと疑ぐった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅学士は狐に鼻をつままれたような感じで、渡されたびしょ濡れの袋を開いた。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "源造よお前は村へ帰った兵隊さんだお前はその訳知ってべよ俺あ営舎じゃガン張ったよ俺あ三十九度の熱が出てどうにもこうにもなんねい位そんでも俺あ将校奴の長靴を磨かされたびしょ雨の中に空ッ腹を抱えて真夜中の強行軍だ何でこんなに戦争がやりたいのか？",
              "citation": {
                "source": "軍服を着た百姓源造の除隊",
                "author": "今野大力",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は手燭を持って、たぶん海水たびしょ濡れになっているだろうと思いながら、上の寝台を調べた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "上床",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
