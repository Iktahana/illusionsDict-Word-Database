[
  {
    "uuid": "33858eae-fafc-587c-ab15-3562ae31c8cb",
    "entry": "単簡",
    "reading": {
      "primary": "たんかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "simple",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "純文学と云えばはなはだ単簡である。",
              "citation": {
                "source": "作物の批評",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "画は一輪花瓶に挿した東菊で、図柄としては極めて単簡な者である。",
              "citation": {
                "source": "子規の画",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ」とは単簡な二文字であるが滅多に使うものでない、これを活かすにはよほど骨が折れる。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三）　もう一つ歴史的研究についての危険を一言単簡に述べておきたいと思います。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "説明はなるべく単簡な方が宜ろしいから、ここに一つの物でも、人でもあるとする。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "（この場合においてもこれは犬なりというのはもっとも単簡なる形式を撰んだものであります）。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも分りやすいためになるべく単簡に通俗な例で説明致します。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ善と悪の混血児はというとほとんど出て来ないんだから、至極単簡で重宝であります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "其間に平岡から四遍程極めて単簡な質問を受けた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども斯う単簡に聞かれたときに、何うして此複雑な経過を、一言で答へ得るだらうと思ふと、返事は容易に口へは出なかつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵談なんていうのも恥かしいくらいトンチンカンな、単簡明瞭な事件なんだが……。",
              "citation": {
                "source": "近眼芸妓と迷宮事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは単簡に当分うちは持たない。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "うんと単簡に返事をしたら山嵐は安心したらしかつた。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に平岡から四遍程極めて単簡な質問を受けた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもこう単簡に聞かれたときに、どうしてこの複雑な経過を、一言で答え得るだろうと思うと、返事は容易に口へは出なかった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎は単簡に、「僕は二十三だ」と答へた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも甚だ単簡なものに過ぎない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "透明な空気の様な、純粋で単簡な芝居が出来さうなものだ」「先生の御覧になつた夢でも、芝居にしたらそんなものが出来るでせう」「君｜希臘の芝居を知つてゐるか」「能く知りません。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "うんと単簡に返事をしたら山嵐は安心したらしかった。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこぶる単簡な面白い巡査である。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は単簡にまた私の納得できるように答をした。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学者だから御世辞を使うとすると、ほかの諸君にすまないけれども、実を云えば長谷川君と余の挨拶が、ああ単簡至極に片づこうとは思わなかった。",
              "citation": {
                "source": "長谷川君と余",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この洋杖は竹の根の方を曲げて柄にした極めて単簡のものだが、ただ蛇を彫ってあるところが普通の杖と違っていた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は単簡にただ「ええいらっしゃい」といっただけであった。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は単簡に礼を述べた。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの主意は単簡でした。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
