          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この映画は大手のシネコンではなく、渋谷の単館系の映画館でのみ公開される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
