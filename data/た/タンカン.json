  {
    "uuid": "9fe3e0a3-ea77-5315-aeef-60520b3a7701",
    "entry": "胆管",
    "reading": {
      "primary": "たんかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bile duct",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "きっと輸胆管のあたりもひきつっていて、胆汁がうまく腸へ送られないだろう。",
              "citation": {
                "source": "ジストマ退治の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親は長年にわたって麻痺状態であり、母親は長期間にわたって疝痛と胆管閉塞で苦しんでいた。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "胆石の手術はどの外科医でもやることだが、彼は胆嚢の中にたまる石を化学分析したり、レントゲン分析して、どうして石が固まるのか、また石が胆管を通して腸内に出てくる生理的な問題に取組んでいた。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも胆管が長かったら長命を示している。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々に伝わっている断片には心臓とその弁、喉頭蓋を含む上気道、肝臓、胆管、脳、の優れた記載が含まれている。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
