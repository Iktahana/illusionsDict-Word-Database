        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "中世の騎士が描かれた巨大な「タペストリー」が、城の壁に飾られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は趣味で、数ヶ月かけて壮大な風景の「タペストリー」を織り上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "博物館の展示室には、歴史的な出来事を記録した「タペストリー」が並ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "開いた窓の横にタペストリーで飾られた寝椅子があり、昼近い陽光が当らないようにゴーズのカーテンが注意深く巡らされていた。",
              "citation": {
                "source": "犬酸漿",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方の天井から下った、タペストリーには、カザリン二世（十七世紀）頃の香があり、死体のかけていた椅子などは、背部の木部の飾りに、ロマノフ廃朝の紋章が浮き彫され、銀の象眼が、なされていた。",
              "citation": {
                "source": "雪",
                "author": "楠田匡介",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
