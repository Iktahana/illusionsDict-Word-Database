    "definitions": [
      {
        "index": 1,
        "gloss": "person who achieves perfection",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
