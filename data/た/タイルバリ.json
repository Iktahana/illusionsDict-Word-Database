        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白いタイル張りのハイカラな浴場であった。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでその杉木立の中にポツネンと立っている南堂家の図書館というのは、五｜間に四間ぐらいの二階建の鉄筋コンクリートに茶褐色のタイル張りで、上等のスレート屋根の下に緑色に塗った鉄のブラインドが並んでいる。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　万事の設備不完全なるは、一々数え立てるまでもないが、肝腎の風呂場とても今日のようなタイル張りや人造石の建築は見られない。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、タイル張りの湯槽に浸っていると、ふと脱衣場の戸があいて、誰か着物を脱ぎはじめたらしい気配がした。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイル張りの、大きなストーブのそばには、ライオンのふたのついている、大きな中国の花瓶がありました。",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方白い、小さいタイル張りの部屋の中で、前川は黙っていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "『浴後』のタイル張りの正確な図式的な配列、それによつて、曾つて『浴女』の湯の中の揺曳で効果をあげたと等しい効果を、そつと誰にも知らさぬやうに効果づけてゐる手腕は末怖ろしいものがある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体の構造は今も昔も変らないが、浴槽も流し場もすべて木造で、人造石やタイル張りのたぐいは殆ど見出されなかった。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "女湯にも人が、人が……」　タイル張りの流し床に蒲団を放り出した女房が、こう叫んだのは、すべて計ることの出来ない瞬間のことである。",
              "citation": {
                "source": "電気風呂の怪死事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　女湯の白いタイル張りの床の上に、年の若い婦人の屍骸が俯伏に倒れていたのだ。",
              "citation": {
                "source": "電気風呂の怪死事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の夕方、その家のタイル張りの湯にひたると、その風呂にはじめて妻に案内されて入った時のことがすぐ甦った。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の夕方、その家のタイル張りの湯にひたると、その風呂にはじめて妻に案内されて入つた時のことがすぐ甦つた。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "中はタイル張りの美しい広い浴場である。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡はさつさと、湯気のたちこめてゐる湯殿へ這入つて行つたが、六七人の老若もみわけがたい男女が、タイル張りの広い浴槽にはいつてゐる賑やかさに気安いものを感じた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてユックリと放尿してしまうと、電球の真下の白いタイル張りの上に投げ出してある白いタオル寝巻きと、黒い革のバンドを取り上げて、不思議そうに検ためていた事を記憶えている。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろこの法曹クラブ・ビルというのは、スベスベしたタイル張りの外壁をもって居り、屋上には廂のようなものが一間ほども外に出ばっていたし、人間｜業では、到底窓の外から忍びこむことが出来そうもなかった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "バイを食して大悟す　タイル張りの浴室に海水を洗い落して、余が二階へ戻ると、放善坊が性こりもなく一句したためて余に示した。",
              "citation": {
                "source": "決戦川中島　上杉謙信の巻",
                "author": "――越後守安吾将軍の奮戦記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "西側の窓の下に洗面所があつて、現代のやうにタイル張りなぞないから、白い竹とゴマ竹とをしやれた縞にはりつめたすのこがあつて、水入れと洗面器が伏せてあり、右手の台の小さい桶から今の水道と同じやうに水が出た。",
              "citation": {
                "source": "トイレット",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒ペンキで塗りつぶせば白墨で書くし、タイル張りにすればわざわざ紙を張って講義する熱心な教師は、どこより来たり、いつの間に書きどこへかくれるのでしょうか？",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "便所の壁が、多くはツルツルしたタイル張りで、楽書が出来ぬというのも事実である。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は指さきで箪笥を叩いてみせ、それから私の注意を、今どきどこへ行っても見られぬはずのタイル張りの絵模様のある暖炉へ向けさせた。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "箪笥からも、タイル張りの暖炉からも、肘掛椅子からも、画布へ毛糸と絹糸で縫いとって、巌丈な不趣味な額縁に嵌めた絵からも、心善い飽食の息吹きがした。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイル張りで、窓も多く、水も温水も出るということですから、手術には間に合いますよ。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり白タイル張りの左手の壁に、ひびの入って蠅のしみのついた鏡がとりつけてあって、その下に洗面台があった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いタイル張りの暖炉があって、上に薬罐がのっている。",
              "citation": {
                "source": "シナーニ書店のベンチ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳白のタイル張りは永い間見詰めていると紫色の彩感が突っ走り、タンクの水勢は谷川のへりに跼んでいるように聴える。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の家でタイル張りの浴室にばかり這入りつけているせいか穴蔵へでも入れられたようで、その上｜丁子を煎じてあるのが、垢だらけに濁った薬湯のような連想を起させるのである。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "珠子は、白タイル張りの浴槽の縁に、断髪の頭をもたせかけて、足を伸ばしてグッタリとなっていた。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が先にともなく、湯殿の中へなだれ込むように入って見ると、タイル張りの洗い場一杯に、珠子の白い身体が長々と横たわっていた。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイルばりの大きなだんろのそばには、ししのふたのついた、青磁のかめが、おいてありました。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
