        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "他説によれば chic の原形は schick である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、第一幕に大尉の生活、感情その他説明する幕があるが、それはまるで、ドニー・トゥルビーニフ〔「トルビン家の日々」〕のときと同じ感じだ。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "とは云へそれは決して論争といふものでは無く、相手と異つた自説を披瀝して喜ぶだけの事であり、他の説に服しない場合にも他説の不備を指摘してその反省を促す程度のもので、所謂論争のやうな熱情も伴はず、論旨としても敢て徹底を期してゐるのでも無く、云はば温雅な談笑に多少の波瀾を求めるためのものであつた。",
              "citation": {
                "source": "個人的な余りに個人的な饒舌",
                "author": "＝龍之介対潤一郎の小説論争＝",
                "note": "青空文庫"
              }
            },
            {
              "text": "一も二もなく他説に従って、「――では早速、備え立てして敵を待とう。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お用いなき他説をお聴きになっても、かえって迷う因ではありませんか」「ともあれ拝聴しましょう」「では忌憚なく申しあげる。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "杖は※状の自然木なるが、その曲りたる処に鼻を凭たせつ、手は後様に骨盤の辺に組み合せて、所作なき時は立ちながら憩いぬ。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは秋のすえごろのことで、はだ寒い風が東からふき、野には人のかげさえ見えず、マタンはさびしさを感じながら、けれど、心のおく深いところには喜びをわきたたせつつ、いそいそと道をたどっていきました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "母娘は顏をみあはせましたが、寂しさうにその何方からも何とも言はず、そして※のうしろ姿がすつかり見えなくなると、またせつせと側目もふらずに織り出しました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨハンネスは、王女をみたせつな、顔いちめんかっと赤くほてって、ただひとしずくの血のしたたりのようになりました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで病苦にも増したせつない思いをしながら、忠利は「許す」と言ったのである。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "三尺以上に接近したら引つぱたくぞ――といつた、近寄りがたい、もたせつぷりたつぷりの作品がまことに多いとき、土牛の単純化の作品は「奥様――土牛さんの柿を拝見してきましたが、たいへんよく熟れてをりましたよ――」と女中が感想を述べる自由も保有されてゐるのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさに一｜箭、はっしと射放たれたかと見えたせつな、むっつりの名人また、身のさばきみごとです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "お引き出物に、ひとつ歌わせておくんなさいな」　いいつつすれ違ったせつな！",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "――弓勢またなかなかにあなどりがたく、寄らば射ろうとばかりにねらいをつけようとしたせつな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "中を改めてみるから、その三宝をちょっとこっちへ貸しな」　引きよせて三宝の上にその一個をうちのせながら、すういと静かにわきざしでまっ二つに切り裂いたせつな！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "――証拠のその赤い袋をそっとうちふところ深くしまい入れて、右と左に伝六とたもとをわかちながら、ゆらりゆらりとここちよげに駕籠をうたせつつ、やがて行きついたところはその四ツ谷ご門前でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、それと知ったせつなです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "不浄な品物をでも扱うように、黙々としてその紙入れをふたたび死人のふところへ返したせつな！",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思われたせつな、何を看破したのかさわやかに微笑すると、穏やかなことばが敬四郎のところへ放たれました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが、とっぷり暮れて、宵五ツの鐘が遠くに消えていったせつな！",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "いぶかるように呼ばれたそのお蘭がひょいと障子をあけたせつな！",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙々沈々、石のごとく冷静に、おしのごとくおし黙りながら、長い間まなこをとじて考えつづけていましたが、そろり、そろりとあの手があのあごのあたりへ散歩を始めたかと思われたせつな！",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、その豆大黒はどこへ祭ってあった」「ここでござります」　いいながら道具屋の亭主がなにげなく次のへやとのふすまをあけたせつな――右門はおやッ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったせつな――ちらちらとはげしく土手の向こうであかりが動きました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの物置き小屋がいんちきばくちの開帳場にちげえねえから、しりごみしていずと乗り込みな」　押し入ろうとしたせつな！",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日――十一月七日の朝「起床」のガラン／＼が鳴ったせつな、監房という監房に足踏みと壁たゝきが湧き上がった。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁に背をもたせつつ、燐寸箱を賣る盲人もあり。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "またせつぱ詰つて書いた作に傑作が多かつた。",
              "citation": {
                "source": "雨の日に",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "青木　まず最初、卵が水面に触れたせつ那を考えましょう。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸に動悸を打たせつゝ、お光はこんなことを考へて、耐まらなくなつた。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
