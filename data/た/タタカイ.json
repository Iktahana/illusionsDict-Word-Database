    "definitions": [
      {
        "index": 1,
        "gloss": "battle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし、戦いは尚つづく。",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦いは王に不利であった。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦いが終わってトーレ・フンドは王の死骸を地上に延ばして上着を掛けた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音楽の布いて行く地盤の上に、遠い昔の北国の曠い野の戦いが進行して行った。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相撲は人間の体力の活技で、一方から見れば霊妙な複雑な器械の戦いである、いずれにしても運用する力はいわゆる器械力で、力の作用する目的物は質量を有する物体だから、やはり相撲も力学の広い縄張の中へ入れても好かろうと思う。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらは拡声器に対し戦いを宣す。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大戦」と、ルパートのいわゆる「戦いはこれから始まるのだ」のその「戦い」との間に、この楽しい球技の戦いが挿入されている。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその美的方則の構成には、非常に複雑な微分数的計算を要するので、あらゆる町の神経が、異常に緊張して戦いていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎長、代官と戦い乍ら叫ぶ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上の菩提樹の古木の枝が、静かに朝風に戦いでいる。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼空は培養硝子を上から冠せたように張り切ったまま、温気を籠らせ、界隈一面の青蘆の洲はところどころ弱々しく戦いている。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は空中滑走する、戦い疲れた陳独秀とビクトリア・カップよりセント・ジョウジ・プレースに至る山頂火車のなかで彼等は力なく握手して、空中の鏡の上にモーニング姿の印度人のイサックを発見するのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンミニストは日を逐うて、戦いの用意を整えている……」この悲痛な手紙を突きつけられた、裏切者、蒋介石の軍司令部の一行だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "煎りつくようなのどの乾きと、傷が生命を奪って行く、それとの戦い、疼痛などで、病室は、檻のようなわめきで、相呼応していた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "オビドマアニュの市街が敵軍に包囲され、そのうちに、攻防両軍の革命家が叛乱を起したため、ついに戦いが終了するのである。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "喬は風に戦いでいるその高い梢に心は惹かれた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――家賃を払う家が少なくて、医者の払いが皆目集まらないというこの町では、肺病は陰忍な戦いである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妄想で自らを卑屈にすることなく、戦うべき相手とこそ戦いたい、そしてその後の調和にこそ安んじたいと願う私の気持をお伝えしたくこの筆をとりました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この化け物と科学者の戦いはおそらく永遠に続くであろう。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これら無数の元子はその運動の結果として不断に物を生成し、また生じた物は不断に破壊され、生成と破壊の戦いによって世界は進行する。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "注文してから書物が到着するまでの数日間は何事よりも重大な期待となんとも知らぬ一種の不安の戦いであった。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば戦いのすんだあとで、ゆるゆる敵を料理して肉でも胆でも食いたければ食うことができる。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく体力と知力との戦いとして見るときに、自分のような素人にもこの勝負の特別な興味が感ぜられるのであった。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら自分は、一生涯こんな憂鬱と戦い、そうして死んで行くということに成るんだな、と思えばおのが身がいじらしくもあった。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと戦いを好まぬ国民が、いまは忍ぶべからずと立ち上った時、こいつは強い。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで手足の指などは自分のからだの一部とは思われないように冷え凍えてこちこちしている代わりに頭の中などはいいかげんにあたたかいものがよい程度に充実しているような気がしている。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会の上に広がる濁った空気を透して見るのでそれが妙な赤茶けたあたたかい色をしていた。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無関心の高い峯の上を、その鳥群のまだらだけが愛を湛えて、哀しい大空にあたたかい味を運んで行く。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれこの生あたたかい春の夜に、そよそよと潮みづながれ、生物の上にみづながれ、貝るゐの舌も、ちらちらとしてもえ哀しげなるに、とほく渚の方を見わたせば、ぬれた渚路には、腰から下のない病人の列があるいてゐる、ふらりふらりと歩いてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままでソファの底に沈んで、情婦のつくってくれたあたたかいラム・パンチをのんでいた田村英介氏は四家フユ子のデコルテの紊れに強い感情を乱されて、――おまい、僕と別れたいんだろう――――ノン、あなたが妾を囲いものにするからさ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
