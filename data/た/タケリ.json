    "definitions": [
      {
        "index": 1,
        "gloss": "ox or whale penis, used as a tonic or aphrodisiac",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「石松ッ」　石松、出て来る　「何だい父っつあん」　「石松、お前やくざに成りたけりゃなれ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉「汝がそれ程Ｔ「出たけりゃ　勝手に出ろ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "をさけびたけり足ぶみて、　　をどりめぐれるすがたゆゑ、老いし博士や郡長、　　　　　やゝ凄涼のおもひなり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、ああ、ガンジス河、幅一｜里にも近い大きな水の流れは、みんなの目の前で、たちまちたけりくるってさかさまにながれました。",
              "citation": {
                "source": "手紙　二",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護員に迫害を加うべき軍夫等の意気は絶頂に達しながら、百人長の手を掉りて頻りに一同を鎮むるにぞ、その命なきに前だちて決して毒手を下さざるべく、かねて警むる処やありけん、地踏韜蹈みてたけり立つをも、夥間同志が抑制して、拳を押え、腕を扼して、野分は無事に吹去りぬ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は荒鷲のようにたけりたけって、グラスをつかんだ。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠カチヤを女房にしたけりゃ、金の耳を揃えて買いに来う。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出したけりや出したら好いぢやないか」　この言葉を聞くと妻は釣り込まれて、立上らうとした様子であつたが、思ひ返したらしく又坐り直して始めて彼の方を振りかへりながら、「でも貴方がお入れになつて私が出してやつたのでは、私がいゝ子にばかりなる訳ですから」　と答へた。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "言われなくたって、出たけりゃ勝手に出ますわ、あなたのお内儀さんじゃあるまいし。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "但その頭の獅子が怒り狂って、たけり戦う勢である。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "行きたけりゃ、余計なことを云わずに、直ぐ仕度をしておいで。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はむつとして、たけりたけつたのである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "舊稿の文章は、たけりたけつて書かれてゐる。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧稿の文章は、たけりたけって書かれている。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵たけり立って膝をすすめ、「武士には、信の一字が大事ですぞ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ、そんなに奉られたけりゃ三太夫でも抱えれば可い。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れを知らぬ肉体が歓び・たけり・汗ばみ・跳ねている・その圧倒的な力量感。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護員に迫害を加ふべき軍夫らの意気は絶頂に達しながら、百人長の手を掉りて頻りに一同を鎮むるにぞ、その命なきに前だちて決して毒手を下さざるべく、予て警むる処やありけん、地踏※蹈みてたけり立つをも、夥間同志が抑制して、拳を押へ、腕を扼して、野分は無事に吹去りぬ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人並の恋がしたけりゃこのわたしとて、今までに随分相手の女もなくはなかった。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――それとも、よっぽど冷やし飴が売りたけりゃ、マニラへ行きなはれ」「なんぜまた、マニラへ……？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの今晩は檀那様がいらっしゃらないだろうと思うから、お前内へ往って泊って来たけりゃあ泊って来ても好いよ」お玉は重ねてこう云った。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聞き付けた宿の者どもが寄って来て、たけり狂うお安を取押えて無理に表へ突き出してしまった。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ふん」と、義雄は横に向き、「喰ひたけりやア、よそへ行つて喰つて來らア――どうせ、おれは、おれの出す金さへ出してゐりやアいいのだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "」かの女も意地になつて、息を大きく呼吸し出して、張つた胸の兩方の乳のあたりまでも衣物の上へ動悸を打たせながら、「別れたけりや今からでも別れてやる――直ぐ病氣を直せ、直せ！",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「行きたけりやア、勝手に行くがいい、さ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うへ行きたけりゃ手前の方からよけて通れ」という鼻の表現を和らげて、「貴殿が紳士なら拙者もゼントルマンで御座る」「御免遊ばせ」「失礼を」で行き違います。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえに彼らは猩々緋の『鎗中村』に突きみだされたうらみを、この黒皮縅の武者の上に復讐せんとして、たけり立っていた。",
              "citation": {
                "source": "形",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、よっ程冷やし飴が売りたけりゃ、マニラへ行ってモンゴ屋商売をせエ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたいと起きて行き、はいろうとすると、繩の帯をした薄汚い男が、そこは俺の寝床だ、借りたけりゃ一晩五円払えと、土蜘蛛のようなカサカサに乾いた手を出した。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
