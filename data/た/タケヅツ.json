[
  {
    "uuid": "8725b503-0356-5413-9cd8-43b6bd3dc7a8",
    "entry": "竹筒",
    "reading": {
      "primary": "たけづつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
