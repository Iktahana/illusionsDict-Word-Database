        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古い教会の祭壇には、精巧に彫られた木製の磔刑像が安置されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祈りを捧げる信者たちの視線は、静かに中央の磔刑像へと注がれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その美術館には、ルネサンス期の名もなき職人が手掛けた磔刑像が展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "マズレヴィチは、老女ケザイアと鋭い牙を持ち鼻を突っ込んでくる毛皮野郎について、長くて要領を得ない物語を聞かせてよこし、そいつらに時々ひどくつきまとわれるのだが、そんな時は自分の持っている銀の｜キリスト磔刑像――その目的で聖スタニスラス教会のイヴァニツキ神父がくれたもの――だけが助けになったと言った。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔女は磔刑像を見てパニックに襲われたようで、首を締め上げる腕の力が緩み、ギルマンが逃れ切るだけの隙ができた。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭壇に視線を落とすと、花と草と花冠で飾られた只中に大いなる金の磔刑像があった。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな村の中心部に大きな鉛の鋳物でできた磔刑像が立っていた。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの男は安息日について清教徒のような言い方をしました……それなのに自分の部屋に磔刑像を飾つていました。",
              "citation": {
                "source": "村の吸血鬼",
                "author": "THE VAMPIRE OF THE VILLAGE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
