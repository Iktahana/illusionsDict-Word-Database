[
  {
    "uuid": "48f4b22d-8e92-5aa9-b905-175a9cfa1658",
    "entry": "対戦",
    "reading": {
      "primary": "たいせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fighting (against)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あれは対戦中の右翼小説ほどひどくは無いが、しかし小うるさい点に於いては、どっちもどっちというところです。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和の長髄彦との御対戦は、古事記に依つても、その御苦戦が察せられる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに元和元年、大坂方と対戦中に、「群書治要」を刊行させてゐる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――第一回の試合は「Ｗ」と「Ｈ」の対戦で開幕された。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「Ｐ」と「Ｈ」との対戦に観戦慾を充たす筈であつたのに、はじめは案の条「Ｗ」が次第に圧され気味であつたところ、後半戦に至つて、持久力に熱を加へた「Ｗ」が稲妻のやうな火花を散して一気に、十六―二十四といふ大差をもつて悠々と、当面の強敵を打ち破つた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｗ」大学は、おそらく五年振りで、第二回戦の機会を獲、強敵フイラデルフイア・チームに対戦するの面目を得たわけであつた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｗ」とフイラデルフイアの対戦では、更に観衆の予想をまつたく裏切つて、当初から「Ｗ」の攻撃が目覚しく五―対―十の順序で、一気呵成に「Ｗ」が圧しきつた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし真剣な努力を以てすれば、戦車の整備に対し対戦車砲の整備は却って容易であり、戦車による敵陣地の突破は、十分に準備した敵に対しては今日といえども必ずしも容易とは言えない。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に考うべきことは対戦車火器の準備は戦車の準備に比して容易な事である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "立会人等は協議の上二回迄の対戦を承認した。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "間隙の無い見事な対戦に観る人の心は胸苦しい迄緊張した。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、右の二つの意見書が両軍対戦における最初の一斉射撃であって、それより双方負けず劣らず多数の意見書、弁駁書等を発して、これを議員、法律家、その他各方面に配附した。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人は今後の戦争は女性との対戦ならんといった。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "前田山、先般、月刊読売誌上に、呉氏に八子で対戦、敗北したが、角界随一の打手の由である。",
              "citation": {
                "source": "本因坊・呉清源十番碁観戦記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "巷間つたへるところの風聞、もつぱら勝負の悪鬼の如き木村名人のすさまじさであり、これも名人戦であつたか、神田八段との対戦で、神田八段が十五分おくれてきた時、対坐して対局にさしかゝる時に、記録係に向ひジロリと目をむいて、十五分、神田八段の持時間から引いておけ、と言つたといふ。",
              "citation": {
                "source": "散る日本",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊之吉の門人は出ると負け、すべて一撃に打ち倒されて、師匠同士の対戦となったが、これも同前、ひとたまりもなかった。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "”　という記事もあって、いよいよ近く英独は、ドーヴァ海峡を距てて対戦するであろうことを示唆しているものもあった。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林秀雄、今日出海両君とゴルフ対戦のことで話があった。",
              "citation": {
                "source": "ゴルフと「悪い仲間」",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "不敗を誇った木村に最初に黒星をつけたのは升田で、木村の自信の喪失はそのときから始まったと云われているが、名人位を失ってからのサンタンたる戦歴の中でも特に升田に対しては特別で、終戦後その時まで五局だか七局だか升田と対戦して一度も勝ったことがない。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが事実上の優勝戦であるばかりか、その勝者は甲子園で優勝するだろうと考えられていたほどの東京では珍しい実力の充実した両チームの対戦であった。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼と古橋との対戦は日本のファンのみでなく全世界の水泳ファンの期待であったし彼が日米競泳に番外として来日したのも古橋と競技したいためであった。",
              "citation": {
                "source": "日本の水を濁らすな",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今まで、ムーアは対戦に良いところが全くなかった。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "見知らぬフランス人と対戦している。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "見知らぬ対戦相手が首を左右に振って、立ち上がり、バカ丁寧にお辞儀して、席を離れた。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "荘園内ではクリケット対戦相手のフリーフォレスターズを迎えて試合があり、正午に庭師の食事会があり、午後には子供たちのお祭りがあった。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはそこから出ることができず、穴の中の熊のように襲われ追窮されて、ハンノーヴルの二個中隊との対戦を甘受した。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューヨーク・ヤンキースがデトロイト・ティグレスと対戦しているはずだった。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "対戦相手の力を知る羽目になった。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮮やかな武器でいつも対戦されました」　バレリイ嬢が抗議した。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思ってそこを見ると、その小さい水玉たちは、僅か三、四寸の空間をきらめいて落ちて行きながら、流れている水面にまた無数の微かな波紋を作って、この美しい光の交響楽は、ますますせんさいに捉えがたいせんりつを織り出しているのでした。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
