    "definitions": [
      {
        "index": 1,
        "gloss": "leaf mustard (Brassica juncea var. integrifolia)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
