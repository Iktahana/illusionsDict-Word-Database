[
  {
    "uuid": "df0a0a50-445a-57a5-b58c-2e4dc88881e0",
    "entry": "為にする",
    "reading": {
      "primary": "ためにする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-サ変-する"
      ],
      "ctype": null,
