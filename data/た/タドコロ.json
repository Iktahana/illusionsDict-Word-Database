        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "座スクはツグの間付きの離れ造り、お米は秋田荘内の飛び切り上等、御菜も二ノ膳つきでござります。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳳嶺の事は田能村竹田の竹田荘師友画録及竹田荘詩話に見えてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹田荘師友画録にかう云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎の梅泉は竹田荘師友画録にも五山堂詩話補遺にも見えてゐて、わたくしは其人を詳にせむと欲してゐたからである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖先は源の頼光より出で、乙葉氏を称したが、摂津国より信濃国に徙り、内蔵助長政と云ふ者が筑摩郡内田郷浅田荘に城を構へて浅田氏となつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "山口高等商業学校の教授であつた作田荘一君（後に京都帝大の教授となり、退官後は満洲建国大学の副総長となつた人）を京都帝大に迎へるため、校長に直接談判をしに出掛けたのである。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "此郷近くに田荘を持つて、奈良に数代住みついた豪族の一人も、あの日は帰つて来て居た。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "刈り上げの秋になると、夫と離れて暮す年頃に達した夫人などは、よく其家の田荘へ行つて、数日を過して来るやうな習はしも、絶えることなくくり返されて居た。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此郷に田荘を残して、奈良に数代住みついた豪族の主人も、その日は、帰つて来て居たつけ。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "刈り上げの秋になると、夫と離れて暮す年頃に達した夫人などは、よく其家の遠い田荘へ行つて、数日を過して来るやうな習しも、絶えることなく、くり返されて居た。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此郷に田荘を残して、奈良に数代住みついた豪族の主人も、その日は、帰って来て居たっけ。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "刈り上げの秋になると、夫と離れて暮す年頃に達した夫人などは、よく其家の遠い田荘へ行って、数日を過して来るような習しも、絶えることなく、くり返されて居た。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はふたたび精神病院の門をくぐり、その後一年あまりを叔父の田荘に病を養った。",
              "citation": {
                "source": "「あかい花　他四篇」あとがき",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "応仁二年将軍の近臣斎藤｜妙椿が、乱の紛れに東氏の先祖が拝領した美濃国山田荘を横領したので、常縁は頗る悲しんで一首の歌を詠じたのが妙椿に伝わり、同情を得て取り返すことができた。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後｜薙髪して素伝といい、多く小田荘郡上城にいた。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪府｜泉北郡八田荘村家原寺）　これと全く同じ話は、また播州加古川の教信寺の池にもありました。",
              "citation": {
                "source": "日本の伝説",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何もしなかつたどころか、父上母上に不孝をした。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れたどころではありません、文六ちゃんがこわいのです。",
              "citation": {
                "source": "狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「聴いてたどころか、隣りの座敷で見ていたも同前だい！",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "えらい早かったなァ」夜店出し「早かったどころかいな。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "安二郎はお君の仕立賃のほか、最近は豹一がお君に渡す月給の幾割かをも右左にまきあげていたので、正直な計算によれば、もはや取るべきものはすっかり取ってしまったどころか、取り過ぎている勘定になっているのだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、それすらも言わなくなったどころか、「猿に毛が三本増えたって猿が幸福になれるもんか。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「怯えたどころか、一時はそのままになるかと思った。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭は大袈裟に、「どうしたどころかい、近頃評判なもんだ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「貰いましたともさ、貰ったどころじゃない、お嬢さんだって、私だって、九死一生な処を助けて下すった方ですもの、」「九死一生、」　お嬢さんと聞いたばかりでもう眼を据え、「煩ったかね。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐに解つたどころではなかつた――終ひには俥屋までが舌を鳴した。",
              "citation": {
                "source": "お蝶の訪れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しなかったどころではない、その中には葉子を考えさせるものが含まれていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "源五兵衛どんがなんぞお番所へでも訴えてまいったんでございますか」「訴えたどころじゃねえ、腹を切って伊豆守様に直訴をしたぜ」「えッ――。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「きたどころの段じゃねえんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あったどころか、どうも容易ならんことを耳に入れたんですよ。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            }
          ]
        }
