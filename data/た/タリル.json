    "definitions": [
      {
        "index": 1,
        "gloss": "to be sufficient",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから猶一台で足りるものかしらと案じてゐるのだ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし著者の意はその辺の些事になくして、蕪村俳句の本質を伝えれば足りるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下宿や洗濯屋の払いを済ませても二十円あれば足りる。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の炭素ランプでは一燭光につき三・五ワットくらいの電力を要するのがこのランプではわずか一ワットで足りる。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の親愛なる者よ、かかる精神をもつてこれ等の頁からはみ出してゐるものをお讀み下さい、――それはあなたの涙を惜しませぬでせう、が、それはあなたの涙に、より明るい、（そして云はば）透明な意義を與へるに足りるものでありませう。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は此處にその最初の巴里滯在中の詩人のすがたを彷彿せしめるに足りる三つの手紙を抄する。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには門番程度の想像力でも足りる。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "今この波瀾重畳険危な骨董世界の有様を想見するに足りる談をちょっと示そう。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚は言うほどもないフクコであったが、秋下りのことであるし、育ちの好いのであったから、二人の膳に上すに十分足りるものであった。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何様も十分調べて置いてシツッコク文字論をするので講者は大に窘められたのでしたが、余り窘められたのでやがて昂然として難者に対って、「僕は読書ただ其の大略を領すれば足りるので、句読訓詁の事などはどうでもよいと思って居る」など互に鎬を削ったものである。",
              "citation": {
                "source": "学生時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間が地上ばかりを歩いている間は普通の地図で足りるが、空を飛び歩くようになった今日では航空用の地図が必要になった。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして単に雪後の春月に対して物思う姿の余情を味わえば足りるであろう。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "園は一人の勤勉な科学者であればそれで足りるのに、兄のように畏敬する星野からの依頼だとはいえ、格別の因縁もない一人の少女に英語を教えるということ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この多い知識のなかには、自分のような特異性を持った性癖の人間をも導くに足りる知識が無いとも限らない。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか、これらの書物のなかで、自分の師とするに足りる書物を指図して欲しい。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」地震以來、解いた事のない帶だから、ぐいと引しめるだけで事は足りる。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が住めば水も要ろうで、何も釣瓶の音が不思議と云うでは、道理上、こりゃ無いのでありまするが、婆さんに聞きました心積り、学生の方が自炊をしてお在と云えば、土瓶か徳利に汲んで事は足りる、と何となく思ってでもおりましたせいか、そのどうも水を汲む音が、馴れた女中衆でありそうに思われました。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それであといくらも残らなかったがたぶん足りるだろうとのんきなことを考えながら、私をかき船に誘ったということだった。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、いくらのんきとはいえ、さすがに心配で、足りるだろうか、足りなければどうしようかなど考えながら食べていると、まるで味などわからなかったと言う。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一茎草を拈じて丈六の仏に化することもわるくないが、私は草の葉の一葉で足りる。",
              "citation": {
                "source": "白い花",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "足りるところに、私の愚が穏坐している。",
              "citation": {
                "source": "白い花",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "下婢で用が足りる位なら、世間の男は誰だツてうるさい妻なんか持ちはしない。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はたゞの人として自己を發揮すれば足りる。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しおかづは手輕だ、葡萄豆と紫蘇卷と燒海苔と鹿菜と蜊貝のお汁………品は多いが、一ツとして胃の腑の充たすに足りるやうな物はない。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても、足りるものではない。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人のアリガネを合わせても、とてもその「後輩」たちに酒肴を供するに足りる筈はなかったのである。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれ等には、単に詩と小説との文学につき、反動の歴史を見れば足りる。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つめたければや胸たりるなし。",
              "citation": {
                "source": "短歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この位なら私でも少し無理をすればたりるんですけれどもね。",
              "citation": {
                "source": "かなしみの日より",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "似て非なるものも交じっていようが、ただここにはやたらに話を記して、肩の凝らぬおもしろいものとなっていたらそれで自分は事たりるとせねばならぬ。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            }
          ]
        }
