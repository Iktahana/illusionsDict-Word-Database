[
  {
    "uuid": "c813c9d7-c4d1-5e86-9f7d-2c0c6c590275",
    "entry": "対峙",
    "reading": {
      "primary": "たいじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
