    "definitions": [
      {
        "index": 1,
        "gloss": "rapeseed oil",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
