  {
    "uuid": "b8b37f07-81ba-5a7f-96af-b393ba1a9724",
    "entry": "多宝塔",
    "reading": {
      "primary": "たほうとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
