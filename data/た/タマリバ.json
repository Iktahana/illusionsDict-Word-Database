        "examples": {
          "standard": [
            {
              "text": "コンビニの前が若者たちの溜まり場になっていて、近隣住民は困り果てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔ながらの喫茶店は、近所の囲碁仲間たちの憩いの溜まり場だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は自分の部屋を友人たちの溜まり場にされるのを、あまり快く思っていない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "地元の人たちの溜まり場のような店だった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "高校生の頃にはそこが柴崎にとっても溜まり場のひとつだった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "デヴォンシャイア公園地域は芸術家の溜まり場、小ぎれいな郊外にあり、建築家や庭師の見せ場でもあった。",
              "citation": {
                "source": "死の土壌",
                "author": "THE DUST OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、尼寺の庭の鐘楼の下は、村のこどものたまりばだからだ。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘆はその辺には生えてはいないが、足跡のついた泥地が洲のように所々高くなっているきりで、他とは変わりのない水たまりばかりであった。",
              "citation": {
                "source": "転機",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
