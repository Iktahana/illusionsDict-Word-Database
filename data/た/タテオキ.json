          "standard": [
            {
              "text": "スマートフォンの画面を「縦置き」にして、友達に写真を送った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このプリンターは、A4用紙を「縦置き」でも「横置き」でも印刷できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「縦置き」のレイアウトで、レポートを作成することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "アルト型の縦置きと思ったディスプレイが、横にも置けると分かったときは笑いがこみ上げてきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "開発者はきっと、縦置きのアルトとしてだけではなく、横置きのスターとしてもこのマシンを使いたかったのだろう。",
              "citation": {
                "source": "パソコン創世記",
