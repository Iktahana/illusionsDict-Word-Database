        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "受診に来る患者の甲乙丙丁が、何につけても姫草さん姫草さんと尋ね求める態度を見ると、ちょうど臼杵病院の中に姫草ユリ子が開業をしているようで、多少の自信を腕に持っている私も、彼女のこうした外交手腕に対しては大いに謙遜の必要を認めさせられていた次第であった。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし世に、真理を尋ね求める人はきわめて多い。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が尋ね求めるものは、若し桶の中に存在するとしても、細小なものであつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋ね求める人に廻りあつても、其とは知らぬあはれな筋立てを含むことが、此「女の旅」の物語の条件に備つてしまうたやうである。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋ね求める人に※りあつても、其とは知らぬあはれな筋立てを含むことが、此「女の旅」の物語の條件に備つてしまうたやうである。",
              "citation": {
                "source": "山越しの阿彌陀像の畫因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋ね求める人に廻りあっても、其とは知らぬあわれな筋立てを含むことが、此「女の旅」の物語の条件に備ってしもうたようである。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人影の、こっちに向いて走って来るのを認めたのも、いくらも経たない後のことでありましたが、不幸にして、その人影は、どう見直しても、自分の尋ね求める少年の姿ではありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これこそ日頃尋ね求める、我らにとっては大事の加担者！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "修験者はじっとその顔を鋭い目付きで瞶めたが、ウムと深く頷いて、「そういう深い事情がござらば尋ね求めるが当然でござる。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その原因を尋ね求めることは、今からではもうむつかしいであろうか否か。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
