[
  {
    "uuid": "5c9ac711-868f-5472-a215-b7dfb3c601ad",
    "entry": "立て直す",
    "reading": {
      "primary": "たてなおす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
