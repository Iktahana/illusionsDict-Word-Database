[
  {
    "uuid": "60497cba-3d10-517d-8c69-39ee9df9d4e2",
    "entry": "体外",
    "reading": {
      "primary": "たいがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
