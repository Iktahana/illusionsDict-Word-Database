    "definitions": [
      {
        "index": 1,
        "gloss": "palanquin set with jewels",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は云わば玉の輿にのったとも云われようが、自分の境遇は随分変った。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿河台の老婦人は、あわれ玉の輿に乗らせたまうべき御身分なるに、腕車に一人｜乗の軽々しさ、これを節倹ゆえと思うは非なり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今この民子も玉の輿に乗り損ねた一人で、彼女の放浪生活もそれから始まったわけだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "素袍でも着た徒が玉の輿持つて、へい、お迎、と下座するのを作らつせえ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は氏なくして玉の輿だから、どんな身分の人に姉さんといわれないとも限らぬが、そりゃ男の方から心を取って惚れさせようとか、気に入られようとかして、後じゃあ玩弄にするためだ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体いつもこの邸の門前には、馬車か、俥か、当世の玉の輿の着いていないことはない。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "月に三度あるいは二度、十四から通うて二十の今まで、いわゆる玉の輿がこの門に在ることは、あえて珍しくはないのであったが、かくまで道を塞いで、縦に横附けになっていたのは、はじめて。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は乗りたや玉の輿で、いずれ、お手車｜処は確に見える。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "みりゃ、どこへ突き出したって玉の輿に乗られるご器量じゃござんせんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉の輿に乗ろうと思えば、いくらでも乗られるそのご器量で、この大仕組みの茶番をするにゃ、何か思いもよらねえいわくがあるだろうとにらみましたが、違いますかね」「…………」「もじもじなさる年ごろでもなさそうじゃござんせんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、せいぜいお客をたいせつに勤め果たして、はようそなたも玉の輿にお乗りなせえよ」　あっさりいうとすうと立ち上がって、おどろきあきれている揚げ屋の者に、ちゃらりと小判を投げ与えておくと、表へ出るや、伝六にもう鋭い声をかけました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前なんぞ年が若いから、もしね、人並みの顔や姿でとんだ自惚れでも持って、あの、口なくして玉の輿なんて草双紙にでもあるようなことを考えてるなら、それこそ大間違い！",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは、うち見たいに貧乏でないし、しまいには玉の輿にさえ乗れるかも知れないんだよ」　私は母と離れて余所の家にやられることが寂しかった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は無論「玉の輿」って何だか知らなかった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程女は氏なくして玉の輿という、生来の美しさ、優やかさ、艶やかさ、それらがやがて地位なり、財産というものなのだ。",
              "citation": {
                "source": "頸飾り",
                "author": "モウパンサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "満がこの村より出でて文学士というエライ者になりたるさえ村中｜一統の誉れなるに我身そのエライ人と縁組せんこそこの上もなき誉れぞと玉の輿に乗る心持「伯父さん、満さんはいつ帰るとも言って来ねいのう」と心持にそぐわぬ物の言いよう。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでひとつ、世話のしついでだから、そのシヤキシヤキのお嬢さんを、今のうちに、手早く、玉の輿へ乗つけちまはうといふ相談だが、聴いてくれるかね？",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寿　　玉の輿……？",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寿　　玉の輿かと思つたら、それぢや革の輿か。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この外に、或は海外雄飛の夢となり、発明発見の夢となり、或は弱者救済の夢となり、武功抜群の夢となり、最も卑俗なものに、玉の輿に乗る夢があり、一攫千金の夢があります。",
              "citation": {
                "source": "青年の夢と憂欝",
                "author": "――力としての文化　第五話",
                "note": "青空文庫"
              }
            },
            {
              "text": "卑俗な一攫千金の夢や、玉の輿に乗る夢などを追ふよりも、むしろますます、かゝる非凡人の努力の生ひ立ちに学ぶ方が、どんなにいゝかわかりません。",
              "citation": {
                "source": "青年の夢と憂欝",
                "author": "――力としての文化　第五話",
                "note": "青空文庫"
              }
            },
            {
              "text": "女氏無くして玉の輿、立身出世しようもしれぬ。",
              "citation": {
                "source": "村井長庵記名の傘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、お屋敷奉公の口があつても、今まで話に乘らなかつたのだが、今度お辰と同年で、幼い時分には一番に仲のいゝ遊び友達であつたおよねが、東京で玉の輿に乘りかけてゐるといふ噂を耳に入れてからは、いろ／＼な迷ひが起つて、頭の中が掻亂されだした。",
              "citation": {
                "source": "玉の輿",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "おんな氏なくして玉の輿に乗るたあ、そこんところをいったもんだろうじゃあねえか。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "京の白拍子たちは、玉の輿にのった同性の幸福を羨やんだり、ねたんだり、中には、せめてその幸せにあやかりたいものと、妓王の妓をとって、妓一、妓二などと名前を変える者まで出るほどの評判であった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸越百貨店のエレベーター・ガールをしているうちに、夕陽新聞の幸田節三に見染められ、一昨年の冬からここに囲われる事になったが、玉の輿とは名ばかりで、一カ月の手当はちょうど判任官級。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂氏なくして玉の輿に乗った人で、日本橋辺の旧い薬種屋の娘で女医学校を卒業し就職を求めにある医学博士を訪問している時、偶然そこへ乗合わせていた先代侯爵が見染めて、親類中の大反対を押し切って妻に迎えたんだそうだ。",
              "citation": {
                "source": "魂の喘ぎ",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を變へ品を換へて、口説きもし、人を頼んで縁談を持込みもしたやうだが、お通さんがあのきりやうで、玉の輿に乘る氣だつたか、見向きもしなかつたといふよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "恋をせぬ女",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
