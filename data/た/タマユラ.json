        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雪をおとして立つ鳥に、　　　妻がけはひのしるければ、仄かに笑まふたまゆらを、　　松は畳めり風のそら。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "連れて翔けこしむらすゞめ、　　たまゆらりうと羽はりて、沈むや宙をたちまちに、　　　　りうと羽はり去りにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草のただよひ湿るたまゆら、辻なる※の絵硝子あがりぬ――ひびく舗石。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "どとと射つ我か、彼か、このたまゆら、勝つ者の正しき狙ひ神のみぞ知ろしめすらむ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "白雪のふれば幽かに、たまゆらは澄みてありけど、白雪の消ぬるたまゆら、仄かなるまたも消にけり。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "白雪のふれば幽かに、たまゆらは澄みてありけど、白雪の消ぬるたまゆら、ほのかなるまたも消にけり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "※りゆく日のあゆみたまゆらに明ると見つつ、過ぎし日のやるせなき思ひ出はまた※りゆく。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "美は、飛んでいく鳥が、目をかすめるほど、たまゆらを閃くものであるというのはそれである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて樹庵次郎蔵は、約一年間、フランシス・カルコばりの憂愁とチャアリイ・チャップリンばりの諧謔を売りものにわが国のジャアナリズムに君臨していたが、天成の我儘な放浪癖は窮屈な文壇にも馴染まず、一時の名声も陽炎のようにたまゆらにして消え去って行った。",
              "citation": {
                "source": "放浪作家の冒険",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうたまゆらの悸乎としたものは再び彼を捉えて、面をくもらせるほどであった。",
              "citation": {
                "source": "津の国人",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "わらべとをとめよりそひぬただたまゆらの火をかこみ、うれしくふたり手をとりぬかひなきことをただ夢み、入日のなかに立つけぶりありやなしやとただほのか、海べの恋のはかなさはこぼれ松葉の火なりけむ。",
              "citation": {
                "source": "面",
                "author": "富田常雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのたまゆらぐ一瞬のありさまが、こまかい部分まで鮮やかに思いだされる。",
              "citation": {
                "source": "おさん",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまゆらの我が天国　延喜十八年の晩春の一日。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
