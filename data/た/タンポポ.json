        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蒲公英の忘れ花あり路の霜　小景小情。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽春の日に、蒲公英の咲く長堤を逍遥するのは、蕪村の最も好んだリリシズムであるが、しかも都会の旗亭につとめて、春情学び得たる浪花風流の少女と道連れになり、喃々戯語を交して春光の下を歩いた記憶は、蕪村にとって永く忘れられないイメージだったろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春風馬堤曲に歌われた藪入りの少女は、こうした蕪村の詩情において、蒲公英の咲く野景と共に、永く残ったイメージの恋人であったろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄日は弱く雲を越さず、畔に咲いた黄蒲公英、咲交る豆の花の、緋、紫にも、ぽつりとも黒い影が見えぬ。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "△犬ころ草がやたらにはびこる、その穂花が犬ころのやうな感じで好きな草だ、其中庵の三雑草として、冬から春はぺん／＼草、春から夏は犬ころ草、秋はお彼岸花をあげなければなるまい、そのほかに、草苺、青萱、車前草、蒲公英。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには金子の牧場があり、牛の乳を搾っていたが、銀子はよくそこで蒲公英や菫を摘んだものだが、ブリキの乳搾りからそっと乳を偸んで呑み、空の時は牛の乳からじかに口呑みに呑んだりもした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "二子山附近われの悔恨は酢えたりさびしく蒲公英の莖を噛まんや。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま日は構外の野景に高く農夫らの鋤に蒲公英の莖は刈られ倒されたり。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつては蒲公英の莖を噛みながら、ひとり物思ひに耽つて徘徊した野川の畔に、今も尚白い菫が咲くだらうか。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏はまた蒲公英少しと、蕗の晩れ出の芽とを採ってくれた。",
              "citation": {
                "source": "野道",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "社會が一賤人一兇人を其一賤人一兇人なるの故を以て冷視したならば、疾病は必らず其處より發芽して、そして蒲公英の種子の如く風に乘じて飛散傳播するで有らう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "土手には田芹、蕗が滿ちて、蒲公英はまだ盛りに、目に幻のあの白い小さな車が自動車の輪に競つて飛んだ。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "優雅な蒲公英や可憐な赤まま草を、罌粟や撫子と優劣をつけたろう。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このごろこんな花が」「蒲公英ですか」と手に取る。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇の中で私に慘殺された無數の思ひつき（それらは、高く風に飛ぶ無數の蒲公英の種子のやうに、闇の中に舞ひ散つて、再び歸つて來ない）の中には、さうした類のものだつて多少は交じつてゐたらうと考へるのは、自惚に過ぎるだらうか？",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲公英の咲く川堤に並んで腰を打ちかけ、お宮の背後から揚る雲雀の声を聞きながら、銀之丞が腰の瓢と盃を取出せば、千六は恥かしながら背負うて来た風呂敷包みの割籠を開いて、焼いた干鰯を抓み出す。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲公英（タンポポ）は、本邦で朝開き午以後萎むといふが、歐洲では、毎朝五時に開き午後八時に閉るから牧童の時計とし、又、晴雨計たり。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "土手には田芹、蕗が満ちて、蒲公英はまだ盛りに、目に幻のあの白い小さな車が自動車の輪に競って飛んだ。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人は蒲公英のそれのやうに堅固な、軽い、巧緻で安全なパラシユート即ち飛行用器を何時、造るに成功するであらうか？",
              "citation": {
                "source": "卓上演説",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の枯芝の間にどうしたものか氣まぐれな蒲公英の黄色な頭がぽつ／＼と見える。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると土手は靜かで暖かなことがあるので、遂騙されて蒲公英がまだ遠い春を遲緩しげに首を出して見ては、また寒く成つたのに驚いて蹙まつたやうな姿である。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "菫、蒲公英、桜草、そこには何でも咲てるよ。",
              "citation": {
                "source": "駒鳥の胸",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大分熱は下つて來た、七度の赤い線をまん中にして、青い鉛筆の跡が、ちようど蒲公英の葉の線のやうに延びて行く。",
              "citation": {
                "source": "輝ける朝",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "南町の私の家を差覗く人は、薊や蒲公英の生えた舊い土藏づくりの朽ちかゝつた屋根の下に、澁い店格子を透いて、銘酒を滿たした五つの朱塗の樽と、同じ色の桝のいくつかに目を留めるであらう。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆく春くれゆく春のかなしさは白髪頭の蒲公英のむく毛がついついとんでゆく風がふくたびとんでゆき若い身そらで禿頭。",
              "citation": {
                "source": "どんたく",
                "author": "絵入り小唄集",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがていろんな色がごっちゃになって、こんがらがってしまう、蒲公英がちゃらちゃらと鳴ったり、橇の鈴や菫が雪のなかで花を開いたり。",
              "citation": {
                "source": "少年・春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "野はだんだん暖かくなって、菜の花が咲き、菫が咲き、蒲公英が咲き、桃の花が咲き、桜が咲いた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "たんぽぽの花を取ったり、茅花を抜いたり、又桑を摘みに山へつれられて行ってはシドミの花を分けて根についてある実を探したり、夢の様に面白かったことは、何十年という月日を過ぎても記憶に存している。",
              "citation": {
                "source": "井戸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの利根川のほとりで土筆やたんぽぽ又は匂ひ高い叙情小曲なぞをかいた此れが紅顔の彼の詩であらうか。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は却ってたんぽぽの毛のほうを好きだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
