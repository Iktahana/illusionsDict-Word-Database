        "examples": {
          "standard": [
            {
              "text": "台湾鹿はかつて乱獲により絶滅寸前まで追い込まれたが、保護活動によって個体数が回復した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "国立公園内の広い敷地で、野生に近い状態で群れをなして生活する台湾鹿を観察した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "台湾鹿の体にある白い斑点は、木漏れ日の差す森の中では完璧な保護色として機能する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "下に石を敷き、上に日よけを張り、白昼なお薄暮のごとくなる等は、台湾鹿港の市街に同じ。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
