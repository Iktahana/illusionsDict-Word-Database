[
  {
    "uuid": "79ea5d2d-31eb-592b-9a2e-2b12be551cfe",
    "entry": "他事",
    "reading": {
      "primary": "たじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
