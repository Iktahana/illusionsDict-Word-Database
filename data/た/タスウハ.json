    "definitions": [
      {
        "index": 1,
        "gloss": "majority group (party, faction)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
