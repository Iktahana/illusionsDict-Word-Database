[
  {
    "uuid": "ea8949f0-01c7-5d2c-9144-f1999d48ce74",
    "entry": "垂らす",
    "reading": {
      "primary": "たらす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
