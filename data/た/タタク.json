    "definitions": [
      {
        "index": 1,
        "gloss": "to strike",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女給達は、今来たばかりの常連らしいひどく冗談口を叩く男のまはりにみんな行つてしまつた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さう早く出るもんか」「だがね、今日はもう何も云つては駄目ですよ、今急病人があつてお父様は気が立つてるからね」　その時、俄然台所の方から、牛肉か何かを叩く音がして来ると、そゝくさと蒼い顔の妻君は長男の部屋をも立ち去つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生大きい口を叩く癖に。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡兎はやつて来て扉を叩く。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから夜しめ出しをくった時入口の戸をコツコツ叩く猫もある。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関の扉をはげしく叩く音――この降るのに誰がまあ、」と思いながら扉を開くと、どやどやと三人ばかり入って来たのは青年、壮年、老年を混ぜて三人の労働者達でした。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "木にとりつくと弾ね返ってうしろのものを叩くというのだろうか。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "音を発しようとすれば、その中のどれかを叩くより仕方がない。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とか言つては、「どうだね」と言つて僕の腰を叩く。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一二三で鉢巻をして手を叩く遊戯。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間でパチパチ手を叩く奴がある。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉「出掛けよう」と手を叩く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次がヨーイ・ドンと手を叩くと、　二人別々の道から走り出す。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツカツカと乞食の傍へ寄り「これこれ」と肩を叩く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夢かな‥‥と思ふと、木の空洞を叩くやうな兵士達の鈍い靴音が耳に著いた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　観音経を唱えていた神経衰弱の伍長が、ふと、湯呑をチンチン叩くのをやめた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太鼓演習、──兵卒を二人向いあって立たせ、お互いに両手で相手の頬を、丁度太鼓を叩くように殴り合いをさせること。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "外から頼むように扉を叩く。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、稲垣、大野、川本、坂田、みなそれぞれ二三分間おくれて、別の扉を叩くのであった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、やはり夜明けごろに窓外の池の汀で板片を叩くような音がする。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またそのきゅんきゅんと叩く音が河向いの塀に反響したような気がするくらい鮮明な印象が残っている。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろは雨つづきで草履屋の商売も休みも同様であるばかりか、亭主の藤吉は宵から出ているので、女房のお徳は店を早く閉めて、奥の長火鉢の前で浴衣の縫い直しをしている時、表の戸をそっと叩く音がきこえたので、お徳は針の手をやめて顔をあげた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "常の時ならばそれが当然であるが、今夜こんなに寝鎮まっているのをお徳はすこし不思議に思いながら、ともかくもそっと戸を叩くと、内では容易に返事がなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦れて幾たびか強く叩くと、小僧の寅次が寝ぼけ眼をこすりながら起きて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　馬は、雪の上を追いまわされて疲れ、これ以上鞭をあてるのが、イワンには、自分の身を叩くように痛く感じられた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰れか、外から門を叩く音がした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと表の河岸でカーンカーンと岩を叩く音がした。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音が俺の心臟を叩くのだ。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もやい綱が船の寝息のようにきしり、それを眠りつかせるように、静かな波のぽちゃぽちゃと舷側を叩く音が、暗い水面にきこえていた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこからか材木を叩く音が――もともと高くもない音らしかったが、町の空へ「カーン、カーン」と反響した。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
