        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こういう時代において、それ自身だけに任せておくととかく立ち枯れになりやすい理論に生命の水をそそぎ、行き詰まりになりやすい抽象に新しい疎通孔をあけるには、やはりいろいろの実験が望ましい。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道ばたにはところどころに赤く立ち枯れになった黍の畑が、暗い森を背景にして、さまざまの手ごろな小品を見せていた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち枯れになった白樺の根本へ女の体は仰向けに寝かされた。",
              "citation": {
                "source": "警察署長",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火を放って焼いたあとらしく、二抱えも三抱えもある大きな白樺の幹が大方は半ば燃えたままに立ち枯れていた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが京ばかりでなく、近郷近国いずれもこの大旱に虐げられて、田畑にあるほどの青い物はみな立ち枯れになってしまった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡瓜は、親指に少し太いほどの實で、萎んだ花の名殘をまだその先につけながら、青枯病に罹つて立ち枯れてゐるものもあつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに隣る、小さく幾つにも不規則に仕切られた、一段歩ほどの田圃は、稻を刈つたあとそのままの姿で、田のおもては霜解けに濡れて、黒い切株のまはりや、株と株との間には、細長く伸びたままに寒さに立ち枯れた枯草が、わびしく風に吹かれてゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには燒け殘つた樹木がまだそのまゝにあつて、芽も吹かずに、多くは立ち枯れとなつてゐるのも物すごく思はれた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には白く骨の如くになって立ち枯れしたものもある。",
              "citation": {
                "source": "木曾御嶽の両面",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には白く骨の如くになつて立ち枯れしたものもある。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで田植ができる雨を聴きつゝ寝る・いたゞきは立ち枯れの一樹・蠅がうるさい独を守る・ひとりのあつい茶をすゝる・花いばら、こゝの土とならうよ　六月廿二日　同前。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "患者は一進一退の後、こうして植物の如く生きながら次第に、頭の先から立ち枯れてゆくのだ。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "畝も消えて平べったくなった畑には、夏から抜き忘れたままの黍が数本立ち枯れて残っていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "生い茂る立ち枯れの萱をごそつかせた後ろ姿の眼につくは、目暗縞の黒きが中を斜に抜けた赤襷である。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち枯れの秋草が気紛の時節を誤って、暖たかき陽炎のちらつくなかに甦えるのは情けない。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一家の主人の運命が大きく変転する場合には、その庭の木が、時ならぬ花を咲かせたり、俄に立ち枯れたりすることが、往々ある。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち枯れする樹木と同じだ。",
              "citation": {
                "source": "ものの影",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸び茂るもの、立ち枯れるもの、他物に絡みつくもの、みな自然にそうなっていた。",
              "citation": {
                "source": "山吹の花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち枯れた雑草の中に私は飛びこみ、そこに屈みこんで泣いた。",
              "citation": {
                "source": "紫の壜",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "色褪せた壁の朱の、立ち枯れた並木の細い枝間に、寂然と光ある如くである。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジッと見て、石松の相に立ち枯れる若木の相があって身を食い枯らす悪虫が這っていると見てとったから、金を貸してやらなかった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、岩屋の中に矗立した、立ち枯れの木に過ぎなかつた。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の草の立ち枯れたのと、今年生えて稍莖を立て初めたのとがまじりあつて、屋敷地から喰み出し、道の上までも延びて居る。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、岩屋の中に矗立した立ち枯れの木に過ぎなかつた。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
