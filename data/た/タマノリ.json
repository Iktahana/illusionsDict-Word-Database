        "examples": {
          "standard": [
            {
              "text": "サーカスのピエロが、大きな鞠の上で絶妙なバランスを保ちながら球乗りを披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アシカが鼻先にボールを乗せたまま球乗りをする姿に、観客から拍手が沸いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "球乗りを練習しすぎて、足の裏の皮がすっかり厚くなってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "又、おばあさんとだけやらされるときもあったが、そんなときには私はいつも球乗りや花屋敷などへ彼女を引っぱって行った。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "晝としよりのゐねむりゐねむりはぎんのはりをのむたまのりむすめふゆのひのみもだえそのはなさきにぶらさがりたるあをぞら。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            }
          ]
        }
