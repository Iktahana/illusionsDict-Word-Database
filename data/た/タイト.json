    "definitions": [
      {
        "index": 1,
        "gloss": "tight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "映画のタイトルに相当する詞書の長短の分布もいろいろ変化があって面白く、この点も研究に値いする。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイレントではタイトルを書く時の苦しみ、トーキーとなって台詞の書けぬ苦しさ。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（移動）　（ヘッド・タイトルを道の移動にダブらしたらどうかと思います）（速やかにＦ・Ｏ）　＝（Ｆ・Ｉ）松平帯刀の邸　一人の旗本、斬られてダダーとのけ反った。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次、Ｔ「昨夜、芝居が　果ててから　帰りを急ぐ仲蔵　の駕籠を……」（此のタイトル次の画面にＯ・Ｌして）　＝深夜の街　帰りを急ぐ駕籠一丁。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえって、下手な活弁を労したり、不つりあいな日本文字のサイドタイトルなどをつけられるよりも、ただそのままにわからぬ言葉を聞くほうがはるかにパリの真実、日本人の見たパリの真実がよくわかるのではないか。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はっはっは、ジッコさんといふのは磁鉄鉱だね、もうわかったさ、喧嘩の相手はバイオタイトだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はっはっは、ジッコさんというのは磁鉄鉱だね、もうわかったさ、喧嘩の相手はバイオタイトだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "A life for a life というタイトルが出たから映画師が殺されるかと思ったら、そうでなくてやはりライオンが一匹やられるのである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画における字幕サブタイトルに相当するものすら、ある絵巻物には書き込まれてあるのも興味あることである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、時々そんな思い切った出鱈目な芝居をしては『敵兵の暴虐』とか何とかタイトルをつけて、しこたま興行価値を上げようとたくらんだんだ」「つまんねえなあ」と、そこで娘は口を尖らすと、紅棒を出してその唇を染めながら、ハンドバッグの鏡を横目で睨みました。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗栖はドイツ物のタイトルを読むのが敏く、詳しい説明をして聞かせるのだったが、映画に限らず、この若いドクトルの知識と趣味は驚くほど広く、油絵も描けば小説も作るのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "デモ　マダ　オメメヲ　トヂテ　ネネシテ　ヰルノデスヨ」　花タチハ　ウマノ　アカンボヲ　ミタイト　オモヒマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "コノ　ヲトコノ　ヒトハ、ナニカ　ヒトノ　ビツクリスルヤウナ　コトヲ　シテ　エラク　ナリタイト　カンガヘテ　ヲリマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンザシヲ　ジブンノ　モノニ　シタイト　オモヒマシタ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "復一自身に取っては自分に一ばん欠乏もし、また軽蔑もしている、そういうタイトルを得たことに、妙なちぐはぐな気持がした。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはわたしのタイトルを五年期限で賃貸することを申出た。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、これより数段、巧みに言い表わされたる、これら諸感情に就いての絶叫もしくは、嗄れた呟きを、阪東妻三郎の映画のタイトルの中に、いくつでも、いくつでも、発見できるつもりで居る。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は映画のタイトルを読むような気忙しさで、この三つのうちから、最も清楚な感じの、最も高価な指環を選んだ。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしはこの前われわれと一緒に来たアンガス・タイト老人を連れて来ればよかった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "電子本『銀河ヒッチハイカーズ・ガイド』　タイトルとなっている『銀河ヒッチハイカーズ・ガイド』とは、この作品で重要な役割を演じる、ある〈本〉の名前です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めてのタイトルとして『市民ケーン』と『キングコング』を出すにあたって、ボイジャーは、標準、基準を意味するクライテリオンというシリーズ名を掲げます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後のタイトルにも、監督自身や脚本家、評論家などによるコメントや、場面のイメージを絵にしたストーリーボード、撮影台本など、さまざまな資料が組み込まれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のつけていたタイトルは「信念の統合処理としてのＤＴＰ」です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「信念の統合処理としてのＤＴＰ」というタイトルに、私はそんな気持ちを込めていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "垂れこめた厚く暗い雲のどこかに切れ目を見つけて、空の青さを望みたいという願いをこめたタイトルです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイトルは『青空のリスタート』だと、オレは唐突に思った。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パイオニアが出したレーザーディスク用タイトルの制作要員募集に応じて採用となり、東映から移ったのは、一九八一（昭和五十六）年の七月です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから大きく普及するはずのヴィデオデッキを飛び越えて、あえてレーザーディスク一本で勝負に出たパイオニアは、タイトルの充実が社運をかけた挑戦の鍵を握ると考えていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩野さんと彼は後に、タイトルの制作子会社としてパイオニアから独立したレーザーディスク株式会社とボイジャー共同のプロジェクトを起こしました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
