        "examples": {
          "standard": [
            {
              "text": "事業に失敗して多額の借金を抱えたが、不撓不屈の精神で数年かけて生活を立て直した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "試合開始直後に失点を喫したものの、後半からは冷静さを取り戻してチームのリズムが立て直った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大雨による被害を受けた農園だが、ボランティアの助けもあって徐々に元の姿へと立て直りつつある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてあなたが自分で云ってたように、いつかはあなたの生活が立て直るに違いないと、ほんとに信じていたんですわ。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事さえあれば、朝から晩まで馬車馬のように追い立てられさえすれば、それで僕の生活が立て直るんだろうよ。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんど変なことになったら、君の生活はもう二度と立て直ることはないだろう、という気が僕にはする。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に、自分の生活が暗闇になって、もう何にも拠り所がなく、再び立て直ることがない、ということを彼は感じた。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は女のひとの中にもひどいすさみがあり、それを癒し立て直るのは実に大事業です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
