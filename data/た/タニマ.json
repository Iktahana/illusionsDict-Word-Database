        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ああ金性の肉のおとろへ、みやま瀧ながれ、青らみいよいよおとろふ、いのれば銀の血となり、肉やぶれ谷間をはしる。",
              "citation": {
                "source": "偏狂",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この声の行くところ、水と、石と、樹と、調子を合せて、谷間の客を揺り起す。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月の炎天も、この谷間までは迫って来ないと見えて、白剥山を一つ超えて、東俣の谷へ来ると、未だ若葉、青葉の新緑が、生々しかったが、ここまで溯ると、濶葉、細葉は、透明を含んだ、黄の克った、明るみのある嫩い緑で、霧の雫にプラチナのように光った裏葉を翻えしている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁を思わせるうす紅色で、雨気を含んだ虚空に、浸み透るように、暈して描かれた自分たちの印画は、この大なる空間を跨いで、谷間へと消え落ちた。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "晝飯をすませて、そろ／＼歸る支度にかゝる頃から空が次第に明るくなつて來て、やがて雲が破れ、東の谷間に虹の橋が懸つた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もどの画家でも相当な人ならばある程度まではそういう事を考えぬ人は無いかもしれないが、しかしそう考えるばかりで何時までも同じ谷間の径路を往復しながら対岸の自然を眺めているのでは到底駄目であろう。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その玩具のような可愛い汽車は、落葉樹の林や、谷間の見える山峡やを、うねうねと曲りながら走って行った。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間のように窪んだ所には、汚れた布団を敷いたように、雪が消え残っている。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間の泉から、苦力が水を荷って病院まで登って来る道々、こぼした水が凍って、それが毎日のことなので、道の両側に氷がうず高く、山脈のように連っていた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、二人は、鉄条網をくゞって谷間に下った。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間から今度は次の山へ登った。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の頂上を暫らく行くと、又、次の谷間へ下るようになっていた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間には沼があった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間には沼に注ぐ河があって、それが凍っているようだった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……間もなく二ツの銃声が谷間に轟き渡った。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間を吹きおろしてくる嵐は寒かった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外には、谷間の嵐が団栗の落葉を吹き散らしていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間の地は痩せて、一倍の苦労をしながら、収穫はどればもなかった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　谷間の白樺のかげに、穴が掘られてあった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘の病院からは、谷間の白樺と、小山になった穴のあとが眺められた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "線路は谷間にかゝり、やがてそこを通りぬけて、また曠野へ出た。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間には、稲の切株が黒くなって、そのまゝ残っていた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間から丘にかけて一帯に耕地が固くなって荒れるがまゝにされている中に、その一隅の麦畑は青々と自分の出来ばえを誇っているようだった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の崖の上から丘の谷間の様子を見ていた留吉が、「おい、皆目、追い出す者はないが、……宇一の奴、ほんとに裏切りやがったぞ！",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘から谷間にかけて、四五匹の豚が、急に広々とした野良へ出たのを喜んで、土や、雑草を蹴って跳ねまわっているばかりだ。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その時には、丘にも谷間にも豚群が呻き騒いで、剛い鼻さきで土を掘りかえしたり、無鉄砲に馳せまわったりしていた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」谷間ばかりを見下していた健二がきいた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間の泉から湧き出る水は、その周囲に凍てついて、氷の岩が出来ていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供達は、皆な、一時に立止まって、谷間の炊事場を見下した。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵舎の樋から落ちた水は、枯れた芝生の間をくぐって、谷間へ小さな急流をなして流れていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
