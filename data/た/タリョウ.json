[
  {
    "uuid": "207a1928-d438-5288-85bb-a9131f256954",
    "entry": "他領",
    "reading": {
      "primary": "たりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
