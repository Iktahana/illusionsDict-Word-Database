[
  {
    "uuid": "44593c62-3950-5b39-9211-3fde2cd26795",
    "entry": "探偵",
    "reading": {
      "primary": "たんてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
