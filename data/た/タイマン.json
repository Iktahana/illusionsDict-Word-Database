    "definitions": [
      {
        "index": 1,
        "gloss": "negligence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　命令に対して、怠慢をつぐなうため、早速銃をとって立ちあがるかと思いの外、彼の部下の顔には、××な、苦々しい感情があり／＼と現れた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "九天たかく存します神は、来る日も来る日も昼寝のみ、まったくの怠慢。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "官衙や商社における組織や行政の不備や吏員の怠慢に対しても犀利な批評と痛切な助言を加えたい。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる保証を有ちながら、私が所有地解放を断行しなかったのは、私としてはなはだ怠慢であったので、諸君に対しことさら面目ない次第です。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "讀書に怠慢な私はかゝる比較をする智識を持つてゐない。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年目の年が明けて、梅もぽつ／＼咲き初めた頃、添田家縁者一統の総代が、泰松寺へ出頭して、宗右衛門の家事不取締りから、使用人の怠慢、家業｜破綻の条々を縷述し、その上、娘お小夜の急病を報じて宗右衛門の自宅へ復帰することを老師に願ひ出でた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "怠慢の二字に尽きる。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "相州さまも、どういふわけか、その頃の将軍家の御政務御怠慢をば見て見ぬ振りをなさつて、いや、それどころか、将軍家とお顔をお合せになるのを努めて避けていらつしやつたやうでございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、かゝる時は碁の方にも意外の見落しや、積り損ひが出來て、そして結局は負になつて仕舞つたり、商業の方は寸時の怠慢より飛んでも無い損耗を仕たりするもので、いづれにしても、餘り好い結果を齎らさぬ勝のものである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、一たび神様となるや、その権威は絶対であって、片言隻句ことごとく神聖視されて、敗戦後各分野で権威や神聖への疑義が提出されているのに、文壇の権威は少しも疑われていないのは、何たる怠慢であろうか。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がこれを写し取ったのは、主として警察のひどい怠慢ぶりを君に示すためなんだ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下トッテン師匠は自殺行為としか思えない米ソフトウエア産業の怠慢と不健全とをさらに指摘する。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "追い抜くには至らぬまでも、次のランナーが追い付きかけてきた以上、これまでは許された怠慢と不健全は自殺行為となる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし標準が不誠実であるか怠慢であるかすれば、浮上するのは黒ビットの現実論である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをアップルコンピュータジャパンの怠慢と呼ぶべきか、はたまた先見の明と解すべきかは知らない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボースンは業務怠慢で下船命令を食ったから、一年間乗船を海事局の名によって停止されるのだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人間の無謀と怠慢とになりし沙漠はこれを恢復するにもっとも難いものであります。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌「文学界」などにしてから、多くの同人を擁しながら沈滞しがちなのは、時世の所為といふよりは、同人の怠慢であるといふより他なく、その他の文芸雑誌にしても、新作家のみ無選択に過ぎる登用が禍してゐるのではなからうか。",
              "citation": {
                "source": "浪曼的時評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一兵卒の怠慢もしばしば強敵の襲来を招く理屈であるから、全軍が注意しなければ堅守の効果は収め難い。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、このような時は碁の方でも意外な見落しや思い違いが出来て、そして結局は負になって仕舞ったり、商売の方は寸時の怠慢からとんでもない損失をしたりするもので、何れにしても余り良い結果をもたらさないものである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "濠州のジェイエリエ人伝うらく、大神ムーラムーラ創世に多く小さき黒蜥蜴を作り、諸の蜒を人間に遣わし、人死せざれと告げしめしに、このもの怠慢て途上の樹に昇り睡る。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "神また考え直して蜥蜴を人間に遣り人死すべしと告げしむると、直ぐ往ってそう言って去った跡へ蜒が怠慢て早く好報を齎さざりしを憤って、烟草を食わせ、身を諸色に変じ、悩死するを見て快と称う。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦令石橋を叩いて理窟を拈る頑固党が言の如く、文学者を以て放埓遊惰怠慢痴呆社会の穀潰し太平の寄生虫となすも、兎に角文学者が天下の最幸最福なる者たるに少しも差閊なし。",
              "citation": {
                "source": "為文学者経",
                "author": "三文字屋金平",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之、文学者を以て怠慢遊惰の張本となすおせツかいは偶／＼怠慢遊惰の却て神の天啓に協ふを知らざる白痴なり。",
              "citation": {
                "source": "為文学者経",
                "author": "三文字屋金平",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頃のお手柄にちと御慢心遊ばして、御怠慢とお見受け申しまする」といった。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "怠慢にもほどがあるわッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう聞くと、自分の怠慢がいよ／＼悔まれるような気がして、わたしはその返事をうけ取った翌日の朝、病気見舞をかねて大久保へ第二回の訪問を試みた。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「閣下、明後日にせまる火星ロケット艦の到着を今まで気がつかなかった天文部員の怠慢を、一つ大いに責めなくちゃならんと思いますわ」「そんなことは後でゆっくり考えることだ。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
