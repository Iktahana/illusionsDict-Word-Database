        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "棄値に売っても五十万の折紙、毎年の採掘高は幾十万円、利益配当の多いことはまず炭山にはほとんどまれで、その炭質の良いことは遠く三池の石炭にも増して、内外諸方へ軍艦用として売り込むものでも毎年およそ何十万｜噸、いや福の神はとんだところにおいでなされた。",
              "citation": {
                "source": "書記官",
                "author": "川上眉山",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの地勢ヴェルダンに似て居て石炭質の樹の生えない山の形とともに、自分につよい印象をのこした。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "常磐では指折の優秀炭質を誇っております。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "グライドの計画は破たんしつつあった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
