    "definitions": [
      {
        "index": 1,
        "gloss": "itinerant entertainer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やがて妾達旅芸人の一行は、ギリシヤ女の水泳する腕にも似たモナコの町に着きました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし歌劇とか現代劇とか、浪花節芝居とかいった旅芸人は、入れ替わり立ち替わり間断なくやって来て、小屋の空く時はほとんどなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と武士は猿を背負つた旅芸人に声をかけました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて組合の禿頭のトムソンが赤つちやけたる鹿爪らしき古外套ををかしがり、恐ろしかりし夏の日のこと、どくだみの臭き花のなかに「キ…ン…タ…マ…が…い…た…い」と白粉厚き皺づらに力なく啜り泣きつつ、終に斃れし旅芸人のかつぽれが臨終の道化姿ぞ目に浮ぶ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅芸人と駈落ちをして又戻って来る。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "な」　ボースンは発育不良な、旅芸人のジョーカー見たいな格好で、マストにとりつけてある梯子を上って行った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはその頃将監さんに仕込まれた咽喉でもって旅芸人を稼いでいたのだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旅芸人か、曲芸師……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし備前少将光政が、旅芸人の手品師が岡山の城下に来たのを召し出して手品を見た事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大歳駅附近には芝居の掛小屋があつた、山口駅では旅芸人の群を見た、彼等に幸福あれ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲走ったその声が、彼の脳天までぴんと響いた、作は主人の兄にあたるやくざ者と、どこのものともしれぬ旅芸人の女との間にできた子供であった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、宇野浩二が書いた小説に、菊富士ホテルの内庭で、わからない言葉で互によんだり、喋ったりしながら右往左往しているロシアの小人たちの旅芸人の一座を描いたものがあった。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上一切が灰燼になったら同気相求める人達と一緒に旅芸人の一団でも組織して、全国を巡業してまわるのも一興だなどと真実考えに耽ってもみたりした。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが外国の演芸界のことでもあれば、名ある唄女の一夕の出演にも、驚く金額ではないかも知れないが、貧乏な国の、しかも多く旅芸人を拾いあげて、安価興行をしなれて来ているものには、それこそ思いもかけぬ高びしゃであったのだろう、信州の興行人は彼女の見識に煙にまかれて手を引いてしまった。",
              "citation": {
                "source": "豊竹呂昇",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には旅芸人の仲間にはいつたり、時には何か臨時の仕事にやとはれたりして、そして大抵は一人で、リスに芸をさしたりバイオリンをひいたりしてお金をもらひ、あてもなく旅をしてゐました。",
              "citation": {
                "source": "エミリアンの旅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台や高座と関係なく、袖乞ひする旅芸人が持つて来たものであつた。",
              "citation": {
                "source": "地唄",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがよく覚えていたつもりの老人の顔も、年を経るにしたがって曖昧になり、その後に知った木賃宿の主人や、泊まり合わして心安くなった旅芸人の老人なぞの顔とごっちゃになり、まったく記憶の外に逃げ去って、今では思い出すことさえできなくなっている。",
              "citation": {
                "source": "抱茗荷の説",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日｜空身でなんの当てもなく町はずれに出てみると、そこの空地に夫婦者らしい旅芸人が人を集めて手品を見せていた。",
              "citation": {
                "source": "抱茗荷の説",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅芸人が商売道具を小さな車に乗せ身仕舞いにかかっても君子はなおそこを離れようとしなかった。",
              "citation": {
                "source": "抱茗荷の説",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして君子はついにこの旅芸人に連れられて旅から旅を流れ渡るようになった。",
              "citation": {
                "source": "抱茗荷の説",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅芸人は時候が暖かになってくると北に向かい、涼しくなってくると南に向かって旅をした。",
              "citation": {
                "source": "抱茗荷の説",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして君子は十年という長い間の旅芸人から足を洗うことができた。",
              "citation": {
                "source": "抱茗荷の説",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母が死んでから子守奉公、それから一日二日とあわただしい旅芸人、今日の日まで君子には人形の衣裳を脱がして見るほど落ち着いた気持ちの時がなかったのである。",
              "citation": {
                "source": "抱茗荷の説",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最古い旅芸人、門づけ芸者であると言ふ事は、語原から推して、誤りない想像と思ふ。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドサ廻りの旅芸人のような旅行はイヤ。",
              "citation": {
                "source": "文化祭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "中でも、いちばん心をひかれたのは、もう、七、八｜年も前になるが、五、六｜人連れの旅芸人が、ある日、急いでここの港から、船に乗って出立したときのことであります。",
              "citation": {
                "source": "海と少年",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原人なる細工の者が、農家に雇われて稲作を害する鳥を駆逐するの職に従事したところから鳥追いと呼ばれ、その鳥追いが門附けの旅芸人となって依然鳥追いの称を以て呼ばれた。",
              "citation": {
                "source": "間人考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
