    "definitions": [
      {
        "index": 1,
        "gloss": "dealt hand consisting of one 5-point card and six 1-point cards",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すなわち長短一味の太刀、三尺の剣はこの瞬間、九尺｜柄の槍と一変する。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後十余日を経て、再びその書生と婦人と余と三人相会して、大小長短一定せざるいろいろの竹を用い、いろいろの蓋を取りてこれを試みしに、みな好成績を得たり。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "その塵毛は大小長短一定せずして、色はたいてい白きを常とすれども、折々、赤き色または青き色のものも見出だすことあり。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後十余日を経て、再びその年少輩と婦人と余と数名相会して、大小、長短一定せざるいろいろの竹をとり、いろいろの蓋を用いてこれを試みしに、みなその成績を得たり。",
              "citation": {
                "source": "妖怪玄談",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
