[
  {
    "uuid": "4b4c719f-1a29-5f0b-9c34-871d05627092",
    "entry": "逞しくする",
    "reading": {
      "primary": "たくましくする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
        "動詞-他動詞"
