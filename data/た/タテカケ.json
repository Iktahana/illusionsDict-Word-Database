        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ジョバンニはその人の卓子の足もとから一つの小さな平たい函をとりだして向ふの電燈のたくさんついた、たてかけてある壁の隅の所へしゃがみ込むと小さなピンセットでまるで粟粒ぐらゐの活字を次から次と拾ひはじめました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い天鵞絨の頭巾をかぶったちひさな子が、毛布につつまれて窓の下の飴色の壁に上手にたてかけられ、まるで寢床に居るやうに、足をこっちにのばしてすやすやと睡ってゐます。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外には幾枚かのカンヴァスの枠に張ったのが壁にたてかけてあったのと、それから、何かしら食器類の、それも汚れたのが、そこらにころがっていたかと思うが、それもたしかではない。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはその人の卓子の足もとから一つの小さな平たい函をとりだして向うの電燈のたくさんついた、たてかけてある壁の隅の所へしゃがみ込むと小さなピンセットでまるで粟粒ぐらいの活字を次から次と拾いはじめました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはその人の卓子の足もとから一つの小さな平たい函をとりだして向こうの電燈のたくさんついた、たてかけてある壁の隅の所へしゃがみ込むと、小さなピンセットでまるで粟粒ぐらいの活字を次から次へと拾いはじめました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジヨバンニはその人の椅子の足もとから一つの小さな平たい箱をとりだして、向うの電燈のたくさんついたたてかけてある壁の隅の所へしやがみ込むと、小さなピンセツトでまるで粟粒ぐらゐの活字を次から次と拾ひはじめました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小十郎は鉄砲を木へたてかけて注意深くそばへ寄って来てこう言うのだった。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅客も杖をたてかけて、さしむかいに背を屈め、石を掻抱くようにして、手をついて実を視めたが、眦を返して近々と我を迎うる皓歯を見た。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子は夏、外したまゝで、残らず破れたなり煤けたなりで便所の傍にたてかけてある。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い一絃琴は仏蘭西わたりのピアノの傍の薄青い陰影のなかにたてかけて、おほかたは静かに眺め入るべきものである。",
              "citation": {
                "source": "桐の花とカステラ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふり返つてみると、くらやみの中にことさらに黒味を帯びた、ちやうど谷間の深淵のよどみをたてかけたやうな深みが、じつとみつめてゐると見とをしができるやうに思はれて、そしてまた壁のやうな不透明な幾つにも切断されて盛りあげられた影がふたりの背後にならんでゐた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る所では長沢から仕入れて来た四合壜を取り出し、路傍に洋傘をたてかけ、その蔭に坐つて啜り合つた。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "わがねむる家のそちこち音に澄みてこほろぎの鳴く夜となりにけりこほろぎのしとどに鳴ける真夜中に喰ふ梨の実のつゆは垂りつつ使ひ終へていまたてかけしまな板の雫垂りつつこほろぎの鳴く　こほろぎと同じく、飼つておくわけでもないに部屋のうちに来て鳴く虫に茶たて虫といふがゐる。",
              "citation": {
                "source": "秋草と虫の音",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、土の盛り上がりの上には粗末な白木の位牌がおいてあり、その前に誰がたててくれたのか水仙の花が二三輪たてかけてあった。",
              "citation": {
                "source": "私はかうして死んだ！",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋のある学者は霙の降る冬の日に蝙蝠傘をさして大学から帰る途々、家へ着いたなら、蝙蝠傘を壁にたてかけて置いて、自分は暖炉に当つて暖まらうと娯みに思つてゐるうち、宅へ辿り着く頃には、すつかり自分と蝙蝠傘とを取り違へ、傘を暖炉に暖ためながら、自分は夜ぴて壁に凭れてゐたといふことだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと気がつくと、すぐ側にたてかけた障子のなかから、微かな物音が伝はつて来ます。",
              "citation": {
                "source": "茶立虫",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "雄鳩の淋しげなのを見て、人が鏡を小屋の横にたてかけた。",
              "citation": {
                "source": "白い翼",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると人力車をたてかけてその上に袈裟衣をつけた僧形の人が一生懸命に何か云っている。",
              "citation": {
                "source": "夢の殺人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから弟の神は、藤の花の咲いた弓矢を少女の居間の戸の前にたてかけておきますと、少女が出がけにそれを見つけて、ふしぎに思いながら、きれいなものですから、つい手に持って出ようとしました。",
              "citation": {
                "source": "春山秋山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹であんだ干籠に、丸いおせんべの原形が干してあったのも、その傍にあたしの着物を張った張板がたてかけてあったのも、その廻りを飛んでいた黄色の蝶と、飛び去ってしまった。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "町の構成",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　黙っている老人連の中からまだ老婆だけは心外の意を露わに向けたてかけて来たが、好意を毒舌にして見せる手際も温く、矢代は、答えかねた窮地の底から、ひそかに門の前の車夫に援助を需む有様だった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪が深くなるにつれ、湖畔のぐるりは白いびょうぶをたてかけたように、樹木も家も深い雪に埋もれてしまう。",
              "citation": {
                "source": "美しい犬",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "×元村の組合員豊治の家まで行って見ると軒下に自転車がもう何台もたてかけてある。",
              "citation": {
                "source": "共同耕作",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも通り、ゆっくりした動作でステッキをビラの下っている壁の隅にたてかけ、ポケットから水色の薄い教科書を出しながら、「――なかなか御馳走ですナ」　笑って教壇がわりの大机の前へ行った。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "重い鉄蓋を、蜂矢はうまくつりあげて、横へたてかけた。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、床の間の隅にたてかけてある革の鞭を見ても、何の感慨も起らなかった。",
              "citation": {
                "source": "立枯れ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は船室のドアに、内がわから机やベッドや本だなをたてかけて、万一ドアがやぶられても防戦ができるようにした。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「クーパー事務長、これだけしておけば、もう大丈夫です」　と、ドアのところへたてかけたベッドや重い長いすなどをしめして、自信ありげに目をかがやかした。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
