[
  {
    "uuid": "0db63cd9-1131-524c-8949-0e82a23d5823",
    "entry": "滞英",
    "reading": {
      "primary": "たいえい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
