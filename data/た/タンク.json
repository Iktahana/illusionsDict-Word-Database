    "definitions": [
      {
        "index": 1,
        "gloss": "tank (of fluid)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "例へばタンクを、軍用自働車と言つたり、装甲自働車と訳したりする。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "碁盤の目ほどに窓の多いデパートメント、タンクを伏せたように重っ苦しい大屋根、長方形の箱を、手品師の手際で累積したようなアメリカ式鉄筋コンクリートの高層築造物は、垂直の圧力を通行人の頭上に加えて虚空の「通せん坊」をしあっている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、飲料水タンクを修理することだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故かって、タンクと海水との間の、彼女のボットムは、動脈硬化症にかかった患者のように、海水が飲料水の部分に浸透して来るからだった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから長い間には、タンクの水は些も減らない代りに、塩水を飲まねばならなくなるんだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場の燻ぶつた車庫や、ペンキのはげかゝつたタンクや轉轍臺のやうなもの迄も、小春の日光と空氣の魔術にかゝつて名状の出來ない美しい色の配合を見せて居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の照明は私設ガスタンクのガスによって、倹約と保守的な気分と面倒がりとのために電燈設備をしないでしまった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海翻車の歩行は何となくタンクを想い出させる。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "方法はやはり水溜りに石油を撒き、井戸やタンクには金網を蔽うのである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは砂町一丁目と上大島町の瓦斯タンクを堡塁のように清砂通りに沿う一線と八幡通りに沿う一線に主力を集め、おのおの三方へ不規則に蔓延している。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄条網は、工場の周囲から、遠くの街路に添い、街路を横切ってのびて行く、Ｓ銀行には、丸い、瓦斯タンクのような歩哨の土嚢塁が築かれた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い屋根の上に、巨大な貯水タンクがのっかっている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に、そこから僅かばかり隔った亜細亜タンクの附近にも六名の死体がかくされてあった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈でも、飛行機でも、潜水艇でもまたタンク戦車のごときものすら欧州大戦よりずっと以前に小説家によって予想されている。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場のくすぶった車庫や、ペンキのはげかかったタンクや転轍台のようなものまでも、小春の日光と空気の魔術にかかって名状のできない美しい色の配合を見せていた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水泳タンクでも魚猿（尾のない、水泳を好む猿）の真似して游ぎ廻るのがありました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）バナナン大将の行進歌合唱「いさおかがやく　バナナン軍マルトン原に　　たむろせど荒さびし山河の　すべもなく饑餓の　陣営　　日にわたり夜をもこむれば　つわもののダムダム弾や　　葡萄弾毒瓦斯タンクは　恐れねどうえとつかれを　いかにせん。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "東練兵場へ出かけて模擬戦を観る、鉄条網、毒瓦斯、煙幕、タンク、機関銃、……労れて、少し憂欝になつて戻る。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、たった一度、我軍のタンクを草むらの中から覗っている野砲があったので、一人の勇士がタンクを乗り捨てて手擲弾でその野砲を退治してみたところが、それもやっぱり敵ではなくて我々と同じようなヘルメットをかぶった味方の兵士だった。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では自動車が荷物を載せて、私の過去の記憶の上を、勇ましくタンクのやうに驀進して行く。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、参謀本部が、誰と誰を支那兵にし、誰を友軍の斥候にし、誰をタンクにするかといふやうなことをきめてゐたときのことだつた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "マークの付いている石油タンクが乱れた列をなして、その後にじりじりと展転して行く。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イギリス海軍用のタンク」　水が見える。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の兵士達はタンクのように固り乍ら行き過ぎようとして居た。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "左の崖はなほ肉桂の生垣の内側に石の門が倒れ、水道のセメントのタンクが酷たらしく壊れた儘で未だ手もつけてない。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三軒茶屋から登戸への街道に面し、牛車、タンク、砲車隊等の轣音、囂音、火山灰の旋風は堪へがたかつた。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると「シュウェエフェルスタンク・ウント・ゾイレ」と書いてあって、「硫黄の臭と酸と」と云うことになっている。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
