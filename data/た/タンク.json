  {
    "uuid": "00b3591a-7858-5c86-b9c9-cf50c46375da",
    "entry": "単句",
    "reading": {
      "primary": "たんく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "simple phrase",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「茂、静かにしろよ」　田山白雲は、うつろ心で叱ってみたけれども、茂太郎は頓着なく、オイセとチョウセオイセとチョウセオイセとチョウセ　この即興と反芻とを兼ねた小天才は、この単句をどこから見つけ出したか知らないが、しきりに繰返しては小船の縁をゆすぶっている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったんくわえた煙草をまたパックのなかに戻そうとしたが途中で折れた。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰途五子同伴たんくまノカウンターニ腰掛ケテ食事シ、二時頃ホテルニ帰ル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてはくたんくたんにたたまれて、呼吸もありやなし、地面にへいつくばッていた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、駄句いくつか書いて、酔いと疲れに、くたんくたんになって寝こむ。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
