    "definitions": [
      {
        "index": 1,
        "gloss": "monotony",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "毎日床の中に寝たきりで、同じような単調な日を繰り返しているうちに、ふと思い出してこの本を読んでみた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時津から早岐まで、哀れげな小蒸気船に乗っての大村湾縦走はただうすら寒い佗しい物憂さの単調なる連続としてしか記憶に残っていない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブリキを火箸でたたくような音が、こういうリズムで、アレグレットのテンポで、単調に繰返される。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人が西洋の楽器を取ってならす事はならすが音楽にならぬと云うのはつまり弾手の情が単調で狂すると云う事がないからで、西洋の名手とまで行かぬ人でも楽の大切な面白い所へくると一切夢中になってしまうそうだ。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "単調な声でゆるやかな拍子で「ナーンモーンデー」と唱えると鉦の音がこれを請けて「カーンコ、カンコ」と響くのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢の鉄瓶の単調なかすかな音を立てているのだけが、何だか心強いような感じを起させる。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ思いが、仲間の顔色に読まれる、飯を炊くのに、未だ時間がある、思い切って天幕から一、二間歩き出した、岩を二ツ三ツ飛び越えて、次第に爪先が上る、無辺無限の単調の線が、どこへ繋がって、どこへ懸っているのか、解らない……やはりあの空線の一つを辿っている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に人に使われて働いていた時分は、生活の心配を離れて、専心に工夫に没頭したら、さぞ快いだろうという、その憧憬から日々の雑役も忍べていたのだがその通りに朝夕を送れることになってみると、単調で苦渋なものだった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かりに桜のない春の国を私は想像して見ます、いかに単調でありましょう。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり単調で気が狂おう（※）そして日本の桜花の層が、程よく、ほどほどにあしらう春のなま温い風手は、徒に人の面にうちつけに触り淫れよう。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでおれは美しい正方形のつめくさの絨氈の上で夕方までいろいろ踊るといふのはどうだ　あんな単調で暑苦しい蔬菜畑の仕事にくらべていくら楽しいかしれないと考へた。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他でも両者のリズムの一致している場合には、多くは単調を感ぜしめる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいて山水遠近の配置が決して単調でなく、大様で少しもせせこましくない変化を豊富に示している。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで彼の一神教的哲学は茫漠たるロシアの単調の原野の民には誠に恰好なものであり、満洲や支那の平野に極めてふさわしいものでなければならない。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体に朱赤色や濃黄色といったような熱色の花には単調な色彩が多くて紫青色がかったものや紅でも紫がかったものにはこうした色のかがよいとでもいったものがあるらしい。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが近年の自分の単調な生活の途上に横たわるちょっとした小山の峠のようなものになっている。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が付いたら室町の三越の横を走っていたので、それではじめてあらゆる幻覚は一度に消えてしまって単調な日常生活の現実が甦って来た。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひきがえるが這出して来るのもこの大きな単調を破るに十分である。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その重苦しい何かしら凶事を予感させるような単調な音も、夕凪の夜の詩には割愛し難い象徴的景物である。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京虫や蚤蚊に攻められながら、野羊の乳を飲み、アラビア人のコックの料理を食って、一八七二年の十二月十二日から翌年三月中旬にわたる単調な船住いをつづけた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処へ行って見ても、同じような人間ばかり住んでおり、同じような村や町やで、同じような単調な生活を繰り返している。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎のどこの小さな町でも、商人は店先で算盤を弾きながら、終日白っぽい往来を見て暮しているし、官吏は役所の中で煙草を吸い、昼飯の菜のことなど考えながら、来る日も来る日も同じように、味気ない単調な日を暮しながら、次第に年老いて行く人生を眺めている。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべては私が知ってる通りの、いつもの通りに変化のない、田舎の単調な町である。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の生活も決して単調ではない。",
              "citation": {
                "source": "田舎から東京を見る",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の精神生活　単調で荒涼な砂漠の国には一神教が生まれると言った人があった。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "目をあいたり閉じたり、舌を出したり引っ込ませたりするような簡単な動作を単調に繰り返すだけである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおぜいの登場者の配置に遠近のパースペクチーヴがなく、粗密のリズムがないから画面が単調で空疎である。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが持ち出される日は、私の単調な一年中の生活に一つの著しい区切りを付ける重要な日になっている。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
