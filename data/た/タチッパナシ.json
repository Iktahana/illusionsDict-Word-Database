        "examples": {
          "standard": [
            {
              "text": "受付の仕事は一日中立ちっぱなしなので、見た目以上に重労働だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ライブ会場でずっと立ちっぱなしで踊っていたら、翌日は激しい筋肉痛になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "家事の合間に座る暇もなく、結局午前中はずっと立ちっぱなしだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その子はしかたなく立ちっぱなし、しかもへとへとだったから、あくびが出た。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "答えるために、スリム氏も立ちっぱなしだ。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
