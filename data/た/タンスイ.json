[
  {
    "uuid": "f5844275-6194-5cc0-86c0-d079ec0e4796",
    "entry": "淡水",
    "reading": {
      "primary": "たんすい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
