    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fresh water (i.e. not salt water)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "淡水に住むものと、鹹水に住むものとは、おのづからその形状も異つてゐるやうだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドゥニパー河の淡水をしたたか交えたケルソンでも海は海だ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時第一に堪難く感じて來たのは渇の苦、茲だ禍變じて幸となると言つたのは、普通ならば、漂流人が、第一に困窮するのは淡水を得られぬ事で、其爲に十｜中八九は斃れてしまうのだが、吾等は其難丈けは免かれた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡水魚の、養殖とか漁獲とか製品保存とかいう、専門中でも狭い専門に係る研究なので、来ている研究生たちは、大概就職の極っている水産物関係の官衙や会社やまたは協会とかの委託生で、いわば人生も生活も技術家としてコースが定められた人たちなので、朴々としていずれも胆汁質の青年に見えた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ淡水産のものだからそう違うまい。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡水でからだを洗い、蒲の毛を敷きつめて、その中にふかふかと埋って寝た。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "水は、海水の流入によつて鹹水であるが、岩木川からそそぎ這入る河水も少くないので、その河口のあたりは淡水で、魚類も淡水魚と鹹水魚と両方宿り住んでゐるといふ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜胆青淀の岩壁をかく穿つもの、滲みいづる滴りの淡水とは誰か思はむ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し淡水と鹹水とを相分つの意なり。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角、濱名湖は淡水湖なりや鹹水湖なりやとむづかしく考へずとも、汽船で一時間も奧に入り込んで來た此處等のこの山の蔭にこれらの魚が棲んでゐやうとはどうも考へにくい事であつた。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、人体の比重は、その自然な状態のときには、それの排除する淡水の容積にほとんど等しいのだ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、この潮のことを問題にしないとしても、淡水のなかでさえ、人間の体がひとりでにすっかり沈んでしまうということはたいへん少ない、と言っていいのだ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹽田のある所を見ると濃厚な鹽分を含有して居るのであらうが汀に近く星月夜の草村が茂つて居たり僅ながら青田が作つてあつたりするところはどうしても淡水の湖としか見えぬ。",
              "citation": {
                "source": "白甜瓜",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は一々ともまで、淡水ポンプをくみに行くか――それは見つかると大変やかましかったから、その方法はあまり取れなかった――または、石油｜罐にロープを結びつけて、海からつり上げるのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "○野間仁根氏――良い意味での爽快性、悪い意味での職人性は、『夏の淡水魚』の作である、野間氏の懐古展で見た実力はこゝでは見られない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "足しない船の中の淡水では洗っても洗ってもねちねちと垢の取り切れなかったものが、さわれば手が切れるほどさばさばと油が抜けて、葉子は頭の中まで軽くなるように思った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の航海には飲料として淡水を積んで行くのが習い、しかもこれがあれば心配はない。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "形鮎に似て鮎に非なる白色の淡水魚なり）がひっかかろうと、あるいは全然なにも釣れなくとも、どっちでもよいのであった。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "水量がぐつと落ちた川尻の塩と淡水との入り交るあたり、朝寒夜寒のきびしさに、ともすれば季節が後退りしようとするこの四五日、芦の切株に張りつめた薄氷のなかから、逸早くも春をめざして躍り出さうとする小さな生命の動きは、これなのか。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これこそは、今日この頃のまだ小雪のちらちらする寒さにも、早くも春の動きを感じて、塩と淡水との境、水底の砂子まじりに、また水腐れがした蘆の葉などにそれみづからを生みつけようとの衝動から、いたいたしいまでに弱さうな、痩形のお前をして冒険にも長い寒水の旅に上らせたものなのだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙も水洟も目高の泳いでゐる淡水のやうに味が無かつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "香気にしてからが然うで、石花菜を食べるのは、海の匂を味はひ、香魚を食べるのは淡水の匂を味はふので、今｜恁うして茸を食べるのは、軈てまた山の匂を味はふのである。",
              "citation": {
                "source": "茸の香",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡水湖と聞く宍道湖の水は、山上の湖水のやうに重苦しくなく、海のやうに激しい變化もない。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ淡水と潮水とが交錯する平原の大河の水は、冷やかな青に、濁った黄の暖かみを交えて、どことなく人間化された親しさと、人間らしい意味において、ライフライクな、なつかしさがあるように思われる。",
              "citation": {
                "source": "大川の水",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは通常の透明な淡水とどこも違わぬ水だったが、彼にはキリストの体を拭き浄めた水に見え、思わずどきりとして胸騒ぎが昂まった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一等運転手は若いハイカラなヤンキー、客船出身だけに淡水と、襟と、ワイシャツの最大浪費者だと聞いた。",
              "citation": {
                "source": "幽霊と推進機",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな河としては殆んど唯一の呼称たる淡水河が、河の語感によく妥当するのと同様である。",
              "citation": {
                "source": "台湾の姿態",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ても、不粋な奴、ちと、わしの伜の幸右衛門でも見習うては何うか』『なに、幸右衛門も、ここにいるのか』『幸右衛門ばかりか、なか様も、しょう様も、すけ様も、たんすい様も』『その、たんすい様とか、すけ様とか云うのは何じゃ』『十内とか、幸右衛門とか、野暮な名は、廓では呼ばぬ。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょう様とは、大高源吾、たんすい様とは村松三太夫、すけ様とは富森助右衛門、しげ様とは、即ちかくいう十内、又、伜幸右衛門は、ほぼたん様と呼ばれての、なかなか、廓では妓にもておる』『参ろうッ』　憤然と、数右衛門は、連れの惣右衛門を促して席を蹴った。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうか』　何か頷いて、『すけ殿、たんすい殿。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
