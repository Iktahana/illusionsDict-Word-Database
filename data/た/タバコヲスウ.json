        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「タバコを吸うのかしら？",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま、タバコを吸う。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ただ、うつけたようにタバコを吸う）村子　あんたはいいかも知れないけどさ。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり酒を飲むな、タバコを吸うななどと、したり顔して忠告するようなフリをして俺の生活から空気を取り上げた。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――うちにはタバコを吸うような者はおりません。",
              "citation": {
                "source": "枡落し",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その暗闇の中で、明智探偵は、タバコを吸うのもがまんして、しんぼうづよく待ちぶせしていました。",
              "citation": {
                "source": "夜光人間",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊りながらタバコをすう。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "タバコをすうようになったのかしら？",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "人がくると竿をあげてまたタバコをすう。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "タバコをすうひまもない。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "タバコをすうひまもないほど釣れて、持ちきれないほど釣っても、重労働のようではいっこうにおもしろくない。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
