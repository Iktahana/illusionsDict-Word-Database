        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "気の毒にみえた奴が、忽ち自分の不得手なことを始めたからだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "答へないＢは、そこで忽ち劣等人種の立場に廻る。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二分も経つか経たぬに勝負は私の負けとなつて、忽ち立て続けの負け十回目が終つてしまつた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ははじめその女が爺々ィの女房ででもあるのかと思つてゐたが、さう云つてまた忽ちその女が向ふへゆくと、爺々ィが、「まあ、どこから出て来た女か知れないけれど、勧進帳で眠くなるなんて、呆れた奴だ」と云つて笑つた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれらの人も、ヴァニティや倨傲を棄てて、自分自身に克ちさへするなら、忽ちに新鮮な生活は展けてくる！",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖母ちやんは、忽ち起つて、干物を入れるために庭に下りた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は、今耕二にツツケンドンな口を利いて来たことが忽ち悔いられた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏祭の日には、家々の軒に、あやめや、菖蒲や、百合などの草花を挿して置くので、それが雨に濡れて茂り、町中が忽ち青々たる草原のようになってしまう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日辻潤來り、わが生活の荒蕪を見て唖然とせしが、忽ち顧みて大に笑ひ、共に酒を汲んで長嘆す。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」忽ち先を爭つて、手のある限りの者は四方八方から走り集つた。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と忽ち又それが僕の良心を振ひおこさせ、そして勇氣を倍加させてくれる」と書いてあります。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　さて新雪について言うと、低地の気温の高い所で、密集した雲が雨となるように、山岳の高寒地のそれは雪になる、しかし今まで降っていた雪が、低い空気層に入ると、忽ち雨と変わることは高山を上下する人のよく遭遇する所である。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の道筋の林間の小徑は往來の人通りも稀れで、安價なる人癲癇は忽ち解消した。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "與四｜郎は忽ち顏の色青く赤く、唇を震はせて惡婆、と※びしが、怒氣心頭に起つて、身よりは黒烟りの立つ如く、紙幣も文も寸斷／＼に裂いて捨てゝ、直然と立しさま人見なば如何なりけん。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔ある国での話であるが、天文の学生が怠けて星の観測簿を偽造して先生に差出したら忽ち見破られてひどくお眼玉を頂戴した。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで小刀を持出す所を見つかると、忽ち叱られて取返されるが常である。",
              "citation": {
                "source": "井戸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は殆ど毎日十八時間労働した、されば予は忽ち同業者間第一の勤勉家と云う評を得た。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "既にして利用を終れば、忽ちまたこれを棄て、今日の味方は明日の敵となつて叛逆した。",
              "citation": {
                "source": "足利尊氏",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而るに今朝来、濃霧四辺を閉ざしシセキを弁じ難き趣きありしが、正午前、玄海洋上に望みし時忽ち右舷に当り大艦影を認む。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱が無くなると忽ち猛烈な食い気です。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち婆さんに見付かってしまった。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲蔵は忽ち江戸中人気の焦点となる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間の観衆忽ち驚く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と忽ち、　団九郎、一つコツンと叩かれた。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と忽ち、　面を殴られて、ワッと倒れる。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ゾフィイを見て、暫くは近眼のために、誰とも見分かず、忽ちそれと知りて。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家は再び戸を鎖し、跡に戻り、物を案ずる様にて部屋の内をあちこち歩き、何かそこらの物を手に取りては置き、また外の物を手に取りては置き、紙巻を一本取りて火を付け、一吸吸い、忽ちそれを投げ捨て、右手の為事机に駈け寄り、慌ただしく物をかき始む。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて暫く空を睨みいて、忽ち激しき運動にて両手を顔に覆い、両肱を机に突き、死人の如く動かずに坐りいる。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は忽ち画家の己れを見るに心付き、詞急に。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが一たび上梓されるや、忽ち一世を風靡した。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            }
          ]
        }
