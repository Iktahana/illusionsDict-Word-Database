        "examples": {
          "standard": [
            {
              "text": "日本の大手自動車メーカー各社は、好調な対米輸出を背景に四半期決算で利益を大きく伸ばしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鉄鋼製品の対米輸出に対して、不当な廉売を防ぐための新たな輸入制限措置が課される可能性が出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地元の伝統工芸品を対米輸出の主力商品に育てるべく、現地の嗜好に合わせた戦略を練っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "技術開発の面では常にトツプに立ってきたビジコン社だが、対米輸出を経営の柱としていた同社にとって、一九七三（昭和四十八）年の石油ショックの与えた影響は深刻だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
