[
  {
    "uuid": "bf79d859-b8ae-5816-87aa-22ae2fc03b63",
    "entry": "大将軍",
    "reading": {
      "primary": "たいしょうぐん",
      "alternatives": [
        "だいしょうぐん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "commander-in-chief",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "修羅道で敵手を喪った大将軍が、血刀を提げてクラ暗の中を見まわしているような悽愴たる感じが一パイに籠っていた。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "角の九つある、竜が、頭を兜に、尾を草摺に敷いて、敵に向う大将軍を飾ったように。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に左に折れて小高い丘にのぼると、高さ五尺にあまる楕円形の大石に征夷大将軍｜左金吾頼家尊霊と刻み、煤びた堂の軒には笹竜胆の紋を打った古い幕が張ってある。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "風にも堪へぬやうな、弱々しく※たけたお方ではごさいましたが、やはり尊いお生れつきのお方はなんといつても違ふもので、征夷大将軍源実朝公の御台所に恥ぢぬ凜乎たる御自負と御決意とをつねにそのお胸の内にお収めなさつて居られたやうに日頃、私たちにも拝されました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六日、丁亥、天晴、安念法師の白状に依りて、謀叛の輩を、所々に於て生虜らる、凡そ張本百三十余人、伴類二百人に及ぶと云々、此事、濫觴を尋ぬれば、信濃国の住人泉小次郎親平、去々年以後謀逆を企て、輩を相語らひ、故左衛門督殿の若君を以て大将軍と為し、相州を度り奉らんと欲すと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿五日、乙酉、晴、六波羅の飛脚到著して申して云ふ、和田左衛門尉義盛、大学助義清等の余類洛陽に住し、故金吾将軍家の御息を以て大将軍と為し、叛逆を巧むの由、其聞有るに依りて、去る十三日、前大膳大夫の在京の家人等、件の旅亭を襲ふの処、禅師忽ち自殺す、伴党又逃亡すと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝黄子澄の言を用い、長興侯耿炳文を大将軍とし、李堅、寧忠を副えて北伐せしめ、又｜安陸侯呉傑、江陰侯呉高、都督都指揮盛庸、潘忠、楊松、顧成、徐凱、李文、陳暉、平安等に命じ、諸道並び進みて、直に北平を擣かしむ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて張士誠に当りて、長興を守ること十年、大小数十戦、戦って勝たざる無く、終に士誠をして志を逞しくする能わざらしめしを以て、太祖の功臣を榜列するや、炳文を以て大将軍｜徐達に付して一等となす。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "炳文の一敗は猶復すべし、帝炳文の敗を聞いて怒りて用いず、黄子澄の言によりて、李景隆を大将軍とし、斧鉞を賜わって炳文に代らしめたもうに至って、大事ほとんど去りぬ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "景隆｜小字は九江、勲業あるにあらずして、大将軍となれる者は何ぞや。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度都では此時参議｜右衛門督藤原忠文を征東大将軍として、東征せしむることになつた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此頃は上は大将軍や管領から、下は庶民に至るまで、哀れな鳥や獣となったものが何程有ったことだったろう。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大将軍｜衛青・嫖騎将軍｜霍去病の武略によって一時｜漠南に王庭なしといわれた元狩以後｜元鼎へかけての数年を除いては、ここ三十年来欠かすことなくこうした北辺の災いがつづいていた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に彼は大将軍｜衛青と衝突した。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は父将軍の惨めな死について衛青を怨み、自ら大将軍の邸に赴いてこれを辱しめた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大将軍の甥にあたる嫖騎将軍｜霍去病がそれを憤って、甘泉宮の猟のときに李敢を射殺した。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年の二月武帝が崩じて、僅か八歳の太子｜弗陵が位を嗣ぐや、遺詔によって侍中奉車都尉霍光が大司馬大将軍として政を輔けることになった。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明軍の大将軍砲、仏郎機砲、霹靂砲、子母砲、火箭等、城門を射撃する爆発の音は絶間もなく、焔烟は城内に満ちる有様であった。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "延暦十六年、田村麻呂を征夷大将軍として、東北の蝦夷（アイヌ）を征せしめられたが、田村麻呂の武威は精悍な蝦夷を各地に破り、胆沢城（岩手市南部）、志波城（盛岡県南方）を築いて、大いに皇威を輝かした。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、たゞ六十六箇国｜総追捕使、もしくは征夷大将軍として、兵馬の権を握ることに専心した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより先、足利尊氏は、京都に於て擅に幕府を開き、征夷大将軍と称し、子｜義詮、孫義満相次いで政権を握つた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "是即ち大将軍家への、第一の御忠勤也。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにと申すに、先づ大将軍と申奉るは、天下に朝廷を軽しめ奉る者を、征伐せさせ玉ふ御職にまし／＼て、此ぞ東照神御祖命の御成業の大義なればなり。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と頭ごかし、前後に同一ような、袷三尺帯の若衆は大勢居たが、大将軍のような顔色で叱ったのは、鯰の伝六といって、ぬらくらの親方株、月々の三十一日には昼間から寄席を仕切って総温習を催す、素人義太夫の切前を語ろうという漢であった。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かしこの威徳｜衰へたりと雖も、さすがは征夷大将軍の居城だ、何処の門も、番衆、見張、厳重にして隙間がない。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「征夷大将軍の江戸城に於ては、紙屑買｜唯一人を、老中はじめ合戦の混乱ぢや。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "角の九つある、竜が、頭を兜に、尾を草摺に敷いて、敵に向ふ大将軍を飾つたやうに。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて大将軍｜孫※の門前を通ると、彼は着物の裾をかかげて、左右に唾しながら走りぬけた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの病気の人は（様々な種別もあるには違ひないが）すつかりメルヘンの王様や魔法使ひや大将軍に成り終せてゐるんだから、子供にとつたらこれ程愉快な相手はあるまい。",
              "citation": {
                "source": "気狂ひ師匠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしてもわたしは、三日の間でも関はぬから大将軍になりきつて、浜の子供等とでも遊んで見たいといふ願望は仲々逞しいけれど、キチガヒ師匠の言行は凡そ忘れてゐて、轍を踏まうにも恰で埒もあかぬのである。",
              "citation": {
                "source": "気狂ひ師匠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
