[
  {
    "uuid": "8d251733-ab3b-5e34-bab5-deae5b76d4a1",
    "entry": "対策",
    "reading": {
      "primary": "たいさく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
