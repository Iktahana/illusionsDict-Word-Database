        "examples": {
          "standard": [
            {
              "text": "彼女の優雅な立ち振る舞いは、長年の茶道の稽古で培われたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "公の場では、育ちの良さを感じさせる洗練された立ち振る舞いが求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "舞台俳優たるもの、指先の動き一つにまで神経の行き届いた立ち振る舞いが必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
