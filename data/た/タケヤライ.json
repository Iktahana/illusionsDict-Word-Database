        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこには、刑場らしい、かまえも、竹矢来も、何もなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それについて毎々議論の出ることは、ここに一定の場所を定め、竹矢来などを結いまわして仇討の勝負をさせる。",
              "citation": {
                "source": "かたき討雑感",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし芝居や講談にあるような、竹矢来結いまわしのかたき討などは実際めったになかったであろう。",
              "citation": {
                "source": "かたき討雑感",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "また刑場の四方には竹矢来を結って、すこしの隙もないようにしてあった。",
              "citation": {
                "source": "幻術",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日の模様、物珍らしきまゝに、われも竹矢来の外の群集に打ちまじりて見物するに、今しも丸山一の大家、初花楼の太夫職にして、初花といふ今年十六の全盛なる少女が、厳めしき検視の役人の前にて踏絵を踏む処なりとて人々、息も吐きあへず見守り居る体なり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "母しやま／＼と悲鳴を揚げつゝ竹矢来の外へ引かれ行けば、並居る役人も其の後よりゾロ／＼と引上げ行く模様、今日の調べはたゞ初花太夫一人の為めなりし体裁なり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小石の多い川原に竹矢来が作られている。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のひそかな絶望の形態が、竹矢来のやうに、自分の周囲に張りめぐらされた気がした。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居講談だと悉く竹矢来を結び廻すが、あれは犯罪人の不穏な連中に対して万一の事を思ったからで、敵討の方は大抵「行馬を廻す」と云って杭を打った。",
              "citation": {
                "source": "相馬の仇討",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「首級を持参の儀苦しゅうない」　講談だとすぐ竹矢来を結んで敵討をするが、本当の話となるとそんな事をして仇討したのは極く稀である。",
              "citation": {
                "source": "相馬の仇討",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "磔柱は周囲の竹矢来の上に、一際高く十字を描いていた。",
              "citation": {
                "source": "じゅりあの・吉助",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、竹矢来の外にいた人々は、今でも彼の祈祷の声が、空中に漂っているような心もちがした。",
              "citation": {
                "source": "じゅりあの・吉助",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて広々として竹矢来をめぐらした所に出た。",
              "citation": {
                "source": "四谷、赤坂",
                "author": "宮島資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私の見たところでは、思いのほかに薄手な屋敷で、長屋にも母屋にも、噂に聞いた竹矢来なぞいっこう見当りませんでした。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭前には竹矢来をめぐらして試合場の用意ができていたが、実は竹矢来の外、屋上や樹上に弓矢鉄砲を伏せ、房吉を狙い討ちにしようという作戦だ。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹矢来の外、そして頭上などに伏せてあるに相違ないのは大方見当がついている。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その攻撃をそらすには竹矢来の外へでるのが何よりであるから、彼の心は刀をぬかないうちから竹矢来を越す方策に集中していた。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "房吉は逃げるとみせて、かいくぐり、敵の後へ走って竹矢来をとびこした。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "とびこした竹矢来の外側が深田であった。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹矢来に手をかけたとたんに物の見事に五、六間も外の方へ跳びこしていたてえのだが、そこが深田とは因果の話じゃないか。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザンゴーを掘り、竹矢来をかまえ、その内側に三段の鉄砲組を構えるのだ。",
              "citation": {
                "source": "梟雄",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで信長の鉄砲組は、鉄砲のほかに竹矢来用の竹と穴掘り道具を持って出陣する。",
              "citation": {
                "source": "梟雄",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "天草四郎はここへ籠って、バラックの城をつくり、失われた石垣の代りには竹矢来や木柵をめぐらした。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場の一面には、八幡宮の鳩と武田菱との幔幕が張りめぐらされてあり、その外は竹矢来でありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "門の前には竹矢来が立てられて、本堂｜再建の寄附金を書連ねた生々しい木札が並べられてあった。",
              "citation": {
                "source": "伝通院",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
