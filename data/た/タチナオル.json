    "definitions": [
      {
        "index": 1,
        "gloss": "to regain one's footing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は、きっと明朗に立ち直る。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち直る、ということは、さっきも言ったように、これは、容易のことではない。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『春服』が立ち直る迄なりと、一つ、月々五十枚位載せて貰える、あなたの知っている同人雑誌に紹介してくれませんか。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまじ、相手が肉親であるだけに、つい言葉も、ぞんざいになり、一旦云い出したとなると、真正面から遠慮会釈もなく、切り込む新子の太刀先を、あしらいかねて、圭子はタジタジとなったが、すぐ立ち直ると出鱈目な受太刀を、ふり廻し始めた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルーシィは子どもということもあって、母親の死んだ衝撃から立ち直るのも早かった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ若者には根っからの行動力がある、一時力を失うも速やかに立ち直る。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "徐ろに傾いては、また徐ろに立ち直る。",
              "citation": {
                "source": "熊野奈智山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、十吉とてもなかなかにさるもの、投げ出されたかと見るまに、くるり一つ廻って立ち直ると、おそろしく言葉の汚ない大名もあればあるもので、憤りながら叫びました。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲労と不意の襲撃に立ち直るひまもなく、あわやプツリと太股へ不覚の穂先を見舞われたかと見えた刹那！",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち直る暇もなく、そのまま隊伍を潰して、横へそれると、実りかけている田の中へ、ドタドタと入り込んでしまった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は逃げるのも業腹だと気づいて、立ち直るや満身の力を込めた右腕で唸りをはらんだ半円を切ると奴の横面に稲妻のやうなパンチを喰はせた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体のひねりに従って、おのずから左肩が後へ引き、ピッタリ姿勢が立ち直る。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『よし、これでまず何とか立ち直るだろう。",
              "citation": {
                "source": "街の探偵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、彼はぴしゃりと跳ね返す扇子のように立ち直ると、黙って秋蘭の肩をドアーの外へ押し出した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "教師である母はあくまで生徒を弁護し、「適当な指導を与えれば必ず立ち直る。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "明けて養和二年、人々は今年こそは物資の豊かな、平和な世に立ち直るものと期待していたのであるが、その期待は見事に裏切られてしまった。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "客はその光をまともに浴びて、一度は卓の方へのめりかかつたが、すぐに又立ち直ると、今度は後へたじろいで、今し方しまつたペンキ塗りの戸へ、どしりと背を凭せてしまつた。",
              "citation": {
                "source": "南京の基督",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう言ふ座で舞ひ荒された田舎曾我が、本流めいて立ち直る機会は幾らでもある。",
              "citation": {
                "source": "芸能民習",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍛錬せられた晩年のせりふの間にも残つて居た一抹の影、稍うら枯れたやうな鼻にかゝる音色が、あくせんとにかゝる点に顕れて、ふと声調の調和を破らうとして、再元に立ち直る人｜懐い、甘美な情趣を動したものだが、此が昔のどうま声のなごりかと思へば、懐しさを感じさせられたものであつた。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "噂はまあ噂として、今後のことに気をつけ、立ち直る覚悟が肝要である。",
              "citation": {
                "source": "程よい人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はさうした事にあふ毎に、虔ましさに立ち直るだけの心は落して居ない。",
              "citation": {
                "source": "古代研究　追ひ書き",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして十分に弄んだ後で、火焔の如き息を吐く猛牛が立ち直ると、数メートルの間隔を引き離してそれと対立する。",
              "citation": {
                "source": "闘牛",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は胸が地面に付くまでへたり込み、立ち直ると小さな男の子を荒々しく地面に払い落とした。",
              "citation": {
                "source": "チカモーガ",
                "author": "Ａ. ビアス　A.Bierce",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神をどういう所に落着けて、そこからどういう風に立ち直るか、その地盤が問題なんだ。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "将来、若し、日本の新劇が、この殻を破つて立ち直る時機があるとすれば、それはいふまでもなく、俳優術の革命からである。",
              "citation": {
                "source": "新劇の殻",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうなつて欲しいといふ願望の作風が頂点に達し或ひは底をつき、現実とのギャップを支へることができなくなつたから、彼には芸術上の転機が必要となり、自らカラを突き破り、その作品の基底に於て現実と同じ地盤に立ち戻り立ち直ることが必要となつた。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで私は、彼に先をこされて立ち直ることの出来ないもどかしさから、いきなり問題にふれていきました。",
              "citation": {
                "source": "香奠",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ飛ぶことを考えている……おれならうまくやるのに……」　ひと時の混乱からたちなおると、大須賀は危機を冷静に処理することに気がついたらしく、振子運動をやめて岩角に顎をあて、ゆっくりとホールドを変えながら右のテラスに移って行った。",
              "citation": {
                "source": "一の倉沢",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今夜はばかに不景気だな」　すると女は、にこりともせず、ただかさねていた脚をはずしすっくとたちなおるようにして、声だけはつくり声のいくぶんか訴えるような、かなしげな、そのくせ態度は淫売婦どくとくのふてぶてしい人をくった冷淡さをみせて、ささやくような日本語で応じた。",
              "citation": {
                "source": "放浪作家の冒険",
                "author": "西尾正",
                "note": "青空文庫"
              }
            }
          ]
        }
