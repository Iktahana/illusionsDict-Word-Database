    "definitions": [
      {
        "index": 1,
        "gloss": "desk (equipment)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それだけに、どうも座敷用または書卓用としては、あまりに殺風景なような気がした。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターで主流になった、Ｘ８６（８０８６、８０２８６、３８６といった具合に、ケツに８６とつく一連のシリーズだ）を作っているインテルという会社は、そもそもは日本のメーカーの依頼を受けて電卓用部品としてマイクロコンピューターを作った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電卓用部品に個人用コンピューターの「臭いアイデア」を付け、後は大衆の海にマシンをほうり投げてぐずぐずかき回しておいた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして我々はすでに、電卓用の部品に大衆の知恵がのってパーソナルコンピューターが生まれ、正統的な技術が流れ込んでワークステーションが誕生するという、振り返ってみればかなり衝撃的な変化を見てきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "インテルが初のマイクロコンピューター４００４を電卓用に開発した年だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「別に、ございませんでしたが……食卓用の、ソフト・チョコレートのチューブが一つ落ちていました」「それはどうしました？",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆の服にブラッシをかけ、サモワールを沸かし、家じゅうの煖炉に薪を運んでおいて、食卓用の薬味入れを磨く。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビジコンではあくまで、電卓用ＬＳＩでプログラム可能なもの、言い換えればソフトウエア追加によって異なった機能を持つものを望んでいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電卓用部品として限定したものでかまわないと考えていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともとは電卓用に開発されたマイクロコンピューターだが、大量に生産される低価格機には、専用の回路を用意した方がはるかに安くつく。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電卓用のＬＳＩを担当しているスタッフに相談してみると、比較的簡単に発光ダイオードの簡単な出力装置が付けられそうだということで、入力装置も簡単なテンキーのようなものでいってはという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同僚の電卓用ＬＳＩの担当者に相談してみると、電卓に使っているレベルのキーボードならごくごく安いものですむという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそもは日本の電卓メーカーだったビジコン社の依頼によって着手した電卓用部品の開発作業の中で、インテルは集積回路にきわめて規模の小さなコンピューターの機能を作り付ける発想を得た。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "数値だけを扱う電卓用に四ビットの４００４を作ったインテルは、端末に使うことを考えてアルファベットに対応した八ビット構成の８００８を発表していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "インテルの製品は、もともと電卓用のチップとして開発された４００４を原点に、端末機用に機能拡張した８００８を経てから、初めて汎用部品を目指していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月に入って書き上げた原稿と図版を手渡すと、編集者は掲載を請け負い、電卓用ＩＣを使った計算機の製作記事を書かないかと、次のテーマまで与えてくれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "食卓用の白い口｜拭きを折り畳んで、客の前に置いてあるのも異国の風俗だ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "食卓用の焼塩の如きは英国某会社の三角形なる其の商標を盗用せるものあり。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "食卓用の普通の酒類のほかに、これもやはり今日のお正客のため特に用意したに相違ないトカイ葡萄酒の一本があった。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "寡婦が親切にも荷解きと整頓を手伝ってあげた時、大匙、シチュー用スプーン、テーブルセット、食卓用小瓶、ソース注し、何枚もの皿、鮮紅色のモーニングカップ、そして程度の差はあるが綺麗でかなりの重さになる単品の食器類があって、彼はそれらを処分しようとしないのだった。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブリキを火箸でたたくような音が、こういうリズムで、アレグレットのテンポで、単調に繰返される。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの広告のイルミネーションが、せわしなくまたたきをするたびに色がぱっぱっと変わる、そのように私の頭の中でもいろいろの考えがまたたくように明滅した。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンケチで首筋の辺をはたくようなことをしている。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽の始まる前の合図にガタンガタンと板の間をたたくような音をさせるのはドイツのと違っていて滑稽な感じがしました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはちょうど鉄鎚で鉄管の端を縦にたたくような音である。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄管をたたくような音がだんだん近くなって来ると、今度は隣室との境の壁の下かと思う所で、強くせわしなくガチンガチンと鳴りだす。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし目をほかへ転じようとする瞬間にまたすばやくまたたくように見えた。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎やみんなは、河原のねむの木の間をまるで徒競走のように走って、いきなりきものをぬぐとすぐどぶんどぶんと水に飛び込んで両足をかわるがわる曲げて、だあんだあんと水をたたくようにしながら斜めにならんで向こう岸へ泳ぎはじめました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち、ピシンと鞭ではたくような銃声が響く。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "外ではなんの返事もなかったが、雨戸をたたくような音はつづけて聞えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
