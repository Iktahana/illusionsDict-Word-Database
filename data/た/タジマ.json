    "definitions": [
      {
        "index": 1,
        "gloss": "Tajima (former province located in the north of present-day Hyōgo Prefecture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
