    "definitions": [
      {
        "index": 1,
        "gloss": "going through a cave, grass ring or the interior of a large Buddhistic statue, etc. (symbolizing rebirth)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "諸所に胎内くぐりめいた穴のある奇巌がそそり立っていた。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "胎内くぐり　むかしは、山の岩あなの中を通るのを、「胎内くぐり」といいました。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、大仏のからだの中にはいって、そこにまつってある小さな仏さまをおがむのも、「胎内くぐり」でした。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林君たち三人の少年は、これから、巨人の胎内くぐりをはじめるのです。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだね、胎内くぐりは、おもしろかったかね。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここが胎内くぐりの終点だよ。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩でできた廊下が、迷路のようにつづいて、その中にインド魔術をやってみせたあの大きな洞窟や、ゾウが消えた大きな部屋や、小林君たちが通った巨大な人間の胎内くぐりや、いろいろな地底のしかけがあるのです。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは、れいの胎内くぐりの巨人の胃袋の近くだったのです。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩かどを、いくつもまがって、たどりついたのは、あの胎内くぐりの巨大な胃袋の前でした。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "明智探偵は、この巨人の胎内くぐりの機械じかけを、じゅうぶん研究しておいたのです。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより他にいきようはないので、いずれまた、段々と上へのぼることになるのであろうと、一同はそれにすがって下りていくと、その深いことはおどろくくらい――、下りるとまたうねうねと道々がある、まるで富士の胎内くぐりという形だ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "是を胎内くぐりという言葉もあり、また障りなくこの行道を為し遂げたことを、生まれ清まわりと呼んでいたとも伝えられる。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
