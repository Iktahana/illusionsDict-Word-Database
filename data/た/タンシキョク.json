        "examples": {
          "standard": [
            {
              "text": "そのピアニストは、ショパンの譚詩曲第1番を感情豊かに演奏した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の作曲した譚詩曲は、深い物語性と叙情性を兼ね備えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私は雨の日に、クラシック音楽の中でも特に美しい譚詩曲を聴くのが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「ピアノと管弦楽のための譚詩曲（作品一九）」はロンの名演がある（コロムビア八〇二九―三〇）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "『二十四の前奏曲』と前後して、ショパンの『譚詩曲＝ト短調』やウェーバーの『舞蹈への勧誘』やリストの『ハンガリー狂詩曲第二番』が出た。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
