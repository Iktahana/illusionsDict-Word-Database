    "definitions": [
      {
        "index": 1,
        "gloss": "retrieving balls (during a practice session; in tennis, baseball, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "野球部の新入生として入部した一ヶ月間は、ひたすら外野で球拾いに明け暮れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "テニススクールの練習後、散らばったボールをカゴに集める球拾いを全員で行う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "打撃練習の飛距離が凄すぎて、球拾いのメンバーが校舎の裏まで走っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これをモールス翁は日本人の徳が、無心の鳥獣までをなつけているように、一人で合点して敬服しておられるが、他にもまだ一つの隠れたる理由はあったので、それだからまた雲仙の球拾いの子供などが難儀をするのである。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "ball boy",
        "register": "standard",
        "nuance": null,
