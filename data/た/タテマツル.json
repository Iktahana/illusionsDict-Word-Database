    "definitions": [
      {
        "index": 1,
        "gloss": "to offer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "近きベンチへ腰をかけて観音様を祈り奉る俄信心を起すも霊験のある筈なしと顔をしかめながら雷門を出づれば仁王の顔いつもよりは苦し。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「寒い」と上衣を着る「おい、俺の上衣じゃ」「儂のは」「お前のは……」○芝居の台詞を活弁の口調で言う兵「近衛後備歩兵第一聯隊長須知源二郎聯隊を代表して謹んで奏上し奉る。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "「加と男」とは「加藤男爵」の略称、御出張とは、特に男爵閣下にわれわれ平民ないし、平ザムライどもが申し上げ奉る、言葉である。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう連中は全く盲人というでもなく、さればといって高慢税を進んで沢山納め奉るほどの金も意気もないので、得て中有に迷った亡者のようになる。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば疾翔大力とは、捨身大菩薩を、鳥より申しあげる別号ぢゃ、まあさう申しては失礼なれど、鳥より仰ぎ奉る一つのあだ名ぢゃと、斯う考へてよろしからう。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿体なくも、我等は光明の日天子をば憚かり奉る。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "来月二十六夜ならば、このお光に疾翔大力さまを拝み申すぢゃなれど、今宵とて又拝み申さぬことでない、みなの衆、ようくまごゝろを以て仰ぎ奉るぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば疾翔大力とは、捨身大菩薩を、鳥より申しあげる別号じゃ、まあそう申しては失礼なれど、鳥より仰ぎ奉る一つのあだ名じゃと、斯う考えてよろしかろう。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "来月二十六夜ならば、このお光に疾翔大力さまを拝み申すじゃなれど、今宵とて又拝み申さぬことでない、みなの衆、ようくまごころを以て仰ぎ奉るじゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　そして卒然起上がつて少年の前に跪き頭を大地に着けて『謹で崇め奉る、怠惰の神様！",
              "citation": {
                "source": "怠惰屋の弟子入り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七四課　聖徳太子仰讃　聖徳太子さまを仏教徒が尊崇し奉るのは、太子さまが、高貴の御身分の方であらせられたのに、親しく仏教を弘通せられたということばかりでありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）僧団上首の一人　――うやまい奉る無上尊。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うやまい奉る御教の数々。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）大衆　――御教に帰依し奉る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さればにて候、別段是と申して君に勸め奉るほどのものも候はねど不圖思附きたるは飼鳥に候、彼を遊ばして御覽候へ」といふ。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼者堪兼ねて、「最早御出し下さるべし、御慈悲に候」と乞ひ奉る。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづれも心も心ならねば、長途の勞を休むる閑なく、急ぎ樣子を伺ひ奉るに何事もおほせ出だされず、ゆる／＼休息いたせとあるに、皆々不審に堪へざりけり。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ幾干ならざるに、昌黎、朝に佛骨の表を奉るに因り、潮州に流されぬ。",
              "citation": {
                "source": "花間文字",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて退りて、手を支へ、は、は、申上げ奉る。",
              "citation": {
                "source": "妙齡",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御神の御心は、仕え奉る神ぬしがよく存じておる。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "神職　ははっ、ははっ、恐れながら、御神に伺い奉る、伺い奉る……謹み謹み白す。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "媛神　（――無言――）神職　恐れながら伺い奉る……御神慮におかせられては――畏くも、これにて漏れ承りまする処におきましては――これなる悪女の不届な願の趣……趣をお聞き届け……媛神　肯きます。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "神職　はッ、白寮権現、媛神と申し上げ奉る。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "神職　さ、さ、それゆえにこそ、祈り奉るものは、身を払い、心を払い、払い清めましての上に、正しき理、夜の道さえ明かなるよう、風も、病も、悪きをば払わせたまえと、御神の御前に祈り奉る。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "刻苦勉励、学問をも仕り、新しき神道を相学び、精進潔斎、朝夕の供物に、魂の切火打って、御前にかしずき奉る……媛神　私は些とも頼みはしません。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――御利益、――御奇特、祝着に存じ奉る。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「平に一同、」「一同｜偏に、」「押して伺い奉る、」村人らも異口同音にやや迫りいう――巫女　知らぬ、とおっしゃる。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭日〔二〕宮沢賢治アナロナビクナビ睡たく桐咲きて峡に瘧のやまひつたはるナビクナビアリナリ赤き幡もちて草の峠を越ゆる母たちナリトナリアナロ御堂のうすあかり毘沙門像に味噌たてまつるアナロナビクナビ踏まるゝ天の邪鬼四方につゝどり鳴きどよむなり",
              "citation": {
                "source": "祭日〔二〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……押して伺いたてまつる。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "母體は昇天す、このときみなそこに魚介はしづみ、いつさいに哀しみの瞳をあげて合唱しあなや合讚したてまつる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
