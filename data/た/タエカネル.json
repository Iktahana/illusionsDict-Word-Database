    "definitions": [
      {
        "index": 1,
        "gloss": "to be unable to endure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
