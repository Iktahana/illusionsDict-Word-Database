        "examples": {
          "standard": [
            {
              "text": "歴史の教科書には、かつての戦争で行われた凄惨な大量虐殺の記録が残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "国際法廷では、人道に対する罪として大量虐殺の首謀者が裁かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "二度とこのような大量虐殺を繰り返してはならないと、平和記念碑に誓った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "東京中心の大地震、それにつづく大火災という災厄のごたくさまぎれに、朝鮮人の大量虐殺と社会主義者の殺害が、警察力によって行われた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "北平の陸軍刑務所を振出しにして、南京の中央刑務所、仏印のパクセ俘虜収禁所、昭南の第一拘禁所、泰緬鉄道建設で俘虜大量虐殺の問題を起している有名なタンピサヤ収容所、ジャカルタの蘭印俘虜収容所……Ｂクラスの収容所まで数えたら何カ所だったかちょっと思いだせない。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "南ヴェトナムのソンミという村で、米軍が大量虐殺をおこなった事実が発覚した。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
