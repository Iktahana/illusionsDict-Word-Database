        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "海浸す日より棲みゐて、　　　　たゝかひにやぶれし神の、二かしら猛きすがたを、　　　　青々と行衛しられず。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし孔子の弟子に子羽といへる人ありて、其猛きこと子路にも勝れり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ近ごろ、猛き獅子と巨蠎と、沙漠の真中にて苦闘するさまを描ける洋画を見たり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛き武人の風流の道は、また格別に可笑しいではないか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "はた※よりも最猛き。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、云ふのは、既にそれと覺悟を定めて居るのであらう、流石に猛き武村兵曹も聲を曇らせ『あゝ、皆私が惡いのだ、私の失策つたばかりに、一同に此樣な憂目を見せる事か。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも氏郷が小小姓名古屋山三郎、生年十五歳、天下に名を得た若者だったが、白綾に紅裏打ったる鎧下、色々糸縅の鎧、小梨打の冑、猩々緋の陣羽織して、手鑓提げ、城内に駈入り鑓を合せ、目覚ましく働きて好き首を取ったのは、猛きばかりが生命の武者共にも嘆賞の眼を見張らさせた。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇は、いたく喜び給ひ、「今、朕汝の人と為りをみるに、身体長大、容貌端正、力能く鼎を扛ぐ、猛きこと雷電の如く、向ふ所かたきなく、攻むる所必ず勝つ。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その猛き眼光、剛い髭、――さながらに猛虎の風貌をも思わしめるものであった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧はそちは心｜猛き童なり、いで死人を見せむといひて、小き戸を開きつ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは猛き獸にて、怒るときは人を殺すと聞く。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の前にて、美しく猛き若駒に首を昂げさせ、手を軍帽に加へて我に禮を施し、振り返りつゝ馳せ去りしは、法皇の禁軍なる士官なりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅馬の鷲、ユピテルの猛き鳥は死して巣の中にあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝の猛き鷲は日邊に到らずして其翼を折けり、世のまがつみと戰ひてネミの湖に沈みたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛き、凄まじき、種々で、ちょいとした棚の置物、床飾り、小児の玩ぶのは勿論の事。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "※さしもに猛き兵助が、切れども突けどもひるまぬ悪党、前後左右に斬りむすぶ、数カ所の疵にながるる血潮、やいばを杖によろぼいながら、ええ口惜しや――。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十節、十一節は獅子の猛きも亡ぶることあれば、不義者の亡ぶる如き当然のみとの意を表わしたのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに獅子、猛き獅子、少き獅子、大獅子、小獅子と五種の獅子を記しているが、原語においてはいずれも別々な語を用いてあって、老少種別等に応じて種々の名の付けられてあった事が分る。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "怖ろしき物を見れば、いかなる猛き人も、頭髪立て足に力なく振い出づ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに猛き義弘も、三樂齋も、前後に敵をうけて、終に大いに敗れぬ。",
              "citation": {
                "source": "國府臺",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "之なくば、如何に猛きも、猛獸と異なる所なき也。",
              "citation": {
                "source": "國府臺",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "児等はただ猛き親を口に指あて眺めたり。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかすがに　猛き人は行かざらめやも。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "兒等はただ猛き親を口に指あて眺めたり。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに猛き清正も虎のゆくえの気にかかり夜な夜なこわき夢をみき。",
              "citation": {
                "source": "どんたく",
                "author": "絵入り小唄集",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリムとは例の犬の名と察せられる、男たる物が犬を相手に、而も彼の猛き中の最も猛きボルドー種の犬を相手に、命の取り遣りをせねば成らぬかと思えば余り好い気持でない、医学士は之を留めて「イヤ婆さん、お前は此の紳士を知って居るのか」　婆「アア先っき伜を馬車に乗せて連れて来た人だよ」医学士「爾かい。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝が底を探りたる、者とてはなく、汝がゆたけき内奥を、知るものとてなかりけり、さまで汝等秘密をば、守らんこと敏なりき！",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "余計なお饒舌や※言を云う時には口では云わずになるたけきつい顔して無言のいましめをしてやります。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "早出の蚊を食おうとぬるい水にもんどり打つ池の真鯉――なやましく藹たけき六月の夕だ。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "早出の蚊を食はうとぬるい水にもんどり打つ池の真鯉――なやましく※たけき六月の夕だ。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
