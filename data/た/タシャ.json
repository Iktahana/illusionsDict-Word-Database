    },
    "definitions": [
      {
        "index": 1,
        "gloss": "another company",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "他社を出し抜くためにあらゆる犠牲が払われ、結局は肝心の真実そのものまでが犠牲にされて惜しいとも思われないようである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私なども編あげ靴の紐を結び直したばかりに、やはり他社のものに先をこされて、あやうく首切られそうになったかなしい経験がございます。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じような提案は、他社からも寄せられます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "働きかけにのった他社からのタイトルに加え、ボイジャー自身は、稲垣足穂の『タルホ・フューチュリカ』を準備していました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "他社の提供する開発ツールを利用した作品が、ボイジャーの新作の大半を占めるようになっていったのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが効いて、やがて他社はＩＢＭ　ＰＣと同じ機能を持つ互換機を作りはじめた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のコンピューター開発の黎明期、東芝は他社に半歩先駆けてスタートを切り、開発史をひもとけば必ず冒頭に出てくるＴＡＣに、東京大学と共に一九五二年から取り組んだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局のところこの二つのプロジェクトのうち、日本語ワープロは一九七九年二月、他社に先駆けて東芝から商品化された。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると他社のパーソナルコンピューター担当マネージャーの顔色が、いっぺんに青くなった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆を上げる際のわずかな思い切りが、他社との予想外の差を生んだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アップルも他社の生産技術を活かすなりしてこの手のマッキントッシュを出さないかぎり、時代においていかれることになる（とこう書いてから百万年ほどたって、ようやくアップルからパワーブックというマシンがでた）。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このＶＧＡ互換ボードが他社の手によって開発され、業界標準であるＰＣ　ＡＴ互換機に組み込まれた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "インテルならインテルに、Ｘ８６と全く同じ製品を他社にもライセンスを与えて作らせるように求めていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それかといって、撮る方は大事な職業で、ことに社と社との競争の激しいこの頃ですから、他社に少しでも写真が劣ると大変ですから、皆血眼になっているのです。",
              "citation": {
                "source": "Ｍ侯爵と写真師",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人参政――被教育権の主張――その他社会的の地位を要求する黄色い声は、天下に満ち満ちて来た。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ他社に対して入社の希望が持てないかというと、たとえば私がいままで日活にいたと仮定する。",
              "citation": {
                "source": "映画界手近の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが他社の末輩の下座に置かれるのを、潔く辛抱するほどまだ墮落してをらない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "家電量販店もまた、他社製品と併売する形ではあったが、競ってＰＣ―８００１を扱ってくれるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで有罪判決を受けたことで、ＩＢＭは他社に競争の機会を与えるよう迫られたが、その後も同社の独占的シェアは揺るがなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "独占していた作表機市場で上げた利益を背景に、コンピューターを徹底して低価格化できたことも、競合する他社を振り切るうえで大きな武器となった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "作表機の時代と同様八〇パーセントを超えるシェアを誇るＩＢＭに対し、わずかな残りを他社と分け合っていたハネウェルは一九六三年、ＩＢＭ機の性能を大きく上回るＨ２００を、１４０１用に書かれたプログラムをそのまま利用できるよう変換するソフトウエアと合わせて発表した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＢＭ機用に合わせてプログラムを開発しているために、たとえ他社がすぐれたハードウエアを開発したとしてもシステムを変更しようがない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした他社の攻勢によって、数パーセントながらシェアを減少させたＩＢＭは一九六四年四月、予定を大幅に繰り上げて開発中の新世代機、システム３６０の発表に踏み切った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、時代を画する新世代機が間もなく最大手のメーカーから出荷されるとの情報は、他社の追撃を抑えるうえで大きな威力を発揮した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡辺の部隊をパーソナルコンピューターの主役として強化することで、他社との競争に勝ち抜いていくことは可能だろう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＢＭがＰＣ―ＤＯＳと名付けたのと同じものを、マイクロソフトはＭＳ―ＤＯＳの名称で他社に販売しようと計画していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、販売の中心となる家電量販店では、他社機との併売を覚悟せざるをえない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "直接には取り引きも資本関係もない他社の製品である対応アプリケーションを、日本電気が費用を負担する新聞広告で、開発元のソフトハウス名入りで紹介してみた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "他社の繰り出してくるどんなマシンよりもはるかに強力な敵が、ＰＣ―９８０１の行く手には控えていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "他社が低価格を武器に電卓市場に乗り出してくると、ＨＰは機能を強化したＨＰ80やＨＰ45で対抗しようと試みた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
