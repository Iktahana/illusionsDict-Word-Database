[
  {
    "uuid": "d64ee181-1f6b-5819-8137-38c78b7ff16e",
    "entry": "他社",
    "reading": {
      "primary": "たしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
