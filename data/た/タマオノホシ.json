        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「魂緒の星は南方朱雀の二番目の宿で、幽霊の星とも呼ばれているんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古星図を広げながら、夜空に浮かぶ魂緒の星の位置を確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "占星術師は、魂緒の星が明るく輝く夜は霊的な力が強まると予言した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
