          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "いじめられて黙っているのはもうやめて、今日は絶対に叩き返してやる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "喧嘩で先に手を出してきた相手を、彼は容赦なく叩き返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつて負けた相手との再戦で、受けた屈辱を倍にして叩き返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
