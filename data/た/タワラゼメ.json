    "definitions": [
      {
        "index": 1,
        "gloss": "Edo-period form of torture in which criminals were stuffed into straw bags with their heads exposed, piled together, and whipped (commonly used on Christians)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "時代劇の拷問シーンで、罪人が俵に入れられて酷い扱いを受ける俵責めの描写があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史資料によれば、俵責めは単なる肉体的苦痛だけでなく、精神的な屈辱も与えるものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつての宗教弾圧において、改宗を拒む者に対して非道な俵責めが行われたという記録がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "川中島の百姓たちの利かない気性を褒めて、俵責めの手段を痛快なりとし、今後、生意気な芸人共はあの手段で行くがいいと唱え出す者もある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
