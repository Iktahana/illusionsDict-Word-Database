    "definitions": [
      {
        "index": 1,
        "gloss": "working one's way up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今までたゞ薩張りした書生さんと見えたものが一度び闥を排すれば子飼いから叩き上げた芸人である。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "叩き上げから鋳物工場を起こした初老の主人公は、原爆、水爆が恐ろしくてしょうがない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二葉亭の頭は根が治国平天下の治者思想で叩き上げられ、一度は軍人をも志願した位だから、ヒューマニチーの福音を説きつつもなお権力の信仰を把持して、“Might is right”の信条を忘れなかった。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大島高次郎という人は、若い時から草鞋穿きで叩き上げたほどな人ですから、なかなか確かりした人物でありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "鋳物の仕事をしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "……何に限らず一緒に出來るかね、一體、餓鬼の時分から苦勞して叩き上げたものと、ほかの方で食ひ詰めて來て、まア仕方がないこれでもやらうかつてものとがさ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｊ・Ｉ・Ｃの秘密をドン底まで叩き上げないではおかないぞ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてすこし違法ではあるが、無理にも志免課長の手に引渡して、有無を云わさず叩き上げさえすれば、一切の真相が判明する筈である。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄雪の方は、嵯峨二位卿の息女であり、一方は門閥もなく、七両の下廻りから叩き上げた千両役者なのであるが、ついにその二人は、島の外にある小島に隔てられて、凋んだ花の香りを、絶海の孤島から偲ぶ身になったのである。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅幇とは、強盗、無頼漢等にて成り、その仕事も直情径行的に頗る荒っぽくやっつける方で、青幇には一度この紅幇の仲間に入って実務でウンと腕っ節を叩き上げたものがその大多数を占めて居る。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも本場で叩き上げた芸と、所謂場違ひの芸とでは大した差があるやうで、今でもどうかすると一時ワツと騒はがれる者が出て来るが、それは一しきりで永続きがしません。",
              "citation": {
                "source": "燕枝芸談",
                "author": "談洲楼燕枝（二代）",
                "note": "青空文庫"
              }
            },
            {
              "text": "４．彼はとうとう叩き上げた。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "千頭津右衛門などと名前だけは大そうだが、こちとらは金持ちとちがって一文無しで叩き上げた筋金入りの腕前。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝次郎は、料理屋の板前で、以前、新橋のＫ……で叩き上げた技倆だと、自慢してる丈の事は有って、年は二十八だが、相応に庖丁も効き、つい此間迄は、浅草の、好く流行る二流所の割烹の板前だった。",
              "citation": {
                "source": "越後獅子",
                "author": "羽志主水",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると漆喰で叩き上げた二坪ほどの土間に、例の車屋の神さんが立ちながら、御飯焚きと車夫を相手にしきりに何か弁じている。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしなにしろ、多年大衆向きとして、講談に芝居に叩き上げられたことなれば、益※精練せられて今では殆んど確定的の事實として、大岡越前守の名奉行振りを稱へられて居る。",
              "citation": {
                "source": "大岡政談",
                "author": "尾佐竹猛校訂",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中のことはわからないもので、岸田を岸田銀行の頭取のせがれだなどといひ、先々金満紳士だつたと思つてゐる人もあるやうだけれど、実はその反対で、徹頭徹尾腕一本で叩き上げた彼は男だ。",
              "citation": {
                "source": "岸田劉生の日本画",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵一つで叩き上げた。",
              "citation": {
                "source": "岸田劉生の日本画",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あの松五郎は一と通りの男ぢやねえ、三道樂の修業が積んで、人間を叩き上げてゐるから、あれ程の娘を殺されて、唯で引込む筈はねえ」　平次は其處まで睨んでゐたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人、先刻一番先に顏を出した萬吉は、五、六年前に亡なつた番頭萬助の伜で、今年二十五の春まで小僧から手代へと店で叩き上げた男で、物の考へやうも手堅く、先々はお染と一緒にして――そんな事を勘兵衞が考へて居た樣子です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "黒い巾着",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんその人が書いた物で叩き上げた名前というものは、名乗った瞬間に対手方に一どきに、全作品がかぶさって行くようである。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "大黒屋という、小体ながら表通りに店を張って、数代叩き上げた内福な呉服屋、番頭の佐吉は、内外一切の采配を揮っている、五十年配の白鼠だったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "八人芸の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十そこそこの陰惨な忍従に叩き上げられたような蒼黒い男です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "土への愛着",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あの松五郎は一と通りの男じゃねえ、三道楽の修業が積んで、人間を叩き上げているから、あれほどの娘を殺されて、ただで引込むはずはねえ」　平次はそこまで睨んでいたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人、先刻一番先に顔を出した万吉は、五、六年前に亡くなった番頭万助の倅で、今年二十五の春まで小僧から手代へと店で叩き上げた男で、物の考えようも手堅く、先々はお染と一緒にして――そんな事を勘兵衛が考えていた様子です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "黒い巾着",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いえ、一番遠く離れて居りますが、年寄は主人を除けば私一人で、あとは二十歳臺の若い者ばかりでございます」　老番頭はさすがに長い商賣の掛引で叩き上げたせゐか、見かけよりはシヤンとして居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お登世の戀人",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十そこ／＼の陰慘な忍從に叩き上げられたやうな蒼黒い男です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "土への愛著",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学を途中で止して平巡査から叩き上げ、長く巡査部長の肩書を持って居りましたが、近頃漸く特別任用で警部になったばかり。",
              "citation": {
                "source": "笑う悪魔",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の死ぬのをヌケヌケと見ていて宜いものか悪いものか、思い知らせてやるから、畜生ッ」　小格子で年一杯叩き上げたおよつは、妖艶で取廻しの良い女でしたが、その代り、執拗で病的で、意地っ張りで気違い染みた女でした。",
              "citation": {
                "source": "芳年写生帖",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの決まったところ、さっとつぶてをかわしたところ、きりっと体が締まったところ、おいたはおよしなさいませとおちついたところ、やっとう剣法、竹刀のけいこでたたきあげたにしても、まず切り紙以上、免許ちけえ腕まえだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には正式のレッスンをうけた正しいゴルファーもいるけれども、大会にでてくる人々の多くはここでたたきあげただんなであるから、ものすごい。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
