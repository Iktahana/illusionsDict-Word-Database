          "literary": [
            {
              "text": "本を読み、麻雀や花札をし、卓球で体を動かす。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポングと名付けられた次のゲームは、ディスプレイをはさんで向き合った二人のプレイヤーが玉を打ち合う、電子式の卓球だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "掘ってみると、卓球のボールほどの海亀の卵が、二十も三十も埋められているのだった。",
              "citation": {
                "source": "甘い野辺",
                "author": "浜本浩",
                "note": "青空文庫"
              }
            },
            {
              "text": "校友会関係でいうと、六人ともそれぞれに何かの委員をやっており、平尾が総務、次郎が文芸、梅本が弁論、新賀が柔道、大山が弓道、馬田が卓球となっている。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
