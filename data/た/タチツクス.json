        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "生まれる前に別れたわが子に三十年後にはじめてめぐり会った人があったとしたら、どんな心持ちがするものか、それは想像はできないが、それといくらか似たものではないかと思われるような不思議な心持ちをいだいてこの絵の前に立ち尽くすのであった。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子　いえいえ、少しも云い憎いことはない故に、ありのままを申しておくれ（使女二人は困却せる風にて立ち尽くす。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて見る本物の鯨に、健一は息を呑み、そのあまりの大きさにただただ茫然と立ち尽くすより他なかった。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち尽くす雲の中に、本物の黄蛾がおり、その姿は小さな毛虫で、脂ぎった体に、眼が突き出ている。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私が初めて東洋における白人支配の虚しさ、くだらなさを把握したのは、まさにこのライフルを持って立ち尽くす瞬間だったのだ。",
              "citation": {
                "source": "象を撃つ",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎこちなく立ち尽くす様子は、場違いで、周囲の豪華さに畏れ多いかのようだった。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇妙な笑みがザリの口元に浮かび、じっと立ち尽くす姿は黒い銅像のよう。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
