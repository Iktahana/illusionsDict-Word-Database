        "examples": {
          "standard": [
            {
              "text": "プラトンの『国家』は、師であるソクラテスと友人たちの対話体で書かれた哲学書だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この入門書は先生と生徒の対話体で構成されており、初心者でも内容が理解しやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "劇作家は登場人物たちの対話体のみで、その場の緊迫した空気感を巧みに表現した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "国語の本に、「五作爺さん」といふ題の対話体の文章がのつてゐた。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『今戸心中』、『黒蜥蜴』、『河内屋』、『亀さん』等の諸作は余の愛読して措く能はざりしものにして余は当時｜紅葉眉山露伴諸家の雅俗文よりも遥に柳浪先生が対話体の小説を好みしなり。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
