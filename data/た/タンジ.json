[
  {
    "uuid": "5eb84475-874b-5ec8-9709-9a3037147100",
    "entry": "探餌",
    "reading": {
      "primary": "たんじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(animal's) foraging",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "手前の方から喧嘩を吹っかけたんじゃねえか」　私は、実は歩くのが堪えられない苦しみであった。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、お前気でも狂ったんじゃないのか」　セコンドメイトは、ポシャッと云った水音で振りかえってそう云った。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒じゃあるめえし、夜中に踏み込まなくたって、逃げも隠れもしやしねえよ」（此儘行ったんじゃ困る。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆やられたんじゃ仕方がないからな。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が予め読者諸氏に、ことわって置く必要があると云うのは、これから、第三金時丸の、乗組員たちが、たといどんな風になって行くにしても、「第一、そんな船に乗りさえしなければよかったんじゃないか、お天陽様と、米の飯はどこにでもついて、まわるじゃないか」と云われるのが、怖しいためなんだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "――俺が踏み殺したんじゃあるまいか？",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "六原に居たんじゃ馬は使えるだろうな。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、あちこちちらばったんじゃさがし出せない。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のこったやっぱり民子を見に来たんじゃないかと、自分で自分を嘲った様なことがしばしばあったのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに政夫は学校へ行ったんじゃないか、暮には帰ってくるよ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は茶を呑みに来たんじゃねえんだ」　と言って立ち上る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに今将棋が面白え処だ、済んでから逢おう、茶でも呑んで待ってろとは何をぬかしやがるんだ」　「うぬは、ど……」　「俺が今日此処へ来たなあ茶を呑みに来たんじゃねえッ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うらア始めから、尋常を上ったら、もうそれより上へはやらん云うのに、お前が無理にやるせにこんなことになったんじゃ。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほいたらいつまでもこんな百姓をせいでもよかったんじゃ！",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うらのはそれでも買うたんじゃぜ。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じいさん、えい着物をこしらえてくれたんじゃどよ。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの鍬をやってしまわずに、一挺持って来たらよかったんじゃがな。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの時は、こっちに鍬がいろうとは思わなんだせにやったんじゃ。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「露西亜語を教わりに行く振りをして、朝鮮人のところへ君は、行っとったんじゃないんか？",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わざと、ちょっぴり怪我をしたんじゃないか？",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だって、あいつら、偽札を使ってたんじゃないか。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんで身投げなどしたんじゃろかなと、女は自問し、この世がいやになったんでしょうかなと自答した。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は藤二のことを思い出すたびに、「あの時、角力を見にやったらよかったんじゃ！",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――緒を柱にかけて引っぱりよって片一方の端から手がはずれてころんだところを牛に踏まれたんじゃ。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとでこの事を友人に話したら腰が抜けて逃げられなくなったんじゃないかといって笑われたくらいであった。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女はいってえ何者だろう」「ねえ、もしや川から出て来たんじゃ無いかしら」と、お徳は摺り寄ってささやいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべ釣って来たのは雄の鯉で、その雌が取り返しに来たんじゃあるめえかな」「返してやったからいいようなものだが、なんだか気味が悪いね」「どうも変だな」　と、藤吉は今更のように表をみかえった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、あいつが真逆やったんじゃあありますまい」「むむ」と、半七は考えていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめえだから云って聞かせるが、師匠は蛇が殺したんじゃあねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い師匠のかたきを取るために、お前さんが大師匠をどうかしたんじゃねえかと、世間で専ら評判をしている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
