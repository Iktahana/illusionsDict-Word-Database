        "examples": {
          "standard": [
            {
              "text": "コンサートの二階席から、単眼鏡を使って推しの表情をじっくり観察した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "視力が低いので、駅の掲示板を見るためにポケットから単眼鏡を取り出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "バードウォッチング初心者の彼に、軽量で使いやすい単眼鏡をプレゼントした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "成層圏の手前から、高度二十キロメートルのところまで、本艇を覗っていた飛行機が十二機もあったので知れる」　と、リーマン博士は、細長の顔によく似合う単眼鏡をきらつかせ、ときには綺麗に刈込んだ頤髯を軽く引っ張ったりして、機嫌は決して悪い方ではなかった。",
              "citation": {
                "source": "宇宙尖兵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕や足をパッパッと光のように動かし、あっという間もなく、変装した姿は軍人、単眼鏡をかけ、仰々しい口髭をつけている。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
