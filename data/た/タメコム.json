          "standard": [],
          "literary": [
            {
              "text": "可愛い妻子に美味いものも喰わせず、楽しみもさせずに、恥は掻き放し、義理も欠き捨て、人情も踏付け通しで、そのたんびに首を縮めて盗賊と、詐欺と、非人の気持を繰返し繰返し、アチラで一文コッチで三文とクスネ込み溜め込むようになります。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＳ―ＤＯＳとマッキントッシュはすでに情報を溜め込む井戸となっているのだから、新しいマシンは異なった井戸をつなぎ、ここから水を汲み出すパイプとならなければいけない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "給金をがっちり溜め込むより外には望みがありそうもない人柄です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "太え野郎で」「何が太え野郎だ」「そんなに溜め込む奴があるから、こちとらには、正月だといふのに、一貫と纒つた小遣ひが入らない」「やつかむなよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "屠蘇の杯",
                "note": "青空文庫"
              }
            },
            {
              "text": "身のまわりに雑多な物をたくさん溜め込む性格の人ではない舞子に、所持品は少なかった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "全員が、ワラを見つめて、息をためこむ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊富さとは、徒に、読こみ、ためこむ、その蓄積一面より、いかに貯え、いかに出すか、その間の活々した流動にあると思う。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "食うものを食わずにダンビラを買い集めて朝夕せッせととぎすましたり原子バクダンを穴倉にためこむような人々を羨む必要はないじゃないか。",
              "citation": {
                "source": "もう軍備はいらない",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "十匹以上も、同じようにして、運んできては、壺の中へためこむのだ。",
              "citation": {
                "source": "智恵の一太郎",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
