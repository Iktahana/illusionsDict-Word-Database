    "definitions": [
      {
        "index": 1,
        "gloss": "insufficient",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "少しずつ貰った小使銭位では、毎日いたずら半分にかける「ハガ」の黐を買うのに足らない。",
              "citation": {
                "source": "井戸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩の要求する歌には、心に浮んだ刹那の感じを伝へたゞけでは足らない。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二坪にも足らない小池のまわり、七度も八度も提灯を照らし回って、くまなく見回したけれども、下駄も浮いていず、そのほか亡き人の物らしいもの何一つ見当たらない。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、グロテスク美術が自然や文明の脅威から生れるものとすれば、あらゆる意味で不安な現代日本で産み出される絵画がこういう傾向をとる事は怪しむに足らないかもしれない。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、集中二、三の旧作は目下の著者の芸術的信念や思想の上から見て飽き足らないものである。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々には、それらの追憶（それだけでは何でもないもので、誇るに足らないものでせう）のみならず、それらの人間的で、かつ「家神的」（家の神といふ意味での）な價値を保存するといふ責任があるのです。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は生きてゐるのです、本當に取るにも足らないもので。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一兵卒」はこれに比すると、量は十分の一にも足らないが、現実は遙かに歪められず自由に掴まれている。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "志一や高天は言うに足らない、山伏や坊さんは職分的であるから興味もない。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく聡明な彼の目には、なお飽き足らない点、補充を要する点がいくらもありはしないかという事は浅学な後輩のわれわれにも想像されない事はない。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし多くの科学の探究者はそれでは飽き足らないであろう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ二十歳にも足らないような女で眉を落とし歯を染めているのも決して珍しくはなかった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに私は、喧嘩を好まず、否、好まぬどころではない、往来で野獣の組打ちを放置し許容しているなどは、文明国の恥辱と信じているので、かの耳を聾せんばかりのけんけんごうごう、きゃんきゃんの犬の野蛮のわめき声には、殺してもなおあき足らない憤怒と憎悪を感じているのである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はしばしば思うた、もし武蔵野の林が楢の類いでなく、松か何かであったらきわめて平凡な変化に乏しい色彩いちようなものとなってさまで珍重するに足らないだろうと。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝起きた時にも、焼けあとに遊びに行ってる時にも、なんだか一つ足らないものがあるようだったが、それはポチがいなかったんだ。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、自分を強いるようにその物足らない気分を打ち消すために、先ほどから明るい障子に羽根を休めている蝿に強く視線を集めようとした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあに、僕のはたいしたことはないんだよ」　まったく医者が見てくれるたびごと、たいしたことはないというのだが、それが何か物足らないのだけれども、この場合やはり医者がいうようにいうのが恰好だと人見は思ったのだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身などは物の数にも足らない。",
              "citation": {
                "source": "宣言一つ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その井戸は三尺にも足らない程の淺さで、井戸がはも半分腐つてゐたが、綺麗に掃除が行き屆いてゐて、林檎箱のこはれで造つたいさゝかのながしも塵一つ溜つてゐなかつた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しながら人間がその存在の中にさぐり求めるあらゆる手段の中、死のみが辛うじて、凡てを撥無してもなほ飽き足らない戀人の熱情を髣髴させるのだ。",
              "citation": {
                "source": "詩への逸脱",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "説明的であり理知的である小説や戲曲によつて自分を表現するのでは如何しても物足らない衷心の要求を持つてゐた。",
              "citation": {
                "source": "詩への逸脱",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は熱に燃える眼を見開いて、見入つても／＼飽き足らないやうに彼れの顏を凝視した。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "實際をいふと妻の死因を實證した時にも、思ひあがつた誇と滿足との裏に、何所か物足らない不思議な感じがあつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫れでもどうやら物足らない様に思つたが、ふと病中にきいたことを思出した。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のこれほどの熱心がまだ松村を動かすに足らないのであらうか。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞をやめたので（旅に出がちでもあり、借銭がふえもするので）、何だか社会と離れたやうな気がする、物足らないと同時に気安にも感じる。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は取るにも足らない良心の脅迫を軽蔑したかった。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "追いかけながら、私はこれ程繁昌な巷に立って見窶しい唖娘の姉が、取るに足らない草花なぞを売って、果してそれを気にとめて買ってくれる人が少しでもいるのであろうか――これは、いよいよ姉は私を欺いているらしいと考えるのであった。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間がその發育した理智によつて、自然の苛虐から自衞を講じ、次第に他の強敵を征服して、自らの文化と歴史とを作つたのは、極めて最近の事蹟であり、人類進化の悠遠な史上に於ては、殆んど言ふに足らない短日月の歴史にすぎない。",
              "citation": {
                "source": "夢",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかに出てくる吉野さんよりも能の楽屋の景色や照葉狂言の楽屋の景色其物に興味がないと極めて物足らない小説になるかも知れぬ。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
