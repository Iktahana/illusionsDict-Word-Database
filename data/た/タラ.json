    },
    "definitions": [
      {
        "index": 1,
        "gloss": "if",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしそれが結果する悲運ときたらだ、いやといふほど味はつてゐる。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "所でラヴェルなんてバッハが見たら苦労性なデコラトゥールだ。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身が無名でさへなかつたならば、何とかしたでもあつたらうけれど、私が話をした知名の人達はどう迂つ闊りとしてゐたものか。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔まひるつとめにまぎらひて〕宮沢賢治まひるつとめにまぎらひてきみがおもかげ来ぬひまはこころやすらひはたらきしそのことなにかねたましき新月きみがおももちをつきの梢にかゝぐれば凍れる泥をうちふみてさびしく恋ふるこゝろかな",
              "citation": {
                "source": "〔まひるつとめにまぎらひて〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "訓導宮沢賢治早くもひとり雪をけりはるかの吹雪をはせ行くは木鼠捕りの悦治なり三人ひとしくはせたちて多吉ぞわらひ軋るとき寅は溜りに倒れゐし赤き毛布にくるまりて風くるごとに足小刻むは十にたらざる児らなれや吹雪きたればあとなる児急ぎて前にすがりつゝ一列遠くうすれ行く",
              "citation": {
                "source": "訓導",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "開墾宮沢賢治落ちしのばらの芽はひかり樹液はしづにかはたれぬあゝこの夕つゝましくきみと祈らばよからんをきみきたらずばわが成さんこの園つひにむなしけん西天黄ばみにごれるに雲の黒闇の見もあへず",
              "citation": {
                "source": "開墾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば日々報道される様々な事件が、昔人間の数の少なかつた時よりも、人の感動を鈍らせ易いものだといふことが云へるとしても、而も芸術とはさういふ事情の問題ではなくして、さういふ事情の中にあつても猶感動する人がゐたら、その人が感動した感動に基因して表現するに到る所のものである。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君がもし一個の林檎に如何にも惚れ惚れとしたら、それを描きたくなるであらう。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "要は、その林檎に如何にもほれぼれとしたら諸君は芸術家だといふことだ。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "感動したらその感動がやがて芸術であり、何もその感動の誘因となつたパンが芸術でもなければルンペンが芸術でもない。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨それでは、その良心は如何にしたら十分になるであらうかと考へる時、私には他力の信仰といふことが思はれるのだ。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "心理的洗練そのものが俗だとはいへまいが、心理的洗練の他に精神的渇望だの信念だのと呼ばれるものがない限り、人は俗物たらざるを得まい。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "理窟を云つてゐたら、ホトホト疲れました",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しそれが知慧だとしたら、知慧とは千偏一律のもので、千偏一律な知慧なぞといふものが、考へられるか？",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂとしたら、何も格別文学談ではないのだ、彼は営んでゐるのが、だいたい文学的生活だといつたわけなのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし彼が独りであつたら、記臆に蓄へるか、それとも帰つてからノートに取るなりする所だ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女給ときたら尚のことだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんな奴が、段々偉くなりやがる」、ハテ面妖なとＡの方で思ふのだが、Ｂとしたら、変な話ぢやないか。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、「君の暮しが、もつと楽だつたらいいだらうなァ」。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで不満なのだつたら、困難も出て来ない、困難だといへば文学全体が困難な俺なぞは、どうすれあいいのだ」。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂとしたら、又してもガツカリだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォルムのない競技で以て、徒らに勝たうとばかりしてゐるやうなもので、仮令勝てたにしても、競技そのものを楽しむ気持はなく、勝つた時に熱病的に嬉しいだけで、十年の後に回想したらば、なんといふこともなかつたと、呆然としなければならない始末だらう。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今仮りに某が、興味を以て是々の文学書を読んだり、是々の作品を物したりして暮してゐるとして、其処へもつてきて「陽気な文学を」、なんて声がして来たらどんなものだらう。",
              "citation": {
                "source": "文学に関係のない文学者",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今、その世界を聊かなりとも解明したいのであるが、当抵手に負へさうもないことであるから、仮りに、さういふ世界に恋著した宮沢賢治が、もし芸術論を書いたとしたら、述べたでもあらう所の事を、かにかくにノート風に、左に書付けてみたいと思ふ。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、人がもし無限に面白かつたら笑ふ暇はない。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻翼の所はおしろいが剥落ちてゐて、一寸突いたらビリビリと破けさうな感じがする。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かといつてどう改良したらいいかといふことになると、結局やつぱりこの儘でいいやといふやうなことになつて来て、此の事ならず一切が、実に屁下手く退屈なのが人生である。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階に昼寝してゐた汚ない顔の女給が、目をこすりながらいやみつたらしく出て来たのだ。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "返事をしないとしたらあの男はひどく残念がるのだし、しまひには腹をたてる。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の此の家だつて、後で叔母の云ふ所によると、信者が家主であるさうで、その家主老夫婦が自分達の隠居のために建てたんださうで、値段に比べたら却々立派な家である。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
