        "examples": {
          "standard": [
            {
              "text": "新しい事業を始めるには、胆大心小の精神で挑むべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はまさに胆大心小を体現したような人物で、大胆な決断と細やかな配慮を両立させている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このプロジェクトの成功には、リーダーの胆大心小なアプローチが不可欠だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は婦人のごとき温柔の面貌に、いささか紅潮をたたえて、底知れぬ図太き胆大心小の立居振舞い、唯々として『御高論御尤なり』と言う。",
              "citation": {
                "source": "アーニイ・パイルの前に立ちて",
                "author": "小林一三",
                "note": "青空文庫"
              }
            }
          ]
        }
