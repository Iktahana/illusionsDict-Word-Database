        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "熊本へ出張して一と晩久しぶりで旅人の気分で歩いたが、熊本といふ所はいい所です　火山地方特有の落付がありますとも書いてゐた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の国々を漂泊して、ついに心の郷愁を慰められなかった旅人ヘルンは、最後にまたその夢の中で漂泊しながら、見知らぬ遠い国々を旅し歩いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくつかの坂を越えて、遠い「時代の旅人」はそこを登るであらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕭条とした山野の中を、孤独に寂しく漂泊していた旅人芭蕉が、あわれ深く優美に咲いた野花を見て、「笠に挿すべき枝のなり」と愛しんだ心こそ、リリシズムの最も純粋な表現である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "から鮭も空也の痩も寒の内　雲水に似た旅人芭蕉も、時には一定の住所に庵を構えて、冬の囲炉裏を囲みながら、侘しく暮していたこともある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスマスは旅人を感傷的にする夕だと誰かが云った通りである。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の照る砂地に落ちてゐた硝子を、歩み来た旅人は周章てて見付けた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田だけは、江戸時代から、郡内の甲斐絹の本場を控えて、旅人の交通が繁かっただけあって、山の坊のさびしさが漂うと共に、宿場の賑わいをも兼ねて見られる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　旅人の「山」　万坊ヶ原の一本松は、暁の暗に隠れた、那須野ヶ原あたりの開墾地にありそうな、板葺小舎から、かんがりと燈がさす。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人がアンデスの登山を悦ぶのは、麓が永久の春であるからだそうだが、山の天国は、発達した裾野を有するところの、富士火山帯に多くあらねばならない。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も旅人として富士を讃美する。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルプスの美を、知覚的に讃美したのは、スイスの農夫でなくて、旅人であった如くに、富土山もそうであった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天地のわかれし時ゆ、神さびて」と歌った山辺赤人は旅人であった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "名もない一遊子ではあるけれど、私も幼い時から、富士の影を浴びて、武蔵相模で育った一児童として、永い間の外国生活から、故国へ放還された一旅人として、親友と、子供と、忠実なる案内者とに囲まれて、今富士の膝下へ来て亡き母の顔に見えまつるが如く、しみじみと見ているのだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "御中道に昔は小舎がなくて、参詣の道者が難渋するため、そのうちの難所たる大沢に、お助け小舎を置いたそうだが、それは疾くにつぶれて、今のは粗末ながら、普通の旅人宿めいた小舎である。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上には旅人宿めいた室、勧工場然たる物産陳列所、郵便局、それから中央の奥宮社殿は、本殿、幣殿、拝殿の三棟に別れて、社務所、参籠所も附属している。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時分上高地峡谷に入る人は、猟師の外に、稀に飛騨の蒲田谷から、焼岳を越えて来るか、あるいはその反対を行く旅人を見るに過ぎなかったのであろうと想像されるが、今日では夏日になれば、登山客がこの谷に多く群集して、数十年来の谷の主、老猟師嘉門次に呆れた眼を※らせるようになった。",
              "citation": {
                "source": "上高地風景保護論",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の町は、夜九時になると死んだやうになる、偶然飛び込んだ旅人を泊める宿屋までも、十時になると眠り込む。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は姉と弟を取って東路へ帰る旅人の手に渡した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この娘を東国へ旅人の手に托けて送ったときの気持に戻って、いっそ、この娘を思い捨てるか。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来の道が拓けるにつれ、東国の西の方よりこの東国の北部の方へ入り込んで来る旅人が多くなった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「福慈の女神はだんだん若くなるようである」と旅人たちはいった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人たちの話を綜合してみて、いちいち驚かれる伯母が持てるものである。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て常陸の山に在って旅人から聞いた話の、八つの湖に女神の姿を待ち侘ぶ河神たちの姿も眼の前に見た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "話の様子では、この街道を通りつけの諸職業の旅人であるらしかった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに不思議なことはこの東海道には、京へ上るという目的意識が今もって旅人に働き、泊り重ねて大津へ着くまでは緊張していて常にうれしいものである。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、水色の汽車の窓の所で、瘠せた旅人が、青白い苹果にパクと噛みついた。",
              "citation": {
                "source": "〔蒼冷と純黒〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小さな列車の窓は一列小さく赤く見え、その中にはたくさんの旅人が、苹果を剥いたり、わらったり、いろいろな風にしてゐると考へますと、ジョバンニは、もう何とも云へずかなしくなって、また眼をそらに挙げました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふりかへって見ると、車室の中の旅人たちは、みなまっすぐにきもののひだを垂れ、黒いバイブルを胸にあてたり、水晶の珠数をかけたり、どの人もつつましく指を組み合せて、そっちに祈ってゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人たちはしづかに席に戻り、二人も胸いっぱいのかなしみに似た新らしい気持ちを、何気なくちがった語で、そっと談し合ったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
