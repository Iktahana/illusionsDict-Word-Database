[
  {
    "uuid": "d5d834b8-5797-54dd-8413-ea765c3d752b",
    "entry": "端座",
    "reading": {
      "primary": "たんざ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
