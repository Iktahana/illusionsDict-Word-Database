[
  {
    "uuid": "095c527f-03a6-55ef-bdc5-cc5fbfcc4a22",
    "entry": "退院",
    "reading": {
      "primary": "たいいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
