[
  {
    "uuid": "e431809f-a447-5b61-b7b7-49a469459e54",
    "entry": "体貌",
    "reading": {
      "primary": "たいぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "appearance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "公其の心事を余に語りて曰く、松隈内閣は一種の聯合内閣なり、之れを従来の内閣に比すれば、稍々進歩したる体貌を有するに似たりと雖も、其の実質は薄弱にして統一を欠き、情弊尚ほ依然として内部に纏綿せり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "シナ人の体貌面相の日本人に異なるは、男女貧富を問わず、一般に緩慢なる相貌を有する点にあり。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてその風姿体貌にいたりては、またはるかに富峰に及ばずと。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば人民の体貌、衣服等は、中央アジアの風に似たるところ多し。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "純次は博文館の日記を開いて鉛筆で何か書いているらしかったが、もぞもぞと十四五字も書いたと思う間もなく、ぱたんとそれを伏せて、吐きだすごとく、「かったいぼう」　とほざいて立ちあがった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが風よりももっとす早く、かったいぼうの手がでて来て、相変らず「ミゼラビリ・エチェレンツア」と鼻をならしつづけました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "花売りにかったいぼう、手相見もいれば、飴屋もいる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "咸臨丸受取",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
