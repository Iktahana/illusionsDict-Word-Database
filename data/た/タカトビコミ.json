        "examples": {
          "standard": [
            {
              "text": "10メートルの高飛び込み台に立つと、プールの水面が遥か遠くに見えて足がすくむ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はオリンピックの高飛び込み競技で、一糸乱れぬ空中動作を披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "観光客たちが崖の上から海へ高飛び込みをする様子を、ボートから眺めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "写真家の専属モデルを務めていた時期もあれば、水上ショーのメンバーに加わって、高飛び込みのスターだった時期もある。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が十五歳の頃、姉はカリフォルニアにいて、高飛び込みに熱中していた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
