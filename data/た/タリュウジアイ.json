    "definitions": [
      {
        "index": 1,
        "gloss": "contest between different schools (of fencing, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女はその客情人の若旦那や取巻き芸者と共にわたしをも引具して諸処で友だち芸妓の開いているお座敷へ遊びの他流試合に行く。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "詮方無さに町道場に押入りて他流試合を挑み、又は支那人の家に押入りて賭場荒しなぞするうちに、やがて春となりし或る日の午の刻下りのこと諏訪山下、坂道の途中にて一人の瘠せ枯れたる唐人の若者に出会ひしに、しきりに叩頭して近付き来る。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二葉亭が春廼舎を訪問したのは、昔の武者修行が道場破りをするツモリで他流試合を申込むと多少似通った意気込がないではなかった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その折の骨を用いて他流試合に参ったごとく持ちかけ、そちの手にあまる者が飛び出て参るまで、当て身、遠当て、程よく腕馴らしやってみい」「心得ました。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "御取次ぎ下さりませい」「何じゃと、何じゃと、他流試合御所望でござるとな。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この前髪者が一手他流試合を所望じゃとよう。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、腕は優れていながら、操行のおさまらぬ職人の中などに、どうかすると、鑿と小刀を風呂敷に包み、「彫り物の武者修業に出るんだ」といって他流試合に出掛けるものがいたもんです。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "仏師の店のはなし（職人気質）",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年あたりから、書道の他流試合を横溝君とやることになり、何度も書を送るのですが、無手勝流といふわけか、一度も横溝君の方から送つて來ないのには困つたものですよ。",
              "citation": {
                "source": "海野十三氏の辯",
                "author": "探偵作家お道樂帳・その五",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つには広い世間を見て他流試合をしなくてはいけないこと。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "他流試合真剣勝負、この意気をもって致します覚悟……」「ははあさようかな。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊島大将を始め至って弱気ですぐ投げたり諦めたりしてしまうから、他流試合には全然ダメで、勝つのは尾崎と僕だけだ。",
              "citation": {
                "source": "文人囲碁会",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾崎は僕より弱くて、僕と尾崎が文人囲碁会チーム選抜軍のドン尻だが、他流試合ともなると、敵手のドン尻は大概二三級で、本来なら文句なしに負ける筈だが、全く、僕はよくガンバる。",
              "citation": {
                "source": "文人囲碁会",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が今迄他流試合をして、その図々しさに呆れたのは将棋さしのチームであった。",
              "citation": {
                "source": "文人囲碁会",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら亡夫は外国航路の船長で、大部分は海で暮して、たまに帰ると家よりも青楼で深酌高唱、時にはまだ学生の庄吉をつれて出たまゝ倅まで青楼へ泊めてしまふていたらくで、亭主と顔を合せるたびに剣客が他流試合をするやうな長々の生活に馴れてきたのだ。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "読書、旅行と共に、若い者相手の他流試合は、爺さんの道楽である。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日のように五人十人と他流試合につめかける。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "噂をきいて、江戸の剣客という剣客、腕に覚えの連中はあらかた他流試合に乗りこんだが、一人としてよい勝負になった者がない。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "事を好む輩は容赦なく破門せられる掟がきびしく行われており、村と村とが対立して他流試合に及ぶことなども、親睦の目的のほかには行われない例になっていたのである。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで房吉の道場を訪ねて他流試合を申込み、房吉にしたたか打ち倒されてホウホウのていで戻ったのである。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら亡夫は外国航路の船長で、大部分は海で暮して、たまに帰ると家よりも青楼で深酌高唱、時にはまだ学生の庄吉をつれて出たまま倅まで青楼へ泊めてしまうていたらくで、亭主と顔を合せるたびに剣客が他流試合をするような長々の生活に馴れてきたのだ。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう実験の一つとして、私は催眠術の先生のところへ他流試合に行って、催眠術が私にかかるかどうか試合をしてみようかと考えたこともあった。",
              "citation": {
                "source": "安吾巷談",
                "author": "巷談師退場",
                "note": "青空文庫"
              }
            },
            {
              "text": "それももう少し調べてお話するといゝのですが、一寸も調べる時間がないので、頼りない記憶で申上げるんですから、間違があるかも知れませぬが、それは他流試合だけに御勘辨を願ひます。",
              "citation": {
                "source": "應仁の亂に就て",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらが他流試合で、又惡口を言ふと反動が怖しいからやめます（笑聲起る）。",
              "citation": {
                "source": "應仁の亂に就て",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に日本の帝室と言ふやうな日本を統一すべき原動力から言つても、大變價値のある時代であつたといふ事は之を明言して妨げなからうと思ひます、まあ他流試合でありますからこれ位の所で御免を蒙つておきます。",
              "citation": {
                "source": "應仁の亂に就て",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "読書と思索とは剣術使の毎日道場にて竹刀を持つが如く、観察は武者修行に出でて他流試合をなすが如し。",
              "citation": {
                "source": "小説作法",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「他流試合希望の者、召し連れましてござります」　取り次ぎの武士は披露した。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
