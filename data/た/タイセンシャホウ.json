        "examples": {
          "standard": [
            {
              "text": "カモフラージュされた対戦車砲が火を噴き、不意を突かれた敵の先頭車両が爆発した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "牽引式の対戦車砲を設置するため、兵士たちはぬかるんだ地面を必死で掘り進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "敵の厚い装甲に対抗するため、より口径の大きな対戦車砲への更新が進められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし真剣な努力を以てすれば、戦車の整備に対し対戦車砲の整備は却って容易であり、戦車による敵陣地の突破は、十分に準備した敵に対しては今日といえども必ずしも容易とは言えない。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            }
          ]
        }
