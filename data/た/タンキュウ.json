[
  {
    "uuid": "8cda1915-ce59-5bd1-bc50-9a77f5f311e0",
    "entry": "単級",
    "reading": {
      "primary": "たんきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
