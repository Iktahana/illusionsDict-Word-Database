  {
    "uuid": "81600976-ee5a-5c93-a791-8a75ad2b01e7",
    "entry": "単式",
    "reading": {
      "primary": "たんしき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
