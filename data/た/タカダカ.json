    "definitions": [
      {
        "index": 1,
        "gloss": "very high",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして多くは高々と枝をかざして、そこにもここにもかしこにも人を待ちうけます――時にはあまりうるさく執拗に息づまるようななやましさをして桜は私の春の至るところに待ちうけます。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「資本主義は、極く少数の特に富有で強力な国家を極端まで押しやり、それらの少数国家は、世界住民の約十分ノ一か、多く見積って高々五分ノ一しか擁しないに拘らず、単なる『利札切り』で全世界を掠奪しているのである。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）というと婦人は背後へ高々と踵を上げて向うへ飛んだ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐中から浅黄地に白の唐草模様の大きな風呂敷を一枚引っぱり出して、両手で高々と吊し拡げた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "アノ高々と聳立している無電塔や議事堂も、事によると本物ではないかも知れない。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後にできた掘立小屋のような柾葦き家根の上にその建物は高々と聳えている。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寺門の左に、やや黄になった葉をつけたまま、高々とそそり立つ名物の「香い桜」。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぺつちやんこだよ」　といつておんつぁんが途方に暮れたやうに高々と笑つた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一羽の雄鶏は群れから少し離れて高々と時をつくった。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々がもとの位置に立ちかへると、彼れは手術衣の腕を高々と看護婦にまくらせた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "餘りですから、主人が引返さうとした時です……藥賣の坊主は、柄のない提灯を高々と擧げて、椎の樹の梢越しに、大屋根でも見るらしく、仰向いて、（先づは送つたぞ……）　と聲を掛けると、何處かで、（御苦勞。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金剛石だって、高々人間が大事がって秘っておくもんだよ、慾の固だね。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "するどい眼をして、ひげが二いろまつ白な、せなかのまがつた大将が、尻尾が箒のかたちになつて、うしろにぴんとのびてゐる白馬に乗つて先頭に立ち、大きな剣を空にあげ、声高々と歌つてゐる。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……其處で、昨日穿いた泥だらけの高足駄を高々と穿いて、此の透通るやうな秋日和には宛然つままれたやうな形で、カラン／＼と戸外へ出た。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "褄を高々と掲げて、膝で挟んだあたりから、紅がしっとり垂れて、白い足くびを絡ったが、どうやら濡しょびれた不気味さに、そうして引上げたものらしい。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見向いた時、畦の嫁菜を褄にして、その掛稲の此方に、目も遥な野原刈田を背にして間が離れて確とは見えぬが、薄藍の浅葱の襟して、髪の艶かな、色の白い女が居て、いま見合せた顔を、急に背けるや否や、たたきつけるように片袖を口に当てたが、声は高々と、澄切った空を、野に響いた。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、廂先へ高々と燈籠のごとくに釣った、白看板の首を擡げて、屋台骨は地の上に獣のごとく這ったのさえある。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　浅井さんも目出たい席ではあり、今夜はいつもよりお酒を過ごしているので、自分の言ったことに間違いのなかったのを誇るように、声高々と笑いながら話しました。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分には空を飛べる能力があるのかも知れないという子供にあり勝ちな空想も、豹一にとっては、いわば彼の虚栄の一つであり、悪人に追われて空を飛び逃げる夢を見た時は鼻高々と人に話し、為に嘲笑されると今にみろ飛んでやると思い、虚栄にうながされてひそかに奇蹟を信じ、奇蹟を待つことが屡々なのである。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ裾が引ずって、だらしがないじゃありませんか」　はっきり判らぬが、多分そんなことを言って罵ったらしく、雛妓は声はなくして、裾を高々と捲り上げ、腰から下は醜い姿となり、なおも、女中の箱屋に背中をせつかれせつかれして行く姿がやがて丈高い蓮の葉の葉群れの蔭で見えなくなった。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御殿女中上りの老婢に粧装られる二人の厚化粧に似合つて高々と結ひ上げた黒髪の光や、秀でた眉の艶が今日は一点の紅をも施さない面立ちを一層品良く引きしめてゐる。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこよ、しっかりッてこの娘――口へ出したうちはまだしも、しまいには目を据えて、熟と視たと思うと、湯上りの浴衣のままで、あの高々と取った欄干を、あッという間もなく、跣足で、跣足で跨いで――お帳場でそういいましたよ。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後に二人、朱の台傘を廂より高々と地摺の黒髪にさしかけたのは、白丁扮装の駕寵人足。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）「絵だけ描いていれぱ、当人も世間も助かるものを、紫の太緒を胸高々と、紋緞子の袴を引摺って、他が油断をしようものなら、白襟を重ねて出やがる。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "親仁は高々と押戴き、毎度何うも、といふ。",
              "citation": {
                "source": "彌次行",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚破秋草に、あやかしのついて候ぞ、と身構したるほどこそあれ、安下宿の娘と書生として、出來合らしき夫婦の來りしが、當歳ばかりの嬰兒を、男が、小手のやうに白シヤツを鎧へる手に、高々と抱いて、大童。",
              "citation": {
                "source": "彌次行",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）といふと婦人は背後へ高々と踵を上げて向ふへ飛んだ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この殿や国の鎮めと、御仏の法の護りと、言よさし築かしし殿、星月夜夜空のくまも、御庇のいや高々に、鐸の音のいやさやさやに、いなのめの光ちかしと、横雲のさわたる雲を、ほのぼのと聳えしづもる。",
              "citation": {
                "source": "篁",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そを懸命に踏み堪へて、左褄高々と紮げ、脛白き右足を擡げて、踏絵の面に乗せむとせし一刹那、「エイツ……」　と一声、足軽の棒に遮り止められ、瞬く間に裲襠を剥ぎ取られて高手小手に縄をかけられつ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、唯一つのたのしみだ）たかだか五枚六枚の隨筆の中にも、私の思ふこと全部を叩き込みたいと力むのである。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
