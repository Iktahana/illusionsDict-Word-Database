[
  {
    "uuid": "c87e14c8-cb4f-505d-96cd-255c99a38927",
    "entry": "高々",
    "reading": {
      "primary": "たかだか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞-と"
