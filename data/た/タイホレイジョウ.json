        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まだやはり逮捕令状のもとにある身分だったから、人に気づかれないように用心しなければならなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツから逃亡当時の逮捕令状のもとにまだあるのだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに多くの証拠がそろったのでオクスフォード殺人の逮捕令状が取れる。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジムは山賊の頭目、本国から追われる身の英国人、つまり英国で逮捕令状が出ている。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "特使が逮捕令状と拘引状とをもたらした時には、ジャヴェルはもう起き上がっていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "検事の署名のある逮捕令状は次のようだった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "本官の手に持っているのが逮捕令状であります。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来なら、本官ごときは口をきけませんが、逮捕令状がありますので、単なる業務執行です。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "逮捕令状が出ておる。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
