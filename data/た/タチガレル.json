        "examples": {
          "standard": [
            {
              "text": "湖畔の木々が立ち枯れる様子を、写真家は幻想的な作品としてカメラに収めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地中の水分が不足し、公園のシンボルだった大樹が徐々に立ち枯れていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "害虫の被害によって森の木々が立ち枯れるのを防ぐため、薬剤散布が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "伸び茂るもの、立ち枯れるもの、他物に絡みつくもの、みな自然にそうなっていた。",
              "citation": {
                "source": "山吹の花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジッと見て、石松の相に立ち枯れる若木の相があって身を食い枯らす悪虫が這っていると見てとったから、金を貸してやらなかった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
