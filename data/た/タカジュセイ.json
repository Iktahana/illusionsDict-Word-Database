        "examples": {
          "standard": [
            {
              "text": "昆虫が花から花へと飛び回ることで、効率的に他花受精が行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "他花受精によって生じた種子は、親とは異なる新しい特徴を持つことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "風媒花は、風によって大量の花粉を飛ばすことで他花受精の確率を高めている。",
              "citation": {
                "source": "幻辭AI",
