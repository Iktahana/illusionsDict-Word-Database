        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "タロ芋を供えて彼が祈ったのは、椰子蟹カタツツと蚯蚓ウラズの祠である。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "貰うものの種類によって、――魚だとか、タロ芋だとか、亀だとか、筵だとか、それに依って「貰う」という言葉が幾通りにも区別されているのだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「タロ芋六千箇」「焼豚三百十九頭」「大海亀三匹」……　それから、未だ見たこともない不思議な情景が現れた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は踊らなかったが、五羽の生きた※、油入｜瓢箪四箇、筵四枚、タロ芋百箇、焼豚二頭、鱶一尾、及び大海亀一匹を贈られた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母もベルもタウイロも私も海亀も豚もタロ芋も鱶も瓢箪も、みんなびしょ濡れ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花筵十三枚、団扇三十枚、豚五頭、魚類の山、タロ芋の更に大きな山を、土産として貰う。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "島の中央にタロ芋田が整然と作られ、その周圍を蛸樹やレモンや麺麭樹やウカル等の雜木の防風木が取卷いてゐる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "全島珊瑚の屑ばかりで土が無いために、全然タロ芋（之が島民にとつての米に當るのだ）の出來ない島も知つてゐる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の島々に比べてタロ芋の産出は豐かだし、椰子も麺麭樹も良く實り、食料は餘る位だ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "タロ芋の切つたのと、燻製らしい魚の切身が載つてゐた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "島の中央にタロ芋田が整然と作られ、その周囲を蛸樹やレモンや麺麭樹やウカルなどの雑木の防風木が取巻いている。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "全島珊瑚の屑ばかりで土が無いために、全然タロ芋（これが島民にとっての米に当るのだ）の出来ない島も知っている。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の島々に比べてタロ芋の産出は豊かだし、椰子も麺麭樹も良く実り、食料は余る位だ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "タロ芋の切ったのと、燻製らしい魚の切身が載っていた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらの食物はタピオカやタロ芋やバナナやパパイヤや、それから魚などだ。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "芋は南洋系民族の常食としているもので、池中に生じて居る所から推すと、今も大洋洲諸島の民族に大切の食糧であるタロ芋であったかも知れない。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
