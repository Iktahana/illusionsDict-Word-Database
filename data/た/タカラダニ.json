    "definitions": [
      {
        "index": 1,
        "gloss": "erythaeid mite (Erythraeoidea spp.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
