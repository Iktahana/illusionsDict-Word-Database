        "examples": {
          "standard": [
            {
              "text": "彼女と私はため年で、誕生日も近かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "クラスメイトの中には、ため年の友達がたくさんいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "たとえため年でなくても、お互いを尊重することが大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そのため年齢も二十二、三には見られるので、真の年はそれより二ツ三ツは取っているかも知れない。",
              "citation": {
                "source": "吾妻橋",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため年齢も二十二三には見られるので、真の年はそれより二ツ三ツは取つてゐるかも知れない。",
              "citation": {
                "source": "吾妻橋",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそのため年に二千フランばかりを得ていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
