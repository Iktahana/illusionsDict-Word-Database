        "examples": {
          "standard": [
            {
              "text": "ベランダで育てているプランターの多年草が、今年も見事な紫色の花をつけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一年草は枯れたら終わりだが、多年草は長い年月をかけて大株に育つ魅力がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "公園の植栽には、管理の手間を考えて丈夫な多年草が選ばれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これは宿根の多年草であるが、もとより種まきの世話もなく、年々歳々生い茂って行くばかりである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは宿根の多年草であるから、もとより種まきの世話もなく、年々歳々おい茂って行くばかりである。",
              "citation": {
                "source": "我家の園芸",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
