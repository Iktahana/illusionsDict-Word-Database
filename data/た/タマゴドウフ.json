        "examples": {
          "standard": [
            {
              "text": "暑くて食欲がない日でも、冷やした卵豆腐ならつるりと喉を通る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "卵豆腐に付属のタレをかけ、お好みでワサビを添えるとさらに味が引き締まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "懐石料理の先付けとして出された卵豆腐は、出汁の香りが上品で非常に美味だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "堅硬至極な片状の花崗岩壁も、卵豆腐のようにすくい取られたり、型で打ち抜いたかと思うほどの、釜状の大穴を穿たれたりしている。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚汁、冷さうめんに卵豆腐、魚フライ、食へないのは、山かけのみ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
