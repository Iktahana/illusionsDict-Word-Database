          "standard": [
            {
              "text": "「お、玉浮きがピコピコ動いてるぞ！魚が餌を突いてる証拠だ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "海釣りで波が高い時は、視認性の良い大きな玉浮きを使うのがセオリーだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "仕掛けを投げ込むと、赤い玉浮きが水面に浮かび、静かにアタリを待つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ありぎぬの　三重の子がさゝがせる　みづたまうきに　浮き　し　脂　落ちなづさひ　みなこをろ／＼に……（記）の場合も、瑞玉盞の同音聯想として、浮きが出て、浮き脂と続くところを、「し」を挿入してゐる。",
              "citation": {
                "source": "形容詞の論",
                "author": "――語尾「し」の発生――",
                "note": "青空文庫"
              }
            }
          ]
