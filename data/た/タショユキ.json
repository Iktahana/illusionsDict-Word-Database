    "definitions": [
      {
        "index": 1,
        "gloss": "going elsewhere",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
