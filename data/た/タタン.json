    "definitions": [
      {
        "index": 1,
        "gloss": "many items",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "千恵造の出奔を切っ掛けとして、児子家は以後多事多端であった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "事に処するは、非常に多端である。",
              "citation": {
                "source": "些細なやうで重大な事",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "水が湯となり氷となるが、人生の事情の多端錯雑、変幻極まりなきに比べてはるかに簡単であり、したがつて物に接するは、事に処するよりも単純であるが、それでも本当に物に接するといふことに徹底するには、大分の知慮分別と、鍛練修業を必要とする。",
              "citation": {
                "source": "些細なやうで重大な事",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "社會的の驅病法も多端である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其理由は足掛三年間の我が運命の多端なりし如く、又実に多端なり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "中古より降って始めて多端を肇む。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "學資の缺乏から早く專門に向はなければならぬ事情もあつたのだけれど、空を論ずることが多岐多端に流れて單純な自分の性情が到底それに堪へることも出來ず、又それを好まなかつたからである。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "不断に武装をつづけて、多端な政務に張り切っていた心が、ふと家臣を労ってやったことから、計らずも人の心に立ちかえって思わぬまに湧き上った涙だったに違いないのである。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人はその時と今とを胸に比較して感慨多端であったが、しかも互に避けて面にあらわさなかった。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "――自分は實際を白状すると、先刻から戰時多端の際であつたので、實は稍々心の平靜を失して居た傾がある。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――自分は実際を白状すると、先刻から戦時多端の際であつたので、実は稍々心の平静を失して居た傾がある。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊露記（三）　滞阪二日の間俗事多端殆ど寸隙がなかつた。",
              "citation": {
                "source": "旅日記",
                "author": "東海道線",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍬を取つて耕す、といふ仕事の形態そのものは單獨ではあるが、農業全體の過程においては、實に複雜多端に他の人々との相互關係に入り組んでゐる。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊太利の王室費は三・二〇〇・〇〇〇弗といふ事になつてゐるが、五六年このかた、経費多端で不足がちだといふ事を聞いてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "長男の鉄夫さんが花嫁をもらわれ、勝彦さんが出征され、松の茂った丘や玉川へ向う眺望のよい病床も多端であった。",
              "citation": {
                "source": "白藤",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "米使渡来｜以還政務の多端なることは古より無き所である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、多岐多端の現代に純一に近い生活を楽しんでいる作家があるとしたら、それは詠嘆的に自然や人生を眺めている一部の詩人的作家よりも、寧ろ、菊池なぞではないかと思う。",
              "citation": {
                "source": "合理的、同時に多量の人間味",
                "author": "――相互印象・菊池氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一月二十九日）　　　　　言語　言語は元より多端なり。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来斎藤茂吉氏の仕事ほど、多岐多端に渡つてゐるものはない。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "御国益論に抵抗す夫れから私共が亜米利加に行た所で、その時に日本は国事多端の折柄、徳川政府の方針に万事倹約は勿論、仮令い政府であろうとも利益あることには着手せねばならぬと云うので、その掛の役人を命じて御国益掛と云うものが出来た。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば人民の政は、ただ多端なるのみに非ず、また盛大有力なりといわざるべからず。",
              "citation": {
                "source": "学者安心論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより私立の事業は多端、かつこれを行なう人にもおのおの所長あるものなれば、わずかに数輩の学者にて悉皆その事をなすべきにあらざれども、わが目的とするところは事を行なうの巧みなるを示すにあらず、ただ天下の人に私立の方向を知らしめんとするのみ。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことさらに政府の事務を多端にし、有用の人を取りて無用の事をなさしむるは策の拙なるものと言うべし。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "春来、国事多端、ついに干戈を動かすにいたり、帷幄の士は内に焦慮し、干役の兵は外に曝骨し、人情恟々、ひいて今日にいたる。",
              "citation": {
                "source": "中元祝酒の記",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に教育の箇条は、前号にも述べたる如く極めて多端なりといえども、早くいえば、人々が天然自然に稟け得たる能力を発達して、人間急務の仕事を仕遂げ得るの力を強くすることなり。",
              "citation": {
                "source": "家庭習慣の教えを論ず",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下統一後に實行した始皇帝の事業は、中々多端であるが、要するに内政と外交とに區別することが出來る。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にこの頃のように俗用多端じゃ――」　こう云いかけた野村の眼には、また冷評されはしないかと云う懸念があった。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七日にいでたたんと長塚に約す。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "古袴など取り出でて十年昔の書生にいでたたんと支度ととのえなどす。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸には近しい親戚も無し、自分もだんだんに年をとって来るもんですから、お亀も娘のそばに行った方が好いという料簡になって、世帯をたたんで一緒に遠いお国へ行きましたよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
