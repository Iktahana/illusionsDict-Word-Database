    "definitions": [
      {
        "index": 1,
        "gloss": "Pacific seaboard",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
