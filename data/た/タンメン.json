    "definitions": [
      {
        "index": 1,
        "gloss": "Chinese-style stir-fried vegetable noodle soup",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これが了り、折からの雨の中、慶楽へ行って、焼売と鶏糸湯麺を注文、ともに大にして食ひ切れず。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座裏の飲食店街にある中華料理芳々亭の隅のテーブルにただ一人、今しもワンタンメンを食べ終ったのは西江葉子であった。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "餃子とタンメンが評判よ」「どちらも好きです」「そこで食べましょうか。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "柴崎はタンメンも食べた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦前の建物ですもの」　餃子とタンメンのあと、美枝子はその家へ柴崎を連れていった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「学校の周辺では、タンメンと餃子が好きです」　直子は笑った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「タンメンとは、なんだったかしら。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "書店をめぐって立ち読みをし、十二時三十分を過ぎて彼は好みのタンメンを食べる店に入った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "タンメンを食べて満足し、喫茶店エイヴォンへ向かった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめて、来々軒のチャーシュウ・ワンタンメンというのを食って、ああ、何たる美味だ！",
              "citation": {
                "source": "浅草を食べる",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "来々軒のワンタンメンと、大阪屋のシチュウとトースト、紅茶とカステラ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
