        "examples": {
          "standard": [
            {
              "text": "ダイエットのためにタップダンスを始めたが、予想以上にハードな運動量だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "駅前の広場で、若者たちがストリートタップダンスを踊って観客を沸かせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "タップダンスの基本ステップを習得するだけでも、かなりの練習期間を要した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "伊代は化粧が終るとタップダンスの真似をして皆を笑わせたりした。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いま舞台の上に、赤星ジュリアの右側の方に、軽いタップダンスを踊っている燕尾服の俳優は、紛れもなく西一郎だった。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "惑星アロハをめぐる小遊星のタップダンス程度なのが今の世の流行であり芸術だ。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
