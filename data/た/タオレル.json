    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to fall (over, down)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『う……うぬ、穢れだ』滿身の怒氣を込めて、身を※くと、無殘、女は胸を一つ突かれて、仰向にばつたり倒れる。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの工場が倒れる一方に他の工場は新に建てられて居る。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "螺の腹でえび蔓の背をした老いの身体は後の丘の芝にいまや倒れるばかりに仰向いて天空を見上ぐるのであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "にはかにくっきり白いその羽根は前の方へ倒れるやうになりインデアンはぴたっと立ちどまってすばやく弓を空にひきました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "室中のひとたちは半分うしろの方へ倒れるやうになりながら腰掛にしっかりしがみついてゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然なピストルの音とともにこの男が倒れる。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の手前兄夫婦の手前、泣くまいとこらえてようやくこらえていた僕は、自分の蚊帳へ這入り蒲団に倒れると、もうたまらなく一度にこみ上げてくる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はどうかして一度、牧水氏と思ひきり酒を飮み、倒れるところまでやつて見たいと考へてゐた。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、ちょっとしたはずみで一人が倒れる。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝境内　嘉助は五郎蔵の一太刀、肩先に受けアッと言って倒れる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しも浪人者は若侍の一太刀受けてあッと倒れる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝妙見――　仲蔵、バッタリ倒れる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と忽ち、　面を殴られて、ワッと倒れる。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "山下町の支那語韻の街まで彼女を追跡すると支那劇場の喧噪な音楽の前でマリは東洋族を驚かすような音を立てて倒れると、地上を寝床にして唇から泡を吹きながらタヌキ寝人を始めた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　馬が日射病にかかって倒れる、それを無理に引ずり起して頭と腹と尻尾を麻縄で高く吊るし上げて、水を呑ませたり、背中から水をぶっかけたりしている。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "にはかにくっきり白いその羽根は前の方へ倒れるやうになりインデアンはぴたっと立ちどまってすばやく弓を空に射ました。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "室中のひとたちは半分うしろの方へ倒れるやうになりながらしっかりしがみついてゐたのです。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は倒れるまで働いて、きっと阿母さんに不自由はさせまい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "倒れるまで働くと云った歌女代の言質を取って、決してべんべんと寝そべっていることはならない、仆れるまで働いてくれと、真っ蒼な顔をして寝ている歌女代を無理に引き摺り起して、朝から晩まで弟子たちの稽古をつづけさせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸棚が倒れる轟音、硝子が割れる音、壁がどさる音。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "バタバタ倒れる者が多くなる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見す見す傷つき倒れる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銃は倒れる男の身体について落ちて行った。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度は誰れが倒れるだろう……女か、子供か？",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらで引鉄を振りしめると、すぐ向うで豚が倒れるのが眼に見えた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには、落盤にへしゃがれるか、蝕ばまれた樹が倒れるように坑夫病で倒れるか、でなければ、親爺のように、ダイナマイトで粉みじんにくだかれてしまうかだ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹の倒れる音響に驚いて小鳥がけたたましく囀って飛びまわる。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "にわかにくっきり白いその羽根は前の方へ倒れるようになりインデアンはぴたっと立ちどまってすばやく弓を空にひきました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "室中のひとたちは半分うしろの方へ倒れるようになりながら腰掛にしっかりしがみついていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この現象は短時間で消え馬はたおれるというのである。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
