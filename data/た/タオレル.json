[
  {
    "uuid": "72bab266-0de9-5db7-8f0d-fbeea3f5bebf",
    "entry": "倒れる",
    "reading": {
      "primary": "たおれる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
