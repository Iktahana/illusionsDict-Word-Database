      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "another village",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "感心して聞く庄屋や其他村人。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｔ　数日の後――Ｓ＝村はずれの街道　庄屋や六助お絹の若夫婦や、　其他村人達に送られて、　武蔵と団九郎が旅立ちであります。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあい、他村がんち、糞がんち。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は病氣のためにしじゆう學校をやすんでゐたのだけれどその小學校の代表者だつたので、他村からの優等生がたくさん集る高等小學校でも一番になるやう努めなければいけなかつたのである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他村のあぞれ者四五名を語らって、そのテキサス移民の鍬開きをすると出かけた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫁入前には誰しも必ず一度は他村へモゴルに行ったものだという。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また同郡｜高田村は、白昼にも他村人が一人で往きかぬるさびしき所なり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は参拝や祭礼にいかに多銭を費やすも、みなその大字民の手に落ちたるに、今は然らず、一文失うも永くこの大字に帰らず、他村他大字の得となる。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "西牟婁郡｜南富田の二社を他の村へ合祀せしに、人民他村へ金落とすを嫌い社参せず騒動す。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "近く往てみると、其村は勿論、小山を一里ばかり越た他村の者共迄、其離れ屋を取卷き耳を側立て、屋内の音を聽くので、慓悍な輩は小川を渉り、石垣を攀ぢ付て爭ひ聽き、交る／＼下り歸つて、今の息は長かつた、是からどうするらしいと、俟ち構えた群衆に報じ誇る、中には六十過た老人も少なく無つたと、叔父が予に語つた。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "タバンの改築の相談、マガレツトの出京、偽画家の遁走、馬蹄鍛冶屋父子の騒動、Ｒ漁場主の更迭――の他村の出来事は大方マメイドから聞きましたが、これが小生出京以来五ヶ月のあの平和な村の出来事かと思ふと、幾多の感慨を覚えて止みません。",
              "citation": {
                "source": "附「歌へる日まで」",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜があけると近所の人々は寺へ行つたり無常道具を買ひに行つたり、他村の姻戚への知らせに行つたりして家には近所の女房が二三｜人義理をいひに來て居た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺ら方へはまあだ、他村から來る頃ぢやあんめえな」「おとつゝあ等がにや分るもんかよ、そんなこと」「そんでも、他村から來んだつて云つけぞ、支度して來んだつて俺ら今日頭髮結つてゝ聞いたんだぞ」「さうえ者な、さうえ者よ」「俺ら行つてんべ、よきも行つて見ろなあ、姉と一｜緒に」おつぎは獨語した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "維新の頃までは若しも他村の男が通つてゞも來れば其村の若い衆の繩張を冐したことに成るので散々に叩きのめして其上に和談の酒を買はせたものだといふ。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども是れ山間の一小村にして、四囲｜層巒を以て繞らし、自然に他村と相隔絶したるの致せしのみ。",
              "citation": {
                "source": "国民と思想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "今を距ること三十年、一度び他村との交通を開きてより、忽ち衰廃して前日の強盛は夢の如く、泡の如く、再び回へすべからざるものとなりぬ。",
              "citation": {
                "source": "国民と思想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "性質の穏かな、言葉数の少ない、慈愛心の深い人で、殊に学問――と謂ふ程でも無いが、御家流の字が村にも匹敵するものが無い程上手で、他村への交渉、飯山藩の武士への文通などは皆この人に頼んで書いて貰ふのが殆ど例になつて居たといふ事である。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角重右衛門は此頃からそろ／＼評判が悪くなつたので、その祖父の孫に対する愛を知つて居る人は、他村の者までも、重右衛門の最後の必ず好くないといふ事を私語き合つたのである。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃ、皆｜他村の衆じゃ。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "其年の三月三十日は、例年の如く證書授與式、近江屋の旦那樣を初め、村長樣もお醫者樣も、其他村の人達が五六人學校に來られた。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは恰度今の並木孝子の前の女教師が他村へ転任した時――去年の十月であつた。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔭で他村には伝播しなかつたが、住民の約四分の一が一秋の中に死んだ。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其年の三月三十日は、例年の如く証書授与式、近江屋の旦那様を初め、村長様もお医者様も、其他村の人達が五六人学校に来られた。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――開業医の加藤は、もと他村の者であるが、この村に医者が一人も無いのを見込んで一昨年の秋、この古家を買つて移つて来た、生村では左程の信用もないさうだが、根が人好のする男で、技術の巧拙よりは患者への親切が、先づ村人の気に入つた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――開業醫の加藤はもと他村の者であるが、この村に醫者が一人も無いのを見込んで一昨年の秋、この古家を買つて移つて來た。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔭で他村には傳播しなかつたが、住民の約四分の一が一秋の中に死んだ。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「またそんなことをいふ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「またそんな渋いことかあ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもまたそんなにして助けてあげるよりはこ〔の〕まゝ神のお前にみんなで行く方がほんたうにこの方たちの幸福だとも思ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あなたそんなことあって。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
