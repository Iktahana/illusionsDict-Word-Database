[
  {
    "uuid": "c13af872-93c8-554e-9fea-69c3ccbec383",
    "entry": "他村",
    "reading": {
      "primary": "たそん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
