    "definitions": [
      {
        "index": 1,
        "gloss": "to save",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "風は害虫を攘ひ、花粉の交媒を助ける。",
              "citation": {
                "source": "風と裾",
                "author": "――何人か良案はないか？――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらにひろがる高い雑木の梢を見た、あすこまで昇ればまづ大低の洪水なら大丈夫だ、そのうちにきっと弟が助けに来る、けれどもどうして助けるのかなとおれは考へた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は、町から、水泳で子供らの溺れるのを助けるために雇われて来ているのでしたが、何ぶんひまに見えたのです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は私はその日までもし溺れる生徒ができたら、こっちはとても助けることもできないし、ただ飛び込んでいって一緒に溺れてやろう、死ぬことの向う側まで一緒についていってやろうと思っていただけでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも近頃聞いた話であるが、稲の生長を助けるアゾトバクテルという黴菌がある。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "市街の煤煙と同様に火山の煙も霧の発生を助けるものである。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭の活け方には色々あるが、要するに炭を並べて真中に縦穴を作り穴の下の方に横穴を作れば全体が丁度ストーヴの煙突と同じ作用をして空気の流通を促し炭の燃えるのを助ける訳になる。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしを助けるのですって。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはこのやうな意識を確認し、かつ表彰し、そしてそれを用心ぶかく慣習のなかへ据ゑつけるのです、そのやうな假定を助けるために、古代の慣習だの、その慣習の名殘りのやうなものだのを求めたり、或ひは埃及の死者崇拜のなかにまでかかる關係の豫知を喚起したりしながら。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な書物を書き有名な絵をかいた偉大な日本人は、自分らを助ける協会などを要しなかった。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が親爺の嫌な仕事を懸命で助けるのも、そんなところからきていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺れが満洲へ来とったって、俺れの一家を助けるどころか家賃を払わなきゃ、住むこたならねえと云ってるんだ。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔たぐれでばがり居で、一向仕事｜助けるもさないで。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて夫の光国が来合わせて助けるというのが、明晩、とあったが、翌晩もそのままで、次第に姫松の声が渇れる。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう簡単にはゆかないまでも、少なくもこういうふうに考えてみることによってこの二つの映画の了解を助けることにはなるであろうと思われる。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手ぬぐい一筋でも箸一本でも物は使いよう次第で人を殺すこともできれば人を助けることもできるのは言うまでもないことである。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は、町から、水泳で子供らの溺れるのを助けるために雇はれて来てゐるのでしたが、何ぶんひまに見えたのです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は私はその日までもし溺れる生徒ができたら、こっちはとても助けることもできないし、たゞ飛び込んで行って一緒に溺れてやらう、死ぬことの向ふ側まで一緒について行ってやらうと思ってゐただけでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "グララアガア、グララアガア、その恐ろしいさわぎの中から、「今助けるから安心しろよ。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とてもこれを助ける薬はありません」　これを聴いた病人は言いました。",
              "citation": {
                "source": "医者と病人",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　親父は急に箸を立てて、にらみつけて、「だから、なお助けるのだ。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこれと反対に隅田川をいよいよ隅田川らしい好風景にしようと思って、沢山桜の出崎を拵えてみたり、川を浅くして菖蒲を植えて見たり、都鳥の飼場を設けたりして、水の流れは、ただ風致を助けるためとばかり気取って曲りくねらせるとする。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御新姐樣、此の上の御無理は、助けると思召しまして、其のお歌を一寸お認め下さいまし、お使の口上と違ひまして、つい馴れませぬ事は下根のものに忘れがちにござります、よく拜見して覺えますやうに。",
              "citation": {
                "source": "片しぐれ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御新造樣、此の上の御無理は、助けると思召しまして、其のお歌を一寸お認め下さいまし。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "助けると思召して後生でございます、私どもへ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯨を食べるならば一｜疋を一万人でも食べられ、又その為に百万疋の鰯を助けることになるのだが甘藍を一つたべるとその為に青虫を百疋も殺していることになる。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "賓人よ、私の心の千分の一でもお察しになつたら、どうか奧樣と日出雄樣を助けると思つて、今夜の御出帆をお延べ下さい。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄を助けるには何事も只犠牲になる。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、ちょっと……」　こんどは本当に頭をかきながら、「――たすけると思って、貸していただけませんか」　道子は急に立ち上って、茶の間を出て行った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――雪子をたすけるか、中之島公園へ行こうか」　と、迷ったのだ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
