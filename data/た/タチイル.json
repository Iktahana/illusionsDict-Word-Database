    "definitions": [
      {
        "index": 1,
        "gloss": "to enter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしこの疑問以上に立ち入る事は科学者の領域以外に踏み出すと思う。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私は今ここでそういう岐路に立ち入るべきではない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（停留所で待つ時間の確率を論じるには、もう少し立ち入る必要があるが、これは略して述べない。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金米糖の物理から出発したのが、だんだんに空想の梯子をよじ登って、とうとう千古の秘密のなぞである生命の起原にまでも立ち入る事になったのはわれながら少しく脱線であると思う。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その周囲の芝生に立ち入るなと書いた明白な立て札はあるが、事実は子供も大供も中供もやはり芝生に立ち入って水の面をのぞかなければ気が済まないのである。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、結局、文楽や俳諧のようなものは、西洋人には立ち入ることのできない別の世界の宝石であろう。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれらの重要な点にもここでは立ち入るべき余裕もなく、またそれはおそらく自分の任でもないから、全然省略して触れないことにする。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはいろいろ話しかけて見ましたが、ロザーロはどうしてもかなしそうで一言か二言しか返事しませんので、わたくしはどうしてももっと立ち入ってファゼーロと二人のことに立ち入ることができませんでした。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう片側には石や岩の破片が散らかり放題といったふうで、立ち入ることもできない。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけに、あの四月二十四日の宵、うちの診療室に立ち入る友人の姿を目にしていささか驚いたのである。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて今日あの谷に立ち入る旅の者が　赫々たる窓二つから目にするは狂いうごめく無数の大影、　外れ調子の旋律に乗りながら。",
              "citation": {
                "source": "ポオ異界詩集",
                "author": "エドガー・Ａ・ポオ　Edger A. Poe",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士｜気質の強いかれらの屋敷では、遊里に立ち入ることは厳禁されていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ寺でやる仕事で、町方が迂闊に立ち入るわけにも行かねえから、わっしも指をくわえて見物していましたが、今に何事か出来するだろうと内々睨んでいると、案の通り、こんな事になりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "門前の左手にある地蔵堂は、寺社方の注意か、寺の遠慮か、板戸や葭簀のような物を入口に立て廻して、堂内に立ち入ること無用の札を立ててあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは全篇を通じて、別れた妻に呼びかけてゐるのであるからさうして改めて妻に自分を語る調子で書かれてあるのだから、今更妻の心に立ち入る必要はなく、自分を語ることゝ事件の報告だけで足りるので、それで小説的効果も認められるが、殊に前半であくどい気持の重複を感ぜさせらるゝのは欠点だと思ふ。",
              "citation": {
                "source": "海浜日誌",
                "author": "六月創作評",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、男員いっさい女座員のへやに立ち入るまじきこと、ならびにまた女座員、いっさい男員べやを犯すまじきこと。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "娯楽室は夕方まで閉まっているはずだし、空き部屋には立ち入るなと、晩餐会後におこなわれた、寮生活のオリエンテイションで注意を受けた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから宣和年間に至るまで年を重ぬること百五十、故宮はいよいよ荒れに荒れて、金鑾殿のうしろから奥へは白昼も立ち入る者がないようになった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "――尤もまア新町には吾家の者が居ないんだから話にならないでせうが、隣りの青町……」「無論さうなんですがね、銀行としては其処まで立ち入るわけには行きませんしね。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "現象の物理的原因にだんだん立ち入るようになった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡ての出来上っている諸問題をば同じ資格を有つ隣人として公平に待遇しようとするならば、却って何かの問題に立ち入る手懸りを失って了うであろう。",
              "citation": {
                "source": "性格としての空間",
                "author": "――理論の輪郭――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたがたがそれを受けようと受けられまいと、それはわしの立ち入る限りではない。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより後我々は歴史を構成する三つの契機としての事實としての歴史、存在としての歴史、ロゴスとしての歴史の間に於ける辯證法的な關係を更に詳細に究明するに際し、それぞれの機會の與へられるに從つて、ディルタイ及び彼の先蹤者たちの批判にも立ち入るであらう。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "また実際私は他人の思想に立ち入ることは好まないから。",
              "citation": {
                "source": "人間と云ふ意識",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "枳園の形装は決してかつて夜逃をした土地へ、忍びやかに立ち入る人とは見えなかった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは目見以上の身分になったからは、今より後市中の湯屋に往くことと、芝居小屋に立ち入ることとは遠慮するが宜しいというのであった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわたくしは強ひて深く此等世系の問題に立ち入ることを欲せぬのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "内生活に立ち入る様な未来もまるで示してないことはないのです。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし神社｜仏閣に不遠慮に立ち入る。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "……紙帳こそは拙者の家、わが城砦、この中にそちたちいる限りは、拙者身をもって護ってとらせる！",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
