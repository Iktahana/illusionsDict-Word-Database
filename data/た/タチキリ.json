[
  {
    "uuid": "c1641a03-80ec-5743-9e47-083c76c31c9a",
    "entry": "断ち切り",
    "reading": {
      "primary": "たちきり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
