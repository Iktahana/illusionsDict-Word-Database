        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "深夜に大音量で音楽を流すのは、近所の人にとって非常に他人迷惑な行為だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「公共の場所で騒ぐのは他人迷惑だから、静かにしなさい」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歩きスマホは衝突の危険があり、周囲の人にとっては他人迷惑極まりない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "願わくは酒を売ろうとした私の過失を君たちにおいて繰り返すことなかれ、いわんや自ら不誠実にして他人迷惑な囮商略を弄するものとなってはならない。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣った魚の網ビクを、さも自慢顔にぶるさげているのも他人迷惑になる。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
