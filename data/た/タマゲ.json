        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "でつかい建物や、ごてごてした裝飾には口をあけておつたまげても、こんな幽邃の美には一向に感心しない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「張大人は野蛮だからよ……さぞ、内地の人間が見たら、おったまげるこったろうな。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、彼等は、たまげちゃったような中隊長の散解の号令をきいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その彼が、たまげた話し方をした。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の邪鬼の小便ぁたまげだ永ぃな。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "がやがやいい罵る人ごみの中を駅員があっちでもこっちでも手を上げたり下げたりしたかと思うと、婆やは飛び上らんばかりにたまげさせられた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいつぁあ、たまげた！",
              "citation": {
                "source": "のろまのハンス",
                "author": "――むかしばなしの再話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "でつかい建物や、ごてごてした装飾には口をあけておつたまげても、こんな幽邃の美には一向に感心しない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はたまげてしまった。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮒の甲焼をするだって言ってた」　花田は「えっ」とたまげた顔をしていましたが、「あいつ知っとるのかなあ」と呟きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふんに、おったまげた酒じゃにゃアか。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上さんはぶつたまげてしまひました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まったく、あんなところで出くわしてたまげたよ。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「たまげたね、ウィリアムソン、この方には言うことが何もない。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君か、たまげたぞ！",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "コムデックスの会場では早くもミップスのＲ４０００（吉野家流でスピードを稼ぐ、例のＲＩＳＣ方式のマイクロコンピューターだ）の上でＷｉｎｄｏｗｓＮＴが動いていたそうで、これはこれで実にたまげた話ではある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり意外で、わしはたまげてしまったよ」「かけは僕の勝ちだったね。",
              "citation": {
                "source": "少年探偵　呉田博士と与一",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい、そのすっかり覆面をしていたものですから、それにわたしはもうのっけからたまげてしまって……」「泥棒の右の手はあったかおぼえとるか？",
              "citation": {
                "source": "祭の夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "手傳ひに行つた山田のおつ母が、衣裳を見てぶつたまげて、蟲干しに何日かかるべつて心配しとつたが、おれもトラツクに荷物を積みながら、これが皆米の俵の化けたのかと思ふと、何だか妙な氣がしたよ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでレントゲン室を物珍しげに覗いていた患者たちは、寒さのためでもあったろうが、顔をば漬かりそこなった茄子のような色にして、このものものしい光景にたまげつつあたふた逃げ去った。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも太郎や次郎の大きくなったのには、たまげた。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十余時間ぶりに御飯がはいつたので胃がたまげて鳴つてゐる、どうだ、うまからう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はあ、何ともはあ……どうぞお前から皆によろしくいってくんさんしょ、いずれ何とかする気では居んが」「そりゃ構うめえが……何だね……おれあたまげたぞ全く、どうなるかと思ったて。",
              "citation": {
                "source": "田舎風なヒューモレスク",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちみち俺はゆずらない」　ひっくり返るほどたまげながら、「こうなりゃ、ほかになんとしよう」アクリーナは「マクシムの額とワルワーラの編髪に祝福した」　若い者たちはアクリーナの思いやりのある才覚で、こっそり教会で婚礼の式をあげることが出来たのであった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "後生の者は、ハイパーカードの実物にたまげてから、時間軸をさかのぼってこの技術にいたるリンクをたどり、テッド・ネルソンのハイパーテキストのアイディアがあったことを知る。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アップルのスティーブン・ウォズニアックは、当初６８００で自分の手作りマシンを設計していたが、６５０２の安さにたまげてこちらに乗り換えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "』請願者はおったまげてしまう。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」かう、藁をかかへた、行きずりの老婆が、おつたまげて声をかけた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
