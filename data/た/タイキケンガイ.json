    "definitions": [
      {
        "index": 1,
        "gloss": "outside Earth's atmosphere",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それで二五〇マイルの高度に達した親子ロケットは、既にその行程の半ばを、大気圏外に乗り出したのである。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肝腎なのはＸ線、極紫外線、放射線などであって、それ等は大気圏外に出なければ観測が出来ないのである。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大気圏外の世界は、人類未到の世界である。",
              "citation": {
                "source": "比較科学論",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アマゾン型とはいったが、物理学の場合は、自然現象のすべてが対象であるから、われわれの身辺から大気圏外までのすべてが「アマゾンの流域」である。",
              "citation": {
                "source": "比較科学論",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだこの再発光の機巧はよく分っていないが、大気圏外も、われわれの身辺も、ともにアマゾンの流域であるという一つの例といって、いいであろう。",
              "citation": {
                "source": "比較科学論",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間を大気圏外の空間にまで打ちあげ、それを無事に回収したのであるから、これは科学の強力さを、いかんなく示した大実験であった。",
              "citation": {
                "source": "犬がなくとガラスがこわれるか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大気圏外で叫んでいるようだ。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "火星基地の地下工場を脱出すると、あなたはロケット噴射の出力を更に上げ、大気圏外へ飛び出した。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
