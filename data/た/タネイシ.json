        "examples": {
          "standard": [
            {
              "text": "テラゾー仕上げの床に色とりどりの種石を散りばめ、モダンな雰囲気を演出する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "左官職人が丁寧に種石を混ぜ込み、滑らかな人造大理石の壁を作り上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "洗い出し仕上げの玄関アプローチに、落ち着いた色合いの種石を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
