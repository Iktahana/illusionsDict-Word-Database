  {
    "uuid": "85559ccd-2448-535d-a104-60f6ec89bd40",
    "entry": "炊いたん",
    "reading": {
      "primary": "たいたん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "nimono",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "苦うてただ炊いたんぢや食へやしません。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まぜごはんは食が進むと思って、今日は余計に炊いたんですけれど、この通りですわ。",
              "citation": {
                "source": "果樹",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「太郎さんのお母さん、今日は味噌汁炊いたんよ、うまげなかざがするがい。",
              "citation": {
                "source": "大根の葉",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日あたしが炊いたんだから、今日は譲治さんが炊いてもいいわ」「じゃ仕方がない、炊いてやろうか。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あ、いけない、追いせまって来た」「え、本当で、そいつア偉い、へえ、あいつをはたいたんで、偉いなあ、大できだ！",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでモルモットが１ぴき手をぱちぱちとたたいたんだけど、ひかえていたやつらにたちまち取りおさえられてね。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼうや、舌をお出しとか、いい子だからねとかなんでもなにかしたいたんびに、『ああ、おしよ』と言ってくれる。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして「おや、タッジオ、きみもやっぱりまたいたんだねえ。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だって城介君は、女の横面をたたいたんだろうな。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとすると修道院長をひっぱたいたんじゃないかしら？",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
