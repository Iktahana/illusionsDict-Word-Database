        "gloss": "short-legged",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これで君もわかるだろう、ほら、長い胴体に引き替え極めて短足なのだ。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、あのならずものも、やつぱり救へなかつたかと言つて、ホームスさんはたんそくしました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　伊那丸以下の者、でる声は、ただこのたんそくばかりであった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
