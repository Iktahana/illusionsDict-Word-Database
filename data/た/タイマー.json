        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "パスタが茹で上がる時間を忘れないように、キッチンのタイマーを7分にセットした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お母さん、タイマーが鳴ってるよ！オーブンの火を消して！」と子供が叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "扇風機のタイマー機能を使い、寝入った頃に自動で切れるように設定しておいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "オールド・タイマーが結集したＧＯ社の手書きシステム、ＰｅｎＰｏｉｎｔによる挑戦は、僕には解体した幻想を再び築き上げようとする試みに見えるのです。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二十九日（木）推定脳細胞総数　１４９億３９００万個　一番ヶ瀬隼人は窓から差し込むうすくやわらかい日の光で目を覚し、毛布の中で陽子に思いを馳せながら二回マスターベーションに耽った後ようやくベッドから抜け出してシャワーを浴び、それが済むとオーブンにサンドイッチを入れてタイマーを５にセットした。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でいうならパート・タイマーであろう。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような状態を、三脚につけた一眼レフのセルフ・タイマーで撮ればいい。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "画角をきめセルフ・タイマーをかけ、冬彦は自分の位置へ小走りに戻った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はヨシオがタイマーをかけにいった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイマーをかけてシャッター・ボタンを押し、四人のところへ戻ると思わせながら、途中から彼はプールへ走って、水へダイヴした。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がセルフ・タイマーをかけてプールに飛び込んだ写真では、ほかの四人の誰もがプールに顔を向け、しかも全員が笑っていた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "セルフ・タイマーをかけてファインダーをのぞきなおし、ぼくは小川に言った。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
