        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼の新らしい詩の表現は、丁度、愛する妻と共に日暮れの街を歩きながら、楽しい買物の話をするやうな、平易な親しさの中に、力強い情熱のひびきをこもらせたものであつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんぼ楽しいの歌でしょう』と言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『人生でいちばん楽しい瞬間は』とゲーテが言ってる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "八雲は縁側に立ってそれに聞き惚れ、『いかに面白いと楽しいですね』と言って喜んだが、また『私、心痛いです』と言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アスハルトの道路と、コンクリートの建築と、人工暖房装置の中に住んでる近代の人々にとつて、おそらく冬は季節の最も楽しい享楽期であらう。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠方から翁の指尖はこつに嵌ったその飛躍の線に沿うて撫で移って行くと音楽のような楽しいリズムを指の腹に感ずる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはいっそ、そっとこのままにしておいて時の捌きを待つよりしかたがないと、思い諦めて、楽しいようなはかないような逢瀬を続けています。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」○フレッシュの苺クリーム、ブライトな日傘、初夏は楽しい。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでおれは美しい正方形のつめくさの絨氈の上で夕方までいろいろ踊るといふのはどうだ　あんな単調で暑苦しい蔬菜畑の仕事にくらべていくら楽しいかしれないと考へた。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子と僕との楽しい関係もこの日の夜までは続かなく、十三日の昼の光と共に全く消えうせてしまった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大戦」と、ルパートのいわゆる「戦いはこれから始まるのだ」のその「戦い」との間に、この楽しい球技の戦いが挿入されている。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「親分が俺達に家を建てて呉れるって話よ」　「そうなると楽しいわね」　「お前がいつも言ってたな。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「やくざ稼業なンて、他で見る程楽しいものじゃねえ」　「そんな事位え、俺だって判ってるよ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "信じるだけでも、今の僕達には楽しいんだからね。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しすべてがそんな風に行つたら、ほんとにどんなに楽しい、どんなに美しい生活だか知れないな。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくこの時が彼の最も楽しい時で、また生きている気持ちのする時であろう。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも彼自身はそれを自分の楽しい義務のように考えているかのように見える。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のいるところからいつも人の窓が見られたらどんなに楽しいだろうと、いつもそう思ってるんです。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして僕の方でも窓を開けておいて、誰かの眼にいつも僕自身を曝らしているのがまたとても楽しいんです。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに酒を飲むにしても、どこか川っぷちのレストランみたいなところで、橋の上からだとか向こう岸からだとか見ている人があって飲んでいるのならどんなに楽しいでしょう。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃は河鹿と同じくそのころの渓間をいかにも楽しいものに思わせる鳥だった。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは見えているというよりも、吉田が無理をして見ているので、それを見ているということがなんとも言えない楽しい気持を自分に起こさせていることを吉田は感じていた。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "政元はそれらの上に念を馳せるでもない、ただもう行法が楽しいのである。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "碁を打つ者は五｜目勝った十目勝ったというその時の心持を楽んで勝とうと思って打つには相違ないが、彼一石我一石を下すその一石一石の間を楽む、イヤそのただ一石を下すその一石を下すのが楽しいのである。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事でも目的を達し意を遂げるのばかりを楽しいと思う中は、まだまだ里の料簡である、その道の山深く入った人の事ではない。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "当下に即ち了するという境界に至って、一石を下す裏に一局の興はあり、一歩を移すところに一日の喜は溢れていると思うようになれば、勝って本より楽しく、負けてまた楽しく、禽を獲て本より楽しく、獲ずしてまた楽しいのである。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間が何千円に当った訳だ、なぞと譏る者があるが、それは譏る方がケチな根性で、一生理屈地獄でノタウチ廻るよりほかの能のない、理屈をぬけた楽しい天地のあることを知らぬからの論だ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校時代の友人とは、共に酒を飲んでも楽しいが、中学校時代の友人とは逢って話しても妙に窮屈だ。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、園子をお湯にいれるのが、私の生活で一ばん一ばん楽しい時だ。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "要らざる時に東京から、のこのこやって来て、この吉田の老若男女ひとしく指折り数えて待っていた楽しい夜を、滅茶滅茶にした雨男は、ここにいます、ということを、この女中さんにちょっとでも告白したならば、私は、たちまち吉田の町民に袋たたきにされるであろう。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
