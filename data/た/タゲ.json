    },
    "definitions": [
      {
        "index": 1,
        "gloss": "looking as if one wants to ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自棄のない詩は神の詩か凡人の詩かそのどつちかと僕が決めたげます",
              "citation": {
                "source": "（テンピにかけて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういへば、ニコニコの底に、なんだかひどく悲しさうな色があつたのだが、また、何か云ひたげで遂に云はずじまひであつたが、人の悪口を云つてはならぬものとばかりに、相変らずの気持であつたのだらうと、幾分不憫でもあつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宰は瞬間まったくの小児のような泣きべそを掻いたが、すぐ、どす黒い唇を引きしめて、傲然と頭をもたげた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてなんとなく空虚と倦怠を感じると同時に妙な精神の不安が頭をもたげて来る。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ううむ、ううむ、と大袈裟に唸りながら、めちや苦茶に鎌を振りまはして、時々、あいたたたた、などと聞えよがしの悲鳴を擧げ、ただもう自分がこのやうに苦心慘憺してゐるといふところを兎に見てもらひたげの樣子で、縱横無盡に荒れ狂ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひところ世界中に流行したアメリカ映畫、あれには、こんな所謂「純眞」な雄や雌がたくさん出て來て、皮膚感觸をもてあまして擽つたげにちよこまか、バネ仕掛けの如く動きまはつてゐた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵に對してこの無數の毒蛇は、素早く一樣に鎌首をもたげ、しゆつしゆつと氣味惡い音を立てて手向ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんの胸中に眠らされてゐた何物かが、この時はじめて頭をもたげたやうにも見えるが、しかし、それは何であるか、筆者（太宰）にもわからない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜間倦んじ疲れて、懈怠の心が起らうとする時、頭をもたげて燈光の中に先生の黒い痩せたお顏を瞥見すると、いまにも抑揚頓挫のある言葉で話しかけようとしてゐられるかの如く思はれる。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその※のうつくしさふと物音におどろきて午睡の夢をさまされし牡牛のごとも、あどけなくかろやかにまたしとやかにもたげられ、さてうち俯しぬ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶褐色に変ったげんげやばらの花束や半分喰い欠いだ林檎もあった。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて絵具入の箪笥の上の鏡を見出し、それに向きてネクタイを直さんとし、鏡に五味のかかりいるを見て、じれったげに体を動かし、ハンケチを見出し鏡を拭き、そのハンケチを椅子の上に投ぐ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家黙りて相手の顔を、何故笑うかと問いたげに見る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い光までなんとなく重たげだつた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボスボロス海峡で過去の汚いものを洗い清めて東西の国境に足をまたげ、土耳古の空を見上げたときは現代の世界が実業家によって支配されるってことが非常に僕を得意にしてケマル・パシャが尻に錨をつけて黒海を泳ぐさまさえ可笑しかったのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は重たげに顏を擧げて、私達の姿に Pensive な瞳を投げた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、物訊ねたげに、傍にいる者の眼を見た。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もさまたげやしない。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ということを言いたげに呉は、安楽椅子に、ポンと落ちこんでチューインガムをしがんでいる深沢をチラと見て、にたにたと笑った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も左樣する前に老人と小聲で一寸と相談があつたらしく、金貸らしい老人は『勿論のこと』と言ひたげな樣子を首の振り方で見せてたのであつた。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　主人は不審そうに客のようすを今さらのようにながめて、何か言いたげな口つきをした。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お仲という若い地弾きが歌女代に同情して、そっと買薬などしてやっていたが、その年の土用の激しい暑気がいよいよ歌女代の弱った身体をしいたげて、彼女はもう骸骨のように痩せ衰えてしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "情報料は冗談だと云いたげな、罪のなげな笑い方をした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云いたげな微笑を含めた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "王はかくれてしまいたげな、気の弱い表情をした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "退職技手こぞりてひとを貶しつゝ、　　　わかれうたげもすさまじき、おのれこよひは暴れんぞと、　　青き瓶袴も惜しげなく、籾緑金に生えそめし、　　　　　代にひたりて田螺ひろへり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏のうたげにはべる身の、　　声をちゞれの髪をはぢ、南かたぶく天の川、　　　　　ひとりたよりとすかし見る。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが次の朝になって、やっと太陽が登った頃、寄宿舎の生徒が三人、げたげた笑って小屋へ来た。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
