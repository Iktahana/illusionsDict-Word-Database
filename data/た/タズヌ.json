    "definitions": [
      {
        "index": 1,
        "gloss": "to ask",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雨催の空濁江に映りて、堤下の杭に漣※寄するも、蘆荻の声静かなりし昔の様尋ぬるに由なく、渡番小屋にペンキ塗の広告看板かゝりては簑打ち払う風流も似合うべくもあらず。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "首尾の松はこのあたりに尋ぬべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋ぬべき名師は大概尋ね尽し、探るべき心疑も殆ど底を傾けたらしい。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と医師の尋ぬるに泰助は振返りて、「宜しい、おはいんなさい。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まてしばし人を尋ぬる身にしあれば、人の形をなしたる物は、何まれ心を注くべきなり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "月ならぬ眞晝の緋葉を潛つて、仰げば同じ姿に、遠く高き峰の緋葉は蒼空を舞つて海に散る……を鹿なく此の山里と詠じけむ嵯峨のあたりの秋の頃――峰の嵐か松風か、尋ぬる人の琴の音か、覺束なく思ひ、駒を早めて行くほどに――　カーン、カーンと鉦の音が細く響く。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時銘誌を尋ぬるに得ることなく、誰が冢たるを知らずと云ふ。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道を尋ぬれば家を去ること正に八百里程。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その仔細を尋ぬれば、心がらとは言いながら、去る年、一｜膳飯屋でぐでんになり、冥途の宵を照らしますじゃ、と碌でもない秀句を吐いて、井桁の中に横｜木瓜、田舎の暗夜には通りものの提灯を借りたので、蠣殻道を照らしながら、安政の地震に出来た、古い処を、鼻唄で、地が崩れそうなひょろひょろ歩行き。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "無頓着なる白糸はただその健康を尋ぬるのみに安んじて、あえてその成業の期を問わず、欣弥もまたあながちこれを告げんとは為さざりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その踏み荒したる靴の跡はそこかここかと尋ぬるも甲斐なし。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが足下に横わっているのは、尋ぬる父の安行であった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "父を尋ぬる市郎も、同じ時刻に此の山路へ迷い入って、或は此のあたりを過ぎたかも知れぬが、お葉は遂に見出されずに了った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六日、丁亥、天晴、安念法師の白状に依りて、謀叛の輩を、所々に於て生虜らる、凡そ張本百三十余人、伴類二百人に及ぶと云々、此事、濫觴を尋ぬれば、信濃国の住人泉小次郎親平、去々年以後謀逆を企て、輩を相語らひ、故左衛門督殿の若君を以て大将軍と為し、相州を度り奉らんと欲すと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなるゆゑぞと尋ぬるに、津軽の岩城山の神はなはだ丹後の人を忌嫌ふ、もし忍びても丹後の人此地に入る時は天気大きに損じて風雨打続き船の出入無く、津軽領はなはだ難儀に及ぶとなり。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "素より生死の際に工夫修行をつみたる僧なれば恐ろしとも見ず、円位と呼ばれしは抑何人にておはすや、と尋ぬれば、嬉しくも詣で来つるものよ、我を誰とは尋ねずもあれ、末葉吹く嵐の風のはげしさに園生の竹の露こぼれける露の身ぞ、よく訪ひつるよ、と聞え玉ふ。",
              "citation": {
                "source": "二日物語",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の思想の由つて來ることを尋ぬるに、蓋し人死して身猶存し、而して其の感思し料簡し命令する所以のものの存せざるに至れるを見たるより發したので有らう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "事の原由を尋ぬるに、旗野の先住に、何某とかや謂ひし武士のありけるが、過まてることありて改易となり、邸を追はれて国境よりぞ放たれし。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに幽靈坂、猫又坂、くらがり坂など謂ふあり、好事の士は尋ぬべし。",
              "citation": {
                "source": "彌次行",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つら／＼明治世界の思想界に於て、新領地を開拓したる耶教一派の先輩の事業の跡を尋ぬるに、宗教上の言葉にて、謂ふ所の生命の木なるものを人間の心の中に植ゑ付けたる外に、彼等は何の事業をか成さんや。",
              "citation": {
                "source": "内部生命論",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この精神を尋ぬる時は、吾人｜奇くも其発源を革命の主因たりし精神の発動に帰せざるべからざる数多の理由を見出すなり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "友と呼び愛人といふも、はしたなきもつれに脆くも水と冷ゆるは世の習ひなり、鷺を白しと云ひ、鴉を黒しといふも唯だ目にみゆるところを言ふのみ、人の心を尋ぬれば、よしなきことを諍ひては瞋恚の焔を懐にもやし、露ほどの恨みも長しへに解くることなく人を毀はんと思ふ。",
              "citation": {
                "source": "哀詞序",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "一条の山径草深くして、昨夕の露なほ葉上にのこり、※ぐる裳も湿れがちに、峡々を越えて行けば、昔遊の跡歴々として尋ぬべし。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "日はもう傾きかかって来るに、尋ぬる墓表は見附からなかった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば此頃は文よむ窓を離れずして、ベルナルドオをも外の友をも尋ぬることなかりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "然はあれどその※忽にして滅するや、彼も此も迹の尋ぬべきなし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等を載せて出でし舟人を尋ぬるに、こも行方知れずとの事なりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "オテルロとは彼シエエクスピイアの戲曲ヱネチアの黒人の主人公にして、市長の家は其舊館なれば、英吉利人は此地に來る毎に必ずこれを尋ぬること、マルクス寺又は武庫に殊ならずといふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "草むらの中に黒き十字架あまた立てるあたりに歩み寄れば、わが尋ぬる墓こそあれ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "乘合の婦人に尋ぬると、あれはルイキユウですとのことであつた。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
