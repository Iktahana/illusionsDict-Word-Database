    "definitions": [
      {
        "index": 1,
        "gloss": "atmospheric refraction",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
