    "definitions": [
      {
        "index": 1,
        "gloss": "to make war (on)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "寒暖二様の空気と海水の相戦うこの辺の海上では、天気の変化もこんなに急なものかと驚かれるのであった。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒暖二様の空気が関東平野の上に相戦うために起る気象現象である。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日露戦役の際でも我軍は露兵と戦うばかりでなく、満洲の大陸的な気候と戦わなければならなかった。",
              "citation": {
                "source": "戦争と気象学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵同士が協力して戦う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすが、日本を喰いあげた私でさえ、アンナの桃色の乳房、私の身命を賭けて戦う。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日のために戦うのだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はも一度組みついて、やがてぐるぐる廻って上になったり下になったり、どっちがどっちかわからず暴れてわめいて戦ううちに、とうとうすてきに大きな音を立てて、引っ組んだまま坂をころげて落ちて来ました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妄想で自らを卑屈にすることなく、戦うべき相手とこそ戦いたい、そしてその後の調和にこそ安んじたいと願う私の気持をお伝えしたくこの筆をとりました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "将来においても、このへんの彼の所説の中のある物が、前衛に立って戦う天体物理学者のある行き詰まった考えの中に、なんらかの暗示の閃光を投げ込むこともありうるであろうと思われる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "測られぬ風の力で底無き大洋をあおって地軸と戦う浜の嵐には、人間の弱い事、小さな事が名残もなく露われて、人の心は幽冥の境へ引寄せられ、こんな物も見るのだろうと思うた。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが先生僕と比較すると初から利口であったねエ、二月ばかりも辛棒していたろうか、或日こんな馬鹿気たことは断然｜止うという動議を提出した、その議論は何も自からこんな思をして隠者になる必要はない自然と戦うよりか寧ろ世間と格闘しようじゃアないか、馬鈴薯よりか牛肉の方が滋養分が多いというんだ。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが先生僕と比較すると初から利口であったねエ、二月ばかりも辛棒していたろうか、或日こんな馬鹿気たことは断然止うという動議を提出した、その議論は何も自からこんな思をして隠者になる必要はない自然と戦うよりか寧ろ世間と格闘しようじゃアないか、馬鈴薯よりか牛肉の方が滋養分が多いというんだ。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその地図に入間郡「小手指原久米川は古戦場なり太平記元弘三年五月十一日源平小手指原にて戦うこと一日がうちに三十余たび日暮れは平家三里退きて久米川に陣を取る明れば源氏久米川の陣へ押寄せると載せたるはこのあたりなるべし」と書きこんであるのを読んだことがある。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども僕は里子のことを思うと、恨も怒も消えて、たゞ限りなき悲哀に沈み、この悲哀の底には愛と絶望が戦うて居るのです。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分の弱さと戦う戦士としては決して弱くなかった。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲の中央にて護法の諸天善神達と、呪いの方の眷属等と戦う。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "但その頭の獅子が怒り狂って、たけり戦う勢である。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　烏の北斗七星戦うものの内的感情です。",
              "citation": {
                "source": "『注文の多い料理店』新刊案内",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女や子供たちまでも、戦う人々の中にまじっていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての人の幸福のために戦うと云うところにあれらの意義はあるのです）　しかし芸術家となった以上、そこにいわゆる社会人のおつとめ以外、もっと大変な芸術というすべてのモラルやカテゴリーや時代を超越したものにぶつかって行くのです。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "受験は人生の最終の目的ではないけれども、兄さんの言ったように、これと戦うところに学生生活の貴さがあるのだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全裸で戦うのは、よほど腕力に自信のある人でなければ出来る芸当でない。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと戦うには、彼の虎穴に敢然と飛び込んで、一日も早くその粋を学び取るより他は無い。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王と戦うに及びて、官軍時に或は勝つあるも、此令あるを以て、飛箭長槍、燕王を殪すに至らず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞿能父子も亦踴躍して戦う。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸｜是に於て兵を麾いて大に戦う。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "建文元年｜耿炳文に従いて燕と戦う。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "このたびはあやまたず、したたかうって殺しぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前はいのちがけで狐とたたかうんだぞ。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このたびはあやまたず、したたかうつて殺しぬ。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
