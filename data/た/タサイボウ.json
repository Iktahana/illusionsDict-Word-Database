        "examples": {
          "standard": [
            {
              "text": "顕微鏡で観察すると、その生物が多くのパーツから成る多細胞構造であることが分かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ボルボックスは単細胞と多細胞の中間に位置する興味深い生物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "私たちの体は約37兆個もの細胞が集まった多細胞系である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一定の時期を経過して、一定の子孫が生ずれば、再びその勢力は枯涸して、また他種のものと合する必要が起るのであるが、多細胞のものにあっては、絶えず他種のものと合することを要する。",
              "citation": {
                "source": "進化論より見たる沖縄の廃藩置県",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは他の惑星でも行ってきたように、食糧として必要な分だけでなく、共同体が必要とする重労働に使役するための一種の多細胞性の原形質の塊を作り出し、これは催眠術による命令で一時的にどんな種類の器官の形でもとることができるため理想的な奴隷となったのだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
