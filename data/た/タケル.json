[
  {
    "uuid": "76c08ef5-5d36-5ee5-a93e-f9b1ce3b6e50",
    "entry": "猛る",
    "reading": {
      "primary": "たける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
