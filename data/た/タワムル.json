    "definitions": [
      {
        "index": 1,
        "gloss": "to be playful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "勝坊の頭を撫で乍ら商人に向って、Ｔ「自分で落しときァがって巫山戯るねえ！",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも真面目な勤勉な市民が羽目をはずして怠け巫山戯る日であった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海棠　牡丹の盛りには蝶蜂の戯るゝを憎しとも思はねど、海棠の咲き乱れたるには色ある禽の近づくをだに嫉しとぞおもふ。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "美人は戯るるがごとくに詰れり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "奢を恣まにせば熊掌の炙りものも食ふに美味ならじ、足るに任すれば鳥足の繕したるも纏ふに佳衣なり、ましてや蘿のからめる窓をも捨てゞ月我を吊ひ、松たてる軒に来つては風我に戯る、ゆかしき方もある住居なり、南無仏南無仏、あはれよき庵、あはれよき松。",
              "citation": {
                "source": "二日物語",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち卯の花に遊ぶこと萩に戯るるが如しである。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白布にて蔽うたる一個の小桶を小脇に、柱をめぐりて、内を覗き、女童の戯るるを視つつ破顔して笑う朱の盤　かちかちかちかち。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田島は勿論、こんな女が自分の傍に居るのを知ってもイベットが何とも思わないことを知って居た、それよりもイベットの子供らしいとはいえ態と自分にからかって他の男に巫山戯る様子にいくらかの嫉妬を感じた。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱棄てた草履に早く戯るる一羽の赤蜻蛉の影でない。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "常の如く戯るるなるべし。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "戯るるにはあらずや、心狂へるにはあらずや。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルコのソリマン二世一日睾丸抜いた牡馬が戯るるを睹、宦者も丸を去ったばかりでは不安心とて、その根部を切り尽さしめ後帝世々その制を沿襲した。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "言に打ち出でて男女のこと、人の上をも言い戯るるこそ、似げなく見苦しけれ』と書き申したわ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "悟空はいつ迄たつても王の手を放さうとしない、果は玩具に戯るゝやうにさすつてみたり、一本一本指を数へてみたりし始めた。",
              "citation": {
                "source": "闘戦勝仏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十四五、実際この頃には誰にでもある煩悶で、この年頃に賤しい女に戯るるものの多いのも、畢竟その淋しさを医す為めである。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ　　　木のうろに隠れうせけりけらつゝきなど戯る。",
              "citation": {
                "source": "旅の旅の旅",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婦人はまたセエブル地方の大きく美しいことを言い添えて、ここへ暑を避けに来ている幾多の家族は皆友達のようであり、砂上に遊び戯るる子供等を見るのも楽いと書いてよこした。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして運命の反復して人に戯るゝを可笑しくおもふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "余語に戯るる語は、其妻妾の事に関するものの如くである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども春台を「天子が侍姫に戯るる処」とするは何の出典に依るか。",
              "citation": {
                "source": "念仁波念遠入礼帖",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "是等は都て家風に存することにして、稚き子供の父たる家の主人が不行跡にて、内に妾を飼い外に花柳に戯るゝなどの乱暴にては、如何に子供を教訓せんとするも、婬猥不潔の手本を近く我が家の内に見聞するが故に、千言万語の教訓は水泡に帰す可きのみ。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち今の有婦の男子が花柳に戯るゝが如き不品行を警しめたるものならんなれども、人間の死生は絶対の天命にして人力の及ぶ所に非ず。",
              "citation": {
                "source": "新女大学",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "花柳の間に奔々して青楼の酒に酔い、別荘｜妾宅の会宴に出入の芸妓を召すが如きは通常の人事にして、甚だしきは大切なる用談も、酒を飲み妓に戯るるの傍らにあらざれば、談者相互の歓心を結ぶに由なしという。",
              "citation": {
                "source": "日本男子論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、｜打たれし牝鹿は泣きて行け、｜無情の牡鹿は戯るる――の方でしょうよ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何うか――」「御勘弁を――」「巫山戯るなっ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、外出の仕度をさせるのに、おしもをわざわざ奥の居間へ呼ぶのも巫山戯るためかと疑い、夜分、寝室で頭を揉ませているのさえ不安な思いで、時折りお春を覗かせにやる。",
              "citation": {
                "source": "女心拾遺",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡てのものの母であるというような広い心は、また只在ることの静かなる悦びは、渚に戯るる小さい漣の音にも融けてゆく。",
              "citation": {
                "source": "湖水と彼等",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "序幕山崎街道｜立場の場は明智の雑兵の乱暴を羽柴の侍が制する処なるが合戦中の事としては、百姓が長閑気に酒を呑み女に戯るるなど無理なる筋多し。",
              "citation": {
                "source": "明治座評",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷲紫にほふ横雲の露や染めけむ花すみれ花に戯るゝ蜂蝶の戀か恨かうつゝ世のはかなき春をよそにして　大空のぼる鷲一羽　あらしは寒し道さびし。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "翳ったり、照ったり、躁いだり、黙ったり、雲と日と風の丘と谷とに戯るゝ鬼子っこを見るにも好い。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
