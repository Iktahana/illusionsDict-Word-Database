        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "番頭と鉄五郎は見知りらしく立ち話し。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝長屋　井戸端でお内儀さん二三人の立ち話し。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の男が立ち話をしていたんだ。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはほんの立ち話で別れたが、それから二、三日過ぎてわたしは赤坂の家をたずねた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前で坊さんが二人立ち話をしている。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある途上で、一人の若い背の高い西洋人の前に、四五人の比較的に背の低いしかし若くて立派な日本人が立ち並んで立ち話をしていた。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりは廊下へ出て立ち話をした。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで立ち話をしないやうにしませうよ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カメラをさげて歩いている途中で知人に会ってちょっと立ち話をするとする。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの地蔵さんだす」　と訊いたので、私は次のような長い立ち話をした。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "というて、折角お前に会うて立ち話だけで別れるいうのも、未練たらしい言い方やが、心残りや。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち話、という程でもないが、二言三言口もきいたであろうか。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち話にきくと、今では堺筋に相当な写真機店を出しているということだった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その視線を感じて、陽子ははじめて、立ち話の長さに気がつき、「ハバハバ行きましょう」　と、小声で誘って、ドレスの裾を持った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋で泊ればいい」「うち、泊るお金あれへん」　そこは藪の中で、蚊が多く、立ち話しているうちに、木崎は神経がいらいらして来たので、いきなり十円札を三枚つかみ出すと、「じゃ、これをやるから宿屋で泊れ！",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ文吉のことなど一寸立ち話した後、浜子は、短気を出したら損やし、丸亀へ戻って出世して六貫村へ錦を飾って帰らんとあかんしと意見した。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち話もそんな場所ではできず、前から部屋を頼んでおいた近くの逢坂町にある春風荘という精神道場へ行こうとすると、新聞の写真班が写真を撮るからちょっと待ってくれと言いました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、いつまでもお千鶴のことを立ち話にきくのも変だと、すぐ話をかえて、「――ところで、お前の方は、いまどうしているんだい？",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らく立ち話して「花屋」の主人と別れ、大阪劇場の前まで来ると、名前を呼ばれた。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "このふたりは湯をあがってからも、必らず立ち話した。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄平と清子が立ち話している。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち話でだんだんに訊けば、蝶子の失踪はすぐに抱主から知らせがあり、どこにどうしていることやら、悪い男にそそのかされて売り飛ばされたのと違うやろか、生きとってくれてるんやろかと心配で夜も眠れなんだという。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "合服といふことがまず寿枝の胸をチクリと刺し、なぜ立ち話にでもあの子の居所をきいてくれなかつたのかと、修一の冷淡さを責めた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関での立ち話では、三人とも頼むべきこともろくに頼めなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "出て来た芸者が男衆らしい男と立ち話していたが、やがて二人肩を寄せて宗右衛門町の方へ折れて行った。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
