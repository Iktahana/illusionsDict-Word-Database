        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "するとキャッという女の声、驚いて下を見ますと、三人の子供は何に恐れたのか、枯れ木を背負ったままアタフタと逃げ出して、たちまち石垣のかなたにその姿を隠してしまいました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐるツと取卷かれて恥しいので、アタフタし、駈け出したい位急足で踏出すと、おもいもの抱いた上に、落着かないからなりふりを失つた。",
              "citation": {
                "source": "迷子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠太はアタフタと出て行つた、が、早速と復引き返して來た。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『オヤマア私とした事が、……御飯の仕度まで忘れて了つて、……』といつて、伯母さんはアタフタと立つた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠太はアタフタと出て行つた、が、早速と復引き返して来た。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "左様当人にも申聞けまして、や、これは、実に、大変な事になりました」　アタフタとして九兵衛は帰り去った。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "織り物をするところでは、輸出向きのタフタのようなものを、動力をつかった沢山の機で織っているのですが、ここは千紫万紅色とりどりに美しい布の洪水です。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたちのパラソルにいいような、黄と青と黒の派手なチェック模様や、真夏の海辺に着たいような赤とブルウの大名縞、そんな人絹のタフタが沢山出来ているそばでは地味な村山大島が、織られていたり、畳を敷いたところでは、娘やおばあさんたちが、派手な着物を縫っていたりしました。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから同日の午後六時三分発上り列車の発車間際に、やはり鳶色の服を着た信造らしい青年が駆けつけて来て、アタフタと乗り込んだ。",
              "citation": {
                "source": "青服の男",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてその人工的「ほくろ」、即ち「ムーシユ」とはどんなものかと云ふに、黒色に染めたタフタ（薄地の帛）を天然のほくろの大きさに似せて、小さな円い形に切つたものである。",
              "citation": {
                "source": "東西ほくろ考",
                "author": "堀口九萬一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時遠くの町角に現われた男は二人の姿を認めて、アタフタと其場を立去って了った。",
              "citation": {
                "source": "緑衣の女",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼田がアタフタと、包みと帽子を抱えて出て来ると、二人は急いで山を下った。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は話を中途で切上げてアタフタと出て行きました。",
              "citation": {
                "source": "文化運動への反省",
                "author": "――東北文化協議会講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　林檎のように顔色の良かった看護婦も、俄かに青森産のそれのように蒼味を加えて、アタフタと室外へ出ていった。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は息を引取ったのが、これで六十……」　と云おうとしたところへ、肥っちょの看護婦がアタフタ駈けてきた。",
              "citation": {
                "source": "蠅",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しばらくの間、ジッと考え込んでいた三吉は、何を思ったか、地震計をしまうと、三井銀行の地下室を、アタフタと飛び出した。",
              "citation": {
                "source": "地中魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官はバットの箱ごと帆村の手に渡して、アタフタと検事の後を追っていった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでボーイが一隅を指すと、ドクトルは村松氏に先へ行くようにと挨拶して、アタフタと手洗所の中へ入っていった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしすぐまた此処へ出直すから後をよろしくと帆村にいってアタフタと出掛けていった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあそこにある受話器で、よく聞いているんだよ」　そういうと佐々記者はアタフタと、宿を飛び出していった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその後から糸子がアタフタ現れて、「ワー。",
              "citation": {
                "source": "心霊殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて糸子がアタフタかけこんできて、「間に合ったア！",
              "citation": {
                "source": "心霊殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき外からアタフタと駈けこんで来た男があった。",
              "citation": {
                "source": "雷",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼が博士の家を出るようになった訳は、どうもウララ夫人によこしまな恋慕をしたためだという話です」「なるほど、そいつは容疑者のうちに加えておいていいネ」　そういっているところへ、階下から一名の警官がアタフタと上ってきた。",
              "citation": {
                "source": "人造人間事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いタフタアの洋服の上に、その時は黒いベルベットのチョッキをつけて棒をふった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――シンプソン夫人のように、高尚だわ――　南原杉子は、金茶色のタフタの洋服を下宿の二階できつけていた。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰色のタフタに、ゴールドのラメ。",
              "citation": {
                "source": "鋏と布と型",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マネキン　灰色のタフタとゴールドのラメ。",
              "citation": {
                "source": "鋏と布と型",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまたひと月経った六月の末、志丈は久々で新三郎を訪ねてきてお露様がお前に焦れ死んだとつたえる、しかもあくまでオッチョコチョイにできている志丈、喋るだけ喋ると寺も何もいわないでアタフタかえっていってしまう。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
