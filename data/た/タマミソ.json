          "standard": [
            {
              "text": "昔の旅人は、保存食として玉味噌を腰にぶら下げて長い道のりを歩いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お湯に玉味噌を溶かすだけで、即席の温かい味噌汁が出来上がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "囲炉裏の火で少し炙った玉味噌の香ばしい匂いが、部屋中に広がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "玉味噌の鑑定とは、ちくと物が違うでな、幾ら私が捻くっても、どこのものだか当りは着かねえ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉味噌を塗って、串にさして焼いて持ちます、その握飯には、魔が寄ると申します。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
