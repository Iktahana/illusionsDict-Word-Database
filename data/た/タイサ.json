        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は陸軍大佐となり王党の国会議員となり、Duke of Leinster の娘の Lady Fitzgerald と結婚した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父の大佐がこの子を始めて見たときに「これはよほど利口か、それとも大馬鹿だ」と云った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達階廊昇りつめると、そこにはデーマン大佐の専制。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社に関係のある予備陸軍大佐の娘を妻に貰った。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "予備大佐はむっつりとものを云う重々しい感じの、田舎では一寸見たことのない人だった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以来両人は大佐を鬼門のように恐れていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに両人は隣室にいる大佐に気がねして、長く横たわることもよくせずにちぢこまっていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――病院の下の木造家屋の中から、休職大佐の娘の腕をとって、五体の大きいメリケン兵が、扉を押しのけて歩きだした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええと、三百円のうち……」彼は、受取ったすぐ、その晩――つまり昨夜、旧ツアー大佐の娘に、毎月内地へ仕送る額と殆ど同じだけやってしまったことを後悔していた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――しかし、彼は大佐の娘の美しさと、なまめかしさに、うっとりして、今ポケットに残してある札も、あとから再び取り出して、おおかたやってしまおうとしていたことは思い出さなかった。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が、大佐の娘に熱中しているのを探り出して、云いふらしたのも吉原だった。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾の子でもう二十八だ相です」「大佐は矢張り一處に居るんですか……東京ですか」「大佐は死んでしまつたんだ――もう餘程前ですよ」と相島が説明する。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は非職海軍大佐某氏の息、理学士の学位あって、しかも父とともに社会の暗雲に蔽われた、一座の兇星であるものを！",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬はね、馬は大佐にしてやろうと思うんです」　おっかさんが笑いながら、　「そうだね、けれどもあんまりいばるんじゃありませんよ」と申しました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちはみんな僕の大佐にする。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "環のまん中に名高い、ヘルマン大佐がいるんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルマン大佐はまっすぐに立って腕を組んでじろじろあたりをめぐっているものを見ているねえ、そして僕たちの眼の色で卑怯だったものをすぐ見わけるんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりはせまわってふらふらしているとこなどを、ヘルマン大佐になど見られようもんならさっそく、おいその赤毛、入れ、なんて来るからねえ、いくら面白いたって少し疲れさえなおったら出発をはじめるんだよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえどかれません、じゃ法令の通りボックシングをやりましょうとなるだろう、勝つことも負けることもある、けれども僕は卑怯は嫌いだからねえ、もしすきをねらって遁げたりするものがあってもそんなやつを追いかけやしない、あとでヘルマン大佐につかまるよってだけ云うんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其頃君は暹羅漫遊中と承つたが、皈國中、或人の媒介で、同郷の松島海軍大佐の妹を妻に娶つて來たのです。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、妻は大佐の病氣次第で早かれ遲かれ歸つて來ますが、兒は永く／＼――日本帝國の天晴れ軍人として世に立つまでは、芙蓉の峯の麓を去らせぬ積です。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "また松島海軍大佐の令妹なる彼の夫人にはまだ面會はせぬが、兄君の病床を見舞はんが爲めに、暫時でも其良君に別を告げ、幼き兒を携へて、浪風荒き萬里の旅に赴くとは仲々殊勝なる振舞よと、心竊かに感服するのである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に私は櫻木海軍大佐とは面識の間柄で、數年前の事、私がまだ今回の漫遊に上らぬ以前、ある夏、北海道旅行を企てた時、横濱から凾館へ赴く船で面會した時も、談話爰に及んだ時、彼はふと衣袋の底を探つて、昨夜旅亭の徒然に作つたのだと言つて、一｜篇の不思議な新體詩を示された。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫻木海軍大佐は其性質からいつても、かゝる擧動に出でたのは大に期する所があつたに相違ない。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、大佐は其後何處に如何して居るだらうと考へるとまた種々の想像も沸いて來る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては先日反古の新聞に記されてあつた櫻木海軍大佐と其帆走船との行衞などが恰も今夜の此物凄い景色と何等かの因縁を有するかのごとく、ありありと私の腦裡に浮んで來た。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "春枝夫人は私の後方に、愛兒をしかと抱きたる儘、默然として言もない、けれど流石に豪壯なる濱島武文の妻、帝國軍人松島海軍大佐の妹君程あつて、些も取亂したる姿のなきは、既に其運命をば天に任せて居るのであらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時分は僕等もまた少年時代の心もちがぬけないで、たいさう純樸な若々しい情緒をもつて居たので、お互に浪漫的な小曲をかいてゐた。",
              "citation": {
                "source": "室生犀星の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六神丸たいさんやすい。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その井戸は三尺にも足らない程の淺さで、井戸がはも半分腐つてゐたが、綺麗に掃除が行き屆いてゐて、林檎箱のこはれで造つたいさゝかのながしも塵一つ溜つてゐなかつた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
