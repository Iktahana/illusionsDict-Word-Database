        "examples": {
          "standard": [
            {
              "text": "短期的な利益だけを追い求めると、将来的に会社の信頼を損なう恐れがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この薬は短期的には効果があるが、長期的な副作用についてはまだ分かっていない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "短期的な視点に囚われず、十年後の社会を見据えた投資を行うべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "併し猶一層確論すると、本來一時は一念なものであるから、長期的散亂心と短期的散亂心と、唯聊か時間の長短の差のあるのみで、有時無時といふ事も無いのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後により短期的には、電子本は大量の部数を望めない出版物を少ないリスクで刊行する手段としても生かされるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし尚一層正確に言うと、本来一時は一念なものであるから、長期的散乱心と短期的散乱心と、ただ、いささか時間の長短の差があるだけで、有時無時という事もないのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七〇年、アメリカ国内の景気は短期的ながら急激な落ち込みを経験した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "短期的な目標は、同年度末までにＰＣ―１００にＧＵＩを間に合わせ、マルチツールのアプリケーションをそろえるところに置いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
