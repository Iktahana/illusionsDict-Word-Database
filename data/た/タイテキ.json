    },
    "definitions": [
      {
        "index": 1,
        "gloss": "great rival",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "』　是非もないことゝ自分も斷念めて咽喉疾には大敵と知りながら煙草を喫い初めた。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対に、間違ったのを正しく読むのは校正の場合の大敵である。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ばん大敵なのは七八年前から特に盛になった模造品の進出であった。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども今より十年後、二十年後、或は三十年後に至つても、米国の陸海軍は今日と同断なりと思はゞ、兵家の所謂油断は大敵なり。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くは日露戦争に於て、我国が大敵露国を打倒せしは、東郷、大山、乃木、其他幾百千の英雄豪傑の力にあらずや。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "たけは、油斷大敵でせえ、と言つただけで格別ほめもしなかつた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "感謝の文学　日本には、ゆだん大敵という言葉があって、いつも人間を寒く小さくしている。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "たけは、油断大敵でせえ、と言つただけで格別ほめもしなかつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "油断大敵のれいである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東　ゆだん大敵西　ゆうれいの浜風　東のは意義顕露なり。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "休止は、おれにとつては大敵なのだつた。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワルトンは意外にジョーンを大敵だと知って怒張した。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "にも拘わらず、何時の間にか、彼は現政府の一大敵国と見做され、恐れられ、憚られ、憎まれるようになっていた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も北国の大敵に向わせられるには、御勢ばかりでは、あまりに小人数である。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして油断の心は大敵である。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、毛利と云う大敵を前に控えて、簡単に攻め上って来るとは思えなかったのだろう。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方山名氏は、新興勢力であって、持豊に至って鬱然として細川氏の一大敵国をなして来たのである。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからそうした分散的な諸勢力を一括した正行は、今や北朝にとっては一大敵国をなして居るわけだ。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "叡慮先づ憤を慰する条、累代の武功返す／″＼も神妙なり、大敵今勢を尽して向ふなれば、今度の合戦天下の安否たるべし、…朕汝を以て股肱とす。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "芹沢亡き後の新撰組は、当然近藤、土方の天下で、幕府の後押しもあり、京都守護職、松平｜容保の信頼もあり、隊の勢は日ならずして隆々として揚り、京洛に劃策する勤皇の志士にとつて、陰然たる一大敵国を成すに到つた。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "或日楼の窓から遥かの山を見渡すと、計らずも攻め寄せてゐた大敵の烽火の挙るのを認めて急を告げた家臣があつた。",
              "citation": {
                "source": "東中野にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はさいわいに危険な位置をいささか離れているけれど、大敵に包囲されている心地である。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし豹はほとんど狗頭猴ほどよく攀じ登ればその大敵で、時にこれを襲うあれば大叫喚を起す、土人いわく、豹は成長せる猴を襲う事稀に時々児猿を捉うと。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "マレー半島のセマン人信ずるは、創世神タボンの大敵カクー、黒身炭のごとく西天に住む。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "アレキサンダー大王、平生四種の絵具だけで城を傾くるほど高価の画を成すアペルレースも、ただこの一の色をかほど扱いあぐむ心根を不便がり、さしもわが身よりも惜しんだ寵姫を思い切ってアに賜いし、それ自ら制して名工を励ました力の偉なる、ペルシャ、インドの大敵を蹂躪した武功に勝る事万々とプリニウスが頌讃した。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "古エジプト人は上述クサタナ国の鼠王同様ヒミズを神とし祈って大敵を破った（ローリンソンの『ヘロドトス』二巻一八九章）。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝる程に、大敵外よりあらはれ、北条氏は秀吉の為に亡ぼされたり。",
              "citation": {
                "source": "秋の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらには、怖ろしい大敵じゃ」と、只一人世評を斥けたのであった。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の大敵は、彼自身の芸が行き詰まっていることである。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "染太夫　わたし等もかゝり合ひだから、なんとか景氣を盛返してみせたいと、色々に燥つてはゐるものゝ、何分にも歌舞伎といふ大敵に蹴壓されて、殘念ながらどうにもならない。",
              "citation": {
                "source": "近松半二の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
