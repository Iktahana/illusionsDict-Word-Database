[
  {
    "uuid": "8ede8764-9866-5d21-b51d-d5a40c5a21e7",
    "entry": "大敵",
    "reading": {
      "primary": "たいてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
