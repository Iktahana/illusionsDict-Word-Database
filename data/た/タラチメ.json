        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ああ望なき人の子に、死は垂乳女の姿あり。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "故人住吉町の円喬師が、『垂乳女』の枕に、　縁は異なもの味なもの。",
              "citation": {
                "source": "噺家の着物",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もういいたらちめは卒業だ」　どの落語家もそうなまるようにやはり垂乳根をたらちめとなまって、ある日師匠助六が言った。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "少したらちめをほめてやったら、もう安心して芸が後戻りしやがる。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにを知ってる」「たらちめです」　真っ先に言った。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ななに」「たらちめ」「たらちめ？",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "オイたらちめってオイ嫁さんがきて、元は京都の産にて姓は安藤、名は慶蔵ってあれだろう」「あれあれ。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな馬鹿馬鹿しいたらちめが……駄目だよ、オイ」　柳美館はふき出した。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "元より怪談らしい凄味もなんにも漂いはしなかったが、「たらちめ」のお嫁さんにさえ、お艶の姿を思い描いてはしゃべる今松。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "白根草の価なにほどなるやとたらちめのお嫁さんみたいなことを言わないだけがめっけもんだ。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこっちもいい心持ちんなって「金明竹」「たらちめ」と、いろいろ御機嫌を伺ってると、これがみんなワッワッと受けるんです。",
              "citation": {
                "source": "初看板",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
