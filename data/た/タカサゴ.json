    "definitions": [
      {
        "index": 1,
        "gloss": "double-lined fusilier (Pterocaesio digramma)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
