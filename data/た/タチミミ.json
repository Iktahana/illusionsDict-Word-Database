        "examples": {
          "standard": [
            {
              "text": "その子犬はピンと立った立ち耳が特徴で、とても愛嬌がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は自分の立ち耳をコンプレックスに思って、いつも髪で隠している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「立ち耳の子は、小さな音にも敏感に反応するんだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "骨を鳴らせて飛び交う鳩の身体からうす冷たい風が立ち耳の根をひやりとさせた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛色は赤にゴマ毛まじり、立ち耳、差し毛、顔がちょっとしゃくれて、ひいき目にも器量がよいとはいえない犬でした。",
              "citation": {
