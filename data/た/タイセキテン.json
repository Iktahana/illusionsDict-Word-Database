        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "太陽が動かないで地球が運行しているという事、地球が球形で対蹠点の住民が逆さにぶら下がっているという事、こういう事がいかに当時の常識に反していたかは想像するに難くない。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正宗白鳥氏はこの点では対蹠点に立つてゐると言つても善い。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて何も谷崎潤一郎氏と対蹠点に立つてゐる訣ではない。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その為に又下流階級に、――彼等の社会的｜対蹠点に病的なを感じていた。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その為に又下流階級に、――彼等の社会的対蹠点に病的なを感じてゐた。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "―或精神的風景画―",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊＊　対蹠点、又は対蹠地、一口に言えば地球の裏側。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "中世・十六世紀においては、地球を平らなものと考えていたので、対蹠点に人が住んでいるなどと考えることは異端とされた。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
