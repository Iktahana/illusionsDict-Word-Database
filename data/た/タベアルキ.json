        "examples": {
          "standard": [
            {
              "text": "彼は自身のブログに『東京ラーメン食べある記』というタイトルで訪問記録を綴っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この雑誌の食べある記、写真がすごく綺麗で全部のお店に行ってみたくなるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "退職後の趣味として、全国の秘湯を巡る『温泉と美食の食べある記』を出版した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
