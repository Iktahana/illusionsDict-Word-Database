        "examples": {
          "standard": [
            {
              "text": "炊飯器から「ピー」と音がして、美味しそうなご飯が炊き上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ふっくらと炊き上がった白いお米の香りが、部屋いっぱいに広がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "キャンプ場で飯盒のご飯が炊き上がるのを、子供たちが今か今かと待っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ひとすくひの米に水を入れて、洗ひもせずにかゆをたいたが、かゆがたきあがると、涼しい紅葉の根元に、かゆの鍋を置いて蓋をあけてさました。",
              "citation": {
                "source": "絵本",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご飯がたきあがると、せっせとお弁当をつくり始める。",
              "citation": {
                "source": "キャラコさん",
                "author": "女の手",
                "note": "青空文庫"
              }
            }
          ]
