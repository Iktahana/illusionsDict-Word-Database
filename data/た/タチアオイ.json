        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "田舎くさい素朴な、直接に田畑のにおいが感じられて、白い立葵を見たと思った。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫陽花のすぐ隣に、立葵の赤と白との花が雨にぬれてゐます。",
              "citation": {
                "source": "雨の日に香を燻く",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は立葵を描いた光琳と乾山との作を見たことがありますが、兄弟相談して画いたかとも思はれる程互によく似てゐました。",
              "citation": {
                "source": "雨の日に香を燻く",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「尋ネ人……サワ蟹ノ棲メル川沿イニ庭アリテ紫ノ立葵咲ク。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいいとして暫くするとそこで母はきっと妾によびかけて、ちょっと庭の方へ行って、立葵の花を一枝折ってきてくれと云いつけるのであった。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾はしぶしぶ云いつけられたとおり庭に下り、梅雨ちかい空の下に咲き乱れる立葵の一と枝をとっては、大急ぎでまた元の座敷牢へとび上っていった。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいカンカンでしょ、ばア……」　妾は立葵を格子の中になげこむと、同じ言葉をくりかえしていうのであった。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾はそのほかにも、舌切雀の遊戯を踊ったりして寝ているはらからを悦ばせることをやったけれど、必ずその途中で母の命令が出て、妾は庭へ下りると立葵の花を折ってきたり、蜻蛉草を摘んできたり、或いはまた大笹の新芽から出てきた幅の広い葉で笹舟を作ってもってきたりするのであった。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら子供ごころにも気のついたことは、庭へ下りて持ってくるのが、立葵であっても蜻蛉草であっても、それからまた笹舟であっても、どれであろうと大した違いがないのだった。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が可愛くはないのだろうテ」「あの立葵の咲いていた分れ家のネ」「ウン」「あの中に、あたしの同胞がいたわネ。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「広告にお書きになりましたサワ蟹とか立葵とかは、日本全国どこにもございまして、これは手懸りになりません。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこならサワ蟹だって、立葵だって沢山あります。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾を見習ってカンカンに赤い三つのリボンをかけたこともよく覚えているそうであるし、紫の立葵のこと及びその色ちがいのもので赤や白のものがあることや、日本全国到る処に棲息するサワ蟹のこと、特にその鋏に大小の差があって鋏に糸をつけるとすぐそれが※げることなどをスラスラ語った。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず妾は貞雄に向い、あの立葵の咲く家の座敷牢の中に寝ていた妾の同胞を探したいという気になって新聞広告をしたことから始めて、静枝や真一などが現れるに至ったまでの話を詳しくして、もしや彼が、妾の同胞を知らないかと尋ねた。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "陣笠に立葵の紋の付いたぶっ割き羽織でも着なくっちゃ納まりの付かない紐だ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "春潮といへば必ず門司を思ふ昭和五年三月ふるひ居る小さき蜘蛛や立葵昭和五年六月二十七日　鎌倉俳句会。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "土屋は九曜で、本多は丸に立葵。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いてしらん、ぎしぎし、たちあおい、かわほね、のいばら、つきみそう、てっせん、かなめ、せきちくなどが咲き、裏の畑の桐の花は高く薫った。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "前栽の金魚草・たちあおい・ゼラニウム・緑・赤毛糸ししゅうみたいな花壇とその奥の窓々に白いレース・カーテンをかいま見させるていどに開放的である。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
