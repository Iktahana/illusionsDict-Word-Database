[
  {
    "uuid": "bc9c418a-aa8c-5d1d-95cf-07d5eba99ba2",
    "entry": "建具",
    "reading": {
      "primary": "たてぐ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
