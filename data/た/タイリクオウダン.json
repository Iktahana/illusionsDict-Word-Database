        "examples": {
          "standard": [
            {
              "text": "彼は定年退職後の夢だったキャンピングカーでの北米大陸横断をついに実現させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大陸横断レースに参加するドライバーたちは、過酷な砂漠地帯や山脈を不眠不休で駆け抜ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつての冒険家にとって、徒歩での大陸横断は命を懸けた壮大な挑戦であった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "大陸横断の無銭徒歩旅行が最後の手段として残されてゐるけれども、いくぶんでも易きにつかうとする誘惑はなかなか強い。",
              "citation": {
                "source": "外遊熱",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "アジア大陸横断にどれくらいかゝるか。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
