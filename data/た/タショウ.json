[
  {
    "uuid": "b605f506-198b-55bd-bb01-e7d1d0f7be40",
    "entry": "他称",
    "reading": {
      "primary": "たしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
