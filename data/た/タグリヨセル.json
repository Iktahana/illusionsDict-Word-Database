    "definitions": [
      {
        "index": 1,
        "gloss": "to haul in (e.g. rope, net, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それを手繰り寄せる頃には、三町ばかりの交番へ使いに行くぐらいの厚意のある男が、きっと弥次馬の中に交っている。",
              "citation": {
                "source": "身投げ救助業",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を利用しうまい汁を吸つてやらうといふのでも、愼重に計畫し、徐々に引綱を思ふ壺へ手繰り寄せるといふのではなくて、溺れるものが藁をつかむやうに、一寸でも自分の足しになると思ふものには、情なく縋りついて來るのだ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これとは違つて繰り返すといふことは本來手繰り寄せるといふことである。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "繰り返すといふことが手繰り寄せるといふことであるから歴史はあるのである。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し手繰り寄せるといふとき、端緒は自分の手元に、從つて現在にある。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」かの歴史に於て繰り返すといふことは、選擇的に繰り返すといふことであることによつて、既に單に繰り返すといふことではあり得ず、それは手繰り寄せるといふことである故に、かかる選擇の原理は現代のうちに含まれてゐるのである。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、我々は歴史を繰り返すといふことが手繰り寄せるといふことであることを云つた。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "見届けたい未来を素早く手繰り寄せるには、大衆運動の旗を振るのが近道だろうと安田は考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "先の二帝の性格に絡んだ万葉人の考へを手繰り寄せる、ほのかながら力ある、一つの手がゝりではあるまいか。",
              "citation": {
                "source": "万葉びとの生活",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと思ひついて、頭の上を手さぐりして、天井から斜ツかひに引つ張られてゐる紐を掴んで、手繰り寄せると、大丈夫手答へがある。",
              "citation": {
                "source": "猫と庄造と二人のをんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと思いついて、頭の上を手さぐりして、天井から斜ッかいに引っ張られている紐を掴んで、手繰り寄せると、大丈夫手答えがある。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野郎ツ」　咽嗟の間に飛付いたガラツ八、曲者の襟髮を手繰り寄せるやうに、後ろから羽掻締にしました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "黒い巾着",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野郎ッ」　咄嗟の間に飛付いたガラッ八、曲者の襟髪を手繰り寄せるように、後ろから羽交締にしました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "黒い巾着",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの眼の深い悩み、――声の柔かい魅惑、何も彼もが、一つの妖かしとなって、半十郎の魂を手繰り寄せるのでしょう。",
              "citation": {
                "source": "江戸の火術",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "行く時はいつも、そんなに恐れるのは卑怯であるとか、意志の力を試すためだとか、何とか彼とか自己を欺いて出かけるのだが、その実あの光景の誘惑が殆ど不可抗力を以て彼を手繰り寄せるのであった。",
              "citation": {
                "source": "武州公秘話",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロープを堅く握って手繰り寄せると、小さなマグロが体を震わせながら引っ張っている力を感じる。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "」彼は大声を出して、ロープを両手で思い切り引き、一ヤードほど手繰り寄せる。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、父と兄とが数年前に一冊の開かれた出納簿をまん中にして向い合っていた一夜の情景を、太い綱をもって手繰り寄せるように、次第に鮮かな形を示してわたしの頭の中に映じだした。",
              "citation": {
                "source": "三等郵便局",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳利をこっちへ貸してくれ」　たぐりよせるように抱えこむと、立てつづけに小次郎は、ぐびぐびあおった。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ野茨だから、棘が一ぱいあるので、枝をたぐりよせることが容易に出來ないのである。",
              "citation": {
                "source": "巣立ち",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぐりよせる綱のさやさやと引擦り会ふ音はさつきと同じやうにあつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十米ぐらいの釣糸をぶら下げて全速力で走りながらたぐりよせると、相当大きな魚がぶらさがって現れてくるね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしの、おたみの女連、彦太郎、千吉、文三という小ッちゃい子供連、これをよびあつめて搦手から話をたぐりよせる。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二　密室大犯罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "あといろいろたぐりよせるのですが、シェクスピアの「オセロ」なんかやはり面白いところがあります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うーむ」と、思い迷ってうなりながら顔をあげたお母さんの視線をたぐりよせるように、健が唇をとがらせてだまって訴えている。",
              "citation": {
                "source": "赤いステッキ",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "道しるべのひもは、どこかで切れてしまったらしく、いくらでもたぐりよせることができるのです。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官は、いま、つたいおりた、ほそいひもを、手もとにたぐりよせると、それをまるめて、ポケットにおしこみ、屋上の出入り口から、劇場のなかへはいっていきました。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
