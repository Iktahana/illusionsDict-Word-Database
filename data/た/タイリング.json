        "examples": {
          "standard": [
            {
              "text": "お風呂場の床を滑りにくくするために、耐水性のあるタイリングを施した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幾何学模様のタイリングが美しいモスクの壁面は、見る人を圧倒する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "キッチンカウンターにカラフルなタイリングをして、自分好みの内装に仕上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "画面を単純に複数のウインドウに分割するだけのタイリング方式も試みられたが、ウインドウの大きさを自由に設定できて、重ね合わせることのできるオーバーラッピングウインドウを考案し、スモールトークに組み込んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイメイク（本来は結膜炎の予防）、毛の回復（最古のものはエーベルス・パピルスにあり第３王朝のシェス王妃のため）、香水（他のタイリングとともに女性性器の香料）、皮膚を滑らかにし容貌を良くするため、などの処方もまた発見された。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
