      {
        "index": 1,
        "gloss": "to rebuild",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "台風で被害を受けた家を、来年中に「建て替え」る予定です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "歴史的建造物を「建て替える」のは、元の姿を忠実に再現することが求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古民家をモダンなデザインに「建て替える」リフォームも人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "自分ひとりの場所となったその家を、彼は建て替えることを考える。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
