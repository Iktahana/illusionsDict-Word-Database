        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "各一つづつ取りて、堀切橋てふ粗かなる橋の袂に來りける。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕風さと袂をはらひて、波立ち騷ぐ音のみしるし。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『喧嘩だ、喧嘩だ、』背中を突かれて驚く男、袂をくぐられて間誤付く女、跳ね飛ばされて泣くは子供、足下を攫はれて轉ぶが年寄、呆氣に取られた人人の間を縫て、矢の樣に走つて行く一人の男。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自宅では勉強が出来ないので円行寺橋の袂にあった老人夫婦の家の静かな座敷を借りて下宿していた。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "てれかくしに袂から敷島を出して火をつけた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の袂に小屋があつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時過ぎに帰って来て、袂からおみやげの金鍔と焼き栗を出して余のノートを読んでいる机のすみへそっとのせて、便所へはいったがやがて出て来て青い顔をして机のそばへすわると同時に急に咳をして血を吐いた。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫は汗を袂で拭いながら言いました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ来たのだろう、夏との袂別をいつしたとも見えないのに秋をひそかに巴里は迎えいれて、むしろ人達を惑わせる。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは橋の袂から飛ぶやうに下の広い河原へおりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うと、またこっちの袂から一人がだくでかけて行きました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗衣かわかしたゝむ君しあればかりねの宿とわがおもはなくに廿三日小山の停車塲にて長塚と袂を分つ。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "済まねえけど少し貸してくんねえ」　「俺もすってんてんにいかれてしまって、これっきりよ」　と銭二三枚袂から出す。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　急ぎ足にすたすたと橋の袂にまで来た時、一人の浪人者とどんと突き当ってはずみを喰らって三次すってんどうと倒れた。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "見送る三次がお絹に、Ｔ「そーれ見なせえお絹さん」　と言って、Ｔ「俺と一緒に居るとお前迄があの通りやくざ者にされちまう」　と言うのを、　始終無言で聞いていたお絹が、　袂で隠して居た十手を三次に示す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お殿様は橋の袂に、何かを見て、お止まりなされた。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "………「あ、さうださうだ」その時私は袂の中の檸檬を憶ひ出した。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "濡れた道を遠泳会の一行は葛西川の袂まで歩いた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兩國橋の袂で先生と自分は一錢蒸汽に乘つた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の手を左の袂に入れてゴソゴソやっていたが、やがて「朝日」を一本取り出して口にくわえた。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "源叔父は袂をさぐりて竹の皮包取りだし握飯一つ撮みて紀州の前に突きだせば、乞食は懐より椀をだしてこれを受けぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の袂に眠りし犬｜頭をあげてその後影を見たれど吠えず。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　橋の袂　千倉で泊った宿屋の二階の床は道路と同平面にある。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の部屋の前が橋の袂に当っているので、夕方橋の上に涼みに来る人と相対して楽に話が出来るくらいである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の主人が一匹の子猫の頸をつまんでぶら下げながら橋の向う側の袂へ行ってぽいとそれをほうり出した。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中に聞いてみると、この橋の袂へ猫を捨てに来る人が毎日のようにあって、それらの不幸なる孤児等が自然の径路でこの宿屋の台所に迷い込んで来るそうである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫を捨てに出た人が格好の捨場を求めて歩いて行くうちに一つの橋の袂に来たとすれば、その人はまたおそらく当然そこでその目的の行為を果たすに相違ない。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の袂は交通線上の一つの特異点であって、歩行者の心のテンポにある加速度を与えるために自然に予定の行為への衝動を受けるのかもしれない。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの生活の行路の上にもまたこういう橋の袂がある。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同様に国家社会の歴史の進展の途上にも幾多の橋の袂がある。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
