        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だが、足るを知ること斯くの如き男でも、やはり、病が酷いよりも軽い方がいいし、真昼の太陽の直射の下でこき使われるよりも木蔭で午睡をした方が快い。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾子夫人の眼から、そっとかくれて、静かな、足るを知る幸福に甘んじて暮して行こうと思っていたのに、綾子夫人はこうした、慎しく隠されたる花園にまで、踏み入って来て、新子をそこから追い出そうとしているのである。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞿伽離見付けて諸比丘に向い、世尊｜毎も舎利弗は欲少なく足るを知ると讃むるが我らの手に入らぬこの珍物を蓄うるは世尊の言と違うと言った。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち万民｜安堵、腹を鼓して足るを知ることなれども、その足るを知るとは、他なし、足らざるを知らざりしのみ。",
              "citation": {
                "source": "教育の目的",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "足るを知るを勧むるにあらず、足らざるを知りてこれを足すの道を求むるにあるものなり。",
              "citation": {
                "source": "教育の目的",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ得意になって書かれてある字にも誤って慢心したる者の字と、いわゆる分を知り、足るを知るものの字は大なる相違があって、第一慢心者の字は慎みがない。",
              "citation": {
                "source": "墨蹟より見たる明治大正の文士",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "足るを知る者は富み、富多くして不幸な者もいる。",
              "citation": {
                "source": "観点",
                "author": "THE POINT OF VIEW",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる美を味わう茶人を数奇者といったが、「奇」とは、足らざる様を指すので、足らざるに足るを知る心の悦びを味ったのである。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝにて富士の根方の山々を望み、山の皺あるをみる、其やゝ近づきたるをしるべし。",
              "citation": {
                "source": "嘉陵紀行",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
