[
  {
    "uuid": "0d36c205-3f43-5259-b6ac-75449885e3dd",
    "entry": "体臭",
    "reading": {
      "primary": "たいしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "body odor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "華々しいもの、潔いもの、勇壮なるもの、さう云つたものから、子供の家へ帰ると、ひつそりと沈んだ冷え冷えとしたものが、両親の体臭のやうに、家中を靄のやうに立ちこめてゐた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の輪講会は人数が少なくてそれだけに却って極めてインチームなものであり、至って「尤もらしく」ない「勿体臭く」ないものであった。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長く風呂に這入らない不潔な体臭がその伍長は特別にひどかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "体臭にまで豚小屋と土の匂いがしみこんで居る。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、獣油や、南京袋の臭いのような毛唐の体臭が残っていた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かすかな体臭のようなものが画面にただよう。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいに、この季節には、べとべと、噎せるほどの体臭がある。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見ることによってわれわれは百度の気温と強烈な体臭を想像する。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲んだばかりの酒の匂いではなく、常習的な酒癖のために、体臭になったかと思われるような匂いだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台には若い娘の体温と体臭がむうんとこもっていた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づいた途端、妙に熱っぽい体臭がぷんと匂った。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱っぽい体臭を感じて、私はびっくりして飛び上った。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、頭の底にコビリ付いている残りの睡たさを貪りながら、いつの間にかグッスリと眠っているらしかったが、そのうちに小さな咳払いを耳にしてフッと眼を醒ますと間もなく、何ともいえない上品な香水の匂いが、悩ましい女の体臭と一緒にムーッと迫って来たので、一寸の間狐に抓まれたような気持ちになった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにかしら同じ体臭が感ぜられた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれこれと考えれば考えるほど青扇と僕との体臭がからまり、反射し合っているようで、加速度的に僕は彼にこだわりはじめたのであった。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままで恋愛ではないと云つてゐた小布施と桂子の交情に、桂子が顧みていくらか忸怩としてゐたことは、男からの体臭的慰安だつた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小布施の普通より大柄の体格が、ネルのやうに柔い乾草のやうに香ばしい体臭を持つてゐた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小布施の体臭からうけるこの影響は、時間も距離も超越してゐた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、それ程あつさりした間柄と思つてゐた男を、あの体臭ぐるみ他人に独占されたとなると、むら／＼と苦痛に絶する焔が肉体の内部を転動させて、長年鍛へた魂の秩序も、善悪の判断も、芸術への殉情も一挙に覆りかけるとは――。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのやうな、名人と申しませうか、奇人と申しませうか、その悪業深い体臭は、まことに強く、おそるべき力を持つてゐるもののやうに思はれます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金魚をいじったあとの、あのたまらない生臭さが、自分のからだ一ぱいにしみついているようで、洗っても、洗っても、落ちないようで、こうして一日一日、自分も雌の体臭を発散させるようになって行くのかと思えば、また、思い当ることもあるので、いっそこのまま、少女のままで死にたくなる。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち、一人の女の眼が、孔雀石の粉を薄くつけた顔が、ほっそりした身体つきが、彼に馴染のしぐさと共に懐かしい体臭まで伴って眼前に現れて来た。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人ともみな若草のような体臭を持った美しい娘たちばかりでありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもこう話しているうちに、決して男性の体臭的でない明るいすがすがしい気配が、青年の顔色や態度に現われて来た。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見栄も外聞もなく加奈子に委せ切った様子が不憫で、また深々と抱き寄せる加奈子の鼻に、少し青くさいような、そして羊毛のような、かすかな京子の体臭が匂う。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "裳裾のようにパッとひらいた頽廃の夜が、葉鶏頭の花にも似た強烈な色彩に揺れて、イヴニングドレスの背中をくりぬいて見せた白い素肌が、蛇のようにくねると、そのくぼみに汗が汗ばみ、女の体臭を男の体臭が絞り出すような夏の夜の踊りに、体の固い若いダンサーのステップもいつか粘るのだった……。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "レンズが肉体に化した木崎の写真は、印画紙からニヒリズムの体臭が漂うくらい、個性が強く、彼のねらう構図にはつねに夜が感じられて、ふとデカダンめいたが、今夜の陽子と茉莉の写真も「夜のポーズ」という彼の好みのテエマにふさわしかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
