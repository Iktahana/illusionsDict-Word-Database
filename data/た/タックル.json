    "definitions": [
      {
        "index": 1,
        "gloss": "tackling (to the ground)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
