    "definitions": [
      {
        "index": 1,
        "gloss": "tackling (to the ground)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "犯人が逃走しようとした瞬間、刑事は背後から鋭いタックルを見舞って地面に組み伏せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「不審者が暴れたので、ガードマンがタックルして取り押さえた」という通報が警察に入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は泥酔して暴れている男にタックルを仕掛け、大きな怪我をすることなく静止させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ヤマ、目いっぱいキツいタックルかなんか、やらない？",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "社の会の帰途十時ごろ、神田駅のプラットフォームで集団スリにとりかこまれて、集団タックルの波状攻撃をうけて全滅したのである。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が自分自身の無理なもの、無駄な飾り、いらない重たいものから抜けだして、日に新しく、日に日に新しく自由な、ほんとうのものになるということの中には、常にまといつく古いもの、進みいこうとする足もとに群がってやってくるタックルのようなものを鋭くはらい捨て、脱落し、脱走するある切実なものがあるわけである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "向いのシルコ屋から飛びだしてきて、左近の腰にタックルするように飛びついた小人があった。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "参道の茶店の婆さんたちはよその土地のパンパンのタックルと同じぐらいの勢いでつかみかからんばかり、あるいは哀願して泣訴のおもかげあるものもあり、だいたい日向もはずれのこの鵜戸の地にこれだけの茶店が参道に並ぶというのが意外なことだ。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンパンなみのタックルもやりかねまじいすさまじさ。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからパンパンが、自分のビジネスとなれば、チョイト、遊バナイ、抱きついたり、タックルしたり、そういうことも出来るのだろう。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "口のかたい警官とちがって、素人の私に新聞記者の総攻撃が集中したのは当然で、私は病院前で車を降りると、パンパン街の百倍ぐらいのタックルにあい、時を失して、病院から締めだしをくうところであった。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り、パンパンのタックルは熱海の比ではない。",
              "citation": {
                "source": "安吾巷談",
                "author": "湯の町エレジー",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひきずりこまれるというのは客ひきの女給が街頭に無数に出ていてタックルするからだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "女給が街頭に出張していると、男が酔っ払って通りかかったのでタックルした。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう奇怪な人物が酒場を経営し、女給に命じてお客をタックルさせ、前後不覚の客に飲み物を押しつけて売るというのが、新宿の公然たる性格なのだから穏かではない。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "タックルしてくる客がお金があろうがなかろうが構わない。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "街娼ということは、決して街頭へでてタックルするというだけのものではない。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、給仕男のタックルはそれより早く、とう／＼ニンゲルをその場にねじ伏せてしまった。",
              "citation": {
                "source": "“能筆ジム”",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瞬前まで息せききって柳子が須永を追いかけまわしていた事が一目でわかる姿で、フットボールの試合でボールを追って横っ飛びしかけた選手を敵の選手がタックルした瞬間に、画面がピタリと停ったのに似ている。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "タックルせざるべからずなど例の高声にひとりうち語る。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
