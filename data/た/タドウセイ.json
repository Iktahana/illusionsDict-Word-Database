        "examples": {
          "standard": [
            {
              "text": "「この表現は、主語の意志が強く反映される他動性が高い言い回しだと言える。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「文学的な表現として、あえて無生物を主語にして他動性を持たせる手法がある。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「言語学の論文で、動詞の他動性が文の構造にどのような変化をもたらすかを検証した。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「――しかし、そのような女が、やがて日がたつと、突如として他動性を発揮して、夫のほかに男をこしらえて、その男に身を任す、進んで身を任すという事実には、もう驚きません。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、女のこんな微笑と大胆な他動性とは男にとつて全く解きがたい謎であるばかりでなく、困つたことには無邪気にさへ見えてしまふ。",
              "citation": {
                "source": "姦淫に寄す",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
