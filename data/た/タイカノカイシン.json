    "definitions": [
      {
        "index": 1,
        "gloss": "Taika Reforms (645 CE)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
