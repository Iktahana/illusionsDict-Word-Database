        "examples": {
          "standard": [
            {
              "text": "このステーキは厚みがあって、「食べで」があるから満足感が高い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "安くて「食べで」のあるメニューを探して、学生街の定食屋に入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "煮込み料理に根菜をたっぷり入れると、ぐっと「食べで」が出る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "少年の頃、自分がうまいものをよそで饗ばれて帰って話すとき、母は根掘り葉掘り詳しく聞き返し、まるで自分が食べでもしたような満足さで顔を生々とさしたではないか。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯ぎれのよい、食べでのある茸だ。",
              "citation": {
                "source": "山の秋",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お前の体じゃ鬼も食べでがあるまいが、鬼も食わないよりましだろう。",
              "citation": {
                "source": "鬼退治",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七日には、寿江子と佐藤さん夫妻を赤坊ごとよんで何か皆でたべでもしましょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
