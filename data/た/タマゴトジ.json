        "examples": {
          "standard": [
            {
              "text": "カツ丼は、サクサクのトンカツを甘辛い出汁と卵とじにすることで美味しさが倍増する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "余った野菜をさっと煮て卵とじにすれば、立派なおかずが一品出来上がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "揚げたての海老天を卵とじにした天とじ丼は、ボリューム満点で学生に人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "昼飯に川魚をと注文したら、石狩川を前に置いて、罐詰の筍の卵とじなど食わした。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五つになる女の子は、卵とじの丼をかかえ、しきりに汁をはねかしながら、蕎麦を喰べるのに熱中してい、年が明けると二歳になるという下の女の子は、母親に抱かれて乳を咥えていた。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかめ、卵とじ、鴨南蛮、鍋焼――と、昔風なのからカレーうどん、きつねうどん（油揚げの入った奴。",
              "citation": {
                "source": "うどんのお化け",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日のこと、又色々考えた末に、今日は一つ、おかめと卵とじの合同うどんを拵えて呉れないか、と註文した。",
              "citation": {
                "source": "うどんのお化け",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
