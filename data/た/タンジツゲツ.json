[
  {
    "uuid": "5c481cbc-2d82-579e-88c7-e5a7d23efb53",
    "entry": "短日月",
    "reading": {
      "primary": "たんじつげつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
