        "examples": {
          "standard": [
            {
              "text": "印刷の前に、色合いを確認するために試し刷りを行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プリンターの調子を見るため、モノクロで試し刷りをしてみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "本番の印刷に入る前に、必ず試し刷りで最終チェックをする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "床には、新聞紙や試し刷りが散らかっている。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし否定すれば、台上にある眼の前の試し刷りで、嘘の皮をひんむくぞ」　ハントが長いゲラ刷りをちらと見て、そわそわ。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "編集長の机には記事の試し刷りがあった。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご覧なさい、グラスゴウ殿下、大儲けのチャンスです」　目の前の大型封筒から、ルペラ男爵が大きな試し刷りを取り出した。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんな時々失敗しますよ」　男爵が試し刷りを拳でぱしゃと叩いた。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
