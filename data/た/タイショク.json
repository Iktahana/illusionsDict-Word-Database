[
  {
    "uuid": "98842b2c-c35a-5993-b404-ae0f36874e73",
    "entry": "退職",
    "reading": {
      "primary": "たいしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
