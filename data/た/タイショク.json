    },
    "definitions": [
      {
        "index": 1,
        "gloss": "retirement",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一九一九年彼の死ぬる少し前に辞表を出し、間もなくグレーズブルックも停年で退職した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "退職技手こぞりてひとを貶しつゝ、　　　わかれうたげもすさまじき、おのれこよひは暴れんぞと、　　青き瓶袴も惜しげなく、籾緑金に生えそめし、　　　　　代にひたりて田螺ひろへり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、チエホフを読んだことのある青年ならば、父は退職の陸軍二等大尉、母は傲慢な貴族、とうっとりと独断しながら、すこし歩をゆるめるであろう。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、間もなく小隊長は右隣の退職官吏の一人娘の一枝に送られて帰って来た。",
              "citation": {
                "source": "電報",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は女学校を卒業して親の家で結婚前の生活をしてゐる期間に、望まれて父親の知合ひで郊外に隠寮を持つ退職官吏Ｙの家へ客分として預けられることになつた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "退職官吏Ｙの考へでは、自分の蒐集品の殊にこまかい細工ものゝ昔人形や、壊れものゝ陶もの類は、骨董美術品商の娘であるかの女の馴れて丹念な指先が、手入れ保存に適当だと思つたからであつた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "教師が退職してしまえば、それっきり他人になるんだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか無垢の人を傷めた気持で、どんな事情なのか、それは本当なのか問い訊す余地もないほど、乞食の老人の言った安宅先生退職の話は、かすかながらも身に覚えがあるのが身の内から証拠を言い立てゝ、真実に思えて仕方ありません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま安宅先生がいないというなら、これが一番確な方法じゃないか」　もしか、また、それでも安宅先生が言うことを聴き容れて呉れないとしたら、先生退職の理由を詳しく確めながら、学園生徒全体の留任運動を正月早々起しても手遅れにはなるまいと、義光ちゃんは考え深く附け足しました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの間の秘密の事情が学園に判れば、普通の常識で捌いて、先生は学園を退職させられる許りでなく、恐らく最早や二度と教育界には立つことは出来ないであろう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「学園から呉れた退職金で二月や三月は食い継ぎは出来るようなものゝ、さて、その先をどうするか、二人ともさんざん気を揉んでるに違いないんだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か退職官吏の邸らしい。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "退職したときにも、数万円の手当を貰った。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "門衛のほうの名簿ですと、松島さんは昨日限り退職されたことになっておりますがね」　門衛は落ち着いて帳簿を繰るのだった。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私は退職外科軍医ですよ」「そうですか。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親は、相場、鉱山などに引かかって、大分不景気だったようですが、もと大蔵省辺に、いい処を勤めた、退職のお役人で、お嬢さん育ちだから、品がよくちょっと権高なくらい。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "子の耕造も、父の訪米中に三井物産を退職していました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューター事業のトップが実際にマシンを使うことを楽しんでいるか否かの割合をオレは世の中一般と同程度とにらんでいて、インタビューの相手と向き合うやいなや、退職した日にこの人物がマシンをドブに捨てるのか、神棚に飾り続けるのか見抜く特技を持っている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『そりゃね、だれも払わんとはいわんのだが、どういう手続きで持って行こうってんだね』『支払い伝票さえ書けばいいこっちゃありませんか』『つまり、退職しようというんだね』と、意地わるの後明人事係はいった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれが、いつ退職なんていったんです』と白水は少しずつ興奮してやり始めた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "『だが、会社の規則では、積立金は、退職の時に支払うということになってるもんだからね。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "『労働者が退職して行く時に、積立金が賃銀と同時に支払われるのは、当然なんだ、それは工場法にも明記されてあることなんだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その金が本人退職後もなお会社に残っていたとすれば、明らかに委託金横領ではないか、その金が支払われるのが、いつも最後の例だからって、その金を受け取ることによって、辞職を意味するなんて、そんな詭弁が、よくも人事係の君の口から吐けたもんだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "『しかし、私はまだ、馘首するとも退職せよともいいはしないんですよ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二八（昭和三）年　六月、旭川新聞社を退職。",
              "citation": {
                "source": "小熊秀雄全集-1",
                "author": "短歌集",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたしてそれは免職と、退職慰労との会社の辞令だった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙には退職慰労金の受け取り方に関する注意が事々しい行書で書いてあるのだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "官報局を罷めたのは偶然であるが、退職すると同時にこの野心が俄に活火山の如く燃上って来た。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "退職願いを出すなあ敬四郎のほうだよ」「じゃ、なんですかい、だんなはまだ勝つつもりでいらっしゃるんですかい」「おかしなことをいうね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
