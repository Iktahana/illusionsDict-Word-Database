    "definitions": [
      {
        "index": 1,
        "gloss": "sleeping away from home",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "死にもせぬ旅寝の果よ秋の暮枯枝に鴉の止りけり秋の暮　曠野の果に行きくれても、芭蕉はその「寂しおり」の杖を離さなかった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅寝の衣には露霜が置いていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "病雁の夜寒に落ちて旅寝かな　　　　　　　　芭蕉僅かの花が散りければ梅は総身に芽ぐみぬ　　井泉水わが足跡人生ひてわれにつゞく朧　　　　　　地橙孫陽の前に鳥ないて安らかな一日　　　　　　　鳳車　これらの句を読んだ時、私は或る物を掴んだように思うた。",
              "citation": {
                "source": "俳句に於ける象徴的表現",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅寝を重ねてこゝまで来る間に、葛岡はもう安宅先生指導の二河白道の距てのバンドも横えず、それから宿帳に夫婦と名乗ってつけることもしなくなりました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅寝を重ねて行くうち私たち二人のみょうとに似た関係もいつか水無川の流れのように断えてしまいました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿飛佐助は、そなたの前から、今宵限りに姿を消して、あとは気任せ、足任せ、時には飛行の一足飛びに、日本全土飛び歩く、忍術道中の草鞋をはいて、はいて捨てるは毒舌三昧、ああこれからが面白いが、そなたに別れるこの苦しさは、少し旅寝の枕を濡らそう。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず一度異境に旅寝しては意外に平気で遊んでいる。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭義の地方に旅寝して、ある夜ある駅に泊まって、まさに足をすすごうとしているところへ、※青の張という役人が数十人の供を連れて、おなじ旅舎へ乗り込んで来た。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "兼ねて楽しんでゐた独りきりの旅寝の夢が結ばれるともう其事ばかり考へて急いだ。",
              "citation": {
                "source": "岬の端",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔡温は旅寝の空に幾度か、かかる悲哀を感じたのでありましょう。",
              "citation": {
                "source": "琉球史の趨勢",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸本が一年近い旅寝の寝台はその額の掛った壁によせて置いてあった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "志の末通りけるか、万里の外なる蘇武が旅寝に故郷の砧きこえしとなり。",
              "citation": {
                "source": "謡曲と画題",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶山が前年の夏より此年の春に至るまで、江戸に旅寝をした間、北条を神辺の留守居に置いたことは、黄葉夕陽村舎詩にも見えてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭中将が、「花の蔭の旅寝ですね。",
              "citation": {
                "source": "源氏物語",
                "author": "藤のうら葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になるといっそう天気が悪くなり、ますます吹きつのる風の音を聞きながら、寂しい旅寝の床に歎き続けておいでになるのもさすがにおいたましく思われて、女王はまた物越しでお話を聞くことにした。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            },
            {
              "text": "やどり木と思ひ出でずば木のもとの旅寝もいかに寂しからまし　と口ずさんでいるのを聞いて、弁が、荒れはつる朽ち木のもとを宿り木と思ひおきけるほどの悲しさ　という。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁の君は、「わざと老人じみたことをお言いになっては反感が起こるものですよ」　と言い、「旅寝してなほ試みよをみなへし盛りの色に移り移らず　そのあとであなたをどんな性質で、お堅いともそうでないとも、きめましょう」　とも言う。",
              "citation": {
                "source": "源氏物語",
                "author": "蜻蛉",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の来て旅寝を誘ふ言ふ様に雲に乗らまし靄に消えまし　今日から見れば丸で夢の様な昔話であるが、我が日本にもさういふことの出来た時代があり、選ばれた少数のものにはそれが出来た。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅寝する人のささやきは同行四人の自分らのささやきであらう。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の色窓にきたりて白ければ旅寝すずしき瀬戸の夜の船船にゐて児らの上をば思ふにも哀れなるかな瀬戸の夜の月八日の朝、門司に碇泊す。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯ちかく旅寝をすれば夜もすがら網引やすらし※の音ぞする衣。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくがれて花に幾夜の旅寝すと知らで家には我を待つらん夕立五首。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○虫声うきふしの、旅寝の身さへ、忘れけり。",
              "citation": {
                "source": "鉄窓の歌",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供を忘れ、身を忘れ、こんな旅寝を、はるばると思ひ立つたは何ゆゑか。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前には拷問の呻きを聞き、今またこの悲しい声を耳にして、熟々旅寝のいぶせき事も知ったし、その上自分も父が旅に病んでいて、それがためにこういう淋しい旅行をするのかと思うといよいよ夢も結ばれぬのであった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "一首は、阿騎の野に今夜旅寝をする人々は、昔の事がいろいろ思い出されて、安らかに眠りがたい、というのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ使者がきて秀吉の旨を伝へたが、勝手にするがいゝさ、秀次は陰気な顔をそむけたばかりで、却つて帰洛の予定を延して旅寝の陰鬱な遊興に沈湎した。",
              "citation": {
                "source": "我鬼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ当もなく逃げまはる旅寝の夢が、私の人生の疲労に手ごろな感傷を添へ、敗残の快感にいさゝかうつゝをぬかしてゐるうちに、女が私の所有に確定するやうな気分的結末を招来してしまつたゞけだ。",
              "citation": {
                "source": "いづこへ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "上皇はわづかばかりの旅寝の日数のうちに、世の移り変りの激しさに驚くのだ。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内にも秋は次第に闌けて旅寝の夜の衾を洩れる風が冷たく身にしむようになってくるにつれて、いつになったら、果てしの着くとも思われない愛欲の満たされない物足りなさに、私はちょうど移りゆく四囲の自然と同じように沈んだ心持に胸を鎖されていた。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
