[
  {
    "uuid": "61a7ad41-bf85-53d1-82f7-4c78f1fe1896",
    "entry": "丹精",
    "reading": {
      "primary": "たんせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
