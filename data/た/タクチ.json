        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしアイヌだと「コッチ」「コーチ」宅地となる。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧宅地の管理は同町内のＯ氏に依頼してあるので、去年以来わたしは滅多に見廻ったこともない。",
              "citation": {
                "source": "九月四日",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもわたしの旧宅地附近は元来が住宅区域であったので、再築に取りかかった家は甚だ少い。",
              "citation": {
                "source": "九月四日",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣にＫ氏の新しい建物が立っているので、わたしの旧宅地もすぐに見出されたが、さもなければ容易にその見当が付き兼ねて、路に迷った旅人のように、この草原のなかを空しくさまよっている事になったかも知れない。",
              "citation": {
                "source": "九月四日",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐵道工廠の住宅地域！",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄道｜工廠の住宅地域！",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口に俥止の杭が打つてある、質素な住宅地の太く通つてゐる筋の道路を右に切れ込んだ角から二軒目に、小布施の住居があつた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の両側は文化住宅地だった。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女達が伯林の新住宅地で見て来たような大小の文化住宅が立ち並んでいる。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何処の国の都会の住宅地でもそうだけど、五万円や八万円かかった住宅はどっさり建ってるでしょう。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく伯林市から離れて近郊に住宅を持つ勤人の遠距離の住宅地の一つなのであろう。",
              "citation": {
                "source": "褐色の求道",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十男の水呑百姓と思つたのは、學校より十町ばかり隔だつて居る松林の奧に一構の宅地を擁し、米倉の三棟を並べて居る百姓、池上權藏といふ男で、大島小學校の創立者、恩人、保護者であつたのです。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "カランカランという踏切の音を背中に聴きながら、寝しずまった住宅地を通り抜けると、もはや門燈のにぶい光もなく道はいきなりずり落ちたような暗さでそこに池がある。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "新らしき文化住宅地緑ヶ丘の突端にある此の馬込の新居は、明朗にして簡素、月・霧・燈・火の夜景は亦九十九谷の名にそむかず、少くとも近代詩趣の一年なり。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "新らしき文化住宅地緑ヶ丘の突端にある此の馬込の新居は、明朗にして簡素、月・霧・燈火の夜景は亦九十九谷の名にそむかず、少くとも近代詩趣の一年なり。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてこの宅地を開く時に自然のままを残したのである。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "登の子四郎右衛門は物奉行を勤めているうちに、寛延三年に旨に忤って知行宅地を没収せられた。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼け跡の区画整理は片付いて邦原君一家は旧宅地へ立ち戻って来たので、知人や出入りの者などについて心あたりを一々聞きただしてみたが、誰も届けた者はないという。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな夜更けの住宅地では、もう帰る車を拾うのも容易ではないと諦めた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会の膨張につれ、郊外の農耕地域の所有価値が激しく暴騰したので、郊外の地主たちは小作人たちからその土地を取り上げて都会の人々に住宅地としてそれを提供した。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでの吾平爺はわずかばかりの小作地を耕すかたわら、集落内の農家に雇われていったのであったが、耕地が住宅地になるにつれ爺を雇ってくれる農家はしだいに少なくなっていった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るい商店続きの町を出外れると、そこから二三町ほどの間は、分譲住宅地として取り残されている荒れ野原だった。",
              "citation": {
                "source": "接吻を盗む女の話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "数マイルほど進むと郊外の住宅地のあたりに入り始めたが、つとホームズは身を震わせ、肩をすくめると、パイプに火をつけた。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車線路のこっちに一幅の耕地を持って高まった丘は、電車が開通するとともに文化住宅地になって、昼間電車の中から見ると丘の樹木の間から碧瓦や赭瓦の簷が見えた。",
              "citation": {
                "source": "白っぽい洋服",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その路には住宅地組合で建てた街燈がぽつぽつあった。",
              "citation": {
                "source": "白っぽい洋服",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは住宅地に住む人達の朝晩に散歩する処であった。",
              "citation": {
                "source": "白っぽい洋服",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに兄は先妻の子で務のためには異母兄であるが、親のように平生家の面倒を見てくれているので、気の小さな務は宅地をなくしては兄に顔を合せることができなかった。",
              "citation": {
                "source": "白っぽい洋服",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は原利息のために務に金を貸していたが、手許がくるしくなったので、壮い男の入智で山岡の宅地を奪って外へ売ろうとしているのであった。",
              "citation": {
                "source": "白っぽい洋服",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小供の背丈けほどもある昼間見ると藜※のような草と粟粒のような微紅い実をつけた草がぎっしり生えた住宅地の入口に、人の足によって通じた一条の路がうっすらと微月の光に見えていた。",
              "citation": {
                "source": "女の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのトッテン師匠の高座が一九九〇年六月十三日、新百合ケ丘のアシスト本部でかかると聞いたものだから、日本一のウイルス男たるこのオレは、システム・ダウン寸前の老骨にむち打って、小金持ちの蝟集する川崎市麻生区の新興高級住宅地へと馳せ参じたのである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
