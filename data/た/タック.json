      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tuck (clothing, sewing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その奥の暗がりの中で、幾個かのチックタックの音が、やはりホコリだらけの呼吸を断続させている。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女のアタック、ボウイングともに輝かんばかりだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初からカラーに対応しており、スタックと呼ばれるカードのまとまりを巧みに連携させる、構造化の仕組みが盛り込まれていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタックを作ることも、作ったスタックを動かすことも、マックの上でしかできません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マシンが届いて三十分の内に小説の数ページがハイパーカードのスタックに仕立てられ、パワーブックで回覧された。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤマ、目いっぱいキツいタックルかなんか、やらない？",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある行為をする自分を反省し、その反省を行う自己を反省するというように、心の内部へ内部へとほり下げて行く、その過程の叙述が現代作家のもっとも興味をもってアタックしたいと考える対象である」と規定せられている。",
              "citation": {
                "source": "芸術が必要とする科学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "失敗しても何度でもアタックする。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカナー　ヤーヤ　ヤキタン　ドー　ハークガ　ヤンムチ　コーティ　タックワー　シー　夕焼があると、何時でも子供達が意味の解らぬなりに面白がって歌ふ謡である。",
              "citation": {
                "source": "奥間巡査",
                "author": "池宮城積宝",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに他のこれと駢列する本能をもってアッタックせらるるとき崩れてしまうのである。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "社の会の帰途十時ごろ、神田駅のプラットフォームで集団スリにとりかこまれて、集団タックルの波状攻撃をうけて全滅したのである。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "獨りで暮してしつかり勉強したいとも思ひ、また下宿料も安かつたので、かうして彼はスタックダヴ町の植木屋のレイバーンの家に住むことになつたのであつた。",
              "citation": {
                "source": "若い僧侶の話",
                "author": "スティーヴンスン",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が自分自身の無理なもの、無駄な飾り、いらない重たいものから抜けだして、日に新しく、日に日に新しく自由な、ほんとうのものになるということの中には、常にまといつく古いもの、進みいこうとする足もとに群がってやってくるタックルのようなものを鋭くはらい捨て、脱落し、脱走するある切実なものがあるわけである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "向いのシルコ屋から飛びだしてきて、左近の腰にタックルするように飛びついた小人があった。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "参道の茶店の婆さんたちはよその土地のパンパンのタックルと同じぐらいの勢いでつかみかからんばかり、あるいは哀願して泣訴のおもかげあるものもあり、だいたい日向もはずれのこの鵜戸の地にこれだけの茶店が参道に並ぶというのが意外なことだ。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンパンなみのタックルもやりかねまじいすさまじさ。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからパンパンが、自分のビジネスとなれば、チョイト、遊バナイ、抱きついたり、タックルしたり、そういうことも出来るのだろう。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "口のかたい警官とちがって、素人の私に新聞記者の総攻撃が集中したのは当然で、私は病院前で車を降りると、パンパン街の百倍ぐらいのタックルにあい、時を失して、病院から締めだしをくうところであった。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り、パンパンのタックルは熱海の比ではない。",
              "citation": {
                "source": "安吾巷談",
                "author": "湯の町エレジー",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひきずりこまれるというのは客ひきの女給が街頭に無数に出ていてタックルするからだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "女給が街頭に出張していると、男が酔っ払って通りかかったのでタックルした。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう奇怪な人物が酒場を経営し、女給に命じてお客をタックルさせ、前後不覚の客に飲み物を押しつけて売るというのが、新宿の公然たる性格なのだから穏かではない。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "タックルしてくる客がお金があろうがなかろうが構わない。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "街娼ということは、決して街頭へでてタックルするというだけのものではない。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、給仕男のタックルはそれより早く、とう／＼ニンゲルをその場にねじ伏せてしまった。",
              "citation": {
                "source": "“能筆ジム”",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「月が星のなかにあります、おおコラムよ、きょう神と共にある老ムルタックは、神とあなたのお心どおり、島の東端のかわいた砂の深みに葬られます」　そこで聖者は疲れねの床から起きあがり、ムルタックの葬られたところに行って、その場所を祝福した、地に這う虫もいかなる生物も聖き死者に触るるなと命じた。",
              "citation": {
                "source": "海豹",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "tuck (diving, gymnastics)",
        "register": "standard",
