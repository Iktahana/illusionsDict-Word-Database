    "definitions": [
      {
        "index": 1,
        "gloss": "to help a person stand",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜中に籠れる歇気を吐くのであろうか、夜中に凝る乳を粒立たすのであろうか、とにかく、この湧玉をみて、そして峯を仰ぐとき、確に山の眼覚めを思わせる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜田川守貞の『近世風俗志』に「首筋に白粉ぬること一本足と号つて、際立たす」といい、また特に遊女、町芸者の白粉について「頸は極て濃粧す」といっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十九年五月　　内陣ほのかなる香炉のくゆり、日のにほひ、燈明のかげ、――文月のゆふべ、蒸し薫る三十三間堂の奥空色しづむ内陣の闇ほのぐらき静寂に、千一体の観世音かさなり立たす香の古びいと蕭やかに後背のにぶき列ぞ白みたる。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬不思議なる夕かな、その光は、高く、熱く、遠近を染め、そして幽かに、今し、思ひがけなき坂の上に虔ましき馬を立たす。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、神々、神つどひ、早も立たすと、暁、来たり立たすと、戟を手に、東の方目翳しましつ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで花のような模様を描いて、海面のところどころに日光を恵んでいた空が、急にさっと薄曇ると、どこからともなく時雨のような霰が降って来て海面を泡立たす。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の心を浮き立たすような笛や鼓の音が、楓の林の中から聞えている。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の心を浮き立たすやうな笛や鼓の音が、楓の林の中から聞えてゐる。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手を不當に憚かつてゐる、卑屈なものを感じて、それは彼を苛立たすのである。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それならそれで、立たす支度をしなけあならん。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "英雄的なものに対する感動はそのときむしろ手をつかねて傍観していた人々の心持を湧き立たすのであって、その消防夫の努力をたやすくしようとしてバケツ一つの水でも走って運んでいる者には、感情と行動の極度の緊張、節約があるだけである。",
              "citation": {
                "source": "祭日ならざる日々",
                "author": "――日本女性の覚悟――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕もよ、僕もチャチン」　姉娘が、母の手許からすりぬけて来た末子を、「坊やちゃん、ここよ」と自分の前に立たす。",
              "citation": {
                "source": "百花園",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で個々の性能をどんな方面に社会的に役立たすかという意味における個性尊重、どういう表現を通じて役立てて行くかという点における個性尊重というものは勿論十分各々行われている。",
              "citation": {
                "source": "ソヴェト・ロシアの素顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇遊獵内野之時中皇命使間人連老獻歌やすみしゝ我大君の、あしたには取り撫でたまひ、夕にはいよせ立てゝし、みとらしの梓の弓の、なか筈の音すなり、朝狩に今立たすらし、夕狩に今立たすらし、みとらしの梓の弓の、なか筈の音すなり　中皇命は舒明天皇の皇女なり。",
              "citation": {
                "source": "萬葉集を讀む",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが人生を波立たす何ものかの一つだったのか。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "盥のなかに湯浴みするよき肉づきの生みの児の白き裸を見るときは、母の心を引立たす。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂に埋れて顔を出す濡れた黄いろの月見草、あれ、あの花が憎いほどわたしの心をさし覗き、思ひなしかは知らねども、やつれた私を引き立たす。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初夏が来た、初夏は青い焔を沸き立たす南の海の精であろ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜は気をうき立たすものぢやに却つてわれにもともに心もとない思をさせる。",
              "citation": {
                "source": "用言の発展",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（とヨハナーンを床の上に立たす。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この長歌は、「やすみしし吾大王の、朝にはとり撫でたまひ、夕にはい倚り立たしし、御執らしの梓弓の、長弭（中弭）の音すなり、朝猟に今立たすらし、暮猟に今立たすらし、御執らしの梓弓の、長弭（中弭）の音すなり」（巻一・三）というのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお山部赤人の歌に、「朝猟に鹿猪履み起し、夕狩に鳥ふみ立て、馬｜並めて御猟ぞ立たす、春の茂野に」（巻六・九二六）がある。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時ので立たす、汽車賃 500、見マイ 2000、何だかほんとという心もちがしない。",
              "citation": {
                "source": "日記",
                "author": "一九五〇年（昭和二十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒の神、常世にいます、石立たす少名御神の、神壽ぎ壽ぎ狂ほし、豐壽ぎ壽ぎ※し、獻り來しみ酒ぞ。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三間先に雷鳥が一羽、人懐しげにこっちを見て立っている、遠い祖先から伝った残忍性の血汐を燃え立たす程の余裕を持たない。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その絶命寸前のオレの脳裏には、ミクロン・オーダーであるはずのウイルスが四十人の坊主頭の科学者による遺伝子操作で超巨大化し、東京タワーをはさんで「ウイルス退散」と大書したたすきをかけた正義のモスラと死闘を演じる様が浮かんだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は、たたすかりますか。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏目にたたすあえかさに、ひと日は、白き難波薔薇夕日がくれに息づきし津の國の野を思ひいで。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さても、眞晝を玉敷の御苑にたたす君なれば、夜半にはかかるくたら野に、すずろ歩きもし給ひぬ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二伏目にたたすあえかさに、ひと日は、白き難波薔薇、夕日がくれに息づきし津の國の野を思ひいで。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
