        "examples": {
          "standard": [
            {
              "text": "炙った畳鰯を軽く手で割って、酒の肴にするのが父の楽しみだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お土産にいただいた畳鰯は、磯の香りが凝縮されていて美味しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この店では、畳鰯をチーズと一緒に焼くという意外な食べ方を提案している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "女はうつむいて、畳鰯を炙っていたが、白い顔には酒の気があるようにも見えなかった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳鰯も喜んで食べた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "精進の畳鰯だと云って、居合せた甲子が、さっそく浸しものに湯がいて、箸を下しながら、酒を飲んだ。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
