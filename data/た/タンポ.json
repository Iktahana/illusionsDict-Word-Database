  {
    "uuid": "aef58c88-24a1-5fcb-b6d4-4c2b3583a9ee",
    "entry": "タンポ",
    "reading": {
      "primary": "タンポ",
      "alternatives": [
        "たんぽ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pad",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "タンポポの花一輪の贈りものでも、決して恥じずに差し出すのが、最も勇気ある、男らしい態度であると信じます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "タンポポの花一輪の信頼が欲しくて、チサの葉いちまいのなぐさめが欲しくて、一生を棒に振った。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると又それに連れて図書館の外側の手入れが不充分になったらしく、スレート屋根の上にタンポポだのペンペン草だのがチラチラと生え始めた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしたちの知っている、たった一つの歌をね」　それから、ゲルダは、つやつやした緑の葉のあいだから、かがやき出ている、タンポポの花のところへ行きました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると、タンポポは、それは美しくかがやいて、もう一度ゲルダをながめました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "タンポポは、どんな歌をうたったでしょうか？",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、これが、わたしのお話ですよ」と、タンポポは言いました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから日が暮れて、女中と一緒にお茶の間で、御飯をたべてしまうと間もなく片隅に敷いてある寝床の中に、湯タンポを入れてもらって、小さな身体をもぐり込ませる。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "スミレ、タンポポ、野菊、ツツジ、白ウツギ、アケビ、野バラ、それから、私の知らない花が、山路の両側の芝生に明るく咲いてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "タンポポ一輪の信頼を欲していただけであった。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "タンポポ（葉と根と）。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "太いタンポポの根もいろいろと使ひ道の有るものである。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻子を引連れて福岡の城外練兵場へ出て、タンポポの根なぞを掘って来て露命を繋いでいたというのだから驚く。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "御本人に聞いてみると、「ナニ、タンポポの根というても別に喰い方というてはない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲公英（タンポポ）は、本邦で朝開き午以後萎むといふが、歐洲では、毎朝五時に開き午後八時に閉るから牧童の時計とし、又、晴雨計たり。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハマボウフウの生えている砂地や、ツクシ、タンポポの丘の辺から、陽炎の立つ柔らかな日の光の下で種々の香りが蒸し出される。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会が一個人を、その一個人である故を以って軽視したなら、疾病は必ずそこから発芽して、そしてタンポポの種子のように風に乗って飛散｜伝播するだろう。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "タンポの付いた大身の槍を、熱に浮された男のようにみだりに打ち振った。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "タンポの付いた稽古槍の仕合は、所詮は偽りの仕合じゃ。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとあと役に立たぬよう、股のあたりへ一本、変ったタンポ槍を見舞ってやるのも一興じゃ。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "得物はそのタンポ槍、未熟者の習い通り、すでに早く焦って突き出そうとしたのを、「慌て召さるな」　静かに制して京弥殊のほかに落ちついているのです。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざッ」　さッと身を引いて六寸八分南蛮鉄の只一本に、九尺柄タンポ槍の敵の得物をぴたりと片手正眼に受けとめたあざやかさ！",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お次はどなたじゃ」　爽やかな京弥の声が飛んだとき、すでに対手はタンポ槍をにぎりしめたまま、急所の脾腹に当て身の一撃を見舞われて、ドタリ地ひびき立てながらそこに悶絶したあとでした。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さよう、いかにも稽古槍、穂先の代わりにタンポがある。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかがタンポ槍、なんでもござらぬ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜日の午後を彼女は思はず昼寝して、帰り損ふことが珍らしくなかつたが、彼女の在、不在を問はず、ベツドの位置もそのまゝになつたまゝ、春が忍び寄るに従つて、私の青春憂鬱症はタンポヽの穂のやうに単なる悩みに富んだ夢の中をさ迷ふだけであつた。",
              "citation": {
                "source": "タンタレスの春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
