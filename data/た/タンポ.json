    "definitions": [
      {
        "index": 1,
        "gloss": "security",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "先ずはじめに銘々の持ちものを何か一つずつ担保 gage として提供させる。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで担保に入れてあったガージュを銘々に返していたとき、一本の鉛筆をさし上げて「これはどなたのでしたか」と主婦が尋ねたら、一座の中の二人のイタリア女の若い方が軽く立上がって親指で自身の胸を指さし、ただ一言ゆっくり静かに Il mio. と云った。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯爵家の不動産が担保に這入りかけているという事実を、意外な方面からチラリと聞き出したのは、その頃の事であった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪は安井銀行、第三蔵庫の担保品。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "出資者は金を出す、事業経営者は二流担保ではあるが担保を出すことまでは極つたが、貸借は直接関係でしたくはない。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに貸出の方なる事業者から徴すべき担保物の調査も届いて居ない。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "此間に松村は借方即ち工事経営者を呼び寄せて担保や報酬の交渉をした。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "事業は屹度成功する、貸金には担保がある。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一三村さんは屋敷まで担保に入っているていうじゃないか。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころになると、主人が生前｜見栄を張っていた松の家も、貸金があると思っていた方に逆に借金のあることが解ったり、電話も担保に入っていたりして、皆で勧めた入院の手おくれた謎も釈けて来た。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その点、おれに担保、証文、利子、期限なしで二百万円出させた君は大したもンや。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人が自分に対して大いに信用を置いて呉れて、一千万円位ならば無担保無利息でも貸与して呉れようという時、喜んでその一千万円を借りるのに少しも不都合はない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは惜福の工夫に於いては欠けているのであって、一千万円の幾分かを借りるとか、あるいは担保を提供して借りるとか、正当の利子を払うとかするのが、自分の福を惜しむ意味になる。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　銀行家は、取引先の担保にいかさまな品書きを見つけた折のように、皮肉な笑を見せた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、いずれにしても、専務が自分の食い込みを、無価値な担保を有価値に見せかけて償っている以上、その欠損は早晩表面に現れるに違いなかった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "やむをえず大丸は、平素の取引商人である小樽切っての海産物問屋大山と契約し製品を担保にして金を融通してもらうことにしたのである。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "高利よりは安い利まわりで固い担保を取って人にも貸した。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "店を担保に置いても駄目？",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀行員ですがね」「担保は？",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち申込者から、普通一円、市外二円の割で、信用｜担保等の調査料を取立てるのであつて、その調査の結果は、御融通できないと云ふことになるのである。",
              "citation": {
                "source": "日本三文オペラ",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この共同の借金の申込には担保が薄弱なためアメリカが応じなかった。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん、あるにはあるさ、だけど、あんなのはみんな担保にはいつてしまつて仕様のないもんばかりだぜ‥‥」「まア、担保つて、何時、そんなことをしたの？",
              "citation": {
                "source": "朝夕",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高利よりは安い利まはりで固い担保を取つて人にも貸した。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、債権者は債務者の門前に座を占めて居催促をなし、債務が弁済されるか、担保が提供されるまでは、一塊の麺麭、一杯の水をも口にしないで、餓死を待つのである。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗谷〔一〕宮沢賢治まくろなる流れの岸に根株燃すゆふべのけむりこらつどひかたみに舞ひてたんぽゝの白き毛をふく丘の上のスリッパ小屋に媼ゐてむすめらに云ふかくてしも畑みな成りてあらたなる艱苦ひらくと",
              "citation": {
                "source": "宗谷〔一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たんぽぽの花を取ったり、茅花を抜いたり、又桑を摘みに山へつれられて行ってはシドミの花を分けて根についてある実を探したり、夢の様に面白かったことは、何十年という月日を過ぎても記憶に存している。",
              "citation": {
                "source": "井戸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの利根川のほとりで土筆やたんぽぽ又は匂ひ高い叙情小曲なぞをかいた此れが紅顔の彼の詩であらうか。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真鍋さんはしきりに例の口調で指図して湯たんぽを取りよせたり氷袋をよこさせたりした、そして助手を一人よこしてつけてくれた。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は却ってたんぽぽの毛のほうを好きだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　松杉、田芹、すつと伸びた酸模草の穂の、そよとも動かないのに、溝川を蔽ふ、たんぽゝの花、豆のつるの、忽ち一｜所に、さら／＼と動くのは、鮒、鰌には揺過ぎる、――昼の水鶏が通るのであらう。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
