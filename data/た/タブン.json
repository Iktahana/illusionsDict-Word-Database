      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "reaching others' ears",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なぞが解けるまではちと他聞をはばかるが、血を分けたお姉御ならばさしつかえもあるまい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうわけで、屋敷の方でも他聞を憚って、飽くまでも秘密に穿鑿しているのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "仮面",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等に取っても一大事なら、当岡山城、池田の御家に取っても容易ならぬ一大事で」「えッ」「他聞を憚る事じゃから、そのつもりで」　半田屋九兵衛、何んだか気味が悪くなって来た。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「半田屋九兵衛、宿屋稼業は致して居りますれど、他聞を憚る一儀ならば、決して口外致しませぬ」「好し。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「他聞は憚る一大事じゃが、しかし女房は一心同体。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "事｜他聞を許さず、過つて洩るゝ時は、或は他藩の怨を求めむ事を恐る。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……して御要件は」「それがその、ええちと他聞を憚る事でございまして」商会主は汗を拭きながら云った。",
              "citation": {
                "source": "真珠塔の秘密",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今でもその若主人が、上布の肩から一なすり墨をぼかしたような夏羽織で、西瓜の皿を前にしながら、まるで他聞でも憚るように、小声でひそひそ話し出した容子が、はっきりと記憶に残っています。",
              "citation": {
                "source": "妖婆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私が不審そうにこう尋ねますと、私の甥はあたかも他聞を憚るように、梅の青葉の影がさして居る部屋の前後へ目をくばりながら、私の耳へ口を附けて、「どうすると云うて、ほかに仕方のある筈がありません。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一人の老人の旅の者が、何んでもこの家へ泊まったのだそうです」貝十郎のすぐ側に坐って、肴をせせっていた村医者らしい、七十近い老人が、声をひそめて他聞を憚るらしく、自分の前に坐っている、これも六十を過ごしたらしい、寺子屋の師匠とでも云いたげの、品のある老人へ囁いた。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "八｜代目団十｜郎や市村羽左衛門の怪談、沢村宗十｜郎の御殿女中の怪談、岩井半四｜郎の怪談、其他聞いた事見た事を種々集めてゐるんですが」と云ふと、是真翁が「円朝さん、妙な怪談の種子がある。",
              "citation": {
                "source": "塩原多助旅日記",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "他聞を憚る事柄ですから、ここだけのことにしておいて下さいませ。",
              "citation": {
                "source": "死因の疑問",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人目を避け他聞をはばかって、奥まった片隅に会議の席を設え、コン吉とタヌが待ち構えていると、ガイヤアルを先登にして三人の山案内が、威風堂々｜舳艫を啣んで乗り込んで来た。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "アルプスの潜水夫　――モンブラン登山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士といえども御他聞にもれずさ。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより山とは言うべくもないが、高いところなら猫の額でも山という名をつけたがるのが万事に大袈裟な江戸者の癖で、御他聞に洩れず半ば塵埃捨場のこの小丘も、どうやら見ようによってはそうも見えるというので、一般には木槌山として通っていた。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "無明の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "他聞を憚かるとしか受取れないその談話が、お延の神経を針のように鋭どくした。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら何でも元日っぱなから警視庁に護送されるところなぞを同業に見られたくないから、他聞を恥じるどの被告もするように、襟巻で面を包み帽子の前鍔を鼻の上まで引き下げ、走り込むように自動車に乗り、その儘の姿で帝国ホテルの車寄せに降りた。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達にとってはね』　夫人は他聞を憚るからと云って、寝室に続いた彼女の居間に私を案内いたしました。",
              "citation": {
                "source": "機密の魅惑",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「實は、他聞を憚るのだが――」　川前市助、部屋の隅に引つ込んでゐる八五郎の長んがい顏を、横眼でジロジロと嘗め廻し乍ら、きり出し兼ねる樣子です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美女罪あり",
                "note": "青空文庫"
              }
            },
            {
              "text": "「杏齋先生、お話と仰しやるのは」「少々他聞を憚るが」　眼顏で誘ひ合つて、二人は部屋の隅に、吹き寄せられたやうに顏を突き合せました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "毒酒藥酒",
                "note": "青空文庫"
              }
            },
            {
              "text": "「杏斎先生、お話と仰しゃるのは」「少々他聞を憚かるが」　眼顔で誘い合って、二人は部屋の隅に、吹き寄せられたように顔を突き合せました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "毒酒薬酒",
                "note": "青空文庫"
              }
            },
            {
              "text": "一體、何がどうなさいました」「他聞を憚ることだが」「それはもう大丈夫、女房の外には、猫の子が一匹だけ、誰も聽いちや居ません」「では申し上げるが――實は昨夜、津志田家に曲者が押入つて、下男の半次に傷を負はせ」「？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美しき人質",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつけても亡くなった私の父親の名と、私の素性を、どうぞお教え下さいまし」「他聞を憚る事、暫らくお待ち下さい」鞍馬は立ち上って、簾の外、夕陽にキラキラする石畳の上を見ましたが、ハッとした様子でお鳥を顧みました。",
              "citation": {
                "source": "裸身の女仙",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に大通、いいところへおいで下さった、我々の仲間で、ぜひ一つ通人に腕貸しをしていただきたいのはほかではない――他聞を憚るによってちと……」　そこで木口勘兵衛と、安直と、通人が鼎になって、ひそひそと物語りをはじめました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまには…………」「コラコラ、社長に向かって何を申すか、ひかえていろ」　二人とも低い声ではあったが、他聞を憚かるようでもなかった。",
              "citation": {
                "source": "薔薇夫人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "他聞をはばかる儀での、もそっと近くよらぬか！",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞之助は、他聞を憚ることもあるから美容院でなく、岡本のお宅の方へお伺いしたいと思いますがと、在宅の時間を確かめておいて、夕刻、いつもよりは遅めに事務所を出て、その足で岡本へ廻った。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "憤るからね、聞けば」「はあ」「君を書斎へ呼び込んだのも他聞を憚るからだ。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "数えて見れば、彼の方からは八回、雪枝さんの方からは十回の文通があったに過ぎず、しかも彼のにも雪枝さんのにも、ことごとく「葉書」と記してあるのを見ると、それには他聞をはばかる様な種類の文言が記してあったとも考えられません。",
              "citation": {
                "source": "日記帳",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人たちは、時折、上人の居間から念仏が洩れるので、「垣の外へ聞こえては」と、他聞を惧れて、開いている妻戸やふすまも閉て籠め、「……もちっと、お低い声音で仰っしゃって下さればよいが」と、ささやいた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
