[
  {
    "uuid": "8fcd2b58-3944-5d51-8146-849dc84a6995",
    "entry": "他聞",
    "reading": {
      "primary": "たぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
