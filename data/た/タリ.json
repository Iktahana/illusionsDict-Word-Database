    "definitions": [
      {
        "index": 1,
        "gloss": "-ing and -ing (e.g. \"coming and going\")",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
