        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その宝庫には強そうな兵隊がチャンと番をしておりまして、その庫の奥にある大きな鉄の宝箱の中に立派な鉄砲が一梃ちゃんと立てかけてありました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "リイはそれを見つけると喜んですぐに、「マム」　と云いますと、もうその宝庫の中の宝箱の中の鉄砲のところへ来てしまいましたから、リイはその鉄砲を肩にかつぎました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今度は次の兄さんのサア王のお城の方を向いて、宝物の刀はどこにあるだろうと遠眼鏡をのぞきながら、「アム」　と云いますと、やっぱりそのお城の宝庫の中の宝箱の中にチャンと蔵ってありましたから、すぐに、「マム」　と云うと、そこへ飛んで行ってその刀の紐を腰に結びつけました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "又波にくだけた宝箱の破片も得ました。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか知らねえが親方が宝箱を持って来るんだとよ」「何が入っているんだろう？",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝箱を次々に開けると、全部空っぽだ。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
