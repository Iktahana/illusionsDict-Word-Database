        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あの多聞天と、廣目天との顏つきに、思ひ當るものがないか、と言ふのであつた。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "多聞天は、大師藤原惠美中卿だ。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "家持は、此が多聞天か、と心に問ひかけて居た。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの多聞天と広目天との顔つきに思ひ当るものがないかと言ふのであつた。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "多聞天は、紫微内相藤原｜中卿だ。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "家持は、此が多聞天かと、心に問ひかけて居た。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの多聞天と、広目天との顔つきに、思ひ当るものがないか、と言ふのであつた。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "多聞天は、大師藤原恵美中卿だ。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの多聞天と、広目天との顔つきに、思い当るものがないか、と言うのであった。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "多聞天は、大師藤原恵美｜中卿だ。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "家持は、此が多聞天か、と心に問いかけて居た。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうやって僕がいつまでもそれから目を放さずにいると、北方の多聞天の像を先刻から見ていたＡ君がこちらに近づいてきて、一しょにそれを見だしたので、「古代の彫刻で、これくらい、こう血の温かみのあるのは少いような気がするね。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "多聞天や広目天もこの意味でかなり優れた作だと思う。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉祥天はバラモン教の美福の女神シュリイで毘沙門天（多聞天）すなわち富神クヴェラを夫としている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天王寺の多聞天が、福徳を全市に蒔き散らしてゐると信ずる人もあらうが、これは單に迷想に過ぎない。",
              "citation": {
                "source": "大阪といふところ",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "須弥三十三天を象って、その主天とし、以下四天王を一楼一楼に組み、その一つを多聞天の閣とよび、多聞櫓を築き出している。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
