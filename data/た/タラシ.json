[
  {
    "uuid": "ecbeb7cb-d77c-56e8-b512-8254612651fd",
    "entry": "誑し",
    "reading": {
      "primary": "たらし",
      "alternatives": [
        "タラシ"
      ],
      "is_heteronym": false
    },
    "grammar": {
