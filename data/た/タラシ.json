  {
    "uuid": "a426a2b6-9602-51df-9fd6-1b0e0a0d0907",
    "entry": "垂らし",
    "reading": {
      "primary": "たらし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
