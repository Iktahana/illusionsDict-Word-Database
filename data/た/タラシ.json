    },
    "definitions": [
      {
        "index": 1,
        "gloss": "seduction",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この頃は乞食が憐れっぽく見せようために、ああやっちゃあ誑しますよ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……と思う間もなく今度は相場師になって身を立てるというので、言葉巧みに親父を誑し込んで、祖父の代から伝わった田地田畠を初め銀行の貯金、親父の保険金なぞいうものを根こそげ捲き上げてしまったあげく、美しいばかりで智慧の足りない私の母親を連れてどこかへ夜逃げをして終ったというのである。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "童謠は（應）が始めて來りし稍以前より、何處より傳へたりとも知らず流行せるものにして、爾來父母※のつくり」、112-8］兄が誑しつ、賺しつ制すれども、頑として少しも肯かざりき。",
              "citation": {
                "source": "蛇くひ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度ッからは、たとい私をお誑しでも、蝋燭の嘘を仰有るとほんとうに怨みますよ、と優しい含声で、ひそひそと申すんで。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……誑しやあがつたな！",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴公より十金誑し取ったに決った。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古狸｜巧に人を誑し、其極終に昼出て児童の獲となること、古今の笑談なり。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹴飛ばしてやろう、おのれ、見返してやろう、おのれ誑してやろう、嬲ってやろう、死ぬような目にあわしてやろう。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と婆は居合腰に伸上って、袂を取って分けようとするのを、身悶して振払い、振向いて屹と見て、「お婆さん、お前にも私は怨があってよ、可い加減なことをいって誑してさ、お肚が痛むか擦ろうなんぞッて言っておくれだから、深切な人だと思ったわ、悔しいじゃあないかね。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼方をやめて帰つて来る時には、是非東京に帰つたら呼寄せるなんて、女を誑して帰つて来たんだが――』『それから逢はない？",
              "citation": {
                "source": "百日紅",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前にとりついとる狐が誑しよるんやがなあ。",
              "citation": {
                "source": "屋上の狂人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐の誑し遊びのように、ちょいと形を代えて細かい札にさえすれば、何十万円という金が、脱税出来るからくりとは知らなかった。",
              "citation": {
                "source": "人間の道義",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ矢張り私を誑しているんだな」　折柄表通りに浅田の姿が見えたので、二人はあわてゝ下に降りた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇治川の先陣争いで、佐々木が梶原を誑した位の事は何でもない事になっている。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに彼でもこんな子供｜誑しのような事を企てはしまい。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両刑事は彼をどうかして自白させようと、或いは脅し、或いは誑し賺かして妻子を枷に彼を釣ったかも知れない。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誑されるやうにして誑し、一気に引かけて、又慣らしながら、ためつゆるめつ争ふところに、竿釣りの焦点がある。",
              "citation": {
                "source": "夏と魚",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐渡には狐がをらず、山中の怪は専ら狸のみであるといふ話であるが、対岸の新潟へくると、すでに狸よりも狐の方が有勢で、こゝには青山の団九郎といふ狐があり、彼が出没して行人を誑したといふ青山の坂道は、今日でも団九郎坂と呼ばれてゐる。",
              "citation": {
                "source": "日本の山と文学",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そう思えばそうも思われる」「しかし進物の十｜行李には、さすがに嬉しそうな顔をしたよ」「そこが泥棒の浅ましさでね」「こっちは贋物の心弱さか」「狐狸の誑し合い、考えて見りゃア面白いよ。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい、誑して取りますので」「さあ、彼奴ら誑されるかな？",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「智恵の浅い岩石人ども、誑して取り返してお目にかけましょう。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階に昼寝してゐた汚ない顔の女給が、目をこすりながらいやみつたらしく出て来たのだ。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "その由を弁解したら、それもさうかと一応は分つたらしかつたが、それでも猶そのお説教を続けるのは、僕にやつぱり一体全体「誠意がないのか」それとも、大概の老人がさうであるやうに、たゞもう剛情なのか。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　押入の掃除をすませて、漸く中から出て来ると、前ゐた人が忘れて行つたらしい粗末な白木の小さな神棚（神道の）、それが茶の間の長押の上に三角の棚を打付けてその上に載せてあるのだが、それを下ろして呉れといふ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬や小鳥やの動物は、単に鼻を嗅ぎ合うとか、尾を振り合うとか、目をちょっと見合すとかいうだけで、相互の意志が完全に疎通するのに、人間は廻りくどく長たらしい会話をして、しかもなお容易に意志を通じ得ない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に室生君には特殊の驚異を感じたらしく、常々「あんな珍しい男を見たことがない」と言つてゐた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の詩の中では、郷土望景詩數篇が最も氣に入つたらしく、口を極めて賞讚してくれた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の多くの友人に對して、芥川君は常に都會人的な洒落や笑談を言つたらしい。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この芥川君の言は、いくらか犀星の感情を害したらしい。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐竹はすぐに察知したらしく、「ペリカンをかいているのです」とひくく私に言って聞かせながら、ペリカンの様様の姿態をおそろしく乱暴な線でさっさと写しとっていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
