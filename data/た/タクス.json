  {
    "uuid": "9cd68e57-427a-50bf-b653-28930c717c3b",
    "entry": "托子",
    "reading": {
      "primary": "たくす",
      "alternatives": [
        "たくし"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "saucer (for a teacup)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "病みに恥つむこの郷を、つめたくすぐる春の風かな。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは物をつめたくする。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように水は物をつめたくする。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくすばらしいよ。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのありさまは、まったくすばらしいものでした。",
              "citation": {
                "source": "いいなずけ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は蒲団の中でからだをかたくする。",
              "citation": {
                "source": "雌に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはどうも、ぜいたくすぎるね。",
              "citation": {
                "source": "饗応夫人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹は心が冷静なときは自分に強いて冷たくするわけでもないと判っているのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまひには、とう／＼床板へ頭をすりつけて、「まつたくすまないことをした。",
              "citation": {
                "source": "ざんげ",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで堅く冷たくすっかり凍結していた自分の中の人間らしい血潮が急に雪解けのように解けて流れて全身をめぐり始めるような気がするのである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水鶏やほととぎすの鳴き声がいかにも静寂であるのに引きかえて、この人間の咽喉をせんたくする音が、なぜこんなにも不快であるのか、これも不思議である。",
              "citation": {
                "source": "軽井沢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある学者は天井裏に年じゅう電燈をともしているそうであるがこの方法はいかに有効でもわれわれには少しぜいたくすぎるような気がする。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すり切れたシルクハットと、しわだらけのビロードの襟が付いたくすんだ褐色のオーバーが、そばにある椅子の上に置かれてあった。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　そこまで言われてですね、事実、わしゃこの通り髪はまったくすばらしいほどの赤い色合いをしておりますので、このことで競うなら今まであったどんなやつにだって負ける気すらせんのですわ。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩の贈答もして高麗人はもう日本の旅が終わろうとする期に臨んで珍しい高貴の相を持つ人に逢ったことは、今さらにこの国を離れがたくすることであるというような意味の作をした。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄八丈の着物をきて藤色の頭巾をかぶって……」　白子屋のお熊が引廻しの馬の上に黄八丈のあわれな姿をさらしてこのかた、若い娘の黄八丈は一時まったくすたれたが、このごろは又だんだんはやり出して、出世前のむすめも芝居で見るお駒を真似るのがちらほらと眼について来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにもかかわらず、新参者が初手から駕籠なんざあぜいたくすぎらあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの家の構えは、浪人者親子三人にしちゃ、すこしぜいたくすぎゃしませんか」「しかり。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "はええところ起きて、とっととしたくすりゃいいんですよ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "子どものすごろく用にはぜいたくすぎる角製のさいころなのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくすばらしい発明だ。",
              "citation": {
                "source": "特許多腕人間方式",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たくするであろうか。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸木塚芭蕉塚平□塚都影居泊、私にはぜいたくすぎるほどだつた。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "（我々のとこでも、今ソヴェトへ労働者・農民が出かけて、ジカに向うの社会主義建設の進展の模様をみ、日ソ労働者大衆の結合をかたくすることが提議されて、実行に移されつつあるが、支配階級はそれを妨害し、弾圧している）「つぎの表をみると、生産の成功によって、賃金がめだってあがったということがわかる。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「石の家は人の心を冷たくする」というロシアの諺が思い出されて、ちょいちょい窃み見するようにして僕の方を見るその看守を、この男はきっと冷たい心を持っているに違いないなぞと思わせる。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに、わたしたちを堪えがたくする現実の矛盾がある。",
              "citation": {
                "source": "権力の悲劇",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれの第一歩的な着眼に固執して、千たび万たび、その角度からだけものをいい、またはその着眼のために理論の全体的な把握を失うような習癖に陥り、それがやがてジャーナリズムにおけるその人の商標となったりしては、理論家としての成長はまったくすたれてしまう。",
              "citation": {
                "source": "両輪",
                "author": "――創造と評論活動の問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女学校の女先生が制服のように着ていたくすんだ紫の羽織をつけただけは同じだが、その脊ののびのびと高い、やや浅黒い、額の心持よく緊張した顔立ちの若い先生は、第一瞥から暖い心情的な感じで若い生徒たちを魅した。",
              "citation": {
                "source": "時代と人々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら、こんにちわたしたちにとって最も重要なのは、戦後五年間の日本で、誰の目にもおおいがたくすりかえられて来た反民主的な諸力に対して、わたしたちの生活と文学は、どのようにたたかいつづけてゆくか、というプログラムをもっているか、もっていないかの問題であるから。",
              "citation": {
                "source": "しかし昔にはかえらない",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君を学校に訪ねて、大山さん歓迎の打合をなし、お茶と煙草とを貰ふ、何から何まで厄介になるのは、まつたくすまない（お嬢さんの容態が悪くないと聞いてほつと安心した）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
