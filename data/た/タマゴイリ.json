        "examples": {
          "standard": [
            {
              "text": "卵入りのスープは、とろみがあって寒い冬の朝には体が芯から温まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アレルギーがあるため、外食の際は必ず卵入りのメニューでないか確認する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "卵入りの特製麺は、モチモチとした食感と豊かな風味が楽しめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それで午後二時頃に本当に昼御膳を喰うので、その時にはまたよい家では卵入りの饂飩をこしらえます。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
