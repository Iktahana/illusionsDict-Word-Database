[
  {
    "uuid": "13a47829-469a-5998-8e4f-a167fc0ab558",
    "entry": "短所",
    "reading": {
      "primary": "たんしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
