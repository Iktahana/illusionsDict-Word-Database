        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "よもすがら音なき雨や種俵うぐひすや家内｜揃ふて飯時分　春の日の遅い朝飯。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは昔この道路の水準がずっと低かった頃に砂利をつめた土俵を並べて飛石代りにしてあった、それをそのまま後に土で埋めて道路面を上げたのであるが、砂利が周囲の湿気を吸収するために、その上に当るところだけ余計に乾燥して白く見えるとの事であった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃を見計らって箒で掃き集めると米俵に一俵くらいは容易に捕れるというのである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土俵の黒白青赤の四本の柱は、悲しいくらゐどぎつい原色なのでありました。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土俵には、ライトを強くあててゐるらしく、力士の裸體は、赤土色に見えます。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の切れっ端や、古俵などが潮に乗って海から川の方へ逆流して行った。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭俵なんかでね」「さうかい。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の方のバックには構内の倉庫の屋根が黒く聳えて、近景に積んだ米俵には西日が黄金のやうに輝いて居り、左の方の澄み通つた秋空に赤や紫や色々の煙が渦卷き昇つて居るのが餘りに美しかつたから、いきなり繪具箱を柵の上に置いてＷＣの壁にもたせかけ大急ぎのスケッチをしようとした。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "問屋と取引のある或る宿屋では内地米三十俵も積重ねる。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旱魃を免れた県には、米穀県外移出禁止というような城壁が築かれてはいるが、表門は閉っていても、裏のくゞり戸があいているので、四斗俵ならぬ三斗五升いりの袋ならその門を通過させてもらえるのだと笑っていた。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その猫どもを三つに分けて、ある者は炭の空き俵に押し込んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな化け猫を生かして置くと、どんな禍いをするか知れない」　家主の発議で、猫は幾つかの空き俵に詰め込まれ、これに大きい石を縛りつけて芝浦の海へ沈められることになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう俵に孔でも開けとるかよ？",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……俵のまわりは鼠の糞だらけじゃ。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、頑丈で、闘志があって、米俵をかつぐ力持にかけては村中、誰も親爺に及ぶ者がなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、朝、早くから、逃亡した工人を追っかけて、汚穢物乾燥場の、汚穢の乾物を積重ねてある蓆俵のかげに、すなんでいたのを掴まえてきた話をした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "虹吉は、去年あたりから、やっと四斗俵がかつげるようになったばッかしじゃもん。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯母の夫は、足駄をはいて、両手に一俵ずつ四斗俵を鷲掴みにさげて歩いたり、肩の上へ同時に三俵の米俵をのっけて、河にかけられた細い、ひわ／＼する板橋を渡ったりする力持ちだった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "米俵をかつぐのは、もう出来ないことだった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お正月に、餅につけて食う砂糖だけはあると思って、帆前垂にくるんだザラメを、小麦俵を積重ねた間にかくして、与助は一と息ついているところだった。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日たって、若い労働者達が小麦俵を積み換えていると、俵の間から、帆前垂にくるんだザラメが出てきた。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がじいっと耳を澄ますと、納屋で蓆や空俵を置き換えている気配がした。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は、やはり反物をかえさずに持って帰って、納屋の蓆か空俵の下に隠したんだな、と彼は思った。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空俵はもと置いてあった所から二三尺横に動いていた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "籾ができると父は細長くきれいに藁を通して編んだ俵につめて中へつめた。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯はかたわらのフィンを呼んで「あの帆柱のそばの背の高いやつを射よ」と命ずる。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……王がよろめき倒れてかたわらの石によりかかり、神の助けを祈っているところへ敵将が来て首と腹を傷つけた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "深刻な表情をして酒盃を傾けている黄をマリは見つけると、つか／＼と彼のかたわら迄彼女は行くと、少しばかりスカートを捲いてマリは薬品の為にオリーブ色になった唾液を床に吐いた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のレジオン・ド・ヌウルはフランス政府が彼の東洋流の栄養法が人口の味覚を満足さした功労によって、エリゼェの大統領官邸で贈与された（彼は巴里で生物学を研究するかたわら党費を稼ぐために豆腐を製造販売していたので。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車が品川を過ぎると、彼女のかたわらに美男のアメリカ人がにこにこしながらやってきた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
