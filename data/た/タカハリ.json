    "definitions": [
      {
        "index": 1,
        "gloss": "large paper lantern on a pole",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "をさけび走る町のこら、　　高張白くつらねたる、　　明治女塾の舎生たち。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜜柑、林檎の水菓子屋が負けじと立てた高張も、人の目に着く手術であろう。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いたのが、例の高張を揚げた威勢の可い、水菓子屋、向顱巻の結び目を、山から飛んで来た、と押立てたのが、仰向けに反を打って、呵々と笑出す。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯の谷の屋根に処々立てた高張の明が射して、眼のあたりは赤く、四方へ黒い布を引いて漲る水は、随処、亀甲形に畝り畝り波を立てて、ざぶりざぶりと山の裾へ打当てる音がした。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "高張、弓張が門の左右へ、掛渡した酸漿提灯も、燦と光が増したのである。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに、おみき所と言ふのに、三寶を供へ、樽を据ゑ、緋の毛氈に青竹の埒、高張提灯、弓張をおし重ねて、積上げたほど赤々と、暑くたつて構はない。",
              "citation": {
                "source": "祭のこと",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……軒へ立てる高張は御存じの事と思ふ、やがて其のくらゐだけれども、夜の畷のこんな時に、唯ばかりでは言ひ足りない。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "市街と同じように高低している船には船灯の垣や、高張提灯の藪を隙してうち重なり、そこに織り出される中流の花火打揚の船がやっと覗かれます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」“Chon-aiko! chon-aiko! ……”「華魁、何をそんなに見てお出でなの、くよくよとさ、黄色いふたつの高張に赤い日が、あのやうに射しかけて、ぴちやぴちやと濁水が凄いわねえ、あら、ちよいと、そんな処でおちんこなんか捲くるもんぢやありませんつたら、小児は罪が無ことねえ、ほほほ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "……軒へ立てる高張は御存じの事と思う、やがてそのくらいだけれども、夜の畷のこんな時に、唯ばかりでは言い足りない。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾十人が打ち揃うて高張提灯を先へ立てゝ聲のかぎり唄ひながら行くのはそれは賑かなものだといつた。",
              "citation": {
                "source": "彌彦山",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間にムシロを敷いて、高張りの提灯を幾つも立てていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに高張提灯をつけて、五種類の酒の出来具合を収税吏と農林技士が吟味しようといふのである。",
              "citation": {
                "source": "酒盗人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は筆をとりあげて、「この月の曇らぬ間に、この酒樽を持ち出すならば……か」　などゝ読みあげながら、まことに antic な契約書をさらさらと認めて、「私の屋敷は、この通りに見事な鬱蒼たる木立にとり囲まれて、月の在所に関はりのない砦であるから、要とあるならば高張提灯を貸さうかの？",
              "citation": {
                "source": "酒盗人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに其田池の前には、今一群の人が黒く影をあつめて居て、その傍には根本家と記した高張提燈が、月が冴々しく満面に照り渡つて居るにも拘はらず、極めて朧げに立てられてあるが、自分はそれと聞いて、驚いて、其傍に駆付けて、その悲惨なる光景を見た時は、果して何んな感に撲たれたであらうか。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかみの少女見むとて街をゆく我ならなくに淋しきものを　　　　　　　　　○　祇園會の神興が御旅所に置かれてゐる間は、路へ向いた御旅所の軒にぎつしりと、高張提灯が掛けられる。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "近火の場合には武家も町家も豪家になると、大提灯または高張りを家前なり、軒下に掲げ、目じるしとして人々の便を計りました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "その頃の消防夫のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頭に立つたのは、處々裂けた一對の高張、次は一對の蓮華の造花、其次は直ぐ棺である。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頭に立つたのは、処々裂けた一対の高張、次は一対の蓮華の造花、其次は直ぐ棺である。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子をあけて見ると、例の房のついた四角な帽子をかぶった二十人ばかりの学生が、てんでに大きなのぼりみたいな旗だの高張提灯だのを引っかついで、わいわい騒いでいる。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の「Ｙ（谷中）村鉱毒問題大演説会」と筆太に書いたのぼりの間に、やはり何か書きつけた高張りの赤い火影がゆらめいて行く光景と、みんなの姿が見えなくなってからもまだしばらく聞えて来るお一二、お一二の掛声とは、今でもまだはっきりと僕の記憶に浮んで来る。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に両藩の高張提灯各十挺が行く。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々の高張、軒提燈は云うも更なり、四ヶ所の大篝火は天をも焦がすばかりにて、森の鳥類を一時に驚かすのであった。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察署の前にはいつもと変わり、高張り提灯が一対ともしてあった。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、この一対の高張り提灯ほど鮮かに覚えているものはない。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、僕は今日でも高張り提灯を見るたびに婚礼や何かを想像するよりもまず戦争を思い出すのである。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "中でも毎週一回は必ず、救世軍の路傍説教があり、きまってはいないが、紋附きに角帽をかぶった三、四人の一団が「仏教救世軍」と記した高張提灯を竹棹の先に縛りつけたのを担いでやって来て「王法為本の旗の色」とか何とかいった歌を歌いながら、救世軍の讃美歌や、タンバリンの威勢のいいのに対抗して説教を始めた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は其の土地の支配者であつたといふ身分の程も考へねば、もう五十に間もないらしい年と、二十歳臺からかうであつたと自身には言つてゐる其のツル／＼とした高張といふ名のついた頭とに、恥づる風もなく、父は毎晩若い衆たちに混つて、娘のある家へ夜遊びに出掛けた。",
              "citation": {
                "source": "父の婚禮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "店頭には何時の間にか山形に日の丸の高張提灯が輝いてゐる。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の高張提灯の傍で兵隊の通るのを見てゐた下女が、長火鉢の横手まで戻つて來て、驚きの眼を瞠りつゝ、お光の盛裝を見上げた。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
