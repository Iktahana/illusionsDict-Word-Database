[
  {
    "uuid": "0a521463-a6d9-5262-a42d-fd8bec4946d4",
    "entry": "頼み込む",
    "reading": {
      "primary": "たのみこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
