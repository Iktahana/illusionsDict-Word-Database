[
  {
    "uuid": "ef539d3f-eeff-546b-9e01-e01e6e99affd",
    "entry": "多様",
    "reading": {
      "primary": "たよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
