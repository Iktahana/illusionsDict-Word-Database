        "examples": {
          "standard": [
            {
              "text": "せっかく作ってもらったのに、お腹がいっぱいで少し「食べ残して」しまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "嫌いな野菜だけを器用に「食べ残す」子供を、先生が優しく諭した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はどんなに量が多くても、決して料理を「食べ残さない」主義だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「いやいや、そんな積りで言つたのぢやない、乃公らが若い時には、骨なぞ食べ残すやうな事はしなかつたと言つた迄さ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリのレストオランに於ては、　……先ず食べ残すことを覚えるのが、第一課である……　とあり。",
              "citation": {
                "source": "駄パンその他",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
