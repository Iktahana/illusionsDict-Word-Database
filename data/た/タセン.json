    "definitions": [
      {
        "index": 1,
        "gloss": "lots of money",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "以前は参拝や祭礼にいかに多銭を費やすも、みなその大字民の手に落ちたるに、今は然らず、一文失うも永くこの大字に帰らず、他村他大字の得となる。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に宝暦明和の昔にもせよ、一月に二両二分の収入では多銭善く買ふ訳にも行かなかつたであらう。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ長袖よく舞い、多銭よく賈う。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "口をいっぱいにあいて下へ落ちたせんべいのありうる可能性などは考えないで悠然として次のを待っている姿は罪のないものである。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴェニスの町は朽ちよごれているが、それは美しく朽ちよごれているので壁のはがれたのも、ないしは窓からぶら下げたせんたく物までも、ことごとく言うに言われぬ美しくくすんだいい色彩を示しています。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "せんたく屋の場面では物干し場の綱につるしたせんたく物のシャツやパジャマが女を相手に踊るという趣向がある。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした私の子供じみたせんちめんたりずむをお笑ひ下さるな。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自宅から自動車で迎へに来たせん子は、赤子を抱いたまゝ会場を廻つたので疲れて、今食堂で何か飲物を摂つてゐる――桂子はたゞ一人闇空の下に立ち現はれてＱ――芸館の屋上庭園を靴の底に踏み締めた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でだれでも子どもならば、鍛冶屋がどうして火をおこし、どうして鍬をうつか、仕立屋がどんなふうにミシンをまわし、どんな工合にエプロンのポケットをぬいつけるか、またせんべやのじいさんが、せんべをさしはさんだ、うちわようのものをどんな順序で火の上でひっくりかえすか細かいところまでよく知っていた。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばふいごをおさせたり、つながったせんべを細かくくだかせたり。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十七日　きのう紛失したせんたく袋がもどって来た。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう子ねずみさえもかからなくなってしまった捕鼠器は、ふたの落ちたまま台所の戸棚の上にほうり上げられて、鈎につるした薩摩揚げは干からびたせんべいのようにそりかえっていた。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり似ているので、ぼくの心にのこっていたせんのむすめのすがたが、いまではどうやらとおくにおしのけられそうだ。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかで気のきいたせんせいたちが、バタパンご持参で、やってきていましたが、それをそばの人にわけようとはしませんでした。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、これは銀貨十二枚ないとわたせんよ。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「峠が見えたぞ‥‥北に取れや舵を‥‥隠れ岩さ乗り上げんな‥‥雪崩にも打たせんなよう‥‥」　そう言う声がてんでんに人々の口からわめかれた。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内に或雨上りの朝、彼は庭へ出かけて見ると、蕗の垂れかかつたせんげの縁に、石を並べてゐる廉一を見つけた。",
              "citation": {
                "source": "庭",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　「この分ぢや随分つもるでせうねえ」　コンパクトで鼻の頭をパンパンと叩いてゐたせん子は思ひ出したやうに、そつと蓄音機のそばの直子のところへ話しかけて行つた。",
              "citation": {
                "source": "「リラ」の女達",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えれえいぶる生木でなア、涙出て仕樣がねえぞ」　長五郎はさう云つて、燒けたせんべいへ手をのばした。",
              "citation": {
                "source": "うき草",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、日本のかうした大衆的な芸術に、あゝしたせんちめんたりずむな気分は、最早滅びる時期が来たのだと思ふ。",
              "citation": {
                "source": "感謝すべき新東京年中行事",
                "author": "――第四回郷土舞踊と民謡の会・批判――",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、大衆芸術には当然感傷味がなければならぬのではあるが、現代では、さうしたせんちめんと以外に、もつと外の或ものが加はらなければならぬのだと思ふ。",
              "citation": {
                "source": "感謝すべき新東京年中行事",
                "author": "――第四回郷土舞踊と民謡の会・批判――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「民族」の集りが、今度「民俗学」に変ると共にかうしたせんちめんとに属する表現法を止めたいと思ひます。",
              "citation": {
                "source": "三河の山村",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "仇を討たせんと思へばなり。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ容積同じ価格の物が決して同一効果を生じない、例えば、デパートで大量生産的にこしらえたせんべいと、或る小店で手塩にかけてこしらえたせんべいとは、その価格や斤量は同じ事でも、営養価が違う、また食器や金物類にしても信用ある独立店で買った方が、デパート物より品物が確かである。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、せんべい焼きにはさまれたせんべいのように、かくもびっしゃり圧しひしゃがれていると、身体のどこを支点にどう動こうかと考えることもできない。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "5855さはれ惑はし盜ませんためにも、人多く殺すこと思ひ立てる、心｜驕れる人に鋼持たせんためにも、かの金をば世に出だすなり。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの風車といっしょにうずらが丘の絵もかきたい――セン・テレーヌ寺の庭に群がっていたせんたく女もえがきたい。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはドイツの利益に役だたせんがために理想主義を歪曲して満足していた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも彼が動かなかったので、彼女は立ち上がって、しぼったせんたく物をひとかかえ取り上げ、それを叢の上に広げ始めながら、彼の顔をうかがう口実を得るために近寄っていった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分を役だたせんがために、自分の身を守らんがために、快楽を得んがために、偉くならんがために、社交的になったのです。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
