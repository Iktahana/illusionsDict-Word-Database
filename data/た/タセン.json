[
  {
    "uuid": "8029cb8f-c2ee-5d14-8e51-a907807dcba4",
    "entry": "他薦",
    "reading": {
      "primary": "たせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
