    "definitions": [
      {
        "index": 1,
        "gloss": "to (seem) eager to",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてヒステリーは現実よりも表現を名称を吟味したがるんだ。",
              "citation": {
                "source": "不可入性",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人は立派な文明を持っていながら好んで野蛮人の真似をしたがると、彼は常に不満を述べていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る種の作家は、本気に書くつもりの小説を前もって広告する事を避けたがるものである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君には、学生時代から少し威張りたがる癖があった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の弱い、情に溺れ易い、好紳士に限って、とかく、太くたくましいステッキを振りまわして歩きたがるのと同断である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「縁談などの時には、たいてい自分の地位やら財産やらをほのめかしたがるものらしいが、小坂のお父さんは、そんな事は一言もおっしゃらなかった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも、同じクラスの者は大学を出てからも、仲の良いくせにつまらないところで張合って喧嘩をしたがる傾向がある。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――余りに実利的な一般人が、形式論（原理）と実地とを直接連つたものと考へたがる。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下はフロべエルの嘆きであるが、「私はいつも眼のまへのものを拒否したがる。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、人というものは懶けもので、小楽をしたがる性分である。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず老爺のヴァイオリン弾きはしきりに辞去したがる。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に始めて渡来した西洋料理がポークカツレツ――通称トンカツであったかどうかは知らないが、西洋にいても日本人はよくこのトンカツを食べたがる。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "用もないのにむやみに外来語を使いたがる稚気と、僅ばかりの外国語の知識をやたらにふりまわしたがる衒気とが民衆にないとは決していえない。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "震源の所在を知りたがる世人は、おそらく自分の宅に侵入した盗人を捕えたがると同様な心理状態にあるものと想像される。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう次第だから、作おんなのお増などは、無上と民子を小面憎がって、何かというと、「民子さんは政夫さんとこへ許り行きたがる、隙さえあれば政夫さんにこびりついている」　などと頻りに云いはやしたらしく、隣のお仙や向うのお浜等までかれこれ噂をする。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "義理にも進んで行きたがる様な素振りは出来ない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが十三回十四回頃からロスの身体の構えに何となく緩みが見え、そうして二人が腕と腕を搦み合っているときにどうもロスの方が相手に凭れかかっていたがるような気配が感ぜられたので、これは少しどうもロスの方が弱ったのではないかと思って見ていた。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術の世界に限らず科学の世界でも何か新しい事を始めようとする人に対する世間の軽侮、冷笑ないし迫害は、往々にして勇気を沮喪させたがるものである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "我邦でも昔から壁土や土器をかじる子供があるが、他人種でもやはり胃病やヒステリーあるいは悪阻のために土を食いたがる者が往々あるそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは動物や人間が丁度自分のからだに必要な栄養品やビタミンを無意識に食いたがるようなものではなかったかという気がするのである。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○鉢巻をしたがる兵隊。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "石松つあんとこは、父っつあんがもともとやくざだから、やくざになりたがるのは無理がないって……」　「父っつあんが……昔やくざ？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタニスラウスと並んで歩く少佐夫人は、体の太つたのと反対に、いつも忙しさうに足を早めたがる。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは時勢のためでもあるが、父親は臆病なくせに大ように見せたがる性分から、家の没落をじりじり眺め乍ら「なに、まだ、まだ」とまけおしみを云って潰して行った。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "事業というものは片っぽうで先走った思い付きを引締めて、片っぽうはひとところへ噛り付きたがる不精な考えを時勢に遅れないように掻き立てて行く。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは文藝作品の――特に世界的な名篇傑作の撮影などと云へば、監督には勿論仕映えのある仕事だらうし、俳優達も進んで出演したがると云ふやうなこともあるからに違ひない。",
              "citation": {
                "source": "文藝作品の映畫化",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
