    "definitions": [
      {
        "index": 1,
        "gloss": "sword fight (in a film, play, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
