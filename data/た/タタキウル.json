          "literary": [
            {
              "text": "女は捕えて又助が介抱、すなわちなぐさんで叩き売る！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　初穂を自分が頂戴し、後を諸人へ総振る舞い――宿場女郎に叩き売る――というのが彼の目算なのであった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざとなりや人間、自分の手足だつて叩き売るんだ。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
