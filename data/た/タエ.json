[
  {
    "uuid": "216d299c-d73f-5e6f-9459-7e1c1f49dcf7",
    "entry": "栲",
    "reading": {
      "primary": "たえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
