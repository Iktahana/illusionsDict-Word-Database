    "definitions": [
      {
        "index": 1,
        "gloss": "someone else writing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――ボーツと春の薄霞のやうに煙つた明るみの中に、とても口では云ひつくすことの出来ないその美しい明るみの中に（それは今のやうにして皆様に自由に想像して戴くより他筆では現せないのです。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も南岳の絵もその全体の布置結構その他筆つきなどもよく働いて居つて固より軽蔑すべきものではない。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔他筆　加除訂正田中　和紙一二枚綴〕",
              "citation": {
                "source": "非常歎願書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリオンは高く　うたひつゆとしもとを　おとす、アンドロメダの　くもはさかなのくちの　かたち。",
              "citation": {
                "source": "星めぐりの歌",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一むらのすすきの陰から、嘉十はちよつと顔をだして、びつくりしてまたひつ込めました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論藝術家が製作に熱中してゐる場合に、些としたひつかゝり氣懸があつても他から想像されぬ位の打撃となる。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "況して周三のは、些としたひつかゝりや輕い意味のそれでは無い。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人は、それを内氣らしくカンヴアスを裏がへしにして部屋の壁へ寄せかけて置いたのに、おれは、躊躇せずそれをまたひつくりかへして眺めたのである。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂ひに狂ひし頑癖も稍静まりて、茲年人間生活の五合目の中阪にたゆたひつゝ、そゞろに旧事を追想し、帰心矢の如しと言ひたげなるこの幻境に再遊の心は、この春松島に遊びし時より衷裡を離れず。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとうちのなかでさんび歌をうたうのが聞こえて、花で飾られたひつぎが、中からはこび出されました。",
              "citation": {
                "source": "赤いくつ",
                "author": "DE RODE SKO",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は永い年月の間田舎のうらぶれた村の書斎で、このランプを点し、このやうな眼つきをして、未だ見ぬ花やかな世界に憧れながら孤独の歌をうたひつゞけた。",
              "citation": {
                "source": "痴酔記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今ははた、鈍色被衣身ぞたゆげに、苅野に凭ひ、隱り沼の水澁に浸り、伏木に添ひて火移りの昨日を夢み、冷かの今に涙ぐみ、もの倦がほにたゆたひつ、迷ひつ、軈て木の上枝より細高に、い行くか烟、ありなし雲とたゞよひて、天のこころに溶け入りぬ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　　　追加一句　津島にて・おわかれの、水鳥がういたりしづんだり　　　改作二句・つく／＼ぼうしあまりにちかくつく／＼ぼうし・月へゆれつつバスガールのうたひつつ　九月廿九日曇、晴れて秋空のよろしさ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "名物男をうたふ・でたらめをうたひつつあさぶをもらひつつ・若葉に月が、をんなはまことにうつくしい・いつ咲いた草の実の赤く　　　江畔老に・その蕎麦をかけば浅間のけむりが　四月二十九日　曇。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "うたひつゝ彼等は行くといふ感じである。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "膝をり伏せて○紙漉き家々に　谷川引きて　水湛へ、歌うたひつゝ　少女紙すく※紙買ひに来る人おほし。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀歌また鶴が自ら長い線を空につくり、彼等の哀歌をうたひつゝ行くごとくダンテ『神曲』地獄篇第五曲脣、抱擁、ああ八月の花に時ならぬ氷雨の雲の來襲！",
              "citation": {
                "source": "展望",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しき木葉の下にてその根の上に坐するを見よ　八五―八七彼をかこめる組をみよ、他はみないよ／＼うるはしき奧深き歌をうたひつゝグリフォネの後より昇る。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "山鳩の、梢に羽ぶく音だに聞ゆる淋しき山路を、「あゝ正成よ」など、高らかにうたひつゝ登る。",
              "citation": {
                "source": "筬の音",
                "author": "――わが幼時の記憶――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かすかなる翼のひゞき力なくして快きすたれし歌の一節はたゆたひつゝも恐る恐る美しき人の移香こめし化粧の間にさまよふ。",
              "citation": {
                "source": "珊瑚集",
                "author": "仏蘭西近代抒情詩選",
                "note": "青空文庫"
              }
            },
            {
              "text": "底野はまたひつくり返る。",
              "citation": {
                "source": "運を主義にまかす男",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "只管繊弱な世界をのみうたひつづけた作者ではあるだらうが、さうした世界をのみ掘り下げつづけた情熱もなか／＼できることではない。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "移香ながき黒髪のその中に、あやしく匂ふまなざしの、たゆたひつゝもしなやかに、見つむる色の、不思議さよ。",
              "citation": {
                "source": "ふるさと",
                "author": "漢那浪笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして、そんなことを覚えてゐるかといへば、それは、ちよつとしたひつかかりがあるからで、以前、この道を通つた時、ふと目についた、よくある例の四角い白ペンキ塗りの立て棒の看板に、「産婆大野登志」と書いてある、その名前が、彼の遠い記憶をおぼろげに呼びさましたからである。",
              "citation": {
                "source": "記憶のいたづら",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはまたひつじの毛皮服を着て、ハープをくぎからはずして、肩にかついで、セン・カンテンからヴァルスへ、ヴァルスからエナンデへ、エナンデからドルジーへと、あなたがたのこれから行く先ざきへたずねて行きましょう。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはまたひつじの毛の服を着て、ハープをかついだが、そこに一つむずかしい問題があった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後愚品ながらぼくのかくこと有るべき女人の日本画ものゝひたひつき、襟足などに、芸が無いとすれば、ぼくは先生に対して申訳ないことゝならうのみ。",
              "citation": {
                "source": "鏑木さん雑感",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "いにしへのあまの子らが、あさごとに磯菜つみけんなりはひのごとく、おのれまたとしつき飢ゑ渇きたるおのれがこころひとつをやしなはんとて、これらのうたをうたひつづりたるここちぞする。",
              "citation": {
                "source": "朝菜集",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に法華経を読んで居る暁に鶴の声を聞き実にめでたいというところから、うたひつる声に明けゆく高の原　　　　あづまの君の千代やことぶくたへづるや妙のみのりの花の庭に　　　　妙のこゑもてみのりことぶくと詠じましてそれで一月一日をめでたく過ごしました。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とつぶやくやうに言つてから、またひつくりかへつて僕にゐざりよりながら、「君の足を撫でさせろよ。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
