          "standard": [
            {
              "text": "高度経済成長期の日本は、大量生産・大量消費の時代を突き進んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "資源の無駄遣いを減らすため、大量消費社会からの脱却が求められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "流行の移り変わりが早いファストファッションは、大量消費の象徴とも言える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "大量生産、大量消費に向けて勢いよく資本主義のエンジンを回し続けるうえで、計算処理を自動化する道具は潤滑油の役割を果たした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
