        "examples": {
          "standard": [
            {
              "text": "二人のベテラン職人は互いの意地を立て引いて、どちらがより精巧な細工を仕上げるか火花を散らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "些細なプライドからお互いに立て引いてしまい、結局どちらも歩み寄ることなく商談は決裂してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いつまでそんな子供じみたことで立て引いているんだ？ 早く仲直りして協力しなさい」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "手切話しに、家を分けて、間夫をたてひく三度の勤めに、消え際がまた栄えた、おなじ屋号の御神燈を掛けたのが、すなわちこの露地で、稲葉屋の前がそれである。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
