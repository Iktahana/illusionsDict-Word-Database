        "examples": {
          "standard": [
            {
              "text": "彼は貴い家柄の出身だが、それを鼻にかけるようなことは決してしない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古くからの伝統を守り続ける貴い家柄に、新しい時代の風が吹き込もうとしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "貴い家柄ゆえの重圧に耐えかね、彼は自由を求めて国を後にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "赤んぼは自分がジョン・フィールドのあわれな痩せこけた餓鬼ではなくて、貴い家柄の裔であり世界の希望であり嘆賞の的であるのに、それを知らないでいるといったふうである。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            }
          ]
        }
