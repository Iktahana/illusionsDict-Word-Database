        "examples": {
          "standard": [
            {
              "text": "タンタラムは、高融点で耐食性に優れるため、電子機器の部品によく使われます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医療分野では、生体適合性の高いタンタラムがインプラント材料として利用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この希少金属タンタラムは、コンデンサの製造に不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また近頃タンタラムという金属の線を代用したのがぼつぼつ用いられる、この針金を糸枠のようなものに巻きつけてある。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
