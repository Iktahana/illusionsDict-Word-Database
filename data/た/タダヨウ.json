[
  {
    "uuid": "a6c38856-39f9-5abe-8c01-68e547da46bf",
    "entry": "漂う",
    "reading": {
      "primary": "ただよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
