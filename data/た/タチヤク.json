        "examples": {
          "standard": [
            {
              "text": "彼は若手ながら、歌舞伎の舞台で見事な立ち役を演じ切り、観客を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「次の演目では、ベテラン俳優の力強い立ち役が見どころですよ」と案内係が教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "立ち役としての風格を出すために、彼は日々の稽古で所作の隅々まで磨き上げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私は立ち役の名は、こゝに起つたものと見てゐる。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃はまだ「立役」の名が表面に出て居ないが、事実わき役にして立ち役なるものである。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
