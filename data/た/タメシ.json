    "definitions": [
      {
        "index": 1,
        "gloss": "trial",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今年の秋になつて病氣の工合が大分よくなつたし、醫者も許し又すゝめてくれたので、何處かへ試しに行つて見ようと思ふと、生憎なもので時候外れの霖雨がしばらくつゞいて、中々適當な日は來なかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辛抱を試しみるように、湖面に、ときどきさざ波が立つ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間と保った試しはないぜ」彼女はこんな言葉を使うようになった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度柚木は力を籠めて試してみたが、老妓にひかれると滑り去って抓り止めていられなかった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分を試して見度がっている。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "身の行ひは清くもあれ、心の腐りのすてがたくば、同じ不貞の身なりけるを、いざさらば心試しに拝し参らせん。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に粗末なものではあるが、しかし釉の色が何となく美しく好もしいので試しに値を聞くと五拾銭だという。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも粗末ではあるが、鼠色がかった白釉の肌合も、鈍重な下膨れの輪郭も、何となく落ちついていい気持がするので、試しに代価を聞いてみると七拾銭だという。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本の色彩をゴチヤゴチヤに積みあげて、一度この檸檬で試して見たら。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "来年あたりから試しに帝展の各室に投票函を置き、「いけない」と思う絵を観客に自由に遠慮なく投票をさせて、オストラキズムの真似をしたらどうかと思う。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは試しに一度やってみる価値があるかもしれない。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車屋や労働者の吸うもっと安い葉巻で、吸口の方に藁切れが飛び出したようなのがあったがその方は試した事がない。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういうわけだか判らないと云って、七之助さんも不思議がっているので、良人が意地をつけて、物は試しだ、魚を持たずに一度帰ってみろ、おふくろがどうするかと……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "試しに杖をあげて見るとささくれまでがはっきりと写った。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本の色彩をゴチャゴチャに積みあげて、一度この檸檬で試してみたら。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは林檎を食って、食った林檎の切が今度は火を吹いて口から出て来るというので、試しに例の男が食わされた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みなの衆、まづ試しに、自分がみそさざいにでもなったと考へてご覧じ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みなの衆、まず試しに、自分がみそさざいにでもなったと考えてご覧じ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは大方手がかりになると思うて何処かへ隠いてしもうた物と睨んどるが、しかし又、万一そうとすればこの一条は、よっぽど深う、巧みに巧んだ仕事で、もちろん尋常の試し斬りや何かじゃない。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初から試し斬りの切柄かけた白鞘の新身の脇差を引付けて、物を訊く法があるものか。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの聖者の伝記を調べて記し終り、試しに二度目に白隠の逸話集のあの個所を読んだときは、もう何の神秘感も起らなくなっていた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだん随分、千利休の隙のないことを試してみて、感心もし、すっかり兜を脱いでいる保護者の秀吉ではありましたが、折しも、この大雪を見ると、もう一度試してみようという考えが起りました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで面当てがましいような素振りさえするのでございます」「どんなふうにだね」「今日のお昼に、わたくしが、親身のような愛情を示そうと、試しに娘の食べかけの残したお菜に箸をつけようとしますと、娘はその皿を急に引ったくりまして、お母様、これは私の食べかけでございます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その籾がどういう地質に合うか合わないか、嘗てそれを実際に試してみて、すなわち因果の理法を実行した結果の成績を記憶にとどめて置きます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぞ、お試し下さい、ねえ、是非一回御試験が仰ぎたい。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ、お試し下さい、口は禍の門、諸病は口からと申すではありませんか、歯は大事にして下さい、口は綺麗にして下さいまし、ねえ、私が願います、どうぞ諸君。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の胸が、この心が、どうなるかそれが試して見たかったが、ドシンばたん、と云う足音。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山賊仲間に聖者のゐたためしは先づないが、修道院の中には天使から悪魔までがずらりとゐる。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢想家が、この世で成功したというためしは、古今東西にわたって、未だ一つも無かったと言ってよい。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑ひながら、ためしに右へ曲るのも、信じて斷乎として右へ曲るのも、その運命は同じ事です。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
