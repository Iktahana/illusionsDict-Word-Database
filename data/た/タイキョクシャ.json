    "definitions": [
      {
        "index": 1,
        "gloss": "player (of go, shogi, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
