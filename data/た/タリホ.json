[
  {
    "uuid": "839acdda-756a-5198-80ab-7850d7d47d91",
    "entry": "垂り穂",
    "reading": {
      "primary": "たりほ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
