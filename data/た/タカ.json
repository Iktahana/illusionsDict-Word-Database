  {
    "uuid": "3f9b43e2-0892-5f59-bc46-f0a86dc031f9",
    "entry": "タカ",
    "reading": {
      "primary": "タカ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
