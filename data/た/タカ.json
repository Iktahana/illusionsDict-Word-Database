        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "財産の多寡で個人の価値を秤量するのが一つ。",
              "citation": {
                "source": "猿の顔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は弱々しい女ひとり、別に恐れるほどのこともあるまいと多寡をくくって、そのまま店へあがらせると、女はうしろを見かえりながらそっと表の戸を閉め切ってはいった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも多寡を括ってそのままにしているのだろうか。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の子供は多寡が二疋三疋の赤蜻蛉を見付けて、珍らしそうに五人も六人もで追い廻している。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい這奴が山※の同類にした所で、一人と一人との勝負ならば多寡の知れたものである。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "対手は多寡が※じゃアないか。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰に逢っても昔の身上を知られる気配もあるまいと多寡を括って、彼は平気で町中を歩いた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵の地震が来たところで、このバラツクならば大して驚くこともないと多寡をくゝつて、わたしが真先に寝床へ転げ込むと、かみさんや娘も気味を悪がりながら寝てしまひました。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "多寡が狐鼠狐鼠どろぼうだから、杖罪で放逐してしまえ。",
              "citation": {
                "source": "自来也の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこの三鷹に引越して来て、まだ四日しか経っていないのだから何も知るまいと、多寡をくくって出鱈目を言っているのに違いない。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴いとは云え多寡が土細工の茶碗だ、それに俺ほどの者が心を動かしたのは何事だ、エエ忌々しい、と其の茶碗を把って、ハッシ、庭前の石へ叩きつけて粉にして終ったということがある。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く彼の笛が無いとありましては、わたくし共めまでも何の様な……」「いや、聟殿があれを二の無いものに大事にして居らるるは予て知ってもおるが、……多寡が一管の古物じゃまで。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鶏卵と、玉子と、字にかくとおんなじというめくらだけれど、おさらいの看板ぐらいは形でわかりますからね、叱られやしないと多寡をくくって、ふらふらと入って来ましたがね。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると豊島は煙草入れの中に入っている小銭を与えながら、乞食の仲間の貰いの様子、家々の屑の捨て方の塩梅、盛り場の食物店の仕込みの多寡――そんなことを小さい声で訊ねます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが廊下でかなり騒ついたのは昨日からの客がかなり混み合っているようで、それに旅館の方でも例の講中式団体客並みに何でも一坪に二、三人の鮨詰めで済ませるものと多寡をくくっていたらしいのだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾花川の堤にはときどきに狐が出るなどというが、まさかそうでもあるまいと多寡をくくって、僕は大胆に答えた。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎　多寡が面一つの細工、いかに丹精を凝らすとも、百日とは費すまい。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には多寡をくくって、着のみ着のままでひやかし半分に駈けだすのもあった。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "多寡が打傷ですから。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を軍籍に措かざれば祖国のために尽すの路なきが如き、利子付きにて戻る国債応募額の多寡によつて愛国心の程度が計らるゝ世の中に候。",
              "citation": {
                "source": "渋民村より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地の大を以て見れば、さしも強豪、無敵の鬼三郎も多寡の知れたる一匹の蛆虫。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝礼の多寡を問わず献身的に斯道の宣揚のために精進した。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、プラッセの配当の多寡は、多くは他の人気馬の入線如何による。",
              "citation": {
                "source": "我が馬券哲学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝帰りの客を当て込んで味噌汁、煮豆、漬物、ご飯と都合四品で十八銭、細かい商売だと多寡をくくっていたところ、ビールなどをとる客もいて、結構商売になったから、少々眠さも我慢出来た。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はわしとわしの運命とのあいだに多寡が氷ぐらいの邪魔物があるからといって、わしがこの国を去られると思うかね。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは浜方より運送の多寡、かつ諸方への出入り勘定、みなことごとく帳に託す。",
              "citation": {
                "source": "失うた帳面を記憶力で書き復した人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もお金の多寡はハッキリわかりませんがね……それから、もう一つ重要なのは、屍体の左手にシッカリと握っていたレミントンの二連銃の中に、発射したままの散弾の薬莢が二発とも残っていた事だそうです」「ハハア……詰め換えないままにですな」「そうです。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "偏に定役の多寡を以て賞罰の目安となせし風なれば、囚徒は何日まで入獄せしとて改化｜遷善の道に赴かんこと思いもよらず、悪しき者は益※悪に陥りて、専心取締りの甘心を迎え、漸く狡獪陰険の風を助長するのみ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の片側は翳り、片側は日射しをうけて、あつたかいけざやかにもわびしい秋の午前です。",
              "citation": {
                "source": "死別の翌日",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうあるべきがよかつたかも知れない多くの元気な顔たちの中に、私は容易におまへを見付ける。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
