[
  {
    "uuid": "9f237dfe-4e5e-57eb-9c42-dd653f7d0c9c",
    "entry": "他山",
    "reading": {
      "primary": "たざん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
