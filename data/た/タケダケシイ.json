[
  {
    "uuid": "92fca69f-bd01-5006-a36e-8ccdf173bcb5",
    "entry": "猛々しい",
    "reading": {
      "primary": "たけだけしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
