      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to engage in",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "此の徳は此の道に携わる者の誰もが持ちたいものだと思う。",
              "citation": {
                "source": "雑録",
                "author": "――前進座に就いて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は一つの仕事に熱情を傾けて携わる場合、いつも此の空気の中にいて働き度いと思う。",
              "citation": {
                "source": "雑録",
                "author": "――前進座に就いて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から偉人には奇蹟が携わる、日を見て、月を見て、星を見て、いや、ちと大道うらないに似て来たかね。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに句読点の処理や数字の表記、漢字の使い方、和文の中に欧文を交ぜ書きする際はどうすれば読みやすくなるかといったさまざまな点に関して、本作りに携わる人たちは工夫を重ね、成果を分かち合ってきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＤＴＰがいかに自由に文書をまとめる機会を与えてくれたとしても、紙の冊子に印刷するという枠の中だけでこうした技術を捉えている限り、その影響は本作りに携わる人にしか及ばない。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "産業として確立されている出版界には、これに携わることで生活を支えている人がたくさんいます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＵＮＩＸに携わる人の中には、この役割を担おうとする志の持ち主がいた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも一の学説を主張するが如くにその論理を運ばするのみであって、実際問題に携わるに当って必要なる気転や分別はその影すら無い。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "学問に携わる者は、少なくともこの聖語を体験し実感しなければならない。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "母方の御｜伯父は皆親王で実際の政治に携わることのできないのも不文律になっていたから、母宮をだけでも后の位に据えて置くことが若宮の強味になるであろうと思召して藤壺の宮を中宮に擬しておいでになった。",
              "citation": {
                "source": "源氏物語",
                "author": "紅葉賀",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏にも朝家の政治に携わる上に心得ていねばならぬことをお教えになり、東宮をお援けせよということを繰り返し繰り返し仰せられた。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は私たちが芸術に携わることは極端に嫌って、ことに軽文学は極端に排斥した。",
              "citation": {
                "source": "私の父と母",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ操觚に携わるものは涙なしには読む事が出来ない。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手紙には女の身として文学に携わることの不心得、女は生理的に母たるの義務を尽さなければならぬ理由、処女にして文学者たるの危険などを縷々として説いて、幾らか罵倒的の文辞をも陳べて、これならもう愛想をつかして断念めて了うであろうと時雄は思って微笑した。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その作品を提出することによって、癩者の幸福に資する点があるとか、あるいは社会問題としての癩に貢献する確乎たる自信がないかぎり、これは芸術家――ことに映画のような娯楽的性格を持つ芸術に携わるもの――の触れてはならない題材ではないだろうか。",
              "citation": {
                "source": "映画と癩の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "学芸に携わるものでも、ビヨンクウルの書記のように自転車隊附として働いているものがあり、ラペエの詩人のように輸送用の自動車に乗って働いているものもある。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学に携わるものとして作家が変るというからは、やはり執拗にそれぞれの作家のよりひろく高い成長を目標として語られ考えられなければならないと思う。",
              "citation": {
                "source": "今日の文学の諸相",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この独特なとざしのきつい日本の社会の仕くみの中で、何ごとかを求めて生きて来た男性で、ましてや芸術に携わる男性で、現代の歴史のむごさを我が肌に痛感しなかった人が在るだろうか。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大臣も、「院の御感情を害してはならないし、自分がそうした間題に携わるのもいかがと思ったので、せっかく正月に逢っていながら何も言いださなかったのは間違いだった。",
              "citation": {
                "source": "源氏物語",
                "author": "竹河",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、半導体の設計や製造に携わる技術系のセクションからではなく、新設された弱小の一販売部門から革命児は誕生することになったのである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実に集積回路作りに携わる技術者も、物理屋や化学屋がほとんど。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月一日には海軍の技術士官となり、その後敗戦まで、音波探知器に携わることになる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "集積回路担当を言い渡された時点で、後藤はごく素直に、製品作りに直接携わる自分の姿を思い描いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五五（昭和三十）年に職場に復帰した石井は、心機一転、日本電気にとっても新しい仕事となるコンピューターに携わることになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸運にも自ら種を蒔く機会を与えられ、この種を育てることが企業にとっても社会にとっても、そして自分自身にとっても幸福であると心から信じられたとき、これに携わるものが目を見張るほどのエネルギーを発揮することを、大内は知っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューター科学の研究者と教育者という経験を持つラスキンは、自社ブランドで売り出しはじめたアップル※用のソフトウエアの品質を、マニュアルも含めて高めていくためのセクションの設立を提案し、この仕事に携わるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このリサの開発計画に携わることになったラスキンはもう一方で、アップルのもう一つの次世代機のアイディアを練っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二部　第四章　ＰＣ―９８０１に誰が魂を吹き込むか一九八二　悪夢の迷宮、互換ベーシックの開発　ともに昭和二十年代の前半に生まれ、大学でコンピューターと出合い、日本電気でオフィスコンピューターに携わることになった早水潔と小澤昇の歩みは、表面的になぞればほとんど重なり合っている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五〇年代の終わり、さまざまな産業分野に散っていった仲間たちの大半は、製造工程のオートメーション化に携わることになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "先行するマシンを後ろから追いかける以上、８０８６をとって一気に追い越そうという見解は、開発計画に携わる者のあいだではじめから一致していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
