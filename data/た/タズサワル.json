[
  {
    "uuid": "b8e4116e-0691-5405-95e1-a698666c853f",
    "entry": "携わる",
    "reading": {
      "primary": "たずさわる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-自動詞"
