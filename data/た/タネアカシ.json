[
  {
    "uuid": "2c4e5903-f8d8-58c4-847a-1e2e1082d79c",
    "entry": "種明かし",
    "reading": {
      "primary": "たねあかし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
