        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これは玻璃蛋白石です。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっさいあのまっしろなプクプクした、玉髄のやうな、玉あられのやうな、又｜蛋白石を刻んでこさへた葡萄の置物のやうな雲の峯は、誰の目にも立派に見えますが、蛙どもには殊にそれが見事なのです。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、ごく上等の蛋白石の注文があるのですがどうでせう、お探しをねがへませんでせうか。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛋白石のいゝのなら、流紋玻璃を探せばいゝ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリーンランドの成金がびっくりする程立派な蛋白石などを、二週間でさがしてやらうなんてのは、実際少し軽率だった。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に君注文が割合に柔らかな蛋白石だらう。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がその山へ入ったら蛋白石どもがみんなざらざら飛びついて来てもうどうしてもはなれないぢゃないか。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが君みんな貴蛋白石の火の燃えるやうなやつなんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際蛋白石ぐらゐたよりのない宝石はないからね。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下等な玻璃蛋白石が三十ばかりころげだす。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっさいあのまっしろなプクプクした、玉髄のような、玉あられのような、又蛋白石を刻んでこさえた葡萄の置物のような雲の峯は、誰の目にも立派に見えますが、蛙どもには殊にそれが見事なのです。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、ごく上等の蛋白石の注文があるのですがどうでしょう、お探しをねがえませんでしょうか。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛋白石のいいのなら、流紋玻璃を探せばいい。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリーンランドの成金がびっくりする程立派な蛋白石などを、二週間でさがしてやろうなんてのは、実際少し軽率だった。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に君注文が割合に柔らかな蛋白石だろう。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がその山へ入ったら蛋白石どもがみんなざらざら飛びついて来てもうどうしてもはなれないじゃないか。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが君みんな貴蛋白石の火の燃えるようなやつなんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際蛋白石ぐらいたよりのない宝石はないからね。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の下にはまつ白な蛋白石のやうな雲の塊が走つて来るのです。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日様は霧がかかると、銀の鏡のようだね」「はい、また、大きな蛋白石の盤のようでございます」「うん。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はあんな大きな蛋白石があるよ。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色な草穂はかがやく猫睛石、いちめんのうめばちそうの花びらはかすかな虹を含む乳色の蛋白石、とうやくの葉は碧玉、そのつぼみは紫水晶の美しいさきを持っていました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『蛋白石と云うのですが、僕には宝石の鑑定などは少しも出来ないのでしてね。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの女は十月生まれですから、蛋白石を欲しがるのですよ。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "青玉が二十一個と、蛋白石が一個。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、譬喩を珠玉に求めむか、彼には青玉黄玉の光輝あり、これには乳光柔き蛋白石の影を浮べ、色に曇るを見る可し。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、譬喩を珠玉に求めむか、彼には青玉黄玉の光輝あり、此には乳光柔き蛋白石の影を浮べ、色に曇るを見る可し。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
