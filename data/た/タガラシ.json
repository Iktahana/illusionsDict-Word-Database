        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "湿り気の多い田んぼの脇に、黄色い小さな花を咲かせたタガラシが群生していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "タガラシの茎を折ると出る汁には毒があるので、触らないように注意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "春先の水田で、タガラシが陽の光を浴びて輝いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "……若い兵隊が一人、口をあけ帽子もなしで、うなじを田芥子の繁みにひたし、眠つてゐる。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "喰べたがらして置き乍ら、いざ取って喰べようとなると歯にかっちりだ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "woodland bittercress (Cardamine flexuosa)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
