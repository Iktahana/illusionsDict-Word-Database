          "literary": [
            {
              "text": "対向車線を、一台の自動車が走ってきた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "対向車線も、車の流れが、すさまじい。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、カーブでは、内側の車線の車は対向車線にはらんでいるから、すり抜けるための幅は、よりいっそう、せまくなる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな黒い鳥のように、ミラーは対向車線へ斜めに飛んだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そのままセンター・ラインを割って対向車線に出ていった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
