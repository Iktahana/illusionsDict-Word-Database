          "literary": [
            {
              "text": "田島は、ため息をつくばかり。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界は自分らのためにのみできているとばかり思っているわれわれ愚かな人間は茫然としてテントの小窓からこの恐ろしい生命のあらしをながめてため息をつくであろう。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ふたりは、ほっとため息をつくのでした。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ため息をつくたびに、なにか、パン、パン、と、小さくはじけるような音がしました。",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "』こう言って、深いため息をつくんだよ。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまりうまくできあがるので、子どもたちは思わず、ため息をつくこともありました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は疲れてぐっすり寝たかと思うと、たびたび目をさましてため息をつく。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こういって、おねえさまたちは、いかにもせつなそうにため息をつくと、波のなかにすがたをかくしました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貞ちゃんやっぱり駄々をこねるか」　一口酒を飲んで、ため息をつくように庭のほうに向いて気を吐いた倉地は、自分で気分を引き立てながら思い出したように葉子のほうを向いてこう尋ねた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、切るからね」　赤電話を増やすべきだ、という母親をなんとかなだめ、受話器をおき、十円玉が一枚も落ちてこないのをたしかめ、大きくため息をつく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その美紅姫がその夢を御覧遊ばした朝、お眼が覚めて吃驚なすった時、窓の処に一匹の赤い鳥が居はしませんでしたか」　紅矢はもう、余りの不思議に呆れてしまって、只深いため息をつくばかりでした。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "六郎　（ため息をつく。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "半二　（ため息をつく）その壇の浦はわたしもよく知つてゐる。",
              "citation": {
                "source": "近松半二の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（更にため息をつく）この正月もやはり不入りであつたか。",
              "citation": {
                "source": "近松半二の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一しきりの讀經が濟んで、親しくしてゐる僧の房へともどつて來た時には、窕子はほつとしてため息をつくほどだつた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "平九郎　（ため息をつく。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）おかめ　（ため息をつく。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊寛　（ため息をつく）あゝ、あなたは囚徒のごとく不安な態度で仏の名を呼ばれます。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜となりの部屋へ六尺ゆたかな大男が来て、ため息をつくような、――うなるような謡曲をする。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　説明が一段落ついた所で、初子はことさら真面目な顔をしながら、ため息をつくようにこう云った。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦しい何秒かが過ぎた後、戸の向うからはかすかながら、ため息をつく声が聞えて来た。",
              "citation": {
                "source": "影",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつも弾いてもいいうただ」　Ｈはため息をつく様な声で云ったのも気持につり合って居た。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お二人さん」　東助とヒトミは、ほっと安心して、ため息をつくばかりであった。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし「部屋なし」と報告することはできないので、みんなしぶい顔をして、ため息をつくばかりだった。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、八日めの朝になると、七つの部屋いっぱいの黄金をまえにして、王さまも大臣の役人たちも、ただため息をつくばかりでした。",
              "citation": {
                "source": "銀の笛と金の毛皮",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ため息をつく）私の心はちょうどこの灰のようなものだ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯円　（ため息をつく）僧一　唯円殿、私はしつこくは申しますまい。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ため息をつく）私はどうすればいいのだろう。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "親鸞　（ため息をつく）いとしい弟子たち！",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "アドロ彗星は、その中の一番巨大なやつで、銀河の暗黒星雲あたりからでてきたすごいやつです」「ははあ、なるほど」テッド隊長は思わずため息をつく。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
