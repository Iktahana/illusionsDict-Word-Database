[
  {
    "uuid": "8873596b-99ed-5c62-909a-045a5cba9b78",
    "entry": "短銃",
    "reading": {
      "primary": "たんじゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
