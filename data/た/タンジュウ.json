    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pistol",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "木陰に短銃を手にしたなりひらが立って居た。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝元の森　なりひらは主膳に短銃を突き付けて、Ｔ「連判状を出せッ※」　と迫る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の縁などに立つて庭を見降すと、體を下に投げ出したくなるやうな衝動に襲はれて、はつとうしろにしざつたり、部屋の本箱の抽出にしまつてある五連發の短銃の事をひよいと、思ひ出すとそれを夢中で取り出してどかんと自分を打つてしまひさうな氣がして恐ろしくてたまらなかつたやうな經驗もやつぱりその當時の事だつた。",
              "citation": {
                "source": "自分の變態心理的經驗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "爆弾なり、短銃なり、ドスなりは、謂はゞ勃凸の肉体の一部分のやうなものだつたのだから。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずどんずどんとどこかで短銃の音がしたので、真蒼になって遁げて帰ると、朋輩のお方が。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰某は屁玉を喰って凹んだと大きに笑われたそうで、もう懲々して、誰も手出しは致しません、何と、短銃では、岩見重太郎宮本の武蔵でも叶いますまい。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と懐中より装弾したる短銃を取｜出し、「打殺すが可いか。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無三、同時に轟然一発、頭を覗って打出す短銃。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰助蒼くなりて一足｜退れば、轟然たり、短銃の第二発。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いとも危うく身を遁れて、泰助は振返り、屹と高楼を見上ぐれば、得三、高田相並んで、窓より半身を乗出し、逆落しに狙う短銃の弾丸は続いて飛来らん。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五　火に入る虫　短銃の筒口に濃き煙の立つと同時に泰助が魂消る末期の絶叫、第三発は命中せり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで光来と、小手にて招くに、得三は腰に付けたる短銃を発射間も焦躁しく、手に取って投附くれば、ひらりとはずして遁出すを、遣らじものを。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」二十一　旭　幾度か水火の中に出入して、場数巧者の探偵吏、三日月と名に負う倉瀬泰助なれば、何とて脆くも得三の短銃に僵るべき。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "得三は刀を手にし、短銃を腰にしたり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "然も、若旦那が短銃を持つて引返したのを知ると、莞爾として微笑んで、一層また、婦人の肩を片手に抱いた。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ひさま、ドンと開けて、衝と入つて、屹と其の短銃を差向けて、一目見るや、あ、と叫んで、若旦那は思はず退つた。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女郎、俺の衣兜には短銃があるぞ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣兜には短銃があるぞ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その短銃を売ってくれるなら千円で買おう。",
              "citation": {
                "source": "お金とピストル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が短刀で自殺する所も、短銃で死ぬ所もあります。",
              "citation": {
                "source": "木下杢太郎著『唐草表紙』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘助井戸の星を覗こうと、末の娘が真先に飜然と上って、続いて一人々々、名ある麗人の霊のごとく朦朧として露われた途端に、英臣はかねてその心構えをしたらしい、やにわに衣兜から短銃を出して、衝と早瀬の胸を狙った。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "無政府主義と暗殺　無政府主義の革命といへば、直ぐ短銃や爆彈で主權者を狙撃する者の如くに解する者が多いのですが、夫は一般に無政府主義の何者たるかが分つてゐない爲めであります。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "（貴下に、その紫の袖を許しました、その責に任ずるために、ここに短銃を所持しております、――その短銃をもってここに居て革鞄を打ちます。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……短銃は特に外国に註文して、英国製の最優良なのを取寄せました。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "短銃なんぞ何になりましょう、私はそれで満足します。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "若奥様が片膝ついて、その燃ゆる火の袖に、キラリと光る短銃を構えると、先生は、両方の膝に手を垂れて、目を瞑って立ちました。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（貴方……短銃を離しても、もう可うございますか。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……立野さん、お道さん、短銃をそちらへ向けて打つような女とお思いなさいましたか。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の偏執と自我と自尊と嫉妬のために、詮ずるに烈しい恋のために、――三年の間、夜に、日に、短銃を持たせられた、血を絞り、肉を刻み、骨を砂利にするような拷掠に、よくもこの手が、鉄にも鉛にもなりませんでした。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かんてぃるゆうぶぁんたんさびぃえいゆままんるぃでぃったんじゅうるたんどるまんだんのうとるろっじゅまんじぇべいねすうばぁんぷうるてるべいるふぁれどらるじゃん　唄がすすむままに一同はもう上機嫌になって、間もなく眼の前に現れて来るパリの実物に接した思いで、それぞれ首を振り振り唄うのであった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
