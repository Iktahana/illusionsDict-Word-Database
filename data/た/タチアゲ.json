    "definitions": [
      {
        "index": 1,
        "gloss": "starting up (e.g. business, computer)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
