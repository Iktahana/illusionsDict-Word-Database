          "literary": [
            {
              "text": "男は、それとも知らず、「よう、卵に目鼻の御入来。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の禿げている人は、たいてい端正な顔をしているものだが、田島先生も、卵に目鼻というような典雅な容貌の持主である。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくももう卵に目鼻という顔は流行らなくなってしまった。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなが、卵に目鼻のような大したお子さんだなどと言って可愛がってくれたが、それもつかの間で、だんだん地がねが出て、私より二つ年上の捨吉という兄弟子といたずらを始めた。",
              "citation": {
                "source": "五十年をかえりみて",
                "author": "宮城道雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
