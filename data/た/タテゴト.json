[
  {
    "uuid": "bfdf02c0-1f18-570e-993f-c9d0722f23db",
    "entry": "竪琴",
    "reading": {
      "primary": "たてごと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
