      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "harp",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あたしきっとあの森の中に立派なお姫さまが立って竪琴を鳴らしてゐらっしゃると思ふわ、お附きの腰元や何かが青い孔雀の羽でうしろからあをいであげてゐるわ。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また自刻の印章――ボート形の内に竪琴と星を刻したの――が押してある。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これについて思い出すのは古いアッシリアの竪琴と正倉院にある箜篌との類似である。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラビアの竪琴ジュンク。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マライのゲンゴンと称する竹製の竪琴。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央アフリカ北東コンゴーのある地方の竪琴にクンディまたはクンズというのがある。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "竪琴の最古のものはテーベの墓の壁画に描かれたものだそうで恐ろしく古いものらしい。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストーヴの傍にいた家族の者らしい老夫婦が、ヴァイオリンと竪琴とでそれに和した。",
              "citation": {
                "source": "ああ華族様だよ　と私は嘘を吐くのであった",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "イスラエルの人民が泣きぬれてバビロンの河辺に立ったとき、あの月は竪琴のかかっているヤナギの木のあいだから、悲しげにそれをのぞいたこともあるのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "――女性よ、詩人が生命の神秘をうたうときには、その竪琴にキスをなさい！",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "竪琴は頭のそばに置いてあり、犬は足もとに横たわっていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "家なき児のルミーは、お犬やお猿をつれて、肩には竪琴をしよつて、お母さんを探して旅してゐまアす、なんて上手に説明したわね。",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "竪琴をかついで少年がはいつて来る）妹　　あら可愛いいわね。",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "竪琴をひいたり、犬のカピーや猿の話をしてあげようと思つて来たのに。",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年　さあゆかう（竪琴を肩にする）姉　　ほんたうにもうゆくの？",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "声は竪琴にでも合いそうにすき透っていた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある高貴な魚族は、美しい縞のある鮮緑の藻の蔭で、竪琴をかき鳴らしながら、宇宙の音楽的調和を讃えておった。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　こゝで音楽はピツタリと止むのであります、シヴアに大切な金の竪琴を奪はれて仕舞つた姫は、悲しみの余り……再びそれを思ひ出して身を震はして泣き始めたのです。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し二人の「金の竪琴」は私の手にだけしかないのですから、二人は、私に「はかないそら頼み」をするばかりです。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『…………』　恋の竪琴はいつ何処で弾かれるかわからなかつた。",
              "citation": {
                "source": "路傍の小草",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "で私は酒に酔ふと稍ともすれば声を挙げて、大昔の酒神頌歌者や哀歌詩人に依つて詠まれた愉快な歌を口にして、余も亦彼等の如く一切の生命を酒と竪琴楽に托して、夢も現もなべて明るく歌ひ暮したいものであるが――などゝいふ嘆息を洩らすのであります。",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あの場面にオルフェスの竪琴を伴奏につかつたところは舞台監督の奇智だつたな。",
              "citation": {
                "source": "変装綺譚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもかれ等の上には恋のエンヂエルはまだその竪琴を弾き出さうとはしなかつた。",
              "citation": {
                "source": "磯清水",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは恰度竪琴のような楽器の音で二人はいつの間にか微妙な曲調に魅せられて手を休めてうっとりと聞きとれていたが、やがてクララははっと我に返って、さて、どこで誰があの音楽を奏しているのかと、窓をあけて辺りを眺め廻した。",
              "citation": {
                "source": "怪談綺談",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、アーチ形の古めかしい墓穴が出てきたり、竪琴を抱いた天使が現われたり、物を言う花だの、はるかに漂ってくる楽の音だの、たいした道具だてだった。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（高津春繁・ギリシア・ローマ辞典（一九六〇、岩波書店）参照）（ｅ）オルペウス（オルフェウス）はギリシア神話に登場する竪琴の名手。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡くなった妻を取り戻すために冥府に行き、得意の竪琴でうまくことを運ぶ。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治二十六年一月に創刊されて、日本のロマンティシズム運動とともに忘れ難いこの雑誌は、五年間の任務を果し、今やその表紙に竪琴を、扉の口絵にはロセッティなどの絵をのせた姿を消すこととなった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この書、太鼓喇叭竪琴などを描きたる銅版画の表紙の上に、Kakkoku Engekishi なる羅馬字を題す。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソロモンはこう歌いながら、大きい竪琴を掻き鳴らした。",
              "citation": {
                "source": "三つのなぜ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
