  {
    "uuid": "e00ed2ba-c89b-5fcb-91e0-2ba07e210abd",
    "entry": "立琴",
    "reading": {
      "primary": "たてごと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "koto erected in one's yard as decoration during the Festival to Plead for Skills",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さうして姫に白孔雀の羅と金の立琴とを呉れた。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――アポローばりの立琴をきかせられたり、優らしい若い女神が、花束飾りをかざして舞うのを見せられたりすると、俺の熾な意気も変に沮喪する。",
              "citation": {
                "source": "対話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワ大学の立琴と鷲のギリシア式鉄柵の間に古本を挾んで売って居る。",
              "citation": {
                "source": "一九二七年八月より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは併し最も自然に立琴が風に鳴るやうなものであつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は漸くカワレリヤ、ルスチカナの幕開きに淋しい立琴を合方にして歌ふシチリヤナの一節を思付いた。",
              "citation": {
                "source": "黄昏の地中海",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらにしてもし誠の心の底から、ミューズやヴェヌスの神に身を捧げる覚悟ならば、われらは立琴を抱くに先立って掟きびしいわれらが祖国を去るに如くはない。",
              "citation": {
                "source": "監獄署の裏",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "北国のある町を歩いていると立琴のようなものを鳴らして乞食が通るのを見た。",
              "citation": {
                "source": "面影",
                "author": "ハーン先生の一周忌に",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となく悲しく、鳴らしている立琴の音を聞きつつ、空想に耽っているとその男の姿は遠くなって見えなくなった。",
              "citation": {
                "source": "面影",
                "author": "ハーン先生の一周忌に",
                "note": "青空文庫"
              }
            },
            {
              "text": "伎楽の楽器として立琴や笛や銅※子子」に傍点］子」の左に「どびょうし」のルビ］のあることもこの点から見て軽視はできない。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の人民は馬鹿野郎ばかりだから腹の中に立琴のようなものが仕込んであるのだと思っていた。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるとき、旅をして歩く、陽気な職人たちが、ことや、たてごとを、この木の枝に、かけたことがありました。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドアの開けたてごとに大伍はカギを使っていたが、あれは彼のカギだし、開けたてごとにカギをかけるのは彼のいつもの習慣だ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十八　踊る時計",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
