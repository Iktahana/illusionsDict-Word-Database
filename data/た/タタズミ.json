    "definitions": [
      {
        "index": 1,
        "gloss": "standing still",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女は立ち上つて、もうすつかり明るくなつてゐる窓の前に佇みながら、微笑して、誰かを呼んでゐた。",
              "citation": {
                "source": "夢",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、つつましやかな氣持で甲板の一隅にぢつと佇みながら、今まで心の中に持つてゐた、人間的なあらゆる醜さ、濁り、曇り、卑しさ、暗さを跡方もなくふきぬぐはれてしまつたやうな、美しく澄み落ち着いた自分になつてゐた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "答へ澁つたまま、私は暫く身動きもせずに佇み過した。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来に、あるいは佇み、あるいはながながと寝そべり、あるいは疾駆し、あるいは牙を光らせて吠えたて、ちょっとした空地でもあるとかならずそこは野犬の巣のごとく、組んずほぐれつ格闘の稽古にふけり、夜など無人の街路を風のごとく、野盗のごとくぞろぞろ大群をなして縦横に駈け廻っている。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "と門前に佇みたるは、倉瀬泰助という当時屈指の探偵なり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しも早く探索せむずと雪の下に赴きて、赤城家の門前に佇みつつ云々と呟きたるが、第一回の始まりなり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　婦人は後に佇みて、帯の間より手帳を取出し、鉛筆をもて何やらん瞬もせず書き認め、一遍読返して、その紙を一枚引裂き、音低くしてしかも遠きに達る口笛を吹鳴らせば、声に応じて駈け来る犬あり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と三吉四辻へ引返せば、老婦人は待飽倦み、亭として佇みつつ手にせる蝙蝠傘を打掉るごとに、はっと散りてはまた集る、飯に寄る蠅、群る小児、持余してぞ居られける。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "船が下流に落ちると、暮雲岸を籠めて水天一色、江波渺茫、遠く蘆が靡けば、戀々として鷺が佇み、近く波が動けば、アヽ鱸か？",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "学円、高く一人｜鐘楼に佇み、水に臨んで、一揖し、合掌す。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白糸が佇みたるは、その裏口の枝折門の前なるが、いかにして忘れたりけむ、戸を鎖さでありければ、渠が靠るるとともに戸はおのずから内に啓きて、吸い込むがごとく白糸を庭の内にぞ引き入れたる。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠はしばらく惘然として佇みぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夕もまた美人をその家まで送り届けし後、杉の根の外に佇みて、例の如く鼻に杖をつきて休らいたり。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等の至れるを見て舟子は急がはしく立ち出で、柳橋の上に良久しく佇みて四方の空のさまを見めぐらす。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "風に吹かれて佇み、見送っていると、向うから東西屋が来て、河童路地の入口で停った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ余りの事に呆れ果て、茫然と佇みて在りしが、物好きの心俄かに高まり来りて止み難くなりつ、何気なく前庭に出づるに、早くも起き出でし寺男と思しく、骨格逞ましく、全身に黥したる中老人が竹箒を荷ぎて本堂の前を浄め居り。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まち子は、電話を切って、茫然と廊下を引きかへしながら、『ほっとかれる事ぢゃない』と繰り返してまた椽に佇みながらやっぱり、中村さんの家にあやまりに行かねばならないと考へた。",
              "citation": {
                "source": "雛鳥の夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時門の内を見入りたるに、黒目がちなる猶太の少女あまた群をなして佇みたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "穉かりし程は、母上我に怪我せさせじとて、とある街の角に佇みて祭の盛を見せ給ひしのみ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "――）画家　（佇み立つ。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お冬は軽く佇みました。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "首を寄来せ」　直行は佇みて様子を候ひゐたり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく晴れた日で、風は冴え瀬は光つてゐたけれども、既にその時は如何に力めても、其處の岩上に佇みし彼、曾て自分同樣に此所等に生息してゐた彼、及び現に空冥｜界を異にしてゐる彼を切實に思ひ浮べることは出來なかつた。",
              "citation": {
                "source": "古い村",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち昇る香煙のなかに佇みながら私は茂左衞門を思ひ、茂左衞門に對する百姓たちの心を思ひ瞼の熱くなるのを感じた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち昇る香煙のなかに佇みながら私は茂左衛門を思い、茂左衛門に対する百姓たちの心を思い瞼の熱くなるのを感じた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、美奈子が宮の下の賑やかな通を出はずれて、段々｜淋しい崖上の道へ来かゝったとき、丁度道の左側にある理髪店の軒端に佇みながら、若い衆が指している将棋を見ている青年の横顔を見付けたのである。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛追ひかへる野の路に、踏むは、紫つぼ菫、踵すりよせ佇みて、なげく心を知るや君。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうに、黙然とやや暫し、そこに佇みながら、血刀をさげたままで、何ごとか沈吟しているもののようでしたが、と見て、塀の上からおどりおりつつ、駈けよって来た京弥を見迎えながら、突如、わびしげに、呟くごとく言いました。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "げに見すぼらしき後ろ影、蓬なす頭、色あせし衣、われはしばしこれを見送りてたたずみぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は橋の一にたたずみて流れの裾を見｜下ろしぬ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
