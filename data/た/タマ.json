          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ほら、見て！この綺麗な泥だんご、ピカピカの玉みたいになったよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供たちが公園の砂場で、泥を丸めて玉を作って遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "手品師が掌から真っ赤な玉を次々と取り出すと、観客から大きな拍手が湧いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あまりに哀しく、きのふきみのくちびる吸ひてきずつけ、かへれば琥珀の石もて魚をかこひ、かの風景をして水盤に泳がしむるの日、遠望の魚鳥ゆゑなきに消え、塔をきづくの額は研がれて、はや秋は晶玉の死を窓にかけたり。",
              "citation": {
                "source": "感傷の塔",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕さむしい Hotel の臺所で、のすたるぢやのメリイが泣いて居る、ほんのり光る玉菜のかげから、ぜんまい仕かけで、鼠がひよつくり顏を出した。",
              "citation": {
                "source": "玩具箱",
                "author": "―人形及び動物のいろいろとその生活―",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は暫く麦のよく稔つた田園を歩いた後、フト玉を突いてみたい欲望を抱いた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて最初に目に入つた玉屋に這入ると、部屋は明るくガランとしてゐて、温室のやうだつた、客の腰掛場になつてゐる、畳二枚を縦に並べた場所の、その中程に置かれた火鉢には其処の主人が如何にも睡げによつかゝつてをり、お主婦さんも割烹着を着たまゝ火鉢で手をぬくめてゐた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "たつた一人の客が、部屋の真中にたつた一台の玉台の一方に立留つたきりで、練習突きをしてゐる。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　私は下高井戸駅――玉川電車の終点で車を棄てた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しく出来た六間道路とその辺の者が呼んでゐる通りには、まだギャレッヂと雑誌屋と玉突場とがあるきりだつた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど『美しいシャボン玉』を壊さないように、注意に注意して気をつけましたと、未亡人となった夫人が後で言っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして眞黒の群衆が、何十萬とも數知れずに押し合ひながら、お玉杓子のやうに行列して居る。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞳の焦点がさだかでなく、硝子製の眼玉のようで、鼻は象牙細工のように冷く、鼻筋が剣のようにするどかった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐竹は太宰のすぐ傍にながながと寝そべり、いかにも、つまらなそうに眼玉をきょろきょろうごかしながら煙草をふかしていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、そのような事実にこそ、高貴な宝玉が光っている場合が多いのだ、それをこそ書きたいというのが、作者の生甲斐になっている。",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　　　　　　　※　扨我等の生活はとみるに、　活動か、寄席か、酒か女か玉突か、トラムプか、棋か、どれにしたもんだらう……部屋の中でジツと話してれあいいんだけれど、どうもそれもパツとしないしなあ……読書か、あれはあんまり興味もないが、さうも云つてゐられんしなあ……困つたなあ。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉｜霰漂母が鍋を乱れうつ　漂母は洗濯｜婆のことで、韓信が漂浪時代に食を乞うたという、支那の故事から引用している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と忍びやかにうち出でさせ給へるに、言の葉なくて、玉枝の君はうち笑みおはしぬ。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉枝の君は、足もいたくなりぬ。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いなとよ、妾は柳は柳なれど、加賀の千代の句近し、おんみは河内の國玉越の里の柳、楊枝にけづりてもなよよかなり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾はこの譬のをかしさに笑へば玉枝の君もうちほほゑむ。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅津の君も今は物もいはで彳めるを、玉枝の君と妾とは目見合せてをり、さすがに恐しからぬにもあらず。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅津玉枝の御二方は、西施の顰をみそかに開かせ給ひぬらん。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば或る時、大目玉を引ン剥いて、毛剃が白眼※した百萬の唐船も斯くやと許り。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『足を蹈んだのは僕が惡かつた、惡かつたから謝罪る、ねえ君、これは僅かだけれど膏藥代に、な、納めて呉れ玉へ、さあ』對手の心事、酒代にありと見て取つた若紳士は、事の組し易きを喜んで、手早く握つた銀貨、二枚、三枚、光る物手をすべつて男の掌に移るよと見る間に「呵」と叫んで紳士は身を轉換した。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の處、年の頃十八九と見える色白の、艶然とした中形單衣、夜目にも透いて見える襟脚の確乎白きに、烏羽玉色の黒髮を潰し島田に結んだ初初しさ、濃紫の帶を太鼓に結んだ端が二寸許り、たれてその先が地に着かんとして觸れ合つて居る。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は云わば玉の輿にのったとも云われようが、自分の境遇は随分変った。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "コバルトの空には玉子色の綿雲が流れて、遠景の広野の果の丘陵に紫の影を落す。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "霊山の雲霧のごとく立昇る湯気の中に、玲瓏玉を溶かせるごとき霊泉の中に紅白の蓮華が一時に咲き満ちたような感じがしたのであった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "オムレツと焼玉子の合の子のようなものが、メニューの中にあった。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園裏にて下り小路を入れば人の往来織るがごとく、壮士芝居あれば娘｜手踊あり、軽業カッポレ浪花踊、評判の江川の玉乗りにタッタ三銭を惜しみたまわぬ方々に満たされて囃子の音ただ八ヶまし。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多門通りより元の道に出てまた前の氷屋に一杯の玉壺を呼んで荷物を受取り停車場に行く。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらの氷店へはいって休んだ時には、森の中にあふるる人影がちらついて、赤い灯や青い旗を吹く風も涼しく、妹婿がいつもの地味な浴衣をくつろげ姪にからかいながらラムネの玉を抜いていた姿がありあり浮ぶ。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
