        "examples": {
          "standard": [
            {
              "text": "彼女の首元で揺れるサファイアの垂れ飾りが、紺色のドレスにとても映えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "シャンデリアから下がるクリスタルの垂れ飾りが、光を反射して部屋を彩る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "異国の市場で見つけた、繊細な銀細工の垂れ飾りを自分への記念に買った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "バルトマイアーという書記などは彼女にすっかり惚れこんでしまって、この鎖と垂れ飾りとを贈ってくれ、その垂れ飾りのなかに自分の肖像を入れたほどだ。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな　ひだひだ、　それに　ししゅうつき　カフス、　たれかざりは　見たことが　ないとの　うわさで！",
              "citation": {
                "source": "グロスターのふくやさん",
                "author": "THE TAILOR OF GLOUCESTER",
                "note": "青空文庫"
              }
            }
          ]
        }
