        "examples": {
          "standard": [
            {
              "text": "庭の草花を使って、子供と一緒にハンカチのたたき染めに挑戦した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "たたき染めで仕上げたＴシャツは、世界に一つだけの自然な風合いがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "布の上に置いた葉っぱを小槌で叩くと、鮮やかな緑が浮かび上がるのがたたき染めの魅力だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
