    "definitions": [
      {
        "index": 1,
        "gloss": "Taiwanese person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
