        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は、手紙をろくろく見ずに、声立てて読みました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、玄関の式台には紋服を着た小坂吉之助氏が、扇子を膝に立てて厳然と正座していた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早春の淡紫に湿つた土の上で、独楽はチリチリヽヽといふ微かな音を立ててシンミリ廻つた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗末な額縁をはめてもらってその上を大事に新聞で包んで店を出た時は、心臓が高い音を立てて踊っていた。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "覘いている竹村君の後ろをジャン／＼と電車が喧しい音を立てて行くと、切るような凩が外套の裾をあおる。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレフンケン・システムの大きな蛇のようなスパークがキュンキュンと音を立ててひらめいては消えるのを見た。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小使が流しの上へ上がって、長い棒を押し立てて、何かゴボゴボ音を立てている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大井川の水｜涸れ／＼にして蛇籠に草離々たる、越すに越されざりし「朝貌日記」何とかの段は更なり、雲助とかの肩によって渡る御侍、磧に錫杖立てて歌よむ行脚など廻り燈籠のように眼前に浮ぶ心地せらる。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が頭から銀の簪をぬいて燈心を掻き立てている姿の幻のようなものを想い出すと同時にあの燈油の濃厚な匂いを聯想するのが常である。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "表の河沿いの道路に面した格子窓には風鈴が吊されて夜風に涼しい音を立てていたように思う。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど哀れをしらぬ征服者が蹄のあとに残して行く戦者の最後の息であるかのような悲しい音を立てている。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢の鉄瓶の単調なかすかな音を立てているのだけが、何だか心強いような感じを起させる。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵に對してこの無數の毒蛇は、素早く一樣に鎌首をもたげ、しゆつしゆつと氣味惡い音を立てて手向ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この傾斜を上り切って、ひょいと顔を出すと、槍ヶ岳の大身の槍尖が、すいと穂を立てている、そうして白い雪が、涎懸けのように半月形をして、その根元の頸を巻いている。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶壁の下なる大深谷からは、霧がすさまじいいきおいで、皺嗄れ声を振り立てて上って来る、近づくほど早くなるかと思うと、端から砕けてサアッと水球を浴びせる、そうして呻りながら、尾根につかまり、槍先へ這いずり上って、犠牲になる生霊もがなと、捜し廻っている。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "火が、ぴしぴし、音を立てて、盛に燃え出すと、樺の立木の葉が、鮮やかに、油紙の屋根に印して、劃然とした印画が炙り出される。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "フツ、フツと、柔くて、しかも鋭敏な音を立てて霧――雨が来た、偃松も、岩も、山も、片ッ端から白い紙になって、虚空に舞い上る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "躯を直角に曲げて、耳をおっ立てて、彼は「グニャグニャしたロープ」を、闇の中に求めた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「思考の節約」という事を旗じるしに押し立てて進んで来たいわゆる精密科学は、自然界におけるあらゆる物並びにその変化と推移を連続的のものと見做そうとする傾向を生じた。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "立入った理論はぬきにして、試みにある一つの歌を一遍声を立てて、読み下した後に、今後は口をむっと力を入れてつぶって黙読してみるといい。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをまた組立てて綱渡りをさせるのが自分の責任だがどうしたらよいかと思い惑っていると、周囲のラウベンコロニーの青い小屋からドイツ人の男女がぞろぞろ出て来た。",
              "citation": {
                "source": "御返事（石原純君へ）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "災害記念碑を立てて永久的警告を残してはどうかという説もあるであろう。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、はじめは人目に付きやすい処に立ててあるのが、道路改修、市区改正等の行われる度にあちらこちらと移されて、おしまいにはどこの山蔭の竹藪の中に埋もれないとも限らない。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊帳を組立てている繊維の表面はよせ集めるとなかなか広い。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よせばよいのに、早くしないかとせき立てておいて、座敷のほうへもどって、横になってけさ見た新聞をのぞく。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "温室の中からガタガタと下駄の音を立てて、田舎のばあさんたちが四五人、きつねにつままれたような顔をして出て来る。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海軍服は小石を拾っては氷の上をすべらせて快い音を立てている。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人が道ばたの花園の青芝の縁に杖を垂直に立てて考えることには、「ヒヤシンスはとても喫むまいが、チュリップというやつはこいつどうも煙草を喫みそうな花だ。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の地響と自動車の笛の音ばかりで、街には犬も声を立てて居ない、積雪に静まり返った真昼時でした。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間は三造を馬鹿にしてはゐない、寧ろ三造を喜んでゐる、しかしとりたてて尊敬してもゐはしない。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
