[
  {
    "uuid": "d76e465e-b104-5d7a-8e36-f5d7434fdba8",
    "entry": "平ら",
    "reading": {
      "primary": "たいら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "flat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "勘平らしき男も見えず、ただ隣りの男の眼付やゝ定九郎らしきばかりなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘はうしろであつまって一つの平らをこしらへる。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "整然として椅子を引いて、眼平らにこっちを見る。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔五、〕天気輪の柱　牧場のうしろはゆるい丘になって、その黒い平らな頂上は、北の大熊星の下に、ぼんやりふだんよりも低く連って見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その島の平らないただきに、立派な眼もさめるやうな、白い十字架がたって、それはもう凍った北極の雲で鋳たといったらいゝか、すきっとした金いろの円光をいただいて、しづかに永久に立ってゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川上の方を見ると、すすきのいっぱいに生えてゐる崖の下に、白い岩が、まるで運動場のやうに平らに川に沿って出てゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふちの上の滝へ平らになって水がするする急いで行く。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな広い平らな明るい瀑はありがたい。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上へ行ったらもっと平らで明るいだろう。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際こんなに川床が平らで水もきれいだし山の中の第一流の道路だ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここも平らで上等の歩道なのだ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い火山灰層のひとところが、平らに水で剥がされて、浅い幅の広い谷のようになっていましたが、その底に二つずつ蹄の痕のある大さ五｜寸ばかりの足あとが、幾つか続いたりぐるっとまわったり、大きいのや小さいのや、実にめちゃくちゃについているではありませんか。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下りて出るは例の池の岸なり、木の切株の平らなるに御座を拂ひて此處にお休みなされよと言へば、嬉しきことよの今朝は弟の介抱をうくるやうなり、其方も此處へ休まばよきにと半分を讓らるれば、何として勿躰なきことゝ直次は別なる枯草の中へうづくまりぬ。",
              "citation": {
                "source": "暗夜",
                "author": "一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人の胸中も自ずから平らかなるを得たようである。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京へ着いて酒保が一日開かれたので、早速一本二十銭のヨーカン五本買ってペロリと平らげて、まだ食いたい気がします。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が靴で踏み荒した雪の上へ新しい雪は地ならしをしたように平らかに降った。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "発育ざかりの私の二人の子供は、一日一升五合くらいの飯を平らげてまだなにかほしそうな顔をしているのだが、外米の入った飯になると、かわいそうなほど急に、いつもの半分くらいしか食わなくなって悄げこんだ。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪から例の瀬戸内通いの汽船に乗って春海波平らかな内海を航するのであるが、ほとんど一昔も前の事であるから、僕もその時の乗合の客がどんな人であったやら、船長がどんな男であったやら、茶菓を運ぶボーイの顔がどんなであったやら、そんなことは少しも憶えていない。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒川改修工事がこの爺さんには何となく不平らしい。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿耨達池やすべて葱嶺から南東の山の上の湖は多くは鏡のように青く平らだ。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜそう平らだかとならば水はみんな下に下ろうとしてお互い下れるとこまで落ち着くからだ。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "平らなことはまるで一枚の板です。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五、天気輪の柱　牧場のうしろはゆるい丘になって、その黒い平らな頂上は、北の大熊星の下に、ぼんやりふだんよりも低く連って見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その島の平らないただきに、立派な眼もさめるような、白い十字架がたって、それはもう凍った北極の雲で鋳たといったらいいか、すきっとした金いろの円光をいただいて、しずかに永久に立っているのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川上の方を見ると、すすきのいっぱいに生えている崖の下に、白い岩が、まるで運動場のように平らに川に沿って出ているのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上さ行げば平らだはんて。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこまでさへ行けばあとはもう十町もずうっと丘の上で平らでしたし来るときは山鳥も何べんも飛び立ち灌木の赤や黄いろの実もあったのです。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上まで行げば雪も降ってなぃしみぢも平らになる。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、あどぁ平らだぞ、楢夫。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうお前たちは思ってゐる、けれどもこの地面はまるっきり平らなのだ。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
