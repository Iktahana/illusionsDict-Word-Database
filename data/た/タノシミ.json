    "definitions": [
      {
        "index": 1,
        "gloss": "enjoyment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし琴、生花、茶道によって教育され、和歌や昔物語によって、物のあわれの風雅を知ってた彼の妻は、良人と共に、その楽しみを別ち味わうことができた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『だれにも解らない二人だけの言葉で、だれにも解らない二人だけの秘密や楽しみやを、愛人同士で語り合っている時である』と。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに氏には「余が俳句観」と題するエツセイもある程なので、さだめし作品が多量にあることだと思ひ、いつかまとめて読んだ上、俳人芥川龍之介論を書かうと楽しみにしてゐた。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生犀星氏がいつか或る随筆で書いてゐたが、仕事の終つた後で、きれいに机を片づけ、硯に墨をすりながら静かに句想を練る気持は、何とも言へない楽しみだと。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に年経て、古く物さびた庵の中には、今もなお故人の霊がいて、あの寂しい風流の道を楽しみ、静かな瞑想に耽っているように見えたか知れない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生前｜一樽の楽しみの外、明日は明日はと言ひ暮して、終に賢者のそしりを受けぬ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いて宇宙の神韻と化し、縹渺の詩境に遊ぶこともまた楽しみである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対に孤独癖の人間は、黙って瞑想に耽ることを楽しみとする。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在のようなジャーナリズム全盛時代ではおそらく大多数のこうした種類の挿画や裏絵は執筆画家の日常の職業意識の下に制作されたものであろうと思うが、あの頃の『ホトトギス』の上記の画家のものはいかにも自分で楽しみながら描いたものだろうという気のするものばかりである。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "募集した絵をゆっくり一枚一枚点検しながら、不折や虚子や碧梧桐を相手に色々批評したり、また同時に自分の描いておいた絵を見せたりして閑談に耽るのがあの頃の子規の一つの楽しみであったろうということも想像される。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹村君はこうして店先を覗くのが一つの楽しみである。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の暑い盛りだと下帯一つの丸裸で晩酌の膳の前にあぐらをかいて、渋団扇で蚊を追いながら実にうまそうに杯をなめては子供等を相手にして色々の話をするのが楽しみであったらしい。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの苗の生長を楽しみにしておられた博士は不幸にして夭折されたのである。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はお前の唄に聞き惚れつつ、さまざまな思い出の中に眠るのが今はたった一つの楽しみなのだ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしたちのして来たことは、まるで行燈をつけては消し、消してはつけるようなまどろい生涯だった」　彼女はメートルの費用の嵩むのに少なからず辟易しながら、電気装置をいじるのを楽しみに、しばらくは毎朝こどものように早起した。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の歿したのちは男の手一つで女中や婆あやや書生を使い、私を育てて来た父には生甲斐として考証詮索の楽しみ以外には無いように見えたが、やはり寂しいらしかった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "｛１｝『春色辰巳園』巻之七に「さぞ意気な年増になるだらうと思ふと、今ツから楽しみだわ」という言葉がある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなら楽しみが多いことであろう。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざわざ痕をつけて、それが日々黒くなるのを楽しみにする人はめったになさそうに思われる。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッチの貼紙や切手を集めあるいはボタンを集め、達磨を集め、甚だしきは蜜柑の皮を蒐集するがごとき、これらは必ずしも時代の新旧とは関係はないが、珍しいものを集めて自ら楽しみ人に誇るという点はやはり骨董趣味と共通である。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また少し種類が違っているが、品物を集めるのではなくて、古い書物や論文を愛読してその中からその価値の如何によらず人のあまり知らぬ研究や事実を掘出して自ら楽しみまた人に示すを喜ぶ趣味もある。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、子供の時に唱歌をやったと同じように、時々ピアノの鍵盤の前に坐って即興的のファンタジーをやるのが人知れぬ楽しみの一つだそうである。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乍併、家庭は尊いものだ、趣味の多いものだ、楽しみ極りないものだ。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事によらず面白味を知らずに其の中にあるより、面白味を知って其の中にあれば、楽しみが一層深いものである。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大変早く御精が出ますね」「ハア吾々なんざア駄賃取りでもして適に一盃やるより外に楽しみもないんですからな。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "政夫さんは、きょうはほんとに口が悪くなったよ」　山の弁当と云えば、土地の者は一般に楽しみの一つとしてある。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬期の休みには帰ってきて民さんに逢うのを楽しみにして居ります。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は必ず民子に逢われることと一方ならず楽しみにして帰って来たのに、この始末で何とも言えず力が落ちて淋しかった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろはそれがたのしみさ」言い終えたら、鼠のような身軽さでちょこちょこ走り去った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客さんの原稿の番號をそろへるのが、毎朝、ずゐぶんたのしみなのだから、たくさんすすんでゐると、うれしい。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
