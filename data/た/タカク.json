    },
    "definitions": [
      {
        "index": 1,
        "gloss": "many visitors",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれどもここにはなにがあるか、遠く都會をはなれたここの田舍には何があるか、ああ、ここには風がある、はてしもなくひろがつた大空がある、たかく盛りあがつた土壤がある。",
              "citation": {
                "source": "都會と田舍",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場は音たかく舌打ちして、「おい佐竹、からかうのはやめろ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはほんとうにバッカスの酒宴で、酒は泉とあふれ、肉は林とうずたかく、その間をパンの群れがニンフの群れを追い回すのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは、それを、ひたかくしにかくしてゐた。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのふ過ぎ、けふと暮れ、明日またかくこそ有るべけれ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ときびしい口調で命令し、浦島は素直に眼をつぶると夕立ちの如き音がして、身邊ほのあたたかく、春風に似て春風よりも少し重たい風が耳朶をなぶる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろは宿屋も、ひどく、おたかく止つてゐる。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただはららかにはららかに涙を含み、あたたかく息づいてゐて下さい。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、み空はたかく、吹く風はこまやかに　　――祈るよりほか、わたくしに、すべはなかつた……寒い夜の自我像きらびやかでもないけれどこの一本の手綱をはなさずこの陰暗の地域を過ぎる！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にまたかくのごとき文学の可能な所以でもある。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一とせ下谷のほとりに仮初の家居して、商人といふ名も恥かしき、唯いさゝかの物とり並べて朝夕のたつきとせし頃、軒端の庇あれたれども、月さすたよりとなるにはあらで、向ひの家の二階のはづれを僅かにもれ出る影したはしく、大路に立て心ぼそく打あふぐに、秋風たかく吹きて空にはいさゝかの雲もなし。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあれひんがし一つらの、　　　　　うこんざくらをせなにして、所長中佐は胸たかく、　　　　　　　野面はるかにのぞみゐる。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人がともだちをほしいのは自分の考えたどんなことでもかくさず話しまたかくさずに聴きたいからだ。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だかあたたかくそしてどこかおだやかに聞えるのでした。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山土のいろもあかく見えたる、あまりうつくしさに恐しくなりて、家路に帰らむと思う時、わが居たる一株の躑躅のなかより、羽音たかく、虫のつと立ちて頬を掠めしが、かなたに飛びて、およそ五六尺隔てたる処に礫のありたるそのわきにとどまりぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは涙の声たかく、あるほど声を絞りて姉をもとめぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてまたかくれあそびを繰返すとて、拳してさがすものを定めしに、われその任にあたりたり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とばかりありて、その姿またかくれ去りつ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は近代物理学によって設立された物質やエネルギーの素量の存在がいわゆる経験によった科学の事実である事を疑わないと同時に、またかくのごとき素量の存在の仮定が物理学の根本仮定のどこかにそもそもの初めから暗黙のうちに包含されているのではないかということをしばしば疑ってみる事がある。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰色の壁と純白な窓掛けとで囲まれたきりで、色彩といえばただ鈍い紅殻塗りの戸棚と、寝台の頭部に光る真鍮の金具のほかには何もない、陰鬱に冷たい病室が急にあたたかくにぎやかになった。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "光っては崩れ、うねっては崩れ、逆巻き、のた打つ浪のなかで互いに離れまいとつないだ手を苦しまぎれに俺が故意と振り切ったとき女は忽ち浪に呑まれて、たかく名を呼んだ。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "九天たかく存します神は、来る日も来る日も昼寝のみ、まったくの怠慢。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたたかくなって、そろそろ桜の花がひらきはじめ、僕はその日、前進座の若手俳優の中村国男君と、眉山軒で逢って或る用談をすることになっていた。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の古典文学の伝統が、もっとも香気たかくしみ出ているものに、名詞がある。",
              "citation": {
                "source": "古典竜頭蛇尾",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土の中にねむっていた蛙たちは、せなかの上の土があたたかくなってきたのでわかりました。",
              "citation": {
                "source": "二ひきの蛙",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで仕方なく、めいめいすきな方へ向いて、いっしょにたかく叫びました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫が久し振りにあたたかくなったので縁側に出て見ると、縁側の鉢の中にいる金魚が五、六匹チラチラしています。",
              "citation": {
                "source": "ドン",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそもまたかく祈る所以の者は、自然は決して彼を愛せし者に背（そむ）かざりしをわれ知ればなり。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めよりかれが恋の春霞たなびく野｜辺のごとかるべしとは期せざりしもまたかくまでに物さびしく物悲しきありさまになりゆくべしとは青年今さらのように感じたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
