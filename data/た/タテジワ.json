        "examples": {
          "standard": [
            {
              "text": "難しい問題に直面すると、彼は無意識のうちに眉間に深い縦ジワを寄せて考え込む癖がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鏡を見ながら、いつの間にか増えてしまった目元の縦ジワを指でそっとなぞってみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "加齢とともに目立ってきた口元の縦ジワを隠すために、彼女は念入りにメイクを重ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "れいのとおり、小熊で豚で人間のようなガン人であったが、ガンマ和尚は、額にしわがより、眉の間にもたてじわが三本も深くみぞをきざんでおり、そして垂れた鼻の両わきから、長い白ひげがさがっていた。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
