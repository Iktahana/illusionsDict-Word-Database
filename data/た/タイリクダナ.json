        "examples": {
          "standard": [
            {
              "text": "この海域の大陸棚はプランクトンが豊富で、古くから世界有数の好漁場として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大陸棚の地下には膨大な天然ガスや石油が眠っている可能性があり、資源開発の期待が高まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "海岸からなだらかに続く大陸棚を抜けると、海底は急激に深くなり深海の世界へと繋がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "陸地から海にはいるものは、大陸棚に沈澱してしまうので、大洋の深海までは届かない。",
              "citation": {
                "source": "エスキモーの国から",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸地から出る泥土は大陸棚とその周辺に沈澱してしまうので、大洋の真中には届かない。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "太平洋の深海は、六千｜米以上の深さで、陸地から来る泥土は、大陸棚とその周辺に沈澱してしまうので、こういう深いところまでは届かない。",
              "citation": {
                "source": "比較科学論",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、種族の中心地を移動した先は大陸棚の海底だったのだが。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
