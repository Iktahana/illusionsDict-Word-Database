    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese toad (Bufo japonicus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
