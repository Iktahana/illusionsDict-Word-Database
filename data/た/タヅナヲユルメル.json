        "examples": {
          "standard": [
            {
              "text": "「テストが終わったからといって、あまり手綱を緩めると次の試験で苦労するぞ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "厳しい指導を続けてきたが、部下の疲労が見えたので、あえて少し手綱を緩めることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "経営が軌道に乗ったからといって、コスト削減の手綱を緩めるわけにはいかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "馭者は舌を上へ捲いてキツ／＼キと口の中で妙な聲をさせて革の手綱を緩めると馬は首を前へのめす樣にして蹄を立てゝ二足三足と重相に歩き出した。",
              "citation": {
                "source": "商機",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこでクレオパトラがどうしました」と抑えた女は再び手綱を緩める。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
