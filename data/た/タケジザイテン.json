        "examples": {
          "standard": [
            {
              "text": "仏教の世界観では、他化自在天は欲界の最高天とされています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "煩悩に囚われることなく、他化自在天に住む者たちは自由である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼はまるで他化自在天の主のように、周囲の人々を意のままに操っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "第七　如是報我は飛来ぬ他化自在天宮に　オヽお辰かと抱き付かれたる御方、見れば髯うるわしく面清く衣裳立派なる人。",
              "citation": {
                "source": "風流仏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六の他化自在天に至ってはただ相視るだけのそれのみが充足である。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
