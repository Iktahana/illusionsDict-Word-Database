        "examples": {
          "standard": [
            {
              "text": "主旋律の裏で流れるチェロの対旋律が、曲全体に深い奥行きを与えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "作曲家は、フルートの軽やかな旋律に対して、ファゴットによる重厚な対旋律を加えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "合唱の練習で、アルトのパートが歌う美しい対旋律をしっかりと響かせるよう指導を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そう思ってそこを見ると、その小さい水玉たちは、僅か三、四寸の空間をきらめいて落ちて行きながら、流れている水面にまた無数の微かな波紋を作って、この美しい光の交響楽は、ますますせんさいに捉えがたいせんりつを織り出しているのでした。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
