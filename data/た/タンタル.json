          "literary": [
            {
              "text": "５　Niobe ――ギリシア神話のタンタルスの女、テーベ王アンフィオンの妻。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イライラする、――tantalizing――Tantalus――Inferno……」　タンタルスは実際硝子戸越しに果物を眺めた僕自身だつた。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イライラする、――tantalizing――Tantalus――Inferno……」　タンタルスは実際硝子戸越しに果物を眺めた僕自身だった。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "羨望の神タンタルを驚す空虚の盃。",
              "citation": {
                "source": "珊瑚集",
                "author": "仏蘭西近代抒情詩選",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはタンタルスの苦痛に似ていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一個の母親に適用されたタンタルス（訳者注　永久の飢渇に処刑せられたるギリシャ神話中の人物）の処刑を、あなたは何と言われますか。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、タンタルス（訳者注　永久の飢渇に処せられし神話中の人物）のように彼らが望んでいた二つのことがある。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
