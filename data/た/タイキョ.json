    "definitions": [
      {
        "index": 1,
        "gloss": "departure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "問題の雀焼きは、お篠の退去後に食べたか、または興覚めて棄てちゃったか、思い出せない。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "準備が整って予定の時刻が迫ると、見物人らは一定の距離に画した非常線の外まで退去を命ぜられたので、自分らも花屋敷の鉄檻の裏手の焼け跡へ行って、合図のラッパの鳴るのを待っていた。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　贋百姓は落ちついて八本の薔薇を植え、白々しいお礼を述べて退去したのである。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "血に飢ゑたる暴徒たちも、この天衣無縫の不思議な気品に打たれて、思はず王と共に、フランス万歳を絶叫し、王の身体には一指も触れずにおとなしく王の居室から退去したのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつあなたに、いかにも如來らしい退去のすがたをおめにかけませう。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　撮影所から退去して、電車にゆられながら、男爵は、ひどく不愉快であった。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをそっと紙で巻き耳の穴に押し込み、正門から素知らぬ顔で堂々とその片眼鏡のにせ貴族は退去したそうだ。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が伏見の東方桃山は、彦根藩が守って居り、幕軍では、自分達の味方だと思っていた所、薩藩は開戦となると、朝命を以て彦根勢を退去せしめ、その後に自軍の大砲を運び上げ、伏見の町を眼下に見おろして、打ちまくった。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後二時頃城内より退去令の伝騎来って後退した。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐平は巡査の背後から一間ばかりも、大狼狽に狼狽て後に退去った。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは後へ退去つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘次は足もとにずる／＼と横はつた蛇を見つけた刹那の如く悚然として退去つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘次も卯平の側を退去つて只恐ろしく僻んだ容子をして居た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸侍の中で城を渡して退去したいものは勝手に退去するが好い。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに諸侍は一人も退去しようとは云わぬ。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けてしまったので王命婦と弁とが源氏の退去をいろいろに言って頼んだ。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "お帰へりなさい彼女は美しい声で邪剣な退去命令を大西に下した。",
              "citation": {
                "source": "託児所をつくれ",
                "author": "小熊秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣国王来り戦いしがその好馬多きを知り、とても勝てぬと諦め退去した。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは郊外へ退去するよりも一層馬鹿気ている。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫工会の成り立ちについて",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼の退去を出願したのです。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "稽神録",
                "note": "青空文庫"
              }
            },
            {
              "text": "神樣は退去になる、猪頭ばかり殘つてる。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月九日、彼らは忽然として、大西洋海中を退去し、この種の事件は跡を絶った。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "急ぎロミオを退去らせい。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥羽伏見で、敵方に錦旗が翻めくと同時に、味方の足が浮いていつとなく総崩れとなり、淀の堤を退去したとき、彼はいつの間にか味方の諸隊と離れていた。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お勢の心一ツで進退去就を決しさえすればイサクサは無い。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "群来た鰊の大群は、午前の三時頃になってようやく退去して行った。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり大騒ぎをして私達の勉強を妨げると、玉那覇は大喝一声で退去を命じたが、未来の海軍大佐は一向平気なもので、叔父をひやかしながら退却するのであった。",
              "citation": {
                "source": "私の子供時分",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "回ってろといや、一年でも二年でも回ってますが、いったいきょうは、どこを探るんでげすかい？",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろ袷に着換えたいきょうこのごろ、家中がムンムとするほど炭火をおこして、その火で反古紙を貼ったものを片っ端から乾かしていった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "その彫刻師という正体を、なぜかあくまで人に隠しておきたい作爺さんは、言い訳がましい眼とともに、そこらの木屑を片づけ、やっとチョビ安のために坐る場所を作ってやりながら、「いったいきょうまでどこにどうしていたのだ、チョビ安。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
