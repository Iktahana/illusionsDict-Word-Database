[
  {
    "uuid": "cdb81e83-d743-58a1-80b1-1f63c47e991c",
    "entry": "退去",
    "reading": {
      "primary": "たいきょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
