    "definitions": [
      {
        "index": 1,
        "gloss": "to light (a fire)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私の口から出る一語一語は、自分の怒りをさらに焚きつける新たな薪のようであった。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "博勞はあゝ丁度いゝ處だ生憎婆さんが居ないからと自ら立つて爐へ榾を焚きつける。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "良因は内へ入りて、爐に枯枝を焚きつける。",
              "citation": {
                "source": "能因法師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝、起きるとすぐ竈の下を焚きつける、ちろちろと燃える、燃えあがる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きるとすぐ火を焚きつける、火はうれしいものだ、冬の火はことさらうれしい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし曇つたが、また持ち直した、腹を立ててゐる私へ鶲が宥めるやうに啼いて来た（百舌鳥は私を焚きつけるやうに絶叫するが）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "木炭が買へないからそこらの雑木をひろひあつめて焚きつける、それでもありがたいことには、御飯が吹き御湯が沸いた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょうことなしに老母の懐に慣らされて来た子供は、夜は空乳を吸わせられて眠ったが、朝になると、背に結びつけられて、老母の焚きつける火のちろちろ燃えて来るのを眺めていた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お島は庭の井戸の水で、白粉のはげかかった顔を洗いなどしてから、裏の田圃道まで出て来たが、濛靄の深い木立際の農家の土間から、釜の下を焚きつける火の影が、ちょろちょろ見えたり、田圃へ出て行く人の寒そうな影が動いていたりした。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "何より寒い今夜の御馳走は火が先だとエジツが倉から小柴を抱へて出て炉を焚きつける。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "火を焚きつけるもの、灰を掻くもの、或は、新しい白木の桶に、「あまづらみせん」を汲んで釜の中へ入れるもの、皆芋粥をつくる準備で、眼のまはる程忙しい。",
              "citation": {
                "source": "芋粥",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　といった調子で、追っかけ引っかけセルゲイは、カテリーナ・リヴォーヴナを焚きつけるのであった。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "十数人の大家族だったので、女中が朝暗いうちから起きて、煤けたかまどに大きい釜をかけて、粗朶を焚きつける。",
              "citation": {
                "source": "おにぎりの味",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "森　（同情するように、また焚きつけるように）うむ。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうこそは、ひと思いに――」　焚きつけるがごとき口調――。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い台所には、妻が竈へ火を焚きつける。",
              "citation": {
                "source": "田園の憂欝",
                "author": "或は病める薔薇",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰り来ると、がっかりして、囲炉裏の傍に座を構えながら、枕屏風を横目に睨んで、「ちぇッ」　舌を鳴らして額の皺を深くしながら、火を焚きつけることが例になっているのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "当世はまず人気を煽って、しかして後に事を行わんとするの風がある、これ冠履顛倒で、余弊｜済うべからざるものがある、よろしく人気の根元を問うべし」と焚きつけるものもあります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことは全く異例であるけれども、これも一つは酒というものが、傍らにいて焚きつけることをしない一つの作用であると見れば見られる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "農奴の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人してひとを焚きつける。",
              "citation": {
                "source": "きもの",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんなあの別莊友だちが焚きつけるんでさ」と、パーヴェル・パーヴロヴィチは見る見る元氣づいて、いきなり威勢のいい聲を出した。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "てんでお取り合いになりますまい」「纒まるものも破れてしまいます」「長船君も一寸買収出来る男じゃありません」「あれは焚きつける方です。",
              "citation": {
                "source": "嫁取婿取",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝などでも、父親がブツブツ云いながら、自分で釜の下を焚きつける日が多かった。",
              "citation": {
                "source": "夢遊病者の死",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつに意外な事を」　不死人はこういって、人を焚きつけるような眼をかがやかした。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会に対し、政府に対し、同胞に対しまた家族に対してあらゆる種類の不平不満をいだいている人は、この原始的楽器を原始的の努力をもってたたきつけるのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まつくらの地面をたたきつける、今夜は雨や風のはげしい晩だ、つめたい草の葉つぱの上でも、ほつと息をすひこむ蛙、ぎよ、ぎよ、ぎよ、ぎよ、と鳴く蛙。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時にはかなり無雑作に勢いよく筆をたたきつけるとおもしろいように目が生きて来たり頬の肉が盛り上がったりする。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、冷静な第三者の目には明白にこの場合に該当すると思われる場合においても、弟子が先生を恨みゴシップがたきつけるという事件の起こることが意外に多いように見受けられる。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こう側の三人の爆笑とそれに続く沈静との週期的交代の観察に気を取られて、しばらく前方の老人の事を忘れていたが、突然、実に突然にその老人が卓上の呼び鈴をやけくそにたたきつけるけたたましい音に驚かされてそのほうに注意をよびもどされた。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩餐会で腹をかかえて哄笑するのもキュラソのビンで自分の肖像のどてっ腹に穴をあけるのも、工場と富とを投げ出してギャングの前にたたきつけるのもみんな自由へのパスポートである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
