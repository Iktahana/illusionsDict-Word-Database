    "definitions": [
      {
        "index": 1,
        "gloss": "to stand (still) a while",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
