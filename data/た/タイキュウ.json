[
  {
    "uuid": "ae199821-784f-5220-ac12-4d3cc5d08112",
    "entry": "耐久",
    "reading": {
      "primary": "たいきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
