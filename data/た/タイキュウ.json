    },
    "definitions": [
      {
        "index": 1,
        "gloss": "endurance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "場合によってはある一人のこういう耐久力のいかんによって一軍あるいは一国の運命が決するようなことがないとも限らない。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また耐久力がないという。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも多くの場合にこのような独創力と耐久力を併有しているような種類の人間は、同時にその性状が奇矯で頑強である場合が多いから、学者と言っても同じく人間であるところの同学や先輩の感情を害することが多いという事実も争われないのである。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "オープンショウ耐久タイヤで特許を取って、ひとかどの成功をしましたので、あとは特許を売って悠々自適に隠居です。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただそれ彼方には建築用材多く、したがって偉大耐久の寺院多し。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが国は木造の建築を主とすれば、彼方ごとき偉大耐久のもの少なし。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "偉大なる思想は一投手、一挙足の間に発生すべきにあらず、寧んぞ知らん、一国民の耐久的修養の力なるものを俟つにあらざれば、蓊欝たる大樹の如き思想は到底期すべからざるを。",
              "citation": {
                "source": "国民と思想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "トポーロフはボルシェヴィキ的耐久性で八年それをやった。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、事業の困難さは、耐久力のない胤子を再び失望させたのみか、北海道へ来たことも、良人の生活態度にも、すべてに気をくさらし、同じ感化院の教務主任守屋と不健全な関係に陥る。",
              "citation": {
                "source": "作品のテーマと人生のテーマ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "法隆寺の金堂や薬師寺の塔は木造建築の耐久性を示す注目すべき実例である。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来得る限り自然の力を利用して、京都の政府と耐久力の一点で戦ったのであった。",
              "citation": {
                "source": "比叡",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "所で、大阪を見たり、論じたりする場合、必ず、その好敵手である東京と比較して、女が、食物がというが、凡そこれ位、常套手段は無い――と思うが、何うも、これは、アメリカ人が、木登り耐久までもして、世界一という比較を誇ろうとする如く、文化の進歩上いい現象なのかもしれない。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷の島が温帯で、いや熱帯圏内に入っても、果して耐久力があるか否かを試験しているのだ。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに一人で考へてゐてもきまりが悪いから、かうして水風呂で身体をきたへておくと、いざとなつて山野に野宿がつゞいても耐久力があると考へた。",
              "citation": {
                "source": "わが戦争に対処せる工夫の数々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際私はこの水風呂以来、厳寒に薄着をしても風をひかなくなつたので、今もつてその耐久力はつゞいてゐる。",
              "citation": {
                "source": "わが戦争に対処せる工夫の数々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、要するに戦災都市のバラックと異るのは耐久力の点だけで、その本質はバラックと変りがない。",
              "citation": {
                "source": "風流",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば自動車は速力、載量、耐久、価格などの多くの要素の複合としての機能概念（Funktionsbegriff）であり、一つの運搬の道具の目的をもつであろう。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この線とこの線の間は何ミリメートルある、この紙質は植物性のもので耐久力は何年、この墨を分析してみると成分はこれこれ……というようなことを、おどろくばかり精密に教えてくれる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば昔の大工や左官が手をぬかなかったために、百年百五十年の耐久力があるにしても、それは、単に耐久力というだけで、庶民生活の豊かさを住宅自体が表しているような豪華なものはどこにもない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "角背の腔背は耐久力に難点がある。",
              "citation": {
                "source": "書籍の風俗",
                "author": "恩地孝四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ、今日洋装の書物が、耐久性からいっても、趣味の上からしても殆んど永久の蔵書に値しないかもしれぬが、なほ優に二三十年間は、原型をとゞむるでありましょう。",
              "citation": {
                "source": "書を愛して書を持たず",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "耐久力の上ではいうまでもないが、一八三四年に鉄造船ガリイ・オーエン号が処女航海で暴風を喰った。",
              "citation": {
                "source": "黒船前後",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "また曰く、「勝利における唯一の道は、殉難に依るに在り、殉難を耐久するに在り」と。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "設備の費用と、耐久力と、霧の捕捉量と、その水による増収量とを計算すれば、経済的に成り立つか否かが決定されるわけである。",
              "citation": {
                "source": "霧を捕える話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんといふ耐久力だらう。",
              "citation": {
                "source": "夜の鳥",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "または両方の武器を作るに同一の分量の労働が必要であるが、しかし両者は非常に耐久力が異ると仮定せよ。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
