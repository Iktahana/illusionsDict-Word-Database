[
  {
    "uuid": "3e435581-4900-5ab9-b731-1b880fb1c8e3",
    "entry": "耐える",
    "reading": {
      "primary": "たえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
