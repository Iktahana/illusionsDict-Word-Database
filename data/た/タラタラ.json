    "definitions": [
      {
        "index": 1,
        "gloss": "drop-by-drop",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "植物園の門をはいってまっすぐに広いたらたら坂を上って左に折れる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己｜嫌悪に打負かされまいと思って、彼の額から脂汗がたらたらと流れた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでゐて水晶のやうな液をたらたらとたらしてゐる。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の玉がたらたら垂れた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいて水晶のような液をたらたらとたらしている。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらら木のたらたら坂に樹の蔭もなし。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見返ればハヤたらたらさがりに、その肩躑躅の花にかくれて、髪結いたる天窓のみ、やがて山蔭に見えずなりぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、」家内は平気で、「三十分くらいこうしていると、汗がたらたら出てまいります。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "憎みに力を添えられて辛うじて座禅の形を続けていると収縮した毛穴から干からびた皮膚へ油汗がたらたらと押し出て全身が痛いようだった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一筋の木目も無いばさばさした淡黄色いくぬぎの切り口には、わずかに汗の様な、うるおいが滲んで居るばかりであったけれど、ところどころに交る女松の木地などには、たらたらと赤黄色い脂が流れて居るのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己嫌悪に打負かされまいと思って、彼の額から脂汗がたらたらと流れた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜辺は煮えて賑かに、町は寂しい樹蔭の細道、たらたら坂を下りて来た、前途は石垣から折曲る、しばらくここに窪んだ処、ちょうどその寺の苔蒸した青黒い段の下、小溝があって、しぼまぬ月草、紺青の空が漏れ透くかと、露もはらはらとこぼれ咲いて、藪は自然の寺の垣。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどそのたらたら坂を下りた、この竹藪のはずれに、草鞋、草履、駄菓子の箱など店に並べた、屋根は茅ぶきの、且つ破れ、且つ古びて、幾秋の月や映し、雨や漏りけん。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、たとえば地蔵様の前に地獄の絵の生首を並べた状に、頸を引抱えた、多津吉の手を、ちょっと遁げて、背いて捻った女の唇から、たらたらと血が溢れた。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は立竦みになりてぶるぶると震えたるが、鮮血たらたらと頬に流れつ、抱きたるお藤をどうと投落して、屏風のごとく倒れたり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　肩と鳩尾に手を懸けて後抱に引起す、腕を伝うて生暖きもの、たらたらたら。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」柳眉を逆立て、星眼血走り、我と我手に喰附けば、右の無名指に二個嵌めたる宝石入の指環を噛みて、あっと口を蓋えるとたん、指より洩れて鮮血たらたら、舌を切りぬ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや傾けたる丸髷の飾の中差の、鼈甲の色たらたらと、打向う、洋燈の光透通って、顔の月も映ろうばかり。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店の横にも、見上るばかりの槐榎の暗い影が樅楓を薄く交えて、藍緑の流に群青の瀬のあるごとき、たらたら上りの径がある。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る内に、額にたらたらと衝と汗を流し、死声を振絞ると、頤から胸へ膏を絞った……あのその大きな唇が海鼠を干したように乾いて来て、舌が硬って呼吸が発奮む。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は客商売をしたに似合わず、性分としてたらたらお愛相のいえない方であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と先に立ち、幕明き前のざわつく廊下を小股にせかせか歩きながら、棧敷の五つ目へ案内し、たらたらお世辞を言って、銀子の肩掛けをはずしたり、コオトを脱がせたり、行火の加減を見たりした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめお世辞たらたら書き認めて、さて、金を送って下されと言いだすのは下手なのであった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめのたらたらのお世辞がその最後の用事の一言でもって瓦解し、いかにもさもしく汚く見えるものである。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私はたらたら汗を流して居る氏を、不思議に見詰めた。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしが急いで近寄って編笠の中を覗くと、彼はせぐり上げせぐり上げして来る涙を、胸の喘ぎだけでは受け留めかねて、赤くした眼からたらたら流している。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
