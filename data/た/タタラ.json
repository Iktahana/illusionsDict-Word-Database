    "definitions": [
      {
        "index": 1,
        "gloss": "foot-operated bellows",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
