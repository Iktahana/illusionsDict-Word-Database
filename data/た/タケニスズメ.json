        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "船には竹に雀の紋をつけた幔幕が張り廻されていた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらの老いたる眼に映るものは、裃である、大小である、竹に雀の御紋である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、かの女は他方のを放したが、かの女の手に殘つたのは、竹に雀の墨繪が書いてあつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "（七月二十日）七十○梅に鶯、竹に雀、などいふやうに、柳に翡翠といふ配合も略画などには陳腐になるほど画き古されて居る。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "序幕から大切までを一つ／＼、俗悪な、浮世絵とも何とも付かぬものにかき現した絵看板は、芝居小屋の表つき一杯に掲げられて、竹に雀か何かの模様を置いた、縮緬地の幅の広い縁を取つてあるのも毒々しかつた。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小剣",
                "note": "青空文庫"
              }
            },
            {
              "text": "序幕から大切までを一つ一つ、俗悪な、浮世繪とも何とも付かぬものにかき現した繪看板は、芝居小屋の表つき一杯に掲げられて、竹に雀か何かの模樣を置いた、縮緬地の幅の廣い縁を取つてあるのも毒々しかつた。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "その医者が、ちょっと竹に雀ぐらいの絵心はあった。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "駕籠を追って　馬の鈴音、鳥の声、竹に雀はの馬子の唄に、ハッと驚いて眼を覚すと紋太郎は急いで刎ね起きた。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "駕籠で飛ばせる人もあり、品川宿の辺りからは道中馬も立つと見えて、竹に雀はの馬子唄に合わせ、チャリンチャリンと鈴の音が松の並木に木精を起こし、いよいよ旅情をそそるのであった。",
              "citation": {
                "source": "戯作者",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹に雀といふ事があるが、成程流石に竹林には雀の遊ぶものである。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「竹に雀はしなよく止る」と謡われます。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親が題を出すにつれて、胡瓜、なす、牡丹、竹に雀、しまひには山水までが、展べられた唐紙の上に、さらさらと描きわけられてゆく。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "『高尾』で仙台公のなりが錦糸で竹に雀、紫頭巾。",
              "citation": {
                "source": "噺家の着物",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊達家の紋は「竹に雀」であるが、竹林の静かな情景をうたった詩句が、綱宗の心を惹きつけたのだろう。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし便器のようなものには今でも達者な筆で、牡丹紋だとか竹に雀だとかを自在に描きます。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
