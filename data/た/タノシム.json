    "definitions": [
      {
        "index": 1,
        "gloss": "to enjoy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "フォルムのない競技で以て、徒らに勝たうとばかりしてゐるやうなもので、仮令勝てたにしても、競技そのものを楽しむ気持はなく、勝つた時に熱病的に嬉しいだけで、十年の後に回想したらば、なんといふこともなかつたと、呆然としなければならない始末だらう。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、詩といへば「ああいふもの」と、一般的にハツキリと位置するものとなつたとしたら、楽しむ方でも作る方でも、事情は一変するのであるが、これは容易に首肯されさうでゐて、却々了得され難いことだと思はれる。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼が自ら言ふ通り、今の彼が詩を書く気持は、昔のやうに張り切つたものではなくつて、飽食の後に一杯の紅茶をすすり、労作の後に机を浄めて、心の余裕を楽しむ閑文学の風雅にすぎない。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼が石を集め、苔を植ゑて庭を造り楽しむ時、しばしばその自己流の道楽芸が専門の庭園師を嘆息させるほど、真にユニイクな芸術創作となるのである。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日だけの休暇を楽しむ、可憐な奉公人の子供は、何の夢を見ていることやら、と言う意味である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの人は、仲間と一緒の方を楽しむらしい。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ僕だけが変人であり、一人の自由と気まま勝手を楽しむのである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は自然に友人を避け、孤独で暮すことを楽しむように、環境から躾けられてしまったのである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを歓び楽しむことで、わしは人后に落ちはせん。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "花を見ながらふと気の付いたことは、若いときから上野の花を何度見たかしれない訳であるが、本当に桜の花を見て楽しむ意味での花見をすることが出来るようになったのはほんの近年のことらしい、ということである。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学の方面で云えば、例えばある方則または事実の発見前幾年に誰が既にこれに類似の事を述べているといったような事を探索して楽しむのである。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もほんとうに絵を味わい楽しむためには、ある意味での批評をしなければならない事は勿論であるが、しかし、意識的に批評のための批評をしようという心持があっては、芸術品を楽しみ味わう邪魔になるばかりでなく、却って本当の正しい批評をすることの障碍になりはしまいか。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分等のようなものが絵の展覧会を見るのは、何時でも絵を見て楽しむためである。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、如何に評判の絵でも、自分に興味のないものは一度きりで見ないで済むし、気に入った絵なら誰に気兼ねもなく何遍でも見て楽しむことが出来る。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それはシベリヤで楽しむ内地の匂いにすぎなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "群集を好む動物があり一方にはまた孤独を楽しむ動物があるかと思うと、また一方ではある時期には群集を選ぶが他の時期、特に営巣生殖の時期には群れを離れて自分だけの領地を占領割拠し、それを結婚の予備行為とした上で歌を歌って領域占領のプロパガンダを叫び、そうして花嫁を呼び迎える鳥類もある。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを味わってみれば、自分一人である問題を解決しようとして一生何も貢献せずに終わり、あるいは恥をかく事もなく、めいめいの分に応じた仕事を楽しむ事ができそうである。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また僕は君が一度こんなことを言ったのを覚えているが、そういう空想を楽しむ気持も今の君にはないのかい。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "え、お香、そうしておまえの苦しむのを見て楽しむさ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨董の佳い物おもしろい物の方が大判やダイヤモンドよりも佳くもあり面白くもあるから、金貨や兌換券で高慢税をウンと払って、釉の工合の妙味言うべからざる茶碗なり茶入なり、何によらず見処のある骨董を、好きならば手にして楽しむ方が、暢達した料簡というものだ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが書画骨董に心を寄せたり手を出したりする者の大多数はこの連中で、仕方がないからこの連中の内で聡明でもあり善良でもある輩は、高級骨董の素晴らしい物に手を掛けたくない事はないが、それは雲に梯の及ばぬ恋路みたようなものだから、やはり自分らの身分相応の中流どころの骨董で楽しむことになる。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番聡明善良なるものは分科的専門的にして、自分の関係しようとする範囲をなるべく狭小にし、そして歳月をその中で楽しむ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の知った範囲内でも、人からは仙人のように思われる学者で思いがけない銀座の漫歩を楽しむ人が少なくないらしい。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがアメリカあたりの観測隊であったら、おそらく電池ぐらいかなり豊富に運び上げて、その日その日のラジオで時を殺し、そうしてまたおそらくポータブルのジャズでステップを踏み、その上にうまいコーヒーで午後の一時間を陽気に朗らかに楽しむではないかと思う。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこれを忘れているおかげで今日を楽しむことができるのだという人があるかもしれないのであるが、それは個人めいめいの哲学に任せるとして、少なくも一国の為政の枢機に参与する人々だけは、この健忘症に対する診療を常々怠らないようにしてもらいたいと思う次第である。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらさらひらひら、と低く呟いてその形容を味わい楽しむみたいに眼を細めていらっしゃる、かと思うと急に、いや、まだ足りない、ああ、雪は鵝毛に似て飛んで散乱す、か。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出来ましたかね」　私のおやじは、伜をカラカッて楽しむというわるい癖がある。",
              "citation": {
                "source": "ざんげの塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分を発展しなくてはやまない活力、これが人生を楽しむ要素である。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "謡の好きな人はその時間に一番ずつうたうもよし、盆栽を楽しむ人は盆栽をいじるもいいし、収集家は収集品の整理をやるもいいだろう。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この流儀で人生に処すると、世の中や人間のあらばかり見え、だんだん浮世が嫌になり、自分独り孤独を楽しむようになって、人交際が出来にくくなります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
