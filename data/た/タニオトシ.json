          "literary": [
            {
              "text": "」　男の子は目を地びたにおとして、くびをふりました。",
              "citation": {
                "source": "乞食の子",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小舎のなかにはゴルドンらがとらえてきたもののほか、新たにおとし穴でとらえたラマ一頭と、バクスターがイルコックとともに飛び弾で生けどった牝牡二頭のヴィクンヤがいた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、おりおり立ちどまっては、そのくずしたパンくずを、地びたにおとしました。",
              "citation": {
                "source": "ヘンゼルとグレーテル",
                "author": "HANSEL UND GRETEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は眼を地べたにおとして考えるふうだった。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ときどき立ちどまっては、パンくずを地べたにおとしていきました。",
              "citation": {
                "source": "ヘンゼルとグレーテル",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            }
          ]
        }
