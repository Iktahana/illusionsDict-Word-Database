    "definitions": [
      {
        "index": 1,
        "gloss": "whichever person (indefinite pronoun)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
