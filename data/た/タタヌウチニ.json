    "definitions": [
      {
        "index": 1,
        "gloss": "before ... days (months, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
