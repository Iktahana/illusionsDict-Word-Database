[
  {
    "uuid": "328abae2-8811-5c47-ae28-84e79b29f9e2",
    "entry": "大変",
    "reading": {
      "primary": "たいへん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "very",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大変元気で粗忽が自慢でもある、甚だ罪のない男がその夜の進行係をやつてゐて、一人で大声で喋舌つてゐたが、大部分の者は聴いてもゐなかつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人によつて色々異ることと思ひますが、私は詩に就いては自分に分るやうにだけは考へますが、それを人に分らせようとするや大変骨が折れます。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年、「宮沢が死んだ」と聞いた時には、大変気の毒に思ひました。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後四つ五つとなると、私は大概の玩具よりも遥かに釘だの戸車だの卦算だのを愛するやうになるのだが、それは何かうまく云へないまでも大変我乍ら好もしいことのやうに思はれてならない。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　それや退屈つてことに対しては、大変同情は感じてるさ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "観れば何時もながら面白く感ずるのだが、観るまでは大変憶怯で、結局一年に一度か二度しか歌舞伎を覗くことはないのが私のこれまでである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間は落付かないし、出掛けてもさして面白くないので、私には朝早く起きることは大変時間の損失なのだ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人共大変に歌舞伎通のやうである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "コノ夏ハクラゲヲ大変｜恐レマス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "スルト大変喜ビマシタ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局それは、夫人の強硬な反対によって中止されたが、後でそれが有名な化物屋敷と解った時、夫人がほッと胸を撫でおろしたとは反対に、ヘルンは大変失望して、『ですからなぜ、あの家住みませんでしたか。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで夫人から『あなた、日本のこと、大変よく書きましたから、お上で、あなた賞めるためお呼びです。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は恰度、その女に退屈してゐた時ではあつたし、といふよりもその女は男に何の夢想も仕事もさせないたちの女なので、大変困惑してゐた時なので、私は女が去つて行くのを内心喜びともしたのだつたが、いよいよ去ると決つた日以来、もう猛烈に悲しくなつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼に就いて語りたい、実に沢山なことをさし措いて、私はもう筆を擱くのだが、大変贅沢をいつても好いなら、富永にはもつと、相像を促す良心、実生活への愛があつてもよかつたと思ふ。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、他の事ではいざ知らず芸術では伝統といふものは大変有難いものである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "所がもう一匹の奴がゐることを知つた時一寸、大変な災難が来たやうな気持になつた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かやうな都会の私立中学にあつては、編入者や退学者が大変多いために、生徒の愛校心は至つて乏しいのである。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の叔父さんには代議士がゐるとかいふことだつたが、彼もよく政談や坐禅の話を、大変大きい声か、それとも大変小さい声かでしてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹は太く、枝は大変よく拡がつてゐたが、丈は高くない松だつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "親の俺からみてもおまへと耕二は大変な違ひだ。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「これやいつたい買つたのかい、大変具合が悪いが。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにこの男が此の頃大変卑怯ではない人の分る事が分るのはどうしたことでせう？",
              "citation": {
                "source": "小林秀雄小論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして此の頃大変魂の大事なことが分るといふのには、彼の自己自身の興味に沈溺する善良性は小さくなかつたのです。",
              "citation": {
                "source": "小林秀雄小論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "友よ、この一文を書きたくなつた今晩君が傍にゐて呉れたら僕は大変沢山なことが喋舌れた。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもこんな草稿でも君に見せれば大変好いと僕は思つてゐるのです。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日迄大変暑かつたのにも今日はボンヤリした日が射してゐて、時々夕立でも降らせさうな雲の塊が乾き切つた庭の土を薄暗くしたり、そして稀々しくも地面を匍ふやうな微風が所々に生えた雑草などを揺るので、私の心は思ひ出を巡るに似合はしい気分になつて、その蛇の思ひ出はだんだん拡がつていつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "見舞の人達が此方を見てゐたので私は大変気持が悪かつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "室津の宿屋の主人はかなりのお婆さんであったが、われわれ二人の中学生の初旅を珍しがって大変にもてなしてくれた上に「珍しいものを見せて上げよう」と云って持出して来たのが一巻の絵巻物であった。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大変に御馳走があって二の膳付の豊富な晩食を食わされたのでいささか嚢中の懸念があったではないかと思う。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンはそれがたいへん気に入り、『面白いの音』といいながら、頬をふくらして、ボオボオと吹き鳴らしては、また『いかに面白い』といって吹き続けた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
