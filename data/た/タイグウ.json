  {
    "uuid": "37431303-01ba-5dfe-8c2d-8b6d5f6a6f16",
    "entry": "対偶",
    "reading": {
      "primary": "たいぐう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
