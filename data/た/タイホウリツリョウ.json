        "examples": {
          "standard": [
            {
              "text": "大宝律令の制定によって、二官八省という中央官制が整えられ、日本は本格的な中央集権国家へと進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地方の行政組織や複雑な税制も大宝律令によって細かく規定され、公地公民に基づく支配が徹底された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "日本史上初めての組織的な体系を持つ法典である大宝律令は、その後の政治制度の基礎を築いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "近江令であり、文武天皇の御代に出来た大宝律令の根本を成すものである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "近江朝廷の令にしても、大宝律令にしても漢文で記されねばならなかったし、詔勅も上奏も太政官符も戸籍も歴史も、すべて支那文化に則る政治風教の百科の事務はみな漢文の記録にたよらなくてはならなかった。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
