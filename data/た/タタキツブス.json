    "definitions": [
      {
        "index": 1,
        "gloss": "to (hit and) crush",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "薪は間違つて肉体を叩き潰すかも知れないが、女の舌は一度に霊魂を窒息させてしまふ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれじゃ全然葉子を叩き潰すようなもので、私も寝醒めが悪くて仕様がありませんから。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ライバル企業を叩き潰すためには手段を選ばなかったＮＣＲは、独占禁止法の違反容疑をかけられて裁判に追い込まれ、ワトソン自身もこれに連座して一度は有罪判決を受けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大原は大根を手に取って力一杯に章魚を叩きおりしがお登和嬢｜振返りて思わず言葉をかけ「大原さん、それでは叩き潰すのです、叩くだけにして下さい」大原「ハイハイ畏りました」とお登和嬢に口を利かるるは小言にてもまた身に心地好し。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "先方が手出しをしやアがったら、相手になって叩き潰すがいい。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日籠つてゐた平次の神算鬼謀が、日本中の大泥棒の巣を、叩き潰す迄に運んで居たのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "その癖、腕前は拔群で、小田卷流を編み出して、近いうちに八間四面の道場を建て、江戸中の道場を一つ殘らず叩き潰す――と、口癖のやうに豪語して居りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "辻斬綺談",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にして見れば、味噌摺用人の一人や二人に腹を切らせるより、一萬二千石の大名を叩き潰す方が、どんなに溜飮が下がるかわからねえ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、私は剣士萩原朔太郎と市中の小ちゃい道場を叩き潰すために、何時も大酒を浴びて同行していた。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にしてみれば、味噌摺用人一人や二人に腹を切らせるより、一万二千石の大名を叩き潰す方が、どんなに溜飲が下がるかわからねえ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "その癖、腕前は抜群で、小田巻流を編み出して、近いうちに八間四面の道場を建て、江戸中の道場を一つ残らず叩き潰す――と、口癖のように豪語しておりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "辻斬綺談",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日籠っていた平次の神算鬼謀が、日本中の大泥棒の巣を、叩き潰すまでに運んでいたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺気満々たる長州の壮士連十余人の一団は、斎藤の道場を微塵に叩き潰す覚悟をきめてやって来たのだから、その権幕は、尋常の他流試合や、入門の希望者とは違う。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ムーンライト・ソナタ』でお月様の出を強調したり、『アパショナタ・ソナタ』で、ピアノを叩き潰すような感情の大荒れを見せられたり、そんな馬鹿げた芝居気の演奏に我々は馴らされて来たのである。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は謀反人ではない」「わしもそう思うだ」「詳しい事情は話せないが、いま天下の大乱にもなりかねないような、恐ろしい陰謀を企てている者がある、私たちは少ない人数で、その陰謀を未然に防ぎ、その計画を叩き潰すために奔走しているのだ」「わしにはむずかしい事はわからねえだ」　老人は云った。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊兵衛くらいの頭で組立てられた理論なら、それが正当であろうとなかろうと即座に叩き潰す自信があるのだ。",
              "citation": {
                "source": "夜明けの辻",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その木の皮を石でたたきつぶすと、いいにおいがしたので、おとなたちが、昼ねをしている昼さがりなど、三人で、まるできつつきのように、木のみきをコツコツとたたいていたりしました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がお母さんを攻撃するのは、実に悪い半面をたたきつぶすのが僕の愛された子としてのつとめだと思っているからです。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、お父さんはそれをたたきつぶすのだ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ではどうして、あの電臓をたたきつぶすのです」　別の機械人間がたずねた。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "匆々たたきつぶす必要のあるのはボスとボスのつくった盛り場の組織と、アンチャンの存在だ。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といって、右の掌に、力いっぱいいれて、ふいに、風船球をたたきつぶすと、さすがに、すきまなく張られているだけに、紙の球は、ひどい音とともに、さんざんに裂けて、掌の上に残ったのであります。",
              "citation": {
                "source": "おさくの話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらには九つの首をもったヒドラの首の根を熱した鉄棒で焼き落としてくれるイオラスのような味方がおらず、一つの首をたたきつぶすと、たちまち二つの首が生えてくるのである。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここで一言でも言ったら承知せんぞ、でなけりゃきさまを……たたきつぶすぞ！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして椋の樹の根もとにかがみ込み、石の上で虫の体をたたきつぶすと、中から器用な手つきでてぐす糸をひき抜く。",
              "citation": {
                "source": "南方郵信",
                "author": "中村地平",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつをたたきつぶすためだけでも、明智さんが帰ってこられるのを、ぼくは待ちかねていたんだ。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、こわすといっても、たたきつぶすのではなくて、まるで機械を分解するように、金具やレンズになるべく傷をつけないように、ときほごして行くのですから、なかなかめんどうな仕事で、一方の筒がバラバラになるまでには、三十分あまりもかかりました。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
