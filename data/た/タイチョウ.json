[
  {
    "uuid": "f561a7ac-3014-5119-b783-95d7f335d8ac",
    "entry": "体調",
    "reading": {
      "primary": "たいちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "physical condition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は体調がすぐれなかったので、厳しい秋風にさらされては大変と思っていたからなのだが、ホームズの方は難しい化学の研究といったものに没頭しており、それに取り組んでいるあいだはまったく他のことを忘れてしまうからだった。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "通常、それなりの精度で人を正しい年代に置けまして、もっとも通常というのは、病気や体調不良の場合はその人物が若くとも老年の手振りそっくりになるからで。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "周期的に落ち込んでしまう体調の深い穴にも、悩まされるようになりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その先に広がるのは混迷なのか、想像を超えた調和なのか」（『免疫の意味論』）　発病以来、繰り返しの長期入院や周期的に訪れる体調の悪化で、仕事はあまりできなくなりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "つらいことばかりのここ三年、どうにか書き続けてきたこの原稿を本にまとめる作業は、体調不良で遅れ遅れになっていた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "体調への不安はいつも頭の隅にあって、外出して動き回った後、大きな疲れが残らないですむと、いちいちほっとしていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどこのままの体調では、後書きを片づけられないのではないかとの思いもあり、再刊を優先する気持ちに傾きました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が身に起こる意識や体調の変化を楽しみ、どうにか完成にこぎ着けるだけの力を与えてくれたことを、向き合ってきたツールキットに感謝していました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "極東の島国の我が同胞は、すっかり体調を崩した紅毛碧眼の大男の苛立ち紛れに、箸の上げ下ろしから用の足し方まで一々難癖を付けられて、切歯扼腕の真最中である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "書きためてあったコラムをまとめるだけと高をくくっていた書籍化の作業は、体調の波に翻弄されて遅れ遅れとなった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その期間ソヴェトに関して出版されたものは、軍、外務省の情報機関を通じたものであり、構想敵の実体調査であった。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第九巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "体調が優れず、自宅療養と可能な限りの在宅勤務となるかも知れないと言う。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "キチガイ病気の正体調べて。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "体調に何を要求するのかね？",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体調子は同じだが、中国の大田鶏に較べて、日本の蝦蟇のほうが美味い。",
              "citation": {
                "source": "蝦蟇を食べた話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間身体の方は、依然として大体調子よく、副作用もほとんど見られなかった。",
              "citation": {
                "source": "ジストマ退治の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赴任する前に長官やら同僚の事など大体調べて、予備知識を得ておくのだが、それでも失敗して随分辛い思いをする事がある。",
              "citation": {
                "source": "妖影",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくこの子自身にとっては単なる疑惑に過ぎなかったのでしょう……ある日ブライアン・カルヴァートは体調を崩して部屋で寝ていました。",
              "citation": {
                "source": "長い部屋",
                "author": "O. H. ダンバー　O. H. Dunbar",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の体調だったら成功したかもしれない。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "――――――――　十一月四日――フランス人居住区で「死」にまつわる珍妙な講演を聞いたが、会場があまりに暑く体調があまりに悪かったので居眠りしてしまった。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "隼人は歩いて帰ろうかとも考えたが意気消沈していたのであまり体を動かす気力もなく、紀伊国屋の階段を降りて地下鉄に乗り、軽い頭痛を自覚しながら体調が不振なのは風邪でもこじらせたのだろうかといぶかった。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "発疹が起きるには体調があまりにも弱かったときには血液の嘔吐に続いて腸管の壊疽が起きる。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "気分や体調と関係なくやって来た。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふっくらと重厚さを見せたいちょうにゆった髪が彼女の容貌を異常に強烈に生気あらしめている。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
