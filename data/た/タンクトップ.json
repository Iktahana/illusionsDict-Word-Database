        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "履き込みの深い灰色のボトムに、タンクトップの裾を胸のふくらみのすぐ下で切り取ったような、おなじ灰色のトップだ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔と手を洗った彼は、服を脱いでタンクトップとショートパンツに着替えた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いタンクトップにハイキング用のカーキー色のショートパンツだ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いタンクトップにカーキー色のショートパンツ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「単なる冷房だけではないでしょう」「よくわかるね」「私のとこもそうなのよ」「タンクトップにショート・パンツ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い髪を背に垂らし、紫色のタンクトップに小花模様の長いスカートだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョギング・ショーツに、肩ひもの細い、紫色のタンクトップ、片手で髪をかきあげ、もういっぽうの手を、フェリーにむかって振っている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "タンクトップの胸のふくらみがいいし、ジョギング・ショーツからのびている脚が、すんなりと、しかも、力を秘めている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗せて」「その格好では、無理だ」　タンクトップにペラペラのジョギング・ショーツのミーヨを、ぼくは指さした。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
