[
  {
    "uuid": "7fc006c4-4977-564c-a7f2-2e3ac4f77b9e",
    "entry": "太祖",
    "reading": {
      "primary": "たいそ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
