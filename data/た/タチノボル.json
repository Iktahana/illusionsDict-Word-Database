        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「分らないものだ……」　近頃彼は口癖のやうに、長いこと坐つてゐて立ち上る時など、何時もさう口ずさむのだ。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言つて、父はペンを置いて立ち上る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお爺さんは苦笑して、もう立ち上る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は茶を呑みに来たんじゃねえんだ」　と言って立ち上る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとはもう大した奴は居ねえよ」　「そうかな」　と源兵衛、面白くなく立ち上る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次オヤッと立ち上る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝三次宅　三次ナニッと立ち上る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「仲蔵はきっと　五郎蔵がとっちめて　お見せします」　大吉、簡単に、Ｔ「お託せする」　と立ち上り、　半次も続いて立ち上る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉、進藤の刀持ってスックと立ち上る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲蔵は、拙者が　親分に頼んで　きっと無事に　舞台へ立たせてやる」　と言ってスックと立ち上る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　滅相なと徳兵衛「結構で御座ります」　なりひらが、Ｔ「後ほど屋敷へ持参致せ」　と言って立ち上る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝広間では　なりひらが悠々立ち上る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と「茶代を置くよ」と言い捨てて立ち上る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵、立ち上ると、傍の草叢の方へ行く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　コミックの女のように肩をゆすって彼女は立ち上ると、部屋の把手をあらあらしく廻した。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『入らつしやい…………』　まあさう云つたことで、壁際の支那風の椅子に腰かけてゐた三四人の若い女が立ち上る。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右の者があって、前進しだすと、始めて「前へ」の号令があったことに気づいて自分も立ち上る。",
              "citation": {
                "source": "戦争について",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「船頭が水に溺れる筈がねえ」　右門無言で立ち上る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬四郎も慌てて立ち上る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門伝六をうながして立ち上る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おふみが「あのね」Ｔ「どうぞ私の願いが叶いますようにッて」　アレッレッ、　と伝六驚いて、　さてはおふみちゃん、Ｔ「誰かに惚れたね」　「知らないわ」　伝六が、　「ハテ誰かな」Ｔ「誰に惚れたんだい」　「知らないッ」　おふみちゃん、ちょいと赧い顔して立ち上る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊吉怒って立ち上る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後三時か四時頃、私は仕事に一区切りをつけて立ち上る。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の空澄み渡って三里隔つる元越山の半腹からまっすぐに立ち上る一縷の青煙すら、ありありと目に浮かんで来る。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "女星は早くも詩人が庭より立ち上る煙を見つけ、今宵はことのほか寒く、天の河にも霜降りたれば、かの煙たつ庭に下りて、たき火かきたてて語りてんというに、男星ほほえみつ、相抱きて煙たどりて音もなく庭に下りぬ。",
              "citation": {
                "source": "星",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後には、血しほしたたる拳あげ、霞める街の大時計睨みつめたる山門の仁王の赤き幻想……その裏をちやるめらのゆく……四十一年十二月　　浴室水落つ、たたと………浴室の真白き湯壺大理石の苦悩に湯気ぞたちのぼる。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して誰が喫みさしたのか、眩ばゆい食卓の一角から軟らかな珈琲の吐息がたちのぼる。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "珈琲の煙はまだ消えもやらずにたちのぼる。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡て溶かして掻き廻す観相の余裕から初めてとりあつめた哀楽のかげひなたが軟かな思の吐息となつてたちのぼる。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "珈琲、珈琲、珈琲の煙はまだ冷めもやらずにたちのぼる。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
