        "examples": {
          "standard": [
            {
              "text": "「万葉集の相聞歌には、恋の苦しさを直接言わずに草木の名に託す『たとえ歌』が多い。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「文学のゼミで、古代歌謡における『たとえ歌』の比喩体系について発表した。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「『たとえ歌』の奥ゆかしさを理解するには、当時の自然観を知る必要がある。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
