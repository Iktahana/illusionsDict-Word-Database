          "literary": [
            {
              "text": "各社は二月から五月までの間に二十四回タブロイド版の新聞を発行した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その新聞もタブロイド版に縮小されてゐた。",
              "citation": {
                "source": "氷花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四部　読書欄　タブロイド八ページ　うち広告三ページ。",
              "citation": {
                "source": "アメリカの新聞",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "民間伝承の会は、初め六年程の間はタブロイド判十六頁ばかりの機関誌を出していた。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は冒険的なタブロイド紙が一紙、淑女の肖像画と称するものを掲載したが、誰もそんな陳腐な仕掛けに騙されなかった。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "タブロイド判ニュースを忙しいビジネスマンは読む。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
