        "examples": {
          "standard": [
            {
              "text": "私たちが普段呼吸している空気は、地表から高さ約10キロメートルまでの対流圏に含まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "対流圏では高度が上がるにつれて気温が低下し、雲や雨などの気象現象のほとんどがここで発生する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ジャンボジェット機は、揺れの少ない成層圏を飛ぶために、対流圏の上端付近まで上昇する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ジェット気流というのは、対流圏の上層部、非常に高いところにある気流である。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
