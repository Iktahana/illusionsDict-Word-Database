    "definitions": [
      {
        "index": 1,
        "gloss": "high-ranking noh actor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "著名な能の太夫が、その日の舞台で主役を演じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若手の役者は、いつか太夫と呼ばれる存在になりたいと語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "太夫の舞は、観客を魅了し、大きな拍手喝采を浴びた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「金銀は卑しきものとて手にも触れず、仮初にも物の直段を知らず、泣言を言はず、まことに公家大名の息女の如し」とは江戸の太夫の讃美であった。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　文楽の義太夫を聞きながら気のついたことは、あの太夫の声の音色が義太夫の太棹の三味線の音色とぴったり適合していることである、ピアノ伴奏では困るのである。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あるとも、一昨日なんか骨膜炎の手術を受けた老人がね、義太夫を唸り出す騷ぎだつたよ‥‥‥』と、水島は相變らず冷靜な顏附で云つた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本太夫、診て、出血あります。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "座が白けて、しばらく言葉が途絶えたうちに所在がないので、唄うたいの太夫、退屈をしたとみえて、顔の前の行燈を吸い込むような大欠伸をしたから。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが看板で、小屋の正面に、鼠の嫁入に担ぎそうな小さな駕籠の中に、くたりとなって、ふんふんと鼻息を荒くするごとに、その出額に蚯蚓のような横筋を畝らせながら、きょろきょろと、込合う群集を視めて控える……口上言がその出番に、「太夫いの、太夫いの。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、「京管領細川右京太夫政元は四十歳の比まで女人禁制にて、魔法飯綱の法愛宕の法を行ひ、さながら出家の如く、山伏の如し、或時は経を読み、陀羅尼をへんしければ、見る人身の毛もよだちける。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "辰さんは小声で義太夫を唸りながら、あらの始末をしている。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎芝居、菜の花畑に鏡立て、よしずで囲った楽屋の太夫に、十円の御祝儀、こころみに差し出せば、たちまち表の花道に墨くろぐろと貼り出されて曰く、一金壱千円也、書生様より。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたは、義太夫をおすきなの？",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして義太夫を習いに、女師匠のもとへ通ったのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、燕尾服を着た仁丹の鬚のある太夫が、お客に彼女のあらましの來歴を告げて、それから、ケルリ、ケルリ、と檻に向つて二聲叫び、右手のむちを小粹に振つた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太夫に嫉妬を感じたのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伴奏は太夫のむちの音であつた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太夫は、おのが身をまもるため、ピストルをポケツトに忍ばせてゐた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、燕尾服を着た仁丹の鬚のある太夫が、お客に彼女のあらましの来歴を告げて、それから、ケルリ、ケルリ、と檻に向って二声叫び、右手のむちを小粋に振った。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伴奏は太夫のむちの音であった。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太夫は、おのが身をまもるため、ピストルをポケットに忍ばせていた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃島の若いものと一しょに稽古をしている義太夫。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "小栗判官、頼光の大江山鬼退治、阿波の鳴戸、三荘太夫の鋸引き、そういったようなものの陰惨にグロテスクな映画がおびえた空想の闇に浮き上がり、しゃがれ声をふりしぼるからくり師の歌がカンテラのすすとともに乱れ合っていたころの話である。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台の右端から流れだす義太夫音楽の呼気がかからなければ決してあれだけの効果を生ずることはできないのはもちろんである。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "百年の後には「金色夜叉」でも「不如帰」でもやはり古典になってしまうであろう、義太夫音楽でも時とともに少しずつその形式を進化させて行けば「モロッコ」や「街の灯」の浄瑠璃化も必ずしも不可能ではないであろう。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしておかないと、またゆうべのように、口を出されて、お話が聞けなくなってしまいますからね。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さまは二人に頬ずりをして、またゆうべのやうな、おいしい果物を分けて食べさせました。",
              "citation": {
                "source": "星の女",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹き分けられるように、敵陣の一角が乱れたところを、猩々緋の武者は鎗をつけたかと思うと、早くも三、四人の端武者を、突き伏せて、またゆうゆうと味方の陣へ引き返した。",
              "citation": {
                "source": "形",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前、えらいぼろい事したゆうやないか。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜行ったら八橋がまたゆうべの身請け話をくりかえすかも知れない。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたゆうべ随分酔つてゐらしたわね。",
              "citation": {
                "source": "砂浜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あなたゆうべ云つたこと、アレほんとなの。",
              "citation": {
                "source": "砂浜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが五体ともに、またゆうべと同じ松、同じ枝につるしてあったというのは、さらに奇怪です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "head of a school of noh performance",
        "register": "standard",
