[
  {
    "uuid": "c996d0b0-2650-509f-bf7a-fad135c91df9",
    "entry": "塔頭",
    "reading": {
      "primary": "たっちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
