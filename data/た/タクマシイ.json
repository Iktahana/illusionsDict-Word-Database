        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は知性の人でなくして感性の人であり、江戸ツ子的神経の都会人でなくして、粗野に逞しい精神をもつた自然人であり、不断に燃焼するパツシヨンによつて、主観の強い意志に生きてる行動人である。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれでゐて何か或る頑丈な逞しい姿勢の影に、微かな虫声に似た優しいセンチメントを感じさせる。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「粗野で逞しいポーズ」と、そのポーズの背後に潜んでゐる「優しくいぢらしいセンチメント」とは、彼のあらゆる小説と詩文学とに本質してゐるものなのである。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "中景の右の方は樫か何かの森で、灰色をした逞しい大きな幹はスクスクと立ち並んで次第に暗い奥の方へつづく。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この花を、山家の少女の衣模様に染めたらば、などと思いながら、森を出て、河原に下り、太い逞しい樹の蔭に立った。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、秋山も小林も、決して、その逞しい足を動かし、その手を延ばそうとはしなかった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが何人がこの女神の逞しい火の性、徹る氷の性に、また氷火相闘つ矛盾の性に承け応えられるものがあったろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この薑、口｜疼く　男は、叫ぶと猛然、女の代りに鹿に飛びかかって、毛深く逞しい拳を振り上げて、丁々と撃った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はこの頃の興奮と思い悩みに、いたく痩せ衰え、逞しい胸で息せき切っている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "逞しい忍耐を以て、この歪んだポーズに堪え、根気よく真に魅力ある理想を探って行き度い。",
              "citation": {
                "source": "時代色",
                "author": "――歪んだポーズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "門の鉄扉の外側に子守が二、三人立って門内の露人の幼児と何か言葉のやりとりをしていると、玄関から逞しいロシア婦人が出て来て、逞しいむき出しの腕でその幼児を軽々と引っかかえて引込んで行った。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある意味では野蛮でブルータルであると同時に一方ではまた新鮮で明朗で逞しい美しさがないとは云われない。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学へはいる頃は、人が振り返るほど美しく逞しい少年になった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "船員の腕にふさわしい逞しい健康そうな女だった。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "城の崖からは太い逞しい喬木や古い椿が緑の衝立を作っていて、井戸はその蔭に坐っていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青で蘆毛、裸馬で逞しいが、鬣の薄い牡じゃわい。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体に逞しい骨骼で顔はいつも銅のように光っている。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……アッ……という間もなく立ち上りかけた青年の上に八ツの逞しい手が折重なって、グルグル巻に縛り上げられた……と思う間もなく夜具の上にコロコロと蹴返された。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿野郎……アッ、新張の奥さん……どうもありがとう御座いました」　そういってペコペコ頭を下げながら前に進み出たのは、四人の中でも一番｜年層らしい、色の黒い、逞しい鬚男であった。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれで算盤弾くかと思われる筋骨逞しい立派な若侍じゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "青黒く逞しい四十恰好の堂々たる武士である。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "年輩四十｜幾干、骨格の逞しい、頭髪の長生た、四角な顔、鋭い眼、大なる鼻、一見一癖あるべき人物で、其風俗は官吏に非ず職人にあらず、百姓にあらず、商人にあらず、実に北海道にして始めて見るべき種類の者らしい、則ち何れの未開地にも必ず先づ最も跋扈する山師らしい。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "みるみる身体が熱くなって今迄に覚えない逞しい生気が脊髄を突き上げて来た。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という太く逞しい自分の悪血の迸りだ。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花のあかみには、ごまのような、跳ねた粒子形のかたまりのような逞しい蝶が、花に打突かる獰猛さで飛んで来ては、また何処かへ行った。",
              "citation": {
                "source": "真夏の幻覚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "是非とも私たちは逞しい持ち前の心を奮い起し、誤解に却ってお礼を言うようになりましょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して、これらの親譲りの便宜なき者が、強い意志を以て四方へ因縁を植え弘めて行く努力は、よき運命への力強き、確実な行歩であって、逞しい精神力の持主である日本民族の最も得意とするところであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに宇宙を一肉体とすれば、その中に籠められていて、宇宙を無限無窮に健かならしめて行く絶対に逞しい魂です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いにしてわが民族精神には、生に対する逞しい健康な気力がもとより備わっており、虚を去って実を採る、真実の理想家の風格があるので、進んでこの大乗の真理を歓迎し文化発展の動力に使ったのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たくましい、一流の作家精神である。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
