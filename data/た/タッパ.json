    "definitions": [
      {
        "index": 1,
        "gloss": "height (of a building, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただ立端が無いまで困じきって、御余裕のある御挨拶を得たさの余りに申しました。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "男も立端を失ったように、一度しまいかかった袂落しの煙草入れを又あけて、細い銀煙管から薄いけむりを吹かせていたが、その吸い殻をぽんと叩くのをきっかけに、今度は思い切って起ちあがった。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいにく相手が戻って来たので、二人も立端をうしなってしまった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりかたっぱしから喧嘩して通るのである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "清作はもうとびだしてみんなかたっぱしからぶんなぐってやりたくてむずむずしましたが、画かきがちゃんと前へ立ちふさがっていますので、どうしても出られませんでした。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗水たらして一日働いても、今日今日をやっと過ごしているだけだが、おれたちはかたわなばかりで、なんにもしないで遊びながら、町の人たちがつくり上げたお金をかたっぱしからまき上げることができる。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又どっかりと椅子へかけようとしましたが何か考えついたらしく、いきなりキーキーいびきをかいているあまがえるの方へ進んで行って、かたっぱしからみんなの財布を引っぱり出して中を改めました。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "コウノトリのおとうさんは、毎日毎日、おいしいカエルや、小さなヘビや、そのほか、見つけることのできたごちそうを、かたっぱしから持ってきてくれました。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの国をも、かたっぱしから、せいふくしていきました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえとわかれて、たちどころに私は、チョッキのボタンを全部、むしり取ってしまって、それから煙草の吸殻を、かたっぱしから、ぽんぽんコーヒー茶碗にほうりこんでやった。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてにしていた夢が、かたっぱしから全部はずれて、大穴あけて、あの悽惨、焦躁、私はそれを知っている。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらの軍勢はそいつらの逃げ道をくいとめて、かたっぱしからどんどん切り殺してしまいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛脚はかたっぱしから狼の頭を斬った。",
              "citation": {
                "source": "鍛冶の母",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常な無神論者で、鬼神変化幽冥果報というようなことを口にする者があると、かたっぱしから折破して、決して神霊の存在を許さなかった。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに学問が博くてしたっぱな人間でないということが解った。",
              "citation": {
                "source": "胡氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、おばあさんは、庭へ出て、そこのばらの木にむかって、かたっぱしから撞木杖をあてました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物や包みはかたっぱしからあけてみました。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくまでも色ざんまいのうえの毒殺とにらんで、このうえともにその点へ見込み捜査をつづけていくならば、もっと方面をひろめてかたっぱし出入りの女を当たってみる必要があるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "一状、一封、一枚、一枚、と箱いっぱいに投げ込まれてある訴え状をかたっぱしから丹念に見調べだしたので、鳴り屋の千鳴り太鼓が、ここをせんどとがらがらやりだしたのは当然でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "事のついでにと思って、一真寺のお残り地蔵のほうも、六人ともにかたっぱし施主の身がらを洗ってみたんだがね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではというので、ただちにもよりの自身番からかたっぱし当たってまいりましたが、しかし、どこの番所でも、答えたことばは、ただ次のごときあっさりとした一語のみでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "三百十八大名をかたっぱし洗って、西条流半弓のお手きき殿さまをかぎつけることにしてからが、同心や岡ッ引きじゃ手が出ねえんだからな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "わからなきゃ、江戸じゅうのくろうと将棋さしをかたっぱし洗って、どいつの持ち物だか調べるんだ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　わからない場合には、江戸じゅうの将棋さしをかたっぱし洗えといったんですから、伝六がめんくらったのも、無理もないでしょう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "野郎ども、だんなのおっしゃるとおり、手を引きな」　だんだら団兵衛とは名のるにもおこがましいような名まえだが、とにかくひざの下のやつも一人まえの親分とみえて、しかりつけたところを、得意の伝六がかたっぱしから数珠つなぎ――。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "青二は、すきな歌を、かたっぱしから口笛で吹いて、いい気持で歩いていった。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、こうなればだれでもむかってこい」　高一は、せめてくる敵兵めがけて電気鳩をとびかからせ、かたっぱしからたおします。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ブルジョア、地主の悪法「治安維持法」というものは、それをキッカケに階級的に目ざめた大衆をかたっぱしから投獄するよう、わざわざ制定されてあるものです。",
              "citation": {
                "source": "ますます確りやりましょう",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわばその眼は見開かれたっぱなしで、やがて太古エジプトの護符の「眼」のように呪文的にもち扱われた。",
              "citation": {
                "source": "作家の経験",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の主情的な文学伝統にとっては、よその言葉のような言葉で提出されたっぱなしであった。",
              "citation": {
                "source": "作家の経験",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
