[
  {
    "uuid": "24d18395-6bd4-5b90-bce0-1c62b34f0ddc",
    "entry": "太傅",
    "reading": {
      "primary": "たいふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
