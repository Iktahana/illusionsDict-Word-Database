        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしその鉄拵えの刀や身なり一体が歳にしてはひどくジミで、とりなしなども手堅く、普通の旅歩きの博徒とは少し違う。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし悲しい荷物を背負って旅歩きしている人のように、浅い眠りより外は眠ったことのない彼には、未だに夢のなかに取残されているように感じられた。",
              "citation": {
                "source": "あめんちあ",
                "author": "富ノ沢麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座の旅歩きにも、不知哉丸は、田楽仲間の手や背なかで、交わりばんこにあやされた。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
