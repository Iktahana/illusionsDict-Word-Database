[
  {
    "uuid": "74a18a85-ca2d-5579-81a0-c1cefc20b4c4",
    "entry": "胎盤",
    "reading": {
      "primary": "たいばん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
