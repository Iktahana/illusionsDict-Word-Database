        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "服装は赫い短靴を埃まみれにしてホームスパンを着ている時もあれば、少し古びた結城で着流しのときもある。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "海に沿った雪道を、私はゴム長靴で、小川君はきゅっきゅっと鳴る赤皮の短靴で、ぶらぶら歩きながら、「軍隊では、ずいぶん殴られましてね。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋常にぬげばすぐぬげる短靴が、ちよつと脱ぎ悪くさうにも見えた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "神さまは、ただ十文半の黄皮の短靴の左足は十文半の黄皮の短靴の右足こそ応わしけれ、と思し召すだけに違いない。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "白麻のハンチング、赤皮の短靴、口をきゅっと引きしめて颯爽と歩き出した。",
              "citation": {
                "source": "座興に非ず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼は怒り、額は愁ひ、短靴はやたらに急いだが、搾めつけられた胸は今やうやく緩んで来た。",
              "citation": {
                "source": "舌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "非番の老近侍は茶の上着を着て白と黒の縞のキッチリのズボン白い飾りのついた短靴をはいて飾りのついた剣をつるす。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴は短靴でしたのですぐぬぐことが出来たのです。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この名前そのものから、それが短靴に由来するものであることは明らかであるが、しかしいつ、いかなる時代に、どんなふうにして、その姓が短靴という言葉から出たものか――それは皆目わからない。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "また当時でも猶太人のみは靴下に短靴といふ軽装をしてゐたから、茲にもその意が含められてゐると見てよい。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂子と別れた後の苦しい放浪の日々、短靴を酔って溝に落し、ひとから貰ったボロ軍靴に、一枚の破れＹシャツしか残っていない私。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼ははでな仕立の背広服をつけ、チョコレート色の短靴、薄茶色のソフト帽、籐のステッキという、すきのない身装をしていた。",
              "citation": {
                "source": "楊先生",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "妖精の国の女王様から、薔薇色をした短靴が幾ダースも幾ダースも、註文がありました。",
              "citation": {
                "source": "虹猫と木精",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女王様は、こんどの宴会に、自分の御殿にゐるものには、みんなお揃ひで、薔薇色の短靴をはかせようと、思召したのです。",
              "citation": {
                "source": "虹猫と木精",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから形のくずれた黒の短靴を。",
              "citation": {
                "source": "地図にない街",
                "author": "橋本五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長椅子の前に、脱ぎ揃えられてあった一足の短靴がそれであった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし緑の服、長く逞しい二本の脚、肌色の長靴下に、若い婦人向きスポーツ好みの短靴――というところから想像されることもない猫女の人がらだった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてスポーツごのみの派手な短靴をはいていた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "スポーツごのみの短靴がはやると見える。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下に光る眼鏡、面長な白い顔、ペタルの上で、ブレーキを踏んでゐるチョコレート色の短靴。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはゴマ塩頭の薄いメリヤスシャツの上に夏背広をぢかに着こみ、巻ゲートルに短靴をはいた、初老に近い痩せ身の男だつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "パナマの帽子を被り、ネクタイピンを光らし、片手で窓際の鉄棒につかまり、片手を麻のズボンのポケットにつき込み、赤の短靴の先を鼻唄の調子でも取るような風に動かし、時々ふーっと酒臭い息を吐いてる、会社員風の中年の男だった。",
              "citation": {
                "source": "電車停留場",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はレースのついた上衣を着て、幅の広い帯に短剣をさし、羽根飾りのついた山高帽をかぶり、赤い長靴下をはき、踵の高い短靴にはばらの花かざりをつけていた。",
              "citation": {
                "source": "リップ・ヴァン・ウィンクル",
                "author": "ディードリッヒ・ニッカボッカーの遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に、ニンフ達は、踵に一対の可愛い小さな翼のついた短靴みたいな、スリッパみたな、草鞋みたいな物を取り出しました。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いかにもおれの親父はどん百姓だったが、おれはというと、この通り白いチョッキを着て、茶色い短靴なんかはいている。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "上はワイシャツの色に合わせて選んだネクタイから、下は黄色い短靴に至るまで、彼はことごとく自分の伊達好みな服装に満足なのである。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、満洲の泥道を想い出しながら、短靴を靴下まで泥にして、山裾の村へ入って行った。",
              "citation": {
                "source": "飢餓地帯を歩く",
                "author": "――東北農村惨状報告書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ずいぶん寒いですね」　事実、私の短靴の中の足も雪水に濡れて、ちぎれそうだったのだ。",
              "citation": {
                "source": "飢餓地帯を歩く",
                "author": "――東北農村惨状報告書――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
