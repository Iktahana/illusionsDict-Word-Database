    "definitions": [
      {
        "index": 1,
        "gloss": "improvement of labor conditions (labour)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "清川や熱田などが臨時工のなかに持っている影響を切り離すために、みんなで「労働強化反対」とか「賃銀値上げ」とか「待遇改善」などを僚友会に持ち込ませる。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日一日と騰貴する物価に、決して追いつくことのない待遇改善の実情は、妻であり母である女性の辛苦を言語に絶した状態においています。",
              "citation": {
                "source": "国際民婦連へのメッセージ",
                "author": "――「女性を守る会」から――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら、待遇改善しても、月給は物価に追いつく時は決してない。",
              "citation": {
                "source": "合図の旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、国鉄の従業員が、生計費の値上りに耐えかねて待遇改善の要求をした。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋田文相が、まず小学校教員の待遇改善の問題をとりあげているのも、このことを語っているのだろう。",
              "citation": {
                "source": "私の感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働組合や、すべての民主勢力が要求している賃金、待遇改善の問題、家事の社会化の実現などは、婦人の二十四時間の内容を男の二十四時間の内容と、おのずからのちがいはありながらも、その社会的質の高さでは等しくしてゆくために、絶対に必要な前提条件である。",
              "citation": {
                "source": "女性の歴史",
                "author": "――文学にそって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働基準法では少年の労働について保護的な規定をもうけているし、労働組合が青少年婦人の待遇改善を要求している。",
              "citation": {
                "source": "女性の歴史",
                "author": "――文学にそって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働組合というものは、働く人の生活の全面にわたる幸福を、たかめるためにあるのですから、待遇改善の要求ばかり出すだけでなく、文化部の仕事としては面白い芝居を団体で見たり、良い映画をもって来たり、自分達の仲間で音楽会を開いたり、雑誌を出したりしてゆきましょう。",
              "citation": {
                "source": "若人の要求",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四六年から四七年の二月に至るまでの時期、日本全国に待遇改善、賃金値上げ、職場の民主化等を主眼とする労働争議が続発した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文部省の「民主化計画」はこのようにして進められていたが、一方に教師の生活難から引き起こされた待遇改善の要求運動は四六年秋から次第にたかまってきた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "待遇改善要求の期間を通じて田中文相の演じた役割は非常に不成功であった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めて当然な賃銀値上げ、待遇改善を要求しても直ぐ警察だ。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はあと二年間無配當で我慢してくれゝば、その後は八分の配當を保證してもいいと云つてるんだが……」　彼は無理にうはべ丈の利益勘定を捻出して蛸配當をする事は、結局何時迄も會社の状態を不安ならしめるものだといふ事と、例によつて職工の待遇改善の急を説いて止まなかつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "要は教育改革第一、先生の待遇改善問題第二なり。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は緑鬼どもと強い押問答をやって、待遇改善をはかっています。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "患者の方はコンニャクのほかにもその他何々の待遇改善要求があったのだが、コンニャクはカルシューム也という一撃によって全的に闘志を失い、もろくも敗北したという戦史があるのである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち三倍の成績をあげているのでありまして、待遇改善から自然にこの好成績がもたらされたのだと私は確信するのであります。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働法が出来たけれども、国鉄従業員が尤もな待遇改善を求めると、当局はそれを拒むことの出来ない代りに、忽ち、運賃値上げをして、人民の負担に転化する。",
              "citation": {
                "source": "現実の必要",
                "author": "――総選挙に際して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの職場に働く勤労者、一般市民が、待遇改善に成功する他の職場の勤労者に対して、心からの同感や協力を感じないように、何となし迷惑めいた気をもつように、扱われている。",
              "citation": {
                "source": "現実の必要",
                "author": "――総選挙に際して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の男の写経机をとりかこんで、わいわい言いながら、各自が思いつきの箇条を「待遇改善の要求書」として練ったのだった。",
              "citation": {
                "source": "美しい日本の歴史",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の官立写経所の筆業生や装※師たちが、官の支給に不平を鳴らして、食事、衣服、休暇などの待遇改善を要求すべく、その文案を大勢で首をあつめて協議したその下書きがこれなのだ。",
              "citation": {
                "source": "正倉院展を観る",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
