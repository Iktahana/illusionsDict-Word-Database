[
  {
    "uuid": "4d41c279-a619-53a7-9411-ec68d9846d37",
    "entry": "祟る",
    "reading": {
      "primary": "たたる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
