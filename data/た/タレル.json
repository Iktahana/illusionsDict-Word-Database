    "definitions": [
      {
        "index": 1,
        "gloss": "to hang",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このたびは霧がなかった、紫の花咲くクカイ草、蘭に似た黄色の花を垂れるミヤマオダマキが、肉皮脱落して白く立っている樅の木を、遠く見て、路傍にしなやかに俯向いている、熊笹が路には多い。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "サルオガセの垂れる針葉樹の間からも、同じように起る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "根曲り竹も、楊の根も、樅の肌も、はた長くしな垂れるサルオガセも、その柔嫩の手に、一旦は、撫でられぬものはない。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は殆んど白痴に近い感覚の最も発作の静まつた時にすら、その指さきからきぬいとのやうなものの垂れるのを感じる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フラフラと立ち上って、足許定まらず壁に凭れて項垂れる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸でも触ると、其のまゝ、いきなり、白い肩を包むで、頬から衣絵さんの血を吸ひさうである、と思つたばかりでも、あゝ、滴々血が垂れる。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際無類絶好の奇宝であり、そして一見した者と一見もせぬ者とに論なく、衆口嘖※としていい伝え聞伝えて羨涎を垂れるところのものであった。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言ひ／＼、がく／＼と項を掉つて首を垂れる。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自慢じゃないが、高原越えだけで普道の人間ならば凹垂れるところである。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑い暑いと凹垂れるごときは意気地無しの骨頂じゃ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこんな事に凹垂れる吾輩でない、などと先頭に立っているので大いに得意になり、津川子と共にエイヤエイヤの掛声を揚げて攀登る。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "慈悲を垂れると附上ってなりません。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "開いて垂れると、舌を出したやうに見えて、風呂敷包が甘澁くニヤリと笑つた。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（霞のような小川の波に、常夏の影がさして、遠くに……（細道）が聞える処へ、手毬が浮いて……三年五年、旅から旅を歩行いたが、またこんな嬉しい里は見ない、）　と、ずぶ濡の衣を垂れる雫さえ、身体から玉がこぼれでもするほどに若え方は喜ばっしゃる。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "故郷を捨てて東京に走り、その職業的有利さから東京に定住している作家、批評家が、両三日地方に出かけて、地方人に地方文学論に就て教えを垂れるという図は、ざらに見うけられたが、まず、色の黒い者に色の黒さを自覚させるために、わざわざ色白が狩り出されるようなもので、御苦労千万である。",
              "citation": {
                "source": "東京文壇に与う",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと強く抱いて、と息をつめて哀願するところもよかったし、あたしは、だめだわと言って、がくりと項垂れるところなど、実に乙女の感じが出ていました。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際無類絶好の奇宝で有り、そして一見した者と一見もせぬ者とに論無く、衆口｜嘖※として云伝へ聞伝へて羨涎を垂れるところのものであつた。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、捻向いて、くなくなと首を垂れると、摺った後褄を、あの真黒な嘴で、ぐい、と啣えて上げた、と思え。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "腐れた肺が呼吸に鳴るのか――ぐしょ濡れで裾から雫が垂れるから、骨を絞る響であろう――傘の古骨が風に軋むように、啾々と不気味に聞こえる。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは一寸白くなった皮膚のおもてが、次第に桃色を帯びてきて、到頭プツリと真赤な血の粒が一点から盛上ると、見る見るそれが大きくなり、やがて糸をひいて、ぽとりと土の上に垂れるのであった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊におほけたでの紅花のふさふさと垂れるのは頗る食慾をそそるのであつた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに若茶柳から松葉納戸・明石鼠に至るまでのさまざまの色をした葉が乱れ垂れるのである。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……不思議というは、青い腰も血の胸も、死骸はすっくり俎の上へ納って、首だけが土間へがっくりと垂れる。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども梢の枝から四方八面に吹き垂れる若葉のしたゝりは嫋々と風にもつれ簾の雨となって、さすが巨岳の赤城の山も水浅黄色に降り埋むばかりであります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛りの頃は地にまで咲き垂れるという粕壁名物の藤の花は、いま指尖で襷を摘んで垂らしたほどの花房でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この弱点を救うには、髪の毛を耳のあたりまで房々と垂れるより仕方がない。",
              "citation": {
                "source": "髪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "望んであまりに遼遠なるが故に、深く頭を垂れるのである。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ頭を深く垂れるのみである。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "春、淡黄色の花房を垂れる。",
              "citation": {
                "source": "風隠集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今思へば涙が垂れる。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            }
          ]
        }
