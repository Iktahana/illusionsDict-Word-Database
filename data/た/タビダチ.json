    "definitions": [
      {
        "index": 1,
        "gloss": "setting off (on a trip)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "麥萩原朔太郎麥はさ青に延び行けり遠き畑の田作りの白き襦袢にえんえんと眞晝の光ふりそそぐ九月はじめの旅立ちに汽車の窓より眺むれば麥の青きに驚きて疲れし心が泣き出せり",
              "citation": {
                "source": "麥",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の七日の旅立ちとでも決まれば、我亦何をか言わンやである。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｔ　数日の後――Ｓ＝村はずれの街道　庄屋や六助お絹の若夫婦や、　其他村人達に送られて、　武蔵と団九郎が旅立ちであります。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日こそはたしかに旅立ちの日でした。",
              "citation": {
                "source": "いてふの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "知名の人の旅立ちでも、新聞があるために妙な見送り人が増して停留場が混雑する。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝ごとに河面は霧が濃くなってうす寒くさえ思われる時節となりましたので、気の早い一人の燕がもう帰ろうと言いだすと、他のもそうだと言うのでそろそろ南に向かって旅立ちを始めました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕はこのわかいりりしい王子の肩に羽をすくめてうす寒い一夜を過ごし、翌日町中をつつむ霧がやや晴れて朝日がうらうらと東に登ろうとするころ旅立ちの用意をしていますと、どこかで「燕、燕」と自分をよぶ声がします。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日も王子は燕の旅立ちをきのどくだがとお引き留めになっておっしゃるには、「今日は北の方に行ってもらいたい。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは急におんつぁんが九州に旅立ち、その旅先きから又世界のどのはづれに行くかも知れないやうな事件が起つたからだ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会的施設の知識についても、警察制度の発達や、交通機関の発達のため、追剥ぎ、辻斬り、水盃をして旅立ち等の悲惨事は絶無になりましたが、他方に失業問題や、階級闘争問題が起りまして、文化の余弊と言われております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "力無く生甲斐無く、漣や滋賀県に佗年月を過すうち、聞く東京に倉瀬とて、弱きを助くる探偵ありと、雲間に高きお姓名の、雁の便に聞ゆるにぞ、さらば助を乞い申して、下枝等を救わむと、行李そこそこかの地を旅立ち、一昨日この地に着きましたが、暑気に中りて昨日一日、旅店に病みて枕もあがらず。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "右に就て当局のその後の調べに依ると同未亡人を甥の妻木という青年と一緒にその旅立ちの前夜に殺害して大金を奪って去ったものは九段高林家の後嗣で旧名音丸久弥といった屈強の青年であることがわかった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と巨男はいって、やはり白鳥をつれ、南の方へ旅立ちました。",
              "citation": {
                "source": "巨男の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、巨男はふたたび南方へ旅立ちました。",
              "citation": {
                "source": "巨男の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "早うこの首うって三井寺へ駆けつけさっしゃれ』（片膝つき右の手で頸を叩く）源右衛門（深い思入れ）『それじゃ、そなたは何もかも、承知の上での旅立ちか』源兵衛『きのう一同会所で相談。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを済ますと親子の旅立ち、行先を訊いてもただ遠いところとばかり。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ととさんと一緒に旅立ちの様子がおかしいと、直ぐそのあとでかかさんを攻め詰って漸よう訊いた事の仔細。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、奈良街道からでは、途中でいざりやめくらに会うし、大阪口から行っても、やはりめくらやいざりに会うので、どちらとも旅立ちには不吉である、脇道の紀井街道をとおって行けば、必ずさい先がよいと、こう占いに出ました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅立ちの事にはいたく心を悩ますとも見えず。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "お妻は女の身で、他家へいったん縁付いてしまえば、めったに旅立ちなどは出来ないのであるから、今度の見物には姉のお妻を連れて行くことにして、ほかに文次郎という若い者が附添って、おとといの朝早く田町の店を出た。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌る朝早く、父上は吾が身の行末を頼む由仰せ残されて四国へ旅立ち給ひぬとて、ひたすらに打泣く妾をいたはり止めつ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "學校、えせ詩人、露肆　フランチエスカの君は夫に隨ひて旅立ち給ひぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "防州でクマオに向って旅立ちすると知って出たら殺され知らずに出たら怪我するとてその日を避ける。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "同年の三月、堀井新治郎は印刷機事情を学ぶためにアメリカに旅立ちました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちわたくしが大ぶ大きくなったので、姉とわたくしとを連れて、父を尋ねに旅立ちました。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨勢君にはかしこなる画堂にて逢ひ、それより交を結びて、こたび巨勢君、ここなる美術学校に、しばし足を駐めむとて、旅立ち玉ふをり、われも倶にかへり路に上りぬ。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃はみな月半ばなれど、旅立ちし諸生多く、隣に人もあらず、業妨ぐべき憂なきを喜びぬ。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "御面師と共に旅立ちたいものよ。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたは旅立ちよしという日と聞いているから、大抵の雨ならば思い切って発つつもりで、親方も兄弟子たちも八軒屋まで送ってやると言うていた」「ほんに長い旅でござんすから、暦のよい日をえらむのが肝腎。",
              "citation": {
                "source": "心中浪華の春雨",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
