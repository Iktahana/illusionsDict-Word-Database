    "definitions": [
      {
        "index": 1,
        "gloss": "insufficient",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――此の場合では素養も足りないが、熱意はもつと足りないと云へるのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「緊張の足りないところもあるだろうねえ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり思念だけでは足りない、思念と物質とが一緒になつて働いてゐるところとか、その結果を見覚えるとかすることが勘甚なのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを学ばないに拘らず、思念だけでは足りない、何かしら芸術は道具を要するものであるから、作品が読まれなければならぬ。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため非難するものは、蕪村の句が絵画的描写に走って、芭蕉のような渋い心境の幽玄さがなく、味が薄く食い足りないと言うのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも土民狩と言つて人民を小鳥か何かのやうに取扱ひ弓等で射殺し、今日は獲物が不足だつたとか、多かつたとかで喜んで居たりしたことは鬼と言つてもまだ言ひ足りない気がする位である。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかくとして最近に私の少数な十に足りない同窓の中で三人まで、わずかの期間に相次いで亡くなった。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程あのガラ／＼の音ぐらゐでは三百六十五日浚つて見たところで梓川がたゞの一ト雨に押し流してくる砂泥をすくひ上げるにも足りないのではないかといふ気がするのであつた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどあのガラガラの音ぐらいでは三百六十五日浚ってみたところで梓川がただの一と雨に押し流してくる砂泥をすくい上げるにも足りないのではないかという気がするのであった。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "想像だけでは物足りない、確かな事実を捕えたいというのが学者の願である。",
              "citation": {
                "source": "天河と星の数",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦揺れの方は今日では別にこれを防ぐ工夫がないようで、物足りないが仕方がない。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが父の祖神の翁には物足りないものがあった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "種族の血を享けてか、情熱と肉体の逞しさだけあって、智慧は足りない方だった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれにはどういふわけで自分に着物が斯う足りないのかどう考へても判らなくてひどく悲しかった。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもはははあ、あの男はやっぱりどこか足りないな、だから子供らが鬼のようにこわがっているのだと思って遠くから笑って見ていました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の十場面は脚本で読ませておいて大切り一場面だけ見せてもいいかもしれない、とも考えられるが、それでは登場人物が劇中人物に成り切るだけの時間が足りないであろう。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから「いろは」四十七では足りないといわなければなりませぬ。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "足りないではありますけれども、しかし「いろは」四十七文字が大体において現代の音の区別を或る程度まで代表していると言うことが出来ます。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかといって「いろは」では少し足りない。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども現代の日本語は、音としては「いろは」にある音だけでは足りないのであって、「いろは」を色々に組合せて書いているのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれを読んだ時に何だか物足りないような気がした。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしなくてはやっぱり物足りない。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八時間労働としても二日では少し足りない。",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけに肩も凝らないがまたどっちもつかずで物足りない気もする。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕上げの足りないという事やじじむさいという事は自分の要求するような意味の創作というものにはあるいはむしろ避くべからざる附き物ではないかと思う。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏はいつでも頭で絵を描いているのを多とするが、しかし頭と心臓と両方が出ないとどこか物足りない。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイヨオルのものの見えないのが物足りない。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸体も美しいが、ずっと遠く離れて見ると、どこかしら、少し物足りない寂しいところがあるように感ずる。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵でも人間でも一と目で先ず引き付けられないようなものにはやはり何か足りないものがあるかと思う。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金が、たりないことにも、気がかゝった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
