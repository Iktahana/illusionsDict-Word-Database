  {
    "uuid": "286bfb72-9a7e-532a-b2a0-a83bb98fe31c",
    "entry": "唯でさえ",
    "reading": {
      "primary": "ただでさえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
