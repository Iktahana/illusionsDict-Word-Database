        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "事務長ガ無電ヲ神戸港ノ司令部ニ打ツ　兵来リテ汽車ニテ○○へ急グ　航行中ノ運送船ヨリ縄梯子ヲ降シ、モーターボートヨリ兵乗リウツル。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸の岩の上には見事なモーターボートを納めた倉庫まで出来た。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい景色じゃないの……明日は早く起きてモーターボートで島めぐりをしてみない」「……ウウン……凪いでいたら行ってみよう」「……だけどコンナ村に住んでいる人間は可愛想なものね。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "村中を駈けずって仲間を呼び出してまわったが、その仲間の四五人が、冷酒の勢いに乗じて別荘に押しかけた時分には、若旦那夫婦と女中二人を乗せたモーターボートが、大凪の沖合はるかに、音も聞こえない処に辷っていたのであった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東京を出てからもう二年目の秋だな」　復一は、鏡のように凪いだ夕暮前の湖面を見渡しながら、モーターボートの纜を解いた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モーターボートで湖を一周しようといふのである。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "右隣はモーターボートに学生風の男ばかり乗り、ビールを飲みながら近所の船の女を品藻してわい／＼騒いでいます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンキの剥げたモーターボートなぞ誰も借りに来る客はありません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでふだんガソリンの用意なぞはなくガソリンを自分で持って来た客だけにモーターボートを貸すことにしています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし久振りに貸手のあったモーターボートは今だに帰って来ません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "河岸に繋いであるモーターボートを見ると、急に思い立ったものと見え、運転手に町のスタンドからガソリンを買わして来てまでして、ボートを借りて出船して行きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秀はさっきから二三度も土手を越し家と桟橋との間を往復して帰り舟を待ったのですが、とう／＼モーターボートの客は帰って来ません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秀はふと、ゆうべ到頭帰って来なかったモーターボートを思い出したらしく、ゆうべの乗船客の身元控帳を調べ始めます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやっと思って見ますと、昨日のモーターボートが帰って来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは、また、この運転手が昨日旦那とその第二夫人をお秀の船宿まで車で送りつけ、その旦那と女はお秀のとこのモーターボートに乗って無断で横浜の磯子まで海を渡って泊り、ボートを返しには磯子の旅館の男が来たことを啓司に語りました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一軒一軒飾窓を覗きまわったので疲れ、ひきかえして戎橋の上で佇んでいると、橋の下を水上警察のモーターボートが走って行った。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、家内の父親の持つてゐるモーターボウトを借り、チグリス河をさかのぼつてバスラといふ町へつきました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウルターは十二時少しまへに、モーターボウトに乗りこんで、船首を河下へ向け、かぢをにぎつて、まちかまへてゐました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その異やうななりをした彼は、河岸につないだぼろけたモーターボウトの破損箇所へ、いかけをしてゐました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを電気炊飯器と言い張るには、たらいの底に扇風機をくっつけてモーターボートと称して売り付けるくらいの心臓が必要だったろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、お父上と琵琶湖でモーターボートに乗り、私が水に飛び込み、藻に棲む小魚が私の脚にあたり、湖の底に、私の脚の影がくっきりと写っていて、そうしてうごいている、そのさまが前後と何の聯関も無く、ふっと胸に浮んで、消えた。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "客も無からうにモーターボートの渡舟が岸に待つてゐた。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "真青な上に白い波を立てて走っている一二のモーターボートも親しい思いをそそった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の庭から、モーターボートのための小さな桟橋が湖の中へ設けられてあった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで飛ぶようにして一隻のモーターボートを傭い、そのレマン号へ乗りつけたのだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると一｜艘のモーターボートが、ポクン、ポクン、ポクンと言いながら、帽子の方へ走出しました。",
              "citation": {
                "source": "都の眼",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯を消して蝟集しているモーターボートの首を連ねて、鎖で縛られた桟橋の黒い足が並んでいた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
