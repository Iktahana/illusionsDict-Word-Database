    "definitions": [
      {
        "index": 1,
        "gloss": "great folly or fool",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どうせ、批評家に言わせると、大愚作なのだろうが、私は前後不覚に泣いたのである。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、慧鶴は在家の法事によばれて行き、役目をしまったあと、その家の珍蔵の大愚和尚の書軸を見せられた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればこそ、七偏人は百物語を催ほして大愚大人を脅かさんと巧み、和合人の土場六先生はヅーフラ（註：オランダ渡来の、ラツパのような形状をした呼筒。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "己れ只一人｜智からんと欲するは大愚のみ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一点をうつ為めに十年の酸苦を嘗めた大愚な画家もあつた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは金銭問題を離れた、神か大愚かというような清浄な生活だった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大賢は大愚に近し」ともいいます。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、光秀征伐時代の秀吉は、機智があまり多くつて、人の同情を引かないが、征韓時代の豐太閤は大愚に似て、而も神々しいところがある。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども彼等の東洋的芸術に――たとへば大愚良寛の書に新らしい美しさを発見するのはいつであらう。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "再生の荷葉と拝む大愚なき世に安んじてよく眠れ牛　伊豆伊東に近い大室山の麓にこの頃一碧湖といはれてゐる吉田の大池がある。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "大愚といふ和尚は支那にも日本にも居る。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は愚にして目前の利害も知らず、人の己れを誹る可きを弁えず、我家人の禍となる可き事を知らず、漫に無辜の人を恨み怒り云々して其結果却て自身の不利たるを知らず、甚しきは子を育つるの法さえも知らざる程の大愚人大馬鹿者なるゆえに、結論は夫に従う可しと言う。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "固より、その影響も或る方面には多少あるかも知れないけれど、然し作家は大抵、先駆者でありまた大愚であって、当面の政策に対する関心よりも、将来への夢を多く孕むものである。",
              "citation": {
                "source": "文学への実感について",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私見――この話のなかで、亀は狡猾な者となっているが、その狡猾さも一種ユーモラスな気味に包まれ、相手を見くびった不敵な大愚とでも云うべきものが目立つのは、亀がおのずから持つ徳の然らしむる所であろうか。",
              "citation": {
                "source": "文学以前",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしが若し人身を受けたならば大愚癡の身となって、念仏勤行の人となりたい」といわれた。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの作が「牡丹燈籠」や「菊模様皿山奇談」に次ぐ初期の作であるため、ここに論うことにしたのであるが、いま久々に読み返してみて花嫁入水前後のくだり、江島屋の番頭金兵衛が呪いの老婆にめぐりあうくだり、この二席のほかは圓朝物としてはおよそ不傑作であり、大愚作であることを熟知した。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧智仙は字は大愚、号を金洞といい、谷中｜芋坂長善寺の住職で詩を枕山に学んでいる。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "大賢大愚、まことに小児のごとき蒲生泰軒であった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "よだれ垂らさんのが不思議さね」「大賢は大愚に似たりか。",
              "citation": {
                "source": "この握りめし",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "道元禅師が正法眼蔵に〈愛語〉を説き、大愚良寛が〈愛語〉の体行をもつて生涯の課題としたことをもおもひ合せ、かういふすぐれた人々の音声は想像するだにすがしく、たのしく、同時に、こんにちテレビ・ラジオに〈美声〉はあつても、〈良声〉〈善声〉のじつに乏しいことまで嘆かれるが、話をもとにもどさう。",
              "citation": {
                "source": "ひとの不幸をともにかなしむ",
                "author": "吉野秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――命が惜しかったら断念しろ、恥は忍べるが死んで生き返ることはできんぞ、ばかはあとで後悔する、転ばぬさきの杖、笑止せんばんの抱腹絶倒、先哲のいわく……」　そのあと大賢は大愚に似たりとか、ほかにもいろいろと並べたてたようだが、又四郎はさっさと出て来たので聞えなかった。",
              "citation": {
                "source": "百足ちがい",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわれこの人、一大努力を以て一大愚論を吐く。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやはや呆れた、大愚作。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＪＯの大河内の「血路」なるもの大愚劇、見てゐられぬ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大愚に返って、自然のふところに遊ぼうとしている一人の野の隠居だ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、帰りがけに奉行所の方へ寄って、すべての打合せを済まして参りました」「してみると鶉坂の老先生は、飽くまで唖を、大愚者と見ておられるのだな」「何しろ世話の焼ける奴です」「ともかく、その手順どおりに踏んでみよう」　夜は更けているが、一日経てば一日だけ捜査は至難になるばかりだ。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、当時の名僧大愚、一糸、雲居などとも交わりふかく、戦国中御衰微の甚だしいうちに、怏々として御憂悶の深かった上皇の侍側にあって、一糸、烏丸光広などと共に、陰にあって、勤王精神に篤かった傑僧であった。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｇ氏は、紙屋川の法輪寺の住職で、ここは愚堂の師、大愚和尚の住んでいたお寺である。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、寺には今も大愚、愚堂の墨跡、尺牘、反古の文字までが数多残されているということであり、わけてＧ氏は、自身大愚と愚堂の遺作も蒐集され、寺祖の研究に、その方面からも長年心を傾けて来た人なのである。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は白状すると矢部さんよりもマルタの方によけい頭が下げたいぐらいだったから。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
