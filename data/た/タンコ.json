[
  {
    "uuid": "c9f6c72a-c360-589d-b81f-18f4540ed63a",
    "entry": "淡湖",
    "reading": {
      "primary": "たんこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "freshwater lake",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただし、いったんこの土地を共有した以上は、かかる差別は消滅して、ともに平等の立場に立つのだということを覚悟してもらわねばなりません。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿江は腹をぺったんこに二つに折って、胡坐の膝で貧乏ゆすりをしながら、上眼使いに指の爪を噛んでいた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「むむ、持たんことがあるもんだか。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "横土間で誂へを聞くのが、前鼻緒のゆるんだ、ぺたんこ下駄で、蹠の眞黒な小婢とは撰が違ふ。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども一たんこの寮へわたくしが入ると、まるで鼠取りの籠の中へ鼠が入った途端に〆めたとばかり捕え主が苛め出すように、池上はすぐさま嫉妬し始めました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の廃朽品である乞食に就ても同様で、一たんこれと目ざした乞食に向けては執拗に詮索を追躡して行く性分である。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子は斎戒すること三日の後、哀公の前に出て、義のために斉を伐たんことを請うた。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如く遠藤の決死は頗る悲壮であるが、彼は、長政が初めて佐和山に於て信長と対面したとき、信長の到底頼むべからざるを察し、急に襲って討たんことを提議し、長政の容るるところとならなかった事がある。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、いよいよ手切れとなるや、単身敵陣に潜入して、信長を討たんことを決心す。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ評定に入るや、かの好漢忠次真先に、鳶ヶ巣以下の諸塁を夜襲し、併せて武田勢の退路を断たんことを提議した。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "つもりつもった涙で、一たんこぼれ出したとなると、後から後からと止める術もなかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストレーカの遺体はいったんここへ、ですね？",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどこの儘に神曲を擲たんことは、わがなすこと能はざるところなりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の勢をもてすれば、その恩義の絆を斷たんこといとむづかし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "市長は時として我｜臥床の傍に坐して、われに心を安んじて全快を待たんことを勸め、ロオザの遠からず來りて病を瞻るべきを告げたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "わきかえるような泡の混乱の中に船をもまれながら行く手を見ると、いったんこわれた波はすぐまた物すごい丘陵に立ちかえって、目の前の空を高くしきりながら、見る見る悪夢のように遠ざかって行く。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは一たんこうと決めたらどこまでもそれで通すのが好き。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋に帰ると妻は蓆の上にペッたんこに坐って馬にやる藁をざくりざくり切っていた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったんこうとにらんで乗り出した以上は、どのようにしてもそなたたちのために尽くしてみようと思うが、どうじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しかし、名人がいったんこうしてごろりと横になりながら、ひとたびその手があごのあたりを散歩しはじめたとなったら、もう梃子でも動くものではない。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい何でもないにしたところで、いったんこんな疑いが、俺の心に起こった以上は、この人が存在する以上は、俺の心はいつまでも平和であり得ないのだ。",
              "citation": {
                "source": "二人の盲人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "智慧を戦はして勝たんことを欲した。",
              "citation": {
                "source": "ある僧の奇蹟",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう人間が多いだけに、いったんこっちの羽振りがよくなれば、昨日のかたきは又すぐ今日の味方に早変わりをするのである。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストレーカの死体はいったんここへつれて帰ったんでしょうね？",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶に時計が九時で留つてゐるとか、愛国婦人会の幹事の鼻がぺたんこであるとかすると、女史は直ぐ苦り切つた顔をして、「西洋にはそんな事は無い。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際ぺたんこな鼻の恰好から、黒味がちな円まつちい眼は、お婆さんそつくりだつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "可愛いんで泥たんこの田舎道を私の家まで六本の牛乳を運ぶのがみじめだったんで牧場から帰りにさっき私達の目の前でしぼって消毒した牛乳のあついのを下げて帰ったりする事もあった。",
              "citation": {
                "source": "旅へ出て",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "道のところどころに、雨あがりの大きい泥たんこが出来ている。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
