      {
        "index": 1,
        "gloss": "traditional Japanese treadle-operated tall loom",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
