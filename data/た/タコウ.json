[
  {
    "uuid": "eaafd093-e682-5852-b5f8-de275b79ae92",
    "entry": "他行",
    "reading": {
      "primary": "たこう",
      "alternatives": [
        "たぎょう"
      ],
      "is_heteronym": false
    },
    "grammar": {
