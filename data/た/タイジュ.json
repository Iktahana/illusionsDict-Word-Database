    },
    "definitions": [
      {
        "index": 1,
        "gloss": "large tree",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と會釋し、鐵扇はらりと開き、屹つと月を見上げて、大樹の如く凝然と動かず。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が宿の大樹にはとまりてさへ鳴くものを、夜ふけ枕にこゝろし給へ。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢、桂、山毛欅、樫、槻、大木大樹の其の齢幾干なるを知れないのが、蘚苔、蘿蔦を、烏金に、青銅に、錬鉄に、刻んで掛け、鋳て絡うて、左右も、前後も、森は山を包み、山は巌を畳み、巌は渓流を穿ち来る。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋燈も珍しいが、座敷もまだ塗立ての生壁で、木の香は高し、高縁の前は、すぐに樫、槻の大木大樹鬱然として、樹の根を繞つて、山清水が潺々と音を寂に流れる。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は近所のあらゆる曲がり角や芝地や、橋のたもとや、大樹のこずえやに一つずつきわめて格好な妖怪を創造して配置した。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつでも見落すことのできないのは、北二条と大通りとの交叉点にただ一本立つエルムの大樹だった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にも省みられないけれども、春が来るごとに黙って葉を連ねているあの楡の大樹、あの老木が一度でも分外な涙を流したか。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "表だけ見えて、欄干が左右へ……真中に榎の大樹があって仕切る、その二階がね、一段低くなって流に臨んで、も一つ高い座敷が裏に有りそうなんだ、夢だからね、お聞き。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼ばれたのは、知事の君が遠縁の法学生、この邸に奇寓する食客であるが、立寄れば大樹の蔭で、涼しい服装、身軽な夏服を着けて、帽を目深に、洋杖も細いので、猟犬ジャム、のほうずに耳の大いのを後に従え、得々として出懸ける処、澄ましていたのが唐突に、しかも呼棄てにされたので。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日出雄少年は、其泉の流に美麗なる小魚を見出したとて、魚を追ふに餘念なき間、私は唯ある大樹の蔭に横つたが、いつか睡魔に襲はれて、夢となく現となく、いろ／＼の想に包まれて居る時、不意に少年は私の膝に飛皈つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて當日は、二十｜里近く進んで日が暮れたので、夜は鐵車をば一大樹の下蔭に停めて、終夜篝火を焚き、二人宛交代に眠る積であつたが、怒り叫ぶ猛獸の聲に妨げられて、安らかな夢を結んだ者は一人も無かつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "中の丸の大樹の枝垂櫻がもう見えぬ。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "画工　俺が入る、待て、（画を取って大樹の幹によせかく）さあ、可いか。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　偶と紫玉は、宵闇の森の下道で真暗な大樹巨木の梢を仰いだ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外の広場の一廓、総湯の前には、火の見の階子が、高く初冬の空を抽いて、そこに、うら枯れつつも、大樹の柳の、しっとりと静に枝垂れたのは、「火事なんかありません。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "行くこと数百歩、あの樟の大樹の鬱蓊たる木の下蔭の、やや薄暗きあたりを行く藤色の衣の端を遠くよりちらとぞ見たる。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央よりすこしく上のかたには梅の大樹ありて、花は白く咲きみだれたり。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その狭い往来に五、六株の大樹が繁っているのであるから、邪魔といえば邪魔であるが、電車も自動車もない時代にはさのみの邪魔とも思われないばかりか、長い堀ばたを徒歩する人々に取っては、その地帯が一種のオアシスとなっていたのである。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに欝蒼というべき大樹であっても、わずかに五株か六株の柳の蔭がこれほどの功徳を施していようとは、交通機関の発達した現代の東京人には思いも及ばぬことであるに相違ない。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいてかの柳の大樹が次から次へと伐り倒された。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "向座敷は障子をあけ放して、その縁側に若い女客が長い洗い髪を日に乾かしているのが、榎の大樹を隔ててみえた。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭焼の竈は家の外、上のかたの奥にある心にて、家の左右には杉の大樹、薄なども生い茂っている。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "市郎も心許なさに其後を追って行くと、唯ある樅の大樹の蔭でトムが凄じく吠えていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉松や山毛欅や扁柏の大樹が日を遮って、山路は漸次に薄暗くなって来た。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、山毛欅の大樹の根を枕にして、一人の男が赤裸で雨の中に倒れていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺には大樹が多かった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大樹の聳ゆる下に落葉焚く煙が白く※って、彼のお杉｜婆は窟を背後に、余念もなく稗の粥を煮ていたが、彼女の耳は非常に敏かった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、やがて傍の岩蔭に聳えたる山椿の大樹に眼を注けると、彼は忽ち猿のように其の梢にするすると攀登った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は声をたづねて探りあるくと、松の大樹から少し距れたところに大きい石が横はつてゐて、赤児の声はその石の下から洩れてくるのであつた。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "登山してから三日目の夕刻、一同は唯ある大樹の下に屯して夕飯を焚く。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
