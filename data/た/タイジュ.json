[
  {
    "uuid": "b1717c9c-4daf-5dc9-9aee-92e3bf9a9cdf",
    "entry": "大樹",
    "reading": {
      "primary": "たいじゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
