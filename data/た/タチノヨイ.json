        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "秀でた額、というものが人の世にはあるけれど、そっくりさんの額はまさに秀でたとしか言いようのない、鋭い頭脳の切れ味を感じさせる、かたちの良い額だった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すんなりとのびた、かたちの良い脚だった。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女のかたちの良い唇に塗った口紅の赤い色を、祐一は見た。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女のいつもはかたちの良い唇が、いまは数字の８の字を横に置いたようになっているのを、ヨシオは見た。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の前に、かたちの良い鼻の穴がふたつ、見える。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、いつも、小さい太郎たちのよい友だちでした。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどいつも小さい太郎たちのよい友達でした。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどいつも小さい太郎たちのよい友だちでした。",
              "citation": {
                "source": "小さい太郎の悲しみ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその病気があまりたちのよいものではないということがわかった。",
              "citation": {
                "source": "手紙",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "イエニーはすべての友人たちのよい女友であり母であった。",
              "citation": {
                "source": "カール・マルクスとその夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男先生はそれを、じぶんの手柄のように思ってよろこび、「なんしろ、今年の生徒んなかには、たちのよいのがおるからなあ」　五年生のなかにたったひとり、本校の大ぜいのなかでも群をぬいてできのよい女の子がいることで、岬からかよっている三十人の男女生徒がちこくしなかったようにいった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからソクラテスも、その臨終の時に自分に向って「先生はどのように葬られることをお望みですか」ときいたクリトンに、「君たちのよいように」と答えたのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちのよい子どもを集めて、みっちりしこんで、りっぱな兵隊にするんだ。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "光琳が屏風にでも写しそうな、かたちのよい、一株の老梅があった。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄妹はいつのまにか自分たちのよい友達みたいに思って、秀吉の背なかへ絡みついたり、小さい手に杯を持って、「もう参れぬ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
