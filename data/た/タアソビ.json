[
  {
    "uuid": "86a10ed5-7e35-5c32-8261-a2d700c23372",
    "entry": "田遊び",
    "reading": {
      "primary": "たあそび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
