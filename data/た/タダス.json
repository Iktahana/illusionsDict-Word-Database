[
  {
    "uuid": "453632d3-bdb9-5972-8564-2d086bdbe609",
    "entry": "質す",
    "reading": {
      "primary": "ただす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to ask (about)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もしそうであらばエネルギーと物質とは打して一丸となり、物質すなわちエネルギーとなる訳である。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の文壇でいふ「隨筆」とは、西洋のエッセイとは全く別種の物であつて、主として季節の推移に於ける自然の情趣や、日常生活に於ける身邊の述懷などを敍するもので、その文學の本質する精神は、全く俳句のそれと共通してゐる。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "惡くいへば、それだけ心が荒んで來るのであらうが、神經質すぎる人にとつては、それで丁度中庸が取れることになつてゐるのである。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも物質元子に、物体と同様な第二次的属性を与える事を拒み、ただその幾何学的性質すなわちその形状と空間的排列とその運動とのみによって偶然的なる「無常」の現象を説明しようとしたのが、驚くべく近代的である。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この現実の世の中で、自分一人が、仏陀とか神仙とかいわれるものに近い永遠不滅の性質を帯びたものに変質するのである。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、更に委しく其の『鬼』の有様を質すと、曰く、半夜に凄風颯として至る。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "四七一一番のオウ・デ・コロンはアルコオルがうんと入っていて、古くなるとウイスキイに変質するって話でも、聞いたことあるかい？",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならこの意味の「詩」という言語は、特殊の形式によるものでなく、あらゆる一切なものにわたって、内容の本質する点を指すのであるから、以下吾人は、暫らく詩という観念から離別をして、表現の原則する公理につき、基本の考察を進めて行こう。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人はこの不思議を解明して、詩の本質する定義を確立せねばならないのだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして詩が本質する精神は、この感情の意味によって訴えられたる、現在しないものへの憧憬である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十章　人生に於ける詩の概観　詩の本質するものが、それ自ら「主観的精神」であることは前に述べた。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前章に述べた通り、すべて倫理感の本質するところは、それ自ら詩的精神である故に、倫理的観念――恋愛を含めて――によって書かれたものは、必然に皆情緒を刺戟し、一種の抒情詩的な陶酔魅惑をあたえる。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この無邪気さには、とても敵わない」　私は気力も脱けて、今度はしきりに朗吟の陶酔に耽っている、社長の肩を揺って、正気に還らせ、「これは真面目なご相談ですが……」と、木下の新嘉坡に於ける女出入や、その他の素行に就いて、私はまるで私立探偵のように訊き質すのであった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "政宗は小十郎の意見を質すと、小十郎は、天下の兵はたとえば蠅のようなもので、これを撲って逐うても、散じては復聚まってまいりまする、と丁度手にして居た団扇を揮って蠅を撲つ状をした。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と質すと、源三は術無そうに、かつは憐愍と宥恕とを乞うような面をして微に点頭た。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "外國の富豪の如きも、其の確固なるものは、皆之を質すに惜福の工夫に富んでゐるのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角、女親とあとは殆ど女だけしかいないような家なのです」　かの女は「まあ」と云って、それより先｜訊き質す勇気はなかった。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主が流行感冒一つ引いても、まっさきに伝染性なりや否やを医師に質すような婦を、貴婦人だって、学者だって、美人だって、年増だって、女房にしていらるるもんか。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "福島にて問い質すに、郡山より東京までは鉄路｜既に通じて汽車の往復ある由なり。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "例のブーランゼー氏に質すと、書物に出た図はもちろん絵虚事だと答えられたから、予もなるほどことごとく図を信ずるは、図なきにしかずと了った。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかくこんな事は女に質すに限ると惟うて例の古畠のお富を問うとその判断が格別だ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼少の頃読んだ物の名は忘れたが、浪人が家主方へ招かれ談して帰った跡で、その席に置いた金が見えず、浪人に質すと、われ貧に苦しみて盗めりとて謝罪し、早速一人娘を遊女に売って償却した。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "敢て罪過論を艸して世上の非罪過論者に質す。",
              "citation": {
                "source": "罪過論",
                "author": "石橋忍月",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのような訓練の賜物か日本人にはこの柔軟性が伝統の中に残っていて、さて危機だと見ると蝉脱するがごとく翻然と転質する気力がある。",
              "citation": {
                "source": "北京と巴里（覚書）",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "実感で試験をせんと自分の性質すら能く分らぬ男だ。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に之が政党に変質することによって社大党との対立を招くことを恐れて支持を止めたのであるが、その運動の形態はとに角として、その観念上の方針については賛意を表するに吝かではない。",
              "citation": {
                "source": "社大党はファッショ化したか？",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルクスは『神聖家族』においてフランスの唯物論と対質するに際して、それのこの意義を明らかにしている。",
              "citation": {
                "source": "マルクス主義と唯物論",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも我々はこの對質することができないものと絶えず對質させられてゐるのである。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "何人もこれと對質すべく迫られてゐる。",
              "citation": {
                "source": "唯物史観と現代の意識",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルクスは『神聖家族』に於てフランスの唯物論と對質するに際して、それのこの意義を明かにしてゐる。",
              "citation": {
                "source": "唯物史観と現代の意識",
                "author": "三木清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
