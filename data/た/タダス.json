  {
    "uuid": "33f8e578-079f-5f30-a4f9-46fce0556a3d",
    "entry": "訂す",
    "reading": {
      "primary": "ただす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to correct (a typo, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "念のために、訂すと、以ての外で。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に此の池水のやうに文語が腐らないやうに假名遣を訂すのは必要でありますけれども、一旦文語となつたものは是れは法則である、正しいものであると云ふことを認めて宜しいかと思ひます。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "從つてこの一派よりは舊史を考訂する學問といふべきものが出た。",
              "citation": {
                "source": "支那史學史概要",
                "author": "――史記より清初まで――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに京水は別に養父錦橋の文を校訂すべき材料を有せなかつたと見えて、其矛盾の所はこれに評註を加へたに過ぎない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村司馬之助、横山文哉｜交を訂す。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十六歳、家居して又た詩稿を刪訂す。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "是は漢文で書かれたもので、兩三年前已に淨書し終つたが、其後多少改訂すべき點を發見されたとかで、其儘になつて居る。",
              "citation": {
                "source": "那珂先生を憶ふ",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして譯は全部、私がノルウェイ語の原文と引合はせて、校訂することになつてゐたが、不幸出版社の都合で、立消えとなり、そのとき出來上がつた譯稿はのち、改造文庫に入つてゐる。",
              "citation": {
                "source": "イプセンの日本語譯",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "常の素読は、『助読』という素読の終っただけの者や、寄宿舎に入って素読以上の事を研究している若者から教えてもらい、それの誤は教官たる先生が訂すのである。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "通常ならば、前年の誤記を訂すといふ事はある。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "水沼間・水沼・弥努波（または、婆）と三様に、出雲文献に出ているから、「水汲」と訂すのは考えものである。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "水沼間・水沼・弥努波（又は、婆）と三様に、出雲文献に出てゐるから、「水汲」と訂すのは考へ物である。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論多少富永の誤を訂すだけのことはありますが、併し富永の根本學説に觸れたやうなことはありませぬ。",
              "citation": {
                "source": "大阪の町人學者富永仲基",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "人によっては卵子は既に Oospore の訳語と成っているから重複して困ると反対することがあるが、これは後ちに出来たその訳語を改訂すればよい。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あめりか物語を校訂す。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "此日全集第三巻に当つべき旧著冷笑を校訂す。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "褥中旧著冷笑を校訂す。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈下勉強して旧稾を校訂す。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕餉の後旧著日和下駄その他を校訂す。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈前旧著日和下駄を校訂す。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "『補陀洛山草創建立記』とは多少の相違や前後した点もあるが、孰れも信ず可き者であるから、二者対照して補訂すればよい。",
              "citation": {
                "source": "山の今昔",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "果たしてそうだとすれば、その学名を Juglans mandshurica Maxim. var. Sieboldiana（Maxim.）Makino と改訂する必要を認める。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "公教要理を改訂する、祈祷書に赤筆を入れる。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "上州の萩原禎助のごときは、和算終末の大家であるが、諸算書の問題を綿密に研究してこれを補訂するのが、この人の最も主要な事業であった。",
              "citation": {
                "source": "和算の社会的・芸術的特性について",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "違つたところを、お前が訂すが宜い」　平次の言葉が優しく靜かに響くと、お町の熱を持つた眼は、大きくまたゝくのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "槍の折れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "違ったところを、お前が訂すがいい」　平次の言葉が優しく静かにひびくと、お町の熱を持った眼は、大きくまたたくのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "槍の折れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "本朝、又、伯夷傳を補訂する者有り。",
              "citation": {
                "source": "國譯史記列傳",
                "author": "伯夷列傳第一",
                "note": "青空文庫"
              }
            },
            {
              "text": "四、文章全体を改訂する。",
              "citation": {
                "source": "怪奇小説の執筆についての覚書",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてモルガニの記しているところによるとこの男はこの手紙を非常に喜んで絶えずもっともっとと要求し「彼は私が70才になるまで引っぱり、……内容を改訂するから返して欲しいと言っても返してくれず、ついに最後には内容を簡単にはしないと私に確約させた。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "益田貞信がフランスで見た「マリウス」の話をきゝ、幕切れを改訂する。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
