    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese ash",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "名刺を読むと、しきりにまたガツテンガツテンをしながら私の顔をみて、それからタモトに入れたのであつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ンの仮名を書かなかったのである）、チ→促音（「発ちて」がタテ、「有ちて」がタモテとなる。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "然も今日多數の同人雜誌、同人雜誌作家の大部分は今尚今後幾度のメタモルフオーゼを行はなければ、その發芽にも至らぬやうに思へる。",
              "citation": {
                "source": "「青空語」に寄せて（昭和二年一月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンタモニカの晩御飯を御馳走して上げてよ。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "記者様――アノ鯉幟ノ棹ハ、私ガ酔ッタ勢イデ立テタモノデスガ、ソレガ記者様ノオ眼ニ止マッテ、コンナ不孝ナ恥ヲ晒ソウトハ夢ニモ思イマセンデシタ。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒト一人のための明日のコンピューターはタイプライターのエピゴーネンじゃない「それがナンなの」とタモリにかまされてから、ヒト一人のためのコンピューティングの明日について考え込んだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "タモリのやっている「音楽は世界だ」というテレビ番組の「デジタモ・ドン」というコーナーを、ボーっと眺めていた時のことだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "山田五郎教授との名尻観賞における突発的な蘇生を例外として、タモリは早死に絶えて久しいと人は言う。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかでもデジタモ・ドンは、コンピューターが名脇役ぶりを発揮して快調である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまあコンピューターによる音の操作の実験をいろいろかましたところで、タモリが「それがナンなの」と落とす。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそれだけなら、「ナンなの」とタモリにかまされて終わりである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "デジタモ・ドンのコーナーのつかみが毎回示すとおり、コンピューターは万能の物真似機械である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにデジタモ・ドンは、万能の物真似パワーを持つがゆえにコンピューターが時に足を取られかねない陥穽を浮彫りにする。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この偉大なるタモリのコンピューター批判を確認したオレの前には、今、テキストとグラフィックスの入力、そしてマシンの制御の一切を全部ペン一本に集約した、厚目のクリップ・ボードのようなコンピューターがある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この技はタモリに「それでナンなの」と切って捨てられるほど、やわなものではなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがすでにデジタモ・ドンの真実を確認したオレは思う。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "てなわけでデジタモ・ドンの真実に目覚めたオレは、ペン・コンピューティングに期待するところ大である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『本草啓蒙』に猴の和名を挙げてコノミドリ、ヨブコトリ、イソノタチハキ、イソノタモトマイ、コガノミコ、タカノミコ、タカ、マシラ、マシコ、マシ、スズミノコ、サルと十二まで列ねた。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "イソノタモトマイ、コガノミコ、タカノミコ等は古え※女の君が巫群を宰った例もあり、巫女が猴を馴らして神前に舞わせたから起った名で、タカは好んで高きに上る故の名と知る。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "オンダモダイタモエンブチハウノモオマエノコジャモノ、キナガニサッシャイ、イカニモショッショ。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓を開け放した脱衣場のわきで、いつまでもモタモタしていたくなかったので、慶一は、そこから五メートルほど離れた非常口に駆けこんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "地上でモタモタしてると、襟首ひっつかまれて、磔にされちまう」　ふたりのあいだに、〈アイル・ビー・バック〉の単純なギター・リフがただよう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判長は神経衰弱に落ちて、カルシュームを含むカルピスと精力素と云う薬と、ヘモグロピンとヴィタモーゲンとを服用し、その上にビフステキを食べるのだが、其れが皆鬚になって了うのである。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコロガ、オツウヤノバンニ、キテイタ人ガオソクナッテカラ目ヲサマシテミルト、ホトケサマノ前ニソナエテイタモノガ、ドレモコレモ一ツノコラズナクナッテイタコトガ分リ、大サワギニナッタノ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "マアー、コトモアロウニ、ジブンタチノ死ンダオ母ッチャニアゲタモノヲ、君チャンヤ弟ヤ妹ガ、ムチウニナッテ、タベテイルデハナイノ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "オヴィドがその著メタモルフォセス（Metamorphoses）の中に述べているところによると始めにはただ秩序なき均等な渾沌、“rudis indigestaque moles”があった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "部分的にはなかなか見事であると思われるオヴィドの叙述の見本を少しばかり、ブレ（Bulle）の翻訳したメタモルフォセス（『変相』）の中から下に紹介する。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "コノコトハ子規ノ書イタモノニカタカナ文ガ多イコトヤ、宮沢賢治ノ病中作デアル「雨ニモ負ケズ」ノ詩ガカタカナデアルコトナドデ間接ニ証明サレルガ、ナオソレニツイテイササカインチキナガラ力学的ニ考察シタ文章ヲ他ノ場所ニ発表シタカラココニハ書カナイ。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "コレハ少シ手習イシタモノナラダレデモ感ジルコトダ。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
