[
  {
    "uuid": "b0d49af8-b24b-5eae-9a7c-97688f815e48",
    "entry": "対岸",
    "reading": {
      "primary": "たいがん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
