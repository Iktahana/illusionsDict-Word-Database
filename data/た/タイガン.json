      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "opposite shore",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは、鑿岩機さえ運転していないで、吹雪さえなければ、対岸までも聞える程の大声であった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "御濠の石垣が少しくずれ、その対岸の道路の崖もくずれている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞西あたりの山のホテルを想はせるやうな帝国ホテルは外側から観賞しただけで梓川の小橋を渡り対岸の温泉ホテルといふ宿屋に泊つた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、逆説的に聞えるかもしれないが、その同じ颱風はまた思いもかけない遠い国土と日本とを結び付ける役目をつとめたかもしれない、というのは、この颱風のおかげで南洋方面や日本海の対岸あたりから意外な珍客が珍奇な文化を齎して漂着したことがしばしばあったらしいということが歴史の記録から想像されるからである。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スイスあたりの山のホテルを想わせるような帝国ホテルは外側から観賞しただけで梓川の小橋を渡り対岸の温泉ホテルという宿屋に泊った。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼過ぎ、昭青年は姫に生飯を持って行って食べさせたあと、二人は川へ向いた苫を少し掻き分けて、対岸の景色を眺めていました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾瀬川の名物の合歓の木は少しばかり残り、対岸の蘆洲の上に船大工だけ今もいた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊が函館まで南下して来て対岸の山々を眺めて、さてあきらめて引き返して行ったことを想像するのは愉快である。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もどの画家でも相当な人ならばある程度まではそういう事を考えぬ人は無いかもしれないが、しかしそう考えるばかりで何時までも同じ谷間の径路を往復しながら対岸の自然を眺めているのでは到底駄目であろう。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の銅羅が暁を破ると見送人達は鉄梯子を下りて対岸に並ぶと、二度目の銅羅と一斉にわめき出す。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "またしても対岸に反乱が勃発したらしい。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミサコはお互の少時間の自由を、対岸を流れる濁水に眼をうつして云った。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "衛兵にまもられた橇が黒龍江を横切って静かに対岸の林へ辷って行く。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "対岸には、搾取のない生産と、新しい社会主義社会の建設と、労働者が、自分たちのための労働を、行いうる地球上たった一つのプロレタリアートの国があった。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒橇や、荷馬車や、徒歩の労働者が、きゅうに檻から放たれた家畜のように、自由に嬉々として、氷上を辷り、頻ぱんに対岸から対岸へ往き来した。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏は、対岸から、踵の高い女の白靴や、桜色に光沢を放っている、すき通るような薄い絹の靴下や、竹の骨を割った日傘が、舟で内密で持ちこまれてくる。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、対岸の河岸が、三十メートル突きだして、ゆるく曲線を描いている関係から、舟は、流れの中へ放りだせば、ひとりでに流れに押されて、こちらの河岸へ吸いつけられるようにやってくる。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二重硝子を透して遠くに、対岸の黒河の屋根が重い支那家屋の家なみが、黒く見えた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方では、飲酒反対、宗教反対のピオニールのデモを見習った対岸の黒河の支那の少年たちが、同様のデモをやったりするのに、他方どうしても、こちらの、すきを伺っては、穀物のぬすみ喰いにたかってくる雀のように、密輸入と、ルーブル紙幣の密輸出を企てる支那人があるのを、ワーシカはいまいましく思った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "クヅネツォフは、対岸の、北の村に住んでいる富農だ。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "対岸の三十メートル突きだした一番地理にめぐまれた地点から、三艘の舟が列をなして、こちらの岸へ吸いつけられるように流れてきた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵は靉河右岸に沿い九連城以北に工事を継続しつつあり、二十八日も時々砲撃しつつあり、二十六日｜九里島対岸においてたおれたる敵の馬匹九十五頭、ほかに生馬六頭を得たり――「どうです、鴨緑江大捷の前触れだ、うれしかったねえ、あの時分は。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを対岸から写すので、自分は堤を下りて川原の草原に出ると、今まで川柳の蔭で見えなかったが、一人の少年が草の中に坐って頻りに水車を写生しているのを見つけた。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば信州へんでもある東西に走る渓流の南岸の斜面には北海道へんで見られるような闊葉樹林がこんもり茂っているのに、対岸の日表の斜面には南国らしい針葉樹交じりの粗林が見られることもある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か旧｜魚河岸の方の側で手鏡を日光に曝らしてそれで反射された光束を対岸のビルディングに向けて一人で嬉しがっているものと思われた。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "待乳山の対岸のやゝ下に○三囲祠あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "本所側にありては電燈会社対岸の下に当りて東に入るの小渠あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "中洲の対岸一水遠く東に入るものを○小名木川とす。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
