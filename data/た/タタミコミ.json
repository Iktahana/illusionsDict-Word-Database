        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "嵐の気配を感じた船長は、直ちに帆の畳み込みを指示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "熟練の船員たちは、荒れ狂う風の中でも迅速に畳み込み作業を進めていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "入港を前に帆の畳み込みを終えた船は、ゆっくりと岸壁へ近づいていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
