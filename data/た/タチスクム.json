    "definitions": [
      {
        "index": 1,
        "gloss": "to be petrified",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あッ親分」　「おい、石松は帰って来てるだろう」　「いいえ」　「なァ七五郎、教えてくれりゃ、五両だすがな、どうだ、七五郎」　七五郎、立ちすくむ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹は呆然と立ちすくむ。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　仲蔵ドキンッとして立ちすくむ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（坂部文六である）　団九郎、紙入れを掏り盗られた事に気附いて、アッ、しまったと立ちすくむ。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蝶ははっと立ちすくむと、便所ならば御案内すると云って彼女が先に立って行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドアをあけて、田島はおどろき、立ちすくむ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し霧の過ぎ去ると共に、船の右舷に被ひかゝるやうに聳え立つた惠山の峭壁を見た時には、船員も船客も呀と魂を消して立ちすくむのみだつた。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "避ける間もなしに両方が突き当ったので、文字春はぎょっとして立ちすくむと、相手はあわただしく声をかけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ちすくむ途端に、かれの足は藤四郎の十手に強く打たれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は入口の土間を転げまわって揉み合ううちに、友蔵は善八を突きのけて表へ跳り出ようとする、その横っ面に半七の強い張り手を喰らわされて、思わずあっと立ちすくむところを、再び胸を強く突かれて、彼はあと戻りして土間に倒れた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を押さえて立ちすくむのもあった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は四角なガラスをはめた入り口の繰り戸を古藤が勢いよくあけるのを待って、中にはいろうとして、八分通りつまった両側の乗客に稲妻のように鋭く目を走らしたが、左側の中央近く新聞を見入った、やせた中年の男に視線がとまると、はっと立ちすくむほど驚いた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "諾否の空照りおもり、唖蝉は氣づかはしげに立ちすくむ日を、きしきしと木食蟲　樹の髓を食む。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "室外の廊下に思い余って、誰かが立ちすくむ様子らしい。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっと驚いて立ちすくむと、相手はすぐに呼びかけた。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意におどろかされて長三郎は思わず立ちすくむと、人は若い女で、かのお冬であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　雲のやうにわきあがつてくる思ひのまへに彼はいくどか昏迷しては立ちどまり、自分の行手をふさぐ暗いかげの前におののいては立ちすくむのであつた。",
              "citation": {
                "source": "盲目",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大掛かりな行列が、其所の坂の下まで来てゐると云ふので、台所の女たちは、恐しさに立ちすくむ者もあつた。",
              "citation": {
                "source": "菜の花月夜",
                "author": "片岡鉄兵",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は彼女を見詰めて微笑むと、立ちすくむ小鳥のような彼女の傍へ大手を拡げて近寄って来た。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……たとえば七面鳥は山の向うに鷹が来ている事を知って雛鳥を蔽い隠し、駱駝は行く手の地平線下にライオンが居るのを知って立ちすくむ。",
              "citation": {
                "source": "霊感！",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アツといつて立ちすくむと、その人は笑ひながら出て來て、「すまなかつたねえ」　といつた。",
              "citation": {
                "source": "下町娘",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「舟はある」「そうですよ、あるにはありますが」と、案内人も立ちすくむのであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、河は、水脈を受けて立ちすくむかと見えた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそのころ、路上でふと立ちすくむことがあつた。",
              "citation": {
                "source": "二十七歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな安宿に彼等が泊る筈はないと信じながら、廊下で見かける人影に、とつぜん胸がしめつけられ、息がつまつて、立ちすくむ。",
              "citation": {
                "source": "二十七歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、私があの人の影におびえて立ちすくむとき、私自身の恐怖の中には、あの人に苦痛と恥辱を与へたくない思ひやりが常にこめられてゐたのだ。",
              "citation": {
                "source": "二十七歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを思うと、脚が立ちすくむ。",
              "citation": {
                "source": "酒徒漂泊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "怖ろしい想像を弄ぶこと、それに怯えて立ちすくむことを私は避けたい。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云つて、そこに立ちすくむ。",
              "citation": {
                "source": "ゼンマイの戯れ（映画脚本）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "こら、（と言つて心臓に手をあて）ここがこんなに……（さう言ひながら、ぐつたりと、そこへ腰をおろしてしまふ）あや子　　（あつけに取られて、そこに立ちすくむ。",
              "citation": {
                "source": "村で一番の栗の木（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
