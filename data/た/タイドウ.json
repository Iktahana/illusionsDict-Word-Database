  {
    "uuid": "d98b9286-de7e-5607-9cbc-0d03e07e9470",
    "entry": "体動",
    "reading": {
      "primary": "たいどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
