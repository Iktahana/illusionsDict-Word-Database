    },
    "definitions": [
      {
        "index": 1,
        "gloss": "taidō (martial art)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
