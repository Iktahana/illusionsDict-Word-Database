        "examples": {
          "standard": [
            {
              "text": "椅子の布を張り替えるため、ホームセンターで購入した強力なタッカーを使って芯を打ち込んでいった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「指を挟まないように、タッカーの扱いには十分注意してくださいね」と工作教室の先生が注意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ポスターを壁に固定するのに、普通のホッチキスでは弱かったので、業務用のタッカーを使用した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それに合わせ、慶一は〈サブスティテュート〉をスタッカートで歌いながら、三階のヴェランダにむかう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スタッカート練習曲」「ワルツ・キャプリス」等のピアノ・レコードもある。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタッカートじゃなくてさ、ホーンの感じで。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
