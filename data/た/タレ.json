    },
    "grammar": {
      "pos": [
        "名詞-接尾辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(TV or radio) entertainer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして読後そのインタレスティングを吟味してみよ。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばタレースは始めて金字塔の高さを測るために、塔の影の終点の辺へ小さな棒を一本立てた。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸にして露西亜はレーニンの奇蹟的な偉業とアンナ・スラビナの半身不随によって、過去タレルキンの饒舌、私に遺伝してしまった。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワルツ、タレルキンの心臓、ニコロの青蛇のような首抱いて、私は踊る。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うちらのような貧乏タレにゃ、そんなことはしとれゃせんのじゃ！",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハアゼンクェフェル――「アンティゴオネ」（希臘劇を改作したものであるが、彼はこれを大戦に結びつけ、タレオンを、前の独逸皇帝ウィルヘルム二世に擬し、戦争のために寡婦となったもの、孤児となったもの、不具となったものをして王に向って飢餓と傷痍を訴えさせ、「将軍を市場に晒せ」と絶叫せしめている。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カクテアシタハヒルトナリ、　　水音イヨヨシゲクシテ、　鳥トキドキニ群レタレド、　　　ヒトノケハヒハナカリケリ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何て云いよるのじゃろか」「……お前たちの事をバカタレって云っているんだよ……ホホホホ」　という声が不意に背後の方から聞こえたので、二人は又もビックリして振り向いた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホーラネ……ホホホホホホ……お前さん達の顔を見て馬鹿タレって云っているでしょう……ネーホラ……バカタレーッて……」「……ちがう……」　と大きい方の児が眼をパチパチさせながら云い放った。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イイエ……よく聞いて御覧……ホーラ……ネ……バカタレーッ……バカタレーッ……てね……ね……ホッホッホッホッ」　この笑い声を聞くと赤い鳥は、一寸頭を傾けているようであったが、忽ち思い出したようにパタパタと羽ばたきをした。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……バカタレーッ……バカタレーッ……バカタレバカタレバカタレバカタレバカタレエーッ……」　そう云う赤い鳥の顔を、眼をまん丸にして見上げていた大きい方の児が、みるみる渋面を作り出した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……エエわからん……まっとハッキリ云え……ナニイ……あの別荘の奴等がか……ウンウン……あの赤い鳥にバカタレと云わせたんか……ウンウン……それに違いないナ」　横に立っていた小さい児も、指を啣えたまま、大きい児と一緒にうなずいた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様等ア……あの赤い鳥を使って、俺の弟を泣かせたろう……村中の人間をバカタレと……イ……云わせたろう……」「……そんなオボエはないぞ……」「……何オッ。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿タレ……バカタレエ……バカタレバカタレバカタレバカタレバカタレエッ……」八幡まいり　収穫が済んだあとの事であった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコロガ、ミンナト　ハナレテ、オカアサンヲ　ナクシタ　カアイサウナ　コドモガ　ヘイニ　モタレテ　ヰマシタ。",
              "citation": {
                "source": "ウグヒスブエヲ　フケバ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘイニ　モタレテ、コドモハ、「ケキヨ、ヨ　ケキヨ、ヨ」ト　フキマシタ。",
              "citation": {
                "source": "ウグヒスブエヲ　フケバ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
