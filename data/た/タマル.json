  {
    "uuid": "214ac3c0-79c3-55df-89dc-708101d622b0",
    "entry": "堪る",
    "reading": {
      "primary": "たまる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-自動詞"
      ],
      "ctype": null,
