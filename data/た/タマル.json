    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to bear",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おまへくらゐのものにまだ相対界を尽滅させられて堪るものかいと空で無頼漢が私にいふ。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へべれけになって暴れられて堪るもんですか、子供たちをどうします」　細君がそう云った。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「余計に悪くなって堪るもんか、この節あ心持が快方だっていうけれど、え、魚気を食わねえじゃあ、身体が弱るっていうのに、父爺はね、腥いものにゃ箸もつけねえで、豆腐でなくっちゃあならねえッていうんだ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "方位によつて従来行動の吉凶祝福を申しまするのも、二千年も前の慰繚子といふ兵法家が既に嘲笑つて居りまして、方角の好否で戦の勝敗が定まつて堪るものかと申して居ります位です。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "怠惰屋なぞになられて堪るものか、學校へ行くのが慊なら櫻の木の皮を剥すが可いか、サア如何だ此大たわけめ！",
              "citation": {
                "source": "怠惰屋の弟子入り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂女に食ものッてね、むしゃむしゃ食散らかされて堪るものかな。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に見せて堪るもんか、そんなどじなこたあしやしないよ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「餘計に惡くなつて堪るもんか、此節あ心持が快方だつていふけれど、え、魚氣を食はねえぢやあ、身體が弱るつていふのに、父爺はね、腥いものにや箸もつけねえで、豆腐でなくつちやあならねえツていふんだ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此奴、狡猾い奴だ」と、兵站係の衣水子、眼玉を剥き出し、「八人前八銭ではないか、余分を返せ」と談判に及べば、船頭は一旦握った金を容易に放して堪るものかと、「この大水だで――」と頑強に抵抗したが、「馬鹿をいうな。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る間に太る額の蒼筋、癇癪持の頭痛｜病にて、中年以来｜丸髷に結いしこと無き難物なれば、何かはもって堪るべき。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、死神のような奴、取附かれて堪るものか。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "己あ恐怖かったのなんのって、お前様｜対手が天狗だと名告るから堪るめえじゃねえか、いまだに震が留まらねえや。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なに止められて堪るものか。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな處で石が轉んで堪るものか。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……勝手な極道とか、遊蕩とかで行留りになった男の、名は体のいい心中だが、死んで行く道連れにされて堪るものではない。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「死んで堪るものか、死ぬ方が間違ってるんだ。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　で、それ以来――事件の起りました、とりわけ暑い日になりますまで、ほとんど誰も腹に堪るものは食わなかったのです。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔦　ええ、厭かれて堪るもんですか。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（軍歌でもやるならまだの事、子守や手毬唄なんかひねくる様な奴の、弁当持って堪るものか。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「飛んだ合せかがみだね、人死が出来て堪るものか。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな人に、いつまでも居据わっていられて堪るもんか。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな山奥へ引摺込まれて、人だか※だか判らぬような怪物共の玩弄にされて堪るものか。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生命に別条があって堪るものか。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いけ洒々と泣いて見せたりしやがったって、そんな手なんかに乗って堪るかってんだ、ほんとうに。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "済みませんが彼家にも電話を引いて下さいナ」　と哀願してみたら叔父は怫然として、「馬鹿野郎……あの家に電話を取って堪るか……折角ノンビリと気保養している時間を、外から勝手に掻き廻わされるじゃないか」　とか何とか一ペンに跳ね付けられてしまったので、いよいよガッカリ、グンニャリした事もあった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し何が何様あろうとも、一生の苦楽を他人に頼る女のことであるから、善かれ悪かれ取宛てた籤の男に別れては堪るものではない。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お前に達引かして堪るものか。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "公子　死ぬまで泣かれて堪るものか。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "公子　ははは、そんな処と一所にされて堪るものか。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　一口がぶりと茶を飲んで、（詰らぬ事を……他所へ来た電報に、一々気を揉んでいて堪るもんですか。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
