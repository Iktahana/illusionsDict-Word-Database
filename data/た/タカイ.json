      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "high",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜景萩原朔太郎高い家根の上で猫が寢てゐる猫の尻尾から月が顏を出し月が青白い眼鏡をかけて見てゐるだが泥棒はそれを知らないから近所の家根へひよつこりとび出しなにかまつくろの衣裝をきこんで煙突の窓から忍びこまうとするところ。",
              "citation": {
                "source": "夜景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る人々は、彼女が気高い暮しをしたと云つてゐる。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論外国にしろ、多少とも此の世の中は左様なものではありますが、高い程度の技術ではともかく、凡そ常識の既に認める範囲にある技術では、我が国程に台所情実は場を占めてないやうであります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うんそれだよ、それで俺も一緒に君所へ行かうつて所なんだ」と傍から三田村は、その躁いだ顔の中に兎のやうな眼を光らせて、高い声で云ふのだつた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所では、日蓮宗の信者達が集つて、お大名を称へてゐる女の疳高い声や睡さうな男の声がしてゐた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この侘しく灰色なる空の下に私たちの心はまづしく語り　孤獨になやみて重たくよりそふ少女よあの遠い空の雷鳴をあなたは聽くかかしこの空にひるがへる浪浪の高いひびきをあなたは聽くか。",
              "citation": {
                "source": "眺望する",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた一所に行きます』と言って、ヘルンが妻を連れ出す所はたいてい多くは寂しい静閑の所であり、寺院の墓地や、邸の空庭や、小高い見晴らしの丘などであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしある時、ヘルンが案内して連れ出した所は、暗い闇夜の野道の中に、小高い丘があるばかりで、周囲は一面の稲田であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あなた鼻高い。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の大きい、鼻の高い、よき坊さんです』『その同じ時、あなた比丘尼となりましょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あなたの鼻高い、あなたの眼大きい』などという時、夫人はいつも指でヘルンの顔を突ついたりして、子供を扱うようにして戯れからかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに芥川君の態度は、どこか自分を高い所におき、單なる智的聰明さを以て人を見てゐる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この公平な理解と見識では、詩壇の最も高い純粹鑑賞に劣らなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一束の弔花を棺に投入して、そうしてハンケチで顔を覆って泣き崩れる姿は、これは気高いものであろうが、けれども、それはわかい女の姿であって、男が、いいとしをして、そんなことは、できない。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高いリアリティとも結びつく。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が浅草の骨董屋から高い金を出して買って来て、この店にあずけてあるのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷公会堂での三度目の辱かしめられた演奏会がおわった夜、馬場は銀座のある名高いビヤホオルの奥隅の鉢の木の蔭に、シゲティの赤い大きな禿頭を見つけた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "懸命に画をかいて、高い価で売って、遊ぶ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ頗る見識の高い人であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る日、眼光鋭く、気品の高い老紳士が私の陋屋を訪れた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」まことに師の恩は山よりも高い。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見えなくならうとする前に彼は一寸振向いて、「お嬢さんさよなら」と、高い声で巫戯けて云つた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "疳高い甘え声が、真昼の暑熱が漸く鈍い渾然さをみせた夕刻の空気の中を、矢のやうに走つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の上に載つてる顔――額には動物園の猿のやうな皺が深く刻まれ、その皺と皺との間は筋肉がプクリと高い。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻中隔の着際が生れたばかりの時突かれでもしたやうに窪んで、彼の癇高い声が而も鼻に掛かり、恰度山羊のそれのやうになるのは多分それが原因だらう。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々その声の間から、調子の高い耕二の声が聞えた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "急にその病室から高い笑ひ声が聞えて来ると、私は母と話したことが全部その病室まで聞えたために笑つたのかと気懸りになつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「馬鹿、高い高いしてやらう来い。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――母の疳高い声が主家の方から聞えて来た。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の片側は翳り、片側は日射しをうけて、あつたかいけざやかにもわびしい秋の午前です。",
              "citation": {
                "source": "死別の翌日",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
