[
  {
    "uuid": "a317abd6-fe49-5bd3-ba4b-74ea6381c847",
    "entry": "高い",
    "reading": {
      "primary": "たかい",
      "alternatives": [
        "たかーい",
        "たっけー",
        "たっかーい"
      ],
      "is_heteronym": false
