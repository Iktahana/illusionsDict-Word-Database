    "definitions": [
      {
        "index": 1,
        "gloss": "high price",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "露店の売品の値価にしては、いささか高値じゃ思わるるじゃろうが、西洋の話じゃ、で、分るじゃろう。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "肝心な事は、路銀が高値い。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お銚子は入が惡くつて、しかも高値いと言ふので、式だけ誂へたほかには、町の酒屋から、かけにして番を口説いた一升入の貧乏徳利を誰かが外套（註。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "米價はその頃も高値だつたが、敢て夜討ちを掛ける繪圖面ではないのであるが、町に向つて檜の木戸、右に忍返しの塀、向つて本磨きの千本格子が奧深く靜まつて、間の植込の緑の中に石燈籠に影が青い。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「米が高値いから不景気だ。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら諸式高値でも、こゝの店は随分倹約だぞ。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かにあるのだが、アシストが先頭に立って押し出してきた低価格ソフトは、高値のソフトに値段相応の価値があるのかをつねに突き付ける。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＤＯＳ／Ｖなんて代物が出てきて構造変化の兆しはあるものの、これまでここでは日本電気の専有アーキテクチャーの独走を背景にＤＯＳマシンは高値維持に成功しており、メーカーはどこもそれなりにいい思いをしてきたのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、ほかに奉公人もあるが、高値の売り物をかかえて武家屋敷へ出向くのであるから、主人自身がゆくことにして、喜右衛門は日の暮れるのを待っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "一つ目小僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋鵞鳥って、おめえ、随分と高値のするもんだぞ。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「幾ら高値でも、松代さんが嫁に行げねえと同じごって、煉瓦場のために、売口が無くて困ってのさ。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく畜の糞から高値な鮓答を得もすれば、糞それ自身が随分金と替えられ得たから、それを大層に訛称して金を糞に出す驢牛等の譚も出来たのだ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらは無上に高値な糞であろう。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともその技に長ぜる馬は、いかほど姿醜く素情悪くともすこぶる高値に売れる。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく高値を払うて教えを受けた中にアペルレースはギリシア空前の画聖、その妙技について一、二談を挙げんに、かつて諸画師と競うて馬を画くに、審査員他の輩に依怙す。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうこの上は、籠釣瓶を手放すよりほかはない」　村正は徳川家に祟るという奇怪な伝説があるので、江戸の侍は村正を不祥の刀として忌むことになっているが、他国の藩士はさのみ頓着しないから、いい相手を見付ければ相当の高値に売れる。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二両二貫が何｜高値いべ。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "製線所では割合に斤目をよく買ってくれたばかりでなく、他の地方が不作なために結実がなかったので、亜麻種を非常な高値で引取る約束をしてくれた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "将来の騰貴を予期して不相当なる高値を歌ってるものもある。",
              "citation": {
                "source": "駆逐されんとする文人",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありゃ青梅金襴といってな、ここの宿でなきゃできねえ高値なしろものさ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれのむっつり虫は、一匹いくらという高値なしろものなんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "一匁いくらというような高値なおいらのからだが、そうたやすくぽうっとなってたまるけえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "原の中へこしらえるものとなると、高値なものではいけないが、といってちっぽけな見てくれのないものではなおさらいけない……どうでしょう。",
              "citation": {
                "source": "佐竹の原へ大仏をこしらえたはなし",
                "author": "高村光雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつけて、四時の天候なども甚だ不順であって、凶作が続き、雨量多く、毎日、じめじめとイヤな日和ばかりで、米は一円に二斗八升（一銭に二合八勺）という高値となる。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "一度家に帰り父に誡められたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏珪の『李白観瀑』は、つい此間行はれた伊達家の大売立に九万五千円と云ふ途方もない高値を附せられた品物だつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、結婚の式場に列るまで、彼は瑠璃子を高値で購つた装飾品のやうにしか思つてゐなかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代更紗は好者の目を牽いて、皆で二万一千円の高値に取引された。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで受けたこともないような河獺の衿つき外套や、臘虎のチョッキなどに、お島は当素法な見積を立てて目の飛出るほどの法外な高値を、何の苦もなく吹きかけたのであった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれは――あんた昨晩知らなかつたかね、あゝもう寝てゐたつけね。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺だって一晩中立ち通したかねえからな」「冗談云うない。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
