    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sun god",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……エジプトの王様は代々、自分の妻を一晩｜毎に取換えて、飽きた女を火焙りにして太陽神に捧げたり、又は生きたままナイル河の水神様の鰐に喰わせたりするのを無上の栄華として楽しんでいた。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし前者でも太陽神マルドゥクが万象並びにまた諸神の主権者として現われている点から見ればやはり一神的の傾向をも帯びている。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽神ラー（Ra）もまた原始水の中で一つの蓮華の莟の中に隠されていたが、創世の日にこの蓮の花弁が開きラーが出現して天における彼の座を占めた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四図　太陽神が創造の際開きかかった蓮華から出現する図。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、古来の数限りもない神々の眷属は一切これを破棄し、唯一の神アテン（Aten）、すなわち、太陽神のみを認めようという宣言を下した。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下に太陽神に対する美しい賛美歌を挙げる。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツァラトゥストラの信徒にとっては、太陽が、最も重要な光として、その崇拝の主要な対象であったことは、ちょうどバビロニア人における太陽神マルドゥクと同様であった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "このシン（Sin）というのは月の神で、シャマシュ（Shamash）は太陽神である。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀元前二〇〇〇年ころに至って、初めて、以前にあの木星の支配者であったところの、バビロンでは特別に大事な神様マルドゥクが、シンやシャマシュに取って代わり、自ら太陽神として何よりも崇ばれるようになったのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽や遊星が十二宮の獣帯に各一〇日ずつに配された三六の星宿の間を縫うて運行する経路が図表中に記入され、そういうものが最も古い時代から太陽神ラー（Ra）の神殿に仕える僧侶たちによって集積された。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、この村には氏神様として太陽神である天照大神を祀っているとても美しい神社と、それに桑畑の中に蚕の神様を祀る小さな祠がある。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも女王様の寝棺の中に秘め置かれた髪切虫か、※河馬にも喰われず、太陽神にも叱られずに二千年後の今日、輪廻転生の道理に恵まれて、呼吸を吹返して来たものか、その辺のところがサッパリ判明しなかったが、やがて間もなく、そんな事はどうでもいい事に気が付いたので、髪切虫は一層、朗かになった。",
              "citation": {
                "source": "髪切虫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "籠は即、太陽神を象り、髯は後光を象徴したものといふ次第なのである。",
              "citation": {
                "source": "盆踊りと祭屋台と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天帝（太陽神）の居る天城で、あまみきょ・しねりきょも其処から来たものである。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "台湾には、みさちだと言ふ太陽神がある。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "琉球では、太陽神の他に、自然崇拝そのまゝの形を残して居る。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も其中、最大切に考へられてゐるのは、井の神・家の神・五穀の神・太陽神・御嶽の神・骨霊などである。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "御すぢの御前は、琉球最初の陰陽神たるあまみきょ・しねりきょの親神なる太陽神即、御日の御前を、祖先神と見たのだと解釈せられよう。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "国王を、天加那志（又は、おちだがなし、首里ちだがなし）と言ふのも、王者を太陽神の化現即、内地の古語で言へば、日のみ子と見たのであるらしい。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、神に扮してゐるのは事実であつて、其が火の神ではなく、太陽神若しくは、にれえ神と考へられてゐる様である。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し我古代生活に於て、最偉大なる信仰の対象は、やはり太陽神であつた。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "語部の物語には、種々な神々の種々な職掌の分化を伝へてゐるが、純乎たる太陽神崇拝の時代から、職掌分化の時代に至る迄には、或過程を頭に入れて考へねばなるまいと思ふ。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論原始的な太陽神崇拝の時代でも、他の神々の信仰は無かつたと言ふのではない。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し此赫奕たる太陽神も、単に大空に懸りいますとばかりでは、古代人の生活とは、霊的に交渉が乏しくなりやすい。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "茲に自分は、太陽神の形代製作に費された我祖先の苦心を語るべき機会に出遭つた。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤後世になつては、地神のよりしろをも木や柱の尖に結び附けたことはあつたが、古代人の考へとしては、雲路を通ふ神には、必或部分まで太陽神の素質が含まれて居たのであるから、今日遺つて居る髯籠の形こそ、最大昔の形に近いものであるかと思ふ。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れは人間でも、浮浪人は悪い事を犯し易い不安定状態に在る如く、浮浪神も亦何時何処に割り込んで来て、神山を占めんとするやら計り難い故に、旁太陽神の御像ならば、睨み返しも十分で安心と言ふ考へであつたかと思はれる。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此で見ても、わが国の神々の属性にも、存外古い種を残してゐたので、太陽神の祭りにすら、暁には神上げをしなければならなかつた位であつた。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体ひげこは日の子の音転で、太陽神の姿を模したのだ、と老人たちは伝へて居るが、恐らくは、竪棒の上に、髯籠の飾りをとりつけて居たのが、段々意匠化せられて出来た（髯籠の話参照）ものか。",
              "citation": {
                "source": "だいがくの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが国の神々の属性にも存外古い種を残してゐるので、太陽神と信じて来た至上神の祭りにすら、暁には神上げをしなければならなかつた。",
              "citation": {
                "source": "古代生活の研究",
                "author": "常世の国",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
