[
  {
    "uuid": "7c9154d4-78c6-54d7-b907-f1de43fd0363",
    "entry": "太陽神",
    "reading": {
      "primary": "たいようしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
