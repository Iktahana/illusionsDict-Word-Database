        "examples": {
          "standard": [
            {
              "text": "運動会の入場行進で、生徒たちは一列の単従陣を組んで堂々と歩みを進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "狭い山道を通る際は、安全を確保するために全員が単従陣になるよう指示された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "単従陣で森の中を進む兵士たちは、足音を殺しながら敵の気配を探った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
