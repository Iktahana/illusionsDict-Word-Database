          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "キャバクラの看板を持った立ちんぼが、「お兄さん、安くしとくよ」としつこく声をかけてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「客引きの立ちんぼについて行ったら、法外な料金を請求された」という被害報告が絶えない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "商店街の入り口で、怪しげなマッサージ店のチラシを配る立ちんぼが通行人を物色していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 5,
        "gloss": "street drug pusher",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
