        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "会社から帰ると、女中がわりに立ち働く。",
              "citation": {
                "source": "犯人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時この人々は濃紫のおふさが木綿著物に襷を掛けて、かいがいしく立ち働くのを見て感心したそうである。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "をぢの部屋には久しく立ち働く音聞えしが、今は人あまた集へりと覺しく、さま／″＼の聲して、戸の隙よりは光もさしたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い服を着て立ち働く看護婦も其當座僕の目には大抵よく見えたのである。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎から出た娘のようではなく、何事にも好く気が附いて、好く立ち働くので、お蝶はお客の褒めものになっている。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "国から来た親類には、随分やかましい事を言われる様子で、お蝶はいつも神妙に俯向いて話を聞いていても、その人を帰した跡では、直ぐ何事もなかったように弾力を回復して、元気よく立ち働く。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その様子は隣人の不幸をいたむというよりも、むしろ、多勢の人の中で、立ち働く機会が降って湧いたのを喜んでいるという風だった。",
              "citation": {
                "source": "誰が何故彼を殺したか",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "……出て行く者、はいって来る者、女は女で立ち働き、男は男で立ち働く。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすまた、もじり、棒、まさかり、こういうものだって馬鹿には出来ねえ、出来るだけ手入れをするがいい」　副頭領の楠右衛門、四人の小頭、十人衆、いわゆる家の子郎党が、クルクルクルクルと立ち働く。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日のうち何時間かを組合の事務所で立ち働くやうになつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いそいそと立ち働くお新が居る。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして黒柿の長手の火鉢や、古い馴染の箪笥はおろか、池の茶屋の料理場の片隅に皆の立ち働くところを眺めることさえ邪魔になるように思われて、ゆっくり腰の掛けられそうな椅子一つ彼女を待っていなかった。",
              "citation": {
                "source": "食堂",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち働く時のキリリとしたお国とは思えぬくらいであった。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこのどんな家のものだか知れないような女連の中に交じって立ち働くのも厭なようで、自分にもそれほど気が進んでもいなかったが、日本橋の方へ帰って、気むずかしい老人夫婦ばかりの、陰気な奥の方を勤めるのも張合いがなかった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十七　翌朝になると、お増は毎朝お今のすることに決まっている浅井のお膳拵えなどを、自分の手に一つに引き取って、さも自信のありそうな様子で、こまこまと立ち働くのであった。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけてそこに立ち働く若い理髪師達の異動のはげしさはいわずもがな、そこの主人の細君でさえ、中頃から違った人になった。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上に帝政復興の寄附金を集める箱が傾いてかかっている下で、ボーイの立ち働く姿を見ながら、少しでも使用人の袖口から襯衣が出すぎているのを見附けると、夫人は黙って指差して直させた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は戦々兢々として馳け違いながら立ち働く兵士たちの間から、暇ある度に卑弥呼の部屋へ戻って来た。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は無電小僧なんて名乗った事はないが、人がそういうのは多分俺の事と思うが、そういってくれる通りどこから入ったか、どこから出たか分からぬように立ち働くのが俺の腕の勝れた所で、俺は人に姿を見られた事はない。",
              "citation": {
                "source": "ニッケルの文鎮",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて言われるままに立ち働く。",
              "citation": {
                "source": "太宰治との一日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "女手は女中一人きりなので、さっちゃんがまたなにかと立ち働く。",
              "citation": {
                "source": "太宰治との一日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "千世子は病気の時いつもする様にきれいな様子をして居たけれ共先よりは重いと見えてじょうだん口もきかずにぶい目で天井の木目を見て居たり人の立ち働くのを見たりして居るのが多かった。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔭日向なく立ち働くのであった。",
              "citation": {
                "source": "国事犯の行方",
                "author": "―破獄の志士赤井景韶―",
                "note": "青空文庫"
              }
            },
            {
              "text": "外の光も知らぬげに与里は六畳に伏せつており、台所には立ち働く総江の姿を見ることができたが、玄也夫妻は見当らぬし、老婆も多次郎も姿が無かつた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴婦人は台所で立ち働く習慣がないからだ。",
              "citation": {
                "source": "味覚馬鹿",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "本陣の囲炉裏ばたには、栄吉、清助をはじめ、出入りの百姓や下男の佐吉を相手に立ち働くおまんだけが残った。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は旅籠屋の廊下に出て旅の荷物を始末したり、台所の方へ行って半蔵のためにぬれた合羽を乾したりして、そういう方にまめまめと立ち働くことを得意とした。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ謹んでお指図のままに立ち働くつもりでござります」「うむ、よく申した、そうなくてはならぬ。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の娘にやあらむ、まめ／＼しくたちはたらくさまの可愛らしきが、一目眇して、よそのみる目も心苦し。",
              "citation": {
                "source": "八鹽のいでゆ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
