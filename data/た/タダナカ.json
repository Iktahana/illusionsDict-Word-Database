        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それがために暗黒アフリカの真只中にロンドン製品の包紙がちらばるようなことになる。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、旗を……　しかし、その旗はみるみる光りはじめ、躍り上がり、大きくなり、眞赤になりだした……　………………………………………　いましも、彼等の旗は敵の眞只中で燃えだしてゐるのだ。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、彼はその眞只中へ自分の馬を躍り入らせた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "戀人は自分の戀の眞只中にゐる。",
              "citation": {
                "source": "窓",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ばか……どこまで行くんだ……ばか、きちがい……小初……先生……小初先生……ばか……ばか……」　風の加った雨脚の激しい海の真只中だ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど「泥中の蓮の花」のように、雑多な野心や誘惑や愛欲の真只中に生活しながらもその汚れに染まず、しかもその欲望、誘惑をうまく消化善用して立派な人格完成、絶対の安心、無上の幸福という花を咲かせるのです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "堕落が来たら堕落のまっ只中に割って入り堕落を怖れぬ勇気あってはじめて現実の理想化が行える。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一筋の道は、湖の只中を霞の渡るように思われた。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし貴下は、唯今うけたまわりましたような可怖い只中に、よく御辛抱なさいます、実に大胆でおいでなさる。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真只中を細い一筋の川――だが近よつて見ると細くはない。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞ひすましたる男の、真只中をひやうつと射て、舟底へ真逆様に射倒す。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲角の青大将と、この傍なる菜の花の中の赤楝蛇と、向うの馬の面とへ線を引くと、細長い三角形の只中へ、封じ籠められた形になる。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲と立罩める名聲の只中に、名人紀昌は次第に老いて行く。",
              "citation": {
                "source": "名人傳",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大さ、大洋の只中に計り知れぬが、巨大なる※の浮いたので、近々と嘲けるような黄色な目、二丈にも余る青い口で、ニヤリとしてやがて沈んだ。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "功徳、恭養、善行、美事、その只中を狙うのが、悪魔の役です。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いうまでもないが、このビルジングを、礎から貫いた階子の、さながら只中に当っていた。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした傾向の中心たる東京の真只中で窮乏に安んじながら能楽を捨てなかった翁の恩師能静氏の如きは実に鶏群中の一鶴と称すべきであったろう。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮令それが惚れたはれたの真只中、浮いた浮いたの真最中でも、相手の女性はこの感得力だけは別にチャンと取っておいて、暗黙の裡に男性の心理状態を研究し続けているものであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……此美女御寵愛のうち、なほ／＼身の曇を去て、月の都の只中に住玉ひぬとある。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　まざまざと見るには堪えぬから、その布で包んだまま、ただ結目を解いただけで、密と取って、骨を広葉の只中へ。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽船が沖に浮んだ時に佐渡が島も海洋の只中に悠然として青く横はつた。",
              "citation": {
                "source": "佐渡が島",
                "author": "波の上",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸福なことに、玲子様も私もこの人生の只中に投げ出されても哀しい破局を避けるだけの理性は有つてをるつもりですが、まだまだ若い私たちですもの。",
              "citation": {
                "source": "〔婦人手紙範例文〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨブは大苦難の真只中にありて前後左右を暗黒に囲まれつつ、一縷この光明を抱いたのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲は騒ぎ、その混沌は物理的に言つても、物質の衝突の只中では却つて動かないものに、中芯が集るものである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、彼等の前に何か邪魔ものが出たとしたら、それがどんなものであらうと、騎兵の一隊が敵陣の眞只中に飛び込んで、馬の蹄で縱横に蹴ちらすやうに、一氣にやつつけたかも知れない。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより盲人であるから、暗いも明るいも頓着はあるまいが、それにしてもこの暗い雨のなかで、勢いよく跳ねまわっている大きい魚をつかまえて、手探りながらにその眼のまっ只中を突き透したのは、世のつねの手練でない。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、学校に出かけることは殆どなく、たいがい例の喧騒の真只中にある風変りな自宅でしめやかに暮していた。",
              "citation": {
                "source": "生きている腸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常に愕くべき出来事の真只中に今自分たちが置かれているのだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、いよいよ船が桟橋について、彼が舷梯を駆下り、花束美人の真只中へ突入してみたところ、意外にも誰一人として彼の胸に花束を持って飛びついてくる女性がいなかったのである。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、かわいそうなゲルダは、靴もなく、手袋もなく、見わたすかぎり氷の原の、寒い寒いフィンマルケンの、まっただなかに、取りのこされたのです。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
