          "literary": [
            {
              "text": "使命を自覚したる者は権威の体現者なり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、生涯寂しい孤独に住まわれた神の使命の体現者クリストのその信仰は、万人の胸に生き来る真理でありました。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "四季の体現者としての夏子。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポワレはかつて役人で、疑いもなく市民道徳の体現者、それでいて思想は持たないといった人間だった。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "――五指は彼の部下であり、五指をもって一拳の力となすには、自身、陣頭に立つことであるを知っている統率の体現者であった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
