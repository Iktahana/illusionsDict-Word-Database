        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "六月十日木戸一郎　　井原退蔵様　拝復。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二十日木戸一郎　　井原退蔵様　前略。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五日井原退蔵　　木戸一郎様　謹啓。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月三十日木戸一郎　　井原退蔵様　拝復。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月三日井原退蔵　　木戸一郎様　拝啓。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木戸一郎　　井原退蔵様　木戸君。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月九日井原退蔵　謹啓。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十六日木戸一郎　　井原退蔵様　拝復。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十六年八月十九日井原退蔵　　木戸一郎様",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都なんて隠退蔵物資みたいなもンだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは、その復興がなぜこんなに進まないのかという原因について研究し、資本家のサボタージュや、生産資材の隠退蔵に重大な原因を発見した。",
              "citation": {
                "source": "ほうき一本",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国会で隠退蔵物資特別調査委員会が出来たことは、政府も権力をもちつづけようとするためには、安定本部の理論数字で現実はごまかしきれないことを認めて来た証拠である。",
              "citation": {
                "source": "ほうき一本",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞の多くの漫画は小さなヤミ買出し人が背中の荷物で警官にきびしく調べられている横を隠退蔵物資のトラックが堂々と走って行く光景を諷刺した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊勢国｜薦野の人、黒沢退蔵の子で、休庵の長女の婿となつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "先霊名録に従へば、伊勢国薦野の人黒沢退蔵の子であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼らが同じころ政策のスローガンにかかげたことはと云えば、隠退蔵物資のテキハツだの遊休大邸宅の解放などと、スパイの中でも三下奴がやるようなことしかやれなかったのである。",
              "citation": {
                "source": "戦後合格者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　書物の文化政策　書物の退蔵の現象については実例はいくらでもある。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "私有図書の退蔵ばかりではなく、却って公有官有の図書の退蔵の方がいちじるしい現象でさえあるように見える。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろこの点では私有図書の退蔵の方が社会的に恕すべき点が多い位いだろう。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "書籍の退蔵などは驚くに値いしないのである。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "この隠退蔵物資の山の奥に、半死半生の姿で、美しいお萩は隠されておりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "棟梁の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "申告すべき退蔵物資の十六種目一覧表も載った。",
              "citation": {
                "source": "モラトリアム質疑",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
