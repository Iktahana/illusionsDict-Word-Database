  {
    "uuid": "544ffb52-15e5-5d08-847f-78f22718825e",
    "entry": "蛸",
    "reading": {
      "primary": "タコ",
      "alternatives": [
        "たこ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
