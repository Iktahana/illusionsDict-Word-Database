      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "callus",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やがて皮削ぎ庖丁や縫針で、胼胝の出来た手で、鼓や太鼓の撥をもち、踊りも、梅にも春や藤娘、お座敷を間に合わせるくらいに仕込まれた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣の肩は陽にやけ、足には草鞋の胼胝ができた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼈四郎が向き嵌って行ったのはそういう苦労｜胼胝で心の感膜が厚くなっている年長の連中であった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "掌に胼胝の痕が遺つてゐるさ。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り眼を近づけて書物ばかり読んでいるので、彼の鷲形の鼻の先は、粘土板と擦れ合って固い胼胝が出来ている。",
              "citation": {
                "source": "文字禍",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『採掘作業をかなりやったことが、その胼胝から。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨子の弟子の禽滑釐が日に焦げ黒み、手足胼胝して苦學したといふが如きも、たゞ室内に在つて道を聞き教を受けるのでは然樣いふことになる譯は無い、工學的の實際を敢てしたればこそ然樣なるのであつて、然樣して其學成就すれば「巨子」となるのである。",
              "citation": {
                "source": "墨子",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした中を抜けつくぐりつ営業する真面目な職業婦人や、何々会なぞのやりにくさといったらないそうで、そんな不平は到る処耳に胼胝である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すみませんが、ちょっとあなたのてのひらを見せて下さい」　――ああ東屋氏は、てのひらの胼胝で怪人物を突き止めるつもりだ。",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、三田村技手のてのひらには胼胝は出来ていなかった。",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは面白くなって来た、と思ったのも束の間、やっぱり風間老人のてのひらにも胼胝は出来ていなかったと見えて、やがて老看守は倉庫の中へ入り、東屋氏は、今度は官舎のほうへ出掛けて行った。",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにてのひら……うん、小使にも細君にも、胼胝などは出来ていなかったよ」「じゃあ、やっぱり妖怪の……」「いや、まあ待ちたまえ……ぼくはそれから、そのお隣の風間さんの官舎へ、ちょっと失礼して上らしてもらったんだ、もちろん娘さんに逢うつもりでね……そしてそこで、大発見をした！",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃあ、寝ている娘のミドリさんのてのひらに胼胝でもあったんですか？",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には幾つかの胼胝も含まれる。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "被害者は掌中に幾つもの胼胝を作りながら、夢中でバルーンを降してしまいました。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら大きな胼胝らしい。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うだけならいいんですが、その『トントン』の足裏に、畳を凹ますほどにいつも擦りつけていたその足裏に、胼胝がなかったりして、駄目になったんです。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "トン／＼トン／＼と店の方で打つ経師屋らしい糊刷毛の音は、寝胼胝のあたつた内儀さんの身体に響けて来る。",
              "citation": {
                "source": "死の床",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "休日にもまだ炭の粉や器械油の附いてゐる、胼胝の出来た手が鳴る。",
              "citation": {
                "source": "防火栓",
                "author": "DAS GROBE VERGNUGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "罅の入つた斑點に汚れた黄色い壁に向つて、これからの生涯を過去の所爲と罪報とに項低れ乍ら、足に胼胝の出來るまで坐り通したら奈何だと魔の聲にでも決斷の臍を囁かれるやうな思ひを、圭一郎は日毎に繰返し押詰めて考へさせられた。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕なんぞはもういい加減耳に胼胝が出来てもよさそうな筈だが、一向聞き倦きもせずに、にこにこしながら会槌を打っているのだから、これも不思議だ。",
              "citation": {
                "source": "雉子日記",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の蹠の胼胝を丹念に鋏で切り取るのだ。",
              "citation": {
                "source": "公孫樹",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "胼胝といっても、踵やなんかに出来るのではなくて、小指の根本の蹠に、五十銭銀貨くらいの大きさに、まんまるく出来るのだった。",
              "citation": {
                "source": "公孫樹",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵日曜日やなんか、比較的朝遅く起き上る日、飯を食って新聞などを見てしまうと、それから、朝日のさしてる座敷の縁側で、ゆっくりと足の胼胝を切りにかかった。",
              "citation": {
                "source": "公孫樹",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "時によると、父は縁側に長く寝転んで、母や女中達に胼胝を切らせることもあった。",
              "citation": {
                "source": "公孫樹",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　父にとっては、蹠の胼胝を切り取ることは、髪を刈ったり入浴したりすることなんかよりも、もっと精神を爽快になすかのようだった。",
              "citation": {
                "source": "公孫樹",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためだかどうだか分らないが、足の胼胝の皮は必ずまとめて、庭の隅の大事な公孫樹の根本に埋めることになっていた。",
              "citation": {
                "source": "公孫樹",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十銭銀貨大の胼胝を薄く切り取ったものだから、円めても小指の先ほどしかなかった。",
              "citation": {
                "source": "公孫樹",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「半蔵さん、わたしはもう胼胝をこしらえてしまった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は悲劇をみて泣いたことはない悲劇に遭遇したことのある自分を発見したゞけであつた。",
              "citation": {
                "source": "（最も純粋に意地悪い奴）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
