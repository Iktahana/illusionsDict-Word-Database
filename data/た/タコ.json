[
  {
    "uuid": "8da0a2ad-6982-5b15-906e-f6d131bbb93a",
    "entry": "胼胝",
    "reading": {
      "primary": "たこ",
      "alternatives": [
        "タコ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
