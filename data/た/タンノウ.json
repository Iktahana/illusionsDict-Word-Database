[
  {
    "uuid": "dc6b54b3-d70c-5c1c-ac17-f39f96c3de3f",
    "entry": "堪能",
    "reading": {
      "primary": "たんのう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
