      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "proficient",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "技術堪能そのものが登用される場合は極めて稀であります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "オットセイは鼻の頭で鞠をつく芸当に堪能である。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋音楽は自分では分らないと云っていたが、音楽に堪能な令息｜恭雄氏の話によると相当な批判力をもっていたそうである。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、母親は、子供に堪能するだけ甘いものを与えなかった。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "和歌は勿論堪能の人であった。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "就中琵琶に堪能で、娘に手をひかれながら、宿屋々々に請ぜられて、安かに、親娘を過ごすようになった。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘も母親のありあまる愛情に堪能していた。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "見事に刻まれた唇、青空の如く深く晴れやかな瞳、豊かな金色の捲毛、ドリアンは自分の美しさに初めて堪能した。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お前が、お前一人で、僕を堪能させてくれなかったからいけないのだ。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人は、海にむかって硝子戸を立てめぐらした座敷で、熱臭い蒲団に落ち込んだ胸をくるんで、潮風の湿気のために白く錆びついた天井を見つめた儘、空咳をせきながら、幸子の心づくしに堪能していたが、それでも覚束ない程感動し易くなっていたので、時々幸子を手古摺らせた。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は胃の腑も強壯な筈だから、ウンと堪能するさ。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "久能の出入り先で今大路という堂上方の家に綾姫という小鼓に堪能な美人がいた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "予、幼時より勾当の名を聞くこと久しかりしも、唯、音楽に堪能なりし盲人とのみ思い居たりき。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士はそこに腰をおろして、「たいそう御堪能と拝しました。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "食い終って一通り堪能したと見え、彼は焜炉の口を閉じはじめて霰の庭を眺め遣った。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにて、この条条を極めさとりて、かんのう（堪能）になれば、定めて天下にゆるされ、めいぼう（名望）を得つべし。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも和歌までも堪能で、男ぶりは何様だったか、ひょろりとして丈高く、さし肩であったと云われるから、ポッチャリとした御公卿さん達の好い男子では無かったろうと思われる。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "横田聞きも果てず、いかにも某は茶事の心得なし、一徹なる武辺者なり、諸芸に堪能なるお手前の表芸が見たしと申すや否や、つと立ち上がり、脇差を抜きて投げつけ候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "相役聞きも果てず、いかにも某は茶事の心得なし、一徹なる武辺者なり、諸芸に堪能なるお手前の表芸が見たしと申すや否や、つと立ち上がり、旅館の床の間なる刀掛より刀を取り、抜打に切つけ候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "太鼓に堪能で喜多流の大家であったというような話を筆者が幼少の時代に祖父から聞き伝えているところから考えると、喜多流なる流派の存在は現在伝うるところよりもズット古く戦国時代から既に存在していて、九州地方にも流行していた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時の在京中藩公の御前は勿論、喜多流の能楽堪能（皆伝）と聞こえた藤堂伯邸へも度々召出されて御能、お囃子等を仰付られた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、従来の朝廷の高官は、藤原氏の人々で、必ずしも練達堪能の士ではないので、新らしい人材を抜擢して、実際的な政治を行ふために、院政と云つた形式が案出されたのではなからうか。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかげで美しいダートムアの空気を少々堪能できました。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　婦女雑誌には彼女が英語に堪能だなどゝ誌してあつたが、彼女の語学の力は二年の中学生にも劣るものだつた。",
              "citation": {
                "source": "小川の流れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉山氏は、漢詩を作つたり南画を描くことに堪能だつた。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう伊左衛門には堪能いたしておるわ。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "長十郎　藤十郎の紙衣姿も、毎年見ると、少しは堪能し過ぎると、悪口をいいくさった公卿衆だちも、今度の新しい狂言にはさぞ駭くことでござりましょう。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "凄艶な面に冷たい笑いを浮べながら、道行く人を物色していましたが、丁度通りかかったのは、夕遊びでもうひと堪能して来たらしい京男でした。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋にたんのうし生活にたんのうしもうこの上何の動きも必要としない境地に落ちついた間柄に見える。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は久し振りにたんのうした。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
