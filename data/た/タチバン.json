        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どの家にも変な日本人が立ち番している。",
              "citation": {
                "source": "防備隊",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "外には二名の警官が立ち番をしているらしかった。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こんなことがあるだろうと、予め屋上の所々に立ち番をしていた守衛は、「こら、こら！",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸のところに誰か立ち番していて、外からあけようとすると、「一寸だめだよ！",
              "citation": {
                "source": "ソヴェト同盟の三月八日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ困つたことをして呉れた……」　建長寺の電話を借りて停車場前の自動車屋にかけさせ、井出君も起して私たちは顏を洗つて自動車の來るのを待つたが、なかなか來ないので、往來まで出て待つことにして二人で出かけたが、往來の門のところで若い巡査が一人立ち番してゐた。",
              "citation": {
                "source": "不良兒",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきの仙太郎が蒼い顔をして入口に立ち番をしていた。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "宇治の茶箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関の扉口に先程からいやな面をした刑事が立ち番をしているし、玄関の間のあの不幸な窓を除くほかどの窓も全部内側から固く施錠されている。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはいつも立ち番をいひつけられた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリユスは終日待っていて、それからまた窓の下の夜の立ち番をした。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、明智探偵の目のさしずにしたがって、入口のドアと、二つの窓の前に、ひとりずつ立ち番をはじめました。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の前に六区の交番があって、色の白い美男のおまわりさんが立ち番をしている。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔵の外の三方には、お巡りさんがふたりずつ立ち番をしています。",
              "citation": {
                "source": "青銅の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから二つの出入り口だけでも、十人の店員が、立ち番をつとめていましたし、ちんれつ室の中にも、ガラスばりのちんれつ台二つにひとりのわりあいで、女店員が見はり番をしていました。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓はぜんぶしめきって、ドアには中からかぎをかけ、壁のだんろの前には、さっきの書生が棍棒を手にして、立ち番をしていました。",
              "citation": {
                "source": "夜光人間",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクサーの青年が、ドアの外と、庭に、ひとりずつ立ち番をしています。",
              "citation": {
                "source": "探偵少年",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
