        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこでこの宇野が黄色い気違いの顔で美しいバラ（何か赤いバラとしか思えず）をたべたところ、白い美しい女の手をかじったところ、非常にタッチングではないか。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "水に濡れたような正真の烏黒に、エメラルド色の細かい斑がいちめんにちらばったところなどは、どう見ても、青い色糸でタッチングしたロシア天鵞絨の感じである。",
              "citation": {
                "source": "春の山",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとともにマッサージ（いろいろな変更型、軽いタッチからタッチングおよび踏み付けまで）、水治療（冷水浴、冷水温水の噴霧、薬湯、高温浴、蒸気浴）、飲水。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
