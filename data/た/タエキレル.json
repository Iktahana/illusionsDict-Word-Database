          "literary": [
            {
              "text": "どんな強い人間だって、むき出しの真実には耐えきれるもんじゃない。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "陥没を陥没のままに捨て置いて、その上に立っていることはとても耐えきれることではありません。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人の勝豊には、耐えきれるところではない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "でなければ、ふつうの人間に、そんなおそろしいことがたえきれるはずがないんだ）と、思っていた。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            }
