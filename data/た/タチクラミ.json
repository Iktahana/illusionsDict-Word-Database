    "definitions": [
      {
        "index": 1,
        "gloss": "dizziness (from standing up too fast)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
