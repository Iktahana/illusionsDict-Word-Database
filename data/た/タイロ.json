[
  {
    "uuid": "3c5bd7fc-69e8-5cc3-9af6-63ad61778db5",
    "entry": "退路",
    "reading": {
      "primary": "たいろ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "path of retreat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "赤旗が退路を遮った。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の退路は、張督弁にふさがれていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、犬は、彼らの退路をも遮っていた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謙信が、海津城を尻目にかけ、わざと敵中深く入ると、信玄はまたそれを尻目にかけて、敵の退路を断ってしまったわけである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ評定に入るや、かの好漢忠次真先に、鳶ヶ巣以下の諸塁を夜襲し、併せて武田勢の退路を断たんことを提議した。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸が締め付けられるような感覚……「退路はただ一つ。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "財布の口を絞められて追い詰められたおっさんは、息子たちの退路を断つために工場に火を付け、ついに精神病院に閉じ込められて幕となる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は、そういってはなんだが、たかが女ふたりだし、退路を断たれたわけでもないのだから、いくらでも逃げられたはずだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は退路というものを持っていない。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれで今迄に残されていた最後の個人的生活の退路――肉親との関係を断ち切ってしまった。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "墺軍はこれに追尾し来たり、九月三十日ゾール附近に於て大王の退路近くに現出した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一の場合退路を遮られないように、同時に、軍の全勢力を自由に働かせ得るように、地勢を調べて中央部となるべきスーラーブの野羊革の大天幕が張られた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その最後の時は、前日に二三の友人に伴はれて、かの青葉城のうしろにある、政宗の立退路と云はれる谷へ、化石を拾ひに行つた。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは本町を西に進んで、迂廻して敵の退路を絶たうと云ふ計画であつた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "退路は瀬戸の方向へ取ることになった。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学への進学を拒否し、退路を断ったところで、ヨーコとの、そしてヒカルとの共和国づくりを夢みた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "何やらわけの分からない、海の物とも山の物とも知れぬ存在に飛びついていくのは、退路を断たれ、行くあてのない決死の人たちだけでしょう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "退路を断たれたままの、憤死です。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき俺たちの隊が退路にまよい、北へ北へといってヴィクトア・ニールにでた。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "自ら退路を断って、死地に身を投じたのだ。",
              "citation": {
                "source": "風景",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "襷に、鉢巻、足許を調べて、「亭主、勘定」　武右衛門と孫右衛門は左角の鍵屋の軒へ忍んで北谷口で逸する敵の退路を切取ると共に先頭に立つ一人を斬る。",
              "citation": {
                "source": "鍵屋の辻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "平馬は、わざと、平然たる態度をよそおおうとして、くわえていた銀煙管の吸口を、噛みつぶすばかり、ギリギリと、噛んで、雪之丞の退路を絶とうと、背後に押し並ばせた、おのが門弟どもに、あたるように、「貴さまたち、何を愚図愚図、それ、引ッ包んで、かまわぬ、斬れ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "船で敵国に上陸して、自分の船を焼き払って退路を断ち、敵地を征服するか戦死するか、どちらかだという、最後の肚をきめることだ。",
              "citation": {
                "source": "別れの辞",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……彼奴らの船だってどこかにあろう、その船を奪って退路を断ち、彼奴らに狼狽させなければならない！",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔のこと、遠い国のこと、知らない土地を占領に出かけた勇敢な人々は、海を渡って来た自分の船をそこで焼き捨てて、帰りの退路を自分で絶ち切ってしまったとか。",
              "citation": {
                "source": "高尾ざんげ",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵の退路へ退路へと迫るわが攻撃作戦の効果が察せられる。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇妙な形をしたいろいろの巨きな岩、滝――女体の峯から戻って来る道には、そういう目の慰みになるものもあった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は見違えるほど体など肥って来たようだがね」　事実、柚木はもとよりいい体格の青年が、ふーっと膨れるように脂肪がついて、坊ちゃんらしくなり、茶色の瞳の眼の上瞼の腫れ具合や、顎が二重に括れて来たところに艶めいたいろさえつけていた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこらから小さな〔嘆息〕やいのりの声が聞えジョバンニもカムパネルラもいままで忘れてゐたいろいろのことをぼんやり思ひ出して眼が熱くなりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「え」音を含む一々の語について、その「え」にどういう万葉仮名が使われているかということを調べてみると、同じ「え」の仮名だと思っていたいろいろの万葉仮名がちゃんと二類に分れているということが見付かったのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
