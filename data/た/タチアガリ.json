[
  {
    "uuid": "030dc1f4-8039-5e38-9437-fecb2f21c765",
    "entry": "裁ち上がり",
    "reading": {
      "primary": "たちあがり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
