        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "わたくしが枕山の女芳樹女史を訪うて親しく聞いた所によると、捨吉は叔父次郎右衛門とは折合がよくなかったので、僅少の金子をふところにして家を出で道中辛苦して尾張に往ったという話である。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでにこないだも東の紙屋の若い奴が、桜木町である女と出来合って、意気事を極めるちゅうから、癪に障ってな、いろいろ験べたが何事もないで、為方がない、内に居る母親が寺｜参をするのに木綿を着せて、汝が傾城買をするのに絹を纏うのは何たることじゃ、という廉をもって、説諭をくらわした。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日からは土塀の方の手が足らんちゅうから、あちらの手伝いに廻ったろかい』信徒二『そやそや。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ただで見せるちゅうからやらずばなんめえてやったら、七銭とられただよ」「しようねえな。",
              "citation": {
                "source": "飛行機の下の村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな人だか、誰知るものもねえだが」「その人がね、昨日の朝見えたゞよ」「不意にかよ」「ウンニャ、前触れがあってね、掃除さしといて呉れちゅうから俺、ちゃんとしといたゞ」「一人で来たのかよ」「ウン、顔の蒼白え若え人でな。",
              "citation": {
                "source": "青服の男",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで蜂矢はとちゅうからひきかえした。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "山ノ井の千ちゃんは、あきれてしまって、とちゅうからもうだまっていることにして、しきりに暗視テレビジョンのちょうしをかえながら艇外へするどい注意力をあつめている。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪は女子の宝だって、平吉が講釈で聞いたちゅうから、おらいつでもよく洗ってるだよ。",
              "citation": {
                "source": "特殊部落の犯罪",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "六兵衛は、その生まれつきの馬鹿のために、仲間からしょっちゅうからかわれて、とんまの六兵衛というあだ名をつけられていました。",
              "citation": {
                "source": "とんまの六兵衛",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ出発しても、天気がわるくなったら、すぐとちゅうからひき返して、気長に天気のよくなるのを待つようにすること。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたは、そそっかしやじゃけ、すぐ、勘ちがいして、困る」「今売り出しの吉田親分を、お前らのような若僧が、蹴ったちゅうから、おれは、かけつけて来たんじゃ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドテラ婆」の一味が、邪魔に入るかも知れんちゅうから、当りまえではいかん。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢数はひょうひょうと虹のごとく放たれたが、時間はほんの瞬間、すでに大鷲は町の空を斜めによぎって、その雄姿を琵琶湖のほうへかけらせたが、なにか白い物をとちゅうからヒラヒラと落としさった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、世の中はゆだんがならない、その男はとちゅうからつけだしたのではなく、じつは、安土の城からくっついてきているのだ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、あの人は見たことがあるぜ」　ものかげにいた蛾次郎は、目をみはって、その馬上を見おくったが、ふと気がついて、「そうだ、そうだ」とばかり、あとからつづく人数のなかにまぎれこみ、まんまと、八風斎の目をくらまして越前落ちのとちゅうから、もとの裾野へ逃げてもどってしまった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ところが、一しょにおちてきた可児才蔵は、こんな狼連につきまとわれては大へんと、いちはやく、とちゅうから姿をかくし、一足さきに上方へ立っていったのである。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ア、ア、あッ……」　と、不安そうに見おくる少女たちの視界をはなれて、とちゅうから、脱兎のごとく駈けてしまった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「したが、加賀爪伝内の遠矢が、額ぶちにりっぱに立っているのに、貴公の矢が鳥居の柱にも立っていないのはどうしたしだいか、これ、弓勢たらずして、矢走りのとちゅうから、谷間へおちた証拠ではあるまいか」　というのは、徳川方の強弁だった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
