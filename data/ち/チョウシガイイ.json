        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "調子がいいぞ、とにやにやしてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）まず恐しく調子がいいじゃて。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めにだいたいの肉色と影をつけてしまった時には、似てはいないがたいへん感じのいいような顔ができたのでこれは調子がいいと思って多少気乗りがして来た。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『まあ――調子がいいわね。",
              "citation": {
                "source": "ああ華族様だよ　と私は嘘を吐くのであった",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬もたいへん調子がいいようで。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポクポクポクポク、なかなかその調子がいい。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬は非常に調子がいいようです。",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中屋の後家も一時から見ると大分調子がいいやうぢゃねえか？",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌は蓋し調子がいいからであらう、それ程即ち「大硯」が供へつけられる程有名な歌であつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもならこの辺へ来るまでに疲れて墜ちてしまう筈なのに、今度は莫迦に調子がいい。",
              "citation": {
                "source": "火を喰つた鴉",
                "author": "逸見猶吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑顔はあまり見せないが、声は調子がいい。",
              "citation": {
                "source": "悲しい誤解",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし原住民の片言の日本語よりは、ずっと調子がいい。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは諸君を初めての案内であったから、終日野山をかけめぐって只一つの巣を見つけただけであるけれど、調子がいいと一日に三つや四つ採るのはむずかしくない。",
              "citation": {
                "source": "採峰徘菌愚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前ンとこの師匠は人前でばかり調子がいいから、だからいやさ」　ある晩、連雀町の白梅の楽屋で浅草亭馬道がこういったときも、泣いて小圓太はつっかかっていって、「分った分った俺が悪かった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そういうものなんですか」「要視察人と話しているところを見られると、あとがうるさくてね、仕事がしにくくなって困ります」「いやどうも」　大貫は笑って、「そうそう、その調子がいいですよ。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとも、御遠慮はいりませんから、なんなりとおっしゃっていただきとう存じます」　顎十郎は、へへえ、と、だらしなく笑って、「あまり調子がいいと、口説くかも知れませんぜ」　小波は、あら、と小さな声で叫ぶと、サッと顔を染めて、「そこまでは、ちと行きすぎます」「いやア、いまのは冗談。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく調子がいいもんだから、いきおい弾みがついて、だいぶ陽気な光景になる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、グレゴールは、長く眠ったのにほんとうに眠気が残っていることを別にすれば、まったく身体の調子がいい気がするし、とくに強い空腹さえ感じているのだった。",
              "citation": {
                "source": "変身",
                "author": "DIE VERWANDLUNG",
                "note": "青空文庫"
              }
            },
            {
              "text": "調子がいいところで気をつけようと思って。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "国は、ああいう人ですから、こうやってやってみて、調子がいいと、それをこちらにかまわずひっぱろうとする傾でね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうふうにお雪ちゃんの調子がいいものですから、道庵もいよいよ附け上って、「そこで、一通りそのお嬢さんの脈を診て上げて帰りに、先生一杯なんて、よけいなことをその家の両親共がすすめるもんだから、ついいい気持になっちまって、それから牛込の改代町まで来ると、出逢頭に子供を一人、蹴飛ばしちまったんだね。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はいつになくノルエピネフリンの調子がいいらしい。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたみの躰の調子がいいときでも、洗濯だけは決してさせなかった。",
              "citation": {
                "source": "追いついた夢",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上最近とても調子がいいし、かつての自分に戻りつつある。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーストパーク競馬へ出走させるつもりは全くなかったのですが、ラッフルの報告では今日は調子がいいというので、あなたの考えを採用しない理由はありません。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに空駕で歩行いたすより、お乗り下すッた方がかえッて手前達の足取も調子がいいと申すもの。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
