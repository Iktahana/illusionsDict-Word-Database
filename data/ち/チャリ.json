[
  {
    "uuid": "e15fb7c8-aad2-5657-b71f-eaad45abb267",
    "entry": "チャリ",
    "reading": {
      "primary": "チャリ",
      "alternatives": [
        "ちゃり"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
