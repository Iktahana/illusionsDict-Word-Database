[
  {
    "uuid": "b2565789-129a-54cf-b4c5-1140dff5d6cc",
    "entry": "弔鐘",
    "reading": {
      "primary": "ちょうしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "funeral bell",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "少くとも芥川龍之介の死は、当時耳に残って消えない文学上の弔鐘の一うちであった。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民は既に挙って寺内内閣の弔鐘を打っております。",
              "citation": {
                "source": "食糧騒動について",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ人はそれを弔鐘と聞くのだろう。",
              "citation": {
                "source": "チェーホフ試論",
                "author": "――チェーホフ序説の一部として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ人はそれを弔鐘と聞くのだろうか。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "茎は緑に、弔鐘形の花｜黄金色。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の耳には全ての失敗した冒険の弔鐘が鳴っており、彼の仲間は全て暗黒の塔から見えるところで丸くうずくまった小塔、愚者の心臓のように見えない、褐色の石で作られて、対応するものが無い全世界に。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "神山東洋の大きな声が弔鐘のように無気味にとどろいた。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "――古典平家物語は、いわばそのころの、日本百年の弔鐘でした。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
