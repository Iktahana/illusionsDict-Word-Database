          "literary": [
            {
              "text": "さようならちょっくら行って参りますよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お光などのように兵隊の気嫌まで取て漸々御飯を戴いていく女もあるから、お前さんなんぞ決して不足に思っちゃなりませんよ」　皮肉も言い尽して、暫らく烟草を吹かしながら坐っていたが、時計を見上げて、「どうせ避けた位だからちょっくら帰って来ないだろう。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "般若の面の男　見よう見真似の、から猿踊りで、はい、一向にこれ、馴れませぬものだでな、ちょっくらばかり面をつけて見ます了見の処。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "半額券を買うとは何の事か訳が知れなかったから、答えるすべもなかったが、これ倖いと、ちょっくら物を訊ねますが、出雲屋は？",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "半額券を買うとは何の事か訳が知れなかったから、答えるすべもなかったが、之倖いと、ちょっくら物を訊ねますが、出雲屋は。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっくら小手しらべに、正宗、村正、はだしというすごいところをお目にかけなせえましよ」「うるさいよ」「へ……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっくらお待ちなせえよ」「バカだな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生の思い出に、あっしもちょっくら使いますかね」　夜ふけをいといもなく数寄屋橋へころころしながら行ったようでしたが、案ずるよりもたやすく用が足りたとみえて、小半ときとたたないうちに帰ってまいりましたものでしたから、右門は待ちうけてその報告を聞きました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぱんぱんと早手回しにやってめえりますからね、ちょっくらお待ちなせえよ」　飛び出していったかと思うと、いかさま早い。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘のお糸に用があるから、ひとっ走りいって、ちょっくら借りてこい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "じきじき、お礼ごん上に伺うが定でごぜえやすが、さすればまたおっかねえものが、あごのところへ飛んで来るかも存じませぬゆえ、ほんのお礼のしるしに、ちょっくらこれを投げこんでおきやした。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、ちょっくら川下のとち狂っている人足どもにそういってきな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、だんな――つかぬことをおねげえするようで面目ござんせんが、ちょっくら月代をあたりてえんですがね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、辰の野郎をすぐひっぱってめえりますから、ちょっくらここでお待ちくだせえましよ」　しかるに、どうも伝六というやつは、なんと考えてみても変な男です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれゃちょっくら朝湯にいって、事のついでに床屋へ回ってくるから、おとなしく待っていなよっていいながら、どんどん出ていったきり、いまだにけえらねえんですよ」「あいそのつきた野郎だな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠慮はいらねえから、早いところおめえの隠し芸をお目にかけて、ちょっくらだんなの肝を冷やしてやんねえよ」　と――ほとんど同時です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきこちらを引き揚げてから、ふたりしてちょっくら神明前の吹き矢へ出かけていったんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "ま、いいや、いいや、ねこをちょっくらこっちへ貸してみな」「かみつきますぜ」「草香流があらあ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗み手のめぼしはついたが、肝心の雪舟はちょっくらちょいとめっからないとでもおっしゃるんですかい」「いいや、そんなものの行くえやありかは、このおれが出馬するとなりゃまたたくまだがね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「不足かい」「だって、兵糧をつめないことには、いくらあっしだって、いくさはできませんよ」「それだから、金葉へでもちょっくら寄って、中ぐしのふた重ねばかりも食べようかといってるんだよ」「え？",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでなくとも、おいら、ゆんべから投げなわの使い場がなくて、うずうずしてるんだから、ちょっくら行ってこようよ」　勢い込んで、手代のあとに従いながら、駆けだしていったようでしたが、ものの四半刻もたたないうちにすごすごと帰ってきたのは、伝六、辰の両名でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりして、ちょっくらご番所を洗ってきなよ」「行くはいいが、何を洗ってくるんですかい」「知れたこっちゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっくら吐かしてめえりますから、どこかその辺の小陰にかくれて、あごでもなでていなせえよ」　得意顔に引っ返していった伝六を見送りながら、名人はそこの横路地の中に身を忍ばせて、様子やいかにと待ちうけました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "もぞりとひとなであごをなでりゃ、このとおりぱんぱんと眼がつくんだからね、景気よくぶっ飛ばすようにちょっくらと駕籠をめっけてめえりますから、お待ちなせえよ」　わがことのようにおどり上がって駆けだそうとしたとき、「お願いでござります！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
