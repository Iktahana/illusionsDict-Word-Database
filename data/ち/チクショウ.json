        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "犬が吠える、虫が鳴く、　　　畜生！",
              "citation": {
                "source": "暗い天候",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おや、踏んづけてやがら、畜生！",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が七輪の炭火の上に倒れても、よう起さないで泣き出してしまう老人に、――畜生！",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時だ、三時だな、畜生！",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "畜生」　小林はそう云って、三尺鑿の先の欠けた奴を抛りだした。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「畜生ッ、保下田の久六奴、卑怯な奴だ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「石松、吉兵衛になァお前の来た事を……」　「誰が言やがったんだろう……畜生」　七五郎、言えなくなって梯子を下りる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、いた」　「なにッ」　「畜生ッ」　「あ、お前さん」Ｓ＝向いの屋根　石松、小路を隔てた向いの屋根へ窓から飛びついている。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "進藤始め若侍「畜生！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "倒されたおしまが、Ｔ「畜生、　吠え面掻くなッ」　ナニッと白倉。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「畜生つ、畜生つ……」と、内心に呟きながら、手洗所へ立つて、わざわざ扉のある方へはひり、聊かあせるやうな氣持でアストオル吸入をつづけてみるのだつたが、もう駄目だつた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は畜生の群れと一緒に寝て起きて、黙っておとなしく稼いでいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの婆さんは生みの息子より畜生の方が可愛いのかしら。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし侍の刀で畜生の首を斬ることはしなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "チュアン　イエン　ペイフォン　ツイイエンジュン　ハン　コアンフイパイ　ファニャン　ワンアルツイホン　ゾアン　イ　コン　ウエイ「畜生！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺れが人殺しでもしたと云うのか、畜生！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手がやり出せば、やぶれかぶれだ、畜生！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺等だって、賃銀を上げろ、上げなきゃ、畜生！",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あン畜生、一つ斜坑にでも叩きこんでやるか！",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつら、畜生、人間の命よりゃ、鉱石の方が大事と思ってやがるんだぞ！",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくしかしそれにしてもと、あんまりお帽子の菱がたが神経質にまあ一寸詩人のやうに鋭く尖っていささかご人体にかゝはりますが、）（えい、畜生まだ何か云ってやがる。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは畜生同然の身分でございますが、私のようなものにさえまことの力はこのようにおおきくはたらきます」「ではそのまことの力とはどんなものかおれのまえで話してみよ」「陛下よ。",
              "citation": {
                "source": "手紙　二",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さよなら、えい、畜生、その骨汁は、空虚だったのか。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（畜生、お客様が見えないかい。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（どうどうどう、畜生これあだけた獣じゃ、やい！",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（嬢様｜勘違いさっしゃるな、これはお前様ではないぞ、何でもはじめからそこなお坊様に目をつけたっけよ、畜生｜俗縁があるだッぺいわさ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも何よ、それ畜生道の地獄の絵を、月夜に映したような怪しの姿が板戸一枚、魑魅魍魎というのであろうか、ざわざわと木の葉が戦ぐ気色だった。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と親仁がその時物語って、ご坊は、孤家の周囲で、猿を見たろう、蟇を見たろう、蝙蝠を見たであろう、兎も蛇も皆嬢様に谷川の水を浴びせられて畜生にされたる輩！",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その居たるあとを踏みにじりて、「畜生、畜生。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒は邪魔になるので、「こんちくしょう、こんちくしょう」　と払い除けようとしましたが、なかなか払い除けられません。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
