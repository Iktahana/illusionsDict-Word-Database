    "definitions": [
      {
        "index": 1,
        "gloss": "children's game in which one skips on one leg",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "扶桑教といや、ちんちんもがもがの行者じゃねえですか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "師匠上ったりで、いよいよ裾をひろげらあ」　と、いった時、泥溝板に音がして、一人の若い衆が、下駄を飛ばした、片足をあげて、ちんちんもがもがしながら、大きい声で「とっ、とっと――猫、転んで、にゃんと鳴く。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士春が「騒々しいね」「ちんちんもがもがどでごんす」　益満は、片足で、三段目から、飛び降りて、そのまま、ぴょんぴょん、富士春の側へ行こうとすると、火鉢の前に一人の男が坐っていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "三田はちんちんもがもがで、往來の靴を拾つて來た。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三度、ちんちんもがもがやっているうちにたがいに立ちすくんで睨みあうようなかたちになった。",
              "citation": {
                "source": "予言",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "雛妓達も客も芸妓も皆んな並べて、「――いっちく、たっちく太右衛門どんの乙姫様は、湯屋で押されて泣く声聞けば、ちんちんもがもが、おひゃりこ、ひゃりこ――」　と声を揃えて歌いながら数え、一人ずつ抜かして、最後に残った一人を鬼にするのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "麝香の匂い",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
