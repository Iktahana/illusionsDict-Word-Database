    "definitions": [
      {
        "index": 1,
        "gloss": "tea plant (Camellia sinensis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこら辺りにやしおの花が鮮に咲き、丸味のある丘には一面茶の木が鶯餅を並べたように萌黄の新芽で装われ、大気の中にまでほのぼのとした匂いを漂わしていた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は茶の木を愛する、その花をさらに愛する。",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "捨てられるともなく捨てられている茶の木は『佗びつくしたる佗人』の観がある。",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の木は枝ぶりもおもしろいし、葉のかたちもよい。",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "この柿の木が其中庵を庵らしく装飾するならば、そこらの茶の木は庵の周囲を庵として完成してくれる。",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "年をとるにしたがって、みょうが、とうがらし、しょうが、ふきのとうが好きになるように、茶の木が、茶の花が好きになる。",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "久助君の家は道の北側にあつたので、呼び声は家の前の段々畑の、茶の木を越えて流れて来た。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "門傍の薄、萩、茶の木垣の横の電柱、白木槿、或は左の書齋の前の山茶花、躑躅、沈丁、月桂樹、小さな祠。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "門傍の薄、萩、茶の木垣の横の電柱、白木槿、或は左の書斎の前の山茶花、躑躅、沈丁、月桂樹、小さな祠。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五人の手で芋を掘つてをる畑の縁には馬が茶の木に繋いであつて俵が轉がつてをる。",
              "citation": {
                "source": "寫生斷片",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬は退屈まぎれにどうかすると茶の木をむしることがある。",
              "citation": {
                "source": "寫生斷片",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑のへりの茶の木の花は白々と光を帶びて居る。",
              "citation": {
                "source": "寫生斷片",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の木の花がやゝだらけて菊がもうよつぽど摘まれた頃である。",
              "citation": {
                "source": "竹の里人〔一〕",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の見收めといふ積りで山門をのぞいて見たら石垣の上の一｜畝の茶の木を白衣の所化が二人で摘んで居る所であつた。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲雀は低く飛んで遙かに先へ行って畑の境の茶の木の株に隠れたり又飛んだりして遁げて歩く。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五人の手で芋を掘つて居る畑の縁には馬が茶の木に繋いであつて俵が轉がつて居る。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬は退屈まぎれに茶の木をむしることがある。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "芋の株を掘り畢つた時に兼次は鍬へついた土を草鞋の底でこき落して茶の木の株へ腰をおろした。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根は茶の木へがさりと止つた。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "春も八十八夜となつて草木のやはらかな緑が四方を飾るやうになるとみじめな姿で顧みられなかつた畑のへりの茶の木のめぐりも赤い襷の女共が笑ひ興じて俄かに賑かになる。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "女達は一畝の茶の木を向合ひになつて手先せはしく摘んで居る。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんぢや行くべえ」　と兼次はおいとの方へ茶の木を押し分けて行つた。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の木に添うては小麥の畑がある。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "この妖怪｜毎も山茶の木製の槌と、三足の鶏を使うたと。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "槌と鶏と怪を為す事、上述デンデンコロリの話にもあり、山茶の木の槌は化ける、また家に置けば病人絶えずとて熊野に今も忌む所あり、拙妻の麁族請川の須川甚助てふ豪家、昔八棟造りを建つるに、烟出しの広さ八畳敷、これに和布、ヒジキ、乾魚などを貯え、凶歳に村民を救うた。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "大工が天井張った時山茶の木の槌を忘れ遺せしが化けたという。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "山茶の木は粘き故当り烈しく、油を搾る長杵にするに折れず。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "那智の観音本像は山茶の木で作るという。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
