    "definitions": [
      {
        "index": 1,
        "gloss": "account book",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "電燈がついてから、看護長が脇の下に帳簿をはさんで、にこ／＼しながら這入って来た。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護長は、帳簿を拡げ、一人一人名前を区切って呼びだした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "サアそれもチャンと返して帳簿を整理しておかんと今のうまい口に行く事ができない。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "親爺は、何か厚い帳簿を持って廊下へ出た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は帳簿に頸を埋めた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「××どんあれはいつ頃だったけ」「へい」　しばらく見ない間にすっかり大人びた小店員が帳簿を繰った。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の椅子に社長をすわらせたつもりにして、その前に帳簿を並べて説明とお世辞の予習をする。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、こっそり帳場へ行って、このたびの祝宴の出費について、一切を記して在る筈の帳簿をしらべた。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「余り心配したせいだろう」「直ぐお寝みなさいな」「イヤ帳簿の調査もあるからお前先へ寝ておくれ」と言って自分は八畳の間に入り机に向った。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐこれを明日銀行に預けて帳簿の表を飾ろうと決定たのである。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "思案に尽きて終に自分の書類、学校の帳簿などばかり入て置く箪笥の抽斗に入れてその上に書類を重ねそして鍵は昼夜自分の肌身より離さないことに決定て漸っと安心した。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何故開けた、どうして開けた」「委員会から帳簿を借してくれろと言って来ましたから開けて渡しました」とじろり自分の顔を見た。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し何時か自分の挙動で箪笥の中に秘密のあることを推し、帳簿を取りに寄こされたを幸に無理に開けたに相違ない。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれはこれに併行する経済的の帳簿の示す数字によって制約されつつ進行するのである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしが役所の机で古い帳簿から写しものをしていますと給仕が来てわたくしの肩をつっついて、「所長さんがすぐ来いって。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから酒屋の主人に帳簿を出さしてしらべて見ましたが酒の売れ高がこのごろ毎年減って行くやうであります。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下に帳簿方と場況見と二人の店員の机が差し向いになっていた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……いいか……貴様は今夜からここで、店の帳簿方と一所に寝るんだぞ。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に今まで毎晩私と一緒に寝ていた帳簿方が結婚をして家を持ったので、私が常設の宿直になった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "店から帳簿を持つて来る者にも、めつきりうるささうな様子を見せるやうになつた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして　ちょうぼに　そのことを　かきつけておくのです。",
              "citation": {
                "source": "ジンジャー＆ピクルスのはなし",
                "author": "THE TALE OF GINGER AND PICKLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「長坊やーい、長次さんやーい」　ひと言ひと言を長く引いて、ちょうぼうやあーい、というふうに呼ぶのであるが、平常とは違うもの悲しげな、訴えるような哀調を帯びた声で、それが井戸の中にこもった反響を起こすため、眼の前に見えていてさえも、背筋が寒くなるようなぶきみさを感じた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "鶯ばか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
