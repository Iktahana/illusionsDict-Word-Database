        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "茶瓶の口が欠けていたので夫人が新しいのと取換えようと云ったが、「これでも結構間に合う」と云って、そのままになった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、茶具の数も、定めの数の二十具を減して十六にし、また、十二具にし、やぶれた都籠から取出したのはぎりぎり間に合せの茶瓶、茶盞、茶罌ぐらゐの数に過ぎなかつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はゆつたりと坐つて作法のやうに受汚で茶盞を拭ひ、茶瓶の蓋を開けて中を吟味し、分茶盒と茶罌を膝元に引付けた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯の沸く間に、彼は彼の唯一の愛玩品の南蛮製の茶瓶を膝に取上げて畸形の両手で花にでも触れるやうに、そつと撫でた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶瓶に湯が注がれて、名茶『一の森』の上※の媚びのやうな淡いいろ気のある香気が立ちのぼつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は茶瓶をむづと掴んだ。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶瓶の口へ彼の尖がつた内曲りの鼻を突込んだ。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「禿茶瓶、要らぬおせつかいをするない。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程大西氏の言ふ通り禿茶瓶には相違なかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "お人好しの博士は初めて自分の禿頭に気が注いたやうに一寸変な顔をしたが、直ぐ例の静かな表情にかへつて、「なんぼ禿茶瓶かて、言はんならん事は言ふわい。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんぼ禿茶瓶かて、言はんならん事は言ふわい。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "山から蘭を三株持つて帰つて、茶瓶に植ゑた、やんがて咲くだらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "大変御馳走になったうえ、茶瓶からコップへなみなみとつがれたお酒をお茶だと思ってぐっと飲んで、しまったと思ったが仕方がない。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "通し物の順番を追はずに、板前を急がせた水の上からの註文は直ぐ出来て、別に添へた一品の料理と香の物、茶瓶なぞとともに、こんな時の用意に備へてある長い綱の付いた平たい籠に入れて、源太郎の手で水の上へ手繰り下された。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小剣",
                "note": "青空文庫"
              }
            },
            {
              "text": "……教へたろか、新田の茶瓶のこつちや。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そいで新田の茶瓶さんが、この村の太政官ちうことだすな。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭は昔からあんな工合に茶瓶さんやがな。",
              "citation": {
                "source": "父の婚禮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "通し物の順番を追はずに、板前を急がせた水の上からの註文は直ぐ出來て、別に添へた一品の料理と香の物、茶瓶なぞとともに、こんな時の用意に備へてある長い綱の付いた平たい籠に入れて、源太郎の手で水の上へ手繰り下された。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶瓶か何かそこへ置きやがったな。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲人を、あの茶瓶がと、寝て話し、桃牛舎南玉が一つ、この茶瓶になりやしょう。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "三田さんのところへしけ込んで來てゐるのがやけて堪らんから、からかつてやつたところが、えらい女でなあ、俺の此の茶瓶にざあと酒を浴せやがつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いたねえ、俺の此の茶瓶に酒をぶつかけたのは、よもや忘れは致すまいが。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へえ、あんたの茶瓶にお酒をかけましたかいな。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのやうなしようむない茶瓶に、おいしいお酒かけるやうなもつたいない事、なんでしたのやろ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上茶瓶仲間だから、酒でもぶつかけられてはかなはん。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まアよい、済んでからのこと――おかみは日が長いよ」「でも――」と甚助は茶瓶を持って立ちあがって、そして叫んだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "また彼等の日用品、例へば石鹸、歯磨道具、手拭、その他茶瓶から食器類などもやはりソコの中にごちやごちやと入れて置かれるのである。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、先生があらわれると、とかく農家のおやつのテーブルには少なからず騒ぎがおこり、菓子や砂糖漬けのご馳走がむやみと増えることもあろうし、ことによれば、銀の茶瓶を見せびらかすこともある。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "この禿茶瓶が、癪に触わってたまらねえんだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "せまい道巾のところへいったら、小さな店に、さびしげにいた黒い白粉をつけたようなお女郎が「おちゃびんだ」とどなって、煙管を畳に投げつけたので、私はびっくりして、格子にぶるさがっていた手をはずしてベソをかいた。",
              "citation": {
                "source": "流れた唾き",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
