[
  {
    "uuid": "9e8abc7a-6ce1-5f84-97a3-1108b2999578",
    "entry": "調子者",
    "reading": {
      "primary": "ちょうしもの",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "person who gets easily elated (when praised, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あの幸福な、お調子者のヂャズにもすつかり倦果てた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど菊次さんもすこしお調子者でありました。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで我が妻アキコを知るお調子者某が、「ホントお宅に行っても僕らにはお茶一杯出しませんよね」などとぬかそうものなら、オレとしてはやむを得ずアキレス腱固めに及ぶしかない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてＰＣ―１００はこのお調子者たちが、さまざまな新しいアイデアを盛り込んで開発した意欲的なマシンだった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが先日、「コンピューターで読む」事を狙った電子本というやつにお目にかかり、お調子者の常で「読むことの電子化」にも積極的な意味があるのではないかと考え始めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく結果的には、その後のパーソナルコンピューターの進む道を体現したマシンの先駆性にしびれ、この国のお調子者の何人かが飛び付いた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがＴ田のようなお調子者のバカタレは、マックで日本語を使うという狂気の沙汰に及ぶ事をいとわなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿父さんのやうなお調子者の真似はするな。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも此方が離れるといふのではなく大概相手の方で、私のカラ元気でお調子者で、性格にも思想にも生活にも何の厚みもなく、ペラペラと安ツぽいことばかりを喋舌つたり、薄ツぺらな感情に動かされて酷く感傷家がつたりするより他に何もないことを見抜いて、誰でも愛想を尽かして了ふのが常だつた。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔさんはあなたに限るようですから」　などといいつけると、ややお調子者の杉浦は、もう大得意で大カメラの入ったズックを重そうに担いで、意気揚々と出かけて行ったものです。",
              "citation": {
                "source": "Ｍ侯爵と写真師",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "反目者が共和生活を保つてゐるといふのは不思議であるが、二人の間に介在する私が何方の思想にも点頭くといふやうなお調子者であつたから、私さへ居れば三角的の平和が辛うじて保たれてゐるのであつた。",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えへへへへへへ」お調子者の嘉平次は、上機嫌になりながら、そのだらしない口元から、落ちそうになる涎を、左の手で幾度も拭った。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "……事業熱に浮されてゐるお調子者の父親、母親はうわべでは旧家の格式を重んじ、夫や悴を古風な教育に屈服させようと努めるのだが、夫は彼女を軽蔑してゐた。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は新聞社へ入つた当座は、お調子者だから気軽くぽんぽんと飛び廻るので大分うけも好かつたのだが、近頃では次第に同僚達に安ツぽい肚を見透かされて、今では社内の軽蔑の的になつてしまつたのだ。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "怠惰と、浮々としたお調子者、他愛もない失恋、親との不和、そして二人とも夫々別々な私立大学を卒業してゐるのだが、学校では何も覚えなかつた、今では、たつた一つの肩書であつた「大学生」も奪はれて、キョトンとしてゐるより他に能がなかつた。",
              "citation": {
                "source": "環魚洞風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "村山氏を、憎む気にもなれなかつたが、愚かなお調子者の非文学的な彼の小説のつまり彼である主人公が、ペラペラと吾家の不祥事を吹聴したり、親の秘密を発いたりする文章を書き綴つてゐる浅猿しさを、彼は自ら嘆いた。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――「まア、何といふだらしのない格構だらう、あきれたお調子者だ。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒笑が御恩を仇で返すようなことをしたのも、お調子者で気が弱いというだけではありません。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあの男がすごいお調子者で神を模倣していることを理解したんだ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
