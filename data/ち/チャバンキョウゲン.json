        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あらゆる新聞講談から茶番狂言からアリストファーネスのコメディーに至るまでがそうである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に悲惨な、愚かしい茶番狂言を見ているような気がして、ああ、もう、この人も落目だ。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御覧にならない方々のためにチョッと知ったか振りを御披露申上げておくが、博多二輪加の本領というものは、東京の茶番狂言や、大阪二輪加なぞと根本的に仕組みの違ったもので、一切の舞台装置や、台本なぞいう面倒なものの御厄介にならない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私はこの茶番狂言もいよいよおしまいになればいいがと思いはじめた。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶番狂言ではあるまいし、一生それで押し通すつもりじゃったか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもてまえの身上でございますから、よく町内のお茶番狂言に呼ばれます」「お座敷商売の按摩だけあって、口のうまいやつじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "○弁天小僧の芝居は、見てゐて楽しいが、全体が茶番狂言の腹で行つた書き物である。",
              "citation": {
                "source": "若手歌舞妓への期待",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶番狂言に類する喜劇で、輕口・口眞似などを主として居る（比嘉春潮氏報告）。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の状の滑稽茶番狂言を見るが如し。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "親の脛かじり相寄って茶番狂言を催さんとするや正に最新芸術の研究とか試演とか称すべし。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな鰯の干物のような奴が、どう足掻いたって、洒落本はおろか、初午の茶番狂言ひとつ、書ける訳はありますまい。",
              "citation": {
                "source": "曲亭馬琴",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿楽の狂言および俗間の茶番狂言なるもの体裁さらに善し。",
              "citation": {
                "source": "国楽を振興すべきの説",
                "author": "神田孝平",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の有閑人たちは、名目さへ立てば、時も處も構はずに、茶番狂言、お温習、手踊り、素人芝居――と、果てしもなく享樂を追ひ求めるのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "毒矢",
                "note": "青空文庫"
              }
            },
            {
              "text": "シェキスピアやモリエールやゴーゴリやボーマルセなどの戯曲を二つか三つ、それもほとんど茶番狂言でもやるのと同じ位の条件と準備とでもって上演する劇団があると、たちまち演劇雑誌にシェキスピアやモリエールやゴーゴリやボーマルセをひと呑みにしたような「堂々たる」論文などを書く人間が現われます。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後の祭で茶番狂言が栄えているようなもんで――嘘だと思ったら、兄さんなんぞのお手のもんの新聞でもいい。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手と握手するようにグージャールから言われると、その茶番狂言が癪にさわった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした、生涯を茶番狂言に終始した嘘つき親爺でも、興奮のあまり実際に身震いをして泣きだすほどの、真に迫った心持になる瞬間があるものである。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "金持が千兩箱に押し潰されて怪我をしたなんてえ圖は、滅多に見られる茶番狂言ぢやありませんよ」「お前は飛んだ惡い口だな」「それに企らんだ殺しは確かですよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "屠蘇の杯",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもその茶番狂言を、ある人々は親切にも本気で受け容れてくれた。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、たれかが演出させた余興である、茶番狂言にすぎないのだ――とは、満座のすべては知っていたが、森の巫女の魔芸は、そう知りぬいている人々をも、ひっそりさせてしまったのである。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
