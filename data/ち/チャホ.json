        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "父は四条御幸町に店を構え、茶舗を創めたばかりのところでした。",
              "citation": {
                "source": "わが母を語る",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "家業は父から受け継いだ茶舗を、母が営んでおりました。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "京橋づめが池田茶舗、この店も古く、昔は店の奥に真黒な茶壺がならんでいて、古風ないい茶店であった。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その縁起を源ぬるに、慶安の頃ほひ、山城国、京洛、祇園の精舎に近く、貴賤群集の巷に年経て住める茶舗｜美登利屋といふがあり。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑閙の角に、茶舗が出ている。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「聞いちゃほっておかれねえのがわしの性分じゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "と申すと物好きのようにお思いでござんしょうが、めかけ奉公のような囲われ者でも、妹にとっちゃほれてほれぬいた江戸屋でござんす。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけどあたし心からかわいそうだという気にならなくっちゃほんとうに愛することはできないんですもの。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            }
          ]
        }
