        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「美和ちゃんのお姉さんのために、チェリオ！",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「美和子のためにも、チェリオ！",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて周囲の御婦人にビールを差し、その都度、プロヂットとか、チェリオとか、乾盃し、多忙である。",
              "citation": {
                "source": "風人録",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、隣席の客をつかまへて迎へうち、自分の席へ拉し来り、又隣席へ割りこんで、談論風発、カラ／＼と笑ひ、ビールをつぎ、プロヂット、チェリオ、間断なく乾盃してゐる。",
              "citation": {
                "source": "風人録",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "又ひとりは対欧策とか対支開発政策などゝいふ遠大な計画をたてつゞけにまくし立てられ間断なくチェリオとかプロジットとか叫びをあげ、時々は御愛想に笑ひ声のひとつぐらゐは立てなければならないと覚悟をかためる。",
              "citation": {
                "source": "風人録",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この切なさを救ふものは、たゞホドコシの心境あるのみでして、美人女給はいけません、お客がムリを重ねる、もう一杯、チェリオ、たべたくないお料理もとりよせる、涙溜息あるのみでして、禁酒を叫び、出家遁世の心ざし、朝ごとに発狂してゐるやうなものでさ、養命保身どころぢやないです。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "トンチンカン以上に魂がふれあう必要がなくて、チェリオとかなんとかやってれば、それで結構憂さは忘れられました。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "イーだ」　セラダと八千代サンは早くもテーブルにつきさっそくビフテキをパクつき、改めてチェリオと乾盃をやっております。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェリオ」　セラダは至って好キゲンでした。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェリオ」　それより例の如くにメートルをあげて両名は飲めや笑えやです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "花が開くように笑って）どうぞ、ゆっくりと、お気軽に、チェリオ！",
              "citation": {
                "source": "殺意（ストリップショウ）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と、もう一つ酒をついで）チェリオ！",
              "citation": {
                "source": "殺意（ストリップショウ）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ふくみ笑いをしながら、又つぐ）チェリオ！",
              "citation": {
                "source": "殺意（ストリップショウ）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪口では人に負けを取らぬヴォルテールも、次の世紀に於て、「書物も人間と同じで、群の中から選択する他はあるまい」と、『チェリオに与うるの書』の中に記した。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物のバルベ・ルキエン・レヴィーの三外人とサンボアへ行き、チェリオ／＼。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
