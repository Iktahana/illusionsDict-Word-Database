    "definitions": [
      {
        "index": 1,
        "gloss": "arrival of a ship",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
