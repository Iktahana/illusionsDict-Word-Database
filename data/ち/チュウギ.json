          "literary": [
            {
              "text": "第三には、幕府にちゅうぎそうな顔をしていたものが、幕府がつぶれると、すぐさまあたらしい政府のほうへついて、すこしでもよい地位をえようと血まなこになっていることだ。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "底がじめじめして、しょっちゅうぎいぎい言うのくらい、いやなものったらありはしない。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
