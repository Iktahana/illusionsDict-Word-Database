[
  {
    "uuid": "2b42d763-bc66-5220-9f6b-07bb3c23586b",
    "entry": "調剤",
    "reading": {
      "primary": "ちょうざい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
