        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "范増（中国、秦末の知将。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "七郎の子は登に漂泊していって、姓を※と変えていたが、兵卒から身を起し、軍功によって同知将軍になって遼陽に帰って来た。",
              "citation": {
                "source": "田七郎",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜助　うわあ、ちしょうめ！",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちしょうめ、ムシャクシャしてならねえんだ！",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしは、いつか、きみたちしょうねんたんていだんと、ちえくらべをしたまほうはかせだよ。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『おうごんのとら』のじけんで、ぼくたちしょうねんたんていだんに負けた、あのまほうはかせだ。",
              "citation": {
                "source": "まほうやしき",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
