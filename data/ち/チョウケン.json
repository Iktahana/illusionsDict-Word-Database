[
  {
    "uuid": "f7a8f454-f915-54af-8441-b0f54410f589",
    "entry": "朝見",
    "reading": {
      "primary": "ちょうけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "audience with the Emperor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夕陽に染められた構内は朝見た時とは丸でちがつた更に／＼美しい別の繪になつて居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝見ると、山吹の垣の後ろは桑畑で、中に木蓮が二、三株美しく咲いていた。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夏のある朝見たら三尾の一尾が横になって浮いている。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕日に染められた構内は朝見た時とはまるでちがったさらにさらに美しい別の絵になっていた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん毎朝見ているものを見ないという一種の手持ちぶさたな感じはあったに相違ないが、それと同時になんだか急に世の中がのんびりしたような気持ちがないでもなかったように思う。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シッカリと刺しておいたつもりでしたが、今朝見ますとその鉄火箸は、この敷居の蔭に落ちておりました」　その板戸の継ぎ嵌めだらけの板片を一つ一つに検めていた草川巡査は、「よし。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "而れども諸番国の使者｜和に随って朝見し、各々其方物を貢す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌隣べの春もをさなしたき火して梅のつぼみをしたしとを見れ寺の井のぽむぷの把手今朝見れば春雨しげし動かしにけり見え来る春かにかくにうつろふ冬や、隙間洩る風を寒みと、破れはてし家にこもると、はららうつ雨のこまかに、置く霜の置くと解くれば、ふる地震のふると消につつ、おのづから霞立つ日ののどけくなりぬ。",
              "citation": {
                "source": "風隠集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "立枯並木の歌霜ふかき野川の堰、あはれよと今朝見に来れば、いつとなく水量涸れつつ、隙間なく氷張りけり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今朝見ると、おまいのつれの商人はのどを切られて死んでゐた。",
              "citation": {
                "source": "ざんげ",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「腹は減つたし、もう暗いし、大佛はあすの朝見ることにしましよう――」「‥‥」女は目をあげてちよツとこちらを見ただけだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日取り換へた処なのに今朝見ると悉くしをれてゐるんだ、変だと思つて、あれだけが皆な一処に活けられる相当大きな花壺なんですがね、験べて見ると中には氷が張り詰めて、持ちあげると胴中からぽかりと割れてしまつてゐるのさ、一滴の水も流れない、珍らしい寒さだ！",
              "citation": {
                "source": "趣味に関して",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "楯井さんは急に、『お寺さんの話では、おなかさんが殺された晩、ひどい音がして朝見ると、御堂の前に血がうんと散らばっていたと云った。",
              "citation": {
                "source": "惨事のあと",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ鯨といふ奴は大きいものですから、港へはひらないので其儘置いたのですが、それがあなた明日の朝見ると夜鯱が来たと見えて鯨の肉がしたゝか噛じられて居るんです。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "多い神仏の内には豪気な奴もありて、『雍州府志』に京の勝仙院住僧玄秀の時、不動尊の像の左の膝を鼠が咬んだ、秀、戯れに明王諸魔｜降伏の徳あって今一鼠を伏する能わずといった、さて翌朝見れば鼠が一疋像の手に持った利剣に貫かれたので感服したと出づ。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は血の多い若々しい頬に夕日を受けて、其朝見つけて置いたといふステツキになる樹の枝を切つて、その皮を剥きながら並んで行つた。",
              "citation": {
                "source": "春雨にぬれた旅",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という崇厳、何という清麗、朝見たよりも益々うららかに輝き入って、全面白光、空の深みに鎮っているのである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、三日、四日と経つうちに、数が多くなり、ことに昨夕は痒さのためによく眠れなかったが、今朝見ると、白く膿を湛えているのが、いくつもできている。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうの朝見たときは、寮の裏から太陽があがった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日まで俺は、息を殺してゐたが、薄々は気づいてゐたんだが、はつきり、それと、おとゝひの朝見とゞけたんだ。",
              "citation": {
                "source": "山男と男装の美女",
                "author": "ミツキイのジヨンニイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ま、明日にでもなったら、試みに調べて御覧なさい」　　　　　　　　　　二　医師の主張は、翌朝見事に確められた。",
              "citation": {
                "source": "闖入者",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "別府所見、――小秦誰、朝見川朝日橋のほとり、竹田が妓にかく書いて与へたといふが、夜はともかく、昼はゴモクアクタでワヤだ！",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど長火鉢のところから見える後庭の崖際にある桜の枝頭が朝見るごとに白みかかって来る時分で、落着きのない自分の書斎を出ると、気紛れな笹村の足はどこという的もなしにいろいろの方へ嚮いて行った。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝見ると、明るい日の光の下に、それ等の旅館の裏二階の欄干や障子が松林の間からはつきり見えてゐる。",
              "citation": {
                "source": "伊良湖の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝見た薄白い雲はもう消えてしまつて、水と接する空は、薄黄色に光つてゐた。",
              "citation": {
                "source": "伊良湖の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝見ると、麻糸の先は針がついたまま戸の鍵穴を抜けて、外へ出ていました。",
              "citation": {
                "source": "三輪の麻糸",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "君自身が何者かというような問題はとりあえず別にしておくとして、君は今朝見たあの少女をどう思うね」　私は質問の意味が解りかねて眼をパチパチさせた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな人だか、誰知るものもねえだが」「その人がね、昨日の朝見えたゞよ」「不意にかよ」「ウンニャ、前触れがあってね、掃除さしといて呉れちゅうから俺、ちゃんとしといたゞ」「一人で来たのかよ」「ウン、顔の蒼白え若え人でな。",
              "citation": {
                "source": "青服の男",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝見る鏡に、眼ばかり大きくなってゆくのがわかるのだが、こう段々に、夜が苦しいものになって来ては堪らないし、眼のさめた瞬間の心さびしさも、朝々ごとに、たまらないものに思った。",
              "citation": {
                "source": "遠藤（岩野）清子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日、鉄砲にうたれた雀が落ちたと云う庭に、今朝見ると血がにじんで居て心地わるい。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
