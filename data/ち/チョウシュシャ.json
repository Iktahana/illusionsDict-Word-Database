[
  {
    "uuid": "dfa22a48-183a-5011-a147-9c000a6173d7",
    "entry": "聴取者",
    "reading": {
      "primary": "ちょうしゅしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
