    },
    "definitions": [
      {
        "index": 1,
        "gloss": "listener (of radio, streaming audio content, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いずれも生まれて初めて飛行機に乗って珍しく感じたことを談り合ってそれを全国の聴取者に聞かせるのである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "全世界に亙る読者と聴取者とは、日の経つに従って焼けつくほどの熱心さを以てそれを新聞社や放送局へ求めるのであった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときに、音響効果を適当にやれば、普通のドラマでは到底出せないような新しい感覚的な娯楽放送を聴取者のラウドスピーカーに送ることが出来ように思っている。",
              "citation": {
                "source": "『地球盗難』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、日本のラジオのプログラムの所謂修養・娯楽の部に対して一部の聴取者が常に感じている水準の低さに対する不満の如き不満が、やはり世界的な現象なのであろうか。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、その中でラジオが好きと迄云い切れる人が殆どないであろうのに、日本のラジオ聴取者の数は放送開始の大正十四年三月の五千四百三十四名から、昭和二年五十万を突破、昭和七年百万。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらのことももとより原因のいくつかをなしているであろうが、現実の事情はこういう文化の積極面からだけ、ラジオの聴取者を増大させているであろうか。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、極めて平凡な日常の常識から、ラジオ聴取者増大の傾向を、もうすこし深く具体的に観察して見たいと思うのである。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本全国三十の放送局は中央放送局に統一されていて、番組編成の基準は、「国民文化の表現乃至は聴取者嗜好の反映として見る限りその番組は撩乱の姿を呈している」が、「放送効果の立場よりする聴衆の必然性の吟味或は社会的公正、文化的妥当の見地より指導方針の検討が加えられなければならない。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオ・サービスとして移動ラジオ相談所を設けたり、明朗聴取運動をおこしたり、様々の点で聴取者の便宜は考えられている。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう細部での便宜があればある程、聴取者の心持に、こういう調子で短波も受けて、アメリカやフランスの国際放送を聴いて見たいという希望の生じるのも亦、自然なことではあるまいか。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオ年鑑によると、ソヴェト連邦は約六十五局、聴取者約一千万、中華民国は全国百二十局内外。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、放送協会は、日本の聴取者が、協会に向って資料として役立つ真面目な投書を少ししかよこさないことを訴えている。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリス放送協会の専務理事サー・ジョンリースは議会で「放送番組の編成並に改善は聴取者からの投書を基礎にして行っている」と明言し、ドイツで昨年音楽放送を増大したが、これは聴取者よりの希望を反映したものであると発表している。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のラジオの組織やプログラムの内容が、今日の民衆に対して、益々自発的見解を社会事象に対して忌憚なく表明させるような方向へ作用しているか、否かを公平に省察すると共に、聴取者は素直に、積極的に、中央放送協会によって公言されている次の態度を身につけるべきであろうと思う。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "協会は当事者として聴取者に求めている。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に「ラジオは百万聴取者のもの、否国民全体のものである。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人の左まわり右へは、さき頃のラジオ討論会、「宗教と科学は両立するか」の時の話し方で聴取者の腹の底までしみ渡りました。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴取者は生きている　あちらこちらでラジオのことが考えられている様子で、十二月号の『中央公論』に宮原誠一氏が「放送新体制への要望」という文章をかいていられる。",
              "citation": {
                "source": "ラジオ時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでいろいろ研究するのだろうが、それにつれて現在までの放送局の研究的な仕事のうちに、聴取者からの反響は、どんな形で調べられ統計づけられて来ているのだろうか、と思った。",
              "citation": {
                "source": "ラジオ時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、おびただしい数の聴取者を持っている文化施設として、ソヴェト同盟が絶えずラジオを文化戦線の最前列に立たせようと努力していることは、はっきりと云える。",
              "citation": {
                "source": "ソヴェト同盟の芝居・キネマ・ラジオ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりラジオ拡声装置所は集団農場の拡大につれ二万四千から五万千ヵ所に、聴取者は二百万人だったのが四百万人になろうとしている。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｃ　ラジオ　一九四五年三月日本全国のラジオ聴取者は七、四七三、六八八戸あった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二百万台の受信機の生産と二百万台の修理をしなければ七百万人の聴取者の要求を満しえない。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画会社とレコード会社の影響から自由になって、軍歌ばかりをつぎこまれていた日本人の歌のこころに、新しい瑞々しい歌と舞踊のメロディーが送られることを、一般聴取者は希望している。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオの放送当事者も聴取者も、一考すべきであろう。",
              "citation": {
                "source": "風俗時評",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラヂオ・ドラマといふ形式についても、いろいろ考へたのだが、結局、擬音といふやうな機械的な効果はそれほど問題ではなく、「語られる言葉」のあらゆる効果と、その効果による聴取者の想像力が、将来のラヂオ・ドラマを決定するのだと思つてゐる。",
              "citation": {
                "source": "「語られる言葉」の美",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「雨が降つてる」と「語らせる」のも一法であらうが、これでは、聴取者の想像力を奪ふことになつて面白くない。",
              "citation": {
                "source": "「語られる言葉」の美",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、悲しいかな、聴取者の想像力には限りがある。",
              "citation": {
                "source": "「語られる言葉」の美",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
