[
  {
    "uuid": "2ad0343d-cf38-5407-9cf5-b6ed83b52e9e",
    "entry": "地底",
    "reading": {
      "primary": "ちてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "depths of the earth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鉱車は、地底に這っている二本のレールを伝って、きし／＼軋りながら移動した。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八番坑のその奥には、土鼠のように、地底をなお奥深く掘進んでいる井村がいた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昇降機がおりて来る竪坑を中心にして、地下百尺ごとに、横坑を穿ち、四百尺から五百尺、六百尺、七百尺とだん／＼下へ下へ鉱脈を掘りつくし、現在、八百尺の地底で作業をつゞけている。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　四　五百米ばかり横に掘り進むと、井村は、地底を遠くやって来たことを感じた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも丸の内の他の建物もだんだんに地底の第三紀層の堅固な基礎の上に樹立される日が来れば、自然に建物と建物の各層相互の交通のために地下道路が縦横に貫通するようになるかもしれない。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地底がそこらまで続いているんだって、何でもないよ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども社界の裡面には常に愀々の声あり、不遇の不平となり、薄命の歎声となり、憤懣心の慨辞となりて、噴火口端の地底より異様の響の聞ゆる如くに、吾人の耳朶を襲ふを聴く。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "』かく彼が言つてその眼光を僕の心の底深く投げた時、僕ははつと此奇異なる地底の人物が僕と昔容易ならぬ交情のあつた人物である事を意識しそれと共に『現在の彼』に対する責任と疑問と警戒の念慮が胸に湧き起つた。",
              "citation": {
                "source": "殺人行者",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは地底の雷聲と天半の火柱と此流とを見聞して、心中の弱處病處の一時に滅盡するを覺えたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "板葦屋根が覆うて居てそれがもう古くなつて朽ち掛けたりした所もあるので地底の坑内へでもはひるやうな心持である。",
              "citation": {
                "source": "旅の日記",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、われわれの家は宙天から地底へまで揺れころぶ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨是れ漸く七歳のメルリンの告げたところと云ふたので、王早く其兒に逢ふて城を固むる法を問はんと自ら出迎へてメを宮中に招き盛饌を供し、翌日伴ふて築城の場に至り夜になると必ず壁が崩るゝは合點行ぬといふに、其は此地底に赤白の二龍が棲み毎夜鬪ふて地を震はすからと答へた。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "歐洲や西亞にも佛語で所謂ウーブリエットが中世の城や大家に多く、地底の密室に人を押籠め又陷れて自ら死せしめた。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "事業が繁栄すればする程地底の空虚は拡大し、危険率は無類の確実さを以って高まりつつあった。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "地上には季節の名残りが山々の襞に深い雪をとどめて、身を切るような北国の海風が、終日陰気に吹きまくっていようと云うに、五百尺の地底は、激しい地熱で暑さに蒸せ返っていた。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし竪坑から五百尺の地底に落ちると、それはもう目も当てられないほど粉砕されてしまう。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人が六本の手を高く上げたとき、地底からかすかに呻めくような音楽がきこえてきた。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽浴の正体は、中央発音所において地底を匍う振動音楽を発生せしめ、これを螺旋椅子を通じて人間の脳髄に送り、脳細胞をマッサージし、画一にして優秀なる標準人間にすることにあった。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九時といえば、古い時刻でいうならば午後七時に当るのだったが、この地底に埋もれている国には、明けることも暮れることもなく、いつも人工光線の下で生活していた。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き残った人間と、わずかの家畜と寄生虫とだけが地底にもぐりこんで種を全うした。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミルキ国の住民たちは、それがミルキ国の地底深く埋まっている無尽蔵の黄金層にあるのだと思っていた。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこのとき、誰かが耳を澄ましたなれば、轢々と地底深く何物かを引きずるような怪しき物音が聞えてくるのに気づいたろう。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その怪音は、厚い壁をとおして、地底から盛りあがるようにだんだんと大きくなっていった。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは愕いた」「博士は、廃坑の底にエンジンを持ちこんで、地底で発電しようと計画しています。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも、地上から測って、探さ数百メートルの地底に奇蹟的に生きている日本人たちであった。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その対策としては、われわれが全く地底に隠れるのも一方法だが、しかしそれでは移動性に欠け、所要の交通や貿易ができなくなるわけだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの多くは、地底定住の努力半ばに於て、坑道内で死滅。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、深刻なる地底耐乏生活百年を経て、地上に匍い出した人達は、氷河期以前の約百分の一に過ぎない。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜって、穴の中で○○獣が暴れれば、穴がますます大きくなり、やがて東京市の地底に大穴が出来るだけのことじゃないんですか」「うん、まあ見ていたまえ。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "風が強くて干し物がいくつか砂利の上に落ちている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
