        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "著名の学者の筆になる「蠅を憎むの辞」が現代的科学的｜修辞に飾られて、しばしばジャーナリズムをにぎわした。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃英国で著名の某大旅館にこれを点じたため、急に世間の注意を引く事となった。",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して著名な作家の作品を見れば如何にこれらの場合における描写が科学的に普遍で必然だと思われるように表われているかが分るだろう。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石炭でも石油でも鉄でも出るには相応に出ても世界で著名なこれらのものの産地の産額に匹敵するものはないであろう。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "著名なる新聞記者、審査員――画家、文学者、某子爵の令夫人が一人。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ L = 0 すなわちＳＫの面内に座する著名の大家を物色する事が困難である。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これについて思い出すのは、東京の著名な神社の祭礼に、街上で神輿をかついで回っている光景である。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学時代にわれわれが多く耳にしたような著名な作家の名前はここではあまり目に立たない。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、そこへ著名な日本の作曲家某氏夫妻がやって来てこの一団に仲間入りをした。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう点では、下町の素人の芝居好きの劇評のほうがかえって前述のごとき著名なインテリゲンチアの映画批評家の主観的概念的評論よりもはるかに啓発的なことがありうるようである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "著名の学者の筆になる「はえを憎むの辞」が現代的科学的修辞に飾られてしばしばジャーナリズムをにぎわした。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "※２　高陵＝磁器の原材料の産出で著名な中国の地名。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "著名な科学者の一代の大論文を読んで感心したあとで、その人のその論文を書くまでの道筋を逆にたどってそれまでのその人の著述を順々に古いほうへと読んで行くと、最初に感心させられたものが、きわめて平凡なあたりまえの落ち着き所であるとしか思えなくなって来る。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たくさんの邦産映画の中には相当なものもあるかもしれないが、自分の見た範囲では遺憾ながらどうひいき目に見ても欧米の著名な映画に比肩しうるようなものはきわめてまれなようである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る／＼内に、大陸の影も名殘りなく、眼界の外に消え失せてしまうと、其内に風はだん／＼烈しくなつて來て、はては印度洋で、著名の颶風と變つてしまつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治以後は多く振るわざりしが、江戸末期における著名の狂言作者の一人にて、黙阿弥らの先輩なり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸以来著名の女形なり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸末期には黙阿弥と対抗する著名の狂言作者にて、「佐倉宗吾」「切られ与三郎」「うわばみお由」など、その代表作と称せらる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙阿弥の高弟にて大阪における著名の狂言作者なり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治初年は新聞記者として、政論家として著名なりしが、後に転じて小説家となり、劇作家となり、歌舞伎座創立以来、同座にありて専ら団十郎のために筆を執れり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士が忽然と著名になったのは、今までまるで人の眼に触れないで経過した科学界という暗黒な人世の象面に、一点急に輝やく場所が出来たと同じ事である。",
              "citation": {
                "source": "学者と名誉",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "○故獨歩は嘗てその著名なる小説の一つに「驚きたい」と云ふ事を書いてあつた。",
              "citation": {
                "source": "歌のいろ／＼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｆ――学園の校長さんは地方の素封家出の文化人で、子供が多いところから一つ自分の手で思うような教育をしてみようと思い立ったのが始まりで、世間の子女たちも預る学校に発展さしたのですが、通って来る講師には著名の芸術家なども多く、男女共学なども行って一風変った学校でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女性の為めになら自分は一生を捧げてもよいと子供ごころに思った」　ゲーテとシュタイン夫人の友情、ジョルヂュサンド夫人とフローベルとの友情――安宅先生はこういう世界で著名な男女間の友情の例を沢山調べて知っていて美しく語った。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ぞ良い考えはないもんかな」　お前はしきりに首をひねっていたが、間もなく、川那子メジシンの広告から全快写真の姿が消え、代って歴史上の英雄豪傑をはじめ、現代の政治家、実業家、文士、著名の俳優、芸者等、凡ゆる階級の代表的人物や、代表的時事問題の誹毀讒謗的文章があらわれだした。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生懸命になつて巴里の地圖をこしらへたりして頭の中では未知の巴里の地理に一かど精通してゐるくせに、もう二年も住んでゐる此の港町の著名な競馬場へも、ひとりでは行けない。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "太子は、内治に御心を用ゐられたばかりでなく、欽明天皇の御世に亡んだ任那日本府を復興せんとし、屡々｜新羅を御征討になつたし、又推古天皇の十五年｜小野妹子を隋に遣はされて対等の国際的関係を結ばれ、尋いで高向玄理、南淵請安などの留学生を送られたことも亦、著名な事件である。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "公然の秘密ではあるが、迅速な確保の栄誉についてはその全くが、著名なるスコットランド・ヤードの警官レストレードおよびグレグソン両氏の担うものである。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "この後者が馬主として著名なロス大佐で、前者はグレゴリ警部、英国探偵界隈で急速にその名を知られつつある人物である。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、著名の豪族みな寺社領より起これり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
