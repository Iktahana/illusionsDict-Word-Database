  {
    "uuid": "dfa33475-a7e8-5753-883e-bf521cf66ec2",
    "entry": "萵苣",
    "reading": {
      "primary": "ちしゃ",
      "alternatives": [
        "ちさ",
        "チシャ"
      ],
      "is_heteronym": false
    },
    "grammar": {
