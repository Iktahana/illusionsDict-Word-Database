        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それにしても、すぐ近くの山にＮＨＫの中継局があって、おそろしくクリアに受信できるのは、なんの因果なのだろう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの諜報中継局が、アメリカの政治首都ワシントンと経済首都ニューヨークを含む地域内に潜伏していることだけは確言できる。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェトは五ヵ年計画で、ラジオの中継局とキノのステーションを何千と新しく造ろうとしている。",
              "citation": {
                "source": "ソヴェト・ロシアの素顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて之は個別化の原理にぞくする中継局の位置を占めることも出来なくはないであろう。",
              "citation": {
                "source": "イデオロギーの論理学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
