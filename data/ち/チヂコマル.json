    "definitions": [
      {
        "index": 1,
        "gloss": "to curl oneself up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
