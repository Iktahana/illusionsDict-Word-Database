    "definitions": [
      {
        "index": 1,
        "gloss": "to play a leading role",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "案内記に「四壁｜屋蓋畳むに石をもってし」とある通りで、奥宮を中心とする山の町である。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも四十二を中心とする厄年の範囲に含まれ得べき有為な年齢に病のために倒れてしまった。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる傾向は層雲を中心とする人々ばかりの間に起ったのではかい。",
              "citation": {
                "source": "俳句に於ける象徴的表現",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠅の事に就いて今挙げた片倉小十郎や伊達政宗に関聯して、天正十八年、陸奥出羽の鎮護の大任を負わされた蒲生氏郷を中心とする。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "緩漫にして長たらしきのみならば責むるにも及ぶまじきが、抑揚の余りに規則立ちたる、短急の其の自然を失ひたるなど、抑も整合を以て唯一の中心とする我劇の弊とせずして何ぞや。",
              "citation": {
                "source": "劇詩の前途如何",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って歴史に現われない歴史の原動力として、福岡人を中心とする所謂九州浪人の名を史上に記念しておく必要がないとは言えないであろう。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "問…王を中心とする自界他界、宇宙万有、地獄天堂の過去現在未来までもか。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "モットモット大きく、私共夫婦を中心とする谷山家の全体を、地獄のドン底に落ちる迄絞り上げながら、高見の見物をしてやろうという、その準備計画のために、ホンの暫くの間、姿を晦ましていたものに過ぎませんでした。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の一派は、岩倉を中心とする排幕派で、既に討幕の密勅も下っている所へ、大政奉還を申し出でたので、勝手が違ったが、たとえ武力で圧倒できなくなったにしろ、他の手段で、幕府の勢力を蹂躙しようと云うのである。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大部隊を中心とする、近世式な砲撃戦に対して、一騎討の戦法は問題でなく、虎徹は元込銃に歯の立つ道理はないのである。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、蘇我氏のかゝる不臣が許されるわけはなく、御英邁なる中大兄皇子を中心とする中臣｜鎌子（後の藤原鎌足）、蘇我｜倉山田石川麻呂、佐伯子麻呂等の活躍に依つて、皇極天皇の四年六月、入鹿は大極殿に於て、誅戮を受けたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如くにして養はれて来た源平二氏を中心とする武士の勢力は、保元の乱に於て、遂に中央の舞台に躍り出たのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、当時、堺の町に多数の外人が居留して、商業が盛んなのに目をつけ、大坂を政治の中心とすると共に、腹心の石田三成を堺町奉行として、外国貿易を自家の監督下に置いた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、大久保を中心とする政府は、よくその措置を誤らず、徹底的に之を鎮定して、明治政府の基礎を確立すると共に、新興日本から不平分子を一掃したのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此主張はもとより史的の正確不正確を以て爭ふべきでも無く、又其主張の中に含まれてゐる意圖の善惡等を以て爭ふべきでも無く、自己を中心とする楊朱の刻薄な思想などより遙に立勝つてゐる博大な善良な立派なものである。",
              "citation": {
                "source": "墨子",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "信濃を中心とする諸高山には劣るも、緯度高きを以て、山上の草木風物は、信濃附近の一万尺以上の高山と匹敵する也。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮に小説を中心とするにしても各方面の作家を網羅する計画で、硯友社叢書とするツモリはなかったのだ。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、本来根岸党の名は根岸を中心とする文人の一群を指して他から与えた名称であって、渠らは折に触れて相集っていわゆる詩酒徴逐の風流に遊んだが、酒を以て集まる無形の交友倶楽部であって、硯友社のような文壇的運動を目的とする団結ではなかった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人物はギリシアの英雄であつたが、服装その他はすつかり当時のフランスの宮廷を中心とする人士の好みに投じたものであつた。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、古典文学が、宮廷生活を中心とする貴族のイデオロギイの表白であつたに反し、新興ブルジヨア階級のイデオロギイの表白であつたことは、多くの文学史家がひとしく認めてゐるところである。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めて大まかな眼で見ると、東京の北部、吉原と浅草を中心とする一帯の地域は、東京に於ける犯罪者の根拠地といって差支えないであろう。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この傾向は、カフェとダンスホールの増加に正比例して、今年にはいってから、ますます知識階級を中心とする消費者階級に全盛の勢いを見せている。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "その建築はどうやら生ける腸の入ったガラス管を中心とするように見えた。",
              "citation": {
                "source": "生きている腸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、「眼根」と「色境」と「眼識」とが和合すると、ここに「眼」を中心とする一つの世界ができるのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして面妖にも、青色の極東を中心とする大地図が消え失せて、あとには始めにみた花鳥の図が、何事もなかったように壁間に掛っていた。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下（漁舎のこと）を中心とする数十間の地の積雪は、屈強な男たちの担ぐ畚に運ばれて、またたく間に除かれてしまった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "松がかなりな林を成してゐるのはそこだけで、松茸は其處以外ではほとんど採れなかつたから、その松林を中心とする一帶が自然茸狩りの場所にきまつたわけだ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿介は、東京を中心とする地方の、關東の諸地方の農村を思ひ出してゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家に附いてゐる、そして彼女が耕作しなければならない土地の廣さは、屈強な男手を中心とする一家の經營としてもなほ足りるほどのものであつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
