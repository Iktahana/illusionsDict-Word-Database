[
  {
    "uuid": "e497d5bd-ba03-5f06-9c4c-4ce45c563716",
    "entry": "誓って",
    "reading": {
      "primary": "ちかって",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
