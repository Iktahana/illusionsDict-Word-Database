    },
    "definitions": [
      {
        "index": 1,
        "gloss": "surely",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は、エホバにだって誓って言えます。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、いくらいかに慧鶴が無情の素振りを示そうとも、彼を待ちつつ、いつまでも心に変りはないことを繰り返し繰り返し誓ってあった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、戦敗れ、自刃する際に臨んで「七度この世に生れて君恩に報いん」とさえ誓っております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誓って御教の如く解し行じ持ち、また普く一切に施さん。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、きみに対して、今は誓って悪心でない、真心だ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "誓って冤罪はお被せ申しません。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……誓ってそう云った因縁があるのですから、私に免じて、何うか、この塔婆は嬲らないで下さい。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　誓ってお前を厭きはしない。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "平に一夜、御住居の筵一枚を貸したまわれ……」　――旅僧はその時、南無仏と唱えながら、漣のごとき杉の木目の式台に立向い、かく誓って合掌して、やがて笠を脱いで一揖したのであった。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と熱心に云えば冷かに、「いや、分別も何もなし、たといいかなることありとも、母上の御心に合わぬ事は誓ってせまじ。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、開けない以上は、誓って、一冊の旅行案内といえども取出さない事を盟約する。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "誓って私は革鞄を開けない。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十時が鳴る丁度その瞬間、今晩やるんだと、一日中心に誓ってきたことをやってのけよう。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は復讐を誓って十八年もの間お前を探し求めていた。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "『神さまに誓ってもいいよ――』　イワンは、生れてない感動に我を忘れて、そう叫びました。",
              "citation": {
                "source": "イワンとイワンの兄",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "誓って責務を遂行します。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいか、あの人に、こう言ってくれ、レヤチーズの妹を、なぐさみものにしたならば、どいつこいつの容赦は無い、どのようなお身分の方であっても生かして置けぬと、レヤチーズが鬼神に誓って言っていました、とそう伝えてくれ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、ホレーショーどの、誓って下さい。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしの、これから言う事を必ず他言しないと誓って下さい。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしは、神さまに誓って申し上げますが、あたしは正直でございます。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、目がさめて、きょうこそは、しっかりした意志を持ちつづけて悔いなく暮そうと、誓ってお床から起き出すのですけど、朝御飯まで、とっても、もちません。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王の言に曰く、予始め難に遘う、已むを得ずして兵を以て禍を救い、誓って奸悪を除き、宗社を安んじ、周公の勲を庶幾せんとす。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "またちっとでも強情りがましい了見があったり、一銭たりとも御心配を掛るような考があるんなら、私は誓って口は利かんのです。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……必ず、連れて参ります――と代官｜婆に、誓って約束をなさいまして、学士先生は東京へ立たれました。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "図書　以後、お天守｜下の往かいには、誓って礼拝をいたします。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "図書　誓って、――仰せまでもありません。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その六人の女中のうち、ひとり目立って貧しげな女の子に、声高く夫婦約束をしてやって、なおそのうえ、女の微笑するようないつわりごとを三つも四つも、あらわでなく誓ってやったものだから、女の子、しだいに大学生を力とたのんだ。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればといって、この要求だけは、自分は誓って先生の注文に応ぜられない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはかの女がわたしに「二人はお互いよ」と誓ってわたしもそれを守って来たものではあるが、それにしても肉体の均勢がとれたかの女の、而かも幾人かの男を次々と愛し取った身の上として、その精神に伴わざる肉体的の克己はどのように辛かったろう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、この学生こそ、姿をかえた神さまか、そうでなければ、神さまの家族のものにちがいない、と、ちかってもいいとさえ、思ったほどでした。",
              "citation": {
                "source": "人形つかい",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
