          "literary": [
            {
              "text": "それでもとやかく申す奴があったら、この有村たたっ切る」「痴言申すな！",
              "citation": {
                "source": "犬神娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「織江とかいう女、助けたがよろしい」「…………」「売かして、金にして、飲むとはどうだ」「貴殿たちにはよろしかろう」「貴殿も飲むのじゃ、三人で飲むのじゃ」「飲む飲まぬ、何を痴言、息ある限りあの女、拙者を狙うことご存知ないか！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ワッハハハ、何を痴言！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワッハハハッ、何を痴言！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さようの痴言申そうより、命が惜しく罪着るが恐い、それゆえ止めじゃと仰せられい！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇想｜却つて平凡の如くに見え、妙刺却つて痴言の如くに聞え、快罵却つて不平の如くに感ぜらる、斯の如きもの、緑雨が撰みたる材料の不自然にして顕著に過ぎたるものなりしことより起るなり。",
              "citation": {
                "source": "「油地獄」を読む",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度そこで申してみろ」「はずみに申した下司の痴言、お聞捨てにねがいます」「はずみとは言わせぬ。",
              "citation": {
                "source": "鈴木主水",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆愚痴言ひつゝ相談する。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ酌こう」　と、土岐左近をつかまえて、ほかの痴言猥歌もよそに。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "大通りなどにあるいちげん客の宿屋じゃない。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
