[
  {
    "uuid": "bfb96d52-c632-5d6d-94e5-e2bc679bf1d8",
    "entry": "中世史",
    "reading": {
      "primary": "ちゅうせいし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
