    "definitions": [
      {
        "index": 1,
        "gloss": "to order (someone to do something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
