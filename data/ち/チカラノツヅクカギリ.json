          "literary": [
            {
              "text": "各地の銀行や仲買店を次から次に汗だくだくで呼び出しつつ、資力の続く限り製糖株を買いにまわった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "引力の続く限り針は……」　なる程僕は、この頃はじめて此処のＳとＮの方向を知つた。",
              "citation": {
                "source": "駆ける朝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私とダンチョンとは物をも云わず土人の声の聞こえない方へ力の続く限り走って行った。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "危難を遁がれた島君は険しい峠を上へ上へと力の続く限り駈け上がった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
