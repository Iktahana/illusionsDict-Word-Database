    "definitions": [
      {
        "index": 1,
        "gloss": "tea gathering (for the tea ceremony)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "奥州武士の伊達政宗が罪を堂ヶ｜島に待つ間にさえ茶事を学んだほど、茶事は行われたのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりでは無い、政宗も底倉幽居を命ぜられた折に、心配の最中でありながら千利休を師として茶事を学んで、秀吉をして「辺鄙の都人」だと嘆賞させたが、氏郷は早くより茶道を愛して、しかも利休門下の高足であった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして茶事が終ったから謝意を叮嚀に致して、其席を辞した。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥州武士の伊達政宗が罪を堂ヶ島に待つ間にさへ茶事を学んだほど、茶事は行はれたのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛永元年五月｜安南船長崎に到着候時、三斎公は御薙髪遊ばされ候てより三年目なりしが、御茶事に御用いなされ候珍らしき品買い求め候様｜仰含められ、相役横田清兵衛と両人にて、長崎へ出向き候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "横田聞きも果てず、いかにも某は茶事の心得なし、一徹なる武辺者なり、諸芸に堪能なるお手前の表芸が見たしと申すや否や、つと立ち上がり、脇差を抜きて投げつけ候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛永元年五月｜安南船長崎に到着候節、当時松向寺殿は御薙髪遊ばされ候てより三年目なりしが、御｜茶事に御用いなされ候珍らしき品買求め候様｜仰含められ、相役と両人にて、長崎へ出向き候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "相役聞きも果てず、いかにも某は茶事の心得なし、一徹なる武辺者なり、諸芸に堪能なるお手前の表芸が見たしと申すや否や、つと立ち上がり、旅館の床の間なる刀掛より刀を取り、抜打に切つけ候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "只圓翁の茶事に疎かりし事は御説の通りに候。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "南坊流の始祖南坊禅師は茶道の堕落を慨して茶事を捨て去つて再び世に出でず。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、衛養療法や静座法を研究する意で千家の茶事を学ぶに等しい二葉亭の態度では禅に満足出来るはずがないのが当然で、結局禅には全く失望した。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の茶事を何と心得おるか。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間のことはなんでも心得ているように思ったが、残念ながら半七は茶事に暗かった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶事に用いる三つ羽箒には野雁の尾羽を好しとするが、その中でも黒に白斑のあるのを第一とし、白に黒斑のあるのを第二とし、数寄者は非常に珍重するので、その価も高い。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "女と茶入９・６（夕）　小堀遠州といへば、茶人切つての技巧家だが、実世間の世渡りも万更ではなかつたと見えて、徳川の二代将軍秀忠にも気に入つて、茶事といへば屹度相談を受けたものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「近況茶事御取出しの由川上｜宗壽、三島の鯉昇などより傳聞｜仕候、宗壽と申候者風流なる人にて、平家をも相應にかたり、貧道は連歌にてまじはり申候、此節江戸一の茶博士に御座候て、愚姪など敬伏仕り居候事に御座候。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "益田氏と山県氏とは単に茶事ばかりの朋友ではない。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は松山城下で錦雲舎という菓子屋の主人であったが、茶事も裏千家の高弟で、また俳句は大阪の芹舎の門人であったので、廃藩後は京都へ住居して水力応用の紡績機械を販売する、傍ら茶と俳諧の宗匠をも兼ねる事になった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今後のお茶というものは、プロレタリヤの境界にあっては、吾人が過去に聞かされたり、教えられたりした古人の心づくしになるお茶事は、もはや再び真似事さえ成し得られるものではない。",
              "citation": {
                "source": "茶美生活",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "現存者中、私の知人に、月並越えて茶事が好き、茶の教えも推量するという二人がある。",
              "citation": {
                "source": "茶美生活",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "完成したお茶事の構想から審美の感覚をのけものにしては、お茶道は全部崩れもすれば嘘にもなるのである。",
              "citation": {
                "source": "茶美生活",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ためにある種の卑俗茶と悪化し、風趣高かるべきせっかくのお茶事を、めちゃめちゃに歪め、俗臭紛々、世の末を思わし、心ある者をして、嘆息せしめざるを得ないのである。",
              "citation": {
                "source": "茶美生活",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらを研究し、それを理解すべく努力し、古人の源意を洞察し、終に古人に学ぶところ多しと、われを捨て茶事の功徳にぬかずくまでに至ってこそ、開眼の念願は達し得られるのである。",
              "citation": {
                "source": "茶美生活",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内容は大正年間尚存するところの茶事に係る名器を蒐めたものである。",
              "citation": {
                "source": "高橋箒庵氏の書道観",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、小學一年生の私は父に伴はれて茶事に列したのである。",
              "citation": {
                "source": "桜もち",
                "author": "心猿",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳をなめそうに、忠相は口を開いて、「新茶の封に宇治で貼りました奉書は、封切りの茶事で縁を切りますだけで、蓋の奉書はそのまま残ります。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも新茶を取りに宇治へやった壺……厳重に封をして当方へ持ち帰り、御前において封切りの茶事を催して開くのです。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "利休がある庭へ招かれた時に茶事の後に黙ってかえったが、あとで石の中に一枚だけ入れかえてあったことを見抜いたそうであった。",
              "citation": {
                "source": "庭をつくる人",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
