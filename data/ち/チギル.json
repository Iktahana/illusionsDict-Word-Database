[
  {
    "uuid": "cd0e04b8-396d-5df8-9329-2ab5f5bcd69f",
    "entry": "契る",
    "reading": {
      "primary": "ちぎる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
