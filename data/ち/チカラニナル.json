[
  {
    "uuid": "b7e3dc4f-e41f-56d4-9f6a-e9dcc4459f4f",
    "entry": "力になる",
    "reading": {
      "primary": "ちからになる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行"
      ],
