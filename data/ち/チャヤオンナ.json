[
  {
    "uuid": "38811019-a196-5e9f-aac1-8d10ac60f669",
    "entry": "茶屋女",
    "reading": {
      "primary": "ちゃやおんな",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
