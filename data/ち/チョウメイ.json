    },
    "definitions": [
      {
        "index": 1,
        "gloss": "long life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小生の母も病弱で、おまへの父上同樣、長命は保證できません。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日前に百花園からつるの手をつけてある目籠に長命菊つくし石竹の苗其他数種の青草を植込にしたやつを買って来て置いたのを持って往ったのであるきょうは暖炉の掃除をやったとの事で先生は八畳の座敷に石油暖炉をたき東向になってねていられた。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで私のように長い病気で久しく仕事をしないで生きているものはそれではその逆で自然が仕事が出来るまで長命さして呉れるだろうか、あるいはながいき出来そうな気もする。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "○長命寺の下、牛の御前祠の地先あたりは水｜特に深くして、いはゆる○墨田の長堤もまた直に水を臨むをもて、陽春三月の頃は水の洋たると互に相映発して、絶好の画趣と詩興とを生ず。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "長命をさせたいのは山々だけれども、齢も齢だし、あの体では所在もないし、手と云つてはねつから届かないんだから、あゝして生きてゐるのが却つて因業だと、兄は来る客ごとにお世辞の一つのやうに云ひ慣はして居た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して仕舞ひには自分までがほろりとなつて、「いゝさ暢気者は長命するつて云ふからね、お母さんはもう長くもあるまいし、兄さんだつてあゝ身をくだいちや何時病気になるかも分らない。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蓑ちゃん、長命寺のさくら餅屋知ってる」「ああ知ってるよ。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓碑に寛延の年号が刻んであるのを見るとよほど長命であったらしい。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の夕刊が二枚と、『探偵小説全集』が一冊と、『南京鼠の合理的長命法』と云うパンフレットと、古い帝国ホテル舞踏会の案内状が一枚出て来たばかりでした。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "古仏と云はれた人の真似も長命も、無論自分の分でないかも知れないけれども、羸弱なら羸弱なりに、現にわが眼前に開展する月日に対して、あらゆる意味に於ての感謝の意を致して、自己の天分の有り丈を尽さうと思ふのである。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃病身の癖に、壮健な彼と同じやうに長命する秋成を腹でいまいましがつてゐる老人だつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏の一生を通じて、氏は餘り有るの聰明を有してゐながら、それを濫用せず、おとなしく身を保つて、そして人の事にも餘り立入らぬ代りに、人にも厄介を掛けず人をも煩はさず、來れば拒まず、去れば追はずといふ調子で、至極穩やかに、名利を求めず、たゞ趣味に生きて、樂しく長命した人で有つた。",
              "citation": {
                "source": "淡島寒月氏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾祖母も祖母も母も、みなそれぞれの夫よりも長命である。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "師匠の鯉丈はその時分長命の芸人によく有り勝ちな枯淡厭世の時期に入っていた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれ、上見りや限りやなし、下見りや限りやなし、諦めさんせの、因果なもんだよ、泣いても焦れても、死ちたらお陀仏、やつこらさつさ、やつこらさ、長命や為まいぞ地獄の夕焼。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "天竺は火事じや、世は火事じや、長命や、耻かい、地獄の夕焼、やれ、もひとつくだれ、下り坂やれ、もひとつあがれ、上り坂やつこらさつさ、やつこらさ。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇子は、日本でがんが卵をうんだということは、これまで一度もお聞きになったことがないものですから、たいそうふしぎにおぼしめして、あとで武内宿禰を召して、「そちは世の中にまれな長命の人であるが、いったい日本でがんが卵をうんだという話を聞いたことがあるか」とこういう意味を歌に歌っておたずねになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻の両親も健康で長命だ。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の両親も健康で長命だった。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後も子孫繁昌して、彼は八十歳までも長命して天寿をまっとうした。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "録異記",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんにおめえもお品さんに死ならつたのが不運だつけのさな、そんだがおめえ長命したゞけええんだよ」婆さん等は口々に慰めつゝいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々がみな去つてしまひ、がらんとした講堂の中に、野村長命博士が腑抜けのやうに、前方の黒板に、講演者がチョークで書きのこして去つた、直線や、電光形や、渦巻きやの白線を凝然とみつめてゐた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大英百科全書』十一版一六巻九七六頁に、犬は十六より十八歳まで生き得るが、三十四歳まで長命の例も記されたと見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "げにや、『人生讀書憂患始』、人も此のやうに沒分曉漢になれば、長命は出來る筈也。",
              "citation": {
                "source": "赤城山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "師匠没後養母お悦さんは心細いことと思い私は出来るだけ気を附けておりましたが、明治三十二年八月十九日、七十九歳の長命でおきせさんの家で没しました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "身を引いた時のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなか長命で四、五年前までお健者でした。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "牙彫りを排し木彫りに固執したはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "人参を飲んで屹と癒るものならば、高貴のお方は百年も長命する筈だが、そうはならない。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓碑に寛延の年号を刻んであるのを見ると、よほど長命であったらしい。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は八十二歳の長命で、明治三十七年の秋に世を去った。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『あの伯父が、僕達の家族の周囲では、一番長命なんだ……。",
              "citation": {
                "source": "ある日",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
