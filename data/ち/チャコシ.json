        "examples": {
          "standard": [
            {
              "text": "お茶を淹れる時は、必ず茶こしを使って茶葉を濾す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "紅茶を飲む時に、茶こしがなくて困ったことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この茶こしは目が細かくて、とても使いやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "先に小さい楕円形　紅茶こしのような金のたまがついて居る。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さじ、ナイフ、紅茶こし、化粧品類、手帳鉛筆その他文房具および装身具。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
