    "definitions": [
      {
        "index": 1,
        "gloss": "restorer of a dynasty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
