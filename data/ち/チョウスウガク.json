        "examples": {
          "standard": [
            {
              "text": "超数学は、数学の基礎や論理構造を探求する分野である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は超数学の論文を読み、その難解さに頭を悩ませた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "超数学的な視点から、数学の公理系を再検討する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "只この一歩を理解する為には百里の半ばを九十九里とする超数学を知らなければならぬ。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "決死の軍に超数学的の援兵がある真実は、幼少の時、阿部川の印地打ちの勝敗を予言したほどの家康は、知って知り過ぎている、それがなお且つ、それを計りそこねたのだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
