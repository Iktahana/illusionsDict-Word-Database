    "definitions": [
      {
        "index": 1,
        "gloss": "volley of rifles at a funeral",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白い函の横に供へられた桔梗二三輪、鳩が二三羽飛んで来て、空にひるがへる、すすり泣きの声が聞える、弔銃のつゝましさ、ラツパの哀音、――行列はしゆく／＼として群集の間を原隊へ帰つて行つた。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こういわれると、ちょんさんはくやしがって、負けずに弟の名前を呼んで、からかい返してやろうとしましたが、「ちょうにん、ちょうにん、ちょうじゅうろう、まんまる入道、ひら入道、せいたか入道、へいがのこ、いっちょうぎりの、ちょうぎりの。",
              "citation": {
                "source": "長い名",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
