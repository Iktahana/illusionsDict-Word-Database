[
  {
    "uuid": "0c3ecd57-bf93-55b5-ba8a-811c3171378e",
    "entry": "着衣",
    "reading": {
      "primary": "ちゃくい",
      "alternatives": [
        "ちゃくえ"
      ],
      "is_heteronym": false
    },
    "grammar": {
