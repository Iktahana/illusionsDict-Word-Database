    "definitions": [
      {
        "index": 1,
        "gloss": "frizzy (hair)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "早春の淡紫に湿つた土の上で、独楽はチリチリヽヽといふ微かな音を立ててシンミリ廻つた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年｜小田原の浜べで大波の日にヘルムホルツの共鳴器を耳に当て波音の分析を試みたことがあったが、かなりピッチの高い共鳴器で聞くとチリチリチリといったように一秒間に十回二十回ぐらいの割合で断続する轢音が聞こえる、それがいくらかこの蝗群の羽音に似通っているのである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に、千鳥と名のあるのは、蕭々たる夜半の風に、野山の水に、虫の声と相触れて、チリチリ鳴りさうに思はれる……その千鳥刈萱。",
              "citation": {
                "source": "玉川の草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の中へ迷ひ込んで来る虫を、夏の虫かと思つて団扇で敲くと、チリチリと哀れな鳴声のまま息絶えて、もう秋の虫である。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "川千鳥がそこまで通って、チリチリ、と音が留まった。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽目も天井も乾いて燥いで、煤の引火奴に礫が飛ぶと、そのままチリチリと火の粉になって燃出しそうな物騒さ。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "手足の先がチリチリ痛むのだった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなホールの中へ、こおろぎが一匹、何にあこがれたのか、さまよい込んで、ピョンとはねた途端、クイックターンのダンスシューズの先に蹴られて、チリチリと哀れな鳴き声のまま、息絶えたが、その声はバンドの騒音に消されて、たれも気がつかなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがの佐伯もそんな部屋にいてはますます病気を悪くするばかりだとチリチリ焦躁を感じていたらしかったが、ほかのアパートや部屋へ移ろうとしない。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵に脱ぎ捨てた浴衣をまた着て、机の前に坐り直した拍子に部屋のなかへ迷い込んで来た虫を、夏の虫かと思って団扇ではたくと、チリチリとあわれな鳴き声のまま息絶えて、秋の虫であった。",
              "citation": {
                "source": "勝負師",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "左の肩へ離れて一ツ在るのが一番大きかったが、その一つ一つに一本｜宛、長い毛がチリチリと曲って生えているのが大変に珍らしかったので、陸に上ってから繰返し繰返し引っぱった。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに老齢で、足はチリチリと冷えるが、それも足袋をはいて寝れば、いくらか我慢が出来る。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その拍子に、母親に返辞一つしなかった自分の態度がチリチリ後悔された。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛り場の灯がチリチリと冷たく、輝いていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢやすぐ行きます……」かう言つて、チリチリンと電話が切れた。",
              "citation": {
                "source": "時子",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、いい秋虫の朝音が、チリチリと庭の茂みからきこえました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "死なないものも火の勢いに恐れてチリチリバラバラに逃げ失せた。",
              "citation": {
                "source": "猿小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――陸の場合のように、住所がチリチリバラバラになっていないこと、それに下地が充分にあったことが、スラスラと運ばせた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し残っていた石油が、雨に濡れた地面にチリチリと紫色の波紋をつくって広がった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "門をあけると、ベルがチリチリンと鳴った。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "チリチリこまかにちぢれた髪のイリーナが、賢い皮肉な笑顔で云った。",
              "citation": {
                "source": "ワーニカとターニャ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、手足にはめた黄金の環飾りをチリチリ鳴らし、何か叫んでぼんぼん、ぼんぼん幾つもの球を巧に投上げては操つって見せる。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "永き日の読書にも倦んじて、話すべき友も傍にはおらず、かかるとき肱を枕にコロリとなれば、軒の風鈴に緑を吹き来る風の音｜喧からず、そのチリチリに誘われてツイ華胥の国に遊び去る、周荘が胡蝶の夢も殊の外に安らかで、醒めぎわの現なしにも愛らしき音は何の妨げともならぬぞ嬉しい。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時電話がチリチリとなつたので彼はいそいで立つて行き、暫く話していたが、まもなくそれが終ると、にこにこしながらもとの椅子に腰をおろした。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘のころチブスにかかって髪が生えかわってからチリチリの縮れっ毛になってしまった。",
              "citation": {
                "source": "鴻ノ巣女房",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手足胴体チリチリバラバラ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その下辺のあたりから、幾つとない火の玉が、チリチリと捲き縮んでいって、現われてはまた消えてゆくのだった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、そうしてしばらく、毛の焦げるような匂いが漂い、チリチリ捲き縮まってゆく、音のみが静寂を支配していたが、そのうち、時江はいきなり身体をもじらせて、甲高い狂ったような叫び声をたてた。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
