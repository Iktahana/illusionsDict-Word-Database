  {
    "uuid": "8f6e9ef2-88db-5a1d-a002-95a0595f357c",
    "entry": "腸線",
    "reading": {
      "primary": "ちょうせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "catgut",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自動車教習所のような環状の道には徒労感が伴うし、岬の果てや盲腸線といった想像は淀みに通じる。",
              "citation": {
                "source": "鉄道模型の夜",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分の方法を完成するのに熱心に働き結紮および縫合のための吸収される無菌の腸線の使用を導入した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、正吉くんは、あかずに、ちょうせんぶなのダンスをするのをながめていました。",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おじいさん、ちょうせんぶなあるの？",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さん、ちょうせんぶなを買うのだからお金をちょうだい。",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょうせんぶななんてあるのですかね。",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といって、小田くんのところで見てきたちょうせんぶなの説明をいたしました。",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "正ちゃんは、ちょうせんぶなを買ってきてどこへ入れるつもり？",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうせんぶななんか入れては金魚をみんな食ってしまうじゃないの。",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "太田さんのお家にもちょうせんぶながいたけれど、おなかがすくと、共食いをはじめて、強いちょうせんぶなが、ほかの弱いのをみんな食べてしまったというのよ。",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、いやなちょうせんぶななんかかわなければね……。",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼく、小ばこをくれれば、ちょうせんぶななんか買わないよ。",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもいい味のもので、じゃがいもと、ちょうせんあざみと、それからいろいろの野菜をいっしょにした味がするのであった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
