        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "例の大氷柱に、ポツンと載った、オードヴル、コーンチャウダー、あとはチーフ任せで松茸飯みたいなもの、バゞロア。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーンチャウダーに、オルドヴル、スパゲティに肝、あんまり凝られるので反ってうまくない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンチャウダーに、ツルネード。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルドヴル、コーンチャウダー、ミニツステーキにマカロニ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンチャウダー、ソセヂサワクラウト、挽肉のもの。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンチャウダーと、肉の刻んだのを食ったが、うまくない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャウダー風のスープ、鱒のムニエル、チキンのフライド、少し残す程度に食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
