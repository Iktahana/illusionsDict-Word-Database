        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あひなるべくは多治見へのして、陶器製造の模樣までで、滯在少くとも一週間の旅費として、一人前二十五兩、注におよばず、切もちたつた一切づゝ。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "画と田地３・２　政友会の本出保太郎氏は、代議士になつてゐた頃は、世間に代議士ほど偉い者はないといふ考へで、「そら君、何ちたつて国会議員やからね……押しも押されもせん国民の選良さ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内に向う川岸の藝者屋が川へ落ちたつて言ふのよ。",
              "citation": {
                "source": "梅龍の話",
                "author": "小山内薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどぼくならもし落ちたつて落ちてうれしいジヤム地獄。",
              "citation": {
                "source": "歌時計",
                "author": "童謠集",
                "note": "青空文庫"
              }
            },
            {
              "text": "話をきくと全然無茶な答案で、名題の吉屋信子女史を古屋信子と言つて済してゐる没常識だから落第に間違ひないと思つてゐたら、何百人ものうちたつた一人及第したといふのには呆れかへつた。",
              "citation": {
                "source": "篠笹の陰の顔",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、おれには、そのうちたつたひとつが必要なんだ。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちたつ女の実兄の長男で、そのとき二十一歳であった。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
