    "definitions": [
      {
        "index": 1,
        "gloss": "father's side (of the family)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
