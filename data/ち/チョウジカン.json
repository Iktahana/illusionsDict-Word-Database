[
  {
    "uuid": "4cfda29d-c119-5782-8291-4935e7eb7004",
    "entry": "長時間",
    "reading": {
      "primary": "ちょうじかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
