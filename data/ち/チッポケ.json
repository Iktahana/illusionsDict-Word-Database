    "definitions": [
      {
        "index": 1,
        "gloss": "very small",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つまりくだらないから俺はこんな沈滞した小っぽけな田舎にはいないと言うただけじゃないか。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くの「銀砂」という小っぽけな珈琲店にはいった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、小っぽけな電球の町工場をもっている松田という男に、口金代百円許り貸していて、抵当に電球三千個とっていた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "△私は以前から小っぽけな純文芸雑誌発刊の希望を胸ふかく抱いています。",
              "citation": {
                "source": "鎖ペンを握って",
                "author": "――三月十九日夜――　　山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんがいくら八っちゃんは弟だから可愛がるんだと仰有ったって、八っちゃんが頬ぺたをひっかけば僕だって口惜しいから僕も力まかせに八っちゃんの小っぽけな鼻の所をひっかいてやった。",
              "citation": {
                "source": "碁石を呑んだ八っちゃん",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは小っぽけな、知恵と元気とに充ちた地の精霊の無邪気と悪戯っ気とです。",
              "citation": {
                "source": "初蛙",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、焼くぞ、こんな燧石箱のような小っぽけな祠は、またたく間に灰にしてしまうぞ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三河万歳",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手の傍屋は、安ものの壁紙を作る小っぽけな工場になっている。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは頗る美貌の、凝った身なりをした栗色の髪の男で、表情に富んだ鳶色の目と、細い小ぢんまりした白い鼻をもち、小っぽけな口の上に、ちょび髭を生やしている。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは嫉妬したり、自分の小っぽけさ加減に愛想をつかしたり、馬鹿みたいにすねてみたり、馬鹿みたいに平つくばったり、――そのくせ、どうにもならない引力で彼女の方へ引きつけられて、彼女の居間の敷居をまたぐ都度、わたしは思わず知らず、幸福のおののきに総身が震えるのだった。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分の恋も、それに伴ういろんな興奮や悩みも、いま新たに出現した未知の何ものかの前へ出すと、我ながらひどく小っぽけな、子供じみた、みすぼらしいものに見えた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな小っぽけな変革ではありません。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "千世子は叔母のひらったい顔と小っぽけな額を思い出した。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はおどろいて、一体どうして暮して行くのだろうかと考え考え、小っぽけな砂糖袋をもって、お七で有名な吉祥寺の前の春の通りを歩いて行ったことを覚えている。",
              "citation": {
                "source": "打あけ話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "原の中へ拵えるものとなると、高値なものではいけないが、といって小っぽけな見てくれのないものでは、なおさらいけない……どうでしょう。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "佐竹の原へ大仏を拵えたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その歯、おかしくて可愛いいわ」「いやだ――何だか小っぽけな癖に生意気らしいんですもの」　その晩泊り、三人一つ蚊帳に眠った。",
              "citation": {
                "source": "九月の或る日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「森」の舞台には、ひとすじの思い切って長く美しい線をもった木橋と、小っぽけな木にペンキを塗った門とブリキ茶罐。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの草の根方に、小っぽけな人間の形をしたものが一杯居る。",
              "citation": {
                "source": "草の根元",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランツは、二人の小っぽけな娘と組になった。",
              "citation": {
                "source": "顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何に飛騨の山の中にいたんでさあ、飛騨なんて小っぽけな国でね、これから信州へ帰るんでさあ。",
              "citation": {
                "source": "木曾御嶽の両面",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "◎ハッとして息をとめた瞬間、空中に一杯になって居る小っぽけな羽虫が、一どきにオミヨ、オミヨ、ワラー　と大変早口にうたったように聴えた。",
              "citation": {
                "source": "「禰宜様宮田」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い部屋だから、眼に力をこめて凝視すると、画と実物の貝殼などとのパノラマ的効果が現れ、小っぽけな窓から海底を覗いて居るような幻覚が起らない限でもないのだ――大人にパノラマが珍重された時代が我々の一九二六年迄かえって来る。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　けれど彼女は大木ではなくて、ほんの小っぽけなしなびた草でありました。",
              "citation": {
                "source": "アッタレーア・プリンケプス",
                "author": "ATTALEA PRINCEPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は小っぽけな草ですから、とても自由なんぞ望めそうもありませんが、あなたはそんなになりも大きいし、力もおありですもの！",
              "citation": {
                "source": "アッタレーア・プリンケプス",
                "author": "ATTALEA PRINCEPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一つお願いは、あなたが自由の天地へお出なすったとき、時たまはこの小っぽけな友だちのことを思い出して下さいね！",
              "citation": {
                "source": "アッタレーア・プリンケプス",
                "author": "ATTALEA PRINCEPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "その右頬に小っぽけな古傷が、「知らん顔」してくっついていた。",
              "citation": {
                "source": "古傷",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその小部屋の壁際に、窮屈そうな三本脚の寝台を据えつけて、その上へ、こちこちのまるで揚煎餅のように薄っぺらな、また恐らくは揚煎餅のように脂じみた、小っぽけな、どうやら蒲団らしい代物をかぶせたが、それは宿屋の主人からうまく借り出して来た品である。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "小っぽけな子供なんぞ袖の下にはいってしまって、父は桟敷にがんばる。",
              "citation": {
                "source": "流れた唾き",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "小っぽけな旦那で、黒ちりめんの羽織で、お刀がチョコンと突っぱって、その風采のみっともなさってったら、あたくしが吹きだしますとね、その人が後を振りむきましたのですよ、どうもあの老爺さんに違いないのですが、あたくしもよく似た人があるものだと思って感心いたしましたが……」　クスクスおばあさんは笑った。",
              "citation": {
                "source": "木魚の顔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほこりを浴びて、私はせいぜい小っぽけな鉛筆をくすねるだけで生きている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
