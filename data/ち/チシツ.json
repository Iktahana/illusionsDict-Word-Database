    },
    "definitions": [
      {
        "index": 1,
        "gloss": "geological features",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "地理学教室ではペンクや助手のベーアマンが引率して近郊の地質地理見学に出掛けた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "フニクラレの客車で日本人らしい人に出会って名乗り合ったら、それは地質学者のＫ氏であった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地理学書でもまた物語でも読んで知っていたアトリオ・デル・カヴルロとかソマムとか、こういう名前も何となく嬉しく、また地質学者から教わる色々の岩石の名前も珍しかったと見えてよく覚えている。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下り坂の茶店で休んだときにそこのお神さんが色々の火山噴出物の標本やラヴァやカメーの細工物などを売付けようとしたが、こしらえもののいかものだけはわが地質学者を欺く訳に行かないのがおかしかった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "片言のイタリア語でお神さんに「コレ、日本の地質学者。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文中の『大日本地誌』は、山崎直方佐藤伝蔵両氏の編で、地質地形等は両氏が受け持ち、部分的の地誌は、花袋らが分担記述していたのであった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その夕、電燈｜煌々として自動車の目まぐるしく飛び交う賑やかな町中で、一枚の号外を握って、地質時代の出来事であるところの、氷河退却時代が、眼のあたりに見られるのだと思った。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち永久に地殻の一部を作っているので、地質学者は雪を岩石の部に編入しているほどである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この山と地質は同じです。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地質調査をするときはこんなどこから来たかわからないあいまいな岩石に鉄槌を加えてはいけないと教えようかな。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならそこは第三｜紀と呼ばれる地質時代の終り頃、たしかにたびたび海の渚だったからでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天文、気象、地質、海洋等に関する自然科学研究に物理学応用の発達して行くのはむしろ当然の事であろうが、普通の意味における物質とはよほど縁の遠い生理学や心理学にまでもだんだん応用が開けて行くようである。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三に地質学上の現象として地震を見るのもまた一つの見方である。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってその地質的変動によって生じた地震の波が如何なる波動であったかというような事はむしろ第二義以下の問題と見られる傾向がある。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またいわゆる震度の分布という問題についても地質学上の見地から見ればいわゆる「地盤」という事をただ地質学的の意味にのみ解釈する事は勿論の事である。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウェーゲナーの大陸漂移説や、最近ジョリーの提出した、放射能性物質の熱によって地質学的｜輪廻変化を説明する仮説のごときも、あながち単なる科学的ロマンスとして捨つべきものでないと思われる。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "想うに、少なくもある地質学的時代においては、起り得べき地震の強さには自ずからな最大限が存在するだろう。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、あのような込み入った面白い地形がどうして出来たかという事は地質学者の議論の種になっているのです。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵具をのせる地質の研究が要る。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは日本の地質構造、従ってそれに支配され影響された地形的構造の複雑多様なこと、錯雑の規模の細かいことと密接に連関している。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際日本の地質図を開いてそのいろいろの色彩に染め分けられたモザイックを、多くの他の大陸的国土の同尺度のそれと見比べてみてもこの特徴は想像するに難くない。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような地質的多様性はそれを生じた地殻運動のためにも、また地質の相違による二次的原因からも、きわめて複雑な地形の分布、水陸の交錯を生み出した、その上にこうした土地に固有な火山現象の頻出がさらにいっそうその変化に特有な異彩を添えたようである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地質地形の複雑さの素因をなした過去の地質時代における地殻の活動は、現代においてもそのかすかな余響を伝えている。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に微気候学的差別のみならず、また地質の多様な変化による植物景観の多様性も日本の土地の相貌を複雑にするのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地質時代に朝鮮と陸続きになっていたころに入り込んでいた象や犀などはたぶん気候の変化のために絶滅して今ではただ若干の化石を残している。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが先頃ゴビの沙漠の砂の中から地質時代の大きな爬虫のディノソーラスの卵を発見した米国の学者達は、今度はまた中部アジアの大沙漠へ、地質時代の人間の祖先の骨を捜しに出かける準備をしている。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕たちしつかりやらうねえ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると蛇は、たちまちしつぽの方でからだをさゝへて立ち上り、によろ／＼と上体をゆすぶりながら、タンブーリンの音に合はせて、にじり歩いてをどります。",
              "citation": {
                "source": "蛇つかひ",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「阿須波山に住みける頃」の歌の一続きと見るべき「汐ならで」の歌の詞書きの「世を遁れて後は、それとたのむべき生業もなく、貧しうものしければ、人も養はず、何わざも自らうちしつゝ、辛きめのみ見つゝ過ぎにけるを……。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧しかつたので、傭ひ人も置くことが出来なかつたと言ふのだとすれば、下の「自らうちしつゝ」に叶うてゐる様だし、其境涯に落ちてもまだ昔の夢を思うてゐる所が見えるが、此後曲りなりでも、暮しが立つやうになつた藁屋時代にも、さうした傭ひ人をしたとは見えぬのだから、此文も真意は外にあるのだらう。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
