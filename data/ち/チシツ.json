[
  {
    "uuid": "8191717c-d42c-5c01-b64a-2d66edb756d7",
    "entry": "地質",
    "reading": {
      "primary": "ちしつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
