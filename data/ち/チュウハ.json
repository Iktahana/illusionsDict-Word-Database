[
  {
    "uuid": "b9f93008-cad5-50b3-83fa-340e1337b5d8",
    "entry": "中波",
    "reading": {
      "primary": "ちゅうは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
