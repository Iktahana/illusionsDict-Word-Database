      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "medium wave",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "海外の放送が国民の耳に触れることを恐れ、戦時中のラジオは中波のみ受信可能とされていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、空中波を飛ばすわけではないので、このコールサインは、ただの飾りものにすぎない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸外国の日本向け日本語放送は、「ヴォイス・オブ・アメリカ」にせよ、ハバロフスク中継のモスクワ放送にせよ、短波受信機でなくても中波程度の受信機で割合容易に聴けるが、世界の動きに特に関心をもつ人々以外は一般に余り注意されていない現状である。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きみのお父さんにね、中波の受信機を作ってもらったことがあるんだよ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その専門知識を駆使するまでもないんだけど、なにしろただの中波だからね、でも機材は軍用のを使って、それはそれは性能の高い、目の覚めるような受信機を作ってくれた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "中波の受信帯を、端から端まで、彼女にダイアルをまわしてもらった。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここ生涯の浮沈とばかり、心中波立っている容子が明らかであった。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "打込む、それよ、カーンカーンと五寸釘……あの可恐い、藁の人形に五寸釘ちゅうは、はあ、その事でござりますかね。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（第一おら、下座だちゅうはずぁあんまい、ふん、お椀のふぢぁ欠げでる、油煙はばやばや、さがなの眼玉は白くてぎろぎろ、誰っても盃よごさないえい糞面白ぐもなぃ）とうとう小吉がぷっと座を立ちました。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何か、お前が出会した――黒門に逗留してござらしゃる少え人が、手鞠を拾ったちゅうはどこらだっけえ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はい、忽然と消えちゅうは、……ここの事だね。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな話は西洋になけれど、一八九九年に出たコンスタンチンの『｜熱帯の性質』に、古ギリシアのアポロン神に殺された大蛇ピゾンが多足の竜ヒドラに化ったちゅうは、蛇が蛸になるを誇張したのであろうとあるは、日本の話を聞いて智慧附いたのかそれとも彼の手製か、いずれに致せ蛸と蛇とは似た物と見えるらしい。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "また日高郡丹生川大字大谷に、蚯蚓小屋ちゅうは昔ここの杣小屋へ大蚯蚓一疋現われしを火に投ずると、暫くの間に満室蚯蚓で満たされその建物倒れそう故逃げ帰った、その小屋｜址という。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の上の水の光にらんちゅうはきわまり燃ゆる四囲ながめぬ「これはねえ、空襲最中のらんちゅうだよ」　そういって、おとうさんはおかしそうに笑いました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水がにえて来る時のらんちゅうはどんなに悲しかったでしょう。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御亭主は活動の方へ出ている人なのだが、時々母の持って来る話では、「トオキイちゅうは何かの？",
              "citation": {
                "source": "落合町山川記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "話をしていても、しょっちゅうはあはあ言ってよ、眼にゃ涙を出してるんだ。",
              "citation": {
                "source": "追放されて",
                "author": "В　ССЫЛКЕ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「修業ちゅうは、しばらくここで暮すのだ。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月ちゅうは毎日ではなくと考えて居りましたが、もう毎日にします。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姥ヶ餅ちゅうはこれかい、旨えのう、もう一盆これへ出しなさろ」　鷹揚に命じたのが金茶金十郎でありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "退職ちゅうは年俸は与えられず、しかも家の格式は守らなければならない。",
              "citation": {
                "source": "竹柏記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――喪主が勤役ちゅうは帰国できるか否かわかるまで葬礼は延ばされるのが通例だった。",
              "citation": {
                "source": "落ち梅記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の者も一斉に低頭し、嘉助が続けた、「昨年ちゅうはお世話になりました、今年はお店もますます御繁昌、私共もまたどうぞよろしくお願い申します」　そして他の者が「おめでとうございます」と声をそろえて云った。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのれんちゅうは役所の新しい同僚だ、恐ろしく酒の強いやつがいるから加減をして呉れ」「ゆっくりしていらっしゃるのでしょう」「みんなを帰してからだ」　少し話があるんですからと云って、お民は半之助の手を自分の胸へ抱緊め、溢れるようなまなざしで男の眼を見た。",
              "citation": {
                "source": "初蕾",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フン、盗人、たけだけしいちゅうは、お前等のことじゃのう。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居の開演ちゅうは、桟敷で飲み食いするから、こちらは稀にしか客がない。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴木家にはしばしば旅の絵師とか書家などが来て滞在した、惣兵衛がそういうことを好むので、これらの者のために部屋が設けてあり、食膳なども別に揃えてあって、滞在ちゅうはかなり鄭重にもてなされる。",
              "citation": {
                "source": "日本婦道記",
                "author": "墨丸",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が寂しがってすすめるし、かくべつ拒む理由もないので、父の在世ちゅうはなしがあったという松井六弥の妹を娶った。",
              "citation": {
                "source": "日本婦道記",
                "author": "墨丸",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、東京の新聞社の写真部員が、空からのけしきを、写真にとるために、操縦士とふたりで、ヘリコプターにのって、神奈川県のほうをまわって、夕がた、東京に帰ってきたのですが、そのとちゅうはるかに東京の町が見えはじめたころ、目のまえの空中に、みょうなものが、飛んでいるのに気がつきました。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
