    "definitions": [
      {
        "index": 1,
        "gloss": "tip",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "帰りにチップをいつもより奮発して出したら突返された。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャンパンのキルクがボーイの鉤鼻から落下すると私のパートナアが横目をつかってボーイに現金で酒代とチップを渡すように催促して別に靴先につける天花粉の代金十｜仙を請求する。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "会員券だからおあいそ（勘定書）も出されぬのを良いことに、チップも置かずに帰った。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで、チップもない客だと、塩をまく真似されたとは知らず、己惚れも手伝って、坂田はたまりかねて大晦日の晩、集金を済ませた足でいそいそと出掛けた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を切られる想いに後悔もされたが、しかし、もうチップを置かぬような野暮な客ではなかった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚多いというのを、むっとした顔で、「チップや」　それで、その夜の収入はすっかり消えてしまった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うちへも集めに来なさるわ」　おかしいことに、半年に一度か二度珈琲を飲んで行くが、そのたび必ずこんな純喫茶だのに置かなくても良いチップを置いて行くのだと、お内儀はゆっくり笑った。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "チップを置いて、威張って出て行ったわけでもあるまい。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に今夜だって私は、チップを五百円ちかくもらったのだもの。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ＦＮへチップ五円わすれぬこと。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は表具屋の息子で、それ、あんたも知ってるやろ、昆布茶一杯でねばって、その代りチップは三円も呉れてた人や。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は表具屋の息子で、それ、あんたも知ってるやろ、タンチー一杯でねばって、その代りチップは三円も呉れてた人や。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラッツェルの『人類史』にアフリカのチップー人は野干に則って外人の所有物を自分らの共有財産と做し掠め取るとある。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがＮＥＣで８ビット機の開発をリードした、もともとは半導体チップの販売担当者だった後藤富雄さんは、一九七七年の発表時点で論文を読み、それ以来これを「自分のバイブルとしてきた」というのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "京セラのリファロは無線通信によるデータの送り込みを前提とし、半導体企業はさらにたくさんの機能を備えた小型、省エネのチップを用意してくるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでＳＰＡＲＣの対抗馬に当たる、ミップス製のチップを選んだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとてつもない大風呂敷を広げて、ＴＲＯＮチップの開発という大仕事に各社を引きずりだした風雲児坂村健の手並みには、３８６からはセカンド・ソース（これがどんな味のソースであるかは、次項で書く）を認めないというインテルの方針も有利に作用しただろうが、オレは実際肝をつぶした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当初坂村さんの頭にあったのは、ＴＲＯＮチップ上でＢＴＲＯＮを動かすきれいな姿だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに伴って、ＴＲＯＮチップ版はＢＴＲＯＮ２と呼ばれるようになった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＴＲＯＮチップのＧ　ＭＩＣＲＯ１００、２００、３００をそれぞれ搭載した複数の製品ラインが用意されるとのことで、低価格攻勢をかけるサンのマシン並のお値段となるだろうと、オレの責任において勝手に予測しておく。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ホームコンピューター』の虚妄を現実に変えるＡＭＤ３８６互換チップの宣戦布告『Ｔｈｅ　ＣＯＭＰＵＴＥＲ』から「Ｗｉｎｄｏｗｓ３・０は流行るか」という、いまさらなにをとぼけているかといいたくなる座談会のお座敷がかかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "チップ界の松田聖子とでも言えばいいのかな、とにかくはでなエピソードだらけのサンダース率いるＡＭＤは、これまで思わず大笑いの奇抜な広告や超特大クリスマス・パーティなんぞで話題を集めてきたが、基本戦略は地味にセカンド・ソースにおいてきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年間有効なこの契約（その後さらに十年間延長したことで、ＡＭＤは一九九五年までこれが継続すると主張する）によって、ＡＭＤは３８６のマイクロコードをコピーして互換チップを製造し得るとし、インテルの独占を打破すると宣言したのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この３８６殴り込み戦略で腹を決めたＡＭＤは、互換チップの方向づけを、処理速度の向上と低消費電力化に定めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九九一年三月、ＡＭＤは初の３８６互換チップ、Ａｍ３８６ＤＸ―40とＡｍ３８６ＤＸＬ―40の量産出荷を開始した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにインテルはコピーしたマイクロコードの製品への組み込みの可否を巡ってＡＭＤと法廷で争っているが、同様の権利が８０２８７コプロセッサーの訴訟で認められた経緯から見れば、今後予定される裁定でＡＭＤの３８６互換チップが法的お墨付きを得る可能性は高い。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "システム屋にとってみれば、ＡＭＤのチップを使ったはいいが後から特許侵害となってインテルの機嫌を損ねたのでは大事になるゆえに、互換チップの採用の件はこれまで一切水面下に潜ってきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
