[
  {
    "uuid": "11074b54-c1fb-5419-985f-a3316831188f",
    "entry": "力づける",
    "reading": {
      "primary": "ちからづける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
