[
  {
    "uuid": "38f12a3a-f7e5-579e-9847-8b0f3ef147b5",
    "entry": "徴収",
    "reading": {
      "primary": "ちょうしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
