  {
    "uuid": "25a7e384-9ec2-5560-ba1e-35837552d374",
    "entry": "頂芽",
    "reading": {
      "primary": "ちょうが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "terminal bud",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてとうとうちょうちょうがたくさんいるじゃがいも畑まで、流れてきました。",
              "citation": {
                "source": "木の祭り",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや」とじゃがいもの葉の上にとまっていた一ぴきのちょうが鼻をうごかしていいました。",
              "citation": {
                "source": "木の祭り",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、別の葉にとまっていたちょうがいいました。",
              "citation": {
                "source": "木の祭り",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこではねにもようのあるいちばん大きなちょうちょうを先にして、白いのや黄色いのや、かれた木の葉みたいなのや、小さな小さなしじみみたいなのや、いろいろなちょうちょうがにおいの流れてくる方へひらひらと飛んでいきました。",
              "citation": {
                "source": "木の祭り",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しじみちょうが小川のふちの水草の葉にとまってやすんでいますと、となりの葉のうらにみたことのない虫が一ぴきうつらうつらしていることに気がつきました。",
              "citation": {
                "source": "木の祭り",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」としじみちょうがききました。",
              "citation": {
                "source": "木の祭り",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」としじみちょうがさそいました。",
              "citation": {
                "source": "木の祭り",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お葬式でお墓にいったときにね、あたしが叔父さんや叔母さんたちの間で立ってたら、白いちょうちょうが舞ってきて、あたしの肩のこの花にとまったのよ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ろうざいくのはくちょうが、上でおよいでいて、そこに影をうつしていました。",
              "citation": {
                "source": "しっかり者のすずの兵隊",
                "author": "DEN STANDHAFTIGE TINSOLDAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりがあおむいてみると、大きいまっ白なはくちょうが一羽、空の上に舞っていました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかい、青い山山のいただきに、ふんわり雪がつもって、きらきら光っているのが、ちょうどはくちょうが寝ているようでした。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまにそれを見たものは、はくちょうがつばさをひろげたのだとおもいました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、きのう、あたしは十一羽のはくちょうが、めいめいあたまに金のかんむりをのせて、すぐそばの川でおよいでいるところをみましたよ。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日さまがちょうどしずもうとしたとき、十一羽の野のはくちょうが、めいめいあたまに金のかんむりをのせて、おかのほうへとんでくるところをエリーザはみました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて高く舞り上がって、下をみると、紺青の海のうえに立つ白いあわは、なん百万と知れないはくちょうが、水のうえでおよいでいるようでした。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ十一羽の野のはくちょうが、お城の上をとびかけって行きました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、十一羽の野のはくちょうがさあッとまいおりました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘藍のまわりにはえぞしろちょうが夥しく飛び廻った。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは、かつて彼女の友人の平塚らいちょうが行っていて、彼女には話しなじみのところだったのだ。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "青青としたやなぎの枝が風になびいて、そのなかで小鳥がないたり、ちょうちょうが舞ったりしていました。",
              "citation": {
                "source": "浦島太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "山吹の真白なじくも押出して、いちょうがえしへかけた。",
              "citation": {
                "source": "大門通り界隈一束",
                "author": "続旧聞日本橋・その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな年寄りが出てくるのかと思ったら、色の浅黒い、顔の長いひっつめのいちょうがえしに結った、額に青筋の出ている、お歯黒をつけた、細二子の袷に黒い帯をひっかけ（おかみさん結び）にした女が出て来て、「なんだ今時帰って来て――」と突然どなってつづけた。",
              "citation": {
                "source": "古屋島七兵衛",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "年増のいちょうがえしの女がそばに立っていた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちょうがえしに結うのだそうだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまだ桃割れの似合う若さだのに、いちょうがえしでなければならないときいてがっかりしてしまう。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一緒に風呂へ行った澄さんと云うのが、御園白粉が一番いいと教えてくれたけれど、もういちょうがえしに結って、金はみんな出してしまったので、白粉は二三日借りる事にする。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十年配のいちょうがえしの女が、寝床に坐ってバットを美味しそうに吸っている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "テッペンにいちょうがえしのごとく束ねて。",
              "citation": {
