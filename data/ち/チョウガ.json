[
  {
    "uuid": "f7bf7cee-df81-5d9a-9d34-5d463a768ad9",
    "entry": "朝賀",
    "reading": {
      "primary": "ちょうが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "New Year's greetings or well-wishes offered by retainers to the Emperor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "其徴は同書倭國傳に建武中元二年、倭奴國奉貢朝賀、使人自稱大夫、倭國之極南界也。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "服従を誓ふことは、実は、一度でよかつたのであるが、其を確実にする為に、いつとなく毎年繰り返すやうになつて、後の朝賀の式にまで発達した。",
              "citation": {
                "source": "呪詞及び祝詞",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "初春朝賀の式が行はれる時に、天皇が祝詞を下されると、群臣が其に御答へとして、寿詞を奉る。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮廷の元旦朝賀の儀式に、寿詞を奏上すると、寿詞なる口頭の散文に対して、今一段くだけた歌なるものを、複演奏上する。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝賀の式が終つた後に、直会をする。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安朝の宮廷では、朝賀の式が済むと、大直日の祭りに相当する事が行はれた。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大直日の祭りは、朝賀の式に接して行はれたが、神を祭るだけではなく、其時奉る言葉に、誤りがあつてはならないので、訂正の意味で、これを行ふのである。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其で見ると、大直日の祭りが、朝賀の式に接して行はれてゐたことがわかる。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう考へると、元旦の朝賀の式のくだけたのが、御歌会である。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "後、朝賀式が重視せられるに至つて、寿詞を奏するやうになつたのである。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして出来た目的は、年頭朝賀の寿詞奏上同様、氏族の歌に含まれた鎮魂的効果を聖躬に及ぼさうとしたのではあるまいか。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "年頭の朝賀の式は、段々、氏々の代表者の賀正事（天子の寿を賀する詞）奏上を重く見る様になつたが、恒例の大事の詔旨は、此受朝の際に行はれた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めて古い時代には、朝賀の賀正事には専ら此を奏上して、神界に君臣の分限が明らかだつた事始めを説いて、其時の如く今も忠勤を抽んでゝ天子に仕へ、其健康を保障しようとする事を誓うた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏々の聖職の起原――転じては、臣従の由来――を説く寿詞（賀正事としてが、最初の用途）が、朝賀の折に、数氏の長上者等によつて奏上せられる様になつてからは、其根元たる中臣寿詞は、即位式――古くは二回、大嘗祭にも――に奏上せられることに定まつて来たのである。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "其が段々のりとの宣下せられるのに対して、奏上するものと考へられる様になつて来たのは、宮廷の大事なる受朝朝賀の初春の宣命と奏寿――元日受朝の最大行事であつた事は後の令の規定にまで現れてゐる――の印象が、此を区別する習慣を作つて行つたものと思はれる。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命の呪言は、宮廷では正月朝賀のをり、大殿祭のをり、特殊な場合では、即位の始めの新嘗即大嘗祭の時である。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "遂に「賀正事」と言ふ字が「よごと」に宛てられ、正月と言ひ、朝賀と言ふと、「よごと」を聯想する事になり、後代の人には持ちにくい程の内容を含む事になつたのである。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "即立皇后皇太子、及元日受朝賀之類也。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "正確に言へば、此詔詞が最適切に用ゐられる場合は、即位式並びに元旦朝賀の時である。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮廷の正儀として、正月朝賀の時に、宣詞宣下があるのに、和し奉ることに定つて居た為、「賀詞」或は「賀正事」なる字を作り、又漠然と「吉事」など書いて、「よごと」と訓じる様になつたのである。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は、日本紀の話であるが、此を毎年の行事でいへば、新嘗祭が済んだ後、直に鎮魂祭が行はれ、其がすんで、元旦の四方拝朝賀式が行はれる。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の祭りは、大嘗祭と、即位式と、四方拝と、もう一つ朝賀式とを兼ねたもので、正月の元日から三日の間に行はれるのである。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "後になつて、御即位の式と、朝賀の式とが分れても、両方共に、仰せられるお言葉は、似たものである。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来、大嘗祭と、即位式と、朝賀の式とは、一続きである。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "元旦の朝賀の式に、天子様が祝詞を下される式は、奈良朝には既に、陰に隠れて了うて、群臣が寿詞を申し上げに出る式のみとなつた。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、のりと及びよごとが、即位式・大嘗祭・元旦朝賀に共通して用ゐられ、或は、其用途が混同してゐるとさへ、見られるやうになつたのである。",
              "citation": {
                "source": "高御座",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此拍手が純國風であつたことは、延暦十八年朝賀の樣の記述を見ても察せられる。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月の三日間というもの、朝賀に参上するものもいなかったが、僅かに桜町中納言とその弟｜左京大夫脩範だけが特に許された。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "天子は、紫宸殿に出御して、この日、公卿百官の朝賀を嘉せられた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――近日、朝賀のご酒宴が殿上で行われるから、その折、禰衡をもちいて鼓を打たそうではないか。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
