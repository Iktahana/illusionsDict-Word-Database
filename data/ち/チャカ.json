        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ヒラメの家では食事はいつもその小僧がつくり、二階のやっかい者の食事だけは別にお膳に載せて小僧が三度々々二階に持ち運んで来てくれて、ヒラメと小僧は、階段の下のじめじめした四畳半で何やら、カチャカチャ皿小鉢の触れ合う音をさせながら、いそがしげに食事しているのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中はカチカチやっていたが、その皿がお膳から反りかえりそうになっても、コチコチで、そのうちカチャカチャ、くるりと皿ごと廻ってしまった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、ありったけの娘子軍は、すでにチャンチャカチャンチャカの鰌すくいに出払ってお留守なのである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでと同じような、幾つものチャカチャカしたテエブルや大勢の事務員がズラリと並んでるようなそう云う大きな事務所を。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六九年、安田講堂攻防戦のシッチャカメッチャカの挙げ句、東大が入試中止に追い込まれた年、古川は麻布高校の一年だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "※――高い山から谷底見れば　　　　　　　瓜や茄子の花ざかり　　　　アリャ、メデタイナ、メデタイナ　そんな変哲もない事がなぜにまためでたいと言うのか、突如向うの二階から、ドンチャカ、ジャカジャカという鳴り物に合わして、奇声をあげながら唄い出した遊客の声がありました。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "※――高い山から谷底見れば　　　　　瓜や茄子の花ざかり　　アリャ、メデタイナ、メデタイナ　そんな変哲もない事がなぜにまためでたいと言うのか、突如向うの二階から、ドンチャカ、ジャカジャカという鳴り物に合わして、奇声をあげながら唄い出した遊客の声がありました。",
              "citation": {
                "source": "旗本退屈男",
                "author": "第一話　旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "勤めがなくて、ぽっぽにたんまりおこづけえがあって、べっぴん片手に船遊山、チャカホイ、チャカホイ、チャカチャカチャ――と、いけませんかね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　盃と銚子がやかましく、カチャカチャと触れ合った。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとには看護婦が残って、手術器械をカチャカチャと片づけているばかりだった。",
              "citation": {
                "source": "幸運の黒子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――うれしがって箸で机をたたいたり、茶碗をカチャカチャ鳴らしたりするものがあった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダチャカン――というのは「埓があかない」の転訛で、つまり「ダメだ」という意味だ。",
              "citation": {
                "source": "だだをこねる",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば「自由をわれ等に」てなことをいったってとうていダチャカンわい――とまあいったような風にだ。",
              "citation": {
                "source": "だだをこねる",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆箱のカチャカチャと鳴る音がいつまでも耳に残り、こんなことがあってから寿女は、途上で女の子を見付けると周章てて道をそらしたりした。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まかり出でたるキチガイ坊主……スカラカ、チャカポコ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャカポコチャカポコ…………サアサ寄った寄った。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャカポコチャカポコ…………サッサ来た来た。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "来て見てビックリ……スチャラカ、チャカポコ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャチャラカ、チャカポコ……　▼ア――あ――。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "スカラカ、チャカポコ外聞晒す。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たたく木魚に尋ねてみたら……スカラカ、チャカポコ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
