[
  {
    "uuid": "d6beeecc-09bf-5137-95bf-06483e1cb1dc",
    "entry": "長途",
    "reading": {
      "primary": "ちょうと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
