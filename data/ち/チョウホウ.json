[
  {
    "uuid": "fe9e6335-a4da-542c-898c-a9458a70d949",
    "entry": "弔砲",
    "reading": {
      "primary": "ちょうほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
