    },
    "definitions": [
      {
        "index": 1,
        "gloss": "artillery funeral salute",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "弔砲がドンドンと聞える。",
              "citation": {
                "source": "ソヴェト・ロシアの素顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに支那人もこの鬼神のような勇戦奮闘には深く心を打たれたのか、獅子山の砲台は、二十一発の弔砲を鳴らして、わが勇士の霊をとむらうのであった。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーニンの葬式のときの模様、それに音楽をつけ、弔砲の擬音もつけた。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「写真を撮るマグネシウムの光でしょうか」「否、弔砲の閃光かも知れん」　先程から引つゞいて、大きな心臓の鼓動の如く、正しい時を隔てゝ弔砲が響いて居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弔砲が鳴つて、非常な盛儀であつた。",
              "citation": {
                "source": "わが心の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいまとても別にぶちょうほうのあったわけではござりませんが、股引きが破れまして、膝から下が露出しでござりますので、見苦しいと、こんなにおっしゃります、へい、御規則も心得ないではござりませんが、つい届きませんもんで、へい、だしぬけにこら！",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それになにしろ往来は道がひどいのでこれはとんだちょうほうでした。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは金貨でおかざりがしてあって、むすこには、たいへんちょうほうなものでした。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            },
            {
              "text": "「気づかれぬよう、あとつけろ」　善光寺辰というちょうほうな生きぢょうちんがあるところへ、月光は降るばかりでしたので、主従は一町ほど間隔を置きながら、足音殺してふたりのあとを尾行いたしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご高名のだんなさまとも存じませず、徒弟どもがとんだぶちょうほうつかまつりまして、恐縮にござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "口はちょうほうなものですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより一面識もない間ではありましたが、そこへいくと職名はちょうほうなものです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことになると、これでおいらのおしゃべりあごもなかなかちょうほうなんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんともぶちょうほうなことを申して、恐れ入りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子はびっくりして、「ほほう、これはちょうほうな男だ。",
              "citation": {
                "source": "ぶくぶく長々火の目小僧",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも存ぜず、とんだぶちょうほうな口をききましてあいすみませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し砕けて出て、ちょうほう暦、百年こよみなどという名をつけてみた。",
              "citation": {
                "source": "トコヨゴヨミ",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいへんちょうほうだ」「なぜ、そんなことをするんですか」「これは、もし前方に危険があったときは、偵察ロケットが感じて知らせてよこす。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに手さきがきようなので、家ではたいへんちょうほうがられていました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに、うちの中のざつようでもなんでも、諭吉は、すこしもいやな顔をしないで、かいがいしくはたらくので、先生ばかりでなく、おくさんにも、女中にも、家じゅうで、たいへんちょうほうがられました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "口はちょうほうなものだテ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくれみのというのは、一度そのみのを身につけますと、人の姿がかき消すように見えなくなって、人中で何をしようと思うがまま、どんな悪いことをしても、とらえられる気づかいがないという、ちょうほうな魔法なのですが、黒い魔物は、それと同じように、やみのなかにとけこんで、人目をくらますことができるのでした。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
