    "definitions": [
      {
        "index": 1,
        "gloss": "Chōhō era (999.1.13-1004.7.20)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
