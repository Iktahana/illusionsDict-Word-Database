        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "花の香もけやけくはあらで優に澄みわたれる、雲さまよふ晨、風定まる黄昏など、特に塵の世のものならぬおもむきあり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に塵の世に生れたる人、誰か罪業なきことを得ん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫は色を正して、さる詞を人にな聞せそ、此塵の世に心｜牽かるゝことおん身の如くならんも拙し、少しは後の世の事をも思へかしと宣給ふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "只々塵の世に我が思ふ人の長へに汚れざれ。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "只※塵の世に我が思ふ人の長へに汚れざれ。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "武田麟太郎の世塵の世界。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いと美しき禮讓はこの塵の世を捨てたるか。",
              "citation": {
                "source": "忌々しき「死」の大君は",
                "author": "ダンテ・アリギエリ　Dante Alighieri",
                "note": "青空文庫"
              }
            },
            {
              "text": "折ふしは天頂高くうちあふぎ、かくて貴なる魂のゆくへや求むる、塵の世の濁に染まぬたましひの。",
              "citation": {
                "source": "泣けよ戀人",
                "author": "ダンテ・アリギエリ　Dante Alighieri",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕の空に現はれて微笑める光に塵の世を慰めてらす星あらば君がかざしの珠とせむ。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "別の袖に別れの袖にふりかゝる清き涙も乾くらむ血汐も湧ける喜の戀もいつしかさめやせむ物皆移り物替るわが塵の世の夕まぐれ仰げば高き大空に無言の光星ひとつ。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは、（ああ、そうだ、ぼくのおっかさんは、あの遠い一つのちりのように見える橙いろの三角標のあたりにいらっしゃって、いまぼくのことを考えているんだった。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは、（ああ、そうだ、ぼくのおっかさんは、あの遠い一つのちりのように見える橙いろの三角標のあたりにいらっしゃって、いまぼくのことを考えているんだった）と思いながら、ぼんやりしてだまっていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、私のところまで、あんなとばっちりのようなムリな電報を寄越したのでございますわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちがそうやって窓に顔を一しょにくっつけて眺めていると、目なかいの、まだ枯れ枯れとした、春あさい山を背景にして、まだ、どこからともなく雪のとばっちりのようなものがちらちらと舞っているのが見えていた。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "米騒動の事件があったとき、吉原もそのとばっちりのようなものを受けた。",
              "citation": {
                "source": "生い立ちの記",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
