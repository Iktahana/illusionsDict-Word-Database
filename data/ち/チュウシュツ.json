[
  {
    "uuid": "d24fb0ff-9b52-57ec-aa28-b4b3d67ae66b",
    "entry": "抽出",
    "reading": {
      "primary": "ちゅうしゅつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
