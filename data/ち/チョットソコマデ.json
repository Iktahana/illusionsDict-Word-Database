        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「私もその時分はこれでなかなか肯かん坊だったから、ああこれなら安心だと監視の手が緩んだ時分に、ちょっとそこまで行くふりして、不断着のまま蟇口だけもって飛び出してしまったんです。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこかへ往くのか」「ちょっとそこまで往って来ますわ」「どこだね」「ちょっとそこですわ」「飯を喫ってからにしちゃ、どうだね、俺も往くよ」「でも、私、ちょっと歩いて来ますわ」「じゃ、俺も散歩しよう」「でも、家は」「家は留守番が出来たから宜いよ」「そう」　順作は起って父親の方を見た。",
              "citation": {
                "source": "藍瓶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花屋の定吉、納所の了哲も手伝いまして、朝から掃除にかかって居りましたが、その日の夕方、ちょっとそこまで行って来ると云って出ましたままで、再び姿を見せません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとそこまでと別口のおせじでもいってな、のがさねえように、うまく引いてきな」「心得たり！",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂をすませて、夕飯を食って、今夜はここに泊まるはずであったが、上原はちょっとそこまで行ってくるといって、好子を残して出たままで今に帰って来ないのをみると、自分はきっと置き去りにされたに相違ない。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "森先生の許へといえば、また何とか意地悪い事を言われるのがいやさに、それとなく、「ちょっとそこまで……」と答えた。",
              "citation": {
                "source": "先生の顔",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっとそこまでならいいでしょう。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっとそこまで行って来るとおっしゃって、そとへ出ていらしたばかりですよ。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、お庄は終いに磯野の方へ向いて、「磯野さん、ちょっとそこまで私と一緒に来て頂戴。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って来て半月ばかり経ったある日、また、みを子は「ちょっとそこまで――」といって出たきり帰らなかった。",
              "citation": {
                "source": "母親",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、お出かけですか」「あゝ、ちょっとそこまで」　岸本は目慧く浅田の持っている手紙に目をつけて、「先生、郵便でしたら私が出して来ましょう」「何、いゝんだ」　浅田はそう云い棄てゝ外へ出た。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうもこそこそ出かけていたから、私がどこへ行きますときいたら、白ばくれてちょっとそこまでと言うのよ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ちょっとそこまで行っています」「今晩は帰らないだろう」「ええ、帰りませんでしょうなあ」　私は、もうどうしても柳沢と逢っているに違いないような気がして来た。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は厚い八端の座蒲団の上にともかくも坐って、女中の静かに汲んで出した暖かい茶を呑んでから、さっき女と電話で約束した会合の場所が、そこからすぐ近いところなので、時計を出して見い見い遅刻せぬようにと、ちょっとそこまでといい置いて、出て行った。",
              "citation": {
                "source": "黒髪",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、ちょっとそこまで来たついでに立ち寄ったというような様子であった。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとそこまで野暮用で」「冗談だろう、嘘をいえ。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いったい、今日までどこに雲がくれしていたんです」　顎十郎は、懐手をしてのっそりと突っ立ったまま、「じつは、長崎のほうに友達ができてな、ちょっとそこまで行って来た」　ひょろ松は、ムッとして、「冗談なんぞをいってる場合じゃありません。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "咸臨丸受取",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはちょっとそこまで、ははははは。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋはちょっとそこまでといったぎりでした。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はちょっとそこまで行って来なきゃなるまい」　蔵人はそう言いながら、今の手紙をお礼の眼から隠して自分の袖に押し込み、両刀を手挟んでもう一度、春の闇の中へ出ようとするのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "敵討果てて",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親方は、ちょっとそこまで用たしに行ったから、もう直ぐに帰るだろう」「あの……あの、君ちゃんはいねえのか」「君ちゃん……」と言って、美人連は面を見合せました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "市中騒動の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「庄さん、ちょっとそこまで一緒に御苦労しておくれ」　やはり風の吹いた同じ日の晩。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっとそこまで出て貰えないか、大島町の河岸で待ってる」　彼はそう云って返辞を待たずに去った。",
              "citation": {
                "source": "追いついた夢",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっとそこまで、つきあって貰いたいんですがね」　傘を傾けて、こちらを覗きこんだ、その息はつよく酒の匂いがした。",
              "citation": {
                "source": "竹柏記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ姉さんや啓さんにわかるわけがないや」と敏夫は手の甲で眼のまわりを拭きながら立ちあがった、「ちょっとそこまでいって来ます」「どうするんだい」と啓三が訊いた。",
              "citation": {
                "source": "ばちあたり",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのことでもあんたに話しがあるの、ちょっとそこまでつきあってちょうだい、いいでしょ」「うん、――いいよ」「うれしい、ついそこの池之端なの、あんたすっかりおとなになったわね」　新八は、よしてくれ、と顔をそむけた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとそこまで、つきあってくれないかい。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
