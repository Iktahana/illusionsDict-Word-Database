        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「喧嘩をしちゃいかん。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "星になるには、それ相応の身分でなくちゃいかん。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「くたびれるから抜手を切っちゃいかん」　河口西側の蘆洲をかすめて靄の隙から市の汚水処分場が見え出した。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うそを云っちゃいかんぞ！",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この眼に負けちゃいかん！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦を荒らしちゃいかんが！",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いらんことを喋っちゃいかん！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなところに置いちゃいかん！",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、そら、あの鉄砲打ちの小さな変な人ね、そしてね、『おい、こんどはも少しよく、粉にして来なくちゃいかんぞ。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう進軍をやめなくちゃいかん。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」山猫博士「おいおい間違っちゃいかんよ。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時ＫがＲに「オイ、Ｒ、ふるえちゃいかんよ」と云ってからかった。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "美的にそこいらを散らかすのを忘れちゃいかんぜ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥かごは、早速、「バタバタ云っちゃいかん。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥かごは、早速、「泣いちゃいかん。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "溶かしちゃいかんぞ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "）大将「いかん、いかん、エボレットを壊しちゃいかん。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "行っちゃいかんぜ」「あれさ、いいやね。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "表現――つまり言い現わし方そのものが独創性に富んでいるばかりでなく、「猫も杓子」云々という言葉の内容自身が、人間というものは独創的でなくっちゃいかん、不和雷同するな、人の言ったことや、したことの真似をすると嗤われるぞ――という、いわば独創の宣伝みたいな意味を含んでおります。",
              "citation": {
                "source": "猫と杓子について",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "莫迦云っちゃいかん。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなでたらめを、子供に教えちゃいかん」と、ソファに腰をおろしていた、お客さまの、こうるさいお役人が言いだしました。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなでたらめを教えちゃいかん。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな事を云って無理をしちゃいかん。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「おまえは今から心がけて人生の本ものの味わいを味わわなくちゃいかん」と口癖にいった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オフィリヤ、さようなら、さっき兄さんの言った事を忘れちゃいかんよ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つまりは、もっと勉強しなくちゃいかんということさ。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
