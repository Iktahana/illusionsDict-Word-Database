    "definitions": [
      {
        "index": 1,
        "gloss": "intestinal catarrh",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
