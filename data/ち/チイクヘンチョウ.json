    "definitions": [
      {
        "index": 1,
        "gloss": "too much intellectual training",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
