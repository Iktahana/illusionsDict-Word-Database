        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なまくらなナイフをブンブン振り回す代わり、押し当てたカミソリにゆっくり力を込めるように、松田優作はスクリーンを切り裂いた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のペースを保っている分には、それほど力を込める必要もない。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "両肩から背中へ、そして背中のぜんたいから腰へ、さらに腰を経由して左右の太腿に、膝に、そして足指まで、可能なかぎりの力を込めることによって、冬彦は射精の反応を受けとめ、それに耐えた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "タオル越しに髪をかきまわす両手の力に対して、腰に力を込めることによって、直子はバランスを取った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
