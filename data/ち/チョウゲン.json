        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こうしてデビュー時に独創的な演奏スタイルを打ち出したオレは、その後「影を慕いて」の名手だった近所の兄ちゃんに「この世には調弦というものがあるのだよ」と深くさとされ、まっとうなギター道に立ち返った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「張り換えた弦を調弦して、コードをひとつ弾いたとき、涙があふれ出てね。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
