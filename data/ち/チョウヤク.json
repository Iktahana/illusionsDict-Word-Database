[
  {
    "uuid": "ab3574f0-655e-5f31-9ecd-22bd8e1ff01a",
    "entry": "調薬",
    "reading": {
      "primary": "ちょうやく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
