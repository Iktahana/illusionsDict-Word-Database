    "definitions": [
      {
        "index": 1,
        "gloss": "staunch (steadfast, single-hearted) in one's devotion to his master (lord)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "忠義一途の用人は、きのう中にすこしは何かの手がかりは付いたかと問い合わせに来たのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが正直一遍、忠義一途に世の中を貫いて行く武士のまことの心がけじゃまで……さもないと不忠不義の輩に欺されて一心、国家を過つような事になる。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "主君から、予期せざる暴行を受けて、勘之介ははっと色を変じたが、忠義一途の彼は、決して身体をかわさなかった。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "頑固ではあるが、主家に対しては忠義一途の人じゃ。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の荒波にジッとたえて高貴な魂を失うことなく、千代梅の内儀に対しては忠義一途、人々に親切で思いやり深く、人柄としては世に稀れな少年だった。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠義一途なこころから、老女が力いっぱいに葵をつかまえる。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆んな一生奉公で」　それは恐ろしい犧牲ですが、その犧牲をさへ意識しないほど、代々の香七、香兵衞、香之助は忠義一途に凝り固まつて居たのでせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "五つの壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも着實さうで、羊羹色の紋附と共に、何んの疑念も不平もなく、忠義一途に世に古りた姿です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "若黨の戀",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりに主人の無事な姿を見た喜びか、あるいは今母国語でかけられた言葉がそれほどまでの感激を彼に齎せたものか、この忠義一途な若者は頓には口も利けぬくらいに硬ばり切っているのであった。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおかたそのお侍は忠義一途にとのさまのおあとをしたい、此処を御じぶんの死に場所とさだめておられたのでござりましょうか。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
