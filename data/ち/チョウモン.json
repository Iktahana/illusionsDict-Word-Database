[
  {
    "uuid": "a92b9be4-85d3-5c94-8326-c35c7644bab3",
    "entry": "弔問",
    "reading": {
      "primary": "ちょうもん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
