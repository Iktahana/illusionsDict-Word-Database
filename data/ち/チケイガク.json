          "literary": [
            {
              "text": "これは地形学者の説を聞いてみなければ分らない。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは地形学者の再検討をわずらわしたい問題である。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういった、隆起に伴われて浸蝕されて行くことを、地形学上からは「回春」または「若返り」と呼んでおります。",
              "citation": {
                "source": "自力更生より自然力更生へ",
                "author": "三澤勝衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "地質学地形学に心身を投じようともした。",
              "citation": {
                "source": "普羅句集",
                "author": "前田普羅",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の観測飛行の間、我々は以前の探検家たちが到達しなかった地域に新たな地形学的特徴を見いだそうと試みた。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
