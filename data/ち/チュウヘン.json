[
  {
    "uuid": "d858345b-c23f-582d-b681-b7413ebc2bdc",
    "entry": "中編",
    "reading": {
      "primary": "ちゅうへん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
