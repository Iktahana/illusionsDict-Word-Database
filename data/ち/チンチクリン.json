    "definitions": [
      {
        "index": 1,
        "gloss": "short (in height)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "俥の背にくまの姿が横にひしゃげて、ちんちくりんに写った。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外門を入ろうとすると、ちょうど中から出て来るちんちくりんな男にぶっつかった。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "牝鶏はというと、足がばかに短いので「ちんちくりん。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それが、もつと体格でもいゝんなら兎も角、ちんちくりんの痩ツぽちでさ、加けにだぶだぶに延びちやツてる股引がイヤにずりこけて、あんなものはいて行かないがいゝのに。",
              "citation": {
                "source": "熱海へ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、ぶつきら棒に言ひすてたまま、年つ喰ひの、ちんちくりんな西大寺の小僧は、先へ立つてさつと廊下へ出掛けて行つたが、つとまた後がへりをして、「あ、忘れとりました。",
              "citation": {
                "source": "西大寺の伎藝天女",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "死にかかつた佛の御蔭で、あのちんちくりんな躯を養つてゐる西大寺の小僧は、とんだ所でまぐれあたりに御爲奉公をした譯で、第三の明りでは、私はなんともつかぬあやふやな感じを得たに止まつた。",
              "citation": {
                "source": "西大寺の伎藝天女",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋人は唐子の約束なんか分らず、人間なら人間のようにもっとすらりと身長が高ければ好いので、あんなに、ぶよぶよ肥太って、ちんちくりんでは第一物を捧げている台として格好が附かないと、まあ、こういった訳なんですから、今度は当り前の人間だと思って、当り前にやって見て下さい。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "店初まっての大作をしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠の外貌がこの悪戯者に似てゐるのは、飛んだ幸福で、名もない、ちんちくりんな野鼠までが長い口髯を捻りながら、象を脅かす事が出来るのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちんちくりんの癖に、いつも妙に口もとを引きしめて、意地悪そうに目を光らして、竹の根の鞭で机の上をぱちぱち鳴らしていた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "手足ちんちくりんで頭ばっかり大きい。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、私はちんちくりんの身体の肩を怒らせ肘を張つて、廊下で行き違ふ新入生のお辞儀を鷹揚に受けつゝ、ゆるく大股に歩いた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うは仲の町でも指折りの華魁だし、こつちは片輪も同様な、ちんちくりんの南瓜だからね。",
              "citation": {
                "source": "南瓜",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を殺したつて、殺さなくつたつて、見た所はやつぱりちんちくりんの、由兵衛奴にフロツクを着た、あの南瓜の市兵衛が、それでもそこにゐた連中にや、別人のやうに見えたんだらう。",
              "citation": {
                "source": "南瓜",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便局長は背丈のちんちくりんな男だが、しかし頓智があって、なかなかの哲学者だ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "背丈がちんちくりんで、顔には薄あばたがあり、髪の毛は赤ちゃけ、それに目がしょぼしょぼしていて、額がすこし禿げあがり、頬の両側には小皺が寄って、どうもその顔いろはいわゆる痔もちらしい……しかし、これはどうも仕方がない！",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、胸に滲み入るような音をあげた、額の禿げあがった、ちんちくりんな官吏の姿が思い出されてならなかった。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくとも、出産の時その場にいあわせた親戚の女で、普通にちび女と呼ばれているような、ちんちくりんの女が赤ん坊を抱きあげるなり、『おやおや、思ったとはまるで違う赤ちゃんだよ！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そして蒸溜人のちんちくりんな胴体は、又もや哄笑とともに揺ぶられた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し不幸なことには、彼女等の多くは、お尻だけは比較的大きいかも知れないが、胴体も寸づまり、脚も寸づまりのちんちくりんなのである。",
              "citation": {
                "source": "ジャングル頭",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で一人のちんちくりんな男が、音楽に合せて一人よがりな唄を歌っています。",
              "citation": {
                "source": "歪んだ夢",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちんちくりんの女だから、卓子の上に面皰だらけの顏を載せたやうで、足は床につくかつかない形だつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "図体が長くって、足がちんちくりんだ。",
              "citation": {
                "source": "潮風",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "痴川は急にわなわなと顫へだして頬の贅肉をひきつらせ、ちんちくりんな拳で伊豆の胸倉をこづいて、「お前といふ奴は、まるで、こん畜生め！",
              "citation": {
                "source": "小さな部屋",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、みんなしてハンスをつれだしてきましたが、当人は、よんどころなくちんちくりんな上っぱりの前をかきあわせて、はだか身をかくしました。",
              "citation": {
                "source": "かわいそうな粉ひきの若いものと小猫",
                "author": "ヤーコップ、ウィルヘルム・グリム　Jacob u. Wilhelm Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "このちんちくりん奴。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔と首の細工がおわると、こんどはちんちくりんな、おかしな服を着始めた。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "その相間相間には、ちんちくりんな外套の羽根の下から手を出して、薄い鼻の下の髭を撫でた。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、子供達のよろこんでいる最中に出て行って、その会の主人公であるセエラに、お前はもう乞食になり下ったのだ、父の喪のためちんちくりんの黒い服に着かえなければいけない、というのは、何だかいやでなりませんでした。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "死骸は、評判の通り四十近い醜い女――と言つても眼鼻立が惡いのではなく、松皮疱瘡で見る影もなくなつて居り、その上横肥りのちんちくりんでまことに散々です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "八五郎の戀人",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が付けたのか判らないが、私の家内より外につける人がいないから、多分、家内がそうつけたものであろう、子供達は私の前でも平気でだぶちんといい、私もだぶちんの意味はよく判らなかったが、背丈が低いのでちんちくりんのちんを取ってそう言ったものらしいが、だぶの意味が通じなかった。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
