    "definitions": [
      {
        "index": 1,
        "gloss": "centre",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "中央に望樓ありて、悲しく四方を眺望しつつ、常に囚人の監視に具ふ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の間から祭壇を持って来て床の中央へ三壇にすえ、神棚から御厨子を下ろし塵を清めて一番高い処へ安置し、御扉をあけて前へ神鏡を立てる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか私邸に呼ばれたときにその自慢の豊富な書庫を見せてもらったことがあったが、その蔵書の一部が教授の死後、わが中央気象台に買取られて保存されている。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下から中央階段を降りようとする途中で窓越しに東を見ると、地下鉄ビルの照明が見える。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四畳半と覚しき間の中央に床をのべて糸のように痩せ細った身体を横たえて時々｜咳が出ると枕上の白木の箱の蓋を取っては吐き込んでいる。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十年七月、中央公論）",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "広河内の土地のありさまは、中央日本アルプスの聖境、上高地の中、島々方面から徳本峠を下り切った地点に、よく似ている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上には旅人宿めいた室、勧工場然たる物産陳列所、郵便局、それから中央の奥宮社殿は、本殿、幣殿、拝殿の三棟に別れて、社務所、参籠所も附属している。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、北から中央、それから南と及ぼして雪の遅速が解る。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が薬師岳で観察した所に依ると、凡べてのカアル皆然りとは言われないが、カアルの初期は、雪が横一文字に堆くなっているに過ぎないが、その両端の垂下力が遅く、中央が速いためか、第二期には三日月形に歪み、更に拡大して勾玉形になって来ている。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると両端から包囲するように、中央部までを喰い取って刳るから、一方の外壁を残して一方を欠いた噴火孔のようになる。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "県庁の入口に立っている煉瓦と石を積んだ門柱四本のうち中央の二本の頭が折れて落ち砕けている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十年四月『中央公論』）",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和九年九月廿九日の早朝新宿駅中央線プラットフォームへ行つて汽車を待つてゐると、湿つぽい朝風が薄い霧を含んでうそ寒く、行先の天気が気遣はれたが、塩尻まで来るととうとう小雨になつた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央アジア東トルキスタン辺の歌謡を見ると勿論色々な型式があるが、中には八、五、八、五の型式がある。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシア人と中央アジア並びにインド人と交渉のあったことは確かであり、後者とシナ人、シナ人と日本人とそれぞれの交通のあったことも間違いないとすれば、歌謡のごときものが全く相互沒交渉に別々に発達したと断定するのも少し危険なような気がするのである。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう見地から見て現在一番信頼の出来る施設は中央気象台とその配下にある海洋気象台のそれである。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治から貞観まで約千年の間にこの程度の颱風がおよそ何回くらい日本の中央部近くを襲ったかと思って考えてみると、仮りに五十年に一回として二十回、二十年に一回として五十回となる勘定である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和九年九月二十九日の早朝新宿駅中央線プラットフォームへ行って汽車を待っていると、湿っぽい朝風が薄い霧を含んでうそ寒く、行先の天気が気遣われたが、塩尻まで来るととうとう小雨になった。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう扁平な板のような天体の中央に居て八方を眺めたと仮定すると、板の面に沿うた方向には沢山の星が重なって帯のように見えるはずでこれがすなわち天の河である。",
              "citation": {
                "source": "天河と星の数",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ縦揺れのために起る上下動は、船の中央部が比較的一番少ないから、近来の良い船の一等室は大抵船の中ほどに置いてある。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年八月三十日『東京朝日新聞』）発電所は難破船　メキシコの南隣グァテマラの西海岸の一小市で近頃電灯を点ずるようになったが、その中央発電所は同市の海岸近くに坐洲したドイツの汽船である。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鼻の位置を狙って両側から皺み込む底の深い鼻唇線は彼女の顔の中央に髑髏の凄惨な感じを与える。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は伯林市の中央チーア公園に行き当った。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山一つさえその通り――「まだそのときのわたくしは、きしゃな細火を背骨にし、べよべよ撓るほどの溶岩を一重の肋骨として周りに持ち、島山の中央の断れ目から島地の上へ平たく膨れ上っただけの山でした」　世の中は、ただうとうとと、あま葛の甘さに感じられた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、私が異様に思ったのは、それらに囲まれて中央に貼ってある少年の大きな写真である。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "応仁の乱は細川勝元、山名宗全の両頭目の死によって一時、中央では小康を得たようなものの、戦禍はかえって四方へ撒き散された形となって、今度は地方地方で小競合いが始まりました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には、第一にその泥岩は、東の北上山地のへりから、西の中央分水嶺の麓まで、一｜枚の板のようになってずうっとひろがっていました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "姿勢の相称性が打破せらるる場合に、中央の垂直線が、曲線への推移において、非現実的理想主義を自覚することが、「いき」の表現としては重要なことである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
