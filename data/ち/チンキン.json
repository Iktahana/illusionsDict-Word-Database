      {
        "index": 1,
        "gloss": "gold-inlaid lacquerware (using powdered gold in etched grooves)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
