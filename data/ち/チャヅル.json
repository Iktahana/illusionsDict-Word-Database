        "examples": {
          "standard": [
            {
              "text": "昨夜の残りのご飯で、ささっと茶漬けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "深夜に小腹が空いて、冷蔵庫にあったもので茶漬けてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ねえ、もうご飯ちゃづっていい？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また此の計なかるべからず、此で唯初音の鳥を煮て、お香々で茶漬るのならば事は足りよう。",
              "citation": {
                "source": "九九九會小記",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十八日）　　　　　　○駆落ちたりと申す語、今日の国民新聞に見え申候茶漬る的筆法の脱化とも申すべく候。",
              "citation": {
                "source": "もゝはがき",
                "author": "斎藤緑雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
