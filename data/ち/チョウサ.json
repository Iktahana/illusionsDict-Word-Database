[
  {
    "uuid": "e3374bbe-7bb6-57e3-91bd-e11e590a182d",
    "entry": "調査",
    "reading": {
      "primary": "ちょうさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
