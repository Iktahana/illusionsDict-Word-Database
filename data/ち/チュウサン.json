[
  {
    "uuid": "acd328e9-5f4f-5a81-9ecf-0d84cce5d9ce",
    "entry": "昼餐",
    "reading": {
      "primary": "ちゅうさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "luncheon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "駒ヶ岳の麓、台ヶ原の客舎に昼餐を了りたる束の間に、禿筆を舐ぶりて偶感を記す、その文を成さざる、冀くは我が興の高きを妨ぐるなからむ。",
              "citation": {
                "source": "山を讃する文",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前十時頃に起きて、朝餐と昼餐を同時に喰ふは趣味多き事なれど、この頃は大抵九時頃に起床を余儀なくせらる。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹林の昼餐をやつと済ますと、私たちは裏の別荘の丘に席を移して、山と海との大観をそれまでほしいままに楽しんでゐたのである。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、白い七｜日八｜日の月も見て、昼餐の料やいただかう。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼餐の料やいただかう。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに正午にはまだかなりの間があるうちから、しきりに腹が空いて、昼餐の合図の銅鑼ばかりが待たれて困った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう昼餐の銅鑼が鳴るのもじきであろう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、前に書くはずなのを、うっかりしていたが、ちょうど、この日の昼餐が済むと、直ぐから、二等船客発起の仮装行列なるものが、それこそジャランジャラン騒ぎでケビンの甲板を一周し二周したものだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とにかく、お昼餐でもやるか。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中が私へ昼餐を持つて来た時、隣の障子が開いて女は一人のお婆さんと階子段をおりて行つた。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "この王｜昼餐後、必ず人に秘して一物を食うに、その何たるを識る者なし。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　昼餐をば神子田のお苑さんといふ従姉（新山堂の伯母さんの二番目娘で、自分より三歳の姉である。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐ帰る筈だつたのが無理に引留められて、昼餐も御馳走になつた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼餐の時は其でよかった。",
              "citation": {
                "source": "或る日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜は十一時頃から教会に行き、昼餐は料理店ですませて市外の公園にゴルフをしに行ったり夫婦で夕暮まで郊外の野道を植物採集に逍遙する。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、三人で、落付いた昼餐をし、立ち入らない話をする間に、自分は彼女の和らいだ心を、まざまざと感じた。",
              "citation": {
                "source": "二つの家を繋ぐ回想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無題（八）宮本百合子　松林、鎧戸を閉したヴィラの間を通って Hotel Hajek の庭　日覆の下の卓で昼餐。",
              "citation": {
                "source": "無題（八）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「代官が一個人の資格をもつて、われわれ風情のところへ来臨される、即ちわしの家へ昼餐に立ち寄られるのぢや。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「村長が代官に昼餐を饗応したといふ話は聞き及びませんぢやて。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "種々昼餐を一緒に食べながらお話しなさる。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼餐を運ばれ、服薬を致しなどせし後、何程の時の間にてもなく候へど、意地悪き迄の深き眠りに落ちしに候。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "偖てお妾さんが別荘へ著いて見ると其の屋敷の並木道には花が一ぱい蒔散らしてあつて、部屋部屋の飾り付けは、目を驚かすばかりなのに、かてて加へて、その昼餐の献立の美しさ贅沢さといつたら又格別だつた。",
              "citation": {
                "source": "フランソア・コッペ訪問記",
                "author": "堀口九萬一",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに鄭重な昼餐の饗応を受けた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "凍れる朝を長野にいって、Ｋを驚かし、やまやという感心もせぬ旅宿に昼餐したため、白馬山におくられ、犀川よぎり、小諸のあたり浅間山を飽かず眺め、八ヶ岳、立科山をそれよと指し、落葉松の赤きに興じ、碓氷もこゆれば、曾遊の榛名、赤城の山々は、夕の空に褪赭色ににじんでいた。",
              "citation": {
                "source": "雪の武石峠",
                "author": "別所梅之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ外にも色々ありますけれども昼餐のお副食物に差上げましょう。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四十一　田毎豆腐　昼餐の支度はなかなかに手間が取れたり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "上げ、ゆっくり二人で昼餐をすませたら、Ａかえり、機嫌よし。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月二十七日（日曜）　光子さんと動物園にゆく五月二十八日（月曜）曇　大使館で、午後一時から昼餐、酒匂夫妻、広岡、大使、令嬢。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日の朝ウェストン氏が宿に来て、昼餐に招待した、私達はそれまで上の丘に散歩にゆく。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って岩見重太郎、もしくは『今昔物語』のちゅうさんこうやのごとき例は、すこしでも動物学の知識を損益するところはないわけである。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
