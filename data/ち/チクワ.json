        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（うまい、ああ旨い、この竹輪は骨がなくて難有い。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は二本目の煙草を点けたところで、その煙が円い竹輪麩を切ったように一つずつ渦を巻いて、それが繋がりながら飛んで往くのに気が注いた。",
              "citation": {
                "source": "雨夜草紙",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙はやはり竹輪麩のように渦を巻いて、それが連続しながら天井の方へ昇って往った。",
              "citation": {
                "source": "雨夜草紙",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お定りの菎蒻に、雁もどき、焼豆府と、竹輪などは、玉子より精進の部に入ります。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいかわらず女の出来ない精進男に、すじか、竹輪か、こってりとした処を食わせたい。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本晴、朝湯、行乞四時間、竹輪で三杯。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈がついてから、竹輪で一杯やつて別れた（こゝはまさに酒屋へ三里、豆腐屋へ二里の感じだ）。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ち設けた敬治君がきた、一杯やつてゐるところへ、樹明君がおくれたのであはてゝやつてきた、これで揃つた、酒、酒、酒、そして鰯、竹輪、うどん、汁、飯、等々等。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、盛るに從つて杓子にかゝる者、青物類はいふに及ばず、豚あり、魚あり、餅あり、竹輪あり、海の物、山の物、何が何といふ事を知らず。",
              "citation": {
                "source": "闇汁圖解",
                "author": "子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹輪に浅蜊貝といったような物を種にして、大阪風の切鮨を売っている。",
              "citation": {
                "source": "世間師",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お新香に竹輪の煮つけが、瀬戸の重ね鉢にはいっていた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンニャク、がんもどき、竹輪につみれ、辛子のひりりッとしたのに、口にふくむような酒をつかって、青々としたほうれん草のひたしですか、元気を出しましょう。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンニャク、いゝね厚く切ってピンとくいちぎって見たい……がんもどき竹輪につみれ、辛子のひりゝッとした奴に、口にふくむような酒をつかって、青々としたほうれん草のひたしか……元気を出そう。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お新香に竹輪の煮つけが、瀬戸の重ね鉢にはいっている。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゴボーに竹輪ブよ」「どうする？",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡麻鹽の握飯、椎茸、高野豆腐、海老、竹輪、菎蒻の煮しめが皆の前へ配られた。",
              "citation": {
                "source": "山遊び",
                "author": "木下利玄",
                "note": "青空文庫"
              }
            },
            {
              "text": "口取に蒲鉾はついてるが、どす黒くて竹輪の出来損ないである。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなんです――いなや鰈や竹輪はおいんなはらーンで、という」「おいんなはらーンででございますか。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食の膳には義母の郷里の名産、竹輪がのつてゐた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこのごろのひどい霜夜、師匠の供をしてかえってくるとき、きっと師匠は途中でそばやへ入る、でなければやた一のおでんやへ飛び込む、そうして熱燗でいっぱいやりながらそばやなら鴨南蛮か天ぬき、おでんやなら竹輪かがんもへ辛子をコテコテと付けてさも美味しそうにそいつをたべる。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "と血糊が走って……虚心流竹輪切りの一剣だ。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は不味い焼｜竹輪をむしゃむしゃ食べながら、酒をぐいぐいほした。",
              "citation": {
                "source": "風宴",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、こんにゃくや竹輪をその場で立食いする子供の客もある。",
              "citation": {
                "source": "日日の麺麭",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "名物の焼竹輪など仕入れて、二時四十分の上りへ乗る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食（ちくわ一皿、ぢやがいも一皿、沢庵漬）うるかをよばれた。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "陋屋の半坪の台所で、ちくわの夕食に馴れたる盲目の鼠だ。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十坪の庭にトマトを植え、ちくわを食いて、洗濯に専念するも、これ天職、われとわがはらわたを破り、わが袖、炎々の焔あげつつあるも、われは嵐にさからって、王者、肩そびやかしてすすまなければならぬ、さだめを負うて生れた。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝は番茶とパン、おひるは漬物と佃煮、夜は一日おきに蒲ぼことちくわ」　叔母はそう云ってからから笑いました。",
              "citation": {
                "source": "落ちてゆく世界",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "書物は取りによこすからそろえておいてくれるように、自分の居所はまだ明かせないが、そのうちくわしく知らせるからといって……　駒井が例の如く籐の鞭を振って立去る姿を、門に立った一学は、朝靄の中に見えずなるまで見送っていました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちくわに、はんぺん、ヤツにガンモ」なんてんで、（ヤツは八つ頭。",
              "citation": {
                "source": "下司味礼讃",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
