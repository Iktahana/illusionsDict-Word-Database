[
  {
    "uuid": "b4dc362f-520f-5dc9-bc93-c8efd3c3cc77",
    "entry": "朝議",
    "reading": {
      "primary": "ちょうぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
