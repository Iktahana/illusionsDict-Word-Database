        "examples": {
          "standard": [
            {
              "text": "そんな言い訳、ちゃんちゃら可笑しいわ。誰も信じないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の提案は現実離れしていて、ちゃんちゃら可笑しいと皆が思った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女が真剣な顔で言った冗談は、ちゃんちゃら可笑しくて吹き出してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "聖降誕祭お目出とうがちゃんちゃら可笑しいわい！",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖降誕祭お目出とうがちゃんちゃら可笑しいやい！",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんちゃら可笑しい！",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（矢野はおれがこの女の傍にいるのを見て、ちゃんちゃらおかしいと思っただろう）　嫉妬の気持はこうして、徐々に豹一の心にしのび込んで来た。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、太夫、お前は兎角うで立てが好きらしいが、そんな生れぞくないに、手込めにされるようじゃあ、このお江戸で、人前でハッキリいえない商売は出来ないんだよ――ちゃんちゃらおかしいや！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いえ、あの、それが、その」　権幕にドギマギしてしまって、「あの、つまり、こちらのお二階を拝借している女の人なんですが」　とたんにグイと剥身屋の主は顔を上げた、肩で笑った、ちゃんちゃらおかしいやと言わないばかりに。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ちゃんちゃらおかしいや。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怨霊首人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははあおかしいや、ちゃんちゃらおかしいや。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
