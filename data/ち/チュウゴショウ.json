[
  {
    "uuid": "2f478016-f4a3-5e3c-a295-5d9c6dc72cb9",
    "entry": "中小姓",
    "reading": {
      "primary": "ちゅうごしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
