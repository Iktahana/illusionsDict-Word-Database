    },
    "definitions": [
      {
        "index": 1,
        "gloss": "middle of a field",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "作家と孤独中原中也　インテリは蒼ざめてゐる。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮沢賢治全集刊行に際して中原中也　宮沢賢治全集の、第一回配本が出ました。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "感想中原中也　地方の詩のグループも多いことだが、どういふものか、ずつと以前から大連と神戸にだけ面白いものが見られるのだつた。",
              "citation": {
                "source": "感想",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "草野心平詩集『母岩』中原中也　草野心平君の第三詩集『母岩』が出た。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩原朔太郎評論集　無からの抗争中原中也　萩原氏の本はよく売れるさうである。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二年九月十五日中原中也高橋新吉様",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は中原中也も立原道造も格別好きでなかつたが、津村だけは好きであつた。",
              "citation": {
                "source": "郷愁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山羊の歌中原中也-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）吁！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "中原〔逐〕鹿三十年、恩怨無別星花転、転と来て転句だ……おゝ何といふ向ふの眼、燃え立つやうな憎悪である。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時中原君は、強度の神經衰弱で弱つてることを告白し、不斷に強迫觀念で苦しんでることを訴へた。",
              "citation": {
                "source": "中原中也君の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "話を聞くと僕も同じやうな病症なので、大に同情して慰め合つたが、それが中原君の印象に殘つたらしく、最近白水社から出した僕の本の批評に、僕の人物を評して「文學的苦勞人」と書いてる。",
              "citation": {
                "source": "中原中也君の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のちよつとした言葉が、そんなに印象に殘つたことを考へると、中原君の生活はよほど孤獨のものであつたらしい。",
              "citation": {
                "source": "中原中也君の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大體の文學者といふものは、殆んど皆一種の精神病者であり、その爲に絶えず惱んでゐるやうなものであるが、特に中原君の如き變質傾向の強い人で、同じ仲間の友人がなく、その苦痛を語り合ふ對手が居なかつたとしたら、生活は耐へがたいものだつたにちがひない。",
              "citation": {
                "source": "中原中也君の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の同じ文中で、中原君は僕のことを淫酒家と言つてるが、この言はむしろ中原君自身の方に適合する。",
              "citation": {
                "source": "中原中也君の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり中原君の場合は、強迫觀念や被害妄想の苦痛を忘れようとして酒を飮み、却つて一層病症を惡くしたのだ。",
              "citation": {
                "source": "中原中也君の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中原の最近出したラムボオ譯詩集はよい出來だつた。",
              "citation": {
                "source": "中原中也君の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラムボオと中原君とは、その純情で虚無的な點や、我がままで人と交際できない點や、アナアキイで不良少年じみてる點や、特に變質者的な點で相似してゐる。",
              "citation": {
                "source": "中原中也君の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただちがふところは、ラムボオが透徹した知性人であつたに反し、中原君がむしろ殉情的な情緒人であつたといふ一事である。",
              "citation": {
                "source": "中原中也君の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔日暴風雨を凌ぎ、疾雷閃電の猛威を以て、中原を席捲し去りたる夢は今｜何処にかある。",
              "citation": {
                "source": "想断々（２）",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかで、一座の先輩と仰がれている中原武太夫という男が言い出した。",
              "citation": {
                "source": "百物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ百箇条の話をするのであるから、一つの話はなるべく短いのを選むという約束であったが、それでも案外に時が移って、かの中原武太夫が第八十三番の座に直ったのは、その夜ももう八つ（午前二時）に近い頃であった。",
              "citation": {
                "source": "百物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "中原は今度で三番目であるから、持ちあわせの怪談も種切れになってしまって、ある山寺の尼僧と小姓とが密通して、ふたりともに鬼になったとかいう紋切形の怪談を短く話して、奥の行燈の火を消しに行った。",
              "citation": {
                "source": "百物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にもいう通り、行燈のある書院までゆき着くには、暗い広い座敷を五間通りぬけなければならないのであるが、中原は最初から二度も通っているので、暗いなかでも大抵の見当は付いていた。",
              "citation": {
                "source": "百物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "中原は無事にもとの席へ戻ったが、自分の見たことを誰にも言わなかった。",
              "citation": {
                "source": "百物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて順々に席を起ったが、どの人もかの怪しいものについて一言もいわないので、中原は内心不思議に思った。",
              "citation": {
                "source": "百物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "中原は試みに一座のものに訊いた。",
              "citation": {
                "source": "百物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　中原が行燈をともして先に立つと、他の人々も一度につづいて行った。",
              "citation": {
                "source": "百物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、中原が言い出した。",
              "citation": {
                "source": "百物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "中原をはじめ、他の人々も厳重に見張っていたのである、それがおのずと煙りのように消え失せてしまったというので、下田も又おどろいた。",
              "citation": {
                "source": "百物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
