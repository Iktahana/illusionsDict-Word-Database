    "definitions": [
      {
        "index": 1,
        "gloss": "blood spray (caused by a weapon)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蚊帳には牛九郎老人の枕元に血飛沫がかかっているだけで、ほかに何の異状も認められないところを見ると、二人の寝息を窺った犯人は、大胆にも電燈を灯けるか何かして蚊帳の中に忍び入って、二人の中間に跼むか片膝を突くかしたまま、右と左に一気に兇行を遂げたものらしい。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ、生れて初めての強敵を刺止めし事とて、ほつと一息、長き溜息しつゝ、あたり見まはす折しもあれ最前の若衆、血飛沫乱れ流れたる明障子を颯と開きて走り寄り、わが腰衣に縋り付きつゝ、やよ鬼三郎ぬし。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "車輛と車輛との間が、鋼鉄車体のところといわず、連結器のところと云わず、真赤な血飛沫がベットリ附着し、下の方へ雫がポタポタと墜ちていた。",
              "citation": {
                "source": "キド効果",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "颯と白紗の蚊帳に血飛沫が散って、唐紅の模様を置いた。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "血飛沫が障子一面に飛んで、白い乳の珠がトロトロと紅い網に包まれた。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右を見廻すと近くに居た連中は皆、八方へ飛退いた姿勢のまま真青な顔を引釣らして福太郎の顔を見上げていたが、中には二三人、顔や手足に血飛沫を浴びている者も居た。",
              "citation": {
                "source": "斜坑",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後の白幕に虹のような血飛沫を残しながら、フットライトの前にヒレ伏した。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、すぐに、武士は、足から先に、紙帳の中へ引き込まれ、忽ち、断末魔の声が起こり、バーッと、血飛沫が、紙帳へかかる音がしたが、やがて、森然と静まってしまった。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "血飛沫によって作られた網が！",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず戸口から青竹の杖が、一本スッと突き出され、つづいて血飛沫の斑点をつけた裾と、土にまみれた足もとがはいって来た。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "血飛沫が壁紙と天井になまなましい花模様をかいている。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あツと言ふ間もない、三太刀、四太刀、滅茶々々に斬つて到頭｜止めを刺し、土藏から飛出した曲者は、血飛沫で汚れた袷を脱いで縁の下に突つ込んだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "凧の詭計",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに下から突き上げちや、下手人は頭から血飛沫を浴びたことになるが――」　平次はさう言ひ乍ら、思ひの外｜巧みに足場を登つて、二階の窓の下のあたりに顏を持つて行きました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿馬鹿しく贅澤な、そして趣味の惡い裝飾のゴテゴテとした八疊で、書院風になつた床側の柱の側、凭れて酒を呑んで居たといふ障子に、一面の血飛沫がして、脇差を通した跡といふのが、不氣味な大穴になつて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下には少しも血が附いちやゐないぜ、障子の血飛沫はひどいが――多分｜脇差を障子越しに突立てられると、主人は傷を負ひ乍ら飛退いたのだらう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "良い男のくせに、顏は恐怖と苦痛に歪んで、妙に物凄まじく、胸の脇差は拔いてありますが、黒つぽい單衣をひたして、疊も障子も恐ろしい血飛沫です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "百足屋殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "得物は彫物師の使ふ鋭い鑿、燒印はガラツ八が言ふ通り、得物が深々と入つたせゐか、大した出血ではありませんが、それでも其邊は一面の血飛沫です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "歎きの菩薩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「氣の毒だが、その胸の血飛沫がモノを言ふから、一刻ばかり此處へ寄り付かないといふ、確かな證人がなきや――」「これは親分」　專次は自分の胸のあたりを眺めました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "十七の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうせ女出入りだ、遅かれ早かれ、殺される野郎さ」　万七は六畳の間に入ると、血飛沫の間を拾って死体に近づきました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "綾吉殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手で使ったら、血飛沫で全身｜蘇芳を浴びたようになるはずだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "綾吉殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "得物は彫物師の使う鋭い鑿、焼印はガラッ八が言う通り、得物が深々と入ったせいか、大した出血ではありませんが、それでもその辺は一面の血飛沫です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "歎きの菩薩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「気の毒だが、その胸の血飛沫がモノを言うから、一刻ばかりここへ寄り付かないという、確かな証人がなきゃ――」「これは親分」　専次は自分の胸のあたりを眺めました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "十七の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍には弟の民五郎、妙にウロウロして、何事も手の付かぬ様子で平次を迎えましたが、さすがに落着きを見せるつもりか、血飛沫の中に、おののく膝を突いて、「親分、御苦労様で」　そんな事を言っております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "血潮と糠",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「その血飛沫の中に、塀の割け目を、裏から繕ったのがあるだろう、――同じような黒い板だが、その板だけは血の跡も無いのはどういうわけだ」「成程ね」　ベットリ板塀を汚した血飛沫の中に、五分幅の二寸程の長さで、裏から貼った繕いの板だけが、少しも血を受けてないのは不思議です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "腰抜け彌八",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「女の寝巻ですよ、――裏の縁側の手摺に掛けてありましたが、下女のお六に訊くと、あのお夏という娘の物なんだそうで」「フーム」「この寝巻の背中から後ろ襟へかけて、血飛沫を浴びて居るんです、――矢張りあのお夏という娘が怪しいんじゃありませんか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鬼の面",
                "note": "青空文庫"
              }
            },
            {
              "text": "長襦袢を寝巻にしたもので、少し色褪せた鹿の子絞りも哀れですが、昼近い陽の中に処女の移り香がほんのり漂って、血飛沫のあとを超えて艶めきます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鬼の面",
                "note": "青空文庫"
              }
            },
            {
              "text": "その遺書を取上げると、遺書の下、疊の上には血飛沫があり、遺書は粗末な半紙に、提灯屋風に、タドタドしい筆蹟でなすつたもので、その文面は、おくがたはじめ、三人もころしたのは、みんなおれのしわざだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美しき人質",
                "note": "青空文庫"
              }
            },
            {
              "text": "河の流れはその石にぶつかって波立ちしぶきをあげ小さい虹を立てる。",
              "citation": {
                "source": "あとがき（『幸福について』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
