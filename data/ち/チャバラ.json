        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かえって胃から必要な場合に水分を分泌する位だから水分を多量に飲むと胃の中へ停滞して俗にいう茶腹が張ったように腹がダブダブする。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、ダブダブの茶腹には、春の日の風が冷たかった。",
              "citation": {
                "source": "圓太郎馬車",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶腹が鳴るワ」「森越中殿、其許は御裕福でござろう、塩という財源をひかえておらるるからナ」「御冗談でしょう。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "定公なんか、「茶腹も一とき、アアもうダブダブになっちゃった」　というさわぎだ。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダブダブの茶腹で、夜っぴて米沢町一丁目の路地の奥に粘るんだから、深草の少将は楽じゃありませんぜ」「フーム」「中でも丹波彌八郎は大変で、――苗字がちゃんとあるんだから、これは二本差の子ですがね。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "腰抜け彌八",
                "note": "青空文庫"
              }
            },
            {
              "text": "「茶腹も一時」というが、これではひょろひょろしてころがり込んだわけだ。",
              "citation": {
                "source": "ブイヨン・ドンゾール",
                "author": "――十一時の肉の煮出し――",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日からは五月梅雨ですから、おお哀れ犀星よ、汝の茶腹をいかんせん、というところです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
