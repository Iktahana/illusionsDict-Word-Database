[
  {
    "uuid": "fdafd887-2aba-58fb-a3c9-87fe26ddbacb",
    "entry": "チョッキ",
    "reading": {
      "primary": "チョッキ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "waistcoat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "坊主刈りでチョッキを着ないドイツ人。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　若いお父さんは、その青白い時計をチョッキのポケットにはさんで靴をかたっと鳴らしました。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてチョッキのみになりたるに心付き、床の上にある上着を取上げ着る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にチョッキの隠袋から、何か小さなものを出して、火縄でそれに点火したのを、手早く筒口から投げ入れると、半秒足らずくらいの後に、爆然と煙が迸り出て、鈍い爆音が聞える。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "食欲に肥えふとって、なにか堅いチョッキでも着たような恰好をしている。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからチョッキのかくしからライターをぬき出して顔の正面の「明視の距離」に持って来ておいてパチリと火ぶたを切る。",
              "citation": {
                "source": "詩と官能",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よもやそんなことはあるまい、あるまいけれど、な、わしの銅像をたてるとき、右の足を半歩だけ前へだし、ゆったりとそりみにして、左の手はチョッキの中へ、右の手は書き損じの原稿をにぎりつぶし、そうして首をつけぬこと。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」獅子はチョッキのかくしから大きながま口を出してせんべい位ある金貨を八つ取り出して象にわたしました。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大森は机に向かって電報用紙に万年筆で電文をしたためているところ、客は上着を脱いでチョッキ一つになり、しきりに書類を調べているところ、煙草盆には埃及煙草の吸いがらがくしゃくしゃに突きこんである。",
              "citation": {
                "source": "疲労",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "上着もチョッキも着ないで、ワイシャツのままで出て来た。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "教場へはいると、まずチョッキのかくしから、鎖も何もつかないニッケル側の時計を出してそっと机の片すみへのせてから講義をはじめた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはすぐチョッキだけ着て山羊を見に行きました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全くの起きたままチョッキだけ着て顔もあらわず帽子もかむらず山羊が居るかどうかもわからない広い畑のまんなかへ飛びだして来ているのです。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の頬の赤いチョッキだけ着た十七ばかりの子どもが、何だかわたくしのらしい雌の山羊の首に帯皮をつけて、はじを持ってわらいながらわたくしに近よって来ました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファゼーロが皮を染めたりするだろう、ぼくはへただけれどもチョッキはつくれるよ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、さう気がついて見ると、小さなガラスの窓は、鳥かごの顔、正面の網戸が、立派なチョッキと云ふわけでした。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四番目のは、先生がある夏、一寸油断をして網のチョッキを大きく開けたまゝ、睡ってゐるあひだに、乱暴な猫大将が来て、いきなりつかんで行ってしまったのです。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又五六日たって、フウねずみが、いつものとほり、大いそぎで鳥箱先生のそばを通りすぎようとしますと、先生が網のチョッキをがたっとさせながら、呼びとめました。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥箱先生は怒って、ほてって、チョッキをばたばたさせながら云ひました。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になったら綿のはいったチョッキもやろう。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昆布を一｜斤とらないうちは綿のはいったチョッキをやらんぞ。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ綿のチョッキをやるぜ。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　チョッキがふらふらのぼって来ました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白や茶いろや、狐の子どもらがチョッキだけを着たり半ズボンだけはいたり、たくさんたくさんこっちを見てはやしているのです。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ隣りの教員室から、黒いチョッキだけ着た、がさがさした茶いろの狐の先生が入って来て私に一礼して云いました。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云いましたら、一番前の私の近くに居た赤いチョッキを着たかあいらしい狐の生徒が、「はいっ。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「この赤と白の斑は私はいつでも昔の海賊のチョッキのような気がするんですよ。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小麦を粉にする日ならペムペルはちぢれた髪からみじかい浅黄のチョッキから木綿のだぶだぶずぼんまで粉ですっかり白くなりながら赤いガラスの水車場でことことやっているだろう。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青いチョッキの虻さんでも黄のだんだらの蜂めまでみなまっさきにあっちへ行くわ。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち進み来たれる紳士は帽を脱して、ボタンの二所｜失れたる茶羅紗のチョッキに、水晶の小印を垂下げたるニッケル鍍の※を繋けて、柱に靠れたる役員の前に頭を下げぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
