    "definitions": [
      {
        "index": 1,
        "gloss": "hair style where the hair is tied up in a bundle on the back of the head (resembling the shape of a tea whisk)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
