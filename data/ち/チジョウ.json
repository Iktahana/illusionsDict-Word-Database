[
  {
    "uuid": "b3879d48-7bd3-583a-886b-133779af100b",
    "entry": "地上",
    "reading": {
      "primary": "ちじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "above ground",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『文学なぞは早晩地上から跡を絶つに決つてゐるもので、今猶文学なぞに執心してゐる奴は愚物に限る』なぞ。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして『西洋の国々と同じく、ここにもやはり醜い生存競争があり、常々不義や奸計が行われている』と、地上の現実社会である日本を見ている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　地上を愛さんために、人は先づ神を愛す必要がある！",
              "citation": {
                "source": "Me Voila",
                "author": "―― a Cobayashi",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には秋のような日が照り渡って、地上には麦が実り、大鎌や小鎌を持った農夫たちが、至るところの畑の中で、戦争のように忙がしく働いている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には中秋の月が冴えて、氷のような月光が独り地上を照らしている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気は梅雨で重たくしめり、地上は一面の桑畑である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という題であったか忘れたが、自分が九歳の頃東海道を人力車で西下したときに、自分の乗っていた車の車夫が檜笠を冠っていて、その影が地上に印しながら走って行くのを椎茸のようだと感じたと見えてその車夫を椎茸と命名したという話を書いた。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦いが終わってトーレ・フンドは王の死骸を地上に延ばして上着を掛けた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴後の茶漬も快く、窓によれば驟雨沛然としてトタン屋根を伝う点滴の音すゞしく、電燈の光地上にうつりて電車の往きかう音も騒がしからず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの光に陶然と醉つて、地上のことを忘れて居たのを！",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、地上に資本主義の毒が廻らぬ隈もないように、彼の心臓も、コレラ菌のために、弱らされていた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはつまり比較的暖かい地上近くの空気が温気を含んだままで気流につれて上昇し、高層の気圧の低い処へ行くに従って膨脹して冷えて来る、ある処まで行くと雲と凝り雨になってしまう事もあるが、ごく寒い時にはこれが直ちに凍って小さい雪片となりこれが次第次第に大きく生長する。",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光の目に見えぬ力で地上のすべての活動をそっとおさえつけてあるように見える。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはひそかに無性な触覚の気安さから一たび風が吹き出すと、吹雪のように中空に、地上に舞い立ち渦巻くあわただしさと変った。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上見ぬ鷲の翔らん天ぎわから地上へかけて雲の帳は相変らずかけ垂れていたが、深まり来るたそがれの色にあらがうように帳の色は明るく薄れ行きつつある。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが同じ地上に在って眺めらるものの姿であるのか。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "麓はよし地上の山にしろ、頂はそれに何の縁もない雲に代って空から湧くまた一つの気体の別山なのではあるまいか。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生けるものに失望したのか、それとも自分自身現実離れして行くのか、女神の姿は、住いの麓の館をはじめ地上ではだんだん見受け悪くなった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妖艶な柳が地上にとどくまで枝垂れている。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからある種の動物は、ただその周囲の地上に圏の筋をひかれただけで、それを越し得ないというそれのように、柚木はここへ来ても老妓の雰囲気から脱し得られない自分がおかしかった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地上から仰いで見てはよく分らないが、飛行機でその層を横にすかして見ると、それが明らかな層をなして棚引き、いわゆる「塵の地平線」を形成している。",
              "citation": {
                "source": "塵埃と光",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中でも水蒸気が地上の物体に接触して生ずる露と霜と木花と、氷点下に過冷却された霧の滴が地物に触れて生ずる樹氷または「花ボロ」を除けば、あとは皆地上数百ないし数千メートルの高所から降下するものである。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正岡君などは全く天降だりした神の子のような詩人ではなく、立派に地上から生れた詩人です。",
              "citation": {
                "source": "子規と和歌",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "恩愛ふかき親に苦を増させて、我れは同じき地上に彷遑ん身の、取あやまちても天上は叶ひがたし。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年九月十三日『東京朝日新聞』）　　　　　　　　　三　　　　　　露　夜地上の草木土石が冷えて空気よりも冷たくなると、空気中の湿気が持ち切れなくなって露と結ぶ。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔エジプトの天文学者は地上に環を立てて北極星に面せしめて置き、環の影が丁度一直線になる日を見て春分秋分を定め、これを基として暦を定めたという事で、その時の環が今日でもアレキサンドリアの博物館に保存してある。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで止むを得ず瓦斯を抜き無事に地上に下りるを得た。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルダーショットからロンドンまで一時間二十四マイルの速度で飛行し、聖ポールの寺院を一まわりして今度は風に逆らって進んだが、あまり風が強かったから水晶宮の辺で地上に下った。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人の説によれば、鳥類が農作物の害虫を駆除する功は非常なもので、もし鳥類濫殺の結果有益な鳥が絶滅に近づく暁には、地上の植物は大半滅亡するに至るであろうというている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのときの王子くんが、ちじょうにあらわれたのは、ここ。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
