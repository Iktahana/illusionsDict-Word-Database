    "definitions": [
      {
        "index": 1,
        "gloss": "tea utensils",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だが、さうなると、紅茶器なんかの上｜等も欲しくなる……」「あら、それぢやきりがないわね。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひびへ漆を入れた茶器を現に二人が讃めたことがあったのです。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽柴筑前守なぞも戦をして手柄を立てる、その勲功の報酬の一部として茶器を頂戴している。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり五万両なら五万両に相当する勲功を立てた時に、五万両の代りに茶器を戴いているのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "関西の大富豪で茶道好きだった人が、死ぬ間際に数万金で一茶器を手に入れて、幾時間を楽んで死んでしまった。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶はいらないというと、せっかく茶器を取りだしかけていたおぬいさんは素直にそのままそれをそこにおいて、机の座に戻ってきた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "書生さんはそこいらに散らばっている茶器を押し除けて、奥から座布団を持って来て私にあてがうと、「私は妻木というものです。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手には机に近く茶器を並べた水屋と水棚があって、壁から出ている水道の口の下に菜種と蓮華草の束が白糸で結わえて置いてある。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶室、茶庭、茶器、掛物、懐石の料理｜献立、読むにしたがって私にも興が湧いて来た。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "多く夏の釣でありますから、泡盛だとか、柳蔭などというものが喜ばれたもので、置水屋ほど大きいものではありませんが上下箱というのに茶器酒器、食器も具えられ、ちょっとした下物、そんなものも仕込まれてあるような訳です。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽柴筑前守なぞも戦をして手柄を立てる、其の勲功の報酬の一部として茶器を頂戴してゐる。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり五万両なら五万両に相当する勲功を立てた時に、五万両の代りに茶器を戴いてゐるのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "関西の大富豪で茶道好きだつた人が、死ぬ間際に数万金で一茶器を手に入れて、幾時間を楽んで死んでしまつた。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "金持の隠居が世を果したのち、茶に凝り、茶器を撫で廻して笑壺に入る。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう一つ如何でございます、」「もう沢山、」「では、お茶を、」　女中は茶器に手を触れた。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月二十六日　午後Ｔ氏がわざわざ用意して手荷物の中に入れて来た煎茶器を出して洗ったりふいたりした。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "祝は喜んで其所へ往って、「どうかお茶を一ぱい飲ましてください」　と言うと、媼さんはこころよく迎えて、「さあ、さあ、どうかお休みくださいまし」　と、言って祝に腰をかけさし、静かに茶を汲んできたが、茶器も立派なうえに茶の色も良かった。",
              "citation": {
                "source": "水莽草",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず、支那の奥地の四川省から雲南、貴州へかけて住んでいる大富豪の中で、お茶の風味がよくわかって、茶器とか、茶室とかの趣味に凝り固まった人間が居るとしますかね。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから些なくて三四台、多くて七八台から十台位の、美事に飾り立てた二頭立の馬車が行くので、その中に崑崙を飲みに行く富豪だの貴人だのが、めいめいに自慢の茶器を抱えて乗っている訳ですが、この時に限って支那富豪に附き物のお妾さんは、一人も行列の中に加わっておりません。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "富豪貴人たちはそこで、その茶器の蓋をした白紙を取除いて、生温い湯をホンノ、チョッピリ啜り込むのです。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫檀の盆に九谷の茶器｜根来の菓子器、念入りの客なことは聞かなくとも解る。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして皆目意識が朦朧としてしまひ、翌朝女房に訊ねたら、酒場で、一人の友達をつかまへ、その友達であり、同時に僕の好きな友達である作家のことを、近頃のその作家の作物が気に喰はん――などと云つて、大騒ぎを演じ、宿に帰ると女房を相手にまた喧嘩をし、茶器をこわしたり、唐紙を破いたりしたさうだつた。",
              "citation": {
                "source": "初夏通信",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢も茶器もちやんと隅にくつゝけてあつて只からりとして居る。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "藥局生は擬ひの相馬燒の茶器に茶を入れて來る。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐治君は鞄の中から白い晒しの切を出して茶器を拭つて茶を侑めた。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶、茶器、縮緬など。",
              "citation": {
                "source": "サフランの花",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "母がそれに腰をかけて「ちゃんちゃんちゃきちゃん」というこれもまた四拍子の拍音を立てながら織っている姿がぼんやりした夢のような記憶に残ってはいるが、自分が少し大きくなってからは、もうこの機はあまり使われなかったらしい。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりで来ちゃきっとここへ落ちるから来年でもいつでもひとりで来ちゃいけないぞ。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりで来ちゃきっとこゝへ落ちるから来年でもいつでもひとりで来ちゃいけないぞ。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体ちゃきちゃきの深川ッ女が、根岸くんだりへ行って、ももんじいに歌を習うなんて、そんな間違ったことはないんです。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
