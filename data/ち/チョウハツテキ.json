[
  {
    "uuid": "e1c007d8-6a85-548b-bee2-240d5573805a",
    "entry": "挑発的",
    "reading": {
      "primary": "ちょうはつてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
