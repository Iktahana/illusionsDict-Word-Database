    },
    "definitions": [
      {
        "index": 1,
        "gloss": "middle way",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かくてこそ、かの成巧者達が、大抵頸の硬い中庸主義者であり、殆んど理論なくカンでばかり体験し、苦労を咬み殺した人達であることが分ります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに常識的といつたのは、自然や設備の上で中庸といふ好みを意味して居る。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に言つた通り、伊香保は中庸的の温泉であるから、自分の趣味で好きといふには不適当だが、嫌ひといふやうな所は全くない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢張伊香保そのものの感じと同じく中庸的である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に伊香保の愛顧者は女性に多いと言つたが、つまりその女性とはかういつたやうな、中庸的の夫人や娘たちである。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議に伊香保といふ所は、何から何まで女性的であり中庸的である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば孔子の教えた中庸ということでも解釈のしようによっては「いつも半分風邪を引いているように」という風に受取れるかもしれない。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "惡くいへば、それだけ心が荒んで來るのであらうが、神經質すぎる人にとつては、それで丁度中庸が取れることになつてゐるのである。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は彼と別れにのぞんで、ミケルド・モンテニュの「社会の計画の中庸を持し、運命的施設を待つ」の一句を彼に進呈した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルネラはそんなことなどは問題にしないと見えて絶えず攻勢を持続するのはよいが、やみなしに中庸な突きを繰り返しているのは、仕事の経済から見ても非常に能率の悪いしかたで、無益の動作に勢力をなしくずしに浪費しているように見えるのであった。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかくに人に対して中庸を得てないわたくしの血筋の性格である。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "発して皆、節に中る、之を和と謂う、と中庸にもあったやろ。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中庸にも、鬼神の徳たる其れ盛なり矣とあるように、死後の鬼というものを非常に畏れ敬っている。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その思想の根本は、或いは仁と言い、或いは中庸と言い、或いは寛恕と言い、さまざまの説もありますが、僕は、礼だと思う。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "繆公の智、中庸の方なり。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "中庸の方は上智英略あらざるものの方策なるを言ふ也。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご存じであろうけれども、南方の強、北方の強、という言葉は、中庸第十章にも見えているようであるが、それとこれとの間に於いては別段、深い意味もないように、私には思われる。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの優れた中庸への本能だ。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いついかなる場合にも夫子の進退を美しいものにする・見事な中庸への本能だ。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあげくヤット現在の中庸を取った無表情式のものが生まれた訳で、能が生まれたのも多分それと一緒ではなかったかと考えられる。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」『中庸（三十章）』のがそれであることが分る。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは『中庸（十三章）』に「忠恕は道を違ること遠からず（忠恕違道不遠）」の語が掲げてあって、その道を違ること遠からずとある「違道不遠」と、「一以貫之」とでは隔たりが有り過ぎると思わせるところからだ。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "全氏は「一以貫之」を説いて、天地の一以貫之、聖人の一以貫之、学者の一以貫之と、三段に一以貫之を挙げて、曽子から教を伝えた子思の手に成った『中庸』を取出し示して、「一貫の説に解説書はいらない、『中庸』を読めば即ちこれが解説書となろう。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言ったのは流石で、『中庸（二十五章・二十六章）』を挙げて解説書とし、宋儒一派の口を封じた。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その作用は常に変わらず、則ちその物を生じること測り知れない、これが自然の営為なり、ああ充ち満ちて尽きることがない」という『中庸（二十六章）』の文を示して、これ天地の一以貫之なりとして、また「誠（まごころ）は自分を完成するだけでなく、他の物を完成させる本である。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして宋儒の「万物一太極、一物一太極、一本万殊、一実万分」等の説を、「その文は繁雑でその道理は解り難い、中庸に既にその意味の掲げられて有るのを知らないのである。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱子も勿論一貫の趣旨の説明に「誠」を用いないことは無いから、『中庸（二十六章）』の「至誠無息（至誠は息むこと無し）」の語を使用している。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どない書いたアるちゅうて、訊いてんねんぜ」「どない書いたアるちゅうようなことは、もう手おくれや。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――もう、南十字星てどの方角に出てる星やねんちゅうような、ぼけたことは言わへんぞ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "和武の馴染の妓ちゅうのは、浜勇ちゅうてその頃はあまり流行らない顔だしたが、まン丸い愛嬌の滴るような可愛い妓だしてな、まア、役徳ちゅう奴で、中々私等の身分で新地で散財するちゅうような事はでける事っちゃおまへんが、費用はなんぼでも出るので、お大尽さんになって、茶屋遊びだす。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
