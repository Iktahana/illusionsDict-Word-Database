    "definitions": [
      {
        "index": 1,
        "gloss": "district",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "中央地区と言ったか、何地区と言ったか、とにかく本郷、小石川、下谷、神田、あの辺の学校全部の、マルクス学生の行動隊々長というものに、自分はなっていたのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスはＭの学生地区にさしかかった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女のむす子はＭ地区の学校を出て、入学試験の成績もよく、上野の美術学校へ入った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "植民について、――土地選定、土地区劃、土地処分。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "アッパ・スウォンダム横町はいかがわしい路地で、波止場の集まる地区の裏手にあたる。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "河岸地区全体でも最低最悪の地獄の馬車で、僕もネヴィル・シンクレアが入ったきり出てこないのではと心配している。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "「消印はロンドン――東地区。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐまえの青建物の貧民学校から、総出でくる、すぐそばの海員地区からも、つながってくる、このお仕置台に首をはさまれている、さらし物の見物で、去年｜竜舌蘭の大輪が咲いたときのさわぎとはまたちがった、大へんな人だかりになるでしょう。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行は吉本組××地区飯場で、水力電気の土工工事に働くのであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "××地区の第××班では、その班会を開くたびに、一人二人とメンバーが殖えて行った。",
              "citation": {
                "source": "疵",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ倉田工業と同じ地区にするのが良いか悪いかで随分迷った。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ地区だと可成り危険性がある。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し他の地区ということになれば交通費の関係上困った。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな場合は勿論他の地区の方が良かったが、然し警察は案外私が他の地区に逃げこんだと思っているかも知れない。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから彼奴等の裏をかいて、同じ地区にいるのも悪くないと思った。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの地区ではまだ具体的にはスパイに顔を知られていなかった、それに工場もやめたので経済的な根拠から同じ地区に下宿を決めることにした。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度のところも倉田工業のある同じ地区にも拘らず、ゴミ／＼した通りから外ずれた深閑とした住宅地になっていた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "太田の「申上げ」によって、彼奴等は私を捕かもうとして、この地区を厳重に見張りしていることは考えられるのだ。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "太田の裏切から私は最近別な地区に移ることに決めたが、自分で家を探がして歩くわけにも行かなかったので、それを笠原に頼んだ。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "充分に気をつけることにして、何時も私達の使わない地区の場所を決め、自動車で須山に連れて来てもらうことにした。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで掃除婦から、その男工はこの地区の青年団の一員で在郷軍人であり、戦争が始まってから特別に雇われて入ってきたということが分った。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「地方」「地区」それに「工細」と仕事が重なって居り、一日に十二三回の連絡さえあることがあった。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "山王の祭礼は三大祭りの王たるもので、氏子の範囲も麹町、四谷、京橋、日本橋にわたって、山の手と下町の中心地区を併合しているので、江戸の祭礼のうちでも最も華麗をきわめたのである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（同上）　　　我来也　京城の繁華の地区には窃盗が極めて多く、その出没すこぶる巧妙で、なかなか根絶することは出来ないのである。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼夷弾はどの位もって来て、どの辺の地区に抛げおとすのであろうか。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――司令部発表、南及び北関東地区、午前五時二十分、空襲警報発令！",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "破甲弾の投下準備は既に完了しあり」「貴官は東京湾上より北上して、まず品川駅を爆撃したる後、丸の内附近より上野駅附近にわたる間に存在する主要｜官公衙その他重要建造物を爆撃し、東京市東側地区の上空に進出すべし。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔霜枯れのトマトの気根〕宮沢賢治霜枯れのトマトの気根その熟れぬ青き実をとり手に裂かばさびしきにほひほのぼのとそらにのぼりて翔け行くは二価アルコホール落ちくるは黒雲のひら",
              "citation": {
                "source": "〔霜枯れのトマトの気根〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "首里の名主といはれて居る謝源は大広間の上座にうちくつろいで座つて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちくらの別莊でもなんでも貸してやるから、きつと病氣をなほさなければいけない。",
              "citation": {
                "source": "先生三人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
