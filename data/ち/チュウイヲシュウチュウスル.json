    "definitions": [
      {
        "index": 1,
        "gloss": "to concentrate one's attention",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
