    "definitions": [
      {
        "index": 1,
        "gloss": "Central China",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "中支に二年、南方に一年いて、病気でたおれて、伊東温泉で療養という事になったんだが、いま思うと、伊東温泉の六箇月が一ばん永かったような気がするな。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中支に二年、南方に一年いたが、いま思うとまるでもう遠い夢のようで、それにまた、兵隊として走り廻っているのが、この自分では無いような気がして、あの当時の事は、まったく語りたくない。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによると、二月二十五日の朝、田中支隊を乗せた汽車が待避線に着くと、香田小隊が将校斥候になって出発したが、その夜九時頃になって、その将校斥候から報告が来た。",
              "citation": {
                "source": "母親に憑る霊",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この話は田中支隊の戦況がまだ内地に達しない時で、その後戦況が判ってみると、すべて勇次郎の霊の云ったとおりであった。",
              "citation": {
                "source": "母親に憑る霊",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それきり顔を見せなくなったが、応召したのか一年ばかりたって中支から突然暑中見舞の葉書が来たことがある。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　中支からの復員の順位は抽籤できまったが、籤運がよくて一番船で帰ることになった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸大卒業後、半年ばかり教育総監部に勤務した後、漢口の中支那派遣隊司令部付となった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "中支空爆の記事を読んでゐると、私の血も湧く。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十六年の中支行きは、そのような訳で私にとっては初旅といっていいものである。",
              "citation": {
                "source": "母への追慕",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分は、滿洲に長く征っていて、それから中支に征き、眼をなくしたンです。",
              "citation": {
                "source": "おにおん倶樂部",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日華事変の間中を、中支で野戦に働いてゐた軍医上りで、年は案外にも、富岡と幾つも違はなかつたのだが、まだ、独身で、父の病院を手伝つてゐると云ふ事だつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この頃はやりの生めよ、ふやせよもいいけれど、私たちのところなんか、いろいろ影響が微妙で……ねえ」　一年半ばかり中支へ行っていた山崎は還って来てから、夫婦の間に子供のないのを頻りに苦にしはじめた。",
              "citation": {
                "source": "杉垣",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、現在、河北平野にある村落が、塵埃をかぶって地面にもぐってるに比べて、中支平野の村落は、ずっと地上に背を伸しているし、その屋背の曲線の美で人の目を楽しませるものも多い。",
              "citation": {
                "source": "北京・青島・村落",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "中支生活者豊島与志雄　杭州へ行った人は大抵、同地の芝原平三郎氏の存在に気付くであろう。",
              "citation": {
                "source": "中支生活者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "田中氏は中支への物資供給に主要な役目をも勤めながら、百貨店を通じて蘇州の民衆に働きかけ、その文化工作にも意を用いている。",
              "citation": {
                "source": "中支生活者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を転ずれば、中支の風光は日本のそれに甚だ似ている。",
              "citation": {
                "source": "中支生活者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、上野の不忍池を理想的に拡大し美化すれば、中支随一の名勝たる杭州西湖ともなるだろう。",
              "citation": {
                "source": "中支生活者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの母胎を、台湾や北支や中支に探ってみた。",
              "citation": {
                "source": "小説・評論集「文学母胎」後記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の病気は昭和十五年、私が皇軍慰問に中支に行って帰って来て、ある十二月の夜音楽会があって独唱するので、肉をたくさん食べたがあまりかまずに食した事をおぼえているが、その翌朝九時麹町の宅で腹痛がはじまり、早速三浦先生においでをいただいて御診察おねがいして、盲腸に似ているからとて、九段坂病院に入院した。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり深く立入つたことは喋れないが、事変後の支那、殊に北支などゝはやゝ趣を異にする中支の健全な発展は、たとへ如何なる中央機関ができたところで、これら現地で直接民衆に接触する人々の双肩にその全責任がかゝつてゐることは、私の信じて疑はないところである。",
              "citation": {
                "source": "私の従軍報告",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "中支に張られた欧米の根　私は中支の各地方で、出来る限り所謂欧米の権益なるものを調べてみた。",
              "citation": {
                "source": "私の従軍報告",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間、宿泊、交通、見学のプログラム、すべて向ふ委せで、われわれは殆んど客分の待遇を受け、重要な個所を見落さなかつた代り、個人的な印象を細かにノートする暇もなく、云はゞ、中支戦場の一般概念の注入に頭を費した期間であつた。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月二十日から三十日まで、楊州に止まつて、私は予定どほり、中支に於ける「隠れたる第一線」の実情を観察した。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "楊州地区は誠にこの問題について語るために誂へ向きの一例であると信じるから、私は今度の中支旅行の印象を誌すにあたつて、この地に於ける滞留十日の記録に重点をおくことにする。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "満洲、北支、中支と、殊勲を樹て続けの、この軍用鉄道の権威は、敵が外した路線材料を、何処へ匿して逃げたかをちやんと知つてゐるのである。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も思い出すことが出来るが、彼は小さな口の上に黒い鼻髭のある三十男で、目をしょっちゅうしばたたいていた。",
              "citation": {
                "source": "玄海灘密航",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "「子供が三人あるというけれど、みんなもう大きいちゅうことだから手もかかるまい」　祖父がこう言うと、祖母はすぐにそれを引きとって、「家の暮し向きはいいちゅうし、それに第一こんな田舎でなく町家だから、今までそこいらうろついて来たお前にはもって来いの縁だよ」　と言った。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "冒険｜救助作業　撮影監督のケンもカメラマンのダビットも、撮影ちゅうししてそばへとんできた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、ながい間、こうしてなにもかもわすれ、ただ実験にねっちゅうしていた。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ自分の有っている温かい情愛を堰き止めて、外へ出られないように仕向けるから、仕方なしにそうするのだ」「誰もそんな意地の悪い事をする人はいないじゃありませんか」「御前はしょっちゅうしているじゃないか」　細君は恨めしそうに健三を見た。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
