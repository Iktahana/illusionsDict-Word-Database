          "literary": [
            {
              "text": "いま道々聞けば、秀の浦とやらを殺害の嫌疑でお呼び立てじゃそうにござりまするが、わたしも二の丸様付きの腰元のなかでは人にそれと名まえを知られた秋楓、いかにも知恵比べいたそうではござりませぬか」「ほほう、なかなか強情なことを申さるるな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでもまだ右門と知恵比べすると申さるるか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが各国物理学者の知恵比べの焦点だったんだ。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は知恵比べをした。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この悪知恵比べ、最後の勝利を得るものは、両者のいずれであろうか。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "サロンでは知恵比べが始まっています。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱりアドロ彗星にくわれてしまうんじゃないかなあ」「けっきょく、ちえくらべさ。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、いつか『おうごんのとら』のとりっこで、ちえくらべをしたまほうはかせだよ。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしは、いつか、きみたちしょうねんたんていだんと、ちえくらべをしたまほうはかせだよ。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬすまれたら、このちえくらべは、きみたちのまけなのだ。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "このちえくらべは、しょうねんたんていだんのかちよ。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
