    },
    "definitions": [
      {
        "index": 1,
        "gloss": "molester",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "我れの如き悲しき痴漢、老いて人生の家郷を知らず、醉うて巷路に徘徊するもの、何所にまた有りや無しや。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの家の女中のひとりが午後十時ごろに外から帰って来る途中、横町の暗いところで例の痴漢に襲われかかったが、折よく巡査が巡回して来たので救われた。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかくにこの種の痴漢が出没するから婦人の夜間外出は注意しろと、町内の組合からも謄写版の通知書をまわして来たことがある。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "おん身がにくしんの兄はあまりに憔悴し、疾患し、酒亂のあしたに菊を摘まむとして敬虔無上の涙せきあへぬ痴漢である。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『わん、と啼いたら、犬だと思はう、彼の痴漢が。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "莚包と焼明を持った背の高い男は、また鵜を持った角顔の男の方を見て、「寺へ入って和尚のような真似をしておるが、あの痴漢のことじゃ、どんな用心をしておるかも判らん」　と云いかけたところで、艪を持っていた男が遮って、「鮎の用心なら知れたものじゃ、鮎の話は、まあ、舟へ乗ってからにしよう」　と云った。",
              "citation": {
                "source": "赤い土の壺",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これで門出の杯はすんだ、出かけよう、油断して痴漢を討もらすな」　それは舟乗りとなっていた男の声であった。",
              "citation": {
                "source": "赤い土の壺",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の友であつた間はそんな痴漢ぢやなかつた、して見りや発狂したのじや。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "田辺町に名高い○永とて不具の痴漢五十余歳で数年前死んだ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　駿馬痴漢を乗せて走るというが、それにしてもアノ美貌を誇る孔雀夫人が択りに択って面胞面の不男を対手にするとは余り物好き過ぎる。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かくなるうえは、老痴漢とてももう施すべきすべがなかったものとみえまして、なにゆえ敬四郎をさらいとったか、恐れ入って実を吐きました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの家の女中のひとりが午後十時ごろに外から帰って来る途中、横町の暗いところで例の痴漢に襲われかかったが、折りよく巡査が巡回して来たので救われた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本当にものの分らねえ鈍痴漢じゃねえか。",
              "citation": {
                "source": "世間師",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "速度の方が恐ろしい、茫然としたこの痴漢のような自分の中で、何が行われているのか私ももう知らない。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫が妻の辛苦を余処に見て安閑たるこそ人倫の罪にして恥ず可きのみならず、其表面を装うが如きは勇気なき痴漢と言う可し。",
              "citation": {
                "source": "新女大学",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よ其裁判の曖昧なる其処分の乱暴なる、其間に起れる流説の奇怪にして醜悪なる、世人をして殆ど仏国の陸軍部内は唯だ悪人と痴漢とを以て充満せらるるかを疑わしめたり。",
              "citation": {
                "source": "ドレフュー大疑獄とエミール・ゾーラ",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍隊の組織は悪人をして其凶暴を逞しくせしむること、他の社会よりも容易にして正義の人物をして痴漢と同様ならしむるの害や、亦他の社会に比して更に大也、何となれば陸軍部内は××の世界なれば也。",
              "citation": {
                "source": "ドレフュー大疑獄とエミール・ゾーラ",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾来予は心を潜めて、満村恭平の行状に注目し、その果して予が一夕の観察に悖らざる痴漢なりや否やを検査したり。",
              "citation": {
                "source": "開化の殺人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにことによったら泥棒ではなくって、店の常連の中の痴漢が一杯機嫌で若い人たちの部屋を覗きに来たのかもしれない」　と、主人が言った。",
              "citation": {
                "source": "宝石の序曲",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ来る前、星野社長はわざわざ、帆村の潔癖を保証したが、その話とはちがって、彼はとんでもない痴漢であった。",
              "citation": {
                "source": "什器破壊業事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこに立っている侍こそは、怨敵白河戸郷に味方をする、某という痴漢でござる！",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お吉へ答える暇も与えず、範之丞は憤怒の声鋭く、「黙れ痴漢！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい、どうして凍死するようなことになったのか、痴漢に襲われた様子もないし、自殺としては、動機も不明だし、他に方法もあった筈だ。",
              "citation": {
                "source": "死因の疑問",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで三人ですね」「若い女性ばかりを覘う痴漢射撃手です」と警部は、ムッとして思わぬことを言い放った。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし赤外線男のすることが、この辺の程度なら、それは悪戯小僧又は軽い痴漢みたいなもので、迷惑ではあるけれど、大して恐ろしいものではない。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼のような深山は、赤外線利用の技術を悪用して、それまでにも、人の寝室を密かに写真にとっては、打ち興じていたという痴漢です。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の聖人は今日の痴漢であった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗和によってボンクラな仁清が一大天才に変わったと解する者があったとしたら、それは度すべからざる痴漢だと私はいう。",
              "citation": {
                "source": "素人製陶本窯を築くべからず",
                "author": "――製陶上についてかつて前山久吉さんを激怒せしめた私のあやまち――",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍しくもねえ銀の平打ちかんざしじゃねえんですか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "またわが国の伝統的精神すなわちかんながらの道を疎外すべきではなかろうと思う。",
              "citation": {
                "source": "明治哲学界の回顧",
                "author": "結論――自分の立場",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
