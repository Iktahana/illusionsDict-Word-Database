[
  {
    "uuid": "a05d4be5-542e-529b-bd71-d60f1183d1e4",
    "entry": "痴漢",
    "reading": {
      "primary": "ちかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
