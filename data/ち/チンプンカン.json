        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「そんな珍糞漢糞の寝言は後廻しにして、われわれはいま、冷静且つ果断に事件の心臓部を突破せにゃならないんだッ。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "身寄りも知辺もない一人者で、時々ブラリと外へ出るほかは、珍糞漢糞な本ばかり読んでますよ」「しめたッ」　ガラッ八は、それだけ聞くと、横っ飛びに徳蔵稲荷へ駆け付けました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鈴を慕う女",
                "note": "青空文庫"
              }
            },
            {
              "text": "身寄も知邊もない一人者で、時々ブラリと外へ出る外は、珍糞漢糞な本ばかり讀んでますよ」「しめたツ」　ガラツ八は、それだけ聞くと、横つ飛に徳藏稻荷へ驅け付けました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鈴を慕ふ女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ぼくにはちんぷんかんぷんです。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだかちんぷんかんなことを言つてるでせう、わたし。",
              "citation": {
                "source": "犬の威嚴",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せっかくの馬さんのお話ですが、私にはなんのことやらちんぷんかんぷんですわ。",
              "citation": {
                "source": "夢がたり",
                "author": "TO, CHEVO NE BYLO",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターに関しては天才的だったウォズニアックにとっても、マイクロコンピューターはゲテ物、要するにちんぷんかんぷんだったのである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲の会話はウォズニアックにとって、ちんぷんかんぷんだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「始めの方は何だか意味のある言葉が続いているが、途中からちんぷんかんぷんに変ってしまう」　それからもう一つ、感想を持った。",
              "citation": {
                "source": "烏啼天駆シリーズ・４　暗号の役割",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちんぷんかんぷんのねごとはやめさせて、となりの部屋部屋を、どんどん洗ってみようじゃありませんか。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、土掘りの名人のもぐらのことを、ぜひ勉強して、出来れば、もぐら式の地下戦車をこしらえてみたいなあ」　一郎のいうことは、一郎にはわかっているが、お百姓さんには、ちんぷんかんぷんだった。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どつちもちんぷんかんぷんである。",
              "citation": {
                "source": "“現代風俗”に就いて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸太郎　俺には又、将棋って奴はちんぷんかんぷんなんでね。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "「字は読めないし、それに半分じゃ、しようがないが、これでもあのおじさんがいったように、これが世界的な莫大な富と関係があるものかなあ」　せっかくもらったが、これでは春木少年にとってちんぷんかんぷんで、わけが分らなかった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにが欲しいんだか、私にはちんぷんかんぷんだ」　老人は、いよいよ軽蔑をこめていう。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一番上へ行けば、海の中が見えますから、魚も見えるわけです」「なんだか君のいうことは、ちんぷんかんぷんで、わけがわからないね」　と、僕はとうとう、さじをなげてしまった。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その話は、茶の間へ入って、博士の前におかれた湯呑の中の茶が冷えるまでもつづいたが、隆夫の母親には、博士の話すことがらの内容が、ちんぷんかんぷんで、さっぱり分からなかった。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、つい彼にばかり質問する気になったが、なにをきいても、秀吉の答えは、ちんぷんかんでありました。",
              "citation": {
                "source": "天女とお化け",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "『イヴァン・ペトローヴィチ　キョウ　キュウセイ、ヌグ　サシズマツ、ツウシキ　カヨウビ』　とこんなぐあいにその電報には『ツウシキ』だとか、更にもっとちんぷんかんぷんな『ヌグ』だとかいう字が打ってあった。",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "その言葉ははっきり聞きとれたが、ちんぷんかんぷんでなんのことやらわからなかった。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもまっさきにイワン・イワーヌィチが目をさまし、すぐに、おばさんかねこのところへ近づいて、首をのばし、あいかわらずちんぷんかんぷんなことを、熱心に、一生けんめいしゃべり始めた。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せっかくおかしいただいたのですが、もくじをみても、ちんぷんかんぷんで、なにがかいてあるのか、よくわかりませんでした。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもこんなのちんぷんかんぷんよ。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリス　おっしゃることがわからなくてよ、ちんぷんかんぷん！",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それもちんぷんかんぷんで」「お前は顏を見られなかつたのか」「見られたかも知れませんね。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "母娘巡禮",
                "note": "青空文庫"
              }
            },
            {
              "text": "処女詩集『邪宗門』をひらいて読んでも、ちんぷんかんぷん何を表象してあるのか解らなかった。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "『邪宗門』がちんぷんかんぷん解らなくとも、えたいの知れぬ麻薬入りの活字があの中に封じこめられていることだけは、今日の私にも解るのである。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく、家政婦さんがきいてくれはって、やれやれ思いましたのどすけれど、なにが、なにやら、ちんぷんかんぷん、わけ、わかりしまへんのやわ」「それ、一体、何のこと」「なんのことも、かんのことも、あらしません。",
              "citation": {
                "source": "おもしろい話",
                "author": "畔柳二美",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、欧米人輩には勿論ちんぷんかんぷんだ。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあくびで、二人の経綸が興をさまし、南条が苦々しい面に軽蔑を浮べて、こちらを向き直るところを、がんりきがまた思いきって両手を差し上げて伸びを打ち、「先生、そんな英雄豪傑のちんぷんかんぷんは、わっしどもにゃあわからねえ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
