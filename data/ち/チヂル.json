        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ひねしなびて四尺七寸の小さな体が、一層縮る想いがした。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "誦経が始ると一同は黙って経の終るのを待っていたが、後から吹きつけて来る風の寒さに、定雄は長い経の早く縮ることばかりを願ってやまなかった。",
              "citation": {
                "source": "比叡",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "』アンドレイ、エヒミチは肩を縮る。",
              "citation": {
                "source": "六號室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "左様あれば縮る所兄弟中もみなよくなりて果は父母様の御仕合、また子供が見習い候えば子孫のためこれほど目出度い事はないではないか〔聖賢の心地、家庭における松陰かくの如し〕。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "新見は益々身が縮る様に思うた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が落ちると、北風の悲鳴と海鳴りが、急にいちぢるしく唸りはじめてくるのだつた。",
              "citation": {
                "source": "蒼茫夢",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
