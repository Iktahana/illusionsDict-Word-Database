        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大事なプレゼンの前日に風邪をひいてしまい、調子が狂ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "相手チームの予想外の戦術に、うちの選手たちは一時、調子が狂ったように見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "練習中に集中力が途切れて、リズムの調子が狂ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
