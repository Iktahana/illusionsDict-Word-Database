    "definitions": [
      {
        "index": 1,
        "gloss": "calm, cool, and collected",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
