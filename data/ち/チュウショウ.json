[
  {
    "uuid": "ef3b7190-1095-5904-9e0e-b945667a6392",
    "entry": "中傷",
    "reading": {
      "primary": "ちゅうしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
