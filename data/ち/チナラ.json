        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "葉の落ちて只黒き幹のぬくぬくとあまた立ちならぶ様のさびしも　初句『葉の落ちて』の極めて自然な詞つきに、はや淋しい声を感ぜられる。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅かの相違であるが『あまた立ちならぶ様のさびしも』と詞に淀みのある云い方が自然に作者の心持を現わして居る。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の横顔が官衙と銀行と、店舗のたちならんだ中央街の支那ホテルのまえまでくると細かく顫えた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれはまた、おまえたちならきっと何かにしなけぁ済まないものと思ってたんだ。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まかり間違うと、鼻持ちならぬキザな虚栄の詠歎に似るおそれもあり、または、呆れるばかりに図々しい面の皮千枚張りの詭弁、または、淫祠邪教のお筆先、または、ほら吹き山師の救国政治談にさえ堕する危険無しとしない。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱いところを、といかにも鼻持ちならぬ謂わば粋人の口調を、真似たつもりで澄ましていた。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本道の兩側に三丁ほど茅葺の家が立ちならんでゐるだけであつたのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本道の両側に三丁ほど茅葺の家が立ちならんでいるだけであったのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓という窓には眼隠しの板が張ってあって、何軒となく立ちならんでいる妓楼は、ただ真黒なものの高低の連なりにすぎないけれども、そのどの家からも、女のはしゃぎきった、すさんだ声が手に取るように聞こえていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "苅入れを終つた燕麥畑の畦に添うて、すく／＼と丈け高く立ちならんでゐるその木並みは、ニセコアン岳に沈んで行かうとする眞紅な夕陽の光を受けて、ねぼけたやうな緑色で深い空の色から自分自身をかぼそく區切る。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京うちなら、郡部でも、私は訪ねて行つて、飮まうと思ふ。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士たちは、ひるがえる旗を持ち、きらめく銃剣を持って、立ちならびました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、だれにも見られないように、みんな、あたしの前に立っていておくれ」　そこで、侍女たちは、お姫さまの前に立ちならんで、スカートのはしをつまんで、ひろげました。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍女たちは、みんな、お姫さまの前に立ちならびました。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "左側にはハツカネズミの紳士たちが立ちならんでいて、前足でひげをなでていました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちなら、一升さげて友人の宅へ行ったら、それは友人と一緒にたいらげる事にきめてしまっていて、また友人のほうでも、それは当然の事と思っているのだ。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし来た、組打ちならば、負けやしません。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな、櫓太鼓みたいなものを、めった矢鱈に打ちならすような音楽でもあったら、いまの僕のいらいらした気持にぴったり来るのかも知れない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "趣味でキリストごっこなんかに、ふけっていやがって、鼻持ちならない深刻ぶった臭い言葉ばかり並べて、そうして本当は、ただちょっと気取ったエゴイストじゃないか。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえたちなら、とびあがってなくな。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころも、芭蕉の辻が仙台の中心という事になっていて、なかなかハイカラな洋風の建築物が立ちならんではいたが、でも、繁華な点では、すでに東一番丁に到底かなわなくなっていた。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻持ちならん、と永い間、私はこの句を敬遠してゐたのだが、いま、いや、さうぢやないと思ひ直した。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」母堂は、品よく笑ひながら、「私たちも、ごらんのとほりお金持ではございませぬし、ことごとしい式などは、かへつて当惑するやうなもので、ただ、あなたおひとり、愛情と、職業に対する熱意さへ、お持ちならば、それで私たち、結構でございます。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちなら、侘びしくても、本を読んだり、景色を眺めたりして、幾分それをまぎらかすことが出来るけれど、新ちゃんには、それができないんだ。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、鼻持ちならぬ美文の大家です。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年の相変らずの思わせぶりが、次第に鼻持ちならなく感ぜられて来たのである。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変らず鼻持ちならねえ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちなら蜂一匹だって、ふところへはいったら、七転八倒の大騒ぎを演ぜざるを得ないのに、この将軍は、敵の大部隊を全部ふところにいれて、これでよし、と言っている。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだ、えらいでないか貴様たちなら何とする？",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小稲、小幾、重子など、狂言｜囃子の女ども、楽屋口より出で来りて、はらりと舞台に立ちならべる、大方あかり消したれば、手に手に白と赤との小提灯、「て」「り」「は」と書けるを提げたり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
