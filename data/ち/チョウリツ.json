[
  {
    "uuid": "00bb679f-cc7f-57a6-83b7-14818e2919d6",
    "entry": "調律",
    "reading": {
      "primary": "ちょうりつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
