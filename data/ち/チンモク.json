    "definitions": [
      {
        "index": 1,
        "gloss": "silence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やはり私は、沈黙していなければならぬ。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神は絶対の沈黙者なり、情なくまた非情なしと。",
              "citation": {
                "source": "地上組織",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが夏の真昼の沈黙や、田舎の静寂さやを、麦の穂の動きにかけて、一語の重複した表象をしているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "句の表現するものは、夏の炎熱の沈黙の中で、地球の廻転する時劫の音を、牡丹の幻覚から聴いてるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その卓の上に、鮮魚の冷たい鮓が、静かに、ひっそりと、沈黙して置いてあるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "万象の死んでる沈黙の中で、暗い台所の一隅に、こうした鮓がならされているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ寄り集って手を握り、互に人の悲しみを感じながら、憐れに沈黙する外はないのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "沈黙してたたずんでいると、鶯鳴き、ホトトギス鳴き、カケスが鳴き、眼覚めた鳥が、一せいに声を合せて鳴き立てる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎが読み終つた時、長い、深い、沈黙があるだけだつた。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "沈黙した三人はしばらく恨めしき池を見やって立ってた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は学校へ往ってしまえばそれでよいけど、民さんは跡でどうなるだろうか」　不図そう思って、そっと民子の方を見ると、お増が枝豆をあさってる後に、民子はうつむいて膝の上に襷をこねくりつつ沈黙している。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "万象が急に静止し、底の知れない沈黙が横たわった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体は沈黙の内でなくては思量せられないはずの事を、言語に現わし色彩に現わすのだ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はユーストンの地下鉄の乗換場附近にある玄関に、日章旗を交錯した日本料理店胡月の卓子で、外交官の松岡、画家の山中、トンテム・ハム・コートの伊太利料理店の主人と暗い東洋風の部屋で、日本食の晩餐後お互に深い沈黙に陥っていた。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "文芸家協会は作品の受取を拒否し、サロンはその撤回をロダンさんに迫ったのですが、ロダンさんは沈黙して自分の意見を発表することはなさらなかったのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は妾の沈黙の裡に、悪い幻影を掬って、それを追求したのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "リー・シー・ツワンは広東にあって時態を先見して沈黙してしまった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞬間人々は恐ろしい沈黙に陥るのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は沈黙のうちに人間の傾斜しすぎた賭博心と、彼のしどろもどろの現状が今なお正装した外観のなかに采配を振るのを感じた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、かの女は冷やかにこたえると、そのまま沈黙して受話器を耳から離さなかった。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ミサコは歳入のたらない夫の沈黙からはなれると、階下に彼女をおとずれた人々に居留守をつかって裏口から銀座にあらわれた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯時に近所の家から「子供の時間」の唱歌などが聞こえて来ても、宅の機械は固く沈黙を守って冷やかにわれわれの食卓を見下ろしているだけであった。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがやっとこの頃になって久し振りのその沈黙を破って再び元気よくわれわれに話しかけることになった。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、曠野の沈黙に吸われるようにすぐどこかへ消えてしまった。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども富沢はその夕暗と沈黙の奥で誰かがじっと息をこらして聴き耳をたてているのを感じた。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは変につらい沈黙でした。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
