    "definitions": [
      {
        "index": 1,
        "gloss": "court ladies of the middle rank serving in the inner palace (Heian period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "五百はすぐに中臈にせられて、殿様｜附と定まり、同時に奥方｜祐筆を兼ねた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが一躍して中臈を贏ち得たのは破格である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "中臈は奥方附であると、奥方の身辺に奉仕して、種々の用事を弁ずるものである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤堂家でも他家と同じように、中臈は三室位に分たれた部屋に住んで、女｜二人を使った。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "勤仕いまだ一年に満たぬのに、天保二年の元日には中臈｜頭に進められた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "中臈頭はただ一人しか置かれぬ役で、通例二十四、五歳の女が勤める。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡野は順承附の中臈になった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "老女、中臈、腰元、端女まで、おびただしい数の女、女、女。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
