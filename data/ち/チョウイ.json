[
  {
    "uuid": "ab7277a9-00cf-5ed4-a13a-f5d71e608f71",
    "entry": "潮位",
    "reading": {
      "primary": "ちょうい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tide level",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "東上州は東京湾の中等潮位から僅に五十米の高さを有するに過ぎない平野ではあるが、試に路傍に立って南方武蔵野の平原に眼を放つと、低い地平線上には遥として展望を遮ぎる何物もない。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明らかに川に通じている、というのもボートが二｜艘あり、前方は格子状になっており、今の潮位であれば簡単にボートを浮かべられる。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつれ、鎌倉中の人口の潮位も激減していよう。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、干潮の最頂期を境として、潮位はまたすぐ、上げ潮へ変ってゆく。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「爺さんお光が――お光ちょう、お光ちょうい」のび上って叫べば、万作もころげ出でて木にすがり泣声あげて「お光ちょうい、おー光ちょうい」と叫んで見ても、舟は次第次第に陸を離れて、果は櫓の音も聞えぬ。",
              "citation": {
                "source": "漁師の娘",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "内のお光ちょうい」。",
              "citation": {
                "source": "漁師の娘",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
