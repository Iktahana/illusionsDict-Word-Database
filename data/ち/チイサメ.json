        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのため政府はそれらの囚人を送るにはあまり適当でない、小さめの船を使わざるを得なかった。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さめなきりっとした愛らしい口元も、真面目に正面を見ている力のこもった眼差も。",
              "citation": {
                "source": "キュリー夫人の命の焔",
                "author": "――彼女を不死にするものは何か、",
                "note": "青空文庫"
              }
            },
            {
              "text": "外から歸つたばかりの、晴着らしい赤い帶、頬が涙に濡れて、小さめの顏が、本當に花のやうに匂ひさうです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "五月人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムロというのは禿だから、頭を小さめにした毛髪の短い子供、切り髪にした童子にほかならない。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひき緊った小さめの顔の、頬がこけ、高い鼻がいっそう高くみえる。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "魅力的に濃いコーヒーは、端正に小さめのカップで出て来た。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "受け皿に載った小さめのカップを、彼は手もとに引き寄せた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがひとしくこの中庸をはずれるなら、むしろ大きすぎるよりは小さめなのがよいなどとは、武人に対しては望みたくない。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
