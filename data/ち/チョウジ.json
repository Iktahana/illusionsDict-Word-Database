      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "clove (Syzygium aromaticum)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "芯の先には大きな丁子ができて、もぐさのように燃えていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶすぶすと臭い香いを立てて燃える丁子の紅い火だけを残して灯は消えてしまった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙ったい暗黒の中に丁子だけがかっちりと燃え残っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」十四「中には諺にも申します、一口｜茄子に食てやるは可惜もの、勿体ないと、神棚へ上げて燈明の燈心を殖しまして、ほほう、茄子ほどな丁子が立った、と大層縁起がっていたのもありまするそうでござりますが、さあ、それが大地震の前兆だとなると、不気味千万。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　この古行燈が、仇も情も、赤くこぼれた丁子のごとく、煤の中に色を籠めて消えずにいて、それが、針の穴を通して、不意に口を利いたような女の声には、松崎もぎょっとした。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒斜子に丁子巴の三つ紋の羽織、紺の無地献上博多の帯腰すっきりと、片手を懐に、裄短な袖を投げた風采は、丈高く痩せぎすな肌に粋である。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "外へ、その人数を吐出したので、風が透いて、すっきり透明になって、行儀よく乗合の膝だけは揃いながら、思い思いに捻向いて、硝子戸から覗く中に、片足膝の上へ投げて、丁子巴の羽織の袖を組合わせて、茶のその中折を額深く、ふらふら坐眠りをしていたらしい人物は、酒井俊蔵であった。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "隔ては一重で、つい目の前の、丁子巴の紋を見ると、莞爾々々と笑いかけて、黙って引込むと、またばたばたばた。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔も真赤に一面の火になったが、遥かに小さく、ちらちらと、ただやっぱり物見の松の梢の処に、丁子頭が揺れるように見て、気が静ると、坊主も猿も影も無い。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "硯は赤間石のチヨイとしたるのなれど、墨は丁子墨なり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋民の小学校にありし頃よく用ひし事あり、丁子と云ふ名はよけれど、之を硯に擦るに、恰も軽石に踵の垢を磨く時の如き異様の音す。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "芬と、麝香の薫のする、金襴の袋を解いて、長刀を、この乳の下へ、平当てにヒヤリと、また芬と、丁子の香がしましたのです。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄の灰色の世界は、今や、濡れ光るサフラン色、硫黄色、薔薇色、丁子色、朱色、土耳古玉色、オレンジ色、群青、菫色――凡て、繻子の光沢を帯びた・其等の・目も眩む色彩に染上げられた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、あとの品はみな売りはらって、びゃくだんと、にっけいと、しょうがと、はっかと、丁子香とを買い入れました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして木立ちの代わりに安価な八つ手や丁子のようなものを垣根のすそに植え、それを遠い地平線を限る常緑樹林の代用として冬枯れの荒涼を緩和するほかはなかった。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには丁子の花のような匂がそこはかとしていた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "因ってその不浄を捨てに行く筥を奪い嘗るに、丁子の煮汁を小便、野老に香を合せ大きな筆管を通して大便に擬しあったので、その用意の細かに感じ、いかでかこの人に会わずしてはやみなんと思い迷うて焦れ死んだと見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の香が丁子の様だからイタリーでジロフリエル、英国で中世ジロフル、共に丁子花の義だ。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "チョーサーの詩などにある通り、十四世紀頃専ら酒を匂はし、又、料理にも高価の丁子に代用した。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "吐息の合間合間に丁子の香りがした。",
              "citation": {
                "source": "坂道の孤独参昧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこの生垣のうちから丁子の香りが漂ふて来た。",
              "citation": {
                "source": "坂道の孤独参昧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "片膝を座蒲団の上に突いて、灯心を掻き立てたとき、花のような丁子がぱたりと朱塗の台に落ちた。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こりゃべっぴんのにおいがするようですが、なんていう髪油でしょうかね」「次から次へ、よくとんきょう口がきけるやつだな、これが有名な古梅園の丁子油じゃねえか」「へへえ、この油が丁子油でござんすか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この髷の都ぶりに結いあげているところから察して、たぶんそのほうが手がけた品じゃろうと、かく夜中わざわざ詮議に参ったが、覚えはないか」　受け取って、丁子油のにおいをかいでいたようでしたが、名人の慧眼やまさに的中――。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "においをかいでみましたら、娘が好んで日ごろ使っておりました丁子油の髪油がかおりましたゆえ、こりゃ、どっちにしてもただごとではあるまいというので、急に騒ぎだしましてな、所々ほうぼうと人を派して、だんだんと捜すうちに、あろうことかあるまいことか、深川の先で死体となって揚がったのでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、なんじゃな、あれなる黒ねこが、髪の毛をはぎとったのも、そちはどこでとられたか覚えもあるまいが、生前娘がかわいがっていたゆえ、丁子油のにおいから、畜生ながらもだいじにしてくれた人の面影を慕うて、人形とも知らずにとびついたのじゃな」「おそらくそうでござりましょう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、もうこの丁子油の髪の毛も用がねえ品だから、ついでにねこへも供養させてやるぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こういわれると、ちょんさんはくやしがって、負けずに弟の名前を呼んで、からかい返してやろうとしましたが、「ちょうにん、ちょうにん、ちょうじゅうろう、まんまる入道、ひら入道、せいたか入道、へいがのこ、いっちょうぎりの、ちょうぎりの。",
              "citation": {
                "source": "長い名",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやはや」と重太夫は隣りにいる浜岡図書と、望月吉太夫に向って苦笑した、「おだれどのに仕上げたのはよいが、少し薬がききすぎたようです」「しかし御家のためにはちょうじょう」　浜岡図書がそう囁いたとき、光辰はべそをかいたような顔で民部に云った。",
              "citation": {
                "source": "若き日の摂津守",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
