[
  {
    "uuid": "c071f17b-df38-56f1-8cdc-27d20dca7401",
    "entry": "丁子",
    "reading": {
      "primary": "ちょうじ",
      "alternatives": [
        "チョウジ"
      ],
      "is_heteronym": false
    },
    "grammar": {
