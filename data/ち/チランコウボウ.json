    "definitions": [
      {
        "index": 1,
        "gloss": "nation's times of peace and war, rise and fall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
