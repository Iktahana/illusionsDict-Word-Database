[
  {
    "uuid": "e1f28ef6-3792-5d66-9a0a-cbed81803e46",
    "entry": "力強い",
    "reading": {
      "primary": "ちからづよい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
