    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ceremony of fitting child with a hakama",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "七五三のお祝いとして、息子に着袴の儀式を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "伝統的な着袴の儀式では、子供の成長を願う様々な作法がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "着袴の写真は、家族にとって大切な思い出となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "人形使　笙篳篥が、紋着袴だ。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に家光の着袴の式が挙げられる際だったので、これを吉事としてそれより銅山は幕府の直轄となった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうせ――どうせ」　斯う思って居るうちにちゃっこい人を馬鹿にした様な涙が、ポロポロと意気地なくこぼれた。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
