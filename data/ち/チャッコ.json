          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "コールセンターでは、常に大量の着呼を処理している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "PBXシステムが着呼を自動的に空いているオペレーターに振り分ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ただいま着呼が集中しており、お電話がつながりにくくなっております」とアナウンスが流れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「どうせ――どうせ」　斯う思って居るうちにちゃっこい人を馬鹿にした様な涙が、ポロポロと意気地なくこぼれた。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
