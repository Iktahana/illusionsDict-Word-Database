    },
    "definitions": [
      {
        "index": 1,
        "gloss": "prompt answer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから話は直答だ。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「当藩財政の改革に当って数々の尽力、過分に思うぞ」「は、は――」「直答許す、仔細申述べよ」　浅二郎は僅かに面をあげた。",
              "citation": {
                "source": "入婿十万両",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お言葉に甘え御直答申上げまする、何分にも無能鈍才の私、このたびの大役とうてい勤まるところにはござりませぬ。",
              "citation": {
                "source": "入婿十万両",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "側の貴族が「よろしい」と答えたが、エルナンド・ピサロは鄭重にインカの直答を促した。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも柳営の出入り自由で、将軍家と会う時も、笹の間かお駕台とよぶ所で、直問直答のならわしである。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "曹真は、わがことのように誇って、「王双、直答申しあげよ」　と、促した。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ宮方への味方を誓ってまいっただけのことか」「いえ」　と、吉致が直答した。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
