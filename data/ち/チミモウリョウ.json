[
  {
    "uuid": "b859067f-2cca-5a08-9c07-7cf4150d6fd7",
    "entry": "魑魅魍魎",
    "reading": {
      "primary": "ちみもうりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
