[
  {
    "uuid": "03c4b681-2425-58d5-b6f1-9f8a1d154302",
    "entry": "着眼",
    "reading": {
      "primary": "ちゃくがん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "focusing on",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あなたの大好きな魯迅先生は、所謂「革命」に依る民衆の幸福の可能性を懐疑し、まず民衆の啓蒙に着眼しました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高原地方や山麓の焼土に多く生棲していて、特に夏の日中に飛翔する小虫を捉えた着眼点にある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは甲と乙とで着眼点がちがうためだと云えばそれまでである。",
              "citation": {
                "source": "観点と距離",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は前途に向かいて着眼の鋭く、細かに、きびしきほど、背後には全く放心せるもののごとし。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、だれか一人のパイオニアーがその現象に着眼して山開きのつるはしをふるって登山道がつき始めると、そうすると、始めて我れも我れもとそのふもとに押しかけるようになるのである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その番号から運転手の名前を探り出して、鼻薬を使いながら未亡人の行先を尋ねてみると、私の着眼が一々的中している事が裏書きされて来た。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯時代に於て斯着眼は頗る聡明であると云わねばならぬ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴君がそれに着眼されたるは流石です。",
              "citation": {
                "source": "蒲原有明に帰れ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ事業を始めるのに着眼点も眼新らしいし精力的でもある。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅順は落ちると云う時期に、身上の有るだけを酒にして、漁師仲間を大連へ送る舟の底積にして乗り出すと云うのは、着眼が好かったよ。",
              "citation": {
                "source": "鼠坂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人の標準とか題したる某君の国家主義論は、推断｜陋劣、着眼浅薄、由来皮相の国家主義を、弥益皮相に述べ来りたる所、稚気｜紛として近づく可からず候。",
              "citation": {
                "source": "渋民村より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ職工以外の人間に着眼されなければならぬ順序になったが、しかしどこから見当を附けていいか、わからないらしかった。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "話がすこし脱線したが、其日庵主は玄洋社を離脱してから海外貿易に着眼し、上海や香港あたりを馳けまわって具に辛酸を嘗めた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "近来外国の芸術家、もしくは芸術愛好者たちが日本の「能」に着眼して、色々な研究をしていると聞いた。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそこまではＡの着眼が百二十パーセントに的中していたのですから、先ず先ず大成功と云ってもよかったのですが、それから先がどうもイケませんでした。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう云ふ場合に捜索をするには、「どう云ふ事が行はれたか」と云ふよりは寧ろ「行はれた事の中で、どれだけが前例のない事か」と云ふところに着眼しなくては行けない。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを日本画畑の吉岡氏が早くもそこに着眼しその方法の進歩性を採用したといふことは皮肉な現象でもある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "是が一種の着眼點であつて、率意派からして熟境に入つたのである。",
              "citation": {
                "source": "北派の書論",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "三種四種をかく解析せる標準は、一には三種に屬する記事が多くは倭より郡に至る方面より着眼し、四種に屬する記事が多くは郡より倭に至る方面より着眼せるの別あるに由る。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日から見ると、甚だ当り前のことであるが、とにかく、私は此所へ着眼して一意専心に写生を研究しました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "実物写生ということのはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "」小僧「私の献上しようと申しますのはデスナ、我国の兵の身長と敵兵の身長との甚だしい相違に着眼したのです。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "着眼は良かったが、まだまだ時勢の真相を把握するの明がなかった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "国家総動員は国民の力を最も合理的に綜合的に運用する事が第一の着眼である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオン最大の兵力（約四十五万）を動かした一八一二年ロシヤ遠征の際の作戦は、なるべく国境近く決戦を強行して不毛の地に侵入する不利を避くる事に根本着眼が置かれた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう細かい生活の実況であるにもかかわらず、総体としてラジオが益々大勢にきかれるようになって来ることには、一方で、出版物の高騰、書籍購買力の低下と伴い、一方では確に放送局で着眼しているとおりニュース価値の増大にあるだろうと思う。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "全国的な米の不足に対して、都会も消費者としての側からばかりでなく、せめては馬鈴薯をつくるなりして、困難を凌いでゆく一つの感情に結ばれて行こうという着眼は理解されるけれども、一々の家庭の現実について見ると、そこに悲しき頬笑みの浮ぶ事情もあるのである。",
              "citation": {
                "source": "昔を今に",
                "author": "――なすよしもなき馬鈴薯と綿――",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々はただ彼に於て客観の方向への着眼を発見するだけであって、たとえこの着眼に於て範疇の意味が重大な変化を受けていることは明らかであるとしても、それによってはまだ吾々の探求に適わしい事例を発見することは出来ないであろう。",
              "citation": {
                "source": "範疇としての空間に就いて",
                "author": "――之は一つの習作である――",
                "note": "青空文庫"
              }
            },
            {
              "text": "であるから範疇を客観に於て求めるという着眼は、吾々をして認識論的範疇を去って、存在論的範疇へと推し進ませずには置かないわけである。",
              "citation": {
                "source": "範疇としての空間に就いて",
                "author": "――之は一つの習作である――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
