  {
    "uuid": "3f9795fb-ce70-5d44-b7d7-676b59101608",
    "entry": "着岸",
    "reading": {
      "primary": "ちゃくがん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "reaching the shore",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "併し、なるべくならば、着岸以前に逐つ払ふのが、上分別である。",
              "citation": {
                "source": "妣が国へ・常世へ",
                "author": "異郷意識の起伏",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ち）と（ち′）とは合体して、一つのうけひの形式になつてくるのであるが、（か）は唐崎着岸までの苦労が其に当る。",
              "citation": {
                "source": "愛護若",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここ五稜廓に凝集される徳川の過去も、旭川に集約された明治の既往も、このうるわしい光景のなかにいつかけしとんで、着岸の日のあの望郷の想念を、このうるわしい光景のなかに、私はほしいままにする。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前六時半、カントンへ着岸す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前七時、木曜島に着岸す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "多数の船舶をして自在に着岸せしむ。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに小河をさかのぼること数マイルにして、市の中央に着岸す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時、ダーバン港に着岸す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "着岸後、歩を市中に散ずるに、日曜にて諸店を閉鎖す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "正午十二時、ジゲルミューレンに着岸す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後三時、スペイン港ラ・コルニャに着岸す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝七時、船モンテビデオ港に着岸す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "早朝六時、メキシコ国サリナクルスに着岸す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "大波が数日続くと、天気が良くてもトリガーセン島に着岸できない。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
