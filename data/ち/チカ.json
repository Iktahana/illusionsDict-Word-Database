    "definitions": [
      {
        "index": 1,
        "gloss": "underground",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "地下鐵道にてひとり來りて地下鐵道の青き歩廊をさまよひつ君待ちかねて悲しめど君が夢には無きものをなに幻影の後尾燈空洞に暗きトンネルの壁に映りて消え行けり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「地下鐵道にて」「昨日にまさる戀しさの」等凡て昭和五――七年の作。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下から中央階段を降りようとする途中で窓越しに東を見ると、地下鉄ビルの照明が見える。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜の午後に谷中へ行ってみると寛永寺坂に地下鉄の停車場が出来たりしてだいぶ昔と様子がちがっている。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギラギラする光の中から、地下室の監房のような船室へ、いきなり飛び込んだ彼は、習慣に信頼して、ズカズカと皿箱をとりに奥へ踏み込んだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野へついて地下室の大阪料理で夕食を食つた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしないと、おしまひには米や大根を地下室の棚で作らなければならない事になるかも知れない。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森から乗った寝台車の明け方近い夢に、地下室のような処でひどい地震を感じた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい交通機関、例えば地下鉄や高架線が開通すると、誰よりも先に乗ってみないと気のすまないという人がある。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい近ごろ、上野公園西郷銅像の踏んばった脚の下あたりの地下に停車場が出来て、そこから成田行、千葉行の電車が出るようになった。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある暖かい日曜に自分もとうとう京成電車上野駅地下道の入口を潜った。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "市中の地下鉄と違って線路が無暗に彎曲しているようである。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピタゴラスはイタリーで長い間地下室に籠っていた後に痩せ衰えて骸骨のようになって出て来た。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下室にいた間は母にたのんで現世の出来事に関する詳細なノートをとって、それを届けてもらって読んでいたという話も伝えられている。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下の歪みの程度を測知する事はある程度までは可能なるべく、また主なる第二次原因を知る事も可能なるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "具体的に云えば地辷り等がある限界内に止まれば、それだけにて止むも、少しにてもこれを超ゆれば他の弱点の破壊を誘起して更に大なる変動を起す事もあるべく、その際如何なる弱点が誘発さるるやはまた偶然的なる地下の局部的構造によると考えらる。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが皺曲や断層やまた地下熔岩の迸出によって生じた脈状あるいは塊状の夾雑物によって複雑な構造物を形成している。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下室の物置部屋へ行く隧道が著しい反響を示すことは彼の『音響学』に書いてある。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下室の中に作った天秤室の空気を乾かすのに、毛布を使ったりしたところにレーリーの面目が現われている。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇一年にロンドンのチューブ地下鉄道が開設されたが、このために家が振動して困るという苦情が出たので、政府はそのために調査委員を設け、レーリーが委員長になった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから帰宿の途中、地下鉄の昇降器の中で卒倒したが、その時はすぐに回復した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧騒の声が地下室に充ちて向き合っての話声も聞取れなくなった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまらない事ではあるが、拘留された俘虜達が脱走を企てて地下に隧道を掘っている場面がある、あの掘り出した多量な土を人目にふれずに一体どこへ始末したか、全く奇蹟的で少なくも物質不滅を信ずる科学者には諒解出来ない。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下電車鉄道の衛生問題　地下鉄道で長い間｜隧道内の空気を呼吸するのは衛生上有害ではないかという事を近頃ニューヨークで調査した。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "プレトリアという所に近い採掘場で地下十八フィートの穴から見出された。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年二月四日『東京朝日新聞』）　　　　　　　　　六十四　　　　　　煤煙問題　ロンドン地下電鉄会社の発電所で焚く石炭の煙がウェストミンスターの町へ掛かって損害を与えるというので、同市会から会社を相手取って訴訟を起した。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで或る街の深夜に、ぐでぐでに醉つて死場所を探してゐる不幸な紳士が、場末の薄暗い地下室で、チャップリンの扮してゐる乞食ルンペンと邂逅する。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹光る地面に竹が生え、青竹が生え、地下には竹の根が生え、根がしだいにほそらみ、根の先より繊毛が生え、かすかにけぶる繊毛が生え、かすかにふるえ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自棄のない詩は神の詩か凡人の詩かそのどつちかと僕が決めたげます",
              "citation": {
                "source": "（テンピにかけて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "東雲ちかい汽車の寢臺で友よ　安らかに眠れ。",
              "citation": {
                "source": "別れ",
                "author": "旅の記念として、室生犀星に",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
