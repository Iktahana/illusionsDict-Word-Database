[
  {
    "uuid": "cdaafa65-5790-539e-95bd-e1ce8ec7b34c",
    "entry": "調理法",
    "reading": {
      "primary": "ちょうりほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
