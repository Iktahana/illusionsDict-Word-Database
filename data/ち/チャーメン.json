          "literary": [
            {
              "text": "餃子の他に、炒麺や、野菜の油炒め、その他何でも、油っ濃く炒めたものが出る。",
              "citation": {
                "source": "ああ東京は食い倒れ",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "挽肉を掛けて、炒麺のように、軽く炒めたものである。",
              "citation": {
                "source": "うどんのお化け",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間、錦江へ行き、豚肉炒麺一つ食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
