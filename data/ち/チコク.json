[
  {
    "uuid": "8ce061ef-3de8-5a02-94a1-ff8e303c4798",
    "entry": "遅刻",
    "reading": {
      "primary": "ちこく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lateness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "アンナ・ニコロに私は再び遅刻してしまう、恋の貉は何故、さまで苦しむのか。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵は約束の時間を何時間も遅刻してさんざんに相手をじらしたというのである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年生のときは、なめくぢと狸がしじゅう遅刻して罰を食ったために蜘蛛が一番になった。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って次の停留所でその遅刻のためによけいに収容しなければならない前述の nb の数を増加させる。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺を先輩だとして敬意を表してくれる好意はいつでも感謝して居るんだが、それで又いつでも遅刻する。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりは底抜けに気の弱い人、決して私との見合いを軽々しく考えたのでも、またわざと遅刻したのでもないと、ずっとあとになってからだが、そう考えることにした。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅刻はするし、酔っぱらっては来るし、もうこんな人とは結婚なんかするものかと思ったが、そう思ったことがかえって気が楽になったのか、相手が口を利かぬ前にこちらから物を言う気になり、大学では何を専攻されましたかと訊くと、はあ、線香ですか、好きです。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒は不潔な堕落のような気がして、このとしになるまで盃をふくんだ事がなかったのですが、国内に酒が少し不足になりかけた頃に、あわてて酒の稽古をするとは、実に、おどろくべき遅刻者であります。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、いつでも遅刻ばっかりしていました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが驚いたことには、参会者はすでに整列をすましていて、何のことはない私は遅刻して来た者のようであった。",
              "citation": {
                "source": "髪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍にいた分会長はこ奴は遅刻したので撲ってやりましたと言った。",
              "citation": {
                "source": "髪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいや遅刻したのではない、点呼令状の指定する時間前に到着したのである旨をありていに述べた。",
              "citation": {
                "source": "髪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅刻した時も教室の廊下で一本吸ってからはいった。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一本の為に、私は試験に遅刻した。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅刻するとわかりながら、吸っていた。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間経ったある朝、豹一が出社して間もなく、白い縮のシャツの上へ薬剤師や医者の着る白い診療服のようなものを羽織った男が、自転車を押してはいって来て、柱時計を見上げ、「あ、五分遅刻したぞ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりあえず、マンチェスター駅よりは三分の一ほど手前のセント・ヘレンス駅へ問合せの電信をうってみると、次のような返電があった――『リヴァプール駅長ジェームス・ブランドへ、――臨列、遅刻なく四時五十二分当駅通過、――セント・ヘレンス、ダウサー。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "小熊秀雄全集-11詩集（10 ）風物詩篇小熊秀雄東京風物伝東京駅東京駅はウハバミの燃える舌で市民の生活を呑吐する玄関口、朝は遅刻を怖れて階段を一足とび夕は疲れて生気なく沈黙の省電に乗る所詮、悪蛇の毒気に触れて人々の痲痺は不感症なり。",
              "citation": {
                "source": "小熊秀雄全集-11",
                "author": "詩集（10 ）風物詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄之丞はここでも主人にむかって遅刻の詫びをしなければならなかった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は古藤にちょっと目で挨拶をして置いて、貞世を抱いたまま末座に膝をついて、一同に遅刻のわびをしようとしていると、主人座にすわり込んでいる叔父が、わが子でもたしなめるように威儀を作って、「なんたらおそい事じゃ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「遅刻だぞ」　と、改札口の外で待っていた高志が声をかけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一は、一瞬、遅刻のことかと思ったが、この映画を見るのは何度目か、ときいているのだと気づいた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「知りませんよ」　一〇三のヴェランダにおいたモニターの垂直同期を調整しながら、そうこたえたワラは、怒っていないどころか、むしろ高志の遅刻を歓迎しているらしい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅刻した奴がいけないんだからな」　そういう山崎のノンシャランな口調に、いちおうは高志に遠慮していたワラも安心したらしく、カメラを水平にもどし、坂を見わたせるように、ズームをいっぱいに引いた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それにしても、腹へったなあ」「メシをもってくとかいった奴が、遅刻するからいけないんだ」　慶一が腹を立てているのは、そのせいでもあった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「遅刻だからね」「わかってる」　令子のことが気になるので、慶一は高志の無礼を、とりあえず不問に付すことにした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手に顔合わせしちまったんだな」「見りゃ、わかるでしょうに」「おまえが遅刻するから、おれの計画が狂ったじゃないか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは闇夜であったからというのを口実にして弁解したが、キッティに恋びとらしくない遅刻を反駁されながら、とにもかくにも食卓に着いた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋常一年生位が遅刻しても、「まだ子供ですから」　という理由で叱らない方針の学校が出来た。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "▲備考　この傾向は紐育のような大都会になると一層烈しいので、同市の自殺原因の統計の中には、朝牛乳瓶が割れたためとか、ヘアピンをなくしたためとか、又は学校に遅刻したためとかいうような物凄いのが驚くべき多数に上っている。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
