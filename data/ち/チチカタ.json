    "definitions": [
      {
        "index": 1,
        "gloss": "father's side of family",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "渡弁護士は倉持には父方の叔父であり、後見人でもあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "父方と母方の先祖は、ずいぶん死んだろうなあ。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これが本家の長男の純一です」　父方の叔父が、まだ私の知らない新しい親類の人に私を紹介した。",
              "citation": {
                "source": "地球儀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　父方の叔父が、未だ私を知らない新しい親類の人に私を紹介した。",
              "citation": {
                "source": "地球儀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "父方の祖父については、私は何の知るところもない。",
              "citation": {
                "source": "私の母",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父方の祖母はかなりシッカリした婦人であったらしい。",
              "citation": {
                "source": "私の母",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年前に死んだ父方の次男のＴの未亡人である。",
              "citation": {
                "source": "冬の風鈴",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（「親父」は私の祖父、「阿母」は父方の祖母、「姉公」とは私の母である。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間で自分は、父方の無智に呑気な祖父母から甘い惰眠を授けられたのだ。",
              "citation": {
                "source": "蔭ひなた",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局私は、父方の朗らかに放縦な血を何かに奪はれ、母方の根強い自尊心と謹直な保守性を何かに盗まれて――私は、斯んなに痩せてしまつたのだ。",
              "citation": {
                "source": "蔭ひなた",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ父方の曾祖父が、お月様を猫に噛ませようと長い間努力して成功せず、疲労の結果、人面疽にかかって死んだということがいささか注目に値するだけである。",
              "citation": {
                "source": "二重人格者",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父の代から、私の家には男ばかりが生れまして、私には、父方の叔母もなければ、又、姉も妹もありませんでした。",
              "citation": {
                "source": "血友病",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "四ツ谷に縁づいている父方の従姉の家へ出入りしている男が、その家をよく知っていたところから、大蔵省へ出ている従姉の良人と叔父との間にそんな話が纏まることになった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "胴の長い痩せぽッちなその骨格と、狭い額際との父親そっくりであるほか、この子が母親の父方の顔容を受け継いでいることは、笹村にとってかえって一種の安易であった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "名古屋と大阪とでは、名古屋では父方の親戚を、大阪では母方の親戚を歩き廻った。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、父方の親戚に大勢吃りのあることは前にも言った。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "母方の祖父も父方の祖父も、私が三つぐらいのとき既に没して、いずれも顔さえ覚えていない。",
              "citation": {
                "source": "明治のランプ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父方の祖母はずっと田舎暮しで、そこの家の本のあるところが、実に夏休みの間の探険場所であった。",
              "citation": {
                "source": "祖父の書斎",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父方の関心はそういうところにあったと思える。",
              "citation": {
                "source": "祖父の書斎",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父方の祖母、母方の祖母が、わたしの幼い時代に徳川時代から明治初年への物語を色こく刻みこませた人々であった。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時分に式部卿の宮と言われておいでになった親王もお薨れになったので、薫は父方の叔父の喪に薄鈍色の喪服を着けているのも、心の中では亡き愛人への志にもなる似合わしいことであると思っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "蜻蛉",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学三年の時、父方の祖母と同居して、代々売薬商を営んでいた加賀谷家の昔話を聞いた。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮の父方の祖母が私の村にやって来た。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄弟五人中津の風に合わず扨中津に帰てから私の覚えて居ることを申せば、私共の兄弟五人はドウシテも中津人と一所に混和することが出来ない、その出来ないと云うのは深い由縁も何もないが、従兄弟が沢山ある、父方の従兄弟もあれば母方の従兄弟もある。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "悧巧な兄は父方の祖母のほめ者だったが、母方の祖母は自分をつかまえて、おまえは兄さんよりもきっと偉くなるよ、と無責任なことをいって可愛がってくれた。",
              "citation": {
                "source": "大人の眼と子供の眼",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この丸亀は折から妻の妹の夫、また私にも父方の従弟に当る菱田中行が基督教の宣伝のため来ていたので、そこへ止宿した。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "己にさえ、己を欺く魔の、どこにか潜んでいるような気持は免かれぬものを、無二の友達とは云え、父方の縁続きとは云え、迂濶には天機を洩らしがたい。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "果然経済学の唱道者は数学者の子孫より出でたり、田口君の推理力は其母方の血統なりとか聞く佐藤一斎に出でしにはあらずして其父方の血統に出でしなり。",
              "citation": {
                "source": "明治文学史",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに兄弟とてなかった父方の親類といえば言われるのはそこきりで、血こそ繋がっていないが今でも親類づき合いをしているのであった。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
