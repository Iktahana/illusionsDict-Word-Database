    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ellipse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大きさおよそ二分ばかり、緑褐色長円形をなす。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "稈の上部は細長円柱形で葉から超出し衆草を抜いて高く聳えている。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "介殻の蝶番部に相当する外套膜にできるものは不正形であるが、非常に光沢のよい長円形の物が生ずることがある。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "三井寺の首長円慶法親王は別当を免ぜられ、役僧も免官、堂衆三十四人は流罪に処せられた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺籍はどこに属する者か」「ひとりは長嶋の長円寺」「やはりそうか」「二名は、性懲りもない、叡山の僧であります。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――類と類だな」「首魁の長円寺の坊主は、さすがにいかに叩いても、そら嘯いて口をあかず、三好の残党も、泥を吐きませんので、叡山の二名を、べつにして、拷問してみましたところ、すべてを白状いたしました」「そうか。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
