[
  {
    "uuid": "972dc5e2-c59f-5add-ba25-7867f663b86b",
    "entry": "腸炎",
    "reading": {
      "primary": "ちょうえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
