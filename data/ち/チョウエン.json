    },
    "definitions": [
      {
        "index": 1,
        "gloss": "enteritis",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
