          "literary": [
            {
              "text": "それから引き返して、中店をぶらぶら歩いた。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかさま、先第一｜木彫の人形か、其次は………イヤ中店のおもちやを一手買占も出るだらうな。",
              "citation": {
                "source": "黄金機会",
                "author": "若松賤子",
                "note": "青空文庫"
              }
            },
            {
              "text": "観音様の中店の「燗銅壺」といった料理店で夜食をしながら、師匠は少し言葉を改め、「幸吉、実は、今度、お前に骨を折ってもらわなくちゃならないことが出来たんだ。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "店初まっての大作をしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "一国一城のあるじが、そちのごとき中店の抱え遊女にお通い召さるとは、変った風流よのう。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことを云つてゐるので、義雄は氷峰から工面して貰つたのを提供すると、呑牛と緑紅とは角の中店を決めに行つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "中店でも、義雄が知つてゐるところには行けない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "と申しますのは、中京辺りの大｜店では、どこの店でも家宝とする立派な屏風を、祇園祭りの間中店に飾ります。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "中店を一寸右へ這入ると其処にバラックの小屋があった。",
              "citation": {
                "source": "広東葱",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは親方も江戸っ子なら、お神さんはすぐ近所の根津の中店にいた人だとかで、家中物分りがよかった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を食べようかと色々考へた末、呉服橋の末広中店へとりを食べに行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
