        "examples": {
          "standard": [
            {
              "text": "食品添加物として認められている着色剤は、安全性が確認されたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この塗料には、耐光性に優れた特殊な着色剤が配合されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "研究室では、細胞組織の観察のために様々な着色剤を試している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "混ぜ物処理の第二の型ではいろいろな種類の着色剤が加えられる。",
              "citation": {
                "source": "食品とその混ぜ物処理",
                "author": "FOOD AND ITS ADULTERATIONS; ANALYTICAL SANITARY COMMISSION OF \"THE LANCET\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "12標品では着色剤は鉛丹（minium）すなわち赤色酸化鉛であった。",
              "citation": {
                "source": "食品とその混ぜ物処理",
                "author": "FOOD AND ITS ADULTERATIONS; ANALYTICAL SANITARY COMMISSION OF \"THE LANCET\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "８．６例において着色剤は朱（vermilion）、辰砂（cinnabar）すなわち硫化第二水銀であった。",
              "citation": {
                "source": "食品とその混ぜ物処理",
                "author": "FOOD AND ITS ADULTERATIONS; ANALYTICAL SANITARY COMMISSION OF \"THE LANCET\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "15例の着色剤は人工のジャーマン群青（ウルトラマリン）であり、これはナトリウムとアルミニウムの硫化物である。",
              "citation": {
                "source": "食品とその混ぜ物処理",
                "author": "FOOD AND ITS ADULTERATIONS; ANALYTICAL SANITARY COMMISSION OF \"THE LANCET\"",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
