[
  {
    "uuid": "9a01d5c7-d339-562e-b215-54f8e5a4d383",
    "entry": "知識層",
    "reading": {
      "primary": "ちしきそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
