        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その大空は地の果てから地の果てにまで広がっていた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ＤＯＳ／Ｖ万歳」の雄叫びはなぜかマッキントッシュの博覧会に響き渡る　地の果ての幕張メッセで開かれたマッキントッシュの博覧会、マックワールド・エキスポの会場で、マック使いのライターのＴ田とバッタリ会った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸の声が、ここ「大地の果て」でぷっつり切れてるのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸地の果てといふ感じが強く胸をめぐる。",
              "citation": {
                "source": "伊良湖の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲が白く靡いて陸地の果てを劃して居るやうに思はれる。",
              "citation": {
                "source": "伊良湖の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "地の果てにある水晶宮のキラキラした泉の姿が……。",
              "citation": {
                "source": "魔のひととき",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほれぼれと涙に溺れて、私の体と心は遠い遠い地の果てにずッとあとしざりしだした。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の村々から吹き上げてきた風が、この地の果てのような場所まで来ると、もう何処へいったらいいか分からなくなってしまったとでも云うように、療養所のまわりをいつまでもうろついていた。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはまた、もし痛手をうけた場所にいて苦しい思い出に耐えられないならば、望みにまかせて住居をかえることもできるし、いわゆる、あけぼのの翼に乗って、「地の果てにとびさり、やすきをうる」こともできる。",
              "citation": {
                "source": "傷心",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "次第に小さくなってゆく船の帆を見つめ、地の果てにただよってゆくわが身を空想するとき、どんなにわたしの眼はあこがれに輝いたことだろう。",
              "citation": {
                "source": "わたくし自身について",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "地の果てを索ね明さんとしてそこにて秘められたる神の面を見たり　探検とは、そもそもどういうことをいうのだろう。",
              "citation": {
                "source": "南極記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "新羅、百済、高麗に逃げたいと夢のようなことをいえば、いや雲の果て、地の果て、海の彼方に行きたいと叫び出す者もいる。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "（極北夜半望日）（欧州の地の果てるあたりは、夜なかばにして太陽はなお天にある。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "その考へによると、空は青い円天井で、だん／＼低くなつて行つて、終ひには地の果てで止まつてゐる。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえは自分の言行が書物に記録されて、時の窮み、地の果てまで伝えられることを知っていたので、すべての人間も自分の例にならって、奇跡を必要としないで神と共に暮らすだろう、そんなことを当てにしていたのだ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲の奥か、地の果てからか、おそろしい響きが人身に感じてきた。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "木曾の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お、あんなほうへ」　やがて、深編笠の浪人、遠く離れてゆくうどん屋の灯を見出して埋地の果てへ走りだした。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、ああ日ぐるまや（ブレエキ）ああひぐるまや、日のあゆみひねもすかぞへ倦みつかれ、旅ゆくみちのはてといふうまし黄金の國を趁ふ。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
