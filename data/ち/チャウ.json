    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to do completely",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "間誤ついてると、細く短くなっちゃうぞ）　汽車が、速度をゆるめた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏み殺されちゃうぜ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな身の毛のよだつような男にしろ、嫉妬をあれほど妬かれるとあとに心が残るものさ」　若い芸妓たちは「姐さんの時代ののんきな話を聴いていると、私たちきょう日の働き方が熟々がつがつにおもえて、いやんなっちゃう」と云った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその天の川の水のなかから四方を見ると、ちゃうど水が深いほど青く見えるやうに、天の川の底の深く遠いところほど星がたくさん集って見えしたがって白くぼんやり見えるのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天の川の形はちゃうどこんななのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あの人はうちのお父さんとはちゃうどおまへたちのやうに小さいときからのお友達だったさうだよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人がその白い道を、肩をならべて行きますと、二人の影は、ちゃうど四方に窓のある室の中の、二本の柱の影のやうに、また二つの車輪の輻のやうに幾本も幾本も四方へ出るのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると黄と青じろとまだらになって、なにかのあかりのやうにひかる雁が、ちゃうどさっきの鷺のやうに、くちばしを揃へて、少し扁べったくなって、ならんでゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがちゃうど十二日目、今日か昨日のあたりです、船が氷山にぶっつかって一ぺんに傾きもう沈みかけました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらの三角標はちゃうどさそりの形にならんでゐるよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジョバンニはまったくその大きな火の向ふに三つの三角標がちゃうどさそりの腕のやうにこっちに五つの三角標がさそりの尾やかぎのやうにならんでゐるのを見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子もちゃうどその通りにしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてたくさんのシグナル〔や〕電燈の灯のなかを汽車はだんだんゆるやかになりたうたう十字架のちゃうどま向ひに行ってすっかりとまりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二人がそのあかしの前を通って行くときはその小さな豆いろの火はちゃうど挨拶でもするやうにぽかっと消え二人が過ぎて行くときまた点くのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月が車室のちゃうど天井にかかってゐるらしく、窓の氷はただぼんやり青白いばかり、電燈は一そう暗くなりました。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ママが泣いちゃう！",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジョバンニはまったくその大きな火の向ふに三つの三角標がちゃうどさそりの腕のやうに　こっちに五つの三角標がさそりの尾やかぎのやうにならんでゐるのを見ました。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてたくさんのシグナルや電燈の灯のなかを汽車はだんだんゆるやかになりたうたう十字架のちゃうどま向ひに行ってすっかりとまりました。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二人がそのあかしの前を通って行くときはその小さな豆いろの火はちゃうど挨拶でもするやうにぽかっと消えて二人が通って行くときまた点くのでした。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ひながらうちはをもってちゃうど大天狗が文化的湯治に来たといふかたちでさっさと引き上げてしまった。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支柱を惜しがって使わねえからこんなことになっちゃうんだ！",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃうど私にぶっつかるばかりだ。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝六、　「ヘヘン、中々言えませんよ」　右門が、　「誰だ、言えよ」　伝六、　「へ……」Ｔ「当てて御覧なさいよ旦那」Ｔ「誰だか言って御覧なさいよ」　右門が、Ｔ「当てて見ろ伝六」　「アッ、嫌ンなっちゃうな」　と伝六。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも彼でも売っちゃうのです。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは沢山の壺穴を連結してちゃうどへうたんをつないだやうに見えました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃうどそのときはつめくさの花のさくころで、あの眼の碧い蜂の群は野原ぢゅうをもうあちこちにちらばって一つ一つの小さなぼんぼりのやうな花から火でももらふやうにして蜜を集めて居りました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙がちゃうど五百ばかりはねたときもう一ぴきの蛙がびっくりしてこっちを見てゐるのに会ひました。",
              "citation": {
                "source": "畑のへり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃうどこのときお父さんの蛙はやっと眼がさめてルラ蛙がどうなったか見ようと思って出掛けて来ました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
