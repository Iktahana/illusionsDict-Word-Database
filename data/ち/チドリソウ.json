          "literary": [
            {
              "text": "……廃果てたメトロポウルホテルに、やはらかな日の光る五時半、萎れた千鳥草と、石鹸の泡のやうな白い小さな花をつけた雑草のなかを、やつと五歳のタアシヤーが押されてゆく、乳母車に載つて、『銀だ、黄色だ、紅だ、緑だ、ようい………』春が逝く。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "荻生さんが持って来てくれた菖蒲の花に千鳥草を交ぜて相馬焼きの花瓶にさした。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏には更に千鳥草の花がある。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千鳥草、又の名は飛燕草。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千鳥草と云えば、直ぐチタの高原が眼に浮ぶ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "野生千鳥草の花である。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
