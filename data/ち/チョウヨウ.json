[
  {
    "uuid": "1df7dd57-07dc-5c46-88cf-6dca483e6084",
    "entry": "重陽",
    "reading": {
      "primary": "ちょうよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
