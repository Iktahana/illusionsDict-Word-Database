  {
    "uuid": "4fad29ee-c422-5ca6-975d-f07a8d329002",
    "entry": "朝陽",
    "reading": {
      "primary": "ちょうよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "morning sun",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "港市の秋石崖に、朝陽が射して秋空は美しいかぎり。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "榊の葉やいろいろの花にこぼれている朝陽の色が、見えるように思われた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝陽が上つたが故に明日又陽が上るものとは誰れが保證し得るのだ。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、暴風のために古菰がはぎ去られ差込む朝陽で、彼はまざまざとほとんど幾年ぶりかのその古池の面を見た。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年の元日の朝陽はさはやかであつた。",
              "citation": {
                "source": "雜煮",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子を隈なく明け放した座敷に悠々と流れ入つた朝陽の色が疊一ぱいに擴がつて床の大花瓶に插されてあつた眞赤な南天の實が冴え冴えと一粒一粒ひかつた。",
              "citation": {
                "source": "雜煮",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕将｜劉保、華聚等、終に朝陽門に至り、備無きを覘いて還りて報ず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側には下半面に朝陽が微紅く射していた。",
              "citation": {
                "source": "蠅供養",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくし達は食事をはじめながら、小くてもほんのり春の朝靄を立てゝいる池の面に、築山の梢を出た朝陽が光を落して、一たん靄に呑まれながらなお余光を水に弾ね返させて、空中へ抜け上る微妙な色調をうっとりと眺めました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝陽は靄を抜けて、光をじかに庭に当て始めたためでしょうか、木々の芽立ちの匂いがくん／＼あたりに立ち籠めてまいりました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "細い手で受け取った鏡を、京子は朝日にかざしてきらりと光らせ、傍の者を眩しがらせてから、も一度、朝陽の在所を見極める。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡と朝陽の照り合いを検べる。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝陽を受けて水に映った己の影の上に、その時大きな物の影がふうわりとかかったが、それは人間の手のような、また見ようによっては蟹の鋏のようにも見える鬼魅の悪いものだった。",
              "citation": {
                "source": "蟹の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝になって室戸岬の沖あいから朝陽が杲杲と登りかけたところで、人夫たちが集まって来た。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄曇のした空から漏れてゐる初夏の朝陽の光が薄赤く帆を染めてゐた。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、窓をあけると輝かしい朝陽がみなぎつてゐた。",
              "citation": {
                "source": "私の一日",
                "author": "軽い酔",
                "note": "青空文庫"
              }
            },
            {
              "text": "深い深い底の見えない穴の口に、出たばかりの朝陽があたっていた。",
              "citation": {
                "source": "申陽洞記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処に南三復の家があって数多の人が朝陽を浴びてその前に集まっていた。",
              "citation": {
                "source": "竇氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出たばかりの初夏の朝陽が微熱をただよわした路には、やはり死人を見に往くのか何か話し話し林の方へ往く人がちらばっていた。",
              "citation": {
                "source": "雀が森の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝陽がむこう側の屋根瓦を寒く染めていた。",
              "citation": {
                "source": "港の妖婦",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海から昇った真紅な朝陽が長者の家の棟棟を照らしておりました。",
              "citation": {
                "source": "宇賀長者物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　おお風が凪いだ、あの怖ろしい雄叫びは綺麗に何処かの国へ逝つてしまつて、清新な朝陽がうらうらと私の頬を撫でた。",
              "citation": {
                "source": "「学生警鐘」と風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "フロラの部屋の窓には爽々しい朝陽が綺麗に当つてゐた。",
              "citation": {
                "source": "鸚鵡のゐる部屋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハネ釣籠の井戸端で、キエは麗らかな朝陽を浴びながら洗濯の音を立てゝゐた。",
              "citation": {
                "source": "滝のある村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸には青年の叫び、海ではフカが小魚をおどろかして通る、雲の交叉、そのスキ間から朝陽が勇躍しヌッと太くたくましい光つた片腕を突出し、村の一角を赤い彩りをもつて捉へる、曠野には馬が放された、風はその馬のたてがみを吹きなびかせる、風よ、お前は馬にとつては、よき調髪師だ。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "稍不気嫌であるらしい仏頂顔で縁側の籐椅子に腰をかけてゐるＹ子の姿は、凝ツと、青葉の間から斑らに射す長雨の後の麗らかな朝陽を浴びて、恰度油絵のやうに収つてゐた。",
              "citation": {
                "source": "小川の流れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニツケルの銃身に朝陽がキラキラと反射する。",
              "citation": {
                "source": "周一と空気銃とハーモニカ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "キラリ、朝陽に短く光りの尾が曳いたかと見るまに、どこからか飛んで来て、プツリ、お駕籠の棒先に突きささったのは手裏剣だった。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "微曇のした空から漏れている初夏の朝陽の光が微紅く帆を染めていた。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃の木や柿の木が生えて、その嫩葉に出たばかりの朝陽が当っていた。",
              "citation": {
                "source": "宝蔵の短刀",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
