[
  {
    "uuid": "25cb1d28-4fa6-5221-9a96-8f3fe9e606fc",
    "entry": "遅延",
    "reading": {
      "primary": "ちえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
