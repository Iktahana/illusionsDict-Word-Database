[
  {
    "uuid": "54e62f7a-9cab-5116-9779-07628e0e6dbe",
    "entry": "朝食",
    "reading": {
      "primary": "ちょうしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
