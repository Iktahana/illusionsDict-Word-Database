        "examples": {
          "standard": [
            {
              "text": "夜空に突如として現れた超新星は、観測者たちを驚かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "天文学者たちは、遠い銀河で発生した超新星を観測している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "超新星爆発は、宇宙で最も壮大な現象の一つである。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その中の一つに、超新星の問題がある。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀河系は一つの小宇宙で、その中には約一千億個の太陽があるが、三百年くらいに一度、このうちの一つが突然爆発して、いわゆる超新星になる。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
