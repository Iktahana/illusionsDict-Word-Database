    "definitions": [
      {
        "index": 1,
        "gloss": "to shrink",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "翁はから火を見ながらかさかさ乾いて亀縮む掌を摩り合わせて「娘が子というものは」と考えた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸びるのは縮まるためであり、縮むのは伸びるためである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸びるのが目的でもなく縮むのが本性でもなく、伸びたり縮んだりするのが生きている心臓や肺の役目である。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（いえ、）（いえじゃあござんせぬ、それ、それ、お法衣の袖が浸るではありませんか、）というと突然背後から帯に手をかけて、身悶をして縮むのを、邪慳らしくすっぱり脱いで取った。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "母から反対に怒鳴つけられたら、どうしようなど思うと、母の剣幕が目先に浮んで来て、足は自と立縮む。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこの結論に到着してしまへばそれで任務は済むと思つて、底辺の長さを縮むることにのみ考を集めて居る。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "環の脈を打って伸び且つ縮むに連れて、画工、ほとんど、無意識なるがごとく、片手また片足を異様に動かす。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい影にしても、人の形を踏むということは遠慮しろという意味から、かの伝説は生まれたらしいのであるが、のちには踏む人の遠慮よりも踏まれる人の恐れとなって、影を踏まれると運が悪くなるとか、寿命が縮むとか、はなはだしきは二年の内に死ぬなどという者がある。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏郷が其の請を拒まないで、何程の事やあらんと懼れ気も無しに、水深うして底を知らざる魔の淵の竜窟｜鮫室の中に平然として入ろうとするのは、縮むことを知らない胆ッ玉だ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "逸る氣になるのもある、散る氣になるのもある、弛む氣の生ずるのもある、亢る氣の生ずるのもある、凝る氣の生ずるのもある、縮む氣の生ずるのも有り、舒びる氣の生ずるのも有る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "）って俯向くんです、……枕にこぼれて束ね切れないの、私はね、櫛を抜いて密と解かしたのよ……雲脂なんかちっとも無いの、するする綺麗ですわ、そして煩ってから余計に殖えたようよ……髪ばかり長くなって、段々命が縮むんだわねえ。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この燈籠寺に対して、辻町糸七の外套の袖から半間な面を出した昼間の提灯は、松風に颯と誘われて、いま二葉三葉散りかかる、折からの緋葉も灯れず、ぽかぽかと暖い磴の小草の日だまりに、あだ白けて、のびれば欠伸、縮むと、嚔をしそうで可笑しい。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（否、）（否ぢやあござんせぬ、それ、それ、お法衣の袖に浸るではありませんか、）といふと突然背後から帯に手をかけて、身悶をして縮むのを、邪慳らしくすつぱり脱いで取つた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてはたと地に落ちて、土蜘蛛の縮むごとく、円くなりて踞りしが、またたく間に立つよとせし、矢のごとく駈け出して、曲り角にて見えずなりぬ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "興奮した小鼻の膨れ縮むのが、水を離した魚の鰓のように喘いでいましたが、だん／＼に静まりました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」との老先生の先夜の言葉を今更のように怪しゅう思って、彼は途々この一言を胸に幾度か繰返した、そして一念｜端なくもその夜の先生の怒罵に触れると急に足が縮むよう思った。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "義理何とかは三年寿命が縮むと来てやがらア」　パイを並べながら、もう軽佻浮薄な口を利いている、このとりとめなさは一体何であろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "目見青きドミニカびとは陀羅尼誦し夢にも語る、禁制の宗門神を、あるはまた、血に染む聖磔、芥子粒を林檎のごとく見すといふ欺罔の器、波羅葦僧の空をも覗く伸び縮む奇なる眼鏡を。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "耀く沼は彼らを一団の焔と縮む。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰌のをどるは苦しきなり、耀く沼は彼らを一団の焔と縮む。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども倫理といふ実用を以て、文学の命運を縮むるは詩神の許さゞるところなり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「芥子粒を林檎のごとく見すという欺罔の器」と「波羅葦僧の空をも覗く、伸び縮む奇なる眼鏡」とを持った奇怪な妖術師である。",
              "citation": {
                "source": "鏡花氏の文章",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり五十近かった氏に、口の開き方が悪いと云って張扇を突込んだり、「首が縮む、シャンとせよ」と云って張扇で鼻の下からハネ上げて鼻血を出させたりしたという話である。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上まで足をあげながら、銀子は身が縮む想いだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「膝が震えて、足が縮む……動けば落ちようし、どないしよう。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "環の脈を打つて伸び且つ縮むに連れて、画工、殆んど、無意識なるが如く、片手又片足を異様に動かす。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "逸る気になるのもある、散る気になるのもある、弛む気の生じるのもある、昂る気の生じるのもある、凝る気の生じるのもある、縮む気の生じるのも有り、伸びる気の生じるのも有る。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら酔つてゐたとはいへ、あんな馬鹿／＼しい動作をしたり、感傷に走つたり、他合もない恐怖に襲はれたり、加けに駆け出したりしたことを思ふと、誰にも見られなかつたから好さゝうなものなのに、彼は、恥しさのあまり身の縮む思ひがした。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "新子は、ちょっと身がちぢむような気がした。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉琴　女夫が祝言のさかずきは……命をちぢむる毒酒なりしか。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
