[
  {
    "uuid": "c77bbf1e-8a6a-5d92-b5dd-914b939e927b",
    "entry": "昼夜帯",
    "reading": {
      "primary": "ちゅうやおび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
