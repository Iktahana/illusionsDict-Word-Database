  {
    "uuid": "38207811-f35e-5ed0-85b1-67bdf6d57fb1",
    "entry": "着",
    "reading": {
      "primary": "ちゃく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-接尾辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "arrival",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "詩人は着物のスソを狂犬病にクヒチギられたが……！",
              "citation": {
                "source": "（風船玉の衝突）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も彼は紺の背広を着て熊のやうにしづ／＼と南国の夏の町を歩いてゐるのであらう。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなたにてきらめく川やさてはまた遠山の雪その枝にからすとまればざんざんと実はうちゆるゝこのときに教諭白藤灰いろのイムバネス着ていぶかしく五助をながめ粘土地をよこぎりてくる",
              "citation": {
                "source": "〔洪積の台のはてなる〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "機会宮沢賢治恋のはじめのおとなひはかの青春に来りけりおなじき第二神来は蒼き上着にありにけりその第三は諸人の栄誉のなかに来りけりいまおゝその四愛憐は何たるぼろの中に来しぞも",
              "citation": {
                "source": "機会",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もひどく無頓着だつた彼女は、彼等との交際も余りしなかつたのではあるが。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒のサージの背広を着て、テカテカに光るネクタイを締めてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "銘仙の袷に金紗の羽織を着、兎の毛で縁をとつたオールドローズの繻子の肩掛に寒々とくるまり、海老茶の袴を胸高く穿いてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れ易く、破れ易く、着くづれし易く、こんな服装を讃へなければならない我々日本男児は、なんとなく不幸であるやうに思へる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて最初に目に入つた玉屋に這入ると、部屋は明るくガランとしてゐて、温室のやうだつた、客の腰掛場になつてゐる、畳二枚を縦に並べた場所の、その中程に置かれた火鉢には其処の主人が如何にも睡げによつかゝつてをり、お主婦さんも割烹着を着たまゝ火鉢で手をぬくめてゐた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "割烹着の胃に当る辺りが濡れてゐるところを見ると、今の今まで茶碗でも洗つてゐたという風だ。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は服を着、怯々しながら隣の部屋にゐる友人の弟に金を借り、――でも、この月曜からは勉強しよう、浪費しまいと、そのやうなことを偶々思つた翌々日であつてみれば、私は読みかけのシュニッツラー選集を一冊持つて出掛けるのであつた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝遅れたと思つて、慌てて先方に行着いたのは六時半だつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳述、私は明治四十年四月の末に生れ、その年十一月三日に郷里を母と母方の祖母と三人で立ち、四日乗船、六日大連着、そこで父に出迎へられ、（その父も今は亡き数、――安らかなれかし！",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが思ふのに、えてして暗くなる時には、その時若し一人でゐたならば可なり着々と何事にまれ運むでゐただらう時のやうである。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "『わたし、フロックコート着る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいつも和服――特に浴衣を好んだ――を着、畳の上に正坐し、日本の煙管で刻煙草を詰めて吸ってた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に買った大久保の家に、書斎を新しく建て増しする時、一切の設計や事務を妻に一任して、自分は全く無頓着で居たが、それでも妻が時々相談を持ちかけると、『もう、あの家よろしいの時、あなた言いましょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから座敷へ上ると、妻が洋服をぬがせて和服に着かえさせてくれる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上に参るの時、あなた、シルクハット、フロックコートですよ』などと、子供をだますようにして説き伏せられ、やっと礼服を新調したけれども、やはり少しも着ようとしない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで式のある日などには、夫人が無理に押えつけ、女中までが手伝って騒ぎながら、まるで駄々ッ子を扱うように、あやしたりすかしたりして、厭がるのを強いて着せねばならなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　だが今日は非常に落着いてゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "街路は冬のやうに白つちやけて、昔ながらの大道店が、ガマの油や、オツトセイや、古着類や、縞蛇や、得體のわからぬ壞れた金物類などを賣つてる。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩いてゐる人たちも、一樣に皆黒いトンビを着て、田舍者の煤ぼけた樣子をして居る。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際あの頃の政府は、馬鹿な悪い親で、大ばくちの尻ぬぐいに女房子供の着物を持ち出し、箪笥はからっぽ、それでもまだ、ばくちをよさずにヤケ酒なんか飲んで女房子供は飢えと寒さにひいひい泣けば、うるさい！",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの大好きな魯迅先生は、所謂「革命」に依る民衆の幸福の可能性を懐疑し、まず民衆の啓蒙に着眼しました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん痩せ細っているようであったけれども身丈は尋常であったし、着ている背広服も黒サアジのふつうのものであったが、そのうえに羽織っている外套がだいいち怪しかった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまの背広服のほかに、学生服を着たり、菜葉服を着たり、あるときには角帯に白足袋という恰好で私を狼狽させ赤面させた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラブ員は海賊のユニフォオムを一着すること。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつは、いそぎんちゃくだよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い火山灰層のひとところが、平らに水で剥がされて、浅い幅の広い谷のようになっていましたが、その底に二つずつ蹄の痕のある大さ五｜寸ばかりの足あとが、幾つか続いたりぐるっとまわったり、大きいのや小さいのや、実にめちゃくちゃについているではありませんか。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
