        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "全体ちゃきちゃきの深川ッ女が、根岸くんだりへ行って、ももんじいに歌を習うなんて、そんな間違ったことはないんです。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い男はやはり何も答えずに、ちゃきちゃきと鋏を鳴らし始めた。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋏の音がちゃきちゃきする。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光と霧と松脂のしずくとが細かく降注ぐ山土の傾斜、ふやけた落葉の堆積のなかから踊り出して来たこの頭の円い菌こそは、松山の赤肌に嗅がれる体臭を、遺伝的にたっぷりと持ち伝えた、ちゃきちゃきの秋の小伜である。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "本書の著者のごときも、変わった方の一人で、ペン・ネームだけを聞くと、戦国時代の武士か何かのようだが、どうして近代人のちゃきちゃき、窒素研究所のラボラトリーで、試験管をいじくることを職業としている工科出身の小壮有為なお役人さんである。",
              "citation": {
                "source": "甲賀三郎『琥珀のパイプ』序",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "若井さんは頭の禿げた年輩な人で、江戸ッ児のちゃきちゃきという柄。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "鶏の製作を引き受けたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "高飛びすりゃしたで顔がきいているからすぐにわかるし、また江戸っ子のちゃきちゃきが、そんなぶざまなまねもしめえじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "本年とってようやく二十六歳という水の出花で、まだ駆けだしの同心でこそあったが、親代々の同心でしたから、微禄ながらもその点からいうとちゃきちゃきのお家がらでありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "軸に書かれた八郎次の孫なる当代大和田十郎次は、旗本も旗本、石高二千八百石を領する小普請頭のちゃきちゃきだったからです。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽッと出のいなか与力じゃあるめえし、ちゃきちゃきの江戸のだんなが、いまさらおひざもとの絵図面に見とれるがところはねえじゃござんせんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "名まえのとおり三代まえからのちゃきちゃきの江戸っ子なんですが、疑ってみるてえと、どうもこれが怪しいとこういうんです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それやどうして、学校出のちゃきちゃきですから気の利いたもんや。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでも自分らは宵越しの金は持たぬちゃきちゃきの江戸ッ子で、自分は芸者の腹から浅草の有名な料理屋に生れ、女房も神田上水に産湯を使ったものだ。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸子のちゃきちゃきだ。",
              "citation": {
                "source": "里芋の芽と不動の目",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが適齢になって兵役に出で、満洲守備に行き、帰って結婚してもう四人の子女の父、郷党のちゃきちゃきです。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルーズベルトの女特使ルス嬢は、この間まで南太平洋の輸送機隊長をしていた航空大佐であり、その相棒たる男特使ベラントはリード商会の若番頭の一人で、ちゃきちゃきの手腕を謳われている人物だった。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "▼上野の動物園にいって見ると（今は知らぬが）前には虎の檻の前などに来るともの珍らし気に江戸児のちゃきちゃきなどが立留って見て鼻をつまみながら、くせえくせえなどと悪口をいって居る、その後へ来た青毛布のじいさんなどは一向匂いなにかは平気な様子でただ虎のでけえのに驚いている。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも長老は相手の眼つきだけで、どんな人物で何の用に来たかということを見抜いてしまうそうですからな、しかし、あなたのようなちゃきちゃきのパリっ児で自由主義の紳士が、どうしてそんなに坊主どもの思わくを気になさるんでしょう。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、あのバガウトフですよ、上流社會出の、ちゃきちゃきのペテルブルグっ兒でさあ。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこの男の弟でね、これもやはりちゃきちゃきのペテルブルグっ兒でしたが、Ｖ縣の知事のもとに勤めていたのがあったんです。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際にはあとから分署の部長が来て、始末書を取られたか、なにがしかの科料処分になったようだが、「大学出の若いちゃきちゃきの巡査を理詰めで降参させた」というので、あさ子はすっかり女をあげたものであった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、お前のお養母さんの浜中屋の女将ときては、公方の肩持ちで、ちゃきちゃきな江戸ッ児だからな。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
