        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "長い時間立ったままで働く女、又は椅子にかけたなりで一日中執務しているような女の体には子宮後屈が多く、不姙その他の不幸を女と男との一生にもたらすことは周知の事実である。",
              "citation": {
                "source": "昨今の話題を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私担当分の講座原稿は一応の準備ができておりますから臥床中執筆、第六回配本に間に合わすよういたします。",
              "citation": {
                "source": "平野義太郎宛書簡",
                "author": "一九三三年三月",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月四日（土曜）雨　午前中執筆、午後、和、読、夜、外国語。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……堅磐常磐に斎ひまつりて、いかし御世に栄えしめまつり、康治元年より始めて、天地日月と共に、照し明らしましまさむことに、本末傾かず、いかしほこの中執り持ちて、仕へ奉る中臣｜祭主正四位上神祇大副大中臣清親寿詞をたゝへ、こと定めまつらくと申す。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月八日（木）　一日中執筆。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は娘で、私の病中執筆には大反対で、Ｓ君にもとうに一本｜釘を打ってある。",
              "citation": {
                "source": "“指揮権発動”を書かざるの記",
                "author": "犬養健",
                "note": "青空文庫"
              }
            }
          ]
        }
