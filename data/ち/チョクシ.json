  {
    "uuid": "80c2a11c-a5d0-5bef-b1ec-0e311bb17f10",
    "entry": "勅旨",
    "reading": {
      "primary": "ちょくし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
