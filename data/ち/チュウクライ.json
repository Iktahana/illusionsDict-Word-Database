        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一晩中くらいはかかって燃えそうに見えた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして中くらいの鮒を二匹、「魚返すよ。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "板壁の一方には中くらいの窓があって棚が出ている。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　　お光が中くらいな鞄を提げて、肩をいからすように、大跨に歩行いて、電車の出発点まで真直ぐに送って来た。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中くらい、おもしろいものはないからなあ。",
              "citation": {
                "source": "家じゅうの人たちの言ったこと",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまりあらくない中くらいな処が好かろうねえ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝一人ならどうにか中くらいにでも食えようが、詮ずる処、妻子｜眷族、つづいては一類一門のつながりに、稼がないではいられないからだよ。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰐口は講堂での出来は中くらいである。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "千生はことし二十三で、男振りもまず中くらいであるが、磨いた顔を忌にてかてかと光らせて、眉毛を細く剃りつけ、見るから芸人を看板にかけているような気障な人体であったが、工面が悪くないので透綾の帷子に博多の帯、顔ばかりでなしに身装も光っていた。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのこもをはねてみな」　ぬっと出た顔は、三十七、八、つら構えは中くらい、しかし、ほおの肉づき、顔のいろ、まだそれほど牢疲れが見えないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "この停車場は大でもなく小でもなく、わたしには余り面白くない中くらいのところであるが、それでも汽車の出たあとの静かな気分を味わうことが出来る。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、そこに中くらいの大さの汽缶車が一ついました。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "表通は中くらいの横町で、向いの平家の低い窓が生垣の透間から見える。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "中くらいな背丈で、全体から受ける感じが清らかな人である。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "中はたいへん広く、中くらいの倉庫ほどあった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きいのはみんな兄弟で、中くらいのがみんな兄弟で、小ちゃいのがみんな兄弟だよ。",
              "citation": {
                "source": "南さんの恋人",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "中くらいの隕石ではあたってもこのかぶとでふせぐことができる」「ああ、そんなものも用意してあるんですね」「そうだ。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "原料第一――選定　さて、原料は鳥にしても、あまり成熟しない中くらいのものがよろしいのでありまして、真に賞味出来るのは、そういうものであります。",
              "citation": {
                "source": "日本料理の基礎観念",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "緯度はだいたい北海道の真中くらいで、寒さも似たようなものである。",
              "citation": {
                "source": "ウィネッカの冬",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予感の的中というようなものは、それが百発百中であるか、百発八十中くらいであるかによって、その意味が大いに異なってくる。",
              "citation": {
                "source": "吉右衛門と神鳴",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百発八十中くらいならば、将来神鳴が起りそうな現在の気象条件と現在の感覚との間の関係になる。",
              "citation": {
                "source": "吉右衛門と神鳴",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで百発八十中、あるいは六十中くらいの神鳴予言者の方は、雷雲発生に適した気象条件を感ずる、あるいは記憶によって思い出すのであろうということにして、御免を蒙らせてもらうことにしよう。",
              "citation": {
                "source": "吉右衛門と神鳴",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが吉右衛門などの場合は、あの記事を読むと、それがどうも九十五中くらいのように思われる。",
              "citation": {
                "source": "吉右衛門と神鳴",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの頃の女中くらい御機嫌の取り悪いものはありませんのね。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中くらいの商人の母が、杖をつき提灯をさげて通る。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "その奥の部屋にはそれぞれに穹稜をもつ石の天井があり、中くらいの大きさで、常ならぬ用途に用いられたのは明白だった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉の向こうの部屋は中くらいの大きさで、台が一つ、椅子が一脚、二群の奇妙な器機類を除いて他の家具はなかった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "おびただしい、色とりどりの服を着た人々が――一人としてはいってきた彼に注意する者はなかった――窓が二つある中くらいの部屋にいっぱいで、部屋は、ほとんど天井の近くで回廊に取巻かれており、その回廊がまた同じように完全に満員で、人々はただ身をかがめてやっと立つことができ、頭と背中とを天井にぶつけていた。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえ、説教壇の石の円天井は異常に低いところから始まり、装飾は全然ついてはいないがきわめて彎曲して上へ昇っているため、中くらいの男でもそこにはまっすぐには立てず、しょっちゅう手すりの前に身体を乗り出していなければならないほどだった。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
