    "definitions": [
      {
        "index": 1,
        "gloss": "falling lightly (e.g. snow, petals, confetti)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「嘘ですよ」一陣の風がスケッチブックをぱらぱらめくって、裸婦や花のデッサンをちらちら見せた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その建築の家屋の上に、雪がちらちら降ってるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の妹で十九になる娘が居て店の奥の方でちらちらする時がある。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の姿のちらちらする日には竹村君は面白そうに一時間の余も話し込んでいるが、娘の顔を見せぬ日は自然に口が重くてそうかといって急に帰るでもなく、朝日を引切りなしに吹かして真鍮のしかみ火鉢の片隅へ吸殻の山をこしらえる。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからかすかに覗われる井の中の様な病房の奥に二人三人の人間の着物の袖か裾かが白くちらちらと動いて見えました……私はあわてて目を逸らしました。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてジョバンニは青い琴の星が、三つにも四つにもなって、ちらちら瞬き、脚が何べんも出たり引っ込んだりして、たうたう蕈のやうに長く延びるのを見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもだんだん気をつけて見ると、そのきれいな水は、ガラスよりも水素よりもすきとほって、ときどき眼の加減か、ちらちら紫いろのこまかな波をたてたり、虹のやうにぎらっと光ったりしながら、声もなくどんどん流れて行き、野原にはあっちにもこっちにも、燐光の三角標が、うつくしく立ってゐたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとほんたうに、そのきれいな野原中の青や橙や、いろいろかゞやく三角標も、てんでに息をつくやうに、ちらちらゆれたり顫へたりしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもたしかに流れてゐたことは、二人の手首の、水にひたったとこが、少し水銀いろに浮いたやうに見え、その手首にぶっつかってできた波は、うつくしい燐光をあげて、ちらちらと燃えるやうに見えたのでもわかりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてきまりが悪いのでカムパネルラと二人、また窓の外をながめてゐましたが、その鳥捕りの時々大したもんだといふやうにちらちらこっちを見てゐるのがぼんやりわかりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楊の木や何かもまっ黒にすかし出され見えない天の川の波もときどきちらちら針のやうに赤く光りました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞたくさんのくるみの木が葉をさんさんと光らしてその霧の中に立ち黄金の円光をもった電気栗鼠が可愛い顔をその中からちらちらのぞいてゐるだけでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚〔を〕とるときのアセチレンランプがたくさんせはしく行ったり来たりして黒い川の水はちらちら小さな波をたてゝ流れてゐるのが見えるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長の大礼服のこまやかな金彩は明るい雪の反射のなかでちらちらちらちら顫へた。",
              "citation": {
                "source": "大礼服の例外的効果",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "外ではちらちらちらちら雪が降っています。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、巨きな波をあげたり、じっと寂まったり、誰も誰も見ていない所でいろいろに変ったその巨きな鹹水の継承者は、今日は波にちらちら火を点じ、ぴたぴた昔の渚をうちながら夜昼南へ流れるのです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の足なみがかげろうのようにちらちらちらちら光りました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれこの生あたたかい春の夜に、そよそよと潮みづながれ、生物の上にみづながれ、貝るゐの舌も、ちらちらとしてもえ哀しげなるに、とほく渚の方を見わたせば、ぬれた渚路には、腰から下のない病人の列があるいてゐる、ふらりふらりと歩いてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ながれてゆく砂と砂との隙間から、蛤はまた舌べろをちらちらと赤くもえいづる、この蛤は非常に憔悴れてゐるのである。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから中座の筋むかい、雁治郎飴の銀杏返しに結った娘さんから、一｜鑵、ゆいわたを締めつけるように買ってきた包のなかから、古典の都市がちらちら介在する。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、其處に八つ並んだ窓の一つ一つの中には寢てゐる病人の黒い頭や、氷嚢を換へたりなどしてゐる看護婦の顏がちらちらと見えた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いが、もとは相当にものが良かったらしい外套の下から、白く洗い晒された彼女のスカートがちらちら見えていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人かげが、硝子戸の中で、ちらちら動いていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い歯がちらちらした。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
