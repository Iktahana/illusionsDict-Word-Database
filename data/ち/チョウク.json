    "definitions": [
      {
        "index": 1,
        "gloss": "long march",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼長駆して闕を犯さば、何を以て之を禦がん、陛下惑いたもうなかれと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤軍長駆して深く敵地に入り、腹背左右、皆我が友たらざる也、北平は遼遠にして、而も本拠の四囲｜亦皆敵たる也。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "長駆深入すれば、一旦糧竭き変生ずるの時、多く士卒を亡ふをいふ。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "周の敬王の四十年、閏十二月某日は良夫に迎えられて長駆都に入った。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、謙信が長駆小田原を囲んだとき、信玄は信濃に入って、策動したのである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "清正は更に開城を経た後大陸を横断して西海岸に出で、海汀倉に大勝し長駆｜豆満江辺の会寧に至った。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "謙信など長駆して来て、小田原を囲んだが、懸軍百里の遠征では、糧続かず人和せず、どうにも出来なかった。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオンはロシヤの軍隊を簡単に撃破して、長駆モスコーまで侵入したのであるが、これはナポレオン軍隊の堅実な行動半径を越えた作戦であったために、そこに無理があった。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "白山まで長駆して歩いてかえる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中堅手がそれを拾うてホームへ投げた、がこのときはすでにおそかった、五大洲とクラモウは長駆してホームへ入り、千三は三塁にすべり込んだ。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "然りと雖も八幡公義家が、馬を朔北の曠野に立て、乱鴻を仰いで長駆、安賊を鏖殺したる、当年の意気豈悉消沈し去らむ哉。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "惟ふに函谷の嶮によれる秦の山川が、私闘に怯にして公戦に勇なる秦人を生めるが如く、革命の気運既に熟して天下乱を思ふの一時に際し、昂然として大義を四海に唱へ、幾多慓悍なる革命の健児を率ゐ、長駆、六波羅に迫れる旭日将軍の故郷として、はた其事業の立脚地として、恥ぢざるの地勢を有したりと云ふべし。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "志雄山の平軍既に破れ、義仲行家疾馳して平軍に迫る、無人の境を行くが如く、安宅の渡を渉りて篠原を襲ひ、遂に大に征北軍を撃破し、勇奮突破、南に進むこと、猛虎の群羊を駆るが如く、将に長駆して京師に入らむとす。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が粟津の敗死は既に彼が、懸軍長駆、白旗をひるがへして洛陽に入れるの日に兆したり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿永三年正月、彼が、股肱の臣樋口次郎兼光をして行家を河内に討たしむるや、兵を用ふること迅速、敏捷、元の太祖が所謂、敵を衝く飢鷹の餌を攫むが如くなる、東軍の飛将軍、源九郎義経は、其慣用手段たる、孤軍長駆を以て、突として宇治に其白旄をひるがへしたり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタンリ・レインプールの『中世』に拠ると、その時アラビアの侵入軍は破壊したバビロン城砦の付近に陣営を張ったまま長駆してアレクサンドリアを攻略し、帰って来てその陣営の位置に新都市を経営した。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、着弾百パーセントという特選爆弾を一発、軽巡奴に御馳走して、マスト飛び、大砲折れサ、ヤンキーが血を見て、いよいよ腰をぬかしている隙に、長駆、大航空母艦の上に、五百キロ爆弾のウンコを落とす」「うわーッ、千手の奥の手が始まった。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚余力あるに於ては、長駆カシマ灘よりトーキョー湾に進撃し、首都トーキョー及びヨコハマの重要地点を攻撃すべし。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度もかけちがいましてお目にかからんけりゃ、わが輩は、だ、長駆｜渤海湾に乗り込んで、太沽の砲台に砲丸の一つもお見舞い申さんと、堪忍袋がたまらん」　「それこそ袋のなかに入るも同然、帰路を絶たれたらどうです？",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度もかけちがいましてお目にかからんけりゃ、わが輩は、だ、長駆｜渤海湾に乗り込んで、太沽の砲台に砲丸の一つもお見舞い申さんと、堪忍袋がたまらん」「それこそ袋のなかに入るも同然、帰路を絶たれたらどうです？",
              "citation": {
                "source": "小説　不如帰",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "邦土美なりといえどもイタリアの単騎長駆ただちにその城下を陥れらるるがごときにあらず。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば主君信長が逆臣明智光秀のために京都本能寺で弑せられたと知るや敵の毛利氏と和を講じ、光秀の構えの整わない先に山陽道を長駆して山崎街道に軍を進め、一戦に敵を破った如き電光石火の早陣であった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本文校了の日たまたま一ノ酉に際会し友人Ｍ、Ｎ、Ｎ三君も来り合せしものありし故天候も良し夕刻より長駆大鷲神社に赴きしが戦乱慌忙の後初の酉の市詣で也。",
              "citation": {
                "source": "東京の風俗　序",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからただちに札荅蘭城を屠り、長駆、抗愛山脈を衝くのだから、稗でも藁でも、充分に食わせておくがよいぞ。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣妖丹下左膳は、乾雲に乗って天を翔り闇黒に走って、自分のこの坤竜を誘い去ろうとしている――それに対し、われは白日坤竜を躍らせ、長駆して乾雲を呼ぶのだ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまこの、武蔵太郎つくるところの一刀をピッタリ青眼につけた諏訪栄三郎、闇黒に沈む庵内に眼をこらして、長駆してくるはずの乾雲丸にそなえていると。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "薙伏せたかと思うと、怨恨と復讐にきらめく一眼を源十郎の上に走らせ、長駆、地を踏みきって、むらがる十手の中を縁へ向かって疾駆し来った。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひそかに自分を訴えでたのは、てっきりこの家のあるじ鈴川源十郎に相違ないと、ひとりぎめに確信した左膳が、今や、算を乱し影をまじえて、むらがる捕吏を突破し、長駆一躍して、縁の源十郎へ殺到した刹那に！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "源助町と無駄に刃を合わすより、一人でも多く番士を斃したほうがいいから、源助町の剣をひっ外して、長駆、番士の群へ殺到すると、その気魄の強さにおそれを抱いたものか、ひとり刀を提げてその一団から逃げ出したものがある。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "西は飯能、八王子、東は茨城｜水海道へんまでも長駆した。",
              "citation": {
                "source": "老残",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
