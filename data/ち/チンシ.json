[
  {
    "uuid": "3aa9b064-326c-5f84-92b6-0934bba1e31c",
    "entry": "沈思",
    "reading": {
      "primary": "ちんし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
