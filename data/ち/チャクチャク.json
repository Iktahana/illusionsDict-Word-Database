[
  {
    "uuid": "ba80d874-6e3f-54d0-b609-dfb4a8d53a8b",
    "entry": "着々",
    "reading": {
      "primary": "ちゃくちゃく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "steadily",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だが思ふのに、えてして暗くなる時には、その時若し一人でゐたならば可なり着々と何事にまれ運むでゐただらう時のやうである。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえは、健康で、着々、画業を進捗していることは、そっちからの新聞雑誌で見るばかりでなく、この間来たクルト・セリグマン氏の口からも、または横光｜利一さんの旅行文、読売の巴里特派員松尾｜邦之助氏の日本の美術雑誌通信でも親しく見聞きして嬉しい。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その歩行や、この巡査には一定の法則ありて存するがごとく、晩からず、早からず、着々歩を進めて路を行くに、身体はきっとして立ちて左右に寸毫も傾かず、決然自若たる態度には一種犯すべからざる威厳を備えつ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査はこのとき囁く声をも聞くべき距離に着々として歩しおれり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際鶏卵や牛乳や靴の欠乏は聞くも気の毒な状態であるらしいが、ただ驚くのはかの国の科学者、特にペンと紙のほかには物質的材料を要しない種類の科学者が依然としてきわめて重要な研究の結果を着々発表している事である。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも自分などが言うまでもなく当局者や各方面の専門学者によってそうした研究がすでに着々合理的に行なわれていることであろうと思われるが、同じようなことは箱根のつり橋についても言われる。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はずいぶん少年にありがちな空想を描くけれども、計画を立ててこれを実行する上については少年の時から今日に至るまで、すこしも変わらず、一定の順序を立てて一歩一歩と着々実行してついに目的どおりに成就するのである。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く桂正作は何らかの計画を立ててその目的に向かって着々歩を進めているだろうという事実である。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこのごろは彼も煩悶の時を脱して決心の境に入り着々その方に向かって進んで来たが未だ故郷の父母にはこの決心を秘しているのである。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして大地はこの時、五百年間の眠りを醒し、一大飛躍をすべく、地下数千尺の処で、着々その準備をすすめつつ在ったのである。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに、時に応じ場所に臨みて正当の心を持つ主となって、着々ともの事の真相を見つめ、疑念や妄想に負けないで、一歩一歩、しっかりした人生を歩めということです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが日本民族は、とうの昔からこの現実の理想化を徹見し、着々生活上に運用を図って来ました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえは、健康で、着々、画業を進捗していることは、そっちからの新聞雑誌で見るばかりでなく、この間来たクルト・セリグマン氏の口からも、または横光利一さんの旅行文、読売の巴里特派員松尾邦之助氏の日本の美術雑誌通信でも親しく見聞きして嬉しい。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを想うに人が金魚を作って行くのではなく、金魚自身の目的が、人間の美に牽かれる一番弱い本能を誘惑し利用して、着々、目的のコースを進めつつあるように考えられる。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むす子の画業は着々進んでいるらしく、ラントランシジャンとかそう云った手堅い巴里新聞の学芸欄に、世界尖鋭画壇の有望画家の十指の一人にむす子の名前が報じられて来るようになって来た。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い学者との結婚の仕度は着々運んで行った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、見よ、いまはこの原野にも着々と開墾の鍬が入れられ、人家の屋根も美しく光り、あれが更生部落、あれが隣村の分村、とアヤの説明を聞きながら、金木も発展して、賑やかになつたものだと、しみじみ思つた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は非常に煩はしく思ふものであるが、馴れゝば然程でも無いもので、たとへば朝起きる、衣服を更へる、夜具を疊む、雨戸を繰り明ける、燈火を消す、室内を掃除する、手水を使ふ、といふやうに、着々と一事々々を拙な事の無いやうに取り行つて行く、譯も造作も無い事である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一着々々に全氣で事を爲す習を付けるのが肝要である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "着々として歩を進めている。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "着々、陽気を取り戻した。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこしずつ危げなく着々と出世して行くお若い人たちのうしろすがたお見送りたてまつること、この世に生きとし生きて在る者の、もっとも尊き御光を拝する気持ちで、昨日は、神棚の掃除いたし、この上は、吉田様の御出世御栄達を祈るのみでございます。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎角して二人の密議が着々進んで、四日目あたりになると、編輯局に多数を制するだけの味方も得た。",
              "citation": {
                "source": "悲しき思出",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を一方に転ずれば、彼三田翁が着々として思想界に於ける領地を拡げ行くを見るなり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角私の翻訳はある計画を立てて、それに由って着々実行して行くと云うよりは、寧水到り渠成ると云う風に出来るに任せて遣っているのだから、凡例にもなんにもならぬわけである。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "靜子のモデル繪はただ一ときの評判で、それツ切り世の中から忘れられたが、大野と靜子との眞面目な共同仕事は、現今、新式の芝居の書き割りなどに現はれて、着々渠の素養と技巧とを見せてゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "この結社は北はカヤンガル島から南はペリリュウ島に至る迄相当根強く喰込んでいたが、当局は島民間の勢力争いや個人的反感などを巧みに利用して、着々と摘発検挙をすすめて行った。",
              "citation": {
                "source": "南島譚",
                "author": "※",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして乾児らしい乾児を一人も近づけないまま、万事タッタ一人の智恵と才覚でもって着々として成功して来た。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人が妄想に落ちて、いたずらに立てるあいだに、花前は二｜頭三頭とちゃくちゃくしぼり進む。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "はや一つの思いきった考えが、ちゃくちゃく形をとりつつあったので。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
