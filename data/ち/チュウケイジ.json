          "literary": [
            {
              "text": "欧州北部とカナダとをつなぐ航空路が、ここを中継地としているのである。",
              "citation": {
                "source": "エスキモーの国から",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "チューレへ行く軍用輸送機は、フィラデルフィアの郊外からとび立って、カナダのグース・ベイ飛行場を中継地として、あとまっすぐにチューレまでとんでしまう。",
              "citation": {
                "source": "エスキモーの国から",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは民間航空路の中継地にもなっている。",
              "citation": {
                "source": "エスキモーの国から",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "香港はそれら患者のいわば中継地になっていた。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸軍の特攻隊はここらを中継地にして、知覧に飛んだのだろう。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
