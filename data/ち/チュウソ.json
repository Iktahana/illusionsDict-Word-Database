[
  {
    "uuid": "f7279c82-7f04-5a3b-9fe9-23a7c506b800",
    "entry": "中ソ",
    "reading": {
      "primary": "ちゅうソ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "China and the Soviet Union",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一九一九年五月十八日の日曜、例の通り教会へ行ったが気分が悪いと云って中途で帰宅し、午後中ソファで寝ていた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井こそ低いが、まるで中ソ国境の名物トーチカの内部のように頑丈にできていた。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラトンの対話篇中ソクラテス史料として価値あるものは、なお他に『ラケス』『小ピピアス』『カルミデス』およびおそらく『イオン』を数えることができる。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この安保条約を廃棄させて日本の平和の保障が確立するならば、すなわち日本が完全独立国家になることができまするならば、中ソ友好同盟条約中にあるところの予想される日本軍国主義とその背後にある勢力にたいする軍事条項もおのずから必要はなくなると私どもは期待をするのであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてさらに中ソ日米によるアジア全体の全般的な平和安全保障体制を確立して日本とアジアに永久平和がくることを日本の社会党はつねに念願としてたたかっているのであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（拍手）昨年末この日本社会党の一貫した自主独立、積極的中立政策について中ソ両国が再確認をしたことにたいしましては、私ども平和外交の前進のために心から喜ぶものであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に中ソ両国の間にある対日軍事関係も切るべく要求すべきであろうと思うのであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
