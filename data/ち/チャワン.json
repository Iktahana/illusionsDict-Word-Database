        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "割烹着の胃に当る辺りが濡れてゐるところを見ると、今の今まで茶碗でも洗つてゐたという風だ。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶に早く起きたせゐもあつてか、その朝を思ひ出すたび、叔母のお茶碗から立つてゐた湯気が白々と見えてくるのだ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男が赤毛氈の縁台のまんなかにあぐらをかいて坐ったまま大きい碾茶の茶碗でたいぎそうに甘酒をすすりながら、ああ、片手あげて私へおいでおいでをしたでないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "王侯のよろこびだよ」ぐっと甘酒を呑みほしてから、だしぬけに碾茶の茶碗を私の方へのべてよこした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この茶碗に書いてある文字、――白馬驕不行。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とくべつに僕用の茶碗としてね。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が死んだなら、君がこの茶碗を使うのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつがねえ」白馬驕不行の碾茶の茶碗は流石にてれくさい故をもってか、とうのむかしに廃止されて、いまは普通のお客と同じに店の青磁の茶碗。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勢で車座に坐って茶碗でも石塊でも順々に手渡しして行く。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は手紙の終りにある住所と名前を見ながら、茶碗に注いであった酒をぐっと一息に呻った。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "興味の向くままに六かしい数学的理論もやれば、甲虫の色を調べたり、コーヒー茶碗をガラス板の上に滑らせたりした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚い錫の茶碗の中に、汲み立ての冷水を盛つて飮むのである。",
              "citation": {
                "source": "ラムネ・他四編",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七五郎、茶碗を置く。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「いや、喰い度くねえンだ」　「何処か悪いんじゃない」　「……」　「でも一杯ぐらい、食べて置かないとお前さん」　「喰い度くねえったら」　お民、茶碗を置く。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから氣むづかしげな樣子をした、栗毛のポインタアは、金色の脚のついた圓卓子の端にその背中をこすりつけながら、漆塗りの臺の上のセエヴル製の茶碗をがたがた顫はせてゐた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "湊も苦笑しながら相手の客に一礼して自分の席に向き直り、重たい湯呑み茶碗に手をかける。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "友｜達なんかと話してゐると三人の位置が引玉に考へられたり、三つ並んだ茶碗の姿が面白い押玉の恰好に見※たりする。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おどれが味噌汁が鍋に茶碗一杯ほど残っとったんをなめよりくさる！",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れた茶碗を洗い、土のついた芋の皮をむいた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間ばかり外米混入の飯を食いつづけた後、一日だけまぜものなしの内地米に戻ると、はじめて本当に身につくものを食った感じで、その身につくものが快よく胃の腑から直ちに血管にめぐって行くようで、子供らは、なんばいもなんばいも茶碗を出すのである。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、大きな茶碗で兵営の小豆飯を食わされる。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅利君はすぐに小使室へ茶碗を取りに行った。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、捲きあげて水をつる井戸の釣瓶や塀の棒杭や、茶碗や、茶壺を持ち出した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と彼は茶碗を置いて云った。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（子供に瀬戸物の茶碗で飯を食はせるな。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘が勝手に茶碗を取出して來てゐる。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然彼女は眉毛を逆立てて自分の茶碗を投げつけた。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻が茶碗をぶつつけるあたりから、おゝこの音を聞け、の邊までは原作と文字通り同樣である。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毬をつく音、靴の響き、飯を食ふ茶碗の音、次にこの大音響、そして永遠に微かな音も立てなくなる、この推移は、素晴らしい響きの藝術である。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんまりだ」　こう一言｜叫んだお政は、客の飲み残した徳利を右手にとって、ちゃわんを左手に、二はい飲み三ばい飲み、なお四はいをついだ。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
