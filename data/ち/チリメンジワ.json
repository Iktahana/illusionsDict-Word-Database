          "literary": [
            {
              "text": "しぼの大きなちりめん皺だ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠相は、そのちりめん皺を寄せて、庭のほうへ膝を向けた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「その橋の下を威張ってとおるたびに、橋は白っぽく長たらしく、僅かに日光をさえぎったところでは、この頃とても寒くなって来たわ、水はちぢんで、ちりめん皺が寄って暗いもの、あたい、どうしようかと毎日くよくよしているんだけど、おじさまだって判ってくれないもの。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "白くふやけた皮に、ちりめん皺が寄っているだけだった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通のものに較べて葉も小さく、花の茎も短く、殊に葉にはちりめんじわが寄つてゐる。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
