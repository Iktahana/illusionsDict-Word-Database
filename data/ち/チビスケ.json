        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「えっ」とかんぷりは眼をみはり、きおいこんでバケツの中から鮒をつかみあげ、――それはもっとも大きな一尾であった、――私のほうへと突き出しながら云った、「しょっからへいってみせえま、このくれえの鮒は一つで五ひゃくもすんだぞ、先生」　このちび助のユダヤ人め、と私は心の中で罵った。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいぬ　の　ちびすけ村山籌子　コイヌ　ノ　チビスケガ　タイヘンニ　イバツテ　ヤツテキマシタ。",
              "citation": {
                "source": "こいぬ　の　ちびすけ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天竺ねずみのちびすけ天竺ねずみのちびすけは、ちびだからふとっちゃいなかった。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "このぶた、ちびすけ　　　　（おなじく）一　このぶた、ちびすけ、市場へまいった。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　このぶた、ちびすけ、お留守番でござる。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　このぶた、ちびすけ、牛肉あぶった。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　このぶた、ちびすけ、なァんにももたなんだ。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　このぶた、ちびすけ、ういういうい。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、このちびすけをちっとはうやまう気持ちになりましたが、でもまあ、とにかくためしてやれ、と腹のなかで思いました。",
              "citation": {
                "source": "いさましい　ちびの仕立屋さん",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "このちびすけに、こんなことができようとは、どうしても信じることができません。",
              "citation": {
                "source": "いさましい　ちびの仕立屋さん",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、これで、あのバッタみたいなちびすけの息の根をとめたつもりでいました。",
              "citation": {
                "source": "いさましい　ちびの仕立屋さん",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは、こんなちびすけはどこか千マイルも遠くへいっちまえばいいのに、とひそかに思っていました。",
              "citation": {
                "source": "いさましい　ちびの仕立屋さん",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポケットにはいるくらい小さいというので、「ポケット小僧」とあだながついているのですから、そのちびすけが、まっ黒になったら、こんどはまめくろんぼです。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "のっぽの初こうは、目の前を、頭から足のさきまでまっ黒なちびすけが、ヒョコヒョコ歩いているので、びっくりしました。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "初こうは、しばらく、まめくろんぼのあとをつけてから、「こらッ、ちびすけ待てッ。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "のっぽの初こうは、身をかわされて、よたよたと前にのめりそうになりましたが、かけっことなれば、ちびすけなんかに負けるものではありません。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "のっぽとちびすけのかけっこですから、すぐにつかまってしまいそうですが、初こうが、ほんきで走ったら、たちまちいきすぎてしまいますし、ポケット小僧は追っつかれても、長い足のあいだをくぐって、チョコチョコと逃げまわるので、なかなかつかまるものではありません。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "のっぽの初こうも、すぐにその部屋にとびこみましたが、ちびすけは、どこへかくれたのか、いくらさがしても見つかりません。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおしいれの中も、さがしましたが、ちびすけのすがたはありません。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い外套に黒いちびすけですから、うすぐらい光では見わけがつきません。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
