[
  {
    "uuid": "f89a639c-3865-5c8d-be0d-038a96accf49",
    "entry": "珍奇",
    "reading": {
      "primary": "ちんき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
