[
  {
    "uuid": "0065ed80-189b-57b9-adc2-2e109966bf37",
    "entry": "チンドン屋",
    "reading": {
      "primary": "ちんどんや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
