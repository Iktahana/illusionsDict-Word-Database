    "definitions": [
      {
        "index": 1,
        "gloss": "bowl of rice topped with a chop-suey-like mixture",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三時すぎに銀座へ出て、山野と支那グリル一番でシウマイ、中華丼を食ひ、早く座へ出て、五月の絵看板の下絵や、歌ひ文句を書く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時に出て来々軒へ行き、中華丼とシュマイを食ひ、三時に本社へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "安くてうまい、といふのが来々軒、こゝは昔――震災前ほどではなくなったが、やっぱり分厚なものを食はせる、焼売など、又中華丼・雲呑がよろしかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一回終って、来々軒の雲呑と中華丼を食った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一回すんで、食ひ物で悩む、結局、中華丼に野菜スープ、久ずしのすし三四個食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひる済んで、中華丼食ひ、旬報の、五日に書いたのを又三枚足して書直す。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十番でシュウマイと中華丼、このまづさに呆れる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "来々軒のワンタンと中華丼。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「凸凹」の間に中華丼をかっ込む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "六時、地下室でまづいシウマイと中華丼を食って、座へ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くのクラブで一荘やり、浅草へのして、来々軒のワンタンに中華丼、王国の生駒のとこでハトヤの冷コーヒー、結局みやこのウイと、浅草を満喫し、酔ひの帰り。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから伊東とハマムラで、シウマイ、中華丼に雲呑を平げて、ＶＡＮへ寄り、みつ豆とコーヒー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に来々軒のシュウマイ食ひたくなり、浅草へ廻り、しゅうまいとワンタン、中華丼食ひ、ミルクの川田と白十字で茶をのみ、日暮里へ女房と清を迎へに行き一緒に帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
