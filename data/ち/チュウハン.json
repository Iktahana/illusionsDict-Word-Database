  {
    "uuid": "0e372aa9-c7a3-5566-888e-e9babbc7d400",
    "entry": "中飯",
    "reading": {
      "primary": "ちゅうはん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the noonday meal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "秀吉は気絶し、食事は喉を通らず、茶碗の上へ泣き伏して顔中飯粒だらけ、汁や佳肴をかきわけて泳ぐやうに泣き仆れてゐる。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日中飯を食わせないこともあるんです。",
              "citation": {
                "source": "林檎",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "掃除被仰付候節は、為中飯壱人に米七合宛被下之候由。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「私は、かつて、一日中飯も食わず、一晩中眠りもしないで思索にふけったことがあった。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを小中飯という漢字をあてる人もあるが、じっさいは昼飯またはヒルイイを、しゃれてチュウハンと言い出してから後の名である。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
