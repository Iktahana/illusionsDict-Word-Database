        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こんな小っこい僕でも、さて、寝込まれてみると不便であった。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆんべ八丁堀のほうにやって来たあのちっこい小娘が、まただんなを名ざしてたずねてきましたぜ」　名ざしといったものでしたから、ますますいぶかしさをおぼえまして、すぐと右門が立とうとすると、しかし伝六が押えていいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく、さっき駆け込み訴訟したちっこい野郎もぐるになって、何かひと狂言うったにちげえねえんだから、いっしょにぱんぱんと啖呵をきってしょっぴいてきな」「ちぇッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "このおひざもとで、上方流儀のねちっこいまねははやらねえぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「不意に、な、な、なんでおまっしゃろな」「その、なんでおまっしゃろなというせりふがねちっこいんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "……俺らとこだって……ちっこい者が出来ねえもんでもなかっぺ。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――南京虫にくわれねえだけでもハアちっこい者にゃ楽だよ。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっこいもんにさせるべえ。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっこいもんはここでよく育って俺のトラクターとソヴェトの守手にならにゃなんねえ。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなちっこい仕事に信仰なんて全然いらん。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっこい女のような足に、エナメル革靴を履いとった。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "小柄で敏捷、ちっこい黒眼の縮れ毛の男だ。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっこい目で、ネズミ毛髪の小男だ」　ボーイ長がすわ一大事と駆け寄り、わけを聞いたが無駄だった。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "背が低く太って、五〇、六〇歳、ちっこい黒眼、オウム似の小さな鉤鼻、頭はつる禿、黄色トマトのような色だ。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
