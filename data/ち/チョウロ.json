        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山頂では狸と兎が朝露を全身に浴びながら、せつせと柴を刈つてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "垣の竹の子きぬゝぎすてゝ、まき葉にかゝる朝露の新らしきを見るもいと恥かしうこそ。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "早朝、練兵場の草原を踏みわけて行くと、草の香も新鮮で、朝露が足をぬらして冷や冷やして、心が豁然とひらけ、ひとりで笑い出したくなるくらいである、という家内の話であった。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝露で、下駄がびしょぬれである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "バ……妖怪が……」　まだ薄暗い方丈の、朝露に濡れた沓脱石まで転けつまろびつ走って来た一人の老婆が、疎らな歯をパクパクと噛み合わせて喘いだ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆の中より、水際立って、美しく水浅葱に朝露置いた大輪の花一輪、白砂の清き浜に、台や開くと、裳を捌いて衝と下り立った、洋装したる一人の婦人。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三の烏　なぞとな、お二めが、体の可い事を吐す癖に、朝烏の、朝桜、朝露の、朝風で、朝飯を急ぐ和郎だ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "堤防を離れた、電信のはりがねの上の、あの辺……崖の中途の椎の枝に、飛上った黒髪が――根をくるくると巻いて、倒に真黒な小蓑を掛けたようになって、それでも、優しい人ですから、すんなりと朝露に濡れていました。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "清い、美しい、朝露に、旭に向って咲いたのだと人なみに思っていました。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝露にしつとりと濡れた花房を枝もたわゝに辛ふじて支へてゐる慎ましく上品な萩。",
              "citation": {
                "source": "秋の七草に添へて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよはその一房一房の朝露を白いエプロンで手早く拭きとつて、下の籠にいれた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、もう老い朽ちてしまえば山へも行かれず、海へも出られないでいますが、その代り小庭の朝露、縁側の夕風ぐらいに満足して、無難に平和な日を過して行けるというもので、まあ年寄はそこいらで落着いて行かなければならないのが自然なのです。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝露の林を分けて、塒を奥山へ出たと思いねえ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓硝子には濤の横腹を押しつけたように欅の若葉がべっとり朝露で粘りついています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みると「さあ、これでお前達の願望はかなつた」　ささげの秘曲　朝露が一めんにをりてゐました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君は、白骨も戻すと極り、夜が明けると、ぱっと朝露に開いた風情に元気になって、洗面の世話をしながら、縁側で、向うの峰を見て顔を洗う小松原に、「昨晩はお楽み……なぜって。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の火は朝露に晃々と、霧を払つて、満山の木の葉に映つた、松明は竜田姫が、恁くて錦を染むる、燃ゆるが如き絵の具であらう。",
              "citation": {
                "source": "貴婦人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "月待草に朝露しとど湿った、浜の芝原を無邪気な子どもを相手に遊んでおれば、人生のことも思う機会がない。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰まで裾を端しょってな、素っ膚足に朝露のかかるのはえいもんさ、日中焼けるように熱いのも随分つれいがな、其熱い時でなけりゃ又朝っぱらのえい気持ということもねい訳だから、世間のことは何でもみんな心の持ちよう一つのもんだ。",
              "citation": {
                "source": "姪子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "みちの芝が人に踏まれても朝露によみがえるとかいう意味の、前にも幾度か聞かされた都々逸であるが、その時だけは、いつものような閉口迷惑を感ぜず、素直に耳傾けて拝聴したのだから奇妙なものだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏は身にしむように思って、朝露と同じように短い命を持つ人間が、この世に何の慾を持って祈祷などをするのだろうと聞いているうちに、「南無当来の導師」　と阿弥陀如来を呼びかけた。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "小母さんのいちばん機嫌のよいのは薔薇の花に、しつとりと朝露の含んだ頃です、その時だけは、小母さんは晴ればれとした顔をして、花園の中を歩るき廻ります。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "深樹の緑に置いた朝露はキラ／＼と美しく光つた。",
              "citation": {
                "source": "耶馬渓の一夜",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには華手なモスリンの端切れが乱雲の中に現われた虹のようにしっとり朝露にしめったまま穢ない馬力の上にしまい忘られていた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな、ちょうろぎのようなの、やっぱりあるのかしら……」　それから程もない或る夕方、ガラリと格子をあけて紙包をかかえた妹が入って来た。",
              "citation": {
                "source": "似たひと",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
