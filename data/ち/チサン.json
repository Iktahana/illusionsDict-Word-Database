[
  {
    "uuid": "b17fb59d-8ec9-50e3-88e3-5f4bb4fa51d9",
    "entry": "治産",
    "reading": {
      "primary": "ちさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
