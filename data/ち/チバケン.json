    "definitions": [
      {
        "index": 1,
        "gloss": "Chiba Prefecture (Kanto area)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
