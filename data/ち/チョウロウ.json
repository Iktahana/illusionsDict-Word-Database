[
  {
    "uuid": "28e83faf-07e4-5496-bd9f-ae74c6dfc5e8",
    "entry": "長老",
    "reading": {
      "primary": "ちょうろう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
