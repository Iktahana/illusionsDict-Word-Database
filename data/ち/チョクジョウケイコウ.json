    "definitions": [
      {
        "index": 1,
        "gloss": "impulsive and straightforward",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "外交官にしては直情径行に過ぎ、議論の多い規矩男の父の春日越後は、自然上司や儕輩たちに好かれなかった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "直情径行のＷ・Ｅ・ヘンレイ（ガルバルジイ将軍を詩人にした様な男だ）が真先に憤慨した。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良原到翁はその極端な清廉潔白と、過激に近い直情径行が世に容れられず、明治以後の現金主義な社会の生存競争場裡に忘却されて、窮死した志士である。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人間と人生を観る眼が、何物にも蔽ひかくされずに鮮かで明かであつたかといふことは疑問だが、直情径行な、天真爛漫な、他人に対して城府を設けないといふやうな紳士らしい処があつた。",
              "citation": {
                "source": "尾崎紅葉とその作品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "大杉は直情径行でスパイの勤まる柄ではない。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、直情径行をもって、政界を切って廻したこの老政治家はそれだけの余裕も見せなかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば直情径行は大和心の美しい特質の一つであるが、近ごろの世の中のどこを見てもそのようなものはない。",
              "citation": {
                "source": "余裕のことなど",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "直情径行といえばすぐに私は宇治川の先陣あらそいでおなじみの梶原源太景季を想い出す。",
              "citation": {
                "source": "余裕のことなど",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "正に直情径行の見本のごとき観がある。",
              "citation": {
                "source": "余裕のことなど",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがつて直情径行は嘲笑と侮蔑の対象でしかなくなる。",
              "citation": {
                "source": "余裕のことなど",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "直情径行で妥協ぎらいで廉潔なカールは、イエニーから見れば本当に巨人的な子供であった。",
              "citation": {
                "source": "カール・マルクスとその夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人になりきった人は、少年から青年期の無思慮な思い出にたいしてさえも微笑むのだけれども、いままさに十七歳であり、少年と青年とのあいなかばした成長の過程にあるものが、直情径行に願うことは何であろう。",
              "citation": {
                "source": "現代の主題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は直情径行で、美しいことは美しく、泣きたい時に泣き、愛すれば心も身もその愛にうちこむ日本人の感情が現われている。",
              "citation": {
                "source": "女性の歴史",
                "author": "――文学にそって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "エミール・ヤニングスが映画のオセロに扮したとき、彼はそのもち味で、黒人の英雄であるオセロの直情径行の素朴な人間性とデスデモーナへの情熱の面を強調した。",
              "citation": {
                "source": "デスデモーナのハンカチーフ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "是は柏軒の直情径行礼法に拘らざる処より来てゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "久保井校長のつぎにきた熊田校長というのはおそろしく厳格な人であった、久保井先生は温厚で謙遜で中和の人であったが、熊田先生は直情径行火のごとき熱血と、雷霆のごとき果断をもっている。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "破壊的政策は彼が畢生の経綸にして、直情径行は彼が一代の性行なりき。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "然りと雖も、彼は唯、直情径行、行雲の如く流水の如く欲するがまゝに動けるのみ。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗馬は、颯爽として、男性的で、直情径行で、ひねくれたくよくよしたものを排除する。",
              "citation": {
                "source": "牛乳と馬",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅幇とは、強盗、無頼漢等にて成り、その仕事も直情径行的に頗る荒っぽくやっつける方で、青幇には一度この紅幇の仲間に入って実務でウンと腕っ節を叩き上げたものがその大多数を占めて居る。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "直情径行は今も昔も医し難き余の病なりしかば、数ば大声を発し、論戦若し危きに及べば所謂横紙破りの我慢をも言出だしき。",
              "citation": {
                "source": "透谷全集を読む",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、有体に申しますと、弟は直情径行の人間である。",
              "citation": {
                "source": "弟を葬る",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "三浦さんは非常に、直情径行の人で、自分の感情をありのままに表現する。",
              "citation": {
                "source": "三浦環のプロフィール",
                "author": "吉本明光",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四十年十一月）　　　伯爵　板垣退助　　　　　板垣退助　世に伝ふ、板垣伯は両面ある人物なり外は直情径行なるに似て内は反つて険怪隠密常に赤誠を口にして善く慷慨すれども、身を処するに巧詐あり世を行くに曲折あり、圭角ある如くにして圭角なく、平板なる如くにして表裏あり然れども余の彼れに見る所は別に是れあり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の性格には直情径行といった一面があり、寧ろ私は彼の本性がそうさせたのだといいたい。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "直情径行のエセックスにそのような狡猾な行動がとれようなどとは夢にも考えられないことではないか。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "中野は、これとくらべると徹頭徹尾、直情径行であり、知的感覚においてもはるかに深く鋭いものを持っていながら、彼の内にひそむ改革者的情熱は、しばしば激情にまかして飛躍するとともに、自ら進んで窮地に陥ることを避けるだけの余裕と術策とに欠けていた。",
              "citation": {
                "source": "叛骨・中野正剛",
                "author": "――主観的な覚え書き",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんは何という直情径行の、そして一面弱い方でしょう！",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、いわゆる直情径行の人とか、活動家などが生活の資としているような、あの程度の意識があったら、十分なのである。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな連中は、まるで猛り立った牡牛のように、角をぐっと下のほうへ傾けながら、まっしぐらに目的を指して突進するので、壁にでもぶっつからない限り、引き止めることはできない（ついでにいっておくが、こんな連中、つまり、直情径行の人だの活動家だのは、壁にぶっつかると、真っ正直に兜をぬいでしまうのである。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
