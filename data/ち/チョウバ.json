[
  {
    "uuid": "a469bd64-eb3c-577a-a0c5-d882010044b0",
    "entry": "帳場",
    "reading": {
      "primary": "ちょうば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(hotel) reception",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんなら、もっと早くから言えば何か方法もあったのに、いまさら、そんな事を言い出しても無理だとは思ったが、とにかく私は控室から料理屋の帳場に電話をかけた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭狹きまでに散り亂れさしも竝びし家財等の一つ一つに處えて二度もとの店の中帳場格子の間より手習雙紙見る頃を。",
              "citation": {
                "source": "煤掃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそばやの帳場の人たちに實状をさとらせたくないので、「ヘルプ！",
              "citation": {
                "source": "郷愁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなに云うんだったら、帳場に行ってチャンを連れて来い」　と女房たちが子供に云った。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々は、此處へ來たときからの約束で暫時帳場の横へ移轉することになつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「花柳街のセット」「宿屋の帳場」「河原の剣劇」「御寺の前の追駆け」「茶屋の二階の障子の影法師」それから……。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューヨークで安ホテルを捜しあてたときに帳場に居たのっぽの番頭がやはりチューインガムを噛んでいた。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝帳場では　又大騒ぎである。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒屋の裏へはいって、格子の外からおみよの家の様子を一応うかがって、それから家主の酒屋をたずねると、御用で来た人だと聞いて、帳場にいた家主も形をあらためた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　酒屋で帳場に居あわせた亭主が庄太の顔をみて丁寧に挨拶した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母が履物をそろえてる間に彼女帳場の方をちらと見ます。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣屋はこの辺に棟を並ぶる木屋の大家で、軒、廂、屋根の上まで、犇と木材を積揃えた、真中を分けて、空高い長方形の透間から凡そ三十畳も敷けようという店の片端が見える、その木材の蔭になって、日の光もあからさまには射さず、薄暗い、冷々とした店前に、帳場格子を控えて、年配の番頭が唯一人｜帳合をしている。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "投げた時、偶と渠は、鼓打である其の従弟が、業体と言ひ、温雅で上品な優しい男の、酒に酔払ふと、場所を選ばず、着て居る外套を脱いで、威勢よくぱつと投出す、帳場の車夫などは、おいでなすつた、と丁と心得て居るくらゐで……電車の中でも此を遣る。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段を上って右側に帳場がある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はいつでもこの帳場の前を通ってまずドイツ書のある所へ行く。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が降って浜へも出られぬ夜は、帳場の茶話に呼ばれて、時には宿泊人届の一枚も手伝ってやる事もある。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう云う淋しい夜にはと帳場へ話しに行った。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってこの下宿の帳場に坐っていつもいつも同じように長い煙管をふすべている主婦ともガラス障子越しの御馴染になって、友の居ると居ないにかかわらず自由に階段を上るのを許されていた。",
              "citation": {
                "source": "雪ちゃん",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帳場で番頭や手代や、それからむすこのＳちゃんといっしょに寄り集まっていろいろの遊戯や話をした。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊本で漱石先生に手引きしてもらって以来俳句に凝って、上京後はおりおり根岸の子規庵をたずねたりしていたころであったから、自然にＩ商店の帳場に新俳句の創作熱を鼓吹したのかもしれない。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二の故郷の一つであったＩの家はとうの昔に一家離散してしまったが家だけは震災前までだいたい昔の姿で残っていたのに今ではそれすら影もなくなってしまい、昔｜帳場格子からながめた向かいの下駄屋さんもどうなったか、今｜三越のすぐ隣にあるのがそれかどうか自分にはわからない。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ宵のうちは帳場の蓄音機が人寄せの佐渡おけさを繰り返していると、ぽつぽつ付近の丘の上から別荘の人たちが見物に出かけて来る。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは小さな女の子など、それに帳場の若い人たちが加わって踊っているうちに、だんだんにおとなも加わって、いつとなしに踊りの輪が丸くつながる。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかっぱに洋装の女の子もあれば、ズボンにワイシャツ、それに下駄ばきの帳場の若い男もある。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルの帳場で勘定をすませて玄関へ出て見たら灰が降り初めていた。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし、尾崎紅葉もここへ泊ったそうで、彼の金色夜叉の原稿が、立派な額縁のなかにいれられて、帳場の長押のうえにかかっていた。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんも、仲々の働き者らしく、いつも帳場に坐って電話の注文を伺っては、てきぱき小僧さんたちに用事を言いつけて居ります。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、こっそり帳場へ行って、このたびの祝宴の出費について、一切を記して在る筈の帳簿をしらべた。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帳場の叔父さんの真面目くさった文字で、歌舞の部、誰、誰、と五人の芸者の名前が書き並べられて、謝礼いくら、いくらと、にこりともせず計算されていた。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まあ、そんなに、私たち、ちょうばかりだったのですか。",
              "citation": {
                "source": "冬のちょう",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
