        "examples": {
          "standard": [
            {
              "text": "紛争の**長期化**は、現地住民の生活をさらに困難にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "経済不況の**長期化**が、企業の倒産件数を増加させている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この交渉の**長期化**は避けたい。早く決着をつけよう」と担当者は焦っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "さてと、対日戦だが、だんだん長期化するのは困るね。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
