[
  {
    "uuid": "6e35340a-b8b9-5ff7-8e9d-af44648dcc12",
    "entry": "知人",
    "reading": {
      "primary": "ちじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
