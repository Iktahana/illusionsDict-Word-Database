  },
  {
    "uuid": "a7ec6944-260d-5050-8c17-910fb1cd73b6",
    "entry": "地神",
    "reading": {
      "primary": "ちじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gods of the land",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "噴火を地神の慟哭と見るのは適切な譬喩であると言わなければなるまい。",
              "citation": {
                "source": "神話と地球物理学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その意味からいうと、美々しい女や華奢な男が、天地神明を忘れて、当面の春色に酔って、優越な都会人種をもって任ずる様や、あるいは天下をわがもの顔に得意にふるまうのが羨ましいのです。",
              "citation": {
                "source": "虚子君へ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、天地神明に誓うのは、貴女の淑徳と貞潔である。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して彼をして天地神明に対して、極めて真面目なるものとならしめたり。",
              "citation": {
                "source": "心機妙変を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "話が一々脱線し過ぎておりますからね……のみならずこの話は、谷山家の内輪でも絶対の秘密になっておりますので、御存じの無いのは御尤も千万ですが、しかし私は天地神明に誓ってもいい事実ばかりを、申上げているのです。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "秦主｜苻堅猛を侍中とせし時猛独りこれを賛し、にわかに地神の縁起譚だがその出処が解らぬ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "他は、幅も底も測知られぬ、山の中を、時々すっと火の筋が閃いて通る……角に松明を括った牛かと思う、稲妻ではない、甲虫が月を浴びて飛ぶのか、土地神が蝋燭点けて歩行くらしい。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリスト教は古宗教の善悪の諸竜を混同して、一斉にこれを邪物とせり、かくて上世の伝説外相を変えて、ミカエル尊者、ジョージ尊者等、上帝に祈りて竜を誅した譚となり、以前ローマの大廟に窟居して大地神女を輔け人に益した神蛇も、法王シルヴェストル一世のために迹を絶つに及べり。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "チユナールの一橋は何度かけても落ちたから、梵種の娘を其地神に牲にし、其れがマリー乃ち其處の靈と成り凶事ある毎に祭られる。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "去れば歐洲が基督教に化した後も人柱は依然行はれたので、此教は一神を奉ずるから地神抔は薩張りもてなくなり、人を牲に供えて地神を慰めるてふ考へは追々人柱で土地の占領を確定し建築を堅固にして崩れ動かざらしむるてふ信念に變つたとベ氏は説いた。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地神明も照覧あれ、わたくしの心事は公明正大であると、先生は云つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "近い話が――これあもう、天地神明に誓つての話ぢやが――あなた方にしてからが、ほんたうにはなさるまいけれど、ある時、ちよつと＊妖女の話をしたところ、どうぢやらう？",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "則天地神明の知る所なり。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年九月初旬　佐々木高行あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天地神明に誓って偽でない事を断言します」　保命館を出て駿河台下の方へ来かかると折柄、そこの大時計は十時を打ち出した。",
              "citation": {
                "source": "真珠塔の秘密",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば女人の御身として、かかる濁世末代に、法華經を供養しましませば、梵王も天眼を以て御覽じ、帝釋は掌を合せてをがませたまひ、地神は御足をいただきて喜び、釋迦佛は靈山より御手をのべて、御頂をなでさせ給ふらん、南無妙法蓮華經南無妙法蓮華經。",
              "citation": {
                "source": "尼たちへの消息",
                "author": "――よく生きよとの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "はかばかしき下人もなきに、かかる亂れたる世に、此殿をつかはされたる心ざし、大地よりもあつし、地神もさだめてしりぬらん。",
              "citation": {
                "source": "尼たちへの消息",
                "author": "――よく生きよとの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "康頼は何でも願さえかければ、天神地神諸仏菩薩、ことごとくあの男の云うなり次第に、利益を垂れると思うている。",
              "citation": {
                "source": "俊寛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかおれはあの男が、海へ卒塔婆を流す時に、帰命頂礼熊野三所の権現、分けては日吉山王、王子の眷属、総じては上は梵天帝釈、下は堅牢地神、殊には内海外海竜神八部、応護の眦を垂れさせ給えと唱えたから、その跡へ並びに西風大明神、黒潮権現も守らせ給え、謹上再拝とつけてやった。",
              "citation": {
                "source": "俊寛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "まざまざとして、映じてくる網膜の上の斉彬は――ある時には、空間に引立てられて、全身が歪み、ある時には、地下へ翻々として落下しながら、恐怖の眼を見開き――それは、天魔、地神に虐げられている、牧の呪いの力によって、斉彬の体に感応した結果を現す形であった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中、九州一円に居た地神盲僧と称する琵琶弾き――師の房など称する――の演芸種目の中にも、此が重いものとなつて居るのが「八島」であつた。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「我すでに地神に請えり、全国通過を許されたり」「汝橋を過ぎたるや否や？",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは昔の神前あるひは君候の前に、敬意を表する名残であつて、今日では無用のやうだが、私はこれを天地神明に祈祷し奉る心で行つてゐる。",
              "citation": {
                "source": "よくぞ能の家に",
                "author": "二十四世　観世左近",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤後世になつては、地神のよりしろをも木や柱の尖に結び附けたことはあつたが、古代人の考へとしては、雲路を通ふ神には、必或部分まで太陽神の素質が含まれて居たのであるから、今日遺つて居る髯籠の形こそ、最大昔の形に近いものであるかと思ふ。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其はとにかく、此神が、兇暴な神である様に見られたのは、八幡神自身が、兇暴と言ふよりも、西から上つて来る途中、其土地々々の、兇悪な土地神を征服して、此を部下にして行つた、其為だと思はれる。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は、この夏川ヤス子も、必ずやモノにしなければならぬと天地神明に誓いをたてた。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は、この小動物も、万苦をしのび、いつの日かモノにする折がなければ、生れいでた主意がたゝぬと、堅く天地神明に誓いをたてた。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、堅く天地神明に誓いをたてて御婦人を追い廻しても、悟らざること甚しく、恋いこがれ、邪推し、千々に乱れて、あげくには深酒に浮身をやつす哀れなキリギリスにすぎなかった。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことをするぐらいなら、はじめから天地神明に誓いをたてやしないのである。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの強調法は、心の最も眞率不二の場合、即ち天地神明に對しまつる神祇歌、天皇に對しまつる賀の歌の場合に多く用ゐられて居る。",
              "citation": {
                "source": "愛國百人一首評釋",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
