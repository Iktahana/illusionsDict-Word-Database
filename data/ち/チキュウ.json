[
  {
    "uuid": "9c4744cd-3523-537b-a244-1cc2fb00ca26",
    "entry": "地球",
    "reading": {
      "primary": "ちきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
