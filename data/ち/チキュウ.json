    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Earth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「此の地球以外にも、人間が住んでゐるでせうか」と訊ねると「ゐません、絶対にゐません！",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人がその空想の中で画くような、ファンタスチックな夢の国は、現実の地球上にあるはずがない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲があたしを連れてくのです……さよなら地球よ、さやうなら！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "句の表現するものは、夏の炎熱の沈黙の中で、地球の廻転する時劫の音を、牡丹の幻覚から聴いてるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道路みな霜に凍りて冬の凜烈たる寒氣の中地球はその週暦を新たにするか。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年　　新年來り、新年去り、地球は百度※轉すれども、宇宙に新しきものあることなし。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球物理談話会もほんの五、六人の仲間であったが、その中にまだ若いコールシュッター氏も交じっていた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気象や地球物理に比べて地理の方は輪講にも講義にも出席者が多く気分がまるで変っていた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気象輪講会は何となく上品にのんびりしていたし、地球物理輪講会は生真面目でしかも家族的な気分であったが、地理の輪講会には何となく物々しい人間臭い気分があった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の冬学期には上記の先生方の外に、ヘルメルトの「地球の形」やオイゲン・マイヤーの「航空に関する応用力学」などを聴いた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは地球から見た時に太陽が天球のどこに来ているかという事を意味するだけの事であるから、太陽系に何か大きな質量の変化が起こるか、重力の方則が変わらない限り、予定のとおり進行してゆくはずである。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "春という言葉が正当な意味をもつのは、地球上でも温帯の一部に限られている。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、その時は、地球の表面に存在するもの悉くに、其の持主の名札が貼られ、一坪の青草原さへ殘つてなかつた。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなが地球を分け合つて居るとき。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「地球はみんな呉れてしまつた。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士くらい大詩人を持った山が、地球上のどこに存在しているだろう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちに待った朝は来た、朝がいかなる方面から、いかに忍び足に寄って来て、一秒ずつ額を白くしたかは徹夜凝視しても解らない、夜と朝の筋目が判然と目立つほどなら、地球の緯度線が草鞋の爪先に引っかかるわけである、しかも争う可らざるは朝の神秘なり、一たび臨むとき、木偶には魂を、大理石には血を与る。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、四十年目の暑さに、地球がうだって、鮒共が総て目を白くして浮び上ったと思うことは、それは間違いであった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りの汽車で陰暦十四日の月を眺めながら一行の若い元気な学者達と地球と人間とに関する雑談に汽車の東京に近づくのを忘れていた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ティアガルテンの冬木立や、オペラの春の夜の人の群や、あるいは地球の北の果の淋しい港の埠頭や、そうした背景の前に立つ佗しげな旅客の絵姿に自分のある日の片影を見出す。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾等が棲む地球はその姉妹なる諸遊星と独楽のように廻りながら太陽の周囲を不断週遊しているのであると講釈する。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海も陸地も地球と一緒に凄まじい速度で太陽のまわりを飛んでいる。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽はまた地球その他の遊星を率いて天の一方リーラ星座に向って突進している。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しずつと云うのは遠い地球から見て云う事で実は驚くべき速度で動いている、がどの星もみなリーラ星宿から外へ向いて散開しつつあるように見える。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあの小さな美しい星が我が地球の何百万倍も大きな火の玉で、それが何万となき群になって無辺の宇宙の果から果に測り難い使命を帯びて急いで行くのだと考えると、一種妙な心持になるのである。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "槓杆の効用は人の知る通り、昔の力学者が「適当な支点を与えてくれれば地球もころがして見せる」と威張ったのは槓杆の効能を極端に云ったものである、だから適当な槓杆と支点を与えれば虻の力で大象も動く、美人の繊手で横綱も釣上げられる。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この白い部分が時期によってあるいは大きくあるいは小さく消長するので、これは多分我が地球と同様に両極は雪で蔽われているのだろうという事になっている。",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら何がその川の水にあたるかと云ひますと、それは真空といふ光をある速さで伝へるもので、太陽や地球もやっぱりそのなかに浮んでゐるのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもの太陽がこのほゞ中ごろにあって地球がそのすぐ近くにあるとします。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば「落体がある場所で九・八メートル／秒秒の加速度をもって垂直に落下する」というのでも、実は地球の重力のみ働き空気の抵抗や電気磁気などの作用がないとした場合の事である。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
