    "definitions": [
      {
        "index": 1,
        "gloss": "thirst for knowledge",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私どもの知識欲は、この荘厳にして視神経を刺戟する程度の強さが、容積の大から来るそれに匹敵する山岳に対して、もう少し、微細に深刻に入って見たい。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その不可解な絵が妙に未知の不思議の世界に対する知識欲を刺戟しそれがいつとなく植物学全体への興味を煽るのであった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもこの失敗した試みが自分の理学的知識欲を刺激する効果のあっただけは確かである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "食うという事は知識欲とともに当時の最大の要事であったのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく知識欲の強い人である。",
              "citation": {
                "source": "二人の友",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、オランダの事物、学術、ことに医術に対する知識欲に渇えながら、妙な意地から、心のままに質問することができなかった。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言って、わたし自身も、またわたしの一家も、直接に鳥屋の熊吉氏と何の交渉を有していたのではないが、劇というものに対して少年時代のわたしの知識欲を満足させてくれたのは、かの鳥熊氏の賜物であることを感謝しなければならない。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "知識欲を滿足させたい要求が、かなりに高度だとしても、ほかのものでもいいわけだらう。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ知識欲を滿したいといふ、渇くやうな純粹な望みだけなのだから。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "健康な清新な純粹な、喘ぎ求めるやうな知識欲は遂にもはやいかな刺※によつても喚起さるることがないか、あるひは甘んじてその欲求を他の諸々の欲求と交換してしかも尚依然として學生服を身につけてゐなければならないといふ大學生達。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "知識欲は書物を食つて生きてゐるやうな生活の中に於てのみ、純粹に保たれ、絶えず新鮮に喚起されると考へたならば間違ふだらう。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ生活のなかでは屡々知識欲も亦變態的であつたり、頽廢的であつたりする。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし青年達のかうした知識欲の行末は？",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等がどんなにものを知りたがつてゐるか、しかしその知識欲は方向を與へられてゐない。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "元來知識欲は一般にさういふ風にして發現するものなのだ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿介は彼等の知識欲に方向を與へ、少しづつでも現實にこれを滿して行くために、自分が何かしなければならぬと思つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵のイズムはこの点において、実生活上の行為を直接に支配するために作られたる指南車というよりは、吾人の知識欲を充たすための統一函である。",
              "citation": {
                "source": "イズムの功過",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "知識欲のさかんな若い人々、レーニンが云っているように向上心にもえ、階級の武器として、あらゆる知識をもちたいと思っている優秀な労働者たちが、その知識慾を餌じきにされて、きたならしい饒舌、ダイジェスト文化に、時間と金を吸いとられ、頭脳をかきまわされるのは何とくちおしいことでしょう。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若々しい知識欲が何か求めて本気で本を見る眼差しは、ただ商品を視線で撫でてすぎるのとはちがう、おのずからなはた目の快さをも誘うのが自然だと思う。",
              "citation": {
                "source": "祖父の書斎",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそは青春のかえがたい贈物である知識欲や成長への欲望、よりよい生活へ憧れるみずみずしい心の動きは、現実にぶつかって、一つ一つその強さを試みられているわけだが、その現実は、青春の思いや人間の成長をねがう善意に対して、何と荒っぽい容赦ない体当りをしばしばくらわせることだろう。",
              "citation": {
                "source": "ものわかりよさ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは学習院の学生達のみち足りた境遇では、知識欲も、珍しさの味――落語にある「目黒の秋刀魚」に類するものか、と、三十数年前の講演で彼が語った、そのことである。",
              "citation": {
                "source": "日本の青春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "リベディンスキーは、この「英雄の誕生」において、生物としての人間が社会的な階級人として成長をとげた歴史的な現代のソヴェトでは人間本能＝性的慾求、食欲、知識欲という諸要素をどんな自主性と社会的見とおしで処理しようとしているかという事実について初歩的な理解と共感さえもっていないような態度を示した。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども好奇心は眞の研究心、眞の知識欲とは違つてゐる。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年が新刊書を喜ぶということはその知識欲の旺盛を示すものであって排斥すべきことではないが、しかしそこにはまた単なる好奇心の虜になる危険もあるのである。",
              "citation": {
                "source": "如何に読書すべきか",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人と一しょに居残った山田は、頻りに知識欲に責められるという様子で、こんな問を出した。",
              "citation": {
                "source": "食堂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の知識欲とそれに対する憧憬は、限りなく続いてゐた。",
              "citation": {
                "source": "惑ひ",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自分の知識欲と創作欲とを私の微力の許す限り充実させることに力めて来た。",
              "citation": {
                "source": "鏡心灯語　抄",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生や職場の大衆が知識欲をみたすための罪のないサークルや読書会をもっても二十九日、又それをむしかえしての拘留を食う。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども好奇心は真の研究心、真の知識欲とは違っている。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めてとり組むものとして、筋よりも何よりもまづ、てまだの思想だのが問題になつたやうだが、其は作者側にも責任はあつたらうが、見物も亦、作者との間の、芝居の黒幕の彼方を、一返に諒会しようと言ふ知識欲に駆られ過ぎてゐると思つた。",
              "citation": {
                "source": "「なよたけ」の解釈",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
