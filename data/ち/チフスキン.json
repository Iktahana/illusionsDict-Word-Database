        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "シラミはチフス菌を背負って歩いていた。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらは結核よりもチフス菌よりも怖ろしいのだ。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも細菌の内容たるやコレラ菌、チフス菌といったしろものだ。",
              "citation": {
                "source": "オフ・ア・ラ・コック・ファンタスティーク",
                "author": "――空想半熟卵――",
                "note": "青空文庫"
              }
            },
            {
              "text": "細菌は1880年にエーベルト（1835-1926）によって発見されチフス菌と名付けられた。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の年にエーベルトとガフキーは腸チフス菌を発見し、ハンセンはハンセン病の病因菌、ラブランがマラリア原虫を発見した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "文明はマラリア原虫から退却し軍隊はコレラ菌、赤痢菌、腸チフス菌の殺人によって粉砕された。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍の威信にかけても、どうしても従業員の便の中からチフス菌を出そうというのだ。",
              "citation": {
                "source": "肝臓先生",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついにチフス菌は現れなかった。",
              "citation": {
                "source": "肝臓先生",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍の威信をもってしても、健全なる人体からチフス菌をとりだすことは不可能だという平凡な事実が証明されただけである。",
              "citation": {
                "source": "肝臓先生",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
