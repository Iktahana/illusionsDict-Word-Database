          "literary": [
            {
              "text": "出さぬと、はさみでちょん切るぞ。",
              "citation": {
                "source": "猿かに合戦",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ならぬと、はさみでちょん切るぞ。",
              "citation": {
                "source": "猿かに合戦",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "姪のお辰も当然疑いの圏内に入るべきですが、二十一になる華奢なお辰では、虫一匹｜潰すのさえむずかしく、大の男の首をちょん切ることなどは、どう考えても出来ないことです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "遺言状",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうちぎることも、便利なようにちょん切ることも出来っこありません。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの鎌とはさみで、地上にはえた二つの首を、草でも刈るように、ちょん切るつもりかもしれない。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしがわたしのものを持ち去るとき、自分で自分の巾着をちょん切るとき、わたしは窃盗取締令をみだすことにはなるまい。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まさかわしたちの首をちょんぎるようなこともあるまい。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            }
          ]
        }
