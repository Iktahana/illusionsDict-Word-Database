[
  {
    "uuid": "b4b3ebd7-56b4-55b0-b4ab-c56dfec85a1e",
    "entry": "着手",
    "reading": {
      "primary": "ちゃくしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
