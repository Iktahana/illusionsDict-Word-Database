          "literary": [
            {
              "text": "それからの数分が爽快でね、力押しのごろつきに対し、左の正拳だ。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十近い、練達な御用聞ですが、聞き込みと力押しで通して來た男で、少しむづかしい事件になると、手も足も出なくなる癖があります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青錢と鍵",
                "note": "青空文庫"
              }
            },
            {
              "text": "本郷一丁目は眞砂町の喜三郎の繩張りですが、若くて力押しの喜三郎に任せて置くにしては、事件があまりにも重大らしい豫感があつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "三つの死",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう力押しのくりかえしはこけなことだ。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
