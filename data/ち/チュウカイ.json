[
  {
    "uuid": "5e7a5930-20fa-5d5d-b094-d2a087982f71",
    "entry": "仲介",
    "reading": {
      "primary": "ちゅうかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
