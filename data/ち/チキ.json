[
  {
    "uuid": "5ce1971b-b0c4-5b8e-8f5a-2a5f55ab9aa1",
    "entry": "知己",
    "reading": {
      "primary": "ちき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
