        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "うめきながら熱冷ましの座薬を使いますが、チューニングの狂ったオーケストラが、ばらばらのメロディーをフォルテシモでがなりたてるような狂騒の宴は、そこからさらに一時間近く続きました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ当時のオレはチューニングという概念を持っておらず、Ａの音を四百四十ヘルツに合わせる気がないのはもちろん、二弦の五フレットを一弦の開放に合わせる気もなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "坐って弾くのだろう、という慶一の予想をうらぎって、片桐はゆっくりと、黒革の幅広のストラップをかけ、立ったまま素早くチューニングして、速いパッセージを弾きはじめた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲じゃない」　といって、片桐はまたペグに手をやり、チューニングをなおす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "片桐はまったく無関心で、チューニングをしている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョンが、素早くチューニングして、マイクに近づき、無造作にコードをストロークして、歌いだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "チューニングが合っていない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "チューニングは、はじめから８１０になっていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "チューニングしてから、受話器をとりあげた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "チューニングだ」「うん」　畳のうえの電話を、机に乗せた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "手ぎわよくチューニングをおえ、演奏がはじまった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも、遠く離れた人々の心にチューニングしようとでもいうかのように。",
              "citation": {
                "source": "いえ、いえ、ラゴーフにはもう！",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
