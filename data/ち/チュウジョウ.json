[
  {
    "uuid": "aac52484-620a-561a-9dc8-1c7bed15c664",
    "entry": "中将",
    "reading": {
      "primary": "ちゅうじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
