        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ギラギラする光の中から、地下室の監房のような船室へ、いきなり飛び込んだ彼は、習慣に信頼して、ズカズカと皿箱をとりに奥へ踏み込んだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野へついて地下室の大阪料理で夕食を食つた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしないと、おしまひには米や大根を地下室の棚で作らなければならない事になるかも知れない。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森から乗った寝台車の明け方近い夢に、地下室のような処でひどい地震を感じた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピタゴラスはイタリーで長い間地下室に籠っていた後に痩せ衰えて骸骨のようになって出て来た。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下室にいた間は母にたのんで現世の出来事に関する詳細なノートをとって、それを届けてもらって読んでいたという話も伝えられている。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下室の物置部屋へ行く隧道が著しい反響を示すことは彼の『音響学』に書いてある。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下室の中に作った天秤室の空気を乾かすのに、毛布を使ったりしたところにレーリーの面目が現われている。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧騒の声が地下室に充ちて向き合っての話声も聞取れなくなった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで或る街の深夜に、ぐでぐでに醉つて死場所を探してゐる不幸な紳士が、場末の薄暗い地下室で、チャップリンの扮してゐる乞食ルンペンと邂逅する。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那のフオックス・トロットが劇場の地下室の踊場から聞えてきた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妾、朝からまっていたのです」　やがて暫しの後、彼女の後姿が、混合酒の触感を撒いて廊下から消えると、私は地下室の湯殿で未来を夢みる。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球の地下室では切開された、メロ・ドラマの開演のベルがけたたましく鳴りひびくのだった。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下室の踊場では、タキシードの男と、夜会服から黄色い腕をだした踊子とが胸と胸の国境をデリケートな交錯で色どりながら踊った。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人がポプラの林の間を拔けて、修道院の建物に近づいた時、地下室から聲高な祈祷の聲を聞いた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階へ上るとようよう地下室から一階へ上った来たような気がした。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　何故、憲兵隊へつれて来られたか、その理由が分らずに、彼は、湿っぽい、地下室の廊下を通って帰るように云われた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし現に丸の内の元警視庁跡に建築されることになっている第一相互の新館は地下六十尺に基礎をすえ、地下室が四階になるはずだそうで、いわば私の夢の一端がすでに実現されかけたように見える。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空腹の大學生たちは、地下室の大食堂からあふれ、入口よりして長蛇の如き列をつくり、地上にはみ出て、列の尾の部分は、銀杏の並木のあたりにまで達してゐた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空腹の大学生たちは、地下室の大食堂からあふれ、入口よりして長蛇の如き列をつくり、地上にはみ出て、列の尾の部分は、銀杏の並木のあたりにまで達していた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに少年の方から附き纏って離れなくなってしまうもんですから困ってしまってカルモチンを服ましてやったのです……そうして地下室の古井戸の中から、いい処へ旅立たしてやったんです。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの地下室の古井戸は随分深い上にピッチリと蓋が出来るようになっていて、息抜きがアノ高い煙突の中へ抜け通っているんです。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしないと、おしまいには米や大根を地下室の棚で作らなければならない事になるかもしれない。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉庫や地下室の中の空気は温度がほとんど均等でこのような寒暑の粒の交錯がない、つまり空気が死んでいる。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「虞美人草」を書いていたころに、自分の研究をしている実験室を見せろと言われるので、一日学校へ案内して地下室の実験装置を見せて詳しい説明をした。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里の料理店は温度の変化の少ない地下室に自店独特の酒を蒐集して料理と共に自店を特色づける。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は毎日四条のもと交潤社という酒場のあった地下室のレッスン場へ通い出した。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下室のグリルで食事を済ませると、信吉は、ロビイへ新聞を取りに行った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "冴子はほのぼの笑って、「あとで……」　地下室のグリルへはいって、向い合って坐ると、「――二箱持って来たわ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吉は冴子に会いに楽屋へ行こうとして花道のうしろについている扉をあけて、地下室への階段を降りて行った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
