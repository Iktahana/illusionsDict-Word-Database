[
  {
    "uuid": "f634693d-7e76-544d-a47e-e61e6dac5759",
    "entry": "鎮護",
    "reading": {
      "primary": "ちんご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "guarding",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "別して造塔、起仏に御熱心にて、自ら七寺（四天王寺、法隆寺、中宮寺、橘寺、蜂丘寺、池後寺、葛城寺）を建立せられた外、諸国にも寺院の配在を奨励せられたのは、国家鎮護の役目とともに、庶民をして和恭の心を発得せしめん御心よりであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠅の事に就いて今挙げた片倉小十郎や伊達政宗に関聯して、天正十八年、陸奥出羽の鎮護の大任を負わされた蒲生氏郷を中心とする。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に今語ろうとする蒲生氏郷は、豊臣秀吉即ち当時の主権執行者の命によりて奥羽鎮護の任を帯びて居たのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは奥州鎮護の大任を全うするに付けては剛勇の武士を手下に備えなければならぬ、就ては秀吉に対して嘗て敵対行為を取って其｜忌諱に触れたために今に何の大名にも召抱えられること無くて居る浪人共をも宥免あって、自分の旗の下に置くことを許容されたい、というのであった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は人間の最上府を鎮護するの任を有せり。",
              "citation": {
                "source": "思想の聖殿",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は斯の如く人間の最上府を囲繞して、而して人間の結托せる社会を鎮護せり。",
              "citation": {
                "source": "思想の聖殿",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨乞いならば八大龍王を頼みまいらすべきに、壇の四方に幣をささげて、南に男山の正八幡大菩薩、北には加茂大明神、天満天神、西東には稲荷、祇園、松尾、大原野の神々を勧請し奉ること、まさしく国家鎮護悪魔調伏の祈祷と見ました。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎮護国家の道場とあるから仏法王法何れを重しとする理由もないが、それは明かに仏法興隆のためではないから、勢ひ王法興隆のためであらうが果して如何かといふ様なことであらう。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "今浅草寺ではこのお狸様を鎮護大使者として祀っています。",
              "citation": {
                "source": "寺内の奇人団",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "水商売の女性たちの参詣が盛んであるようですが、これは御鎮護様をオチンボサマに懸けた洒落参りなのかも知れません。",
              "citation": {
                "source": "寺内の奇人団",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども中には『竜王が鎮護遊ばすあの池に獺の棲もう筈もないから、それはきっと竜王が魚鱗の命を御憫みになって、御自分のいらっしゃる池の中へ御召し寄せなすったのに相違ない。",
              "citation": {
                "source": "竜",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この島の火山には鎮護のためか、岩殿と云う祠がある。",
              "citation": {
                "source": "俊寛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "三番叟の所作発言はことほぎと称せられるものであるが、同時にあの詞章だけをとつて来ると、鎮護詞と言ふものゝ古代の用語例に這入るものなのである。",
              "citation": {
                "source": "日本文学における一つの象徴",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎮護詞には全体として、其所作ことほぎが残つたのである。",
              "citation": {
                "source": "日本文学における一つの象徴",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは鎮詞・護詞・鎮護詞などゝ書かれるいはひごとである。",
              "citation": {
                "source": "呪詞及び祝詞",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、鎮詞・鎮護詞などゝ書かれてゐるのである。",
              "citation": {
                "source": "呪詞及び祝詞",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等をすべて見はるかす形勝の地であるから、アクロポリスはアテナイにとって天下を支配すべき主神鎮護の霊地として尊ばれた。",
              "citation": {
                "source": "パルテノン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其で、歌の上もやはり、さうした時代的合理化が這入つて来て「念ふ鳥」だの遺愛の「放ち鳥」などゝ言ふ風に、表は矛盾なく、形を整へてゐるが、ほぎ歌・鎮護詞・魂ごひ歌などの展開の順序を知つてかゝると、長い年月の変化が語られる。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうしたよごとの分化に伴うて、のりとから分化して来たのが、いはひごと（鎮護詞）であつた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、よごとであるべきものが鎮護詞と呼ばれたり、又祝詞と呼ばれる物の中にも、斎部などのいはひ詞を多く交へてゐる訣である。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "其陰陽道の方式は鎮護詞と同じ様な形式を採つた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭儀も詞章も、勢ひかうした方面へ進んで行つた為に、文学・演芸の萌芽も、鎮護詞及び其演出の影響ばかりを自然に、深く受けなければならない様になつた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い用法で言へば、日本古代詞章の中、わりに短い形の物は、鎮護詞章と其舞踊者の転詠――物語の歌から出た物の外は――から出て居ると謂うてよい程である。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎮護詞章は寿詞であるが、同時に、いはひ詞の発生を導いた内的動機の大きなものになつてゐる。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "此種のうたは、鎮護詞系統から出たものばかりであつたと言うてよい。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、詞章から言へば、いはひごと――鎮護詞――と言ふべきものを元として、其を更にくづして唱へたものらしい。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此が所謂｜鎮護詞である。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其意味に於いて、延喜式の祝詞は誤解を重ねて、寿詞と称しながら、鎮護詞の形をとり、更に祝詞の中にこめられてゐる。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
