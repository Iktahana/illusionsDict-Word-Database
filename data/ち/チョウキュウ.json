    "entry": "徴求",
    "reading": {
      "primary": "ちょうきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "demand",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あえてあからさまに過去と現在とを告げて徴求の源をふさぐ。",
              "citation": {
                "source": "なかじきり",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大永四年に家康の祖父岡崎次郎三郎清康が、忠行の父忠茂の謀を用ゐて、松平弾正左衛門信貞入道昌安の兵を破り、昌安の女婿となつて岡崎城に入つた時、忠茂は岡崎市の小物成を申し受け、さて毫釐も徴求せずにゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
