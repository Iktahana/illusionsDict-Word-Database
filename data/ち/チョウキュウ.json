    },
    "definitions": [
      {
        "index": 1,
        "gloss": "longbow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼が悍馬に鞭ちて疾駆するや、彼が長弓を横へて雉兎を逐ふや、彼は常に「これは平家を攻むべき手ならひ」と云へり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば戦車・戦艦・爆撃機は生まれつき専制君主の武器であり、一方ライフル銃・マスケット銃・長弓・手榴弾は民主制の武器である。",
              "citation": {
                "source": "あなたと原子爆弾",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
