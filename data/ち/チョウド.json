    },
    "definitions": [
      {
        "index": 1,
        "gloss": "exactly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕の連れの男は僕の丁度直ぐ前の席に、もう先刻から眠つてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の新らしい詩の表現は、丁度、愛する妻と共に日暮れの街を歩きながら、楽しい買物の話をするやうな、平易な親しさの中に、力強い情熱のひびきをこもらせたものであつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "常々菊池寛氏を敬愛して「英雄」と呼んで居たのも、やはりその反性格の爲であつて、丁度あの神經質のボードレエルが、豪放で世俗的なユーゴーを崇敬して居たのと同じである。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度小説の價値批判が、描寫（表現）の巧拙にかかるやうに、詩についても同じ描寫の效果性（即ち表現技巧）について求めた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度あの所謂劇通が、劇に對してもつ興味のやうに、單にその藝術を「批判する」のであつて、一般觀客の如く、眞にそれを樂んだり、感激したりするのではない。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば彼の中には、丁度我々の詩が求めてゐるやうな「新鮮さ」や、特殊な鋭い「敏感さ」やがあり、或る説明できない神經の尖鋭が、溌剌たる言語の中で泳いでゐるのを見るからだ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、彼のあの容貌がさうである如く、どこかに子供らしい、元氣の好い、何でも新しいものや舶來のものに憧憬をもつ、鮮新無比の感覺がをどつてゐる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は彼の作品について、時にしばしば一種の鬼氣を――支那の言語で、丁度「鬼」といふ字が表象する所の悽愴感を――感じてゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、ひどい憂鬱の厭世觀に憑かれてゐた私は、談話のあらゆる本質點に於て彼と一致し、同氣あひ引く誼みを感じた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに丁度、酒に醉つた者が醉はない人々の中にゐて、意地惡く狂態を觀察されるやうな、一種不愉快な自覺が生ずる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度その頃、雜誌「驢馬」の同人を主とし、室生、芥川の二君を賓とするパイプの會が上野にあつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度先客と對談中であつた彼は、ひどく憔悴して見えた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度万葉集の和歌が、古来日本人の詩歌の中で、最も「若い」情操の表現であったように、蕪村の俳句がまた、近世の日本における最も若い、一の例外的なポエジイだった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がドストイェフスキイを讀んだ頃は、丁度｢白樺」の一派が活躍して、人道主義が一世を風靡した時代であつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度その時、僕は處女詩集「月に吠える」を出し、室生犀星君もまた第一詩集「愛の詩集」を發行した。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、その小説の主人公である白痴の貴族が、丁度その僕と同じ精神変質者であったからだ。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは丁度、深い密林の中で白堊の洋館を見る時のやうな感じである。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御城の杉の梢は丁度この絵と同じようなさびた色をして、お濠の石崖の上には葉をふるうた椋の大木が、枯菰の中のつめたい水に影を落している。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も陳列所前の砂道を横切って向いの杉林に這入るとパノラマ館の前でやっている楽隊が面白そうに聞えたからつい其方へ足が向いたが丁度その前まで行くと一切り済んだのであろうぴたりと止めてしまって楽手は煙草などふかしてじろ／＼見物の顔を見ている。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白粉花ばかりは咲き残っていたが鶏頭は障子にかくれて丁度見えなかった。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺風景な病室の粗末な寝台の上で最期の息を引いた人の面影を忘れたのでもない、秋雨のふる日に焼場へ行った時の佗しい光景を思い起さぬでもないが、今の平一の心持にはそれが丁度覚めたばかりの宵の悪夢のように思われるのである。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船も丁度あると来たので帰る事と定める。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しこの時謝源が空を見上げたならば、もう一つの気味の悪い大きな星が彼の丁度頭の上で、さつきと同じやうに長い尾を引いて流れたのを見たことであつたらう。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "性なきまでに白げられたる、木の骨――というより外に、与える名がない――と、砂に埋まれた楕円石や、稜角の鋭いヒイラギ石やは、丁度、人間の屍骸が、木乃伊となって、木偶か陶製の人物か、区別が見えないと同じように、原性を失って、唯一自然の平等相に復帰している。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、白峰山脈からいえば、農鳥山の支峰の下で、河原から、赤石山脈の間の岳とは、真面に向き合っている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、デッキと同じ大きさの、熱した鉄瓶の尻と、空気ほどの広さの、赤熱した鉄板と、その間の、＊＊＊＊＊＊そうでもない。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "魂は丁度｜睫毛のところまで出ていたのだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドドーン、ドドーン、ドーン、バラバラ、ドワーン　小林の頭上に、丁度、彼自身の頭と同じ程の太さの、滅茶苦茶に角の多い尖った、岩片が墜ちて来た。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の隧道を抜けていよ／＼上高地の関門をくゞつたとき一番に自分の眼に映じた美しい見ものは、昔から写真でお馴染の大正池の眺めではなくて、丁度その時雲の霽間にその全貌を現はした焼岳の姿と色彩とであつた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋に籠つて寐轉んで居ると、すぐ近くの階段や廊下を往來する人々の足音が間斷なく聞こえ、それが丁度御會式の太鼓のやうに響き渡り、音ばかりでなく家屋全體が其の色々な固有振動の週期で連續的に振動して居る。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
