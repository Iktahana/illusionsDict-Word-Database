        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それからすぐまたなんだか役者の話なぞベチヤクチヤ喋舌り散らしてゐる。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、ことさらに独自性をわめき散らし、排除し合うのも、どうかしている。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "取散らした包紙の黴臭いのは奥の間の縁へほうり出して一ぺん掃除をする。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵葉書屋へはいったら一面に散らした新年のカードの中には売れ残りのクリスマスカードもあった。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右脇には句集など取散らして原稿紙に何か書きかけていた様子である。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして河向いの高い塀の曲り角のところの内側に塔のような絞首台の建物の屋根が少し見えて、その上には巨杉に蔽われた城山の真暗なシルエットが銀砂を散らした星空に高く聳えていたのである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と得意滿面、このたびの大厄難突破の次第を、唾を飛ばし散らしながら物語る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "張ったばかりの天井にふんの砂子を散らしたり、馬の眼瞼をなめただらして盲目にする厄介ものとも見られていた。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし物好きな人があってこの模様を散らした着物でも作ればきっと面白い物が出来るだろうと思われる。",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "外を歩いてゐると、いつの間にか曇り出し小さいつむじ風が舗道の散らしビラを漏斗型に捲き上げる。",
              "citation": {
                "source": "風と裾",
                "author": "――何人か良案はないか？――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが驚いたなあ」　老妓は腕に指痕の血の気がさしたのを、縮緬の襦袢の袖で擦り散らしてから、腕を納めていった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新仏教」明38・２三　調子に乗って大きな事を云い散らしてしまった。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が心は清めるか濁れるか」　封じ目ときて取出せば一尋あまりに筆のあやもなく、有難き事の数々、辱じけなき事の山々、思ふ、恋ふ、忘れがたし、血の涙、胸の炎、これ等の文字を縦横に散らして、文字はやがて耳の脇に恐しき声もて※くぞかし。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだという返答をたしかめてから後に悠々と卓布一杯に散々楽書をし散らして、そうして苦い顔をしているオーバーを残してゆるゆる引上げたという話もある。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽しみに学問をするというのはいけないことかもしれないが、自分はどうも結局自分の我儘な道楽のために物理学関係の学問をかじり散らして来たものらしい。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、そうすることによって結局は奉公の第一義にかなうことが出来るという自分勝手な考えもありはしたが、とにかく興味の向くことなら何でも構わず貪るように意地汚くかじり散らした。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝内部　徳兵衛、番頭手代に当り散らして居る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "やりなれないことでもあり、同人の清水が京都から上京して來たり、氣を散らして、たうとう締切に迫られ充分なものが書けなかつた。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ややつよい微風が吹いてゐて、細ながい黒雲を追ひ散らしてゐました、まるで光つてゐる圓盤の上をたえず横ぎる狹いリボンのやうに。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "コメット・ヌマタは夜の空間、花火吹散らして空高く、飛行ズボン脱いで牡鶏の真似をしている。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "レムブルグを抱えた米良が舞踊場に機械が造り出した人間の造花の美と、同志の終りに近づいた純潔を撒き散らした。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "エムパシー・シアターではアグレヴナースラビアンスキー一座がロシアの十七世紀のクラシック・オペラを開演していたが、何故か時刻になっても開場せず、出所不明のインタナショナルの放送ラジオが放送局の演劇ラジオと空中で火華を散らして戦った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何時の間にか雪を散らしたやうな點になつて、遠くの波の間にふんはりと浮ぶ。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外には、谷間の嵐が団栗の落葉を吹き散らしていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の取り散らしたヤチのない家とは全く様子が異っていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の中にはカルムイコフが捕虜を殺したあとを分らなくするために血に染った雪を靴で蹴散らしてあった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の靴は、固い雪を蹴散らした。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "街路樹の菩提樹の葉が、黄色の吹雪を絶えずサラサラサラ撒きちらして居た。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みちらしく踏まれたところもある。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかにみんなそう云う気もちらしかったのです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
