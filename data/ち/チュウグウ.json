[
  {
    "uuid": "a4ad9cc8-2725-555e-9fe0-a23c5e945526",
    "entry": "中宮",
    "reading": {
      "primary": "ちゅうぐう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
