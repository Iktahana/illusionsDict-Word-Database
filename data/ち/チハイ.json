        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "メーデーだと云っても、決して遅配のお米が配られては来ません。",
              "citation": {
                "source": "メーデーと婦人の生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅配、欠配、棚上げは改善されませんでした。",
              "citation": {
                "source": "今年こそは",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "またりんごもバナナもかきも、一年中いつでもならせることができます」「すると、遅配だの飢餓だのということは、もう起らないのですね」「えっ、なんとかおっしゃいましたか」　技師は正吉の質問が分らなくて問いかえした。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まちがいなく五十倍の増産がらくに出来る今の世の中に、遅配だの飢餓だのということが分らないのはあたり前だ。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらでは又、食糧の遅配がはじまりどうなることやら暗澹たるものです。",
              "citation": {
                "source": "書簡",
                "author": "家族・親族宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、さきに餓死した判事のごとき人物が首相となり、窮乏の時であるから遅配に我慢せよ、余が範をたれると称して餓死されては、国民たるもの、降参せざるをえない。",
              "citation": {
                "source": "帝銀事件を論ず",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月六月遅配と欠配、食糧難深刻、餓死者続出、附近の家々も最後の最悪の事態に陥つ、泪なしには見られず聞かれず。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこの本を読んでいたのは終戦にちかいころの、一日一合七勺、それが十日、三十日という遅配欠配の最中ですよ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "長崎チャンポン――九州の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、実にワガハイが一日三合の白米どころか、一合七勺のその十日三十日の遅配欠配にさしたる顔もせず、自分一人アメリカ向けに白旗をふって降参しようなどゝ考えたこともありやしない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "長崎チャンポン――九州の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレが一合七勺の遅配欠配に我慢ができても、長崎の胃袋は三合ズツの完全配給に音をあげるのは当り前だ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "長崎チャンポン――九州の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日、表町の外食券食堂へ行く途中（私達家族三人は主食配給が遅配がちなのと、隣組の輪番制当番がうるさかつたので外食にきりかへたのだ）一人の年増婦人からかう訊ねられた。",
              "citation": {
                "source": "老残",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも我々は、第三次元の世界なる現代に生れて、遅配に悩んだり、食糧の買出しをしたり、暴力行為の流行に腹を立てたりして居る間に、第四次元の世界に同時に生活して恋をしたり、御馳走をたべたり、帝王になったり、ルンペンになったりして居ないとも限りません。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "第四次元の恋",
                "note": "青空文庫"
              }
            },
            {
              "text": "久子　内のがって、だってあんた、もう二十日からの、遅配なんですよ。",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔青びかる天弧のはてに〕宮沢賢治青びかる天弧のはてにきらゝかに町はうかびて六月のたつきのみちはいまやはた尽きはてにけりいさゝかの書籍とセロを思ふまゝ〔以下空白〕",
              "citation": {
                "source": "〔青びかる天弧のはてに〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり私たちと大学が同期であって、誰よりも気が弱く、私たちはいつもこの人の煙草ばかりを吸っていた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「福慈の女神はだんだん若くなるようである」と旅人たちはいった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは、（さうだ、ぼくたちはいま、いっしょにさそって出掛けたのだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊たちはいちばんはじの列から馬をひいてだんだん川へ入りました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはいまにだんだん深い処へさえ来れば、兵隊たちはたてがみにとりついて泳ぎ出すだろうと思って待っていました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十幾本の鉤を凧糸につけて、その根を一本にまとめて、これを栗の木の幹に結び、これでよしと、四郎と二人が思わず星影寒き大空の一方を望んだ時の心持ちはいつまでも忘れる事ができません。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえたちはいままでにそう云う人たちの話を沢山きいて来た。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくたちはいまいそがしいんだよ。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは、（そうだ、ぼくたちはいま、いっしょにさそって出掛けたのだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みちはいつか谷川からはなれて大きな象のやうな形の丘の中腹をまはりはじめました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが馬を引いた人たちはいろいろ話をはじめました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきのうすくらい野原で一緒だった人たちはいまみな立派に変ってゐました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちはいつも強い好奇心で、その人の謙遜な身なりを嗅ぎ、その人の謙遜な話に聞き惚れた。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初のうちはいろいろの片輪者や化け物が生まれた。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう環境におおぜいの若い娘たちを置いたら彼女たちはいかに反応するか。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　青年たちはいつでも本氣に議論をしない。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
