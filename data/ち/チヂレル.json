        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "声に混じり煙草の火で頭髪の焦げ縮れる音がじじッとした。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　御米のぶら／＼し出したのは、秋も半ば過ぎて、紅葉の赤黒く縮れる頃であつた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　御米のぶらぶらし出したのは、秋も半ば過ぎて、紅葉の赤黒く縮れる頃であった。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチパチと急にちぢれるやうな音がして、青い煙が上り、薄暗い蝋燭の光りの下に焔は赤かつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　縮緬のじゅばんの袖口がちぢれるほど、ハンケチとちゃんぽんに涙を拭くのだが、相手は、「そんなことは、他へいっていえよ。",
              "citation": {
                "source": "モルガンお雪",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜちぢれるかということは、極めて簡単に説明することが出来る。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに鉋で削れた縮緬皺の土肌に（古えの作風、素焼きしないで生のままのとき）火度に強い釉薬を直に厚く掛けて焼くとき、必ずちぢれるのがカイラギとなって現われる。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
