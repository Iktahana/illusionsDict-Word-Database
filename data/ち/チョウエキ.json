[
  {
    "uuid": "9c68e80a-bf0c-5880-b4fc-3c33ba32a828",
    "entry": "懲役",
    "reading": {
      "primary": "ちょうえき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "penal servitude",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "我れ少年の日は、常に麥笛を鳴らして此所を過ぎ、長き煉瓦の塀を※りて、果なき憂愁にさびしみしが、崖を下りて河原に立てば、冬枯れの木立の中に、悲しき懲役の人人、看守に引かれて石を運び、利根川の淺き川瀬を速くせり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、五年の懲役を求刑されたよりも、みじめな思いをした。",
              "citation": {
                "source": "あさましきもの",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかといって懲役に行くような犯罪をここに発表するわけにも行かぬ……たとえあるにしてでもである。",
              "citation": {
                "source": "ざんげの塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、それよりもこんなことになるのはどこの国の政治家でもすぐわかる、これはいかんと云うわけでお気の毒ながら諸君をみんな終身｜懲役にしちまいます。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか死刑にはなりますまいが終身懲役だってそんないいもんじゃありませんよ。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」爾薩待（うなだれる）（農民等　黙然）農民二（ややあって）「いま、もぐり歯医者でも懲役になるもの、人｜欺して、こったなごとしてそれで通るづ筈なぃがべじゃ。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お前は一審で懲役一年に処せられたが、その判決が不服だと云ふので控訴したのか。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "○七月、守田座にて「亀山の仇討」を開演中、石井兵助を勤むる嵐璃鶴が召捕られて、後に懲役三カ年を申渡さる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして葛飾は幾年かの懲役を云い渡された。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の渡り賃を払わずにこの河を渡った者は懲役に行くのだ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る友人から「服役中は留守宅の世話｜云々」という手紙をもらい、その「服役」という言葉が、懲役にでも服しているような陰惨な感じがして、これは「服務中」の間違いではなかろうかと思って、ひとに尋ねてみたが、やはりそれは「服役」というのが正しい言い習わしになっていると聞かされ、うんざりした事がある。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "懲役なんて、嘘です。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその傷がなほるとすぐに、他の懲役人たちと一しよに、とほくシベリヤへおくられました。",
              "citation": {
                "source": "ざんげ",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔭で会社が潰れて二百名の職工が路頭に迷いますというのや、貴方の乾分の弁護士の御蔭で三年の懲役が五年になりました。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "懲役に行かずに飯喰いよれあ、それで宜え訳で……もっともこれが又、博多児の資格の中でも一番困難しい資格で御座います。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで誰にも云わずにおりましたが……懲役に遣られるかも知れませんので……。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "生胆の要るなら遣る』『馬鹿……今、貴様の生胆を取れあ、俺が懲役に行くだけじゃないか……おいツン州……大変事の出来たぞ』『……芽出度い……』『殴わせるぞ畜生。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏様担いで柳町へ行きゃあ花魁の顔見ん内に懲役に行くぞ」「ああ、そうか」「とりあえずお寺へ行こうお寺へ行こう」「仁三郎は何宗かい」「仁三郎が宗旨を構うかいか」「そんなら成丈け景気のええお寺へ行こう」「あッ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからウィリアムソンとウードレーは、誘拐罪と殴打罪で、前者は七年の懲役、後者は同じく十年に処された。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん数ヶ月の懲役と云うところが、適当な求刑であったろう。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "この亜米利加人のアベー・スラネーは、ノーアウィッチの冬期巡回裁判で、死刑を宣告されたのであったが、しかしヒルトン・キューピット氏が、最初に発射したと云うことが明瞭になったので情状酌量して、死刑を改めて懲役刑とされた。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もう一方の端には、我々が無実を証明せねば七年の懲役刑を受けるかもしれぬ男がいるのだ。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ人、エイブ・スレイニは、ノリッジの冬季巡回裁判で死刑を宣告されたが、軽減に値する事由があり、ヒルトン・キュービット氏が先に撃ったことが確実であったので、刑を改めて懲役刑とされた。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "先週からホール・パイクロフトと名乗る仲買人が新しく社に雇われていたが、この人物が有名な偽造・強盗犯ベディントンなのは間違いないと思われ、その兄とともに五年間の懲役刑を勤め上げたばかりだった。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日は人の波打ちしコルソオの大道には、往き交ふ人｜疎にして、白衣に藍色の縁取りしを衣たる懲役人の一群、霰の如く散りぼひたる石膏の丸を掃き居たり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんだが、此の年齡になつて懲役に行ぐな厭よ俺れも」爺さんはずつと垂れた頭を手で抑へて笑ひこけた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、おもての者たちにとっては、それは、灰色に塗りつぶされた、懲役囚の一夜のように惰力的な一夜であった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八六三年、法刑及び懲役にされた、囚徒の給養や労働状態について、英国政府が調査した結果からマルクスは、ポートランドの監獄囚徒が、農業労働者や、植字工などよりも、よい営養をとっていたことを証明している。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日に十四時間は、まるで、懲役囚よりも長時間です。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれのやうな奴が懲役に行かずに、内の……内の……雅之のやうな孝行者が……先祖を尋ぬれば、甲斐国の住人｜武田大膳太夫信玄入道、田夫野人の為に欺かれて、このまま断絶する家へ誰が嫁に来る。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
