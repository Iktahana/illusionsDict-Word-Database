        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蚊帳が釣ってありますので、よくわかりませんが、枕元の畳と床の間のあいだが一面、血の海になっております」「いつ頃殺されたんか。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "野をあげて末期のあらび――暗き血の海に溺るる赤き悲苦、赤きくるめき、ああ、今し、くわとこそ狂へ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い鳥、血の海　變な夢を見た。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれこそまさしく京できいたヘゲタレじゃ」　苦が笑いしながらとって返すと、血の海の断末魔の悲しい嘶きをつづけながら、のたうち苦しんでいる愛馬の首を、わが子のようにしッかと抱きかかえて、声も絶え絶えと嘆き悲しんでいた若者へ、詫びるように呼びかけました。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれこそまさしく京できいたヘゲタレじゃ」　苦が笑いしながらとって返すと、血の海の断末魔の悲しい嘶きをつづけながら、のたうち苦しんでいる愛馬の首を、わが子のようにしッかと抱きかかえて、声も絶え絶えと嘆き悲しんでいた若者へ、詑びるように呼びかけました。",
              "citation": {
                "source": "旗本退屈男",
                "author": "第五話　三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまに館がひとり、山村がいち人、あとの四人を残りの近侍達が斬りすてて、広場の砂礫は凄惨として血の海だった。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "凄惨というか、惨虐というか、畳一、二畳ほどは一面の血の海で、その血に染まっている相手がうら若い美貌のあだものだけに、むごたらしさもまた一倍だったからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "――辺りは、一面の血の海だ。",
              "citation": {
                "source": "気狂い機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間一面の血の海で、その血溜りの真ン中へのけぞるように倒れた人は、昨夜のままのパジャマを着た明らかに赤沢院長の無惨な姿だった。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたり一面の血の海だ。",
              "citation": {
                "source": "銀座幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察は、一面の血の海の中でひとり泣いている小さな男の子を発見したが、まったくの無傷であった。",
              "citation": {
                "source": "停車場にて",
                "author": "AT A RAILWAY STATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、四辺一面の血の海は、次々と発見された事件の衝動に麻痺された一同の心に、只燃えつつある絨鍛の如くに映った。",
              "citation": {
                "source": "電気風呂の怪死事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "真赤な血の海の中をひくひくと動く蒼白な肌の色は何人も描くことの出来ない美の極地ですね』　こういって、その男は、軽く一息ついた。",
              "citation": {
                "source": "自殺",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "底に青ずみ漂う血の海。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（罌粟畑を眺め）この広い血の海で、その白無垢が赤く染まる。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千万人に試みて、千万人に成功した我が誘惑の「暗と血薔薇」の一曲が、罌粟畑の血の海でどれだけ音高く歌われるか聞け。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、あと数分ののち、この黒曜石のような美しい氷上が、血の海と化するであろう。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "假に私の親友が血の海から私の方へ戻つてくるのを見たとしても、私の愛情は少しだつて變りはしないよ。",
              "citation": {
                "source": "醫師と旅行鞄の話",
                "author": "ロバート・ルイス・スティーヴンソン",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、寝床を血の海にして死んでいる真弓の姿が発見された。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハルクは、血の海の中に、うつ伏せとなり、水兵ナイフをそこへ放りだしたまま、虫の息となっていた。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はて――」　局長は、櫂を借りて、二号艇の血の海のなかから、気になるその手首をそっとすくいあげた。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の海の中に、腐った魚みたいに目の玉とびだしてさ。",
              "citation": {
                "source": "都会の中の孤島",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いきって中へはいってみると、夫婦二人はまさに腐った魚のように目を外へたらして血の海の中に死んでいたのであった。",
              "citation": {
                "source": "都会の中の孤島",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "サチ子はすでに血の海に倒れ、微動もしない屍体になるが、心は然し安らかであつたであらう。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も亦、その安らかな血の海を、いつまでも、静かな心で眺めてゐることができるであらう。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "サチ子はすでに血の海に倒れ、然し心は安らかであつたに相違ない。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは金品を探して血の海の室内をずいぶんうろついた筈なのだ。",
              "citation": {
                "source": "フシギな女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "カスバはその眼の前に血の海を見ました、その海は次第に陸にひろがり、大谿に溢れみなぎり、高山の背を洗い浸し、山々の峰をこえて、ゲエルの全地に鳴りとどろく赤い血の洪水となって流れおち、赤い血の海にまで流れ入ったということでございます。",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりは鮮血の海であった。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
