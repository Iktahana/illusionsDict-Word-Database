  {
    "uuid": "0dee35a4-a918-5e28-9f54-c6a171122b7b",
    "entry": "ちょうちん",
    "reading": {
      "primary": "ちょうちん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "chōchin",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで私はまず城山を捜すがよかろうと、田口の僕を一人連れて、ちょうちんの用意をして、心に怪しい痛ましいおもいをいだきながら、いつもの慣れた小道を登って城あとに達しました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの家では、ちょうちんやろうそくを売っておりました。",
              "citation": {
                "source": "ひとつの火",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある晩のこと、ひとりのうしかいが、わたしの家でちょうちんとろうそくを買いました。",
              "citation": {
                "source": "ひとつの火",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といって、うしかいは、火のともったちょうちんを牛のよこはらのところにつるして、いってしまいました。",
              "citation": {
                "source": "ひとつの火",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といって、うしかいの火をかりて、じぶんのちょうちんにうつすだろう。",
              "citation": {
                "source": "ひとつの火",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すみませんが、ちょっとちょうちんの火をかしてください。",
              "citation": {
                "source": "ひとつの火",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といって、旅人から火をかり、みんなのちょうちんにつけるだろう。",
              "citation": {
                "source": "ひとつの火",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "長いちょうちんやまるいちょうちんにつけるだろう。",
              "citation": {
                "source": "ひとつの火",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはいまでも、あのときわたしがうしかいのちょうちんにともしてやった火が、つぎからつぎへうつされて、どこかにともっているのではないか、とおもいます。",
              "citation": {
                "source": "ひとつの火",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "びっくりしてはね起きて見ると、外ではほんとうにひどく風が吹いて、林はまるでほえるよう、あけがた近くの青ぐろいうすあかりが、障子や棚の上のちょうちん箱や、家じゅういっぱいでした。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ月は出るけれども地図が見えないといけないと思って、ガラス函のちょうちんも持ちました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、夕やみがこくなってくると、色とりどりの、何百ものちょうちんに、火がともされました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう今は、色とりどりのちょうちんの火は消えて、花火も空に上がらなくなりました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで小さいちょうちんが木にいっぱいともされたようなぐあいでした。",
              "citation": {
                "source": "木の祭り",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえおよしばあさんは、小田原ちょうちんに火をともして、牛車の台のうしろにつるしてやります。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶屋のおよしばあさんが、いろいろ和太郎さんの世話をやいて、松から手綱をといてくれたり、小田原ちょうちんに火をともしてくれたのも、いつものとおりでした。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして男たちは、手に手にちょうちんを持って、山にはいっていきました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに小田原ちょうちんがつけてありますに、ごらんくだせェ」といって、和太郎さんは牛車の下へ頭をつっこみました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが小田原ちょうちんは、上半分しか残っていませんでした。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水にぬれたので、こんなになっちめえました」と和太郎さんは、ちぎれて半分の小田原ちょうちんをはずして見せました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっ暗い峠を、足さぐりでこすのはあぶないので、茶店のばあさんに、ちょうちんをかりていこうと思いました。",
              "citation": {
                "source": "のら犬",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうちんだけかりるのも、へんなので、常念坊は、「おい、おばあさん。",
              "citation": {
                "source": "のら犬",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すまないが、わしに、ちょうちんをかしておくれんか。",
              "citation": {
                "source": "のら犬",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
