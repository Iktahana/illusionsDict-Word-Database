    "definitions": [
      {
        "index": 1,
        "gloss": "long (defensive) wall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "兵士達自身が、綿々と連続せる鉄条網と、万里の長城のような土塁を見かえして、われながら、自分の作業の結果にびっくりした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長城万里に亘り荒蕪落日に乱るゝの所、悵たる征驂をとゞめて遊子天地に俯仰すれば、ために万巻の史書泣動し、満天の白雲｜凝つて大地を圧するの思あり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "沙漠の嵐吹き荒ぶ北は蒙古、滿洲里亞、見よ、長城の嶮にして八達嶺は雲｜鎭む。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "萬里の長城を二重にして、青く塗つた樣なもんだね。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、暇つぶしに、あの脊の高い書架の長城の城壁の前をぶらぶら歩いているうちに、「随筆」と札のかかった区劃の前に出た。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮れがたになってはさしもに大きな一まちの田も、きれいに刈り上げられて、稲は畔の限りに長く長城のごとくに組み立てられた。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢張りこれらの先走りのものより何程秋田氏の過去の仕事から脱しきれないものであり稀薄な位置にあるものとしても『万里の長城』『西湖』の作風こそその底に永久動かすことのできないものが一派として残つてゐるのではないか。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "この浄化されこれら詩趣に立脚して次の仕事美学上の公理やまた方式などを全く忘れた秋田義を期待するそして『万里長城』などのともすれば黙殺され勝ちなものから現在プログラム外出品の『蘇洲城裏』『長江夕映』『長江遠望』などの仕事を産んだことは実に素晴らしいではないか。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "万寿山へも行けば、万里の長城へも行つた。",
              "citation": {
                "source": "犬",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「長城を築く、長城を築く」　その声を聞くと、かれらは狼狽して山奥へ逃げ込むという。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "長城を築く――毛人らが何故それを恐れるかというと、かれらはその昔、秦の始皇帝が万里の長城を築いたときに駆り出された役夫である。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらはその工事の苦役に堪えかねて、同盟脱走してこの山中に逃げ籠ったが、歳久しゅうして死なず、遂にかかる怪物となったのであって、かれらは今に至るも築城工事に駆り出されることを深く恐れているらしく、人に逢えば長城はもう出来あがってしまったかと訊く。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "その弱味に付け込んで、さあ長城を築くぞと囃し立てると、かれらはびっくり敗亡して、たちまちに姿を隠すのであると伝えられている。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "万里の長城を二重にして、青く塗った様なもんだね』『何処で芝居を演るんだ？",
              "citation": {
                "source": "火星の芝居",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし婦人の半奴隷的な境遇はつづいて、全人民による選挙と国会開設を求める自由民権運動に参加した十九歳の岸田俊子（のち自由党首領中島信行・長城の夫人。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　尼寺の垣根は、まるで小型の万里の長城のように、どこまでも続いていた。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも長城から哈爾賓を越えると爆薬の値段が二倍になる。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "東漢の陳琳の飮馬長城窟行に、生兒愼莫擧、生女哺用脯。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "攘ひ斥けた地面に三十四縣――或は四十四縣とも傳ふ――を置き、ここに漢族數萬家を移住せしめ、所謂萬里の長城を築きて、華夷の疆界を嚴重に限定した。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "北狄の侵入に對して長城を築くことは、必ずしも始皇帝の時に創つたのではない。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "降つて春秋戰國の交から、秦・魏・趙・燕等北邊の諸國は、相繼いで北狄を防がん爲に、長城を築いたことがある。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "始皇帝は幾分これら以前の長城を利用して、萬里の長城を作つたものと見える。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "その萬里の長城は、今の甘肅省鞏昌府附近から起つて、黄河の外を廻り、今の山西・直隷二省の北邊を縫うて、盛京省の東部に達したのであるから、勿論今日現存の長城とは、大いに相違して居る。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の長城は、秦以後西漢・後魏・北齊・北周・隋・明時代に渉つて、幾度となく増築又は改築されたものである。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "其他咸陽の國都といひ、阿房の宮殿といひ、萬里の長城といひ、彼の計畫したものには、どこにか雄大の面影を存して居る。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "驪山の陵が夷げらるることがあつても、長城の礎が動くことがあつても、支那史乘に於ける始皇の位置は確固不拔であらう。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやはや」と重太夫は隣りにいる浜岡図書と、望月吉太夫に向って苦笑した、「おだれどのに仕上げたのはよいが、少し薬がききすぎたようです」「しかし御家のためにはちょうじょう」　浜岡図書がそう囁いたとき、光辰はべそをかいたような顔で民部に云った。",
              "citation": {
                "source": "若き日の摂津守",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
