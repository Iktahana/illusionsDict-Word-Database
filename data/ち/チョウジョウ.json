[
  {
    "uuid": "23be5e2c-3f7f-5e0b-8cc6-7c5fde5dc7d1",
    "entry": "重畳",
    "reading": {
      "primary": "ちょうじょう",
      "alternatives": [
        "じゅうじょう"
      ],
      "is_heteronym": false
    },
    "grammar": {
