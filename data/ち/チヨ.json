    "definitions": [
      {
        "index": 1,
        "gloss": "many nights",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この間の長さは千夜にもあたるように源氏には思われたのである。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "千夜程も逗留してつかわそうぞ。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "二待つにし來ます君ならば、千夜をもかくてあらましを、忘れてのみは、いつの代もめぐり會ふ日はなかるべし。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐藤千夜子外二三嬢の作曲による作品も数篇加へてある。",
              "citation": {
                "source": "極楽とんぼ",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常におもしろくて千夜の時のあれと望まれた一夜がむぞうさに明けていったのを見て、若い人たちは渚の帰る波のようにここを去らねばならぬことを残念がった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "八千夜添ふとも、名古屋さま。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなような千夜のうちの一夜だった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怨霊首人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "「幾晩かけても――千夜一夜でもない限り――いいから好きなだけ続けてくれ。",
              "citation": {
                "source": "長い部屋",
                "author": "O. H. ダンバー　O. H. Dunbar",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おひきあわせ申します」と婦人が弥十郎に云った、「わたくしのお仕えする嬢さまで、お名は千夜と仰しゃいます、どうぞ、おらくにあそばして、――」三　それから中一日ずつおいて、「ゆき」からの呼びだしの手紙が三度来た。",
              "citation": {
                "source": "屏風はたたまれた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千夜という娘はまるで見当がつかない。",
              "citation": {
                "source": "屏風はたたまれた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　弥十郎と千夜とは、「川西」で七たび逢った。",
              "citation": {
                "source": "屏風はたたまれた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めてのとき、千夜がひじょうな苦痛を訴えたこと、また苦痛の証明を見たことで、彼は殆んど動顛した。",
              "citation": {
                "source": "屏風はたたまれた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千夜がひたむきに求めるので、なかばやむなく応ずるのだが、また苦痛を与えるのではないかという、危惧と懸念のほうがいつもつよかった。",
              "citation": {
                "source": "屏風はたたまれた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千夜も快楽を感じていないことは慥かであった。",
              "citation": {
                "source": "屏風はたたまれた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しょせん奥さまにはなれないのですものね」と千夜は熱い囁きで彼に迫った、「一生の思い出になるのですから、どうぞお好きなようになすって」　そのあとで千夜はいつも泣いた。",
              "citation": {
                "source": "屏風はたたまれた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうして結婚できないのだ」と或るとき弥十郎が訊いた、「こうなったら結婚するのが当然ではないか」　千夜は泣くばかりであった。",
              "citation": {
                "source": "屏風はたたまれた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わけを聞かせてくれ」と彼はべつのときに云った、「どうして結婚できないんだ、まさか身分などにこだわっているのではないだろう、ほかに約束した者でもあるのか」　千夜はやはり泣きながら首を振るだけであった。",
              "citation": {
                "source": "屏風はたたまれた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このほか、彼女のことを知ろうとして、弥十郎はずいぶん言葉をつくしたが、千夜は「なにも訊いてくれるな」と云うばかりで、どんな質問にも答えなかった。",
              "citation": {
                "source": "屏風はたたまれた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、いまに」と千夜は頼りなげに答えた、「いまにおりをみまして」　七たびめに、彼は千夜の肩をつかみ、暴あらしく揺りたてながら「いつ二人だけで逢えるか」と迫った。",
              "citation": {
                "source": "屏風はたたまれた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "閉じこめられている千夜の心を揺りさまそうとでもするように、力まかせに揺りたてながら、「いつだ、いつだ」と責めた。",
              "citation": {
                "source": "屏風はたたまれた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千夜はされるままになっていて、それからようやく「あさって、いつもの時刻に、このうちで」と答えた。",
              "citation": {
                "source": "屏風はたたまれた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うれしゅうございます」と千夜は囁き返して云った、「あさっておめにかかりましたら、すっかりお話し申します」「それでいい」と彼は云った、「間違いなくあさってだよ」「はい」と頷いて、千夜は大胆に身をすりよせた。",
              "citation": {
                "source": "屏風はたたまれた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その七度めを最後に、千夜はまったく消息を絶った。",
              "citation": {
                "source": "屏風はたたまれた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――千夜と約束の日に、「川西」へゆくと、初めて見る女中が出て来て、いま座敷がみな塞がっているから、と断わられた。",
              "citation": {
                "source": "屏風はたたまれた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は悪い冗談だと思い、今日ここで千夜と逢う約束になっていること、千夜がそれを云い置かなかったかもしれないが、たしかに来ると思うことなどを話し、どんな部屋でもいいからそれまで待たせてもらいたい、と頼んだ。",
              "citation": {
                "source": "屏風はたたまれた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ舟にのりて行かば、くるほしきなみの亂れもここちよく、ちのみごの夜びえする、あやしきこゑもきかであるべきに、ふるとせひとにかくれて、わがはぐくみしいろぐさのはや涸れぬとぞ、けふきけば薄葉に涙しをるる、よしゑやし、悲しきものはあだがたき、君ならなくに、はやも我が世をのがれいでばや。",
              "citation": {
                "source": "浮名",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まひる利根川のほとりを歩めば、二人歩めばしばなくつぐみ、つぐみの鳴くに感じたるわが友のしんじつは尚深けれども、いまもわが身の身うちよりもえいづる、永日の嘆きはいやさらにときがたし、まことに故郷の春はさびしく、ここらへて山際の雪消ゆるを見ず。",
              "citation": {
                "source": "利根川の岸邊より",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こはよき朝のめざめなり、をとめらのさんたまりやの祈祷なり、みな少女、素足あしなみそろへ行く手に、ちよこれいと銀紙に卷かれ、くだものは竝木の柵に飾られぬ。",
              "citation": {
                "source": "若き尼たちの歩む路",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔郡属伊原忠右エ門〕宮沢賢治郡属伊原忠右エ門科頭にゴムの靴はきて冬の芝生をうちよぎり南ちゞれし綿雲に雨量計をぞさゝげたる天狗巣病にはあらねどもあまりにしげきこずゑかな",
              "citation": {
                "source": "〔郡属伊原忠右エ門〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自嘲の習慣を持つてゐたので、自分の作品への偽つた解釈をちよいちよいやつてゐる。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
