        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "舌のさきで青い蛍のやうな色や橙いろの火やらきれいな花の図案になってチラチラ見えるのでした。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅を離れて暫しの間はまだ灯がチラチラ見えてゐたが、やがて広い広い闇が両側にひろげられて来た。",
              "citation": {
                "source": "百日紅",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化住宅は市内にもチラチラ見える。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それ等には気もかけない様子だった代表が興奮して云うのを一通りきいてから、「要求条項」と、三百人の「誓約書」を形式的にチラチラ見ると、「後悔しないか」と、拍子抜けするほど、ゆっくり云った。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼しい心地のいい風が川から来て、青い空が葉の間からチラチラ見える。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五日置きに、遠慮ぶかく、水色の襷が、動く手や頭の間にチラチラ見えた。",
              "citation": {
                "source": "弟子の心",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、帆の破れ目からチラチラ見るくらいでは物足りぬ。",
              "citation": {
                "source": "悪因縁の怨",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "土人の姿がチラチラ見える。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "波子だけは平然として、二人の顔をチラチラ見ながら、然し、母に腹を立てゝゐた。",
              "citation": {
                "source": "波子",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱根越えに、山の墨色の起伏と、チラチラ見える灯かげとに、温泉らしい趣を味う。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その部屋へ行く途中の手術室の前を通るときに、チラチラ見える人影や何かに好奇心を動かされて、のぞきたいと思いながらこわくて止めた事は幾度だか分らない。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "袴無しの着流しで、蝋塗りの細身の大小を差し、白扇を胸の辺りでパチツカせ、青簾に釣忍、そんなものが軒にチラチラ見える町通りを歩いて行った。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、遥か行手にあたり、火光がチラチラ見えて来た。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上の下座の座っている棚のようなところからもう夏らしい水芸の囃子が聞こえてき、高座には燕を思わせる色の肩衣つけた若い娘がスイスイ刀の切尖から水を噴き上げさせて喝采を浴びている姿が、姿勢よく座った海老団治の後ろの楽屋格子をとおしてチラチラ見えていた。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意に頭の上が明るくなって、行手に白いものがチラチラ見え出したと思ったら、小黒部の椈倉谷に落ち込む雪渓の一つに突き当った。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "身幅の狭い着物ですから、かあいい脛がチラチラ見えて。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　おっかさんは相変らず腸が悪い腸が悪いと言うて……そりゃいいが、近頃又一倍気むずかしくなって――（ユックリ歩いて上手のカシバミの叢の方へ消えて行く青年の後姿をチラチラ見る）百姓　うん、ありゃ気で患うと言う人だ。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、歩く、……へえ、じょうぶ苦労して、やっと戻って来たそうなが、その眠くなっちゃ雪ん中さつっころげてウトウトしかけると、きまって、おデコの辺がムシムシしてな、家の火じろで火が燃えてるのがチラチラ見えたそうな。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物車の向う側でウロウロしてゐる人の姿が、車と線路の間からチラチラ見える。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番手前の者の菅笠と尻が時々穂の間からチラチラ見える。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんなら、寄り添った人影もチラチラ見えよう時刻だが、さすがに元旦からこんな処をうろつく者もないと見え、まだ宵の口ながら森閑と鎮まりかえり、池の汀のアーク灯ばかり徒らに皎々と冴えかえっている。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時は腑だの財布だのといふ代物は、チラチラ見せびらかさないやうに、腹掛の丼にでもしまつて置け」　夜の大氣は、まだ温くはあつたが、なんとなく新凉を感じさせる爽やかさがあります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "持參千兩",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇の中を歩いていても、海後磋磯之介の眼には、未だに白い光りものがチラチラ見えてならない、あの日の吹雪の幻影である。",
              "citation": {
                "source": "旗岡巡査",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンドイツチ・マンの生活の蔭に、その女房子だの、ひよつとしたら養つてゐる年よりだの、それがチラチラ見えて仕方がない。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が群れつどう町々を見、楽器の音を聞き、そこここに陽気な会合が、食物と酒とを真中に開かれているのをチラチラ見ることは、誠に活気をつける。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の少女が、人なつっこく大胆にチラ見して通り過ぎた。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "前を走る車の後部の窓から、妻の白い襟足がチラチラ見えた。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその後ろ姿に尻尾のようなものがチラチラ見えるようなんで、ああやっぱり行かないでいい事をしたと、そのときはそう思いながら、又あくる日のゆうがたになると、今夜も誘いに来やしないかなと心待ちに待つようになる。",
              "citation": {
                "source": "紀伊国狐憑漆掻語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、あすこ、ほら、木の幹のあいだから、チラチラ見えるだろう。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "海でおぼれて、このふかい底までしずんだ人間が、白骨になって、さんご虫の腕のあいだにちらちらみえていました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
