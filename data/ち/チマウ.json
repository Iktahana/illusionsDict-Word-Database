        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おいらあ、一月娑婆に居りあ、お前さんなんかが、十年暮してるよりか、もっと、世間に通じちまうんだからね。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "冗談じゃないぜ息が詰っちまうぜ」　彼は、暫くして少年を揺り起した。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふくろも子も乾上っちまう。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも心配事があると直ぐレコードをかけて直ぐ紛らかしちまう癖があるんだけれど。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくたちなんか、鼻でふきとばされちまうよ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはそのときばけものの胃ぶくろのなかでこの網をだしてね、すっかりかぶっちまうんだ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからおなかじゅうをめっちゃめちゃにこわしちまうんだよ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見送る三次がお絹に、Ｔ「そーれ見なせえお絹さん」　と言って、Ｔ「俺と一緒に居るとお前迄があの通りやくざ者にされちまう」　と言うのを、　始終無言で聞いていたお絹が、　袂で隠して居た十手を三次に示す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「困っちまうなァ本当に」と云ってる時、　又チョンチョンと鳴る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなに獲っていちゃ、シベリヤの兎が種がつきちまうだろう。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とんでもない処へ行っちまうぜ」と云うので、教えられたままにそこから直角に曲って南へ正しい街道を求めながら人気の稀な多摩の原野を疾走した。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんな奴を放って置いちゃ、北伐軍でもやって来た日にゃ、手がつけられなくなっちまうんだ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎は、あんまり気長く放って置くと、自分の努力が時効にかゝっちまう、と気をもんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だって、おじさんのようにひょこ／＼歩いていた日にゃ、斬るんだって、うつんだって人が逃げッちまうんじゃないの？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か、外の奴にしてやられちまう。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前金でも渡したら、もう、手にとれなくなっちまうぞ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕虜ンなっちまうぞ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おびき出した娘をかっさらッちまうのは、館駅街に於てやる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぎというものは、みんな天の川の砂が凝って、ぼおっとできるもんですからね、そして始終川へ帰りますからね、川原で待っていて、鷺がみんな、脚をこういう風にして下りてくるとこを、そいつが地べたへつくかつかないうちに、ぴたっと押えちまうんです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「早いといいなあ、囲って置いた葱だって、あんまり永いと凍っちまう。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ何だな、知ってれば味方の内情を、残らず饒舌ッちまう処だったな。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぎというものは、みんな天の川の砂が凝って、ぼおっとできるもんですからね、そして始終川へ帰りますからね、川原で待っていて、鷺がみんな、脚をこういうふうにしておりてくるとこを、そいつが地べたへつくかつかないうちに、ぴたっと押えちまうんです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（カムパネルラ、僕もう行っちまうぞ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも斯う人の居ない海岸などへ来て、つくづく夕方歩いていると東京のまちのまん中で鼻の赤い連中などを相手にして、いい加減の法螺を吹いたことが全く情けなくなっちまう。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全くいやになっちまうな。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやになっちまうなあ。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやになっちまうなあ。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……何んだ、試験だ……試験ぐらい貴様、教場に行って居眠りをしていりゃあ、その間に書けっちまうじゃねえか」「俺に用がなければ行くぞ」　石岡が顔色も動かさずにそういいながら座をはずしかけた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもあなた、きっと日本なんかいやだって外国にでも行っちまうんでしょう。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私あなたのことを思うと、変に悲しくなって、泣いちまうんですもの……戸部　　君……冗談をいうない、冗談を……花田　　ともちゃん、でかしたぞ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
