[
  {
    "uuid": "16c20765-0708-5455-ae81-e28534d2699d",
    "entry": "地代",
    "reading": {
      "primary": "ちだい",
      "alternatives": [
        "じだい",
        "じしろ"
      ],
      "is_heteronym": false
    },
    "grammar": {
