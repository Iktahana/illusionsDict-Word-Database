[
  {
    "uuid": "669c1676-e86d-5df0-9b5f-941e1f6df2e3",
    "entry": "昼夜",
    "reading": {
      "primary": "ちゅうや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
