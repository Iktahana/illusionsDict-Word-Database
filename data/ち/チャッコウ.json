    "definitions": [
      {
        "index": 1,
        "gloss": "starting (construction) work",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
