[
  {
    "uuid": "b54aaa91-274d-5f82-a885-07b0c0e544e8",
    "entry": "朝野",
    "reading": {
      "primary": "ちょうや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
