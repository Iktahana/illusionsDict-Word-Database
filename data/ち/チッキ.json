[
  {
    "uuid": "9c26c502-30f5-5437-a17f-9df495669a1c",
    "entry": "チッキ",
    "reading": {
      "primary": "チッキ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
