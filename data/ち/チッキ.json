      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "check (token for left luggage)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "身の廻りのもの一切、冬の着物、夜具、買い溜めていた靴、帽子のたぐいまで、持って行くことにしてチッキにして、劇団への挨拶、友人との別れ、町会への異動申告、みんな一人で半日かけずり廻って済ませ、信吉と汽車の中で食べる弁当まで自分の手で作って、駅へかけつけた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから僕は、銚子駅で、親切ごかしに僕自身の手でこ奴をチッキにつけたんだよ。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今頃は屹度岸田の奥さん、大騒ぎで両国駅へ、チッキならぬワタリをつけているだろうよ。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "手荷物のチッキも貰った。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれが鳴り止むと、今度はチッキンチッキンと忙しい音が続く。",
              "citation": {
                "source": "童話",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「で私は、チッキ主任ジョウジ・ブルッカアに、特に其のトランクの保留を命じました。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、そうですね、丁度正午頃のことです」　一人の青年を連れた若い女が、手荷物受取所へ現れて、チッキを提出し、そのトランク二個の交附方を求めたのだ。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "チッキの番号は、一つは「６６３１６５」、もう一つは、「４０６７４９」。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず、その日の正午にチッキを持ってトランクを受取りに来た、若い二名の男女の容貌、服装、言語の特徴などを、応対した駅係員に就いて詳細に聴取するところから、このセンセイショナルな捜査の第一幕は切って落される。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、チッキ主任ブルッカアは、何うもあの青年の顔に見覚えがあるようだと言う。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォニックス市のＳ・Ｐ会社へ宛てて、チッキ番号ＮＯ・４０６７４９と６６３１６５と、この二個のトランクを発送した人物に関する調査依頼の電報が飛ぶ。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「其の地でチッキを提出した婦人の人相に当て填まるものは」フォニックスの係員は続けて、「当署の調査に依れば、ルウス・ジュッド夫人ではないかと思われる。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の中川さも自慢顔に「大原君、このボイルドチッキンこそ如何なる贅沢家も金満家もまだ滅多に口にした事のない天下の珍味だ。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "小山の妻君もわざと調戯顔に「お登和さん、私は大原さんと反対で貴嬢のお拵えなさるような柔いお料理が大好きですがこのボイルドチッキンはどうするのですか。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "咲行李送ろうともって行かせたら、もう小荷物はうけつけないチッキだけという。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "チッキ島田迄三円也　この前東京に帰った頃よりは（六月下旬）ずっと閑散になっている。",
              "citation": {
                "source": "日記",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さいコーリもチッキにたのむ。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お寒くはないかと思つて、チッキで毛布とお下着を二三枚送りましたの。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきチッキにして送り出して、明日の私の出立ちは、小さい手提カバン一つです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "チッキが番号札もらうのに徹夜の由。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはわたしで、太郎と自分のチッキで荷物をすこしまとめてあちらに送れるということがあり、国も息子のお伴をわたしがして、おかみさんのこしてくれれば、田端まで荷運びもしてくれるでしょう、（荷運びもなかなかの問題ですから）急な思いつきですが、みんな好都合ということだし、わたしははりきりです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い出して、チッキを出して見てから、そのためにわざ／＼引っ返すこともないと決め、そのまま先へ行きました。",
              "citation": {
                "source": "クロイツェル・ソナタ",
                "author": "KREITSEROVA SONATA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにチッキがあるから、手荷物を貰って来い、さあ、早く。",
              "citation": {
                "source": "クロイツェル・ソナタ",
                "author": "KREITSEROVA SONATA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……英国では、汽車旅行して、手荷物をあずけても、チッキなどというものはない。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "チッキを信じるのでなくて、人間を信用する。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「田中館氏はチッキのない方が、高度の文明だと言われるが、人間には思い違いもあり、忘れることもある。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争で、物が不自由なころ、軽井沢へ出かける前に、苦心して手に入れた上等のお茶を、カバンに詰めてチッキで送ったところ、どうしたわけか、これが着かない。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
