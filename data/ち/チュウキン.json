[
  {
    "uuid": "677c9dca-b770-59b5-aef0-0eac7ab592bc",
    "entry": "鋳金",
    "reading": {
      "primary": "ちゅうきん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
