    "definitions": [
      {
        "index": 1,
        "gloss": "eldest daughter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」小坂氏は、ふり向いてその写真をちらと見て、「長女の婿でございます。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「長女の婿は三、四年前に北支で戦死、家族はいま小坂の家に住んでいる筈だ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜汽車の暗爾たる車燈の影に、長女は疲れて眠り、次女は醒めて夢に歔欷す。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこの物語を読んでいた時に、離れた座敷で長女がピアノの練習をやっているのが聞こえていた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこのセント・オラーフの最期の顛末を読んだ日に、偶然にも長女が前日と同じ曲の練習をしていた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後にも長女は時々同じ曲の練習をしていた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上がってからおよそ十五、六分も過ぎたと思う時分に、あわただしき迎えのものは、長女とお手伝いであった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び出る間際にも、「奈々子は泣いたかッ」　と問うたら、長女の声でまだ泣かないと聞こえた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "長女と長男を死なせた時には彼女の心も砕けたと思われたがそれもやり通して来た。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の半日をアトリエに籠つた夫は庭で二人の子供と快活な笑聲を立ててゐた長女の夏繪と四つになる長男の敏樹と、子供好きの夫は氣持よく仕事が運んだあとでひどく上機嫌だつた。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秀の父は東京府に勤めて三十五円ばかり取って居て夫婦の間にお秀を長女としてお梅源三郎の三人の児を持て、左まで不自由なく暮らしていた。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人の子供が銘々に隠しあって描いたのを長女が纏めて綴った後に発表する事にしていた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が亡くなった翌年の夏、郷里の家を畳んで母と長女を連れ、陸路｜琴平高松を経て岡山で一泊したその晩も暑かった。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長女は既に十四になっている。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻と長女とに下図を見せて違った所を捜させるとじきにいろいろな誤りが発見された。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや去年の秋、すぐ上の姉がその幼い長女と共に写した手札型の写真を一枚送ってよこしたが、本当に、その写真一枚きりで、他の肉親の写真は何も無いのだ。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長女が未だ八つにしかならぬのに、お兼は既に三人の娘たちの立派な縁組みを夢みていたのである。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間後に、もう夕陽丘女学校の四年生になっていた鼻の頭の赤いお兼の長女が豹一に乱暴な接吻をされて、十日余り、ぽうとした気持になっていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――政江の長女｜千満子の縁談であろうと人々はにらんだ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　庭で遊んでいた七つの長女が、お勝手口のバケツで足を洗いながら、無心に私にたずねます。",
              "citation": {
                "source": "おさん",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長女のマサ子も、長男の義太郎も、何か両親のそんな気持のこだわりを敏感に察するものらしく、ひどくおとなしく代用食の蒸パンをズルチンの紅茶にひたしてたべています。",
              "citation": {
                "source": "おさん",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長女は七歳、長男は四歳、次女は一歳である。",
              "citation": {
                "source": "桜桃",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は、一歳の次女におっぱいを含ませながら、そうして、お父さんと長女と長男のお給仕をするやら、子供たちのこぼしたものを拭くやら、拾うやら、鼻をかんでやるやら、八面六臂のすさまじい働きをして、「お父さんは、お鼻に一ばん汗をおかきになるようね。",
              "citation": {
                "source": "桜桃",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供、……七歳の長女も、ことしの春に生れた次女も、少し風邪をひき易いけれども、まずまあ人並。",
              "citation": {
                "source": "桜桃",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長女は北津軽のこの町の桶屋に嫁いでいる。",
              "citation": {
                "source": "親という二字",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長女は、かれのぶっとふくれた不機嫌の顔を見かねて、ひとりでは大人になった気でいても、誰も大人と見ぬぞかなしき、という和歌を一首つくって末弟に与えかれの在野遺賢の無聊をなぐさめてやった。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長女、次男は、逃げ廻っている。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長女は、私にはとてもその資格がありませんからと固辞して利巧に逃げている。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一家そろって、お雑煮を食べてそれから長女ひとりは、すぐに自分の書斎へしりぞいた。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　長女は、自信たっぷりの顔つきで、とどこおる事なく書き流し、ここまで書いて静かに筆を擱いた。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
