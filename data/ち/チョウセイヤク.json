        "examples": {
          "standard": [
            {
              "text": "イベントの成功は、敏腕な調整役の働きにかかっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、部署間の連携を円滑にする調整役として、チームをまとめ上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議では、中立的な立場の調整役が議論を整理した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "だが、一九七七（昭和五十二）年から一九七九年にかけて府中のコンピューターの開発、生産要員の約三分の一が営業や保守部門に配置替えとなる中で、ＩＴＯＳの開発は全体の調整役を置くという問題意識と人員の余裕を欠いたまま進められた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
