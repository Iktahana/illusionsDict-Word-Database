        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "クねずみはこわれたちり取りのかげで立ちぎきをしておりました。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はちり取りを持ってごみ捨てに川原に出ました。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムーアは敵の首根っこにがっちり取りついた。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご一新という大した浮世の機構を勉強して来たから、露八もこれからは、きっと、食うにゃ困らねえでしょうよ」「人が悪くなっちゃ交際いにくいね」「そう行けるくらいなら、大丞参議にゃなれないまでも、太政官のお髯のちり取りぐらいにゃ出世していまさあね」「冗戯をいってるまに、昏くなってしまう。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでツェねずみはしかたなしに、こんどは、柱だの、こわれたちりとりだの、バケツだの、ほうきだのと交際をはじめました。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてそののちのことですが、ちりとりはある日、ツェねずみに半分になった最中を一つやりました。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、いつものとおりツェねずみは、まどっておくれを百ばかりも、ちりとりに言いました。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちりとりもあきれて、もうねずみとの交際はやめました。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぱっちりとりっぱなやつが二つくっついていらあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、是からさきのしんふわい／＼ちりとりににてもかきのけられず、かまでもくわでもはらハれず、ふいぶん／＼せいだしてながいをとしををくりなよ。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年一月二十日　姪春猪あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十かいでは「ちりとり、ひとつ。",
              "citation": {
                "source": "ばべるの塔",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と　おねずみおばさんは　もっている　ちりとりを　うちならすのです。",
              "citation": {
                "source": "おねずみおばさんのはなし",
                "author": "THE TALE OF MRS. TITTLEMOUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして　まいにち　あさはやく　――　だれも　おきないうちに　――　もぐもぐハンカは　ちりとりと　ほうきを　もってきて　ドールハウスの　おそうじを　するのでした。",
              "citation": {
                "source": "わるねずふたりぐみのはなし",
                "author": "THE TALE OF TWO BAD MICE",
                "note": "青空文庫"
              }
            },
            {
              "text": "御寺の境内は申す迄もなく、近所の木の下かやの下までもおびたゞしい人数が充ちあふれて、輿、ちりとり、鞍を置いた馬などが幾千萬と云う数を知らず、凡そ其の日の群衆と云ったら、此のあたりの三箇国の人々が寄って来たのだと申すことでした。",
              "citation": {
                "source": "三人法師",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
