    "definitions": [
      {
        "index": 1,
        "gloss": "grave",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "聲はむしろ沈痛にさへしづんでゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "聲の調子そのものから、非常に沈痛の響をもつてた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにその時、あらゆる天才の不運について、藝術家の宿命的な孤獨と悲慘について、彼が沈痛な聲で訴へたか。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句には或る象徴的な、沈痛で暗い宿命的の意味を持った暗示がある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時間的なイメージを持っているところの、沈痛な魂の瞑想が感じられ、象徴味の深い俳句である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正客の歌人の右翼にすわっていた芥川君が沈痛な顔をして立ち上がって、自分は何もここで述べるような感想を持ち合わさない。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "心はあかしてのたまわねど、太くもの思に沈ませたまい、軽快｜濶達なりし昨日に似ず、憂鬱沈痛になりたまえば、どうして良かろうと、ご家来も呆れ果ててぞいられける。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠らのある者は沈痛に、ある者は憂慮わしげに、はたある者はあわただしげに、いずれも顔色穏やかならで、忙しげなる小刻みの靴の音、草履の響き、一種｜寂寞たる病院の高き天井と、広き建具と、長き廊下との間にて、異様の跫音を響かしつつ、うたた陰惨の趣をなせり。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　沈痛な調子で恁う云ツて、友は其の幅のある肩を聳やかした。",
              "citation": {
                "source": "虚弱",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　戰場での幻想　機關銃よりも悲しげに、繋留氣球よりも憂鬱に、炸裂彈よりも殘忍に、毒瓦斯よりも沈痛に、曳火彈よりも蒼白く、大砲よりもロマンチツクに、煙幕よりも寂しげに、銃火の白く閃めくやうな詩が書きたい！",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」戰場での幻想　機關銃よりも悲しげに、繋留氣球よりも憂鬱に、炸裂彈よりも殘忍に、毒瓦斯よりも沈痛に、曳火彈よりも蒼白く、大砲よりもロマンチツクに、煙幕よりも寂しげに、銃火の白く閃めくやうな詩が書きたい！",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして支那の詩の多くのものが、沈痛無比な響を以て人生を慷慨悲憤していることぞ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた方はむす子の友人です」それから沈痛な唇の引き締め方をして、また事務に取りかかった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』先夜ひそかに如上の文章を読みかえしてみて、おのが思念の風貌、十春秋、ほとんど変っていないことを知るに及んで呆然たり、いや、いや、十春秋一日の如く変らぬわが眉間の沈痛の色に、今更ながらうんざりしたのである。",
              "citation": {
                "source": "喝采",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　　　＊　　　　　＊　　　　　＊忽ち門内沈痛悲壮なるゐおろんちえろのそろ。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と呉々も申し聞かせたのですが駄目です」　荘子は腕を措き眼を瞑って深く考え沈んで居たがやがて沈痛な声の調子で云った。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "沈痛の呻吟この時、闇重き夜色のなかに蓬髪の男｜蹌踉き落涙す、蒼白き頬に。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや沈痛凄惻人生を穢土なりとのみ観ずる厭世家の境界に於てをや。",
              "citation": {
                "source": "厭世詩家と女性",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "何が故に二書を愛読する、曰く、一種の沈痛深刻なる哲理の其｜中に存するあるを見ればなり。",
              "citation": {
                "source": "「伽羅枕」及び「新葉末集」",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより急調に眼を過ぐるものを言ひ、「三ツ四ツおちし村雨は、つゝみかねたる誰が涙かな」にて結び、更に「玉鉾の道は小暗し、たどりゆく繩手はほそし、松風の筧の音も、身にしみていとうらかなし、」と巧麗婉艶の筆を以て、行路の詩人の沈痛なる同情を醒起す。",
              "citation": {
                "source": "「桂川」（吊歌）を評して情死に及ぶ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "広巳は蒼白い沈痛な顔をして黙々と歩いていた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢幻境　わが再び眼を開きし時の光景は、今猶目に在ること、彼壯大なる火山の活畫の如く、又彼沈痛なるアヌンチヤタの別離の記念の如し。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾千年の昔からこの春の音で打ちなだめられてきた上総下総の人には、ほとんど沈痛な性質を欠いている。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の声を知らない人に沈痛な趣味のありようがない。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学者じみた考えを持っていて、非常な勝気な男だ、真剣にえらいかどうか知れないが、とにかくいうことは奇抜で沈痛だ。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年に對する一片の訓示で特に奇拔なものではなかつたが其沈痛な低い聲が自分の胸を刺戟した。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四節までの友に対する語は、天地に挑むが如き元気｜充盈せるものにて、あたかもバイロンやニエチェの一篇を読むようであるが、これに反して二十五節以下は沈痛｜悲寥なる哀語である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "韻律の日本の実体は海の潮騒のやうな厳粛沈痛なものと知つてくれ。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "終はりに語らんとするもの、是れ曩に驚絶駭絶の経験と言ひたるものにして、これまで予が神の現前につきて経験せるもののうち、かくばかり新鮮、赫奕、鋭利、沈痛なるはあらじと思はるゝ程なり。",
              "citation": {
                "source": "予が見神の実験",
                "author": "綱島梁川",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
