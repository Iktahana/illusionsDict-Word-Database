        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夕刻又出かけ、新宿中村屋でボルシチと炒飯を食べ、丸の内へ出て東宝名人会へ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "東興園の焼売と炒飯をとる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼売大きくて味気なし、炒飯は、まるで淡りしてゝ話にならない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆきひらと牛乳沸しの中に、めしと汁などがはいっていて、それはパンとシチューであったり、チャーハンとコーヒーであったり、肉と野菜と魚と、パン屑や米のめしの入り混った、なんと云いようもない食物であったりしたが、父も子も、それがどんな料理であるかについては、無関心であった。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "食べ始めた僕は、父親がチャーハンをうまく作ったことを、思い出した。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご飯しかないときには、葱を細かく刻んで具にして、父親はおいしいチャーハンを作った。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、なぜだか、チャーハンばかりつくる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャーハンとしては、けっこういける。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャーハンをつくれ、山のなかで」「いいよ」　ミーヨとふたりでキャンプにいったときの道具を、まだあずかったままだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りに、屋台のどて焼とチャーハンを食って、宿へ帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜店のドテヤキ、チャーハンと下れば又他地になき味あり。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "村上日麿といふ金持らしき人物現はれ、一緒に飲まうと残月といふとこへ行き、帰りに夜店のチャーハンを食った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これとチャーハンが軒を並べて出てゐる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "主任の岡崎と上山・白川・須田村・ＰＣＬの三上等でラッキーへ、ウイのみ、夜店のチャーハン食って帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "座へ出る前、支那グリル一番でシュウマイ、チャーハン。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
