        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「チェッ、電気ブランでも飲んで来やがったんだぜ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "次はヘルマン・チェッツ百貨店の二三町もあり相な延大な飾窓は、殆ど実物大の小屋の数層を数多見せ、サンタクロースが壮厳にある屋根から降りつつ見る下の此処彼処の家に、小児が贈物を待ちつつ眠るところ、何れも豪華に独逸の精力的な重大性を見せたものです。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ではまた露語でｇがｈに代用されまた時にｖのように発音されることから見ると、フィン語の山 vuori やチェック語の hora が同じものになるし、ｈが消えたりｖが母音化するとギリシアの oro や蒙古の oola も一つになって来る。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくロシアの golova, glava（セルボ・クロアチアも同じ）、チェッコの hlava, ズールの inhloko（in は接頭語）等いずれも「カラワ」と音が近い。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "することが綿密丹念で手綺麗で、面倒な計算をチェックしたり、実験の読取りを記帳し、また自分でも読取りをやった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「貴ン方怒るかも知れないけれど、妾……子供だけはやくざにしたくないの」　「チェッ何を言ってやがんでえ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェッと舌打ちしてその印籠を投げる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次チェッと舌打ちする。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "手くせが悪れぇや、チェッ！",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……山仕事の方がどれだけ面白いかしれない……「チェッ…………どうなりゃ！",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代の人が驚異したのに無理はないが、今日はバッチェット方法、ポイグナード方法、その他の方法を知れば、随分大きな魔方陣でも列べ得ること容易である。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "返すと見えたのは包装のボール箱だけ……又は用意して来た、ほかの下らない本を詰めたりしてモトの隙間へ突込んで、入用な本はチャント脇の下に挟みながら……チェッ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてチェッキが出来たらアンタ自身にソレを持って駅で待っていて頂戴ね。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ、荷物とチェッキが出来ないじゃ御座いませんか。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋山男爵はこの言葉を聞いて、「チェッ残念※」と一言叫んだと思うと、急所の傷手にはかなく絶命して終った。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さああまがえるどもはよろこんだのなんのって、チェッコという算術のうまいかえるなどは、もうすぐ暗算をはじめました。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるものは松露をへし破って、チェッと言って水に棄てた。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "港の停車場に着くと、父は車夫を呼んでチェッキで大きな赤革のスートケースを二つも受け取らせた。",
              "citation": {
                "source": "父を失う話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "高価なネクタイだのチェッコスロバキヤの硝子細工だのを売る店の様子は戦争に行く前とちっとも変っていませんでした。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェッ、あのアヒルの子は、ありゃあ、なんてやつだ。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "各社とも騒いで居るんだが、何か一つ特種を市内版までに抜かなくちゃならないんだ」「村井は居ないのかい」「チェッ。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "絽の帯も……ヴェールも……アッ……束髪の仮髪だこれは……畜生……どこかで変装しやがったナ」「……チェッ……」と一人の私服らしい男が舌打ちした。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿題「チェック・チャックに就いて。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま面白そうな本を引っぱり出して中を二三行読むと、直ぐにチェッと舌打ちしてモトの本棚に押込んでしまうのであるが、何が、お前をそうさせるのかと、自分の頭に反問しても、返事は一つも浮かみ上がらない。",
              "citation": {
                "source": "探偵小説の正体",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると父は何と思ったかチェッと一つ舌打ちして遠ざかって行った。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同胞の露西亜人には無論のこと、チェックにも、猶太人にも、支那人にも、米国人にも……けれども一人として信じてくれるものがいないのです。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チェッ、素敵なものか。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前はこうやって今じゃお前の家にいるが、おいらまだ塩漬樽の中から、塩臭え肉をつまみ出して喰ってるのよ」「チェッ。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「チェッ、なんだい。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い文章の中から、チェックしたいと思う言葉を検索する。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
