  {
    "uuid": "299472d7-e079-5450-b6ae-bdc57aa04566",
    "entry": "超低",
    "reading": {
      "primary": "ちょうてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
        "接頭辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "very low (deep, cold, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一九七五（昭和五十）年一月号の『ポピュラーエレクトロニクス』で発表されて以来、アメリカではキット式の超低価格コンピューター、アルテアの人気が沸騰していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "或るときは敵機が超低空で機銃掃射を加え、そのガソリンの煙と香いが室内に流れこんできたこともある。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "超低速でぼくたちの前まできたヤマハＲＤ２５０は、とまった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カワサキにとっては超低速に近いスピードで、ぼくはさらにミニ・パトカーをひきつけた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らん顔で、ぼくは、超低速の蛇行をつづけた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉は風に負けまいとして一生懸命に走っているが、カワサキにとっては超低速だ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
