    "definitions": [
      {
        "index": 1,
        "gloss": "penis",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "流れ渡った洋犬でさえ骨一つでちんちんお預はするものを。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "上手にちんちんを致します、それそれ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく洞穴へ帰って来た子狐は、「お母ちゃん、お手々が冷たい、お手々がちんちんする」と言って、濡れて牡丹色になった両手を母さん狐の前にさしだしました。",
              "citation": {
                "source": "手袋を買いに",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れるまで……日本の憂鬱な十月の夜の彼岸に寂しい三味線がちんちんと鳴り出すまで、なほも善主麿、おおらつしよの祈をつづけながら……無益にも……月の方に青ざめた帆前の黒い幻想を眺めながら……",
              "citation": {
                "source": "北原白秋氏の肖像",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でん、いや、でん、つるんでん、ちんでん、いや、ちんちんちんでん――」　夕月の三日月の下の河岸の家から地太い男の声で浄瑠璃の口三味線が聞えています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちんちんをするような形で、棒を呑んでしゃっきりと立った、愛吉の前へ小さな紫檀の食卓の上から、衝と手を伸ばして、（親方、申上げよう、）　といって猪口をさして、山の井さんが、呵々と笑ったとお思いなさい。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一電車のちんちん鳴るので驚いた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからそのちんちん鳴るあいだに、非常に多くの人間が乗ったり降りたりするので驚いた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルがちんちんちんちんいう。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄瓶がちんちん鳴っている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "扶桑教といや、ちんちんもがもがの行者じゃねえですか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もうお盆はあと二日ののちに迫っていたので、おりからちょうど非番だったのをさいわい、のこぎり、かんな、のみ、かなづちなぞ大工の七つ道具を、ちんちんと昼日の照りつける庭先に持ち出しながら、しきりと今日さまにおせじを使って仕事にかかりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は私が厭がれば厭がるほど巧みに私の眼を盗んで、マルを伴れ出すと、途方もない虫ケラなどを囮にして、ちんちんとか、おあづけなどといふ類ひの芸を仕込まうとするらしいのだ。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "見なさい、鉦たたきは、あの小高い木の枝でちんちんとお念仏の鉦を叩き続け、おかまこほろぎは、彼奴が大好きな人家に潜り込むことすら忘れて、あんなに機嫌よく踊つてるぢやないか。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "藥罐をちんちん云はせにや。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして女房のちんちんなどは素知らぬ顔で相変らずお茶を啜つてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんはと聞くと、電車ちんちん餡パン買いに行ったなんて、それは面白いことを言いますよ。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、下町の心に自然な暢やかさがない者達が、いじらしい程怜悧な犬をつかまえて、ちんちんしろだの、おあずけだの、おまわりだのさせて居るのを見ると、まるで心持がわるい。",
              "citation": {
                "source": "犬のはじまり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隣りが自分の家で、そのまた次ぎには電車の車掌がいて、人のまだよく眠ってる時からがたッぴしやりだして、ちんちん屋の商売に出て行きゃアがる。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちんちんちんと鳴って来るのは、何の音か。",
              "citation": {
                "source": "詩集『花電車』序",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が更けると、汽車の汽笛が四圍に響くのと、時々手水場の板戸の音がする外は、部屋の火鉢にかけた鐵瓶がちんちんとたぎつてゐるだけ、かうした靜かな部屋で、孝次郎はふつと名古屋にゐる中學時代からの仲のよかつた友人を思ひ出した。",
              "citation": {
                "source": "雨",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "師匠上ったりで、いよいよ裾をひろげらあ」　と、いった時、泥溝板に音がして、一人の若い衆が、下駄を飛ばした、片足をあげて、ちんちんもがもがしながら、大きい声で「とっ、とっと――猫、転んで、にゃんと鳴く。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、瓦をことこと鳴らしつつ、二階の窓から、入って来て「ちんとち、ちんちん、とちちんちん、ちんちん鴨とは、どでごんす――」　と、唄いながら、段を下りた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士春が「騒々しいね」「ちんちんもがもがどでごんす」　益満は、片足で、三段目から、飛び降りて、そのまま、ぴょんぴょん、富士春の側へ行こうとすると、火鉢の前に一人の男が坐っていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
