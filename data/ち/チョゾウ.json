[
  {
    "uuid": "ff92ee4a-92b8-5cd2-8123-1b2453ccdf39",
    "entry": "貯蔵",
    "reading": {
      "primary": "ちょぞう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
