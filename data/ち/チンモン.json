          "literary": [
            {
              "text": "・珍問答　　お月さんですよ！",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日、書き洩らしてはならない珍問答を書き洩らしてゐた、大堂津で藷焼酎の生一本をひつかけて、ほろ／＼機嫌で、やつてくると、妙な中年男がいやに丁寧にお辞儀をした、そして私が僧侶（？",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっと上った笑声の中から、このひとは赤ちゃんをどこへおんぶするつもりかしら、などと珍問も出る。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下ことごとく日本人同士英語での珍問答と心得べし。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
