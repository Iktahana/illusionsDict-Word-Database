    "definitions": [
      {
        "index": 1,
        "gloss": "(Japanese-style) living room",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
