    "definitions": [
      {
        "index": 1,
        "gloss": "putting a criminal to death",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「誅戮」「討伐」「征伐」「征討」などと、武張ったどこかの国のジャーナリストなら書きたい所であろう。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後遂に誅戮せらる、恁の如きもの人妖也。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ燕王は叔父たりと雖も、既に爵を削られて庶人たり、庶人にして兇器を弄し王師に抗す、其罪｜本より誅戮に当る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "四度目の罪がある場合には間違いなく誅戮なさるでしょうな。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四度目の罪がある場合には間違ひなく誅戮なさるでせうな。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天に代って貴様等を誅戮に来たんだ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに勤王派が盛り返すと今度は佐幕派の全部を誅戮する。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "其身既に誅戮を蒙りたる者なれば、行の是非を論ぜず、其の勇に至りては惜む可き壮士なりと云はざる者なし――　とある。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、蘇我氏のかゝる不臣が許されるわけはなく、御英邁なる中大兄皇子を中心とする中臣｜鎌子（後の藤原鎌足）、蘇我｜倉山田石川麻呂、佐伯子麻呂等の活躍に依つて、皇極天皇の四年六月、入鹿は大極殿に於て、誅戮を受けたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "薩長の諸将は慶喜を憎むこと甚だしく、ぜひこれを誅戮して、刑典を正さねばならぬと主張する者が多かつたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの大臣これ後日聖主となり亡国を復興する人物と、后に向い祝辞を述べ、家人を戒めこの語を洩らさば誅戮すべしというた。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでは大黒時に鼠や賊を制止｜誅戮し、槌は殺伐の具となって居る。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙りのなかへ駈け入って早く妖魔を誅戮せよ」　かの大まさかりを掻い込んで、雷震はどこからか現われた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにも仰々しく誅伐の誅戮のと騒ぎ立てるには及ばないのであると、彼女は事もなげに説き明かした。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "若私にも御嫌疑被為在候へば、何等の弁解も不仕候間、速に私｜御召捕に相成、私一人｜誅戮被為遊、他之者は不残御赦免之御処置｜相願度奉存候。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "温和なる宋の太祖の如きは、巧言を以て宿將を説服して、權要の地を退隱せしめ、刻薄なる明の太祖の如きは、露骨に功臣を誅戮した。",
              "citation": {
                "source": "支那人の妥協性と猜疑心",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は第一囘の北伐の時に、大將の馬謖が彼の指揮に違背して敗軍した罪を正すべく、之を誅戮した。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "隋の煬帝が叛臣の斛斯政を捕へて之を誅戮し、その肉を烹て、百官をして之を食せしめた。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は諸方面の反感を買つたが、後にその罪惡が暴露して誅戮された時、かねて彼の專横を惡める人々は爭うてその肉を食した。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "旌表と誅戮とは、一致することが出來ぬ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "禮として旌表すべき者を誅し、刑として誅戮すべきものを奬めては、國民をして適從する所に迷惑せしむといふのである。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、（※）の二つで御座いまして、双方ともに、神通誅戮と云う意味が含まれて居ります」　と盤得尼は、妙に皮肉にともとれる微笑を湛えて云い返した。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誅戮などと云う怖ろしい世界が、御仏の掌の中にあろうとは思われませんでした。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "燃ゆるが如くなる、血性の彼にして、焉ぞ手を袖して誅戮を待たむや。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が旗下の桃李寥々たりしにも関らず、四郎兼平の如き、次郎兼光の如き、はた大弥太行親の如き、一死を以て彼に報じたる、是を源頼朝が源九郎を赤族し、蒲冠者を誅戮し、蔵人行家を追殺し、彼等をして高鳥尽きて良弓納めらるゝの思をなさしめたるに比すれば、其差何ぞ独り天淵のみならむや。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの者、不忠、不所存きわまるによって、誅戮いたしたまででござる。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
