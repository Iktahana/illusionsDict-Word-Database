    "definitions": [
      {
        "index": 1,
        "gloss": "features of the Earth (rivers, mountains, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうして世界の可死を論じるために水や空気や火の輪廻を引用して種々の地文学的の問題に触れている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この四箇条などは、おそらく今でもどこかの川について地文学者のだれかが月並みに繰り返しつつあるものと全然同様である。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その絵はがきの中に天文や地文に関する図解や写真をコロタイプで印刷した一組のものが目についた。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学に行くようになってからは、小冊の地文学、地理書のようなものを数多く読み、また小説なども大いに読んだものである。",
              "citation": {
                "source": "わが中学時代の勉強法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五節、六節には彼の地文学の知識が窺われる、「彼れ（神）山を移し給うに山知らず、彼れ震怒をもてこれを覆し給う」は火山の爆声を形容せし語、「彼れ地を震いてその所を離れしめ給えばその柱ゆるぐ」は大地震を描きし語である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「地」というも勿論当時の地文学に循っての語であって、地球を意味せず、地を扁平なものと見ての言である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの小説は嫌ひだが眼は好きです円地文子よだが惚れることは差控へようあなたは散文的に恋愛をするさうだから。",
              "citation": {
                "source": "小熊秀雄全集-12",
                "author": "詩集（11）文壇諷刺詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一層大きいなら、日本の話より五大州の話、ないしは天文地文の話、地獄極楽の話などの方が、効能がありはしませんかな。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用聞きというものは、人相手相方宅から、うらない、まじない、天文地文、そういうものまで知らなけりゃアならねえ、てめえ達のつら、どうもよくねえ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二は、可なり朦朧とした Creature と Beings の説明で、第三から人体、衣食住に関する常識以下、博物、地文、産業、経済、物理、生理にまできっちり七行ずつ、触れている。",
              "citation": {
                "source": "蠹魚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窪川稲子「素足の娘」、真杉静枝の「小魚の心」「ひなどり」（短篇集）、大谷藤子「須崎屋」、中里恒子「乗合馬車」、壺井栄「暦」、そのほか矢田津世子「神楽坂」、美川きよ、森三千代、円地文子など当時の婦人作家はその人々の文学的閲歴にとって無視することのできない活動をした。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと後、昭和に入って『女人芸術』の出来た頃戯曲で出発した円地文子が、それから後に小説に移ってしまっている事実も、私たちに婦人劇作家の成長の困難さについて考えさせる一つの実例である。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この雑誌には、山川菊栄、神近市子、板垣直子のような評論家からフランス文学の翻訳の仕事をした大久保（八木）さわ子、そのほか下位文子、正宗乙未、松本恵子等の翻訳家、平林たい子、中本たか子、戸田豊子、大田洋子、円地文子、大谷藤子、真杉静枝、大石千代子、林芙美子、詩人として永瀬清子等の作品ものせられた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは戯曲家で出発した円地文子の名が、記憶にあるのは久しいことであるし、地味な大谷藤子が、ぽつりぽつりと発表して来ている作品の数も既に少くない。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "之等の一見、つまらなく見える話を、鉱物学だとか、地文学だとか云ふ見地から、総て解決し、説明し得たりと思つて居ると大変な間違ひであります。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "正雪は一代の反抗児、十能六芸武芸十八番、天文地文人相家相、あらゆる知識に達していたので、曾て驚いたことが無い。",
              "citation": {
                "source": "鵞湖仙人",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天文地文数学などに極めて造詣の深かった亜剌比亜人の建築物だけに、何処も彼処も幾何学的に、それでいて如何にも装飾的に、出来ているのでございます。",
              "citation": {
                "source": "西班牙の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその所謂日の本の地も、内地文化の進展とともに、次第に東方に退却して、近世では北海道アイヌは得撫以往の北千島をチュプカと呼び、その住民なる千島アイヌをチュプカグルと云う。",
              "citation": {
                "source": "国号の由来",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二）民間地文学的説話（イ）干満潮の理由如何　「アイヌ」神話は答えて曰く、世界創造の以前に、混沌の中に大なる魚あり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が地理や地文を覚えるのに何程の助けになるか知れやしない。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "△潟の生成變遷する地文上の趨向　此地方を歩いて見ますると、潟が出來てはまた無くなる地文上の趨向が善くわかるのです。",
              "citation": {
                "source": "潟に關する聯想",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年地文学教書や対数表が出版されたが、これも急場を切り抜けるためのアルバイトではなかったろうか。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる精密な地文学的条件の下にこの地点における氷床の形成が行われたかは、今後の解明を待たねばならない。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡本かの子、円地文子、小山いと子、佐藤俊子、宇野千代子、矢田津世子の諸雄です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙雛、島の雛、豆雛、いちもん雛と数うるさえ、しおらしく可懐い。",
              "citation": {
                "source": "雛がたり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おらも婿だが、昔から譬にいう通り、婿ちもんはいやなもんよ。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おう機と云へばなイ手古奈、綿ちもんは立派なもんだど、明日にも一寸畑へ往つて見てきさい、なイ手古奈や雪のやうな白い實がなつたど」……いつになく兄が話をする。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時の約束でしたが、ああ、久しぶりに仕事にありついたばっかしに、ちっとばかり慾を出して、つまり天罰ちもんでしょうか？",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "標題だけでも大した値うちもんだからね！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし　これは　とんちもんどうですから、また　べつです。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
