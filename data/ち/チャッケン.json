        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "身体の芯から慄えてきて、着剣している銃を持った手がしびれて力が抜けてしまう。",
              "citation": {
                "source": "戦争について",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼れは、小屋のかげから着剣した銃を持って踊りでた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂場の入口は、着剣した二人の歩哨によって守られた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、西はずれの、三倍の抵抗力にやり直した堅固な土嚢塁に、はゞまれた細い通りで、一人の支那人をつれた日本人が、着剣の歩哨に咎められていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーキ服の兵士達は、着剣した銃をさげ、ばらばらとそのあとへ現われた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "着剣のカーキ服が馳せて来る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "着剣した銃を持って、四五人のカーキ色の兵士が、ばらばらと立っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが終らないうちに、右翼は、重藤中尉が先頭に立って、開き扉を押し割り、着剣した銃を突き出し、クレゾールくさい室内へ突入していた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は銃に着剣して人間を突き殺したことがある。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "着剣した、兵士の銃と銃、剣と剣が触れあって、がちゃがちゃ鳴ったり、床尾板がほかの者の剣鞘をはねあげたりした。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "着剣をしているではないか！",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次の汽艇からも、やっぱり銃の先きに、着剣した、顎紐をかけた水兵！",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "着剣をした警戒兵がドヤドヤと入ってきて、扉の脇に立つ。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はＡと、もう一人信州の男と、三人で、着剣の兵に守られた処々を通り林町の通りに出、門を見、自分にかけよるきよの声をきく、父上の無事を知ったら何とも云えない心持がした。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○○の一将校が、銃に着剣をした○○兵を従へて、のつそり歩いて来た。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "今井君は銃に着剣して私のそばについてゐてくれ、私も万一の用心に拳銃を手に握つてはゐるが、どうも芝居じみてゐるやうな気がしてならぬ。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪船上の乱闘　闇の海上に、魔のように眠っている汽船サルビヤ号の舷側へ、静かについたモータア艇があったと見るまに、するすると龍介君を先頭にした、博士、大佐、着剣した銃を持った水兵十名の一隊が、甲板に乗移った。",
              "citation": {
                "source": "危し※　潜水艦の秘密",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
