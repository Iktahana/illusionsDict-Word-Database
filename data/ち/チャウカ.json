        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……泣きっ面なんかしてると汽車の中へ置いてきぼりにしちゃうから！",
              "citation": {
                "source": "父を失う話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなばかげた気まぐれは、どっかへとんでっちゃうから」「でも、水の上を泳ぐのは、すばらしいんですよ」と、アヒルの子は言いました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『でも、あたし、姉さんと違って、安眠しちゃうから。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたいたちも見つかると喰べられちゃうかもしれないから、喰べられそうになったら、早く鬼を殺してしまわないといけないんだって……」「ああ、もうそんな話はよそう。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私どもきっとぐっすり眠っちゃうから、明日の朝まで荷物見るものがないでしょう？",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　引こしがあってその荷もつを　八時半までにつれて来る「小母さん、じゃ煉炭に当ってて下さい　ひぐまいさんが来ればすっかりそろっちゃうから」　行くというのが父母が十三人　みんな子供をつれて行くということ。",
              "citation": {
                "source": "「乳房」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからそんな余計な心配をしないで一パイお飲みなさいったら……飲まなけああんたを殺したいわけを話さないからいい……寝てる間に黙って殺しちゃうから……さあ……グッと……そうよ。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾あんたが睡ってたって構わないから……そのまんま突き刺しちゃうから……いいこと……？",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きっと今にどうかなっちゃうから、見ていらっしゃい」　藤堂は暫く黙っていたが、しんねり、「こいつもヒステリーです」と云った。",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五ヵ年計画を、万ガ一にも投げちゃうかも知れない。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一緒に暮せる間、万々遺憾ないように大いに積極的に暮すべきだわね」「そんなことになると、作家同盟の婦人作家が片っ端から『愛情の問題』の傑作ばかり書いてやりきれなくなっちゃうかもしれないね」　これには思わずみんな笑い出し、云った当人の窪川いね子も床の上に座ったなりハアハアと笑った。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――本当にね」　素直にまさが同感し、手をやめて眺めていたが、やがて、「いいよ、どうせじきに黒くなっちゃうから」　そして、さっさとすっかり白テープをとおし、結んで、手のひらの上に両方揃えてのせた。",
              "citation": {
                "source": "鏡餅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「エエたしかに――だけどあんまりすきかすきかなんておっしゃるときらいになっちゃうかもしれない――」　千世子はこんな事を云って笑った。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚するくらいなら、あたしたち、情死しちゃうかも知れないわね。",
              "citation": {
                "source": "死の前後",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝床の中で口説かれるなんて、そんなこと、私田代さんに惨めな思いさせたり惨めな田代さん見たくないから、許しちゃうかも知れないのよ。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "○九時すぎに出て、お茶の水まで歩いて、新宿に出ようと云いながら、Ｙ目白まで買ったよ、かえっちゃうかもしれないと云って、家へかえって来てしまった。",
              "citation": {
                "source": "日記",
                "author": "一九三一年（昭和六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が変れば、どこかへ行っちゃうから、それまで置いてね」　もう友達同士のような口々きいて、なれなれしいものだ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑わないと泣いちゃうからさ、というフィガロの科白が題字のところに刷りこんである。",
              "citation": {
                "source": "茶番に寄せて",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それを彼女ときめちゃうから変なんだ。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いきって、やッちゃうからね」　坊介は奏楽の騒音にまぎれて、そッと半平にさゝやく。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "エロ作家ぐらい、一目で悩殺しちゃうからネ。",
              "citation": {
                "source": "お魚女史",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなムダづかいしちゃうから、ダメね。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "デー　いいね、この子も見物できる、ただ近寄りすぎない方がいい、ぼくはいつもいきり立ったら見えるものは何でも叩いちゃうから。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダン　それにぼくは見えても見えなくても手当たり次第に叩いちゃうから！",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわいそうに　アリスみたく　つまさきを　ふまれちゃうから。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてやそれどころか、ハリネズミをどこへ転がしたいにしても、たいていその方向には凸か凹、それに２つ折りの強者どもはしじゅう起き上がってべつのところへ歩いていっちゃうから、アリスもたちまち、この試合むつかしすぎると思うにいたる。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてやそれどころか、ハリネズミをどこへ転がしたいにしても、たいてい行く先には凸か凹、それに２つ折りの強者どもはしじゅう起き上がってべつのところへ歩いていっちゃうから、アリスもたちまち、この試合むつかしすぎると思うにいたる。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "百合子は人差指を唇にあて、「云うときかないよ、殺しちゃうから」　そこに落ちていた小道具の短刀を突きつけて威した。",
              "citation": {
                "source": "鷺娘",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここんとこまで読んだら、ミミコすぐねちゃうから。",
              "citation": {
                "source": "あとの祭り",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
