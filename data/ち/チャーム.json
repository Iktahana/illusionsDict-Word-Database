        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "勝太郎の声のチャームがすっかり打消されてしまっている。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "額から鼻へかけての対称的な白ぶちが彼女の容貌に一種のチャームを与えていた。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして何処かに判然しないチャームを持っています。",
              "citation": {
                "source": "木下杢太郎著『唐草表紙』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "古藤は思わず笑いをもらしながら、「間違うとたいへんですから」という言葉を、時おり葉子の口から聞くチャームに満ちた子供らしい言葉の一つとでも思っているらしかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のチャームというものが、習慣的な絆から解き放されて、その力だけに働く事のできる生活がそこにはあるに違いない。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "総てに懐しい昔の錆が現われて、石に生えてる苔までが、私をチャームするのです。",
              "citation": {
                "source": "「奈良」に遊びて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょッと男をチャームするところのある女だ。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "美少年のことを、チャームと言っていた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のチャームを持って連れて歩くのが幅利きであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「初心」という小説を書いて、中国新聞に投書したりしていたが、度々私が遊びに行くのと、本人が色々話すので、私が、野平君のチャームだという噂が立った。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「上級生のおもちゃなんかになるものか」　やはり美少年の噂のあるクラスの誰れ彼れが、その私たちをなぐると言って威した野球選手のＹのチャームになったということを聞いて、私はひそかに軽蔑した。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも私がチャームされたのは水芸の始まる前のアトラクションのような形で、ピエロを対手におどって見せたダンスであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の鋭い年少の感受性は神楽というもののチャームを把握した。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の噂では彼は宮本のチャームになり、その自転車も買って貰ったのだという事であった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は宮本のチャームだって人が言ってるよ」「親切にして下さるから仲よくしてるだけなんです」　彼は額を赤らめもせずにこう言って、試めすように私の顔を見ていたが、「あなただったらいいんだけれど」「僕は何も買ってあげられないよ」「何も要りません」　と彼は強く言った。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに親しくこの人に接したものは、彼の青ざめた顔、大きな口、凹んだ眼を忘れてその慈愛に富んだ表情にのみチャームされた。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "千鳥波は女の初々しさ、ウブな色気にひと方ならずチャームされるところがあったから、一度はこんな風にこれも女の初々しさによるせいだなどゝ思ってみたが、そうじゃない。",
              "citation": {
                "source": "ニューフェイス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の物徂徠ほどの人間でさえ、中国風には兜を脱いでその容貌風采に全く惚れきってしまったくらいだから、大概な人間が一応はチャームされるのも決して無理はないが、それにしても今日までにはずいぶんと体験も積んだことだから、今後はチト心して自覚すべきではないか。",
              "citation": {
                "source": "陶磁印六顆を紹介する",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこを取り立てていうことは出来ないが、一種のチャームを持っているのである。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、蜀山人と貝原益軒もいいが、外国のものでは、チャーム・オブ・ロードですね。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ある者にはチャームの力を試し、　ある者には薬の入った液体を与える。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿山には一種のチャームがあり、海外におっても夢は故郷を回らずして鹿山の空に落ちたことが屡※あった。",
              "citation": {
                "source": "鹿山庵居",
                "author": "鈴木大拙",
                "note": "青空文庫"
              }
            }
          ]
        }
