          "literary": [
            {
              "text": "Ｂ女は、「うち、チキンカツやわ」と言う。",
              "citation": {
                "source": "色町洋食",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "終って大阪屋のホワイトシチュウ、チキンカツと飯。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋谷の白十字で、一人はかなくチキンカツを食って帰宅。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "出て、赤門富士アイスでチキンカツを食ひ、押切駅へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月二十四日（月曜）　十一時起き、ガスビルへ永田氏を訪れる、女房とも／″＼行くと、食堂へ案内され、昼食と他にチキンカツレツを馳走になり、二階の映画場で「木に攀る女」といふ映画を見る、涼しくていゝ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "六時半、チキンカツ、ぶりの煮附にて、飯を二杯半と食った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
