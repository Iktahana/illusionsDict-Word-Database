          "literary": [
            {
              "text": "「あたし、チーズバーガーも。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「サブマリンサンド」とか、「チーズバーガー」とか、「ペストリー」とか、「ワッフル」とか、知らない食べ物ばかりだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "チーズバーガーというのは、どういうものかと、慶一は知子の皿を見た。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、チーズバーガーか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に入ってテリヤキチキンバーガーとモスチーズバーガーを注文し、オレンジ色の番号札をもらって空いているスツールに坐り、ハンバーガーが焼き上がるまで待った。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンバーガーと称する、ハンバーグ・サンドウイッチや、チーズバーガーなんていうものが、スナック・バアでは、どんどん売れている。",
              "citation": {
                "source": "ああ東京は食い倒れ",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
