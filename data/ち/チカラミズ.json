      {
        "index": 1,
        "gloss": "water offered to wrestlers just prior to a bout",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
