      {
        "index": 1,
        "gloss": "poems collected at the behest of the Emperor (from 905 to 1439)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
