  {
    "uuid": "60e3b89c-2646-5074-8551-9629a8a0c2c4",
    "entry": "珍果",
    "reading": {
      "primary": "ちんか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
