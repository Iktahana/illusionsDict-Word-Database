[
  {
    "uuid": "57ce2e56-5814-58c8-beda-70fe1fd20a32",
    "entry": "千曳",
    "reading": {
      "primary": "ちびき",
      "alternatives": [
        "ちひき"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
