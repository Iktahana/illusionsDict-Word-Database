    "definitions": [
      {
        "index": 1,
        "gloss": "to fall (e.g. blossoms, leaves)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "水部の線宮沢賢治きみがおもかげうかべんと夜を仰げばこのまひる蝋紙に描きし北上の水線青くひかるなれ竜や棲みしと伝へたるこのこもりぬの辺を来れば夜ぞらに泛ぶ水線の火花となりて青々と散る",
              "citation": {
                "source": "水部の線",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里の喫茶店で、街路にマロニエの葉の散るのを眺めながら、一杯の葡萄酒で半日も暮してゐるなんてことは、話に聞くだけでも贅沢至極のことである。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪の中に一本大きな赤椿があって、鵯の渡る頃は、落ち散る花を笹の枝に貫いて戦遊びの陣屋を飾った。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "否今もなおこの凩に吹き散る雲の影のようななんらかの希望の影を追うているではあるまいか。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さかなたちは、靜かに無言で左右に散る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷が狭くなって、崖側を行くと、緩いながらも雪の傾斜で辷るから、ミヤマナナカマドの枝を捉えながら上る、前にも増した雪の断裂で、草鞋に踏み蹂った雪片は、山桜の葩弁のように、白く光ってあたりに飛び散る。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その梢に、一面のほうけた絮が、風もないのに、氷でも解けるように、はらり、はらりと、落ち散るのであった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年九月十二日『東京朝日新聞』）　　　　　　　　　二　　　　　　一葉『淮南子』には一葉落而知天下秋とあるが、植物学者に聞いてみると、木の葉が夏過ぎて落ち散るのは葉柄の根元の処にコルク質の薄い層が出来てそこだけ脆くなるから少しの風にでも誘われて天下の秋を示すものだそうだ。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それッとばかり八方に散る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "海峽の霧の夜に朧ろな月が差し入る時、または靜かな秋の夜にポプラのわくら葉がかさこそと散るのを聞く時、彼等は密かに床の上にぬかづいて、心から神に祈るのであらう。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、それらの文学と深い関係のある、或る意味ではその先覚者と目される正岡子規の、日清戦争に従軍した際の句に、行かばわれ筆の花散る処までいくさかな、われもいでたつ花に剣秋風の韓山敵の影もなし　等があるばかりである。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹田なる鍛冶の夜業の火花闇に散る前を行過ぎんとして立ちどまり、日暮のころ紀州この前を通らざりしかと問えば、気つかざりしと槌持てる若者の一人答えて訝しげなる顔す。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ春の日永の殿上の欄にもたれて花散る庭でも眺めているような陶然とした心持になった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のもが／＼は、濃くなって、ぼんやりして来るかと思うと、また雲が散るように晴れて透き通って来たりした。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車は志す人をのせて、陸奥をさして下り行く――早や暮れかゝる日暮里のあたり、森の下闇に、遅桜の散るかと見たのは、夕靄の空が葉に刻まれてちら／＼と映るのであつた。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "掃へど掃へど又しても又しても新しく花の散るとて、子僮はつぶやくべけれど、散りても散りても後より後より新しき花の咲き出づるは、主人がよろこぶところなるべし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の植物生理的機能を学んで後に始めて充分に咲く花の喜びと散る花の哀れを感ずることもできるであろう。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓から時々コンフェッチを投げるのがちょうど桜の散るような心持ちがします。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はそれに答えず縁側の柱に凭れたまま、嵐も名残と吹き散る白雲の空をぼんやり眺めていた。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔にふるる芭蕉涼しや籐の寝椅子涼しさや蚊帳の中より和歌の浦水盤に雲呼ぶ石の影涼し夕立や蟹這い上る簀の子縁したたりは歯朶に飛び散る清水かな満潮や涼んでおれば月が出る　日本固有の涼しさを十七字に結晶させたものである。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その葉は散るまで青いのだ。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉の裏だけがじりじり枯れて虫に食われているのだが、それをこっそりかくして置いて、散るまで青いふりをする。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時Ｍ氏に贈った句に「登る露散る露秋の別れかな」というのがある。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "散るべくしてわずかに散らないでいた桐の一葉が、風のない静かな夕べにおのずから枝を離れて落ちたような心持ちがした。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三毛のお墓に花が散る。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんこんこごめの花が散る。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして梨を作り、墨絵をかきなぐり、めりやすを着用し、午の貝をぶうぶうと鳴らし、茣蓙に寝ね、芙蓉の散るを賞し、そうして水前寺の吸い物をすするのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば仏教思想の表面的な姿にのみとらわれた凡庸の歌人は、花の散るのを見ては常套的の無常を感じて平凡なる歌を詠んだに過ぎないであろうが、それは決してさびしおりではない。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "井田は、「いかにたゝへん、いかにほめん」とか、「あまつそらに、今日始めて歌の組の首となり　香とび散る百合の影に」とか、「此世にて又遇ふべきか――遇はざるか　此世にて又遇ふ事のなかれかし。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまた酔い心地にほほえみながら、楡の花のほろほろと散る間をぬけて台所口の方に廻った。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
