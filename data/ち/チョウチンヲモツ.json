    "definitions": [
      {
        "index": 1,
        "gloss": "to sing someone's praises",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……御主人の女の弟子が、提灯を持つて連立つた。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが漸次に近くと、女の背に負はれた三歳ばかりの小供が、竹の柄を付けた白張のぶら提灯を持つてゐるのだ。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "若僧は提灯を持つて先に立つた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで居るからであらう、若僧は直に其手拭で泥足をあらましに拭いて、提灯を持つたまゝ、ずん／＼と上り込んだ。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大器氏に一寸会釈するや否や、若僧は落付いた、しかしテキパキした態度で、彼の提灯を持つて土間へ下り、蓑笠するや否や忽ち戸外へ出て、物静かに戸を引寄せ、そして飛ぶが如くに行つて仕舞つた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづきて屋号を染めたる提灯を持つ男。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方近く成つてから三｜人は雨戸を締て、火のない提灯を持つて田圃を越えて墓地へ行つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "提灯を持つて、拍子木を敲いて來る夜廻の爺いさんに、お奉行樣の所へはどう往つたら往かれようと、いちがたづねた。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "米屋商売であるから下総屋としるした提灯を持つべきであるのに、今夜の藤助は無じるしの提灯を持っている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の息子と番頭と二人、物々しく手に／＼提灯を持つて其処に突つ立つてゐる。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿に入つて湯を訊くと、少し離れてゐてお氣の毒ですが、と言ひながら背の高い老婆が提灯を持つて先に立つた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "するともう一人の男が、やつ張り前の男に調弄はれでもしたと見えて、怒つたやうにその男の名を呼びかけながら、火の消えた提灯を持つて息卷きながら追つかけて來た。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "提灯を持つ手が、ぶるぶる顫えて居たので、沢はただならぬことが起きたと思いました。",
              "citation": {
                "source": "暴風雨の夜",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "姐さん品川へはどう行きますか、といふ問に、品川ですか、品川はこのさきを左へ曲つてまた右に曲つて……其処まで私がお伴致しませう、といひながら、提灯を持つて先に駈け出した。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは少年が自分の母校を罵つたので、人情として些かせき込み過ぎたのと、もう一つは彼れが慶應に入るまいと思つて安心してゐたので、うつかり提灯を持つてしまつたのである。",
              "citation": {
                "source": "貝殼追放",
                "author": "先生の忠告",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間の戸が二方とも開けられてあつて、外の通りをお祭の晩の賑やかな灯明りが思はれる程、沢山の人々は手に手に提灯を持つて走つて行くのでした。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治中世までは往来が真暗だつたから提灯を持つて来るお客が殆んどだつたので、此らの提灯へ早足に灯を点してやらなければならない。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は国民歌謡にけちを付ける気が毛頭ないように、レコード屋さんの提灯を持つ気も毛頭、毛頭、毛頭ないが、もし私がレコード屋さんの取締役であったら、国民歌謡のようなものがいくら出来ようが、全く平気である。",
              "citation": {
                "source": "流行唄",
                "author": "兼常清佐",
                "note": "青空文庫"
              }
            },
            {
              "text": "提灯を持つて来ればよかつた。",
              "citation": {
                "source": "狐に化された話",
                "author": "土田耕平",
                "note": "青空文庫"
              }
            },
            {
              "text": "長吉は覚えず後を追つて路地内へ這入らうとしたが、同時に一番近くの格子戸が人声と共に開いて、細長い弓張提灯を持つた男が出て来たので、何と云ふ事なく長吉は気後れのしたばかりか、顔を見られるのが厭さに、一散に通りの方へと遠かつた。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "提灯を持つた群衆が、浜に集つてゐる。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "其他袴の股立ちを高く取つた男狐が四匹定紋附の大提灯を持つて駕籠の先に立つて行く。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はまだ日の出ない初夏の朝を、とぼ／＼と十字架のついた提灯を持つて貧民窟から十五六町もある弁天浜へ出かけて行くのであつた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内に立つたのは提灯を持つた金次郎、その背を見て、平次は何やらガラツ八に眼配せしました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お此お糸",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の通り提灯を持つてゐる――それにこの取引は誰も知らぬことだ」「それぢやお渡し申しますよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "佛像の膝",
                "note": "青空文庫"
              }
            },
            {
              "text": "サア、尻でも端折つて、來るが宜い」　八五郎はもう提灯を持つて、もう一度格子の外へ飛出してをりました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "水垢離",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大變ツ、旦那を突いて逃げた奴があるんだ」　幸七は年甲斐もなくひどく取亂して居りましたが、思ひ直した樣子で、「灯、灯だ」　提灯を持つて行く人を呼びかけます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "花見の果て",
                "note": "青空文庫"
              }
            },
            {
              "text": "提灯を持つて居て下さい」「頼むとしようか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "火遁の術",
                "note": "青空文庫"
              }
            },
            {
              "text": "「梯子と提灯を貸してくれ」「へエ」　春之助が物置の方へ行くと、間もなく下男の茂吉に九つ梯子を持たせ、自分は灯の入つた提灯を持つて戻つて來ました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "罠に落ちた女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
