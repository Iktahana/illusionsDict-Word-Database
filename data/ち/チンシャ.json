[
  {
    "uuid": "d46de545-2d76-547b-b41e-5c44a93fd990",
    "entry": "陳謝",
    "reading": {
      "primary": "ちんしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
