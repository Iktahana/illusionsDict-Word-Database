[
  {
    "uuid": "2c757ea6-b35d-5db2-bd67-4065a30a9bee",
    "entry": "力及ばず",
    "reading": {
      "primary": "ちからおよばず",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
