    },
    "definitions": [
      {
        "index": 1,
        "gloss": "soil fertility",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこらの氷店へはいって休んだ時には、森の中にあふるる人影がちらついて、赤い灯や青い旗を吹く風も涼しく、妹婿がいつもの地味な浴衣をくつろげ姪にからかいながらラムネの玉を抜いていた姿がありあり浮ぶ。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石英粗面岩の凝灰岩、大へん地味が悪いのです。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「派手」は対立者に「地味」を有する。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通には「渋味」と「派手」とを対立させて考えるが、「派手」は相手として「地味」をもっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二）　派手―地味とは対他性の様態上の区別である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "地味とは根が地を味わうのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、派手、地味の対立はそれ自身においては何ら価値判断を含んでいない非価値的のものである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "地味は原本的に消極的対他関係に立つために「いき」の有する媚態をもち得ない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りに樸素な地味は、一種の「さび」を見せて「いき」のうちの「諦め」に通う可能性をもっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "地味が品質の検校を受けてしばしば上品の列に加わるのは、さびた心の奥床しさによるのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "派手の反対意味としては地味がある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋味をも地味をも斉しく派手に対立させることによって、渋味と地味とを混同する結果を来たす。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋味と地味とは共に消極的対他性を表わす点に共通点をもっているが、重要なる相違点は、地味が人性的一般性を公共圏として甘味とは始めより何ら関係なく成立しているに反して、渋味は異性的特殊性を公共圏として甘味の否定によって生じたものであるという事実である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、渋味は地味よりも豊富な過去および現在をもっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、上品、意気、野暮、下品を角頂にもつ矩形は対自性上の対立を示し、派手、甘味、渋味、地味を角頂とする矩形は対他性上の対立を表わしている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、Ｏ、Ｐ、甘味、派手の矩形は積極性、Ｏ、Ｐ、渋味、地味の矩形は消極性を表わしている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さび」とは、Ｏ、上品、地味のつくる三角形と、Ｐ、意気、渋味のつくる三角形とを両端面に有する三角が三角※の形で現勢的に存在する点にある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雅」は、上品と地味と渋味との作る三角形を底面とし、Ｏを頂点とする四面体のうちに求むべきものである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして意識はどつちみち人を悲しませるものです。",
              "citation": {
                "source": "小林秀雄小論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまちみんなはいろいろな国語で一ぺんにそれをうたひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みちみち源叔父は、わが帰りの遅かりしゆえ淋しさに堪えざりしか、夕餉は戸棚に調えおきしものをなどいいいい行けり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "つめたき西の風きたり、　　　　あららにひとの秘呪とりて、粟の垂穂をうちみだし、　　　　すすきを紅く燿やかす。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまちみんなはいろいろな国語で一ぺんにそれをうたいました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく古代では国君ならびにその輔佐の任に当たる大官たちみずからこれらの科学的な事がらにも深い思慮を費やしたのではないかと想像される。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちみんな、ずいぶん世話を焼かせましたからね。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬は私についてきながら、みちみちお互いに喧嘩などはじめて、私は、わざと振りかえって見もせず、知らぬふりして歩いているのだが、内心、じつに閉口であった。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、せめて、人の情にみちみちたこの四日間をゆつくりゆつくりなつかしまう。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまちみんなはいろいろな國語で一ぺんにそれを歌ひました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その時、十一歳であった私と、七ツになったばかりのアヤ子と二人のために、余るほどの豊饒な食物が、みちみちておりました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世の中はソンナ様な神秘めかした嘘言ばっかりでみちみちているんですよ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
