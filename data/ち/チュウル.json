    "definitions": [
      {
        "index": 1,
        "gloss": "banishment (to a somewhat distant province)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "船は中流に出でて走る。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗客間もなく満ちて船は中流に出でたり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "舷のすれあう音ようやく止んで船は中流に出でたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜宮岩といふのは、木曾川の中流に、島を為して残つてゐる一大岩塊で、高山の様子がある。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角中流以下のレストラントには必ず何人かの常客がいて、毎日同じテーブルに同時間に同じ顔を見ることが出来る。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂美食に飽きた食通がうまいものを探すのは中流の料理屋に於てである。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "美食探険家はこういう中流料理屋のスペシャリテの中に思わぬ味を探し当てることがあるという。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌麿の『風俗三段娘』は、上品之部、中品之部、下品之部の三段に分れているが、当時の婦女風俗を上流、中流、下流の三に分って描いている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会と郊外の境界線にある中流のホテル、時刻は東京駅を十時五十五分の神戸行急行列車の発車すこしまえの混雑時だった。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "中流より望みてその華表の上半のみ見ゆるに、初めてこれを見る人も猜してその三囲祠たるを知るべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "川はこれより山の宿町、花川戸、小梅町、新小梅町の間を下りて吾妻橋に至るなるが、東岸の方の深かりしは漸く転じて、中流もしくは西の方の深からんとするの勢をなす。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが書画骨董に心を寄せたり手を出したりする者の大多数はこの連中で、仕方がないからこの連中の内で聡明でもあり善良でもある輩は、高級骨董の素晴らしい物に手を掛けたくない事はないが、それは雲に梯の及ばぬ恋路みたようなものだから、やはり自分らの身分相応の中流どころの骨董で楽しむことになる。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬ようやく船に乗りて船、河の中流に出ずれば、灘山の端を離れてさえさえと照る月の光、鮮やかに映りて馬白く人黒く舟危うし。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "中流より石級の方を望めば理髪所の燈火赤く四囲の闇を隈どり、そが前を少女の群れゆきつ返りつして守唄の節合わするが聞こゆ。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄｜薔薇色に一｜幅曳いている中流の水靄の中を、鐘ヶ淵へ石炭を運ぶ汽艇附の曳舟が鼓動の音を立てて行く。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中流へ太陽がさして、みつめているとまばゆいばかり。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぞへに下りて石垣へ立つと、私の丈ぐらゐな下に、船の小べりが横づけになつて、中流の方に二艘、谷崎さんはその眞中に寒風に吹かれながら颯爽として立つてゐた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……で、すこし岸をさがつた處で、中流へ掛渡した歩板を渡ると、其處に木小屋の柱ばかり、圍の疎い「獨鈷の湯。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、およそ中流の処を乗切れない。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても上流中流の人達が留守にした巴里の混雑のなかに、優雅な夫人と、鄙びて居ても何処か上品な娘を連れた新吉の一行は人の眼についた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来からの茅葺、柾葺、杉皮葺は、とにかくとして、現在多くの民は、トタン葺の家に住み、ふろしきを被つて、もんぺいをはき、中流以下悉く粗食に甘んじてゐる、といふ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが書画骨董に心を寄せたり手を出したりする者の大多数は此の連中で、仕方が無いから此の連中の内で聡明でも有り善良でも有る輩は、高級骨董の素晴らしい物に手を掛けたく無い事は無いが、それは雲に梯の及ばぬ恋路みたやうなものだから、矢張り自分等の身分相応の中流どころの骨董で楽しむことになる。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは石壁の岸高きが下に碧潭深く湛へてゐる一大河に架つてゐる橋が、しかも直に對岸にかゝつてゐるのでは無く、河中の一大巨巖が中流に蟠峙して河を二分してゐる其巨巖に架つてゐるので、橋は一旦巖上に中絶した如くなつて後に、また新に對岸に架されてゐるのである。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "北八は、にやり／＼、中流に至る頃ひ一錢蒸汽の餘波來る、ぴツたり突伏して了ふ。",
              "citation": {
                "source": "彌次行",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "榎の枝からは時々はら／＼と雫が落ちる、中流へ太陽がさして、みつめて居るとまばゆいばかり。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "市街と同じように高低している船には船灯の垣や、高張提灯の藪を隙してうち重なり、そこに織り出される中流の花火打揚の船がやっと覗かれます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処か中流以上の家庭の若夫人ででもあるらしい。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "声も醜く、押しつぶされたように荒れていたのは、一日中流行歌をうたっているせいばかりでなく、この女中の生活の荒れでもあった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
