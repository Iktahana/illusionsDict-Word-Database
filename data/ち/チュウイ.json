[
  {
    "uuid": "aff6781d-f8d8-5722-b125-dce912b7c28a",
    "entry": "中位",
    "reading": {
      "primary": "ちゅうい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
