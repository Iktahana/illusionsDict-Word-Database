    "entry": "中衣",
    "reading": {
      "primary": "ちゅうい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "inner layer of clothing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "秋のあらしに、影の中衣剥がれし梢は、濁りて曇りし鏡の上に、冷かなる其の冠をぬぐまもあらず、落る木の葉の一ひらごとに皺の刻みは眠れる水にひろがりて、凋落を迎ふる水の面に、落る木の葉はゆるやかに流る。",
              "citation": {
                "source": "珊瑚集",
                "author": "仏蘭西近代抒情詩選",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、そんな筒井の考えにはこの家を売るのに都合のよい立退の仕儀にもなり、道中衣裳の費用にも役立つのであった。",
