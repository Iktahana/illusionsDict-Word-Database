    "definitions": [
      {
        "index": 1,
        "gloss": "eldest son's descendants",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "建文皇帝｜諱は允※、太祖高皇帝の嫡孫なり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "匡衡は大江維時の嫡孫であって、家も其格が好い。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿橋辺から出沢にかけて防戦したが、勝頼落延びたりと見届けると、岡の上に馬を乗り上げ、「六孫王｜経基の嫡孫摂津守頼光より四代の孫源三位頼政の後裔馬場美濃守信房」と名乗った。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長公の嫡孫三法師殿の在すからには、この君を立て参らせるのが、最も正当であると存ずるが、如何であろう」と。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "長秀曰く、子を立てるとしたら此場合、信雄信孝両公の孰れを推すかは頗る問題となるから、それより秀吉の言の如く、嫡孫の三法師殿を立てるのが一番大義名分に応って居るように思われる。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "傳ふる所に據れば、源三位頼政の嫡孫、伊豆冠者有綱、逃れてこの地に來り、鹽原家忠に依りけるが、鎌倉勢に押寄せられ、敗れてこの窟に隱れて身を全うしたりとの事也。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "語を換へて言へば、安政以後には二人の狩谷三右衛門が並存してゐて、※斎の嫡孫に係るものは隠れて世に知られず、却て彼三右衛門従之が名を藝苑に列してゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って嫡孫たちは宗麟の姪の子であった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方読者はみな既に感じておられるように、清和天皇から流れ出て、頼義・義家以来東国土豪の棟梁になった源氏の嫡孫は、田舎人になっていても貴族である。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村田｜与三は、納戸役であるが、しかし、今は肥後へ行っている柳生家の嫡孫｜兵庫とは、好敵手だといわれた者である。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "身不肖にも小野寺家の嫡孫にて候、かようの時、うろつきては、家の疵、一門のつらよごし、時至らば、心よく死ぬべしと、思い極め申し候。",
              "citation": {
                "source": "日本名婦伝",
                "author": "小野寺十内の妻",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、次第に出世して、彰考館の総裁にあげられ、転じて、嫡孫｜菊千代の傅役となり、ついには江戸家老にまで登ってゆくあいだに、そろそろ紋太夫のうちにふかく流れていたべつな本質もあらわれ出して来た。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、いまではこの安土城のあとへ、信長の嫡孫、三｜法師丸が清洲からうつされてきて、焼けのこりの本丸を修理し、故右大臣家の跡目をうけついでいる。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死に臨んでは、嫡孫信勝、勝頼以下の一族諸将を枕頭に呼んで、「わが亡きのちは、構えて、みだりに兵をうごかすな。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、元就の嫡孫で、現在、毛利家の主君の位置にある輝元を、遺憾なく扶け合っていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "この心理の傾きは、秀吉がいう嫡孫承祖の正論に肯定を余儀なくされたというだけのものではない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢庵の門を熱心に叩いた諸侯としては、先に述べた柳生但馬の他、酒井忠勝、堀田｜正盛、板倉｜周防、小堀遠州、佐久間｜将監等が著名であるが、沢庵が最も愛したのは、細川家の卓抜な嫡孫、越中守忠利であった。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
