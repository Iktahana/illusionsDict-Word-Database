        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かれは茶っぽい縮のシャツを着て、麻のズボンをはいていた。",
              "citation": {
                "source": "麻畑の一夜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶っぽい光の列車の電燈の下では、伯父の顔にももう先刻の妙な「気」はすっかり払い落されてしまっていた。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "広栄はセルの単に茶っぽい縦縞の袷羽織を着て、体を猫背にして両脚を前へ投げだしていた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶っぽい帯の傍からうす色の帯上げが少しのぞいて白い足袋に蹴り上げられる絹の裾が陰の多い襞を作るのを篤は静かに見て居た。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　千世子は茶っぽい銘仙のぴったり体についた着物を着て白っぽい帯が胸と胴の境を手際よく区切って居る。",
              "citation": {
                "source": "蛋白石",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "低いソフト・カラアにネクタイを結び、茶っぽい毛糸のスウェータァの上へいきなり銀灰色の柔い上着を着ている。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "死後そのままここに移したもので、窓かけも椅子も敷物も茶っぽい緑の一色、簡素な部屋だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてだか茶っぽい。",
              "citation": {
                "source": "茶色っぽい町",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その茶っぽい雰囲気は、山伏町の通へ来ると殆ど黒い程になる。",
              "citation": {
                "source": "茶色っぽい町",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "がっしり天井の低い低い茶っぽい食堂の壁に、夥しく花鳥の額、聯の類が懸っている。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶っぽい小虫の群が、草の根元にかじかんだ様になって居るのを雌鴨は見つけたのである。",
              "citation": {
                "source": "一条の繩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶っぽい粗布の獄衣を着せられた活人形がその中で、獣のような抑圧と闘いながら読書している革命家の姿を示している。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宏子は、古風な沓脱石の上に立って、茶っぽい靴の踵のところを右と左とすり合わすようにして揃えてぬぎ、外套にベレーもかぶったまま、ドンドンかまわず薄暗い奥の方へ行った。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫紺の極く濃いのと茶っぽい色とを好いて居る千世子が夏の外出に、白い帯に赤味がかった帯をすると気がさす様で仕様がなかった。",
              "citation": {
                "source": "千世子（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶っぽい棒なんだよ。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで僕は、博士の背中にもうすこしでつきそうなその茶っぽい棒をつかんだのさ。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この注射器の底に、ほんのり茶っぽいものが附いているが、これは、なんて薬かい」「うん、なんか附いてはいるが――」若い男は注射器を、明り窓の方に透かして、その茶色の汚点に眺め入った。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、振ってみると、硝子のところに、茶っぽい色が見えるだろう」「それとも、やっぱりあれは、血のあとか。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子の窓から内部を覗いてみると、底にはふくよかな脱脂綿の褥があって、その上に茶っぽい硝子｜屑のようなものが散らばっている。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊岡警官が保管している「茶っぽい硝子の破片のようなもの」は何であるか。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろな樹がみんな芽をふくらませているので、空は茶っぽい緑の点、点、点で描かれているような眺め。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶っぽい水の流れている川へ出た。",
              "citation": {
                "source": "日記",
                "author": "一九四七年（昭和二十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、あれは何だろうな」　そのうちに、その茶っぽい棒が、ふらふらしながら、室内をおどるように、うごきだした。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "小男だから、いつも相手をすくいあげるようにして、しわんだ、よく光る茶っぽい眼でみつめながら、いうのである。",
              "citation": {
                "source": "白い道",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶っぽい襟巻と、脊の丸くなった古トンビを羽織っているので、最初は老人のようにみえたが……。",
              "citation": {
                "source": "冬枯れ",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふた品ほどの皿の上――ひとつは真黒い粒々でもうひとつは茶っぽいドロッとしたものだった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その大さは矢張り五｜寸許、蒼味がかった茶っぽい唐服を着て、そしてきれいな羽根を生やして居るのでした。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の茶っぽい服を着た女学生が自分の席から、「シェンション」と呼んで手をあげた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスク※では、黒パンと茶っぽい粉でやいたコッペのような形のパンしかなかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "川を見下す涼しそうな広縁に、茶っぽい織物の大きな帯を解けそうにゆるく腰にまきつけた女が、薄ものの袖から透きとおる腕をあげて簪にさわりながら、くずおれている。",
              "citation": {
                "source": "午市",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
