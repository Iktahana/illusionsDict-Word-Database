[
  {
    "uuid": "cbe510b9-48dd-52e0-9798-7bc8268180c7",
    "entry": "茶褐色",
    "reading": {
      "primary": "ちゃかっしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dark reddish-brown",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼の肘の前にある灰皿の中の、喫ひ終つたばかりの喫殻から登る紫色の煙と、他の古い喫殻にそれが燃え移つて出る茶褐色の毒々しい煙とが、やゝもすれば彼の顔に打つ衝かつたが、そんなことには元来頓着ない彼であつた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "コップに一杯の砂糖水をつくって、その上に小さな罎に入った茶褐色の薬液の一滴を垂らすと、それがぱっと拡がって水は乳色に変わった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶褐色に変ったげんげやばらの花束や半分喰い欠いだ林檎もあった。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "首からぶらさげた三角のナフキンに、茶褐色の斑点をつけてミサコが云った。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "つつじはもうすっかり散ったあとであったが、ほんの少しばかりところどころに茶褐色に枯れちぢれた花弁のなごりがくっついていたことと、初夏の日ざしがボーイのまっ白な給仕服に照り輝き、それがなんとも言えないはかない空虚な絶望的なものの象徴のように感ぜられたことを思い出すのである。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、地震前には漆のように黒かった髪の毛が、急に胡麻塩になって、しかもその白髪であるべき部分は薄汚い茶褐色を帯びている事であった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "呆気に取られて見る見る内に、下の方から縮みながら、ぶくぶくと太って行くのは生血をしたたかに吸込むせいで、濁った黒い滑らかな肌に茶褐色の縞をもった、疣胡瓜のような血を取る動物、こいつは蛭じゃよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでその杉木立の中にポツネンと立っている南堂家の図書館というのは、五｜間に四間ぐらいの二階建の鉄筋コンクリートに茶褐色のタイル張りで、上等のスレート屋根の下に緑色に塗った鉄のブラインドが並んでいる。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と一緒に地方版の編集をやっていた松石という男は、月末近くなると、茶褐色に変色したカンカン帽を持って、一巡する。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後四時頃、麹町永田町なる深川夫人の邸の庭へ、垣より潜入りたる茶褐色の犬あり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩の辺に負れかかりて、茶褐色の犬一頭、飼主の病苦を憂慮いてそを看護らんと勤むるごとし。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方は笠を上にした茶褐色で、霜こしの黄なるに対して、女郎花の根にこぼれた、茨の枯葉のようなのを、――ここに二人たった渠等女たちに、フト思い較べながら指すと、「かっぱ。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "盲縞の腹掛け、股引きに汚れたる白小倉の背広を着て、ゴムの解れたる深靴を穿き、鍔広なる麦稈帽子を阿弥陀に被りて、踏ん跨ぎたる膝の間に、茶褐色なる渦毛の犬の太くたくましきを容れて、その頭を撫でつつ、専念に書見したりしが、このとき鈴の音を聞くと斉しく身を起こして、ひらりと御者台に乗り移れり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "呆気に取れて見る／＼内に、下の方から縮みながら、ぶくぶくと太つて行くのは生血をしたゝかに吸込む所為で、濁つた黒い滑らかな肌に茶褐色の縞をもつた、痣胡瓜のやうな血を取る動物、此奴は蛭ぢやよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の顏色は例によつて生々と、或ひはテラ／＼と茶褐色に飽く迄光り輝き、短い袖からは鬼をもひしぎさうな赤銅色の太い腕が逞しく出てをり、圓柱の如き脚の下で、靴の細く高い踵が折れさうに見えた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の顔色は例によって生々と、あるいはテラテラと茶褐色にあくまで光り輝き、短い袖からは鬼をもひしぎそうな赤銅色の太い腕が逞しく出ており、円柱の如き脚の下で、靴の細く高い踵が折れそうに見えた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "刈ったあとには茶褐色にやけた朽ち葉と根との網の上に、まっ白にもえた茎が、針を植えたように現われた。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、うめのきごけが、樹皮の乾燥している老幹に宿をかりるという、科学的な、又は自然的な関係からばかりでなく、自然の美的情緒を深めるためにも、梅の老樹を灰白色に、或いは茶褐色にぬりつぶしているような気がします。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣服は茶褐色、コーヒーよりもやや濃く、首元と袖には少し紫色のフラシ天が。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "身長五フィート七インチ、体格よし、顔色悪し、黒髪、頭頂に小禿あり、たわわな黒い頬髯口髭、色眼鏡、話し方はやや訥々、失踪時の服装は黒のフロックコート、黒のベスト、金のアルバート鎖、下はハリスツイードの鼠色、ゴム布の長靴に茶褐色のゲートルを重ねる。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うむ、茶褐色の外套を着た男――赤ら顔で、尖ったつま先の靴を履く例の男だ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャールズの首がまだしっかりつながっていた頃、このやや茶褐色の背の本が印刷されたわけだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は長身で赤ら顔、茶褐色の長い外套を着ていたそうで。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶褐色の髪やあごひげには白いものがまじっていて、くぼんだ眼窩の奥で目が不自然にぎらぎらと光っていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその箱の半以上を、茶褐色の背革の大きい本三冊が占めていて、跡は小さい本と雑記帳とで填まっている。",
              "citation": {
                "source": "二人の友",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側なしに造った家の敷居、鴨居から柱、天井、壁、畳まで、bitume の勝った画のように、濃淡種々の茶褐色に染まっている。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶褐色の大皿で、東半球の地圖を燒きつけてある。",
              "citation": {
                "source": "よしなし事",
                "author": "〔源内の手紙、原稿料のことなど〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今朝新聞を見ましたところが、阿父さんが、大怪我を為つたと出てをつたので、早速お見舞に参つたのです」　白髪を交へたる茶褐色の髪の頭に置余るばかりなるを撫でて、直行は、「何新聞か知らんけれど、それは間の間違ぢやが。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは全身茶褐色の雌鷄で、白い雌鷄に比してどこやら形が武骨であつた。",
              "citation": {
                "source": "白い雌鷄の行方",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処の壁の上には、もうすつかり茶褐色に変つてゐる七郎のと並んで八重の高等小学校卒業の優等の免状が額に入つてゐる。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
