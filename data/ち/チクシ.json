        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "◇　支那から伝来して来た竹紙という、紙を撚合せて作った火縄のようなものがあったが、これに点火されておっても、一見消えた如くで、一吹きすると火を現わすのでなかなか経済的で、煙草の火附に非常に便利がられた。",
              "citation": {
                "source": "亡び行く江戸趣味",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言って弱い竹紙のような微笑んだ皺を頬にあらわした。",
              "citation": {
                "source": "音楽時計",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "神仏に祈願するときには、竹紙を焼くことが盛んに行われておる。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹紙とは、名のごとく竹にて製したる黄色の紙にして、これに金を塗りつけたるものと銀を塗りつけたるものとがある。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "その知識の浅薄なること、葛衣竹紙の薄きよりもはなはだしと評せざるべからず。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは、ふしぎにも一枚の薄い竹紙のような紙のなかにも、卑俗な女学雑誌の表紙に描かれた生生しい女の首や、貝のような手つきをまで忍ぶため、いちいち大切に秘蔵しているのであった。",
              "citation": {
                "source": "幻影の都市",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた友の肉体に潜んだいろいろな苦悶と疾患とが、友を非常な神経質な針のさきのやうなちくちくした痛みを絶えず経験させた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒は邪魔になるので、「こんちくしょう、こんちくしょう」　と払い除けようとしましたが、なかなか払い除けられません。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖マルティンのちくしょうめ」　とジャンはジャンで見えない目からくやし涙を流します。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんちくしょう、早く言え」　と言うなり坊さんを押えつけて鉈をふり上げました。",
              "citation": {
                "source": "ツクツク法師",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（野中）（呻く）ううむ、ちえっ、ちくしょう！",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏切りやがって、ちくしょうめ！",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風の如くアトリエを飛び出し、ちくしょうめ！",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそのとき、どろみぞからあがっていた石太郎は、ちくしょうと口ばしって、目にもとまらぬ敏捷さで、いたちを地べたへたたきつけた。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "春吉君は、いつも水藻のような石太郎が、こんなにはっきり、ちくしょうっという日本語を使ったこともふしぎだったし、こんなにすばしこい動作ができるということも不可解な気がした。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は考えた、腹をくちくしたのは此の七枚目の半分であるのだ。",
              "citation": {
                "source": "愚かな男の話",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう云ふのは「ちくしやう」と云ふ國語と認めて宜しい。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここからすぐに追っかけるんだ」「ちくしょうッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちくしょうッ」「いてえ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどね、ちくしょうめ、さあ来い！",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちくしょうめ、やけにうれしくなりゃがったね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちくしょうッいけねえ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちくしょうめ、ふざけたまねをやりやがって、どいつか沈めやがったなッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちくしょうッ、ひと足先にずらかりましたぜ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちくしょうめ、なんだって気短におっ死にゃがったんでしょうね！",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちくしょうッ、ざまあみろい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ちくしょう、ひとりで目鼻をつけてやろうと、けさ起きぬけにお番所へ出かけていったら――」「何がどうしたというんだよ」「人ごろしがあったっていうんですよ」「ウフフ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちくしょうめ、すっかり世の中が明るくなりゃがったじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月万歳、雪やこんこん、ちくしょうめ、降りやがるなと思ったら、きょうにかぎってこのとおりのぽかぽか天気なんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょいと見ると、このお組屋敷の門前を変な女がちらくら走っていやがるからね、夜ふけじゃあるし、ちくしょうめ臭いなと思ったんで、まっしぐらに飛んできたら、このうちの中へすうと消えたんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
