  {
    "uuid": "42060a2d-ca77-576b-836c-4791d48049d6",
    "entry": "秩序",
    "reading": {
      "primary": "ちつじょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
