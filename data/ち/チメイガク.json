        "examples": {
          "standard": [
            {
              "text": "彼は地名学の専門家で、古代の地名から歴史を読み解いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地名学は、言語学や歴史学とも深く関連している学問分野だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地名学の研究は、失われた文化や民族の移動経路を解明する手がかりとなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これ等の説話中には、説明説話義あり、民間地名学あり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如き者を称して、「民間地名学」と云う。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろやっと日本地名学研究所というのができて、本も出るようになった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらを一つ一つ西洋の地名学者が調べたように当って行くことは、日本では実は無理な事であった。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
