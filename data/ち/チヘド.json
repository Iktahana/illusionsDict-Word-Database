        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "毒薬には劇毒で飲むと直に死ぬのも有ろうし、程経て利くのも有ろうが、かかる場合に飲んで直に血反吐を出すような毒を飼おうようは無いから、仕込んだなら緩毒、少くとも二三日後になって其効をあらわす毒を仕込んだであろう。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "陪臣の分を仕つて、御先祖様お名をかたります如き、血反吐を吐いて即死をします。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは笹村の留守の間に、ついここから二タ筋目の通りのある店家の内儀さんが、多分その亭主の手に殺されて、血反吐を吐きながら、お銀の家の門の前にのめって死んでいたという出来事があってからであった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧しい肺病やみの学生が、血反吐をはいてのたうち廻っていた。",
              "citation": {
                "source": "都会の幽気",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "主水正は、まだ血反吐を吐かぬだけよいぞ……主水ッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜兵衛は、勿論、血反吐をはいて、絶息してしまった。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちへどきな」　小作りの下総男、田舎じみた風体をしているが、なかなか扱いが馴れたものです、腰低く小侍たちに一礼すると、人中で騒ぎを起して、近所迷惑になってはならぬと言うように、ひたすらわび入りました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっちへどきな」　今のさき求めてきた用意の生うるしを筆にしめすと、何を思ったか、血がめのそのふたのつまみ柄のまわりへ、ぺたぺたとぬりつけました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "――邪魔だからそっちへどいてなさいよ、男のくせに」「は、は、男だから、さ。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那は、野象の穴へ落ちたとき、磁針をお壊しなすったので、儂らは、どっちへどう出たらこの森を抜けられるか、いま途方に暮れているでがす。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民党を援けると決めたなら決めたで、そっちへどんどんお金を注ぎこむ。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "異様な形をした魚群が、こっちへどんどん近づいて来たと思ったら、ぱっと花を散らしたように上下左右へとんだ。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではこっちへどうぞ」　金博士は、給仕頭の案内で、王老師の部屋を訪れた。",
              "citation": {
                "source": "大使館の始末機関",
                "author": "――金博士シリーズ・７――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじいさん、あっちへどいてくれ。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人造人間が動きだしたぞ」「こっちへどいた」　ガチャンガチャンと金属音を発して、人造人間は函の中から一歩外に出た。",
              "citation": {
                "source": "人造人間事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちへどうなろうと、その又次にも、何かがあるものだよ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これではどっちへどう廻ってもドジの踏みようがなかった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "非難すれば非難するだけ、礼讃すれば礼讃するだけ、どっちへどう転んでも圓朝の名はうららな朝日のいろにと染められていくばかりだった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだこの手紙にははっきりかけませんけれど、私にはたたいてもこっち向くその薄桃色の鼻面が改めて自分にいとしく思われるし、やっぱりどっちへどうするかということで先の十年は大した相異をもつことを痛感しはじめています。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、日本の国の政治がどっちへどうなろうとも、やがて落着けば、一切、異人相手の仕事ということになるはきまっている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "たれかおらぬかッ」　と、陣小屋のうちへどなった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
