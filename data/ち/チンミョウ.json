        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "名画をもじったタブロー・ヴィヴァンの中にダヴィドの「ルカミエー夫人」を模したのなどは美しかったが、シャバの「水浴の少女」をそっくりそのままベッドの前に立たせ、変なおやじが箒で腰をなぐろうとしている光景は甚だ珍妙ないかがわしいものであった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "話の中心が一人の男（職人らしい）「話しだけじゃ分らねえ」と立ち上り、側に乾してある破れ傘持って、　尻からげして天晴れ定九郎振りよろしく珍妙な大見得切る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん外国からの通信の翻訳であろうと思うが、あの記事なども科学者の目には実に珍妙なものであった。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夜の夕刊に青森県｜大鰐の婚礼の奇風を紹介した写真があって、それに紋付き羽織｜袴の男装をした婦人が酒樽に付き添って嫁入り行列の先頭に立っている珍妙な姿が写っている。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺絣に角帯というのもまた珍妙な風俗ですね。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "てめえたちが飲めない程の珍妙なウイスキイを、客にすすめるとは、ひどいじゃないか。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドテラ姿で、古扇子で七輪を煽いでいる、ロイド眼鏡のオヤジの恰好は随分珍妙なものに違いない。",
              "citation": {
                "source": "私の生活",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その注射をすると自分は、からだの衰弱も忘れて、漫画の仕事に精が出て、自分で画きながら噴き出してしまうほど珍妙な趣向が生れるのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にも知られぬ、このような侘びしいおしゃれは、年一年と工夫に富み、村の小学校を卒業して馬車にゆられ汽車に乗り十里はなれた県庁所在地の小都会へ、中学校の入学試験を受けるために出掛けたときの、そのときの少年の服装は、あわれに珍妙なものでありました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "発展しすぎて、やはり珍妙なものになりました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "せいぜい、まあ、田舎公卿、とでもいふやうな猿に冠を着けさせた珍妙な姿のお公卿が出来上るだけだ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて、珍妙な、所謂「直言」が試みられている。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなはち、「誰にも知られぬ、このやうな佗びしいおしやれは、年一年と工夫に富み、村の小学校を卒業して馬車にゆられ汽車に乗り十里はなれた県庁所在地の小都会へ、中学校の入学試験を受けるために出掛けたときの、そのときの少年の服装は、あはれに珍妙なものでありました。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言つて頗る大袈裟に奥さんに向つてこぶしを振り上げ、あまりにどうも珍妙な喧嘩なので、甥のその子が、ぷつと噴き出して、Ｎ君もこぶしを振り上げながら笑ひ出し、奥さんも笑つて、何が何やら、うやむやになつたといふ事などもあつたさうで、それもまた、Ｎ君の人柄の片鱗を示す好箇の挿話であると私には感じられた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから先生と大将との間に頗る珍妙な商談がはじまった。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに對した側には色斑らな上衣及びスカウトの西洋婦人の一群が好奇の目を※つて「チヤノユ」の珍妙の手續を見て居たが、今第一の茶が同邦人の前に配せられた時一齊に手を叩いた。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を食うて生きているのじゃ」と、問うたので、度肝を抜いてくれようと、蝮蛇を食うている旨答えると、「日の下にあって、最も聰明にして怖しき毒蛇をくらうとは、近頃珍妙じゃ。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴公出て、珍妙なる歌でも作るさ」　と、佐助が言うと、三好は坊主頭をかいて、「ところが、俺ア笛と法螺なら、人並以上にうまく吹くが、歌と来た日にゃ、からきしだめなんだ。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か珍妙なデマを飛ばしたくてうずうずしているようだった。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は、もしかしたらこれは、長髪の生徒の中には社会主義の思想を抱いている者が多いから、丸刈りを強制したのかも知れないという珍妙な想像をして、ひそかに吹きだした。",
              "citation": {
                "source": "髪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍妙にして恐るべきカドリルよ！",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八一四年当時の囚人が斯くも珍妙な制服を着せられ、一週二回ずつ髭を剃っていたとは！",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の顔の表情は少しも変りはしなかったが、彼の目蓋は重く彼の上に垂れさがり、彼の唇からは、あたかもその医者の話す一つ一つの珍妙な物語を、更に不思議にするかのように、濃い煙草の煙がもくもくと吐かれていた。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍妙ふしぎ、お目にかけたい。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "其間だ、供人は盛裝喧噪して珍妙に唄ひ踊り續ける。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそのいくらか珍妙な話のおしまいに彼のいわゆるデュパンのこつなるものについてのお世辞を述べ、それから彼に向ってじかに、十分に手厚い申し出をした。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "正午までにたった三分という時に、この珍妙な物ははなはだちっぽけな外国の者らしい若い男だということがわかった。",
              "citation": {
                "source": "鐘塔の悪魔",
                "author": "THE DIVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分珍妙な話なんです。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、きょう、ちょっと珍妙な事件があったので、前便の不備の補足かたがた早速御一報に及ぶ次第なのだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "選挙と言えば、きょうこの道場に於いて、とても珍妙な事件が起った。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
