[
  {
    "uuid": "1cd97ff9-99a5-5e22-9458-da7d724c44ed",
    "entry": "中数",
    "reading": {
      "primary": "ちゅうすう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
