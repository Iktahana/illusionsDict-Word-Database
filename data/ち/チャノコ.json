[
  {
    "uuid": "944c4850-1676-5f3f-b209-591b254996c5",
    "entry": "茶の子",
    "reading": {
      "primary": "ちゃのこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
