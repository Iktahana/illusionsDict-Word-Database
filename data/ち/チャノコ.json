    "definitions": [
      {
        "index": 1,
        "gloss": "cake served with tea",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "闊歩横行、登攀、跋渉、そんな事はお茶の子で。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……我人ともに年中｜螻では不可ません、一攫千金、お茶の子の朝飯前という……次は、」　と細字に認めた行燈をくるりと廻す。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金目の懸った宝なんざ、人が大切がって惜しむもので、歩るくにも坐るにも腰巾着につけていようが、鎖を下ろしておこうが、土の中へ埋めてあろうが、私等が手にゃあお茶の子さ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "火遁だって、土遁どろどろどろ、すいとんだって、焼鳥だってお茶の子だわ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな品は盗っても、売るのに六ヶしいから見逃がして置くものの、盗ろうと思やお茶の子でさあ。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……手前、幼少の頃など、学校を怠けて、船で淡島へ渡って、鳥居前、あの頂辺で弁当を食べるなぞはお茶の子だったものですが、さて、この三津、重寺、口野一帯と来ますと、行軍の扮装でもむずかしい冒険だとしたものでしてな。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言い懸けて、渋茶にまた舌打しながら、円い茶の子を口の端へ持って行くと、さあらぬ方を見ていながら天眼通でもある事か、逸疾くぎろりと見附けて、「やあ、石を噛りゃあがる。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父に電話をかけて来るお客の声を、モシモシのモの字一字で聞き分けたり、受話機の外し工合で男か女かを察したり、両方から一時に混線して来た用向きを別々に聞き分けて飲み込んだりする位の事はお茶の子サイサイであった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もなかなかの悪戯もので、逗子の三太郎……その目白鳥――がお茶の子だから雀の口真似をした所為でもあるまいが、日向の縁に出して人のいない時は、籠のまわりが雀どもの足跡だらけ。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "処を沖へ出て一つ暴風雨と来るか、がちゃめちゃの真暗やみで、浪だか滝だか分らねえ、真水と塩水をちゃんぽんにがぶりと遣っちゃ、あみの塩からをぺろぺろとお茶の子で、鼻唄を唄うんだい、誰が沖へ出てベソなんか。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、もう他事ではない、既に今朝の雪の朝茶の子に、肝まで抜かれて、ぐったりとしているんだ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金や女の幽霊なら、お茶の子サイサイ狃れ切っとるが、今度の奴は特別｜誂えの日本の水雷艇みたような奴じゃ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも微塵も鼻の表現をたじろがせずに常に先方に遺憾なき感動を与えるのをお茶の子仕事と心得ているのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ドウダイ……事実とピッタリ一致するじゃないか」「相変らず素早いんだね君は……」「これ位はお茶の子さ。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しさも、凄さもこれほどなら朝茶の子、こいつ見物と、裾を捲って、蹲み込んで、（負けるな、ウシ、）　などと面白半分、鼬殿を煽ったが、もう弱ったか、キチキチという声も出ぬ。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（姉さんは、娘はんですか、此楼の……）　いやな野郎で、聞覚えの京言葉を、茶の子でなしに噛りましたが、娘か、と思ったほど、人がらが勝っている。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　坐睡をしていたのか、寝惚面で承るとむっくと立ち、おっと合点お茶の子で飛出した。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃腸なぞはそりゃに、お茶の子じゃぞ。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "親戚朋友がよろこびを言いに来ると、又七郎は笑って、「元亀天正のころは、城攻め野合せが朝夕の飯同様であった、阿部一族討取りなぞは茶の子の茶の子の朝茶の子じゃ」と言った。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏それは御茶の子だ、信能く駛流を渡り、放逸ならぬ者能く大海を渡り、精進能く苦を抜き、智慧能く清浄を得と答うると、鬼神さもあろう、それもそうよのうと感心して仏弟子となり、手に長者の男児を捉えて仏の鉢中に入れた、曠野鬼神の手から救われ返った故この児を曠野手と名づけ王となる。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "本伝寺の大屋根へ足場なしに上るんやもの、こなな低い屋根やこしはお茶の子や。",
              "citation": {
                "source": "屋上の狂人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "千人、二千人おりましょうとも、この可賀が引きうけましたからには、お茶の子さいさいでござりやす。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻雀の聴牌を当てるぐらいの事はお茶の子サイサイで、職業紹介欄の三行広告のインチキを閑暇に明かして探り出す。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや叔母の意見に負く位の事は朝飯前の仕事、お茶の子さいさいとも思わない。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "時速四十｜哩などは、お茶の子サイサイであった。",
              "citation": {
                "source": "西湖の屍人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな故障なんか直すことは彼には、お茶の子さいさいである。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、こんなものはお茶の子です。",
              "citation": {
                "source": "動く海底",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども上村少佐にだつてそんなことはお茶の子さい／＼だつた。",
              "citation": {
                "source": "風変りな決闘",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猫のオルガン」が何のことだか分からないが多分おもちゃのことらしい。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、ガチョウの骨で作ってある子供のおもちゃのことで、それにさわると、とびあがるしかけになっています。",
              "citation": {
                "source": "とびくらべ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
