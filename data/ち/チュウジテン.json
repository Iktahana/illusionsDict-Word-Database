        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いま、ふと、ダンデスムという言葉を思い出し、そうしてこの言葉の語根は、ダンテというのではなかろうか、と多少のときめきを以て、机上の辞書を調べたが、私の貧しい英和中辞典は、なんにも教えて呉れなかった。",
              "citation": {
                "source": "思案の敗北",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼自身もまたフランスの大辞典リットレないしラルース等の名著およびダルメステテール等の中辞典から平素得つつある智識を、他山の石として、乃父の『改訂辞苑』旧版本の礎石の材料にも供してくれた。",
              "citation": {
                "source": "『広辞苑』自序",
                "author": "新村出",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうは又、知っている人に割引で岩波の斎藤の『中辞典』を買って届けて貰い、うれしかった。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "『第八路軍従軍記』と井上の和英中辞典もお送りしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "英和では岩波版、斎藤、熟語本位英和中辞典。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に中学校時代かに使用した斎藤秀三郎氏の「英和中辞典」を見ると「山国の人、山人、登山（業）者」としてある。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの胸中辞典には、武人がややもすると口にする乾坤一擲――だの、また――運ヲ天ニ任ス――などということばはない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
