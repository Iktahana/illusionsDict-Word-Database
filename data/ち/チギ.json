[
  {
    "uuid": "4ccdcd61-a37f-5cc4-b965-ea5d3b65027b",
    "entry": "千木",
    "reading": {
      "primary": "ちぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ornamental crossed rafter ends on shrine gables",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山｜麓の端山の千木たかしる家へ山の祖神の翁は岳神を訪ねた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの高い森の上に、千木のお屋根が拝される……ここの鎮守様の思召しに相違ない。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊留満喜三郎　それわが神でいゆすは天地六合の唯一神、宇宙万象の能造の主、天地空寂のうちに万象を造り、かるが故に日月星宿光を放つて、明歴々として東湧西没の時を違へず、地には千木万草あつて、飛鳥落葉の期を誤たず。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷鞍ぐしといふのは棟が千木を建てたやうになつてるのである。",
              "citation": {
                "source": "鉛筆日抄",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "青柳喜兵衛、水彩の千木良富士、陳億旺、牧野醇、梅沢照司、尾崎三郎は色々の意味で批評したいが紙数が尽きたので次の機会にゆずる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "祠は神武天皇の御世にはじまり、底つ岩根に宮柱ふとしきたち、高天原に千木高知り、萬古儼として威靈を留む。",
              "citation": {
                "source": "鹿島詣",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮は千木が天雲に隠れる程大きな建築であつた。",
              "citation": {
                "source": "老いたる素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "老僧の寺は十丁ほど東にあつて、私の家から其の天臺に象つたといふ二重屋根の甍がよく見えるし、老僧の庫裡の窓から、私の方のお宮の杉木立や、檜皮葺きの屋根や、棟の千木までが見えたりした。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの屋根の上にも五つ六つの千木を打ち違え、それを泛き上らせた霧雨がぼけ靡いて竹林に籠っている。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "月は高倉の千木を浮かべて現れた。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「事実、迎春館主の和歌宮鈍千木氏の技倆は大したもんだ。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "和歌宮鈍千木氏は……」「そのワカミヤ、ドンチキとかいうのは主任医なのかね」「そうだ。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、迎春館主和歌宮鈍千木師なる者は実在の人物かね」　私は声が詰って、しばらく返事ができなかった。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の調べたところでは、多くの人々が迎春館という名を知っており、和歌宮鈍千木師の名前も聞いて知っているが、さて迎春館のはっきりした所在も知らず、また和歌宮師に会った者もないのだ。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　迎春館も和歌宮鈍千木氏も実在せず。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも古城のそれのように、千木や勝男木が立ててある。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもそのうちの一棟が、とりわけ高く他の棟から抽んで、しかもその屋根に千木を立て、社めいた造りに出来ているのが、不思議に思われてなりませんでした。",
              "citation": {
                "source": "犬神娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日の最後の夕陽の光が、猩々緋のように華やかに、千木の立ててある建物の雨戸にあたって、火の燃えているように見えているのへ、わたしは無心に眼をやりながら、つかれた膝の辺を撫でていました。",
              "citation": {
                "source": "犬神娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「千木の立ててある建物から――建物の二階の雨戸から、綺麗な上品な手が出ましたので……」「ナニ、千木のたててある建物から、綺麗な上品の手が出たんだって」と、その男はひどく驚いたように云って、その建物を振りかえって眺めましたが、「何を馬鹿らしいそんなことが。",
              "citation": {
                "source": "犬神娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それも大勢いるらしい」　植え込みの間を分けながら、千木の立っている建物の方へ、わたしたちが数間歩きました時、囁くような声で国臣様は云われ、にわかに足を止められました。",
              "citation": {
                "source": "犬神娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千木のたててある建物が立っていて、その門の戸があいていて、そこから火の光が射していて、その前に十数人の人影がいて、何やら叫んでおります姿が、わたしたちの眼に見えました。",
              "citation": {
                "source": "犬神娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし千木のある建物の、その門口まで走りついた時には、わたしも国臣様も「あッ」と叫び、思わず足を止めてしまいました。",
              "citation": {
                "source": "犬神娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　犬神の娘の慟哭する、犬の悲鳴さながらの声を、千木のたっている建物の、二階の部屋に聞き流して、ご上人様をお守りして、その屋敷から脱け出しましたのは、それから間もなくのことでございました。",
              "citation": {
                "source": "犬神娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その様式は神明造、千木が左右に付いている。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの農家は屋根に千木をつけている。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根に千木をいただく農家に住んではいるがそれが彼ら本来の住居だと断ずる根拠もない。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラビヤの最初の写真はこの国見の丘から見おろした高千穂の長崎という部落の風景であるが、四方にこれに類似の山また山、そして屋根に千木をのせた小さな部落風景を見はるかす地に洋風の共同便所がチョコンと建っているのである。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ車窓に見ることのできる屋根に千木をいただいた家々が非常に物悲しいものに映じたのであった。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大室社（千木良村）大牟礼社（吉野宿）王勢籠於々勢以呂宇。",
              "citation": {
                "source": "マル及ムレについて",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空もいんいん、地もいんいん、肢體に青き血ながれ、するどくしたたり、電光したたり、身肉ちぎれやぶれむとす、いま裸形を恥ぢず、十字架のうへ、齒がみをなしてわれいのる。",
              "citation": {
                "source": "情慾",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
