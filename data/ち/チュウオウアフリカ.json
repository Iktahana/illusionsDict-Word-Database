        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "中央アフリカ北東コンゴーのある地方の竪琴にクンディまたはクンズというのがある。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央アフリカにおいても、大中小の酋長はいずれもみな神権を持っていて、自由に地水風火の原素を使役する。",
              "citation": {
                "source": "奴隷根性論",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは赤道中央アフリカのコンゴ北東部にある。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが、パナマ、スマトラと中央アフリカにしかない、ジャングルの大奇景なのである。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　恵まれた湖水　ウヂヂは中央アフリカでも早くから開けた町で、一方にはアラビア人が住み、他方には土人が住んでゐます。",
              "citation": {
                "source": "アフリカのスタンレー",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "企みだろうがなかろうが、もしジョニが罠を仕掛けたら、中央アフリカの誰かが最高衣装を易々手に入れるってことだ。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここは中央アフリカの裏口だ。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            }
