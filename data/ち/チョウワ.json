[
  {
    "uuid": "e6966930-97c3-50c9-a139-1ec8aa6cc6dc",
    "entry": "調和",
    "reading": {
      "primary": "ちょうわ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
