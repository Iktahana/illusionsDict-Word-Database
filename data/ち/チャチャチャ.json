          "literary": [
            {
              "text": "」「チャチャチャッチキチッチドンドン。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チャチャチャッチキチッチ、」と低く口吟みながら、格子戸をがらりと開けると、同時に框の障子を開いて、「よくねえ、」と声を懸けて、逸早く今欄干に立顕れたその女中が出迎えた。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の中悪戯をして叱られると、内を駈出して、近所の馬鹿｜囃子の中へ紛込んで、チャチャチャッチキチッチッと躍っていると、追駈けて来た者が分らないで黙って見遁しては帰ったが、私の顔は今でもおかめの面に肖ているかといって、尋ねられたこともある。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダブリ、ダブリ、チャチャチャと水の音。",
              "citation": {
                "source": "破れわらじ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
