        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "朝鮮語の「ナツ」は昼である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし朝鮮語で夏を意味する言葉は「ヨールム」で熱がヨールである。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮語で冬は「キョーウル」である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮語「モーリ（頭）」は「つむり」の「むり」と比較される。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "通訳が、何か、朝鮮語で云って、手を動かした。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮語の話は、傍できいていると、癇高く、符号でも叫んでいるようだった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、朝鮮語は、「オブソ」という言葉だけしか知らなかった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとから来た通訳が朝鮮語で何か云った。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで本邦地名の問題に触れるとなれば、自然の勢いで、アイヌ語や朝鮮語による地名起原説を参照しなければならぬ事になる。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方朝鮮語やウラルアルタイ、チャムモンクメール、オセアニック等の語系との関係についての論文は往々われわれの目にも入ったが、正面からマライとの関係を論じて、そうしてそれが一般学界ひいては世人の注意をひくほどに至ったもののあった事は寡聞にしてまだ知らなかったのである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮語との語彙の近似は、何人もいだくべき予期に反して案外に少ないもののようである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "キチベエというのは「女の子」という意味の朝鮮語であった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ、これでも朝鮮語を少しは覚えているな」という考えが彼を微笑させた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後を向いて、立っている三造にむかって「坐れ」というような手真似をしながら朝鮮語で何か言った。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼の知っている少数の朝鮮語の中の一つであった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう意味を、彼は、彼の知っている限りの朝鮮語を、日本語と交ぜて使いながら説明しようとした。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男も黙ったまま之に応じ、趙の朝鮮語での説明を聞きながら、私の顔を見下して微笑した。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "趙は私の前であまり朝鮮語を使うのを好まないようであった。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一等お終いに、司令官が言うぜ、『今日縄の下を、縄につかえずに通った者は、大きな体格の良い女房をもらえ』ってね」「ニキミ、シバラ」（馬鹿野郎）　と、林田は朝鮮語で言い返すのだった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "長長秋夜　　　　　――ぢやん、ぢやん、ちゆう、やは朝鮮語で長い長い秋の夜といふ意味。",
              "citation": {
                "source": "小熊秀雄全集-7",
                "author": "詩集（６）長篇詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "劣惡ナル者ガ亡ビテ優秀ナル者ガ殘存スル自然淘汰律ハ日本語ト國際語ノ存亡ヲ決スル如ク、百年ヲ出デズシテ日本領土内ノ歐洲各國語、支那、印度、朝鮮語ハ亦當然ニ國際語ノタメニ亡ブベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮崎道三郎博士かつて『東洋学芸雑誌』に書かれたは、朝鮮語で晨をアチム、例推するに本邦で上世、晨すなわち日の出る事をアズマと呼び、東は日の出る方故、東国を朝早く鳴く鶏に併せて鳥が鳴く吾妻と称えただろうと、洵に正説で、ドイツでも朝も東も通じてモルゲンと名づくる。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中を長いキセルでぽかりぽかりと悠長な煙を吐きながら、変わり種の清正が美人の妓生とぬれ場をひとしきり演ずるというのですから、ずいぶんと人を食った清正というべきですが、それよりももっと見物をあっといわした珍趣向は、そのぬれごとのせりふが全部朝鮮語であるということでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん、でたらめの朝鮮語ではありますが、ともかくも、日本語でないことばでいろごとをしようというのですから、かりにも江戸一円の警察権を預かっている八丁堀のおだんながたがくふうした趣向にしては、まことに変わった思いつきというべきでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台はとんとんと進んで、ふたたび長助の虎が現われる、鈴江の妓生がきゃっと朝鮮語で悲鳴をあげる、それからあとは話に伝わる清正のとおりで、やおら三つまたの長槍を手にかいぐり出したとみるまに、岡っ引き長助の虎はたった一突きで清正に突き伏せられてしまいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁は、露語と朝鮮語の宣伝びらや、切抜きや楽書でいっぱいだ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『スターズ・アンド・ストライプス』（ＧＨＱ）、『ビーコン』（英連邦占領軍）、『中華日報』（中国人経営日本語版）、『国際タイムス』（朝鮮人経営日本語版）、（朝鮮人経営朝鮮語版）、『国際新聞』（中国人経営）、『自由日報』（同上）　在日特派員クラブは現在六十一名の会員をもっている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生」それは朝鮮語だった。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあお掛けなさい」私は二人きりになった時静かに朝鮮語で話しかけた。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザバレと云うのは捕えろという意味の朝鮮語で、朝鮮移住の内地人がよく使う言葉だった。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
