[
  {
    "uuid": "c9ba6846-e7a3-534a-a1fa-8d4833725d1d",
    "entry": "著",
    "reading": {
      "primary": "ちょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(written) work",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところが著いてみると、恐ろしい当て外れだつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今、その世界を聊かなりとも解明したいのであるが、当抵手に負へさうもないことであるから、仮りに、さういふ世界に恋著した宮沢賢治が、もし芸術論を書いたとしたら、述べたでもあらう所の事を、かにかくにノート風に、左に書付けてみたいと思ふ。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "散文も少々あるやうだが、詩集アムール・ジョーヌは彼の主著である。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "繰返して言ふ、私はこの書物の著者及びその人の生活に関しては、世の何ぴとよりも深徹な智識をもつてゐるものである。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "順つて私の著者に対する大胆な評価は、凡てこの自信と無遠慮の独断から出発する。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故多くのヘルンの著作は、書物から得た材料ではなく、その妻によって主観的に飜案化され、創作化されたものを、さらにまたヘルンが詩文学化したものであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故にヘルンもまた、自分の著作は皆妻の功績によるものだといって、深く夫人の労に感謝し、ある著述のごときは、実際に夫人の名で出版しようとしたほどであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時ヘルンは、黙って彼女を書架の前に導き、彼の尨大な著作全集を見せて言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば彼の最近の作風には、一の著るしい變化と跳躍とが見られるから。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども彼の批判態度は、常に著るしく客觀的だつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に彼の觀照が澄めば澄むほど、素通しの硝子における陰影の缺陷が著るしかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　芥川君の文學は、そのあまりに文藝的であると共に、またあまりに少年的な、少年的であることに於て著るしい。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども此處に、彼の著るしい破綻が感じられた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議なくらいに顕著なおでこと、鉄縁の小さな眼鏡とたいへんなちぢれ毛と、尖った顎と、無精鬚。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Pirate という言葉は、著作物の剽窃者を指していうときにも使用されるようだが、それでもかまわないか、と私が言ったら、馬場は即座に、いよいよ面白いと答えた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿に著いて、すぐ女中さんたちに輕い冗談言へるやうな、器用な男ではないのである。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しき男といふのは文学青年で、――尠くもその頃まで――本を読むと自分をその本の著者のやうに思ひ做す、かの智的不随児であつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽に於けるその著しい例がベートーベンである。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、このことは、芸術家が、非常に顕著に芸術的である場合にのみ起る。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "概観するに批評精神の等閑にされた時代はえてロマンチックと謂はれる傾向が比較的顕著であつた。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "名辞以後、名辞と名辞の交渉の範囲にだけ大部分の生活があり、名辞の内包、即ちやがて新しき名辞とならんものが著しく貧弱である。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私は西田幾多郎著「自覚に於ける直観と反省」に共鳴するものだ。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「その頃の生活」に妥協性の多かつた私が、そんな友人との絶交の仕方が出来るやうになつてゐた私の変り方の著しさをしみじみ気付いて自分で驚いた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "著実な詩の書が、ぼつぼつと出ることともなれば、文壇はもつと住心地のよい所ともなるであらう。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論実生活側の集積的活動が余りに顕著ではまづいのだが、余り弱くても不可ない。",
              "citation": {
                "source": "アンドレ・ジイド管見",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした最近の流行唄について、特に著るしい特色として感ずることは、歌詞の取扱ひ方に対する、作曲の方法が著るしい変つて来てゐることである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の時代の子供たち、特に現代日本の子供たちが、一昔前の子供に比し、科學に對して著るしい興味を持つてることは事實である。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那文字の輸入以來、我々は漢語のデタラメな無韻的和讀によつて、著るしく「耳の健康」を障害し、言語上の音痴民族となつてしまつた。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "書斎に仕事をしている時のヘルンは、周囲のちょっとした物音にも、すぐ『私の考え破れました』といって、腹立しくペンを投げた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬や小鳥やの動物は、単に鼻を嗅ぎ合うとか、尾を振り合うとか、目をちょっと見合すとかいうだけで、相互の意志が完全に疎通するのに、人間は廻りくどく長たらしい会話をして、しかもなお容易に意志を通じ得ない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
