    "definitions": [
      {
        "index": 1,
        "gloss": "impact (of a projectile)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
