    "definitions": [
      {
        "index": 1,
        "gloss": "spirit residing in the ground",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
