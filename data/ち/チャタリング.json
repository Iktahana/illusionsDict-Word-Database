        "examples": {
          "standard": [
            {
              "text": "冬の寒空の下、ブルブルとチャタリングしながらバスを待った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い機械の部品が摩耗して、不規則なチャタリング音を発している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "キーボードのチャタリング現象で、意図しない文字が入力されて困っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "コンピューター用の本格的なキーボードは、キーを押したり放したりする際に生じるチャタリングと呼ばれる信号のノイズをきれいに取ってやるために、いろいろな工夫を凝らしていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方厳しいコストの切り下げを求められる電卓では、ちゃちなキーボードが生じさせるチャタリングを、ソフトウエアで判定してキャンセルしてしまう工夫が進められていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
