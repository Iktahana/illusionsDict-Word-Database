          "literary": [
            {
              "text": "コンピューター用の本格的なキーボードは、キーを押したり放したりする際に生じるチャタリングと呼ばれる信号のノイズをきれいに取ってやるために、いろいろな工夫を凝らしていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方厳しいコストの切り下げを求められる電卓では、ちゃちなキーボードが生じさせるチャタリングを、ソフトウエアで判定してキャンセルしてしまう工夫が進められていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
