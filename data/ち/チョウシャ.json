[
  {
    "uuid": "f1caee52-40c3-5294-955c-1bc22aff9e61",
    "entry": "庁舎",
    "reading": {
      "primary": "ちょうしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
