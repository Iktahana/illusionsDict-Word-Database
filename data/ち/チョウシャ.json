      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "government office building",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "めう……めうおおお……めう……めうおおお……　それこそまた濡れ鼠になって、向うの向うの庁舎の方へと、いっさんに駈け出す私たちであった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "庁舎の押上げ窓の硝子を透かして。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "六条の御息所は左衛門の庁舎へ斎宮がおはいりになったので、いっそう厳重になった潔斎的な生活に喪中の人の交渉を遠慮する意味に託してその人へだけは消息もしないのである。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車が庁舎の前のゆるい勾配を一気に駈け上ると、根賀地が第一番に広場の砂利の上に降り立った。",
              "citation": {
                "source": "空中墳墓",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "川口町では、旧大阪府庁舎などは最も代表的のものと思う。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその府庁舎は空家となり、この先き、この風景はどんな事になって行くか、私は心細い。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "円屋根といえば私は先きに述べた処の旧府庁舎の円屋根を愛する。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏査した新しい支配地の貸付を、開拓使の仮庁舎に出頭して懇請しなければならない。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年まで函館にあった庁舎は、今年、融雪期とともにゼニバコに移り、そこからサッポロの都府築営を監督して、いよいよ先日移転したというのである。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからのまると一年間の月日が、カヤの生えた原野に町割りをつくり、アカダモの樹間には、庁舎、倉庫を立ちならばせた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大友道からサッポロに辿り着いた彼は、ひろい空地のように見える草ッ原――やがてそれも道路になるのであろうが――その向うに、土塀をめぐらした白木づくりの庁舎に目を注いだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "満足して、笠を小脇にかかえた彼は、正門の真ン中からゆったりと庭を横ぎって、庁舎正面の泥だらけの玄関にぬッと立った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "命をおとしてもいいのかい」「にげるけれど、猫がいないから探しているんだ」　混乱のうちに、めりめり音がして、庁舎がさけだした。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が戸口から出て、ダムの破壊箇所と反対の方向へ、二三歩走ったと思うと、庁舎は大きな音をたてて、決潰ダムの下のさかまく泥水の中へ、がらがらと落ちていった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話どころか、庁舎も下の方へ流れていってしまった」「おお、そうだったな。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこの赤煉瓦の先代の建物である開拓使本庁舎は、ドームのてっぺんたかく青地にまっかな星一つある開拓使旗をひるがえして、絵になってのこっている。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……パリにおけるコレラによる死亡は多く、1832年にエレガントなショセ・ダンタンやモンマルトルのような高台では１万人あたり80人であり、オテル・ド・ヴィル（市庁舎）やシテ島のように低いところでは530人および520人であった（p. lxxviii）。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽の光線が、煤煙のために妨げられて、市庁舎の窓まで届かないものだから、池上市長と関助役は昼間も電気燈をつけて執務せねばならぬということは、三十三世紀後にはとても考えられたことではないが、事実はまったくそうであるから仕方がない。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央公会堂のすぐ裏に立つ市庁舎には、昼間に電燈があかあかと灯っているのである。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず市参事会員に会い、それから市会を招集して自分の意見を開陳することにする」　賀川市長が、市庁舎に帰って、事務室の机の前に坐ったのは、午後の三時半過ぎであったが、室内はとても暗くて、事務がとれない。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不満な心持ちで、市庁舎の窓から、大阪の西の空を見てみると、野田、春日出の方面において、住友伸銅所の太い三本の煙筒から、そして、春日出の電燈会社の太い煙筒からもうもうと、雲のごとき煙の立ち登るのを見た。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時たちまち、万雷の轟くがごとく市庁舎の前に「万歳！",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一六　市庁舎の内外　市庁舎前の群衆はすでに号外で報ぜられた大示威運動であった。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "市長は眼に涙を湛えながら、市庁舎に急いだ。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三九　市吏員の長襷主義　市庁舎へ行ってみて驚くことは今日に限って各課とも大繁忙の大繁忙、まるで火事場のようであった。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんど市庁舎の吏員全部であった。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
