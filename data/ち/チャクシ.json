        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "主人が妄想に落ちて、いたずらに立てるあいだに、花前は二｜頭三頭とちゃくちゃくしぼり進む。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもんちゃくして居るとき、ソローキン、ドイツへ出かけようとして党切符を出し出国許可を貰おうとする。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどくもんちゃくしたのが、父に気に入りのナポリだったということが、伸子を悲しくさせた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の名前にとんちゃくしないのは、彼にとっては一つの貴族的な癖だった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも、そいつが気に食わんのだ」「じゃあ、梁山泊を小っちゃくしたようなもんですが、二龍山の宝珠寺へ行ってみませんか」「ふウむ、そんな恰好な隠れ家があるのか」「そこにも、三、四百人は立て籠っておりましょう。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
