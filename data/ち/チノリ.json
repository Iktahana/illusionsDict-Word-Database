      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "locational advantage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いつか海洋博物館での通俗講演会でペンクが青島の話をしたとき、かの地がいかに地の利に富むかということを力説し、ここを占有しているドイツは東洋の咽喉を扼しているようなものだという意味を婉曲に匂わせながら聴衆の中に交じっている日本留学生の自分の顔を見てにこにこした。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い村落は永い間の自然淘汰によって、颱風の害の最小なような地の利のある地域に定着しているのに、新集落は、そうした非常時に対する考慮を抜きにして発達したものだとすれば、これはむしろ当然すぎるほど当然なことであると云わなければならない。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、一つには建築様式の相違にもよるであろうが、また一つにはいわゆる地の利によるであろう。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――天の時、地の利、人の和、まさしく時節じゃ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の西郊、彼の卜した地の利も彼に幸ひした。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地の利を得ないのじゃ。",
              "citation": {
                "source": "失敗園",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地の利によらないことは、それが木曾路でも、ふとすると、こんな処で、どうした拍子、何かの縁で、おなじ人に、逢うまじきものでもない、と思ったろう。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "織田信長が、先づ京都に入つて彼の理想たる「天下布武」の第一歩に成功したのは、彼が他の群雄に比して、最も地の利を得てゐたからである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――天の時、地の利、人の和、まさしく時節ぢや。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の利益と持株の利益とを別にして了ふことも必要と思つてゐますが、兎も角充分に案に付き練りました上で、農園の総会に提出したいと考へてゐるのです。",
              "citation": {
                "source": "農場開放顛末",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に敵は、地の利を得ている。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄は敵と戦うのに、地の利を得ていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今日ならばともかくも、その当時において猿若町は地の利を得ていなかった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "地の利を占めているとはいえ、二百五十人を相手にしては、ちょっとどうも防ぎかねる」銅兵衛はますます不安そうにした。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに「天の時は地の利に如かず、地の利は人の和に如かず」で、和の欠けた国家が隆昌し、発展したためしはありません。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄は敵と戦ふのに、地の利を得てゐた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度蹉跌しなければならなかつた志村は地の利を失つてはゐる。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　国文学のもつ地の利　日本文学の古典が、今日の文学の現実的な進みを助ける力としてよりも、寧ろそれを制しとどめるような力として持ち出されて来ていることについて、一部の社会情勢がしからしめていることは勿論云うまでもない。",
              "citation": {
                "source": "文学上の復古的提唱に対して",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の事実を綜合して見ると、今日、国文学の古典について云々することは、読者大衆の側からの鋭い視線にそなえる用意も比較的なくてすむし、本当の国文学研究者たちの、大衆的場面への批判的進出の懸念もさし当りはないという、一種異様な地の利を占めた安全地帯に身をよせる仕儀となるのである。",
              "citation": {
                "source": "文学上の復古的提唱に対して",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらずこの辺一帯の地の利もすでに悪くなって、真砂座のあった時分の下町｜情緒も影を潜め、水上の交通が頻繁になった割に、だだ広くなった幹線道路はどこも薄暗かった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "米の不足を補うために、東京市は馬鈴薯の種をとりよせ、それを十坪以内の土地の利用者に限って分ける、という話である。",
              "citation": {
                "source": "昔を今に",
                "author": "――なすよしもなき馬鈴薯と綿――",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会化した土地の利用ということの代りに、今度は自分達が地主となって元の地主からとった土地を分け合えるものと、旧い私有財産制に毒された理解に執していた。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地の利を生かし、父や知り合いのつてを頼って部品を集めたウォズニアックは、近くに住むハイスクールの後輩のビル・フェルナンデスを引き込んで、クリームソーダ片手に数週間ぶっ続けで作業に取り組んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その計画の第一は、先ず、目下満洲に勢力を張っております張作霖に軍資金と、十数台の優秀なる飛行機を貸し与え、従来の親日傾向を放棄させて日本を圧迫させる一方に、一時平静に帰しております支那の内治を再び攪乱し、その虚に乗じて、支那各地の利権と、金融機関の中心を掌握するにありました。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも地の利さえ占めている。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて杭州に近き泉州は、地の利を占めた上に、南宋時代を通じて、支那政府は國庫の收入を増加せんが爲に、頻りに外蕃の通商を奬勵したから、泉州の貿易は年一年と長足の發展をして、廣州と頡頏して讓らざる位置に立ち、更に南宋末から元時代にかけて、泉州の勢力は遂に廣州をも凌駕するに至つた。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日、我が稲門健児は不幸にも、北側の第一レインを割り当てられ、逆風と逆浪の最も激しい難路を辿らねばならず、且つ、長身に伍して、短躯のクルウを連ね、天候さえ冷え勝ちで、天の利、地の利、人の利、すべて我々に幸いせず。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時またみちのりを問うに、さきの答は五十町一里なりけり。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お先に……」　怪しむようにふり向いた同僚たちの目に送られながら、名人は不審に首をかしげて、迎えの駕籠にうちのりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この暑いのに、右門のだんなともあろうおかたを汗びたしにさせたといっちゃ、あっしが女の子たちに合わす顔がござんせんからね」　現金なところもあるがあいきょうのあるやつで、伝六がかってな理屈をつけながらつじ駕籠を雇ってまいりましたので、右門も苦笑しながらうちのりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
