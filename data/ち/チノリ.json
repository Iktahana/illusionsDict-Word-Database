[
  {
    "uuid": "4a1bc2bd-7396-5ce2-ad9b-9c5f8c0ca624",
    "entry": "地の利",
    "reading": {
      "primary": "ちのり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "名詞"
      ],
