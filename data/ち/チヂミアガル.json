          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "乾燥機の熱で、Tシャツが縮み上がって子供服のようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長く水に浸けておくと、木綿の布は縮み上がる性質がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "寒い日に外に出ると、思わず体が縮み上がるのを感じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
