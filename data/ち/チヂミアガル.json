    "definitions": [
      {
        "index": 1,
        "gloss": "to freeze (in fear, surprise, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "突然の大きな音に、猫が驚いて縮み上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "先生に厳しく𠮟られて、彼はすっかり縮み上がってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "予想外の出来事に、私はただ縮み上がって立ち尽くすしかなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "百メートル、二百メートルなどのワイアの長さを読み上げられた時、われわれは、海の深さより、それを巻き上げることの困難さに縮み上がる。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "喉が乾いて居りますから一掬い飲んで見ると手は縮み上がる程冷たいので、二度と掬って飲む勇気がなかった。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとか組のなんとか氏は、そうワカラズ屋の暴力団ではないらしかったが、Ｈ氏という女性的に神経質のニセ豪傑がひがんだ主観で事実を自分流にまげて伝えているから、変にこじれて受けとり、どやしつければ文学青年はちぢみあがるもんだと考えて乗りこんだらしい。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "女主人はいうまでもなくおせいちゃんの母親であるが、年はそれほどでもない筈なのに、あたまはすっかり白髪だったし、痩せていて皺だらけで、これに総入れ歯を外して睨まれると、どんなにあらくれた蒸気乗りでもちぢみあがる、といわれていた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこのまちがいも、もとはといえば、やはりその癇癖のつよい、気のみじかいところから起ったことなのでしょうが、御城代のごきげんが悪いときくと、城中のさむらいたちでも、この邸につかえている召使たちでも、声をひそめてちぢみあがるといわれるくらい、名代のかんしゃくもちでとどろきわたっているかたでした。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいことってのはな、躯じゅう八万八千の毛穴が一つ一つちぢみあがるような気持だとよ。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to shrink up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
