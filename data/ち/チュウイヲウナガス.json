[
  {
    "uuid": "514f1487-c950-5040-8f58-6b1ad6c403c8",
    "entry": "注意を促す",
    "reading": {
      "primary": "ちゅういをうながす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
