  {
    "uuid": "49066d5b-c50a-556a-8068-099ff6af8e0c",
    "entry": "着彩",
    "reading": {
      "primary": "ちゃくさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "colouring (a drawing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "栄三郎は昼の時間が惜しかった、絵はもう完成に近く、あの（落ちている）扇子に着彩すればいいところまでいっていた。",
              "citation": {
                "source": "扇野",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの線もどの点も、またぼかしの部分や着彩の順にも、いささかの誤りもためらいもなく、すらすらと描きあげてゆくのを見るようであった。",
              "citation": {
                "source": "醜聞",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "疊敷きの質素な部屋であつたが、ロダンのほんものの素描着彩がかかつてゐた。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            },
            {
              "text": "右がわに、絵具を溶いた（宿の食器を利用したらしい）小皿を、八枚ほど置いて、線描が乾くと着彩するのであるが、線はたしかなものだし、色の合わせようも巧みなものであった。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水墨、着彩――人物や山水や花卉、とりどりであるが、それらは全部、いまでも眼の前に、細部まで、ありありと繰りひろげて見ることができる、と一玄は云った。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
