  {
    "uuid": "5e8560bb-8576-5e6c-8c9d-1f1fc11af007",
    "entry": "帙",
    "reading": {
      "primary": "ちつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "protective covering for a book (often in the form of a folding case with clasps)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "帙と離ればなれに転っている本の類。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国手、一個の書架の抽斗、それには小説、伝奇の類が大分｜帙を揃えて置かれた――中から、金唐革の手箱を、二個出して、それを開けると無造作に、莞爾々々しながら卓子の上に並べられた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）松の葉、帙入美本、十四円。",
              "citation": {
                "source": "パンの会の回想",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十七八を頭にわたくしが最年少者で十九の娘、五人、欧洲婦人の服飾史や、押花の帙や図案集が挿し込まれている書棚。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "数十部の画帙画套が恰も一本の棟木のように一つに固まって真黒に焼けて了った。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間、年を閲する二十八、巻帙百六冊の多きに達す。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "九輯となると上中下の三｜帙を予定し、上帙六冊、中帙七冊、下帙は更に二分して上下両帙の十冊とした。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "余のごときは黄巻青帙の間に起臥して書斎以外にいかなる出来事が起るか知らんでも済む天下の逸民である。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "此年には布帙、書堂新下絳紗帷」と云ふより推せば、堀江は聘せられて学校に往つたのであらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "凹巷は「堂上散書帙、聚徒垂絳帷」と云つてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "懶眠繙帙罕　　懶眠帙を繙くこと罕に、晏坐覆棋頻　　晏坐棋を覆すること頻りなり。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "病骨支離難耐歩　　病骨支離歩に耐へがたし、間窗枕帙夢江南　　間窓帙を枕として江南を夢む。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "青帙悲遺響　　青帙遺響を悲み、紅爐愛暮鐘　　紅炉暮鐘を愛す。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月二十六日頃日賣舊藏『國富論』、換漢籍、樂不少蠹書聊得買　　蠹書聊か買ふことを得、青帙散空牀　　青帙空牀に散ず。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月六日、六月十日、六月二十六日、定稿閑中好閑中好　　　　閑中好し青帙散空牀　　青帙空牀に散ず、此趣人無會　　此の趣、人の会する無し、白雲環草堂　　白雲草堂を環る。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概は帙をひもといて古人の詩を読んで暮らす。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "茅堂一架帙　　茅堂一架の帙、取次百花披」　取次百花｜披けり。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "米國のエドワルド、エス、モールス氏が、明治十二｜年に於て、初めて此所に遺跡を發見し、然うして大發掘を試みられた記事は『理科會粹』の第一｜帙として、東京大學法理文學部から印行せられてある。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "大森貝塚の發掘",
                "note": "青空文庫"
              }
            },
            {
              "text": "六朝時代を通じて、僧尼は離俗出家といふので、その父母を拜せず、却つて父母の禮を受くるを例とした（唐の彦※「集沙門不應拜俗等事」【『縮刷藏經』露帙七册所收】）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、不便が嬉しくはちつともない。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちつまり言へば、彼は私の最も「親愛なる友」であつたのだ。",
