[
  {
    "uuid": "9869fce9-8510-5b0f-9853-43c5fa0dd142",
    "entry": "沈勇",
    "reading": {
      "primary": "ちんゆう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
