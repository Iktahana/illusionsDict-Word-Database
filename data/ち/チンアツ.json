[
  {
    "uuid": "c2d4ca4f-3e6a-5a7d-aaf8-bebdaface37c",
    "entry": "鎮圧",
    "reading": {
      "primary": "ちんあつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
