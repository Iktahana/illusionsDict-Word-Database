          "literary": [
            {
              "text": "「鳴いたり鳴いたり、鼠の鳴き声」　人形は「チュウ、チュウ、チュチュー」と鳴きました。",
              "citation": {
                "source": "人形使い",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "とみる間にチュチュチュチュチュッ。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "外かしら、それとも室のどこかで飼っているのかしら、チュチュンチュンチュンと囀っている。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "水ッ洟をチュチュさせて、お客様のそばへ寄るとな、それ……お客様の鮟鱇鍋がまずくならあ」「なに、かまやしねえ」　と隅にいた客。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
