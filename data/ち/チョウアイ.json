[
  {
    "uuid": "24e8464d-c874-5fda-b873-ef0f148033bd",
    "entry": "寵愛",
    "reading": {
      "primary": "ちょうあい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "favor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "深く寵愛していたのでまだどこの山へも送らず、手元で養っていたのであるが、翁はとうとう決心した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "身は桜町家に一年幾度の出替り、小間使といへば人らしけれど、御寵愛には犬猫も御膝をけがす物ぞかし。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "寵愛の鳥、梟を黄昏の空に飛ばしてこつそり笑つて眺めてゐる智慧の女神のミネル※に。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまで美しというにあらねど童には手ごろの生き物ゆえ長の児が寵愛なおざりならず、ただかの青年にのみはその背を借すことあり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "元二の順に杯も※つて來た時、自分國許の事に懲りて仔細あつて、世を忍ぶ若ものが庄屋の屋敷に奉公して、其の妻と不義をする、なかだちは、婦が寵愛の猫で、此の首環へ戀歌を結んで褄を引くと云ふ運び。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　後前を見廻して、「それはね、城のお殿様の御寵愛の、その姉さんだったと言いましてね。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は王侯の寵愛に依ツて馬車に乗ツてゐる狆よりも、寧自由に野をのさばツて歩くむく犬になりたい。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "「玉を懐いて罪あり」AMADEUS HOFFMANN　路易第十四世の寵愛が、メントノン公爵夫人の一身に萃まって世人の目を驚かした頃、宮中に出入をする年寄った女学士にマドレエヌ・ド・スキュデリイと云う人があった。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿様の寵愛を奪はれたからといつて、相手に斬りつけたのは兄さんの間違ひではなかつたか。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉のお千代に塾をひかしてから主婦の役をさせ、妹のお絹は寵愛物にしていた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはよくば、Ｙが寵愛してゐる弟息子を奪つて、父の傲慢の鼻を明かしてやらうとさへヒステリカルに感じた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰朝後はいよ／＼交際を密接にした弥一郎と勇吉とは、寵愛してゐるパイプ――ネクタイピン――卓上の一枝の花――を一方は割愛し、一方は愛用し始めるといつた無雑作な調子で、兄はその友人と自分の妹の婚約を取計つた。",
              "citation": {
                "source": "夏の夜の夢",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れ立ての赤子の掌を寵愛せずにはゐられないやうな、女の本能のプチー（小さくて可愛いゝ）なものに牽かるゝ母性愛的愛慾がかの女の青春を飛び越して、食慾に化してかの女を前へ推しやつた。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十余年間、臣ポローニヤスのみならず、家族の者まで、御寵愛と御庇護を得てまいりました。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老齢と雖もさらに奮起一番して粉骨砕身いよいよ御忠勤をはげみ、余栄を御子孫に残すべきところでございましたのに、まことに生憎のもので、この御寵愛最も繁かりしその翌年、あの大騒動にて御一族全滅に相成りました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでながら、この将軍家の最も御寵愛なされてゐた新兵衛尉朝盛さまさへ、この五月の兵乱には、やつぱり和田氏御一族に従ひ、黒衣の入道の姿で御ところへ攻め入つたのでございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大星だか由良之助だかで、鼻を衝く、鬱陶しい巴の紋も、ここへ来ると、木曾殿の寵愛を思い出させるから奥床しい。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "名を村といひて寵愛｜限無かりき。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も用のない時は、押入の中を掃除したり、寵愛の銀煙管を研いたりする。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋ほど自然に寵愛され、自然を原形のまま利用するのを許されている国々にこのくらいな植物は探したら無いことはなかろう。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "惣蔵、容姿端麗にしてしかも剛気であったので、勝頼の寵愛深かった。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はもっとも曾に寵愛せられた。",
              "citation": {
                "source": "続黄梁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……此美女御寵愛のうち、なほ／＼身の曇を去て、月の都の只中に住玉ひぬとある。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "後日に相知るゝ御事、又御枕のうち身の曇り去るとは處女膜が彼の御ン事に御寵愛の其夕べまで嚴存せしを指たのだ）。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "16　Antinous ――第二世紀のローマ皇帝ハドリアヌスに寵愛された美少年の小姓。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとうさん、おとうさん」「とんちゃん、とんちゃん」　糟谷はきょうにかぎって、それがうるさくてたまらないけれど、子煩悩な自分が、毎朝かならず出勤のまえに、こうして子どもを寵愛してきたのであるから、無心な子どもは例のごとく父にかわいがられようとするのを、どうもしかりとばすこともできない。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "高官たちも殿上役人たちも困って、御｜覚醒になるのを期しながら、当分は見ぬ顔をしていたいという態度をとるほどの御｜寵愛ぶりであった。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死んでからまでも人の気を悪くさせる御寵愛ぶりね」　などと言って、右大臣の娘の弘徽殿の女御などは今さえも嫉妬を捨てなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "女御として藤壺の宮の御｜寵愛が並びないものであったから対句のように作って、輝く日の宮と一方を申していた。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばんうえの姫君はお茶々どのと申し上げて、まだいたいけなお児でござりましたが、このお児が後に太閤殿下の御ちょうあいをおうけなされ、かたじけなくも右だいじん秀頼公のおふくろさまとおなりなされた淀のおん方であらせらりょうとは、まことに人のゆくすえはわからぬものでござります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
