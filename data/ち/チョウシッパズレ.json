        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だがタケシの目には、開きかけた桜と空の青とがひどく調子っぱずれに映った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがどうも調子っぱずれなので、あたしは微笑んで、やたらにいやいやをしてると、ふいに、村尾さんの眼から、涙が流れだしました。",
              "citation": {
                "source": "千代次の驚き",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の子が、恐ろしい調子っぱずれな声を張りあげて唱歌らしいものを歌って居ると、わきではこまかいのが玩具の引っぱりっこをして居る中に入って奥さんが上気あがって居たりするのを見ると気の毒になってしまう。",
              "citation": {
                "source": "二十三番地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間が騒々しいとおてんどさままでが調子っぱずれだ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「た、大変ッ」　麹町四丁目、畳屋弥助のところにいる職人の勝蔵が、裏口から調子っぱずれな声を出します。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "くるい咲き",
                "note": "青空文庫"
              }
            },
            {
              "text": "調子っぱずれなラッパの音がした。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経がぶるぶる震え、いつも吸ってる煙草のせいで、体が調子っぱずれに怖いほどジンジン鳴った。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "出てきても調子っぱずれだったりする。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お馬にのったへいたいさんてっぽうかついであるいてるトットコ　トットコあるいてるへいたいさんは　大すきだ　気ばりすぎて調子っぱずれになった歌が家の中から聞こえてくる。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間の外国人が仏国家ラ・マルセイエーズを調子っぱずれで歌い始めた。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
