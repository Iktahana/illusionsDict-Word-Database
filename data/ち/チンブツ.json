    "definitions": [
      {
        "index": 1,
        "gloss": "rare item (esp. food)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「いかものも、あのくらゐに成ると珍物だよ。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　みな似たような思いと見えて、一座しんみりして、遠慮しながら互いに小声で盃のやりとりをしていたが、そのうちに皆、酒の酔い方を思い出して来たと見えて、笑声も起り、次第に座敷が陽気になって来た頃、主人の原田はれいの小判十両の紙包を取出し、「きょうは御一同に御｜披露したい珍物がございます。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍物（君子）をもありふれた物（小人）をも併せ用ゐて料理の獻立は出來るのである。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇人快人というから、どんな珍物が出て来るかと思ったら頭山先生が出て来た。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞿伽離見付けて諸比丘に向い、世尊｜毎も舎利弗は欲少なく足るを知ると讃むるが我らの手に入らぬこの珍物を蓄うるは世尊の言と違うと言った。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、今日でも『珍物』なぞという贈り物があるとか聞いていますが……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこことシェキスピアとを結びつける因縁ばなしにすぎないんだが、エルシノアには、ハムレットのお父さんなる王様の幽霊が出たという現場と、もう一つ「ハムレットの墓」と称する珍物があるのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一つ珍物を喰はさうかなあ。",
              "citation": {
                "source": "父の婚禮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「平七つあん、まだ珍物があるがなア。",
              "citation": {
                "source": "父の婚禮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那、……珍物結構、……頂戴。",
              "citation": {
                "source": "父の婚禮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "一首の道歌とも見れば見られ、蓋し晶子歌中の珍物である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "このレンズは初め土佐の山内侯が外国から取寄せられたもので、それが渡り渡って典物となり、遂に父の手に入ったもので、当時よほど珍物に思われていたものと見えます。",
              "citation": {
                "source": "寺内の奇人団",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "マア、僕らは、きょう千載に一遇の機会で、お目にかかれたというわけだ」「ううむ、そんな珍物かね」と、温厚学究君子のケプナラ君は感じ入るばかり。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際あり来たりの独楽、凧、太鼓、そんな物に飽きたお屋敷の子は珍物好きの心から烈しい異国趣味に陥って何でも上等舶来と言われなければ喜ばなかった。",
              "citation": {
                "source": "山の手の子",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「闇、わしもこれで、六十年、天下の珍物を採集するに骨を折ってまいった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八　闇太郎、浪路のなき骸を入れた唐櫃の蓋に手をかけたが、三斎隠居を見て、「さあ、御隠居、立ち寄って、御覧が、願げえてえんで――」「おお、大分、前口上のある品、定めて、目をおどろかす珍物であろうな？",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長も度胆をぬかれて、人間の皮膚がこれほど黒い筈は有り得ないから作りものだと疑つて、着物を脱がせ、褌もとらせて仔細に点検した後にやうやく正真正銘皮膚の色に間違ひないと納得、以来この珍物が気に入つて身辺に侍らせ、奴僕として使つてゐたが、本能寺の変に暗夜に紛れて行衛不明になつてしまつた。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大原心の中に「なるほど非常の珍物だ、この人たちがこんなに驚くほどだから」と内々愉快に堪えず。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも天下の富豪や贅沢家がまだ口に入れた事のない珍物だ」と自分のコップへは惜しそうに半ばほど注ぎぬ。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "時にこのフライは何だね、やっぱり珍物かね」中川「それは川魚の第一といわれるヤマメのフライだ。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "客の三人は珍物よと聞きて賞翫しつつ小山夫婦｜頻に感歎し「なるほどこれは無類だ。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "サア今度の料理も珍物だから試してくれ給え」と客の前の皿を下女に取かえさしめ「大原君、これはハンブルクビフステーキといって肉を叩いたビフテキの上へ玉子を載せたのだがこの肉が普通の品でない。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "我ながら珍物だと思っているが、僕は男であって然も女である。",
              "citation": {
                "source": "みみず先生の歌",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや樺山君とやらが、數年前掘り出した明刀錢の如き學界を聳動した珍物や、某君の拾はれたと云ふ石鏃の如きは、蝙蝠傘の先きでツツいた位では飛び出しさうもなかつたが、私には此の丘の上にある龜甲形の、琉球式の墓を見ただけでも面白い獲物であつた。",
              "citation": {
                "source": "沖繩の旅",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人物が珍妙であると共に、その槍の手筋は非常なる珍物であることを知っておりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "道庵は、よくそんなところへ出会せる男で、いつぞやも伊勢参りをした時に、やはり、こんなような鉢合せから始まって、宇治山田の米友という珍物を掘り出したのは、この先生の手柄であります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生」「やあ、珍物入来」　さすがの道庵先生が舌を巻いて、額を逆さに撫で上げました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はて、何であろうか」と、早速これを掬い採つて見たら、一向に見慣れぬ一つの水草であつたので、匆々東京に戻つて、すぐ様、大学の植物学教室（当時のいわゆる青長屋）に持ち行き、同室の人々にこの珍物を見せたところ、みな「これは？",
              "citation": {
                "source": "ムジナモ発見物語り",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "具石山・吉田屋敷・鳥の巣等には化石の珍物が出るので名高い。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の『中央公論』に「二百十日」と申す珍物をかきました。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
