        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "左側の川崎屋の入口には、厨夫らしい壮い男と酌婦らしい島田の女が立って笑いあっていたが、厨夫らしい壮い男はその時広巳の姿を見つけた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はね、外国航路の厨夫だったんですが、一度東京の震災を見たいと思いましてね、一と船休んで、こっちに連れて来て貰ったんですよ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はね、外国航路の厨夫なんですが、一度東京の震災も見度いと思いましてね、一と船休んで、こっちに連れて来て貰ったんですよ。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "厨夫長見舞に見え、粥を召し給はばいかになど云はれしかば、今日の昼より鶏卵とそれを貰ふ事に致し候。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだ、つまらないといったような顔をして、一座の面めんはみなシガーを取り寄せると、司厨夫のスタッブスがどこからとなしに現われて、アルコールなしのシャンパンの壜を持って来たので、だれかかった一座が救われた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "上床",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで両人の者はその作男兼馬丁兼｜厨夫がたくさんの兼職の中へ今一つ葬儀屋の職を加えて、やんごとない主人を棺の中に釘づけにしておいたという事実を発見した。",
              "citation": {
                "source": "作男・ゴーの名誉",
                "author": "THE HONOUR OF ISRAEL GOW",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなにしょっちゅうふかしどおしじゃ？",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、貴方、郡山（町の名）さ芝居が掛りましたぞえ、東京の名優、尾上菊五郎ちゅうふれ込みでない。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じつは　この　かめの　なかにある　みずあめの　ような　ものは、ほんとうは、みずあめでは　なくて、てんじくから　とうらいした　ちゅうふうの　くすりじゃ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは　ちゅうふうの　くすりじゃ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゅうふうという　びょうきは　子どもには　かからぬ、わしの　ような　ろうじんにだけ　ある　びょうきじゃ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの　くすりは、ろうじんの　ちゅうふうには　よく　きくが、子どもが　なめたら　いのちが　なくなる。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やっぱり　ちゅうふうの　くすりだなんて　うそだ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょっちゅうふざけているゴロちゃんは、その時ももちろんふざけた調子だったが、私はその奥に何か薄気味の悪いさむざむとしたものを感じたのだ。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
