    "definitions": [
      {
        "index": 1,
        "gloss": "chow chow (dog)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "支那種のチャウチャウという犬が、やっぱり日本犬によく似ている。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして現在小型の日本犬と称するものには、チャウチャウとのアイノコも多い。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャウチャウもそうだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばチャウチャウには相当程度狼の血が入っていますね。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さて、月探検犬ですが、マダム・ストーナリー、これはライカ種のもので、チャウチャウ以上に狼の血が入った犬種です。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「マダム、貴女がご存知の狼の特徴というのは、愛すべきジャッカルの特徴によって薄められたもの、例えばチャウチャウに見るようなものに限られます。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
