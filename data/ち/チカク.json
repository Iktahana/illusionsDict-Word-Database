[
  {
    "uuid": "3bafdd64-493b-548f-99ff-4e6ba2013e61",
    "entry": "近く",
    "reading": {
      "primary": "ちかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
