        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なお貯蔵室に粉二樽と、それから数の知れないほどに煙草がたくさんある。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の貯蔵室を作つたのである。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は真青になつた少年を抱き上げて床下の貯蔵室へ入れた。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所も貯蔵室も食べものでいっぱいで、こんな運命のめぐり合わせに感しゃすべきじゃよ。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "署長の腰骨が他人のものとしか考えられなくなった頃、液体空気貯蔵室へ来た。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "長方形の大広間は一方が扉によって屍体の貯蔵室に隣っている外、他の三方は広い硝子窓が並び、建築の様式が古い為に窓と窓との間には約半間幅位の壁がある。",
              "citation": {
                "source": "屍体異変",
                "author": "森於菟",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏にある地下貯蔵室の窓が無防備にぽっかり口をあけ、都合の良い開口部を作り出していた。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇妙なことに、その呼吸器は二酸化炭素ではなく酸素を扱っていると言え、また異様な空気貯蔵室があり、外のメンバに附属する開口部から完全な発達を遂げた他の二つの呼吸システム――鰓と気孔――へと切り替える機構があるという証拠があった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "食糧貯蔵室のぐちゃぐちゃぶり、特定の食品の紛失、最も相応しからぬ所から最も相応しからぬ方法でこじ開けた缶詰の忌まわしい程コミカルな山。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所や貯蔵室で采配を振る。",
              "citation": {
                "source": "トリスタン",
                "author": "TRISTAN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
