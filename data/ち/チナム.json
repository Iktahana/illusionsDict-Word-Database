    "definitions": [
      {
        "index": 1,
        "gloss": "to be associated (with)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
