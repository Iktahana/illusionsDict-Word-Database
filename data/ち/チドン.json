[
  {
    "uuid": "1a9279f2-7244-5dc4-a40b-ac960aabafef",
    "entry": "遅鈍",
    "reading": {
      "primary": "ちどん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
