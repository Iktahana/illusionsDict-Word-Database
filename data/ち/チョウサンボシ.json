    "definitions": [
      {
        "index": 1,
        "gloss": "being preoccupied with immediate (superficial) differences without realizing that there are no differences in substance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
