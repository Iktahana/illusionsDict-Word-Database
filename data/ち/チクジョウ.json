    "definitions": [
      {
        "index": 1,
        "gloss": "castle construction",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この江戸築城以前の流域を調べることは何かと首都の地理学的歴史を訪ねるのに都合が良かった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしの築城の大家は、城の設計にあたって、その城の廃墟になったときの姿を、最も顧慮して図をひいた。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで元就が考えたのは、厳島に築城する事だ。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "元就は、厳島に築城して、ここが毛利にとって大切な場所であるように見せかけ、ここへ陶の大軍を誘き寄せて、狭隘の地に於て、無二の一戦を試みようとしたのである。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "元就が厳島へ築城を初めると、元就の隠謀を知らない家臣はみんな反対した。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に秀吉は自ら京に留り、山崎宝寺に築城して居住し、宮廷に近づき畿内の諸大名と昵懇になり、政治に力を注いだから、天下の衆望は自ら一身に集って来た。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵器船舶の整備を急がせると共に、黒田長政、小西行長、加藤清正をして、肥前松浦郡｜名護屋に築城せしめ、更に松浦｜鎮信をして壱岐｜風本（今勝本）に築かしめた。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦術も上手だし、築城術にも通じている。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "天正十一年五月、秀吉は諸国から大木巨岩を集め、三十余国からの人夫を使役して、大坂に大規模な築城工事を起し、翌年の八月に殆んど竣工した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉は築城と同時に、大都市建設の計画を立てて、堺や伏見から商人を移住させた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉は、聚楽第の造営や大仏殿の建立、大坂、伏見の築城、朝鮮出兵と、華美好きに任せて莫大な費用を使つたやうに見えてゐて、少しも金には困らなかつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸大名に対しては、私に婚姻するを禁じ、築城や無届の修築を禁止するなど、十三箇条の武家諸法度を厳に励行させた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "朶石からは画の他に漢詩作法と篆刻と築城講話と、そして国手から半弓と碁と笛と釣りと箱庭作法とを習つた。",
              "citation": {
                "source": "気狂ひ師匠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八九年版ジョーンスとクロップのマジャール俚譚、三七七頁）　此程の本紙（大正十四年六月廿五日大阪毎日）に誰かゞ橋や築島に人柱はきくが築城に人柱は聞かぬといふ樣に書かれたが、井林廣政氏から曾て伊豫大洲の城は立てる時お龜てふ女を人柱にしたのでお龜城と名づくと聞いた。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一八七九年版ヘンダーソンの北英諸州俚俗二七四頁）甲子夜話の大阪城内に現ずる山伏、老媼茶話の猪苗代城の龜姫、島原城の大女、姫路城天守の貴女等築城の人柱に立つた女の靈が上に引いた印度のマリー同然所謂ヌシと成りて其城を鎭守した者らしい。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほ築城の人柱の例若干を集めて置いたが、病人を抱へて此稿を書く故引出し得ぬ。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨是れ漸く七歳のメルリンの告げたところと云ふたので、王早く其兒に逢ふて城を固むる法を問はんと自ら出迎へてメを宮中に招き盛饌を供し、翌日伴ふて築城の場に至り夜になると必ず壁が崩るゝは合點行ぬといふに、其は此地底に赤白の二龍が棲み毎夜鬪ふて地を震はすからと答へた。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて築城は功を奏したが王の意安んぜず。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらはその工事の苦役に堪えかねて、同盟脱走してこの山中に逃げ籠ったが、歳久しゅうして死なず、遂にかかる怪物となったのであって、かれらは今に至るも築城工事に駆り出されることを深く恐れているらしく、人に逢えば長城はもう出来あがってしまったかと訊く。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘密を保つのが築城の極意、図面を一見しただけで、わかるようでは名城とはいえない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に彼は古今を通じての最も偉大な画家であり、彫刻家であり、まだおまけに築城師であり、また最も優雅な著作者でもあった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦国時代の築城は当時の武力をもってしては力攻することが困難で、それが持久戦争の重大原因となった。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "１項は一般文化と不可分であり、２項は主として武器や築城に制約される問題であって、時代性と密接な関係がある。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "刀槍は裸体の個人間の闘争には決戦的武器であるが、鎧の進歩によってその威力は制限され、殊に築城に拠る敵を攻撃することは甚だしく困難となる。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対し、火砲は小銃に比し攻撃を有利にするが、その威力も築城と防禦方法の進歩により掣肘される。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち近時の機関銃の出現と築城の進歩とは防禦威力を急速に高めたが、大口径火砲の大量使用は一時、敵線の突破を可能ならしめた。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "地上の戦闘では土地が築城に利用され、場所によってはそのまま強い障害ともなり、防禦に偉大な力となる。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦国時代の築城は当時これを力攻する事困難でこれが持久戦争の重大原因となった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "１項は一般文化と密に関係があり、２項は主として武器、築城に依って制約せらるる問題であって、歴史的時代性とやはり密な関係がある。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七世紀ボーバン等の大家が出て築城が発達し、各国が国境附近に設けた要塞は運動性に乏しかった軍の行動を掣肘する事極めて大きかった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
