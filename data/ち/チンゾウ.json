  {
    "uuid": "56f8a2d2-a614-5172-814b-b151e76225b6",
    "entry": "頂相",
    "reading": {
      "primary": "ちんぞう",
      "alternatives": [
        "ちょうそう"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "portrait or sculpture of a renowned Zen monk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彫刻１・19サンデー毎日一　欧洲大戦争の当時、彫刻家ロダンが、ロオマへ旅をして、法王の頂相を刻んだことがあつた。",
              "citation": {
                "source": "茶話",
                "author": "昭和五（一九三〇）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの弟子達は、師家の達者なうちにその頂相を残しておきたいものだと思つて、なにがしといふ彫師にそのことを依頼した。",
              "citation": {
                "source": "茶話",
                "author": "昭和五（一九三〇）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上禅宗では頂相を尊ぶので一種特別な禅宗風な高僧の肖像彫刻が随所にのこっている。",
              "citation": {
                "source": "本邦肖像彫刻技法の推移",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "達磨｜頂相、蘆葉達磨など、この図はかなり多く現存している。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
