[
  {
    "uuid": "65d63e78-abeb-5797-b2b7-02d296889873",
    "entry": "珍蔵",
    "reading": {
      "primary": "ちんぞう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
