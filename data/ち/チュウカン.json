[
  {
    "uuid": "be644c6f-29ec-5bcc-a313-88eadc3ce7af",
    "entry": "中巻",
    "reading": {
      "primary": "ちゅうかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "second volume (of three)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "尤も此三十五版と云うのは上巻で、中巻や下巻はもっと版数が少い。",
              "citation": {
                "source": "文士の生活",
                "author": "夏目漱石氏−収入−衣食住−娯楽−趣味−愛憎−日常生活−執筆の前後",
                "note": "青空文庫"
              }
            },
            {
              "text": "世に丸の嘘はないもので、加藤｜咄堂君の『日本風俗志』中巻に、『伊豆日記』を引いていわく、八丈の島人女を恋うても物書かねば文贈らず、小さく作った草履を色々の染糸を添えたる紙にて包み贈る。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとて随分名高かった証拠は近松門左の戯曲『薩摩歌』中巻お蘭比丘尼の詞に「あのおしゃんす事わいの、苦は色替ゆる松風通り、風の吹くように、身にも染まぬ一時恋」。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何に拠ったか知らぬが、当時大いに売れた菊池三渓の『本朝｜虞初新誌』中巻に出でいた。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "中巻は最早日本人を離れて、西洋文を取って来た。",
              "citation": {
                "source": "予が半生の懺悔",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "中巻新来朝五国聯合　バード・ストーン一座大曲馬プログラム　（午後一時開演）（同　五時終了）★１……君が代行進曲　専属音楽団★２……文字を解し、計算し、地図を読む馬　米国理学博士　アスタ・セガンチニ夫人★３……二頭立戦車曲芸　◇第一戦車　〔伊太利〕　ルビヤ・ベルチニ嬢。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "中巻　このプログラムを貰って演技場に這入って行くと、入口に突立っている巡査は古い顔｜馴染であったが、一寸胡散臭そうな眼付きをして私を見送っただけで、横の方を向いてしまった。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "近松の「女殺油地獄」中巻に「五月五日の一夜さを、女の家と言ふぞかし」とあるのも、其を言うたのである。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "日には十日を（古事記中巻）五　七　七五　七　七此は対立した歌である。",
              "citation": {
                "source": "万葉集の解題",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "古事記中巻、応神天皇御製歌に、麻用賀岐許邇加岐多礼、和名鈔容飾具に、黛、和名｜万由須美。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "中巻第一図と第二図とは本所御船蔵を望む両国広小路の雑沓なり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて両国橋納涼の群集と屋形船屋根船の往来（中巻第三図）を見て過れば、第四図は新柳橋に夕立降りそそぎて、艶しき女三人袖吹き払ふ雨風に傘をつぼめ跣足の裾を乱して小走りに急げば、それと行違ひに薄べりと浴衣を冠りし真裸体の男二人雨をついて走る。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "首尾の松の釣船涼しく椎木屋敷の夕蝉（中巻第五図）に秋は早くも立初め、榧寺の高燈籠を望む御馬屋河岸の渡船（中巻第六図）には托鉢の僧二人を真中にして桃太郎のやうなる着物着たる猿廻し、御幣を肩にしたる老婆、風呂敷包背負ひたる女房、物売りの男なぞ乗合ひたり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒形堂の白壁に日脚は傾き、多田薬師の行雁（中巻第七図）に夕暮迫れば、第八図は大川橋の橋袂にて、竹藪茂る小梅の里を望む橋上には行人絡繹たり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから六年に「武士文学の時代」を、八年と十年とに「平民文学の時代」の上巻と中巻とを出した。",
              "citation": {
                "source": "学究生活五十年",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "北越雪譜中巻　終北越雪譜二編　巻三越後塩沢　　　鈴木牧之　　編選江戸　　　　　京山人百樹　増修○　鳥追櫓　農家市中正月の行事に鳥追といふ事あり。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「大菩薩峠」の読者は知っているわけだが、あの大長篇の中巻あたりに、ピグミーと呼ぶ一種の下等動物が出てくる。",
              "citation": {
                "source": "西隣塾記",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
