        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "出かけるとなって庭へおりると、髪があんまりひどいからちょっとなでつけるまで待ってちょうだいと言う。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンケチにいっぱい拾って包んでだいじそうに縛っているから、もうよすかと思うと、今度は「あなたのハンケチも貸してちょうだい」と言う。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆるしてちょうだい。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はマクローにだって衣裳が要るように、あなた妾を労働女にして街に棄てないでちょうだい。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕間はあんた、場内の視聴を妾に貸してちょうだい。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ちょっとこれを待ってちょうだい。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オーセ」は「ちょうだい」という意味であるが、ここの「ホンケ」はこの薬売り自身をさすのではなくて、薬売りの配って歩く広告のビラ紙のことである。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日などはチュンセがくるみの木にのぼって青い実を落していましたら、ポーセが小さな卵形のあたまをぬれたハンケチで包んで、「兄さん、くるみちょうだい。",
              "citation": {
                "source": "手紙　四",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜の直方発の終列車の上りの客車便に……そう……十時五十分に間に合うように大急ぎで荷造りしてちょうだい。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "来ますとも」「どうぞいらしってちょうだいね」　奥さんが……主人の加勢をするように主人には聞こえ、渡瀬を誘惑するように渡瀬には聞こえるそんな調子で。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とも子　じゃ一生懸命で勇気を出して……けど、私がこれっていった人は、いやだなんていわないでちょうだいね。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……戸部　　畜生……とも子　悪口になったら、許してちょうだい。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がいい人を選んでも、どうか怒らないでちょうだいよ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒らないでちょうだいよ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足もと……」「いや若様、雷が参りました節は手前一身におんわざわいをちょうだいいたします。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、もっとそばでよく見てちょうだい。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、それをちょうだい。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほっといてちょうだい」と、おかあさんアヒルは、言いました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、世の中でいちばんきれいなところのお話をしてちょうだい。",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、その中で、おかあさんの子が、いちばんりっぱなことを、見せてちょうだいね。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、あそこへ行って、あの楽器のおねだんをきいてきてちょうだい」　こういうわけで、侍女のひとりが、その中へはいっていかなければならないことになりました。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「じゃ、そっと言ってちょうだい」そこで、侍女は、お姫さまにそっと申しあげました。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしの侍女たちのキスを十でもいいかって、きいてきてちょうだい」「いいえ、ごめんこうむります」と、ブタ飼いは言いました。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、あそこへ行って、あの楽器のおねだんをきいてきてちょうだい。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの男に、こう言ってちょうだい。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ソフィーちゃん、起っきしてちょうだい。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた、お気の毒だけど、今夜は、引出しの中で、がまんしてねんねしてちょうだいね。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、あなたたち、夏になったら、また大きくなって、今よりもっときれいになってちょうだいね」と、イーダちゃんは言いました。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかのものが、ばかばかしいことを、おまえさんに言ってきかせるよりは、そのほうが、よっぽどましさ」「その子を、いじめないでちょうだい」と、ポルトガル奥さんが言いました。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女は強か私を振りもぎって立ち去りかけたが、ちょっと足をとめてふり返って、――もしも、髭がほんとに生えたならば、あなたの窓へ、汽車のシグナルみたいな赤い電気をつけてちょうだい。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
