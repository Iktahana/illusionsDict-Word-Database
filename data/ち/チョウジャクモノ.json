        "examples": {
          "standard": [
            {
              "text": "工場では、長尺物を効率的に運搬するシステムが導入されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この建材は長尺物なので、運搬には特別な注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "倉庫には、長尺物を保管するための専用ラックが設置されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "作品としては特に感心したところはなかつたが、とにかく十何巻かの長尺物を退屈させずに見せたのは相当の腕達者だという印象を受けた。",
              "citation": {
                "source": "人間山中貞雄",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のろんどんは瑕だらけな緩動映画の、しかもやり切れない長尺物だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには女一代の古びたるフィルムの長尺物を感じることさえ出来る。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはどこからうつしたものか、彼と妻君との戯れが長尺物になって、スクリーンの上にうつし出されたではないか！",
              "citation": {
                "source": "蠅",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種の映画としては、思いきった長尺物を作るとして、まず一時間半というところが、極限と思われる。",
              "citation": {
                "source": "映画『人類の歴史』",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
