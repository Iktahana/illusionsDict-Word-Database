    "definitions": [
      {
        "index": 1,
        "gloss": "kettle (used in tea ceremony)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
