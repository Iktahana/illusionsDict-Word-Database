    "definitions": [
      {
        "index": 1,
        "gloss": "everlasting spring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "酒後に英雄多く、死前に豪傑｜少きは、世間の常態なるが、太祖は是れ真豪傑、生きて長春不老の癡想を懐かず、死して万物自然の数理に安んぜんとす。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚ほ長春吉林間、奉天新義州間を往復し、また大連へ還る。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も二三日前から、西伯利亜のトボリスクに幽閉されて居た廃帝の皇女のタチアナ姫が、トボリスクを脱出して、米国へ渡る為に、日本へ向うと云う電報が、ハルピンや長春から二三通来て居ました。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "明くれば一行の外、温泉の若主人塩谷忠氏、画家吉積長春氏加わりて、層雲峡を溯る。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それはその女を主としての話ではなしに、その長春の事務所長をしてゐるＳ氏の話が出た時に、Ｂは画家らしいのんきな調子で、莞爾と笑ひながら言つたのであつた。",
              "citation": {
                "source": "アカシヤの花",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもハルビンも危険だといふので、手に手を取つて松花江の氷の上をわたつて、陸続として長春から吉林の方へ入つて来たのださうですが、それは惨めなものだつたさうです。",
              "citation": {
                "source": "一少女",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あれで、あゝいふ人達も、皆な身分のあるやうな人なんですから……』　一緒に長春からやつて来たＩさんは言ひました。",
              "citation": {
                "source": "一少女",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十六年四月八日於東京　　石原莞爾第一篇　戦争史大観昭和四年七月長春に於ける講話要領昭和十三年五月新京に於て訂正昭和十五年一月京都に於て修正第一　緒論一　戦争の進化は人類一般文化の発達と歩調を一にす。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "演習第一日は車中で研究を行ない長春に着いた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の垣根には長春が燃えるように紅い色の花を垂れている。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "（活気づいて高声に読み続ける）「因に東清鉄道会社は、翌二十二日のため長春ハルビン間に特別列車を用意したり。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "長春からハルビンまでの特別列車？",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の晩か明後日の朝、出迎えの特別列車がハルビンから長春へ向って出発する。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "東清鉄道長春ハルビン間の特別列車、食堂車内。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「長春」　のりかえ。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "「明治四十二年十月二十六日午前八時、元勲伊藤公の坐乗せる特別列車は、長春より一路｜哈爾賓をさして急ぎつつあった。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月二十五日発｜奉天赴長春汽車中作万里平原南満洲　　風光潤遠一天秋当年戦跡留余憤　　更使行人牽暗愁「日露の親和がこの汽車中にはじまり、汽車の前進するがごとくますます進展せんことを望む。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "長春は新京と名を改め、今は「満州国」の首府である。",
              "citation": {
                "source": "ドン・バス炭坑区の「労働宮」",
                "author": "――ソヴェト同盟の労働者はどんな文化設備をもっているか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」長春水｜惟完を広島に見、仲春風惟疆を長崎に見、季杏坪｜惟柔を江戸に見たのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "是は素榛軒の祖父｜信階の師武田長春院の家に伝へてゐた物であつたが、武田氏は家道漸く衰へて、これを商賈の手に委ねむとした。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハルピンや、長春、奉天、撫順、金州、三十里堡、青島、上海、南京、杭州、蘇州、これだけを約二ヶ月でまわって、放浪記の印税はみんなつかい果たして、上落合の小さい家に帰って来た。",
              "citation": {
                "source": "落合町山川記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五銭のレモンティを呑みながら、見当もつかない茫々とした遠い道筋の事を考へたのですが、――「此間満鉄の社員が一人、ハルピンと長春との間で列車から引きずり降ろされて今だに不明なんですがね」とか、「チチハルの領事が惨殺されたさうですよ」なぞと、奉天通過の時の列車中の話です。",
              "citation": {
                "source": "シベリヤの三等列車",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝだけでも二等にされた方が良いと云ふ言葉をすなほに受けて、長春ハルピン間を二等の寝台に換へました。",
              "citation": {
                "source": "シベリヤの三等列車",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マアルシユカ、ナタアシヤなどの冠りもの稀に色めく寛城子かな　寛城子は長春のロシヤ側の駅名で今日ではとうにそんな駅はあるまいが、当時でも随分なさびれ方であつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処にもアンペラ小屋のものもあるが、戦禍による半壊の家屋を使用してる者が多いのは幸で、世帯整理もよく行届き、長春里第×号などと洒落た名称がついている。",
              "citation": {
                "source": "上海の渋面",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "また像を掩うて今は落葉して居る一｜樹の長春藤が枝を垂れて居た。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長春から来て哈爾賓で後へ二つ繋がれた客車の人をも交ぜて三十人余りの女の中で此婦人が出色の人である。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此地で邦人の経営してゐる満洲製粉会社は、原料の小麦に富んでゐるので最も有望な特産工業として知られ、長春、哈爾賓、済南、奉天、鎮南浦等に工場を持つてゐる相である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "その更に向ふは茫茫たる吉林省の曠原となり、浦塩斯徳に向ふ東支鉄道が東走し、長春に赴いて満鉄本線に連続する東支鉄道が南走してゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　今日佐藤惣之助さんが一日先に立つて長春へ引返された。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
