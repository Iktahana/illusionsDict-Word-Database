        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "郊外の安文化住宅で、新婚の若夫婦がいちゃつくという意味ではない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "行って見て来いってうわけでバキチが剣をがちゃつかせ、耕牧舎へやって来たでしょう。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　画かきはにわかにまじめになって、赤だの白だのぐちゃぐちゃついた汚ない絵の具｜箱をかついで、さっさと林の中にはいりました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「国手、お前んはまた毎晩のように、蛇が蟠を巻いておる上で、お孝といちゃついてござる勘定だ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "百人のうち九十九人の女は、私がかれらに飽きたら、かれらもまた私に飽きるであろうし、百人のうち七十五人までは、他の男と無遠慮に、盛んにいちゃついて、私に復讐するであろう。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間若い者のいちゃつくのを見てなんかおれるもんですか。",
              "citation": {
                "source": "祭の夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "△洋服をぬぎ、洋服かけがちゃつく。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ベロヴゾーロフは、サーベルをがちゃつかせて、まっしぐらにそのあとを追った。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖炉の横に赤い帽子を被った士官が何かしきりに話しながら折々｜佩剣をがちゃつかせている。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく世話して、喧嘩でもしちゃつまらないから。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの身｜代を人に取られちゃつまらないよ」「作の馬鹿はどんな顔している」お島は車のうえから笑った。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの身代を人に取られちゃつまらないよ」「作の馬鹿はどんな顔している」お島は車のうえから笑った。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその二階は図書室と学長室などがあって、太いズボンをつけた外山さんが、鍵をがちゃつかしながら、よく学長室に出入せられるのを見た。",
              "citation": {
                "source": "明治二十四、五年頃の東京文科大学選科",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「薄暗い隅っこで若僧といちゃついてる！",
              "citation": {
                "source": "「インガ」",
                "author": "――ソヴェト文学に現れた婦人の生活――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、勝手にしろよ、家へ帰って女房とさんざいちゃつくがいいや、助平野郎め！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "『忌々しいが、女にいちゃつくのは暫らく待とう！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "こまかい節まわしのところはうまく行かなくて笑声混りにごちゃつきながら、終りの　　おお　　われら　若い者――　　われら　若い者という反覆句になると、それまではひょろひょろしながらついていた声も急に目の醒めたような心からの力で、　　おお　　われら　若い者と声を揃えて歌い切るのである。",
              "citation": {
                "source": "広場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の、食事中にはネクタイをきちんと結べ、フォオクをがちゃつかすな、スウプを飲むのに音を立てるな、頭髪に手を触れるな、といった食卓作法も、まだ出発して一週間にならない、あの頃はよく守られていました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "練習場の入口におしよせる観衆のなかから、唇と頬の真ッ紅な、職業女を呼びだして、近くの芝生でいちゃついていた、外国の選手達もみました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "巣を、只ねる場所として居る処、落付いて居る処、あまり雌雄でもいちゃつかない処。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――相手とのいちゃつきがすむと、それがないと、現在に、心的な不満、最善でない、と云う反省が湧く。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "女といちゃつきたい時は西洋風を持ち出すし。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると寺尾は真面目な顔をして、戦争は何時でもするが、日露戦争後の日本の様に往生しちゃつまらんじゃないか。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはこう考えて何か云おうかなと考えてみたが、云うなら人を驚ろすかように滔々と述べたてなくっちゃつまらない、おれの癖として、腹が立ったときに口をきくと、二言か三言で必ず行き塞ってしまう。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
