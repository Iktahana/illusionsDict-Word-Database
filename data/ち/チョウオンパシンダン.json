        "examples": {
          "standard": [
            {
              "text": "病変の早期発見には、迅速な超音波診断が不可欠です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "超音波診断装置の進歩により、より高精度な診断が可能になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この画像、超音波診断で何か異常が見つかったんですか？」と患者は不安そうに尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "こうした発想から、大内はソナーという軍需技術を超音波診断装置という医療用機器に転用することを目指した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り返ればそれも、海軍時代に携わった音波探知機の技術を、超音波診断という命を守る側に生かせると心から信じることができ、日本電気にとってもメディカルエレクトロニクス分野の開拓が大きな意味を持つと確信できたからこそだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
