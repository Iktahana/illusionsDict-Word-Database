    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to make fun of",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分という馬鹿者が、この二人のあいだにはいって、いまに二人を滅茶苦茶にするのだ。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "多芸も多芸であったが、こういう世間を茶にする真似もした。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この浮世三分五厘と脂下って世間を茶にする江戸作者の洒落な風は江戸の文化に親しむものの大部分が浸染していたので、強ち硯友社のみに限らなかった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「紅子戯語」には当時の硯友社の生活が活けるが如くに描かれ、幹部の八人の風が活き活きとして、若い花やかな世間を茶にする気分が全幅に漂うておる。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘ッたるい恋物語で食もたれしている処へ三唖の人を茶にする三馬式の軽い滑稽は餅菓子のあとへ塩煎餅を出したようなもので、三唖の処女作はかなりに受けた。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一代の奇才は死の瞬間までも世間を茶にする用意を失わなかったが、一人の友人の見舞うものもない終焉は極めて淋しかった。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を茶にするにもほどがあらあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を茶にするにもほどがあらあ、だから、ひとり者をいつまでもひとりで寝かしておきたかねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは兼輔の晴れの直衣をあたら揉み苦茶にするほどに、袖や袂を遠慮なしに掴んで小突きまわして、さあ白状しろと責めさいなんだ。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『君は何時も人の話を茶にする。",
              "citation": {
                "source": "漂泊",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『君は何時でも人の話を茶にする。",
              "citation": {
                "source": "漂泊",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、自分を茶にするのだと取る。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の道徳的な考えを滅茶滅茶にする丈、強い力はどこにも見つかりそうにもない。",
              "citation": {
                "source": "「禰宜様宮田」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その波が高まると、よく彼は「人間が人間を揉み苦茶にする」と悲鳴をあげた。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫れは何歳の娘が妙な事を念じて居るなどゝ、唯それを見るのが面白くて毎度｜遣た事だが、兎に角に人の一心を籠めた祈願を無茶苦茶にするとは罪の深いことだ。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "家と云うものの為に、人一人を滅茶にするのは大間違だと云い乍ら、とりは娘にそれを期待して居る。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、自分を茶にするのだと取る。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化文政の岡場所が衰えても、この時代の柳橋は、それほど江戸っ児の風流を無茶にするものではありませんでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、婚礼の式には来客に茶を出さざるは、人を茶にするということの連合よりきたり、客の帰り去るを御帰りといわずして「御開き」というは、連想上帰るの意を避け、客の帰るを見送りせざるも同意なるべし。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一つは、人を茶にするということからも嫌われる。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘三人の心持を滅茶滅茶にするより、いつまでも独り者の八五郎の方が立派さ」「その気で付き合って下さい、親分」「ハッハッ、これで、八の嫁話も当分｜沙汰止みか」「有馬屋の親娘は憎いじゃありませんか」　八五郎はまだ憤々しております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "縁結び",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥などは附いちや居ないぜ」　平次は何處までこの話を茶にする氣でせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女護の島異變",
                "note": "青空文庫"
              }
            },
            {
              "text": "左半面しか見せない女は、――雪を払うた庭石の上に立って、雪見灯籠にもたれたまま、凍え死にかけて居るにも拘らず、その曲線の美しさを燃焼させて、宗三郎の理性を滅茶滅茶にするだけの力はあったのです。",
              "citation": {
                "source": "猟色の果",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は伸子たちの室で、お茶にすることになった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれやれ、私は昨日も一昨日も来たのに、絵を描きに写生に行ってるとかって、たんびに無駄足ばかりさせられて、ホントにまあ、絵だか屁だか知らんけど、しとを茶にするのもいいかげんにして下さいよ。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の先まで、口小言を言いながらも、極めて熱心忠実に洗濯をしていたものが、いくら短気だとはいえ、癇癪まぎれにおっぽり出して、それで命ぜられて、或いは頼まれて引受けた約束を無茶にすることほど、米友の短気は没義道な短気ではないはずです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "『タンホイザーの序曲』をピアノで弾いて、「ああお手々がくたびれた」といった恰好をして見せたモイセヴィッチのように、私はあまり愉快でない技巧家を見せつけられて、がっかりするばかりでなく、折角レコードを通して築き上げたフォイアマンに対するイリュージョンを、滅茶滅茶にするのではあるまいかと惧れたのである。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "神社の庭には天狗がおもちゃにするというまさかり、かま、太刀などが、散乱している。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生をおもちゃにする気は毛頭ありません。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッチのペーパーや広告の散らし紙や、女の子のおもちゃにするおすべ紙や、あらゆるそう云った色刷のどれかを想い出させるような片々が見出されて来た。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
