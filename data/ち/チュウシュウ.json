    "definitions": [
      {
        "index": 1,
        "gloss": "15th day of the 8th lunar month",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "空には中秋の月が冴えて、氷のような月光が独り地上を照らしている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、結局高い澄み切った青空の下で北欧の中秋の好晴の日は静粛な午後を保っていた。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく十年の中秋の豪雨は坪当り一石三斗で、この時もほとんど流しかけた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中秋の或る快晴の日の午後、景子は友人の某大学英文科の助教授宮坂を案内して彼がしきりに逢いたがって居た此の国の文学者ジョン・ガルスワーシー邸を訪ねて行った。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つくつくほふしが啼き、中秋のものあはれさが、そこらここらに涼しく動いた。",
              "citation": {
                "source": "竹林生活",
                "author": "――震災手記断片――",
                "note": "青空文庫"
              }
            },
            {
              "text": "図らざりき身事忙促として、空しく中秋の好時節を紅塵万丈の裡に過さんとは。",
              "citation": {
                "source": "秋窓雑記",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど秋の夜で、中秋の月が綺麗であるから、李汾は庭前を歩いた後に、琴を弾いていると、外の方で琴に感心しているような人の声がした。",
              "citation": {
                "source": "豕",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣　稟鴉は木に眠り豆は莢の中秋の日の眞實丘の畑きんいろ。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣稟鴉は木に眠り豆は莢の中秋の日の眞實丘の畑きんいろ。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜が中秋であったという月夜空、雲がぐんぐんと動いていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るい月が出て、今日が中秋の十五夜であることに源氏は気がついた。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "いぶかりながら裏へ回ってみると、中秋九日の夕月がちょうど上って、隅田の川は足もとにきらめく月光をあびながら、その川の上へぬっと枝葉を突き出している大川名代の首尾の松までがくっきりとひと目でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十歳ぐらいの主人がにこにこしながらはいって来て、今夜は中秋であるから皆さんを招待したいという。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして陰暦の中秋などは我々の関知する所でなかったが、二、三日前から宿の雇人らが遼陽城内へしばしば買物に出てゆく。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが中秋の月を祭る用意であることを知って、もう十五夜が来るのかと私たちも初めて気がついた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに申し分のない中秋である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから私たちを母屋へ招じ入れて、中秋の宴を開くことになったが、案の如くに種々の御馳走が出た。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたは大金持だが、惜しいことにはこの中秋の前後三日のうちに寿命が終る」　それを聞いて、商人はひどくおそれた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "輟耕録",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十年九月、古中秋無月の夕岡本綺堂",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "凡例",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十七年中秋伊波普猷",
              "citation": {
                "source": "「古琉球」改版に際して",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "中秋近い頃には、大内裏で歌會や詩會があつたりして、兼家は忙しさうにあちこちと出かけたが、それでも大抵はちつとでも來てかの女を見舞ふことを例にしてゐた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十歳ぐらいの主人がにこにこしながら這入って来て、今夜は中秋であるから皆さんを招待したいという。",
              "citation": {
                "source": "はなしの話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに申分のない中秋である。",
              "citation": {
                "source": "はなしの話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝる夜の月も見にけり野辺送り　これは俳人去来が中秋名月の夜に、甥の柩を送った時の句である。",
              "citation": {
                "source": "正月の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅葉見え滝見える茶屋の床几かな紅葉出て落ちこむ滝や霧の中秋の山滝を残して紅葉かななど中々にいふだけが蛇足なり。",
              "citation": {
                "source": "日光の紅葉",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中秋後一夕、陪茶山先生、歩月茗渓、途値臼田才佐、遂同到礫川、賞咏至夜半」と云ふのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日には蘭軒が「中秋思郷」の七絶を作つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
