[
  {
    "uuid": "ad06401f-68ea-56b6-af2a-0c57a8fd2691",
    "entry": "陳皮",
    "reading": {
      "primary": "ちんぴ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
