[
  {
    "uuid": "a974b7e9-e37f-5c3e-9046-3e17a317a01c",
    "entry": "ちゃん",
    "reading": {
      "primary": "ちゃん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接尾辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "suffix for familiar person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「罪と罰」でも、「田園交響楽」でも、「阿部一族」でも、ちゃんと映画になっている様子だ。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでなくて、自分の哲学的思想体系を、ちゃんと腹に収めてからでなければ、どんな行動も起し得ない種類の人間も、たくさんあることと思う。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんと知っていたのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙の中にちゃんと書かれてあるのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいえ、菊ちゃんにはかないません」私は固くなって、へんな応えかたをした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "叙述でもなし、会話でもなし、描写でもなし、どうも不思議な、それでいてちゃんと独立している無気味な文体。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、私は馬場との約束どおり、午後の四時頃、上野公園の菊ちゃんの甘酒屋を訪れたのであるが、馬場は紺飛白の単衣に小倉の袴という維新風俗で赤毛氈の縁台に腰かけて私を待っていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場の足もとに、真赤な麻の葉模様の帯をしめ白い花の簪をつけた菊ちゃんが、お給仕の塗盆を持って丸く蹲って馬場の顔をふり仰いだまま、みじろぎもせずじっとしていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が近づいていって、やあ、と馬場に声をかけたら、菊ちゃんが、あ、と小さく叫んで飛びあがり、ふりむいて私に白い歯を見せて挨拶したが、みるみる豊かな頬をあかくした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思わず口を滑らせたら、菊ちゃんは一瞬はっと表情をかえて妙にまじめな眼つきで私の顔を見つめたかと思うと、くるっと私に背をむけお盆で顔をかくすようにして店の奥へ駈けこんでいったものだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "罵るなら、ちゃんと罵るがいい」「からかってやしないよ」しずかにそう応えて、胸のポケットからむらさき色のハンケチをとり出し、頸のまわりの汗をのろのろ拭きはじめた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊ちゃん、ビイルをおくれ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊ちゃんだけを好きなんだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川のむこうにいた女よりさきに菊ちゃんを見て知っていたような気もするのです」「まあ、いい」馬場はそう呟いて微笑んでみせたが、いきなり左手で顔をひたと覆って、嗚咽をはじめた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野次郎氏と遊びたくてせっせとこれだけこしらえたのだが」「僕におくれ」「いいとも」「菊ちゃん。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だって、いつまでも上品な坊ちゃんではおられない。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこの家で生れた日の事を、ちゃんと皆が知っているのである。",
              "citation": {
                "source": "六月十九日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん御拝の長かったは母上で、いちばん神様の御気に召したかと思われるはせいちゃんのであった。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうですかせいちゃんは、神様の前で御膝を出して。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父上のいくさの話が出て子供等が急におとなしくなったと思うたら、小さいのとせいちゃんは姉上の膝の上ではや寝てしまった。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ生れのＯ夫人がちゃんと時刻をたがえずやって来て一つの鍋のロースを日本の箸ではさんでいた。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野へ入れば往来の人ようやくしげく、ステッキ引きずる書生の群あれば盛装せる御嬢様坊ちゃん方をはじめ、自転車はしらして得意気なる人、動物園の前に大口あいて立つ田舎漢、乗車をすゝむる人力、イラッシャイを叫ぶ茶店の女など並ぶるは管なり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく幼少なる「加八」君はここでそのありたけの深謀をちゃんちゃんこの裏にめぐらして最後の狙いを定めて「ズドーン」と云って火蓋を切る真似をする。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "重兵衛さんの家は維新前にはちゃんとした店をもった商人であったらしいが、自分の近づきになった頃はいわゆる「仲持」すなわち、今の土地家屋売買周旋業と云ったような商売で、口と足とさえ働かしておれば自然に懐中に金の這入って来る種類の職業であったらしい。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ覚えているのは、丑尾さんが着古した袖無のちゃんちゃんを着て、頭を小ちゃなおちごに結っていたことと、それから、その日の小春の日影が実にうららかに暖かくのどかであったということだけである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしよく見るとそういうのでも、どこかちゃんと一つの全体を形作って一人の作者のある時期の心の世界の断面を見るような気がすることもしばしばあります。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに俺に食ってかかったって、仕方がないじゃないか、な、ちゃんと嘆願さえすれば、船長だって涙金位寄越さないものでもないんだ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「父ちゃん、いやだよ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
