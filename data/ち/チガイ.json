[
  {
    "uuid": "380d778c-8354-5bfe-813a-4416409a2e2b",
    "entry": "違い",
    "reading": {
      "primary": "ちがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
