        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「じゃあいくら買って来るの」「ちゃぶ台の脚のところに五銭ころがっている。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "船はちゃんころでも炭薪ゃ積まぬというのが唄にもある。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ちゃんころ）　ホージャ！",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ちゃんころ）」と、囃したててはねまわっている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
