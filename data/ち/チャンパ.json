    "definitions": [
      {
        "index": 1,
        "gloss": "Champa (former kingdom(s) in central Vietnam)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "元来、チャボは占城国とかから渡ったもので舶来種だが、この鶏は舶来なんですかね。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "矮鶏のモデルを探したはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく支那の四圍を見渡すと、西のチベット人、北の蒙古人、東の朝鮮人、南の安南、占城諸國民の間にも、嘗て Cannibalism の行はれた證跡歴然たるものがある。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "占城即ち占婆 Champa にも、アラブ商人が多く假寓して居つた樣である。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "『宋史』外國傳に據ると、五代の周の世宗の顯徳年間（西暦九五四―九五九）に、占城國の使者訶散の名もアラブ人で、Abul Hassan の音譯らしい。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はもと占城の貴人であるが、中國に滯留して、その國の貿易事務を管掌することとなつた。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "岳珂は蒲姓を占城の人と記して居るが、上に述べた如く、當時占城にアラブ商人の假寓した者が尠くない筈故、この蒲姓ももと占城に僑居したアラブ商人と認むべきであらう。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "その直接又は間接の結果として、占城 Chamnpa、馬八兒 〔Ma^bar〕 の二國先づ通商を開き、引續きその他の南海諸國も之にならひ、元一代の外國貿易も亦かなり盛況を極めて居る。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日も妙な着物を着ているから、それは何だねと訊いて見ると、占城という物だと答えるじゃないか？",
              "citation": {
                "source": "一夕話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の友だち多しといえども、占城なぞという着物を着ているものは、若槻を除いては一人もあるまい。",
              "citation": {
                "source": "一夕話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮫は占城の結構なところ、柄糸は煮紺三分に巻き揚げ立派な物でございます。",
              "citation": {
                "source": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "author": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の内で一六〇八年にチャムパ（占城）へ行った有馬晴信の船は、帰途マカオに滞留して事件を起した。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めもしやそれは諸方に多いケシ科のタケニグサすなわちチャンパギク（博落廻）ではないだろうかと想像してみた。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで一行は一二九二年の初め四本マストの十三艘の船に乗り、マンジ（Manzi 南シナ）の海を渡って、チャンパに着き、更にシャムを経てピンタン島に達した。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "前二者はインド経由でシナに来り、北京で教会を建設・経営しているが、中でもオデリコは、スマトラ、ジャバ、ボルネオ、チャンパを経て広東に達し、マルコ・ポーロの描いた Zayton, Quinsay や南京などを通って北京に来たのである。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処も危い危いと云って二階へ上ると、今度は電球と云う電球がパチャンパチャン割れる。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　字引を引いて見るとこの草の本名チャンパギク、博落廻とあるのが我々を考えさせる。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら本名でもチャンパギクでは歌にならぬということが、偶然ながらも我々に大きな暗示を与えている。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆるチャンパ菊の異名を知った土地はあまり多くない。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャンパ菊の異名に今一つ、辞書にも認められたササヤキグサというのがある。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
