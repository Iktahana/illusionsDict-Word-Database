        "examples": {
          "standard": [
            {
              "text": "フロイトの理論によれば、超自我は道徳的な規範を内面化したものである。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の行動は、強い超自我に律されているため、常に正しいとされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "時には、超自我の束縛から解放され、自由な発想をすることも大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "眞に深く眠つてしまへば、人はもはや意識を失ひ、或る超自我の生命支配者がするところの、勝手な法則に夢を委ねなければならなくなる。",
              "citation": {
                "source": "夢",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
