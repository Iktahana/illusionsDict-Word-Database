        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "文章も実に珍無類だ。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そして君の甲虫というのが、もしこれに似てるのなら、それこそ珍無類の甲虫にちがいない。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋軒は、また、その日も、珍無類なお客を迎えた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実が既に珍無類だから、説明も亦珍無類である。",
              "citation": {
                "source": "露都雑記",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　たしかにそれは、まったく思いもよらぬ、またどの点から見ても珍無類な断案であった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱海の間歇温泉ではないが、この、珍無類夫妻の間には、間歇的に例の無言の闘争が始まるのだった。",
              "citation": {
                "source": "遠藤（岩野）清子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "失恋した笛吹川画伯の様子は珍無類でした。",
              "citation": {
                "source": "赤耀館事件の真相",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "よオし、なんとしても追いついてやるんだ」　帆村の姿と来たら、実にもう珍無類だった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが戦国時代に生れて奇妙に衆に押されて前面へでて、最後にはファッショの御大のやうなクーデタをやらざるを得なくなつたから何とも珍無類な古狸の化けそこなひのやうな不手際な天下のとり方をしたのである。",
              "citation": {
                "source": "家康",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "書くのは厭だと言ふのだが、これが又、珍無類の人物で、育ちが良いのかも知れん、大井広介に似て、より純粋で、珍妙で、底ぬけで、目下稲垣足穂にころがりこまれて、同じ屋根の下にゐるさうだが、彼は何一つ持たんです、と云ふ。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとも珍無類なものであった。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "書くのは厭だと言うのだが、これが又、珍無類の人物で、育ちが良いのかも知れん、大井広介に似て、より純粋で、珍妙で、底ぬけで、目下｜稲垣足穂にころがりこまれて、同じ屋根の下にいるそうだが、彼は何一つ持たんです、と云う。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代えて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その有様が、おのずから珍無類の滑稽になっているのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペストのように避けて通る――ローマ浴場の廃址、「若干のいい画を蔵する」博物館、珍無類の彫刻、ファサアドが、何百何年とやらに造られ、大祭壇がなんとやらの教会堂。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、私の代になると、家内の実家の鳥取米子流にしてもよかつたのを、強いて習慣に拘泥しないわれわれ一流のやり方で、関東、関西をチャンポンにし、時には中国式や欧米風を交えた、珍無類の料理を正月の膳にのせた。",
              "citation": {
                "source": "時　処　人",
                "author": "――年頭雑感――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分ひとりで読むのは勿体ないやうな、珍無類なラヴレタアだから、参考のために是非読んでおけと云つて、それを奥から持ち出して来た。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "うん、さう云へば、島にゐる間に、ちよつと珍無類な光景をみたよ。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮ごと竪に二つに割って、横に薄く切り、醤油を滴らして食うと、酒の肴に珍無類、仙気を帯びた異味となる。",
              "citation": {
                "source": "九年母",
                "author": "青木正児",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おじさまの子なら、似ているに決っている、人間の顔をした珍無類の金魚でございと、触れこんだら慾張りの金魚屋のお爺ちゃんがね、息せき切って買いに来るかもわからないわ。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが戦国時代に生れて奇妙に衆に押されて前面へでて、最後にはファッショの御大のようなクーデタをやらざるを得なくなったから何とも珍無類な古狸の化けそこないのような不手際な天下のとり方をしたのである。",
              "citation": {
                "source": "家康",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "此好奇心に刺戟せられて、空想に空想を重ね、遂に珍無類の形を創造する。",
              "citation": {
                "source": "妖怪研究",
                "author": "伊東忠太",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがまた珍無類である。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを水に投げ込むと亀の子が競泳を始め、何度も何度もパクンパクンやってはそれを遠くに投げ、それが水びたしになるか、池の辺をなす石垣へ押しつけられるかに至って、すぐさま破壊されて食い尽されるその光景は、実に珍無類である（図689）。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
