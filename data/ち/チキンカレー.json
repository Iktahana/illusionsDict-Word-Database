          "literary": [
            {
              "text": "リリーが何か食べたいというので、入って、私のためにはチキンカレー、リリーのためには、焼そばと卵のスープを取った。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひる終って、上野永藤まで食事しに行く、ビフテキとチキンカレー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "プルニエで食事、ポタージュに舌平目洋酒蒸、チキンカレーライス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ前のカティへ入り、チキンカレー（百五十円）を食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
