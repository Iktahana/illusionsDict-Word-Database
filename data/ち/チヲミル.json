    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to come to bloodshed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あの人がまた、血を見ると癲癇を起すくらい臆病だからね。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘はほのおが消えないように、そのまわりに手をかざしていましたから、わたしはかぼそい指の中の、いきいきとした赤い血を見ることができました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスケットの、蔦の血を見るにつけても、青い呼吸をついてぐったりした。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと臆病な丹造は、支店長の顔を見るなりぶるぶるふるえていたが、鼻血を見るが早いか、あっと叫んで、小柄の一徳、相手の股をくぐるようにして、跣足のまま逃げてしまい、二日居所をくらましていた……。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしが声をあげると、雑用夫も戻ってきたんですが、血を見ると卒倒寸前で。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "血を見ると猩々の怒りは狂気のようになった。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "血を見ることを恐れるおれではないと思いながらも、八橋を切ることは次郎左衛門に取って一生で一度のおそろしい仕事であった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い間の血を見る程な悪戦苦闘も皇后を一瞥しただけで容易に報いられた。",
              "citation": {
                "source": "闘戦勝仏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、同じ時代の他の作家の作と比べて決して見劣りしなかったが、己れの疵瑕を感ずるに余りに鋭敏な作者は、丁度神経過敏家が卯の毛で突いたほどの負傷でも血を見ると直ぐ気絶するように、自分の作が意に満たないと坐ても起ってもいられなかったらしい。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は、血を見ると、一種の陶酔から覚めて命が惜しくなったらしく、急に悲鳴を挙げながら逃げ出した。",
              "citation": {
                "source": "恩を返す話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、一旦血を見ると、市九郎の心は、たちまちに変っていた。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "胆を以て、腕を以て、あの向う傷に物を言わせて、力ずくにこれを押し破ったならば破って破れないことはないが、そのため怪我人を出し、血を見るような事になったら、他の猪勇に逸る旗本なら格別、わが早乙女主水之介には出来ないのです。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "御具足櫃に血を見るはおめでたい。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の血を見る事を恐れず明暮れを只争闘と罪悪に暮して悔ゆる所のない哀れな不具な心を持ったものどもでも、一度若しこの美くしさをしみじみと感じたならば、悔いと安心の涙にむせびながら尊い美を感謝するに違いない――――と。",
              "citation": {
                "source": "繊細な美の観賞と云う事について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、鮮かな一筋の血を見ると、忽ち胸が嘔氣を催す樣にムッとして、目が眩んだのだから、阿母さんの顏の見えたも不思議な位。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、鮮かな一筋の血を見ると、忽ち胸が嘔気を催す様にムツとして、目が眩んだのだから、阿母さんの顔の見えたも不思議な位。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "サヂズムを持った人間は、通常血を見ることを非常に好むといわれて居りますが、私は特に血を見ることを好むというほどではありませんでした。",
              "citation": {
                "source": "三つの痣",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "血を見ると、腰から脹脛にかけての神經がざわざわして來るのが駿介の平常だつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "フリードリヒ大王は、最初は当時の風潮に反して会戦を相当に使ったのでありますが、さすがのフリードリヒ大王も、多く血を見る会戦では戦争の運命を決定しかね、遂に機動主義に傾いて来たのであります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三は血を見るのもいやだったし、寄って行くのに気が差して、わざと次ぎの部屋に立っていたが、すっかり支度のできた博士が、駄々ッ児の子供をでも見るような、頬笑みをたたえて手術台に寄って行くと、メスの冷たい閃光でも感じたらしい葉子は、にわかに居直ったような悪戯な調子で叫ぶのであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして初めて我に返つた鍛冶屋は其処に倒れてゐる彦七の顔を流れてゐる血を見ると、呆然として大地に座り込んでしまつたのでした。",
              "citation": {
                "source": "火つけ彦七",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は少年の時から至極元気の宜い男で、時として大言壮語したことも多いが、天禀気の弱い性質で、殺生が嫌い、人の血を見ることが大嫌い。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "八郎太は畳みかけて「牧の修法か」　二人は「如何にも――それを知って通るとあらば、血を見るぞ」　と、叫んだ瞬間、杉木立に、谷間に、山肌に木魂して「ええいっ」　小太郎の腰が、少し低くなって、左脚が、後方へ――きらっと、閃いた白刃は、対手を打つか、打たぬかに、小太郎の頭上で、八相に構えられていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "……彼はどうかした機會に、血を見ると、それが自分のであらうと、他人のであらうと、すぐ腦貧血を起してしまふ癖があつた。",
              "citation": {
                "source": "恢復期",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……抜けば必ず血を見る長船！",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今は血を見る事をお嫌いなさるが、其の頃は動ともすれば血判だの、迚も立行が出来んから切腹致すの、武士道が相立たん自殺致すなどと申したもので、寺島松蔭｜等の反逆も悉皆下組の相談が出来て、明和の四年に相成りました。",
              "citation": {
                "source": "菊模様皿山奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は窮乏のドン底時代だから、その数が多く、かつ、戦争という悪夢の中で生育して冷酷さに無感動となったために、いらざる血を見る事件がふえた。",
              "citation": {
                "source": "帝銀事件を論ず",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジム、」と私に向って、「君は血を見るのが怖いかね？",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "さびしい花やかな燈火の奧にふしぎな性の悶えをかんじて重たい翼をばたばたさせるかすてらのやうな蛾をみるあはれな　孤獨の　あこがれきつたいのちをみる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちがこっちをみる。",
              "citation": {
                "source": "従妹への手紙",
                "author": "――「子供の家」の物語――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
