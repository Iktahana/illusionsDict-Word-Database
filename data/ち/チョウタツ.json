[
  {
    "uuid": "d9e7e2f5-b718-5173-9ff4-e079dde24d35",
    "entry": "調達",
    "reading": {
      "primary": "ちょうたつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
