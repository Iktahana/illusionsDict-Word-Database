        "examples": {
          "standard": [
            {
              "text": "パラシュート降下の訓練では、指定された着陸地帯に正確に降りることが求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "探査機が着陸地帯の地形を詳細に調査し、最適な着地点を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "敵の目を欺くため、部隊は秘密裏に着陸地帯を確保した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして火星の表面に着陸地帯として、もってこいの平らな砂漠を探しあてると、一気にそれへまい下ったのであった。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
