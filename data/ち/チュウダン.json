[
  {
    "uuid": "9fbe7a15-509e-5aab-bf6b-06c860a3be38",
    "entry": "中断",
    "reading": {
      "primary": "ちゅうだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
