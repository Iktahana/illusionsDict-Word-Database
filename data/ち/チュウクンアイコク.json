[
  {
    "uuid": "4fdddd07-29d7-52d7-b1a0-c9f90909ff55",
    "entry": "忠君愛国",
    "reading": {
      "primary": "ちゅうくんあいこく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
