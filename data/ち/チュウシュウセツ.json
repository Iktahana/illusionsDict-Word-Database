          "literary": [
            {
              "text": "第六章　中興から末路へ　阿Ｑが再び未荘に現われた時はその年の中秋節が過ぎ去ったばかりの時だ。",
              "citation": {
                "source": "阿Ｑ正伝",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおかた中秋節の二三日前だったろうと思う。",
              "citation": {
                "source": "孔乙己",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "中秋節が過ぎてから、風は日増しに涼しくなり、みるみるうちに初冬も近づいた。",
              "citation": {
                "source": "孔乙己",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ十九銭貸しがある」　中秋節にはもうなんにも言わなくなった。",
              "citation": {
                "source": "孔乙己",
                "author": "魯迅",
                "note": "青空文庫"
              }
            }
          ]
        }
