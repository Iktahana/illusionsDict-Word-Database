    },
    "definitions": [
      {
        "index": 1,
        "gloss": "teak (Tectona grandis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（一九二三ヽ八ヽ一ヽ）津軽海峡夏の稀薄から却って玉髄の雲が凍える亜鉛張りの浪は白光の水平線から続き新らしく潮で洗ったチークの甲板の上をみんなはぞろぞろ行ったり来たりする。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはサディが云った通り室の端れに――グロテスクなチーク材の彫像が立っていた。",
              "citation": {
                "source": "赤い手",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日に二度発行、十頁、オムスク鉄道バラビンスキー停車場内鉄道従業員組合ウチーク・そこが編輯所である。",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "チーク材の床には敷物もなかつたが、かへつて涼しさうだつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "チークダンス　チークダンスの実況写真が某紙にスッパ抜かれて、ダンスのタイハイこゝに至る、ホール業者、ダンス教師、御愛好の男女代表、ダンサー、文部省、警視庁、御歴々が御参集あって協議あらせられたとある。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この写真に見参するまで、私はもっぱらカストリなどにかゝりきっていて、チークダンスという言葉も知らなかった。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "チークダンスは、ダンスを踊って交合の低さとワイセツでしかない。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり我々の多くが、男女関係というと、チークダンスのようなことにしか主点がない。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "表向きは亭主関白とオサンドンとの関係であり、裏面ではチークダンスの関係である。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "チークダンス愛好家は悪趣味、無教養というだけのことであるから、その対策はフンジバルこととは別だろうと私は思う。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "立派な革椅子に、チーク材の卓子など、すこぶる上等な家具が並んでいて、床を蔽う絨氈は地が緋色で、黒い線で模様がついていた。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイゴンといえば、ちかごろは、わが欧州航路の汽船でかならずよっていくという重要な貿易港であって、米、チーク材、棉花などを輸出し、パリー風の賑かな町で、フランスの東洋艦隊の根拠地でもある。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "チークダンスの必要がないのだもの。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "場内の壁に何カ所も、「リズム・チークジルバー　　右　固くお断り申し上げます」　と貼り紙がされている。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは私が、まだ芸道未熟で、それだけの余裕がないせゐもあらうが、事実他の人々に聞いても、踊つてゐる中は大抵誰でも……シミイとかチークとかいふ特殊なダンスでない限り、さうした欲情に捉はれる事などはないさうである。",
              "citation": {
                "source": "私の社交ダンス",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学ではプラトンの『ソピステース』やヘーゲルの『エンチークロペディー』などがその典型である。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓は悉く閉め切って、内側からさし込みで留めた上、厚い窓掛を念入に引いてありますし、チークの大｜卓の上も、波斯模様の絨毯の上も、日本語とフランス語の本が一杯に取り散らばしてありますが、それも一種のリズムと人格のある散らかしようで、決して主人公以外の者の掻き乱したものではありません。",
              "citation": {
                "source": "流行作家の死",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この有能なる種族の祖先は父をチークム・セーロンといいましてこのヒマラヤ山の土から化生したという。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "といったような、極めて簡単な望みの下に行を起したのであったが、小径は、桃花心木やチークの大木と大木との間を縫って、だらだらと降り切ると、やがて向う側の山の登りに掛かった。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この巨木中にシダーラといわるる材質の緻密堅牢なるチーク材以上のものがあり、しかもこの緻密にして堅牢なる材質が、湖水中に多年倒れていることによって寒暖の差に鍛え上げられ、いかなることあるも決して湾屈せず、水に腐蝕浸透せられざるものとして、すなわちこの材料が選ばれたのであります。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何だか知らないが、あんまり見っともいいもんじゃないね」「ほんとうよ、実際下品よ」ナオミはペッペッと唾を吐くような口つきをして、「あれはチーク・ダンスって云って、真面目な場所でやれるものじゃないんだって。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
