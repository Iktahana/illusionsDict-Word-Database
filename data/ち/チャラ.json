    "definitions": [
      {
        "index": 1,
        "gloss": "cancelling (a debt)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
