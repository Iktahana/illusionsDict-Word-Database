[
  {
    "uuid": "43b5579c-73c4-583b-b612-b5e0e1112df4",
    "entry": "乳兄弟",
    "reading": {
      "primary": "ちきょうだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
