    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cheer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（チア）（ク）（ラズ）（ヤク）（シ）。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドュフランは官署へ出かけて行って警視長官チアベと向い合った。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がチア公園の落葉の森を出端れて街の太陽の光の中に出た時、彼の古マントの袖は破れ、下駄の緒は切れ、木の根で痛めた指からはなまなましく血が滲んで居た。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "またショパンは「ヘ」短調司伴楽の第二楽章の美しいラルジェットがコンスタンチア・グラコウスカに対する自分の感情を旋律化したのであることを自ら語っている｛７｝。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくロシアの golova, glava（セルボ・クロアチアも同じ）、チェッコの hlava, ズールの inhloko（in は接頭語）等いずれも「カラワ」と音が近い。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十字架の基督や矢を受けた聖セバスチアンもそうであるし、また地獄変相図やそれに似た耶蘇教の地獄図、聖アントニオの誘惑の絵の中にも同じようなものが往々見出される。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリアでは就中ヴェネチアが好なのです。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、突然夕暮がやつて來て、公園のなかには燃えるやうな薄明を生じさせ、ゆるやかに水の漂つてゐる運河にはヴェネチア風の夢を與へ、それから戀人達には孤獨をもたらす……」",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリーやセルボクロアチアンからフィンランドまで行ってみても同様である。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はＩ君がサイクラメンとポインセチアを届けてくれた。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポインセチアはこれまで花屋で見かけた事はあるが、名はそれまでは知らなかった。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポインセチアとはいったいどうつづるのか知りたいと思っていた。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」壁に布切れやしわくちゃの紙片をだらしなく貼りつけたのをバックにして、平凡な牛乳びんに二本のポインセチアが無雑作に突きさしてあるだけである。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベコニアや蘭の勢いのいいのに比べて、ポインセチアは次第に弱るように見えた。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポインセチアも頂上の赤い葉だけが鳥毛のようになって残っていた。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスチアンとイドウとが氷塊を小汽艇へ積み込んでいるところへテレーズがコーヒーの茶わんを持ってくる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスチアンがいきなり女を船に引きおろしておいてモーターをスタートする。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう点では、下町の素人の芝居好きの劇評のほうがかえって前述のごとき著名なインテリゲンチアの映画批評家の主観的概念的評論よりもはるかに啓発的なことがありうるようである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれを、おまえの花婿の御陵の上に、幽霊のような大理石の都ベネチアの上にかけなさい！",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかんずく、イタリアの美しい自然を背景として美少年アントーニオと歌姫アヌンチアータとの悲恋を描いた『即興詩人』のごときは忘れがたい作品の一つであるといえよう。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにこの一方には、ミケランゼロや、チチアンや、応挙や、北斎や、ロダンや、セザンヌやの如く、純粋に観照的な態度によって、確実に事物の真相を掴もうとするところの、美術家の中の美術主義者が居る。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オネーギン」にはタチアナのよい戀文がある。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "タチアナは、それから、神樣のみこころ、夢、おもかげ、囁き、憂愁、まぼろし、天使、ひとりぼつち、などといふ言葉を、おくめんもなく並べたててゐる。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オネーギン」にはタチアナのよい恋文がある。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "タチアナは、それから、神様のみこころ、夢、おもかげ、囁き、憂愁、まぼろし、天使、ひとりぼっち、などという言葉を、おくめんもなく並べたてている。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唾液は水なり、ムチンの存在によつて粘きも、其実は弱アルカリ性の水にして、酵素のプチアリンを含めるのみ。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此中プチアリンは消化作用の一助をなすに止まり、ムチンは蓋し外物の強烈の刺激を緩和する為に存せりと覚しく、味を解きて人に伝ふるものは、実に水の力なり。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
