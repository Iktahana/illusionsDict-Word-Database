        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――百雑砕――燃ゆる陽を浴びて夾竹桃のうつくしさ、夏の花として満点である。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はカントの流儀によつて哲学は又食通だといふ建前で、ソースなどは自分で作れるぐらゐ、昔は相当料理の本を読んで、牛の脳味噌、牛の尻尾、臓モツの料理、雉の腹へ色々の珍味をつめて焼きあげる奴、マカロニ料理からチャプスイに至るまで自ら料理のできるほど色々と通じてゐる。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所から臭つて来る香ひは、これや、てつきり、ママお得意の筍入りチャプスイだ。",
              "citation": {
                "source": "犬は鎖に繋ぐべからず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "店主の小田亀造ちゅうのは、アメリカの駆逐艦のコックをしとったとかいう面白い男でな、註文してあるけ、後で来るじゃろが、チャップリンとか、チャプスイとかいうような、珍しい料理も作る。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "大黒と上山でオリムピックへ寄り、トマトスープと、チャプスイを食ふ、トマトスープはいゝが、チャプスイはゼロ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
