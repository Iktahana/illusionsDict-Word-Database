[
  {
    "uuid": "ff24ab8f-6109-5cd3-b370-0c8dd2d2f52b",
    "entry": "中級",
    "reading": {
      "primary": "ちゅうきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
