    "definitions": [
      {
        "index": 1,
        "gloss": "muscleman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いまになって彼は恋の力持ちが辛うじて同志の体面を維持していたことを知るのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯母の夫は、足駄をはいて、両手に一俵ずつ四斗俵を鷲掴みにさげて歩いたり、肩の上へ同時に三俵の米俵をのっけて、河にかけられた細い、ひわ／＼する板橋を渡ったりする力持ちだった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲人は御縁の下の力持ち　　　　　　　　　　腰を押いたり尻を押いたり　それから四、五日経って後のこと、目明の良助が、例の通りの尻端折に頬冠り姿でノッソリと猪口兵衛の縁端に腰をかけた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "香具師の力持ちの夫婦は肥った運動服のかみさんを先に立てゝ、のそ／＼キャフェの軒の下に避難しに行く。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "図案工なんて、ほんとうに縁の下の力持ちみたいなものですのね。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "横痃のはじけそうな時でも、二人分の力持ちを、平気でやった男だ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをはじめにして乙姫の「竜宮の舞い」、達磨大師の「コロコロ踊り」、花咲爺の「花咲踊り」、舌切雀の「雀踊り」、桃太郎の「剣舞」、金太郎の「力持ち」、獣のダンス、鳥のダンスなぞが次から次へ数限りなく、いつまで見ても面白う御座いました。",
              "citation": {
                "source": "雪の塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "）息子がさういつて、馬をつなぐ筈のところの梶棒を持ちあげたぢやないの、ところが、ひとりで、いくら力持ちだつて人間が馬の代りなんて出来はしない！",
              "citation": {
                "source": "ダイアナの馬",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」滝は力持ちのやうに両腕を胸に組み直してうなりました。",
              "citation": {
                "source": "舞踏会余話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "表面に現れることなどは欲しない、縁の下の力持ちに甘んじて一生かかつて一つの基礎工事をコツコツやるといふやうな――」　それまで默つて二人の話を聞いてゐた三井が、その時、「確かに今迄は餘りに理窟が多かつたですからね。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この度私が楠公の馬を彫刻するとなれば、従前の関係上、必ず助力をしてくれることでありますが、しかし、その助力を蔭のものにして、私が表面に立って、美事に馬が出来たとして、後藤氏の力がそれに多分に加わっているにもかかわらず、後藤氏は全く縁の下の力持ちになってしまうわけであります。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "馬専門の彫刻家のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はやはり同じクラスの堀江太郎という「気はやさしくて力持ち」の少年と、も一人池上正夫という非常に優美なことの好きなクラスメートを語らって、柔道場の畳の上に「歌がるた」を並べて堀野を誘ってやりだした。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二歳の力持ちのハーヒ。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "パン焼職人達は「最初の日から、彼をおかしな道化者、又は面白い話をするひとに対して子供が示すような素朴な愛でもって」若い、力持ちの新しい仲間を見た。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　そして、素晴しい力持ちでもあった。",
              "citation": {
                "source": "格子縞の毛布",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "社長の川崎は、主筆ばかりが讃められて自分は殆ど縁の下の力持ち同樣なのに業を煮やしたのだらう。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "入神の妙技はさて措くとしても、これも残された江戸趣味の一つとして見れば、実はここらからその復興を企てて、新しい江戸を東京の今にものしたいものだと、まァさ、折角そんなに思っているので、こちとらは随分椽の下の力持ちもしてえる奴さ。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはじっと我慢をし通して来たが、あの大男の力持ちに殴られちゃ、敵うもんじゃない。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしい力持ちじゃ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "女でも合田のおときなぞは力持ちだから、体の弱い亭主に二俵背負はせ、自分は三俵背負ってさっさと登る。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはこの、力者の狐直の四世の孫にあたる、大力女の、力｜※べの話で、しかも、この狐の子孫の方が、一方の、まじりなし人間｜種の力持ち女に負けた話なのである。",
              "citation": {
                "source": "春宵戲語",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうかい――本当に、妾ゃ、縁の下の力持ちさ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "謹直枯淡で縁の下の力持ちの如き一生を終つた杏坪先生。",
              "citation": {
                "source": "頼杏坪先生",
                "author": "中村憲吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "其で、わたしも、あなたを見まねで、縁の下の力持ちをやる気になりました訣です。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者をひいきすると言ふ事も、いろ／＼あるが、ぱとろんとしての誇りを衒かすことも出来ず、又、好色に泥んで縁の下の力持ちをする気にもならぬ。",
              "citation": {
                "source": "芝居見の芝居知らず",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "９　五郎投げ石・力持ち石。",
              "citation": {
                "source": "漂著石神論計画",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし源一は力持ちだったから、相手をかついで田の中をわたり、道まで出た。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学の頃から急にムク／＼ふとりだしてスポーツが巧くなつたり、力持ちになつたり、いつ頃からか人前へ出しやばつて生きることにも馴れたものだが、かうしてぎり／＼のところへくると、オド／＼した物蔭の小学生が偽らぬ自分の姿だと思ひだされてしまふのである。",
              "citation": {
                "source": "母の上京",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かと思ふと急に引返して暖簾に首を突き入れ、駄夫の肩を押しからがして、「吉原の話はおつかあにナイショだよ」　男はニヤ／＼して、「オレのおつかあは力持ちだからね」と言つてゐたが、首を引つ込めると口笛を吹き流して向ふへ歩き去るのが分つた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
