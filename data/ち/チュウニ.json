    "definitions": [
      {
        "index": 1,
        "gloss": "second year of junior high school",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼らは毎日中２度、毎晩２度、入浴した。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ず識らずの女が夜ちゅうに人の店へあがり込もうというのは、なんだか胡散らしいとも思ったが、お徳はもう三十を越している。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、これ、開けてはなんねえちゅうに、」「だって、あれ、あれ、助けてくれ、と云うものを。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この僧侶は祈っているようすでしたが、そのお祈りのさいちゅうに何か物思いにしずんでいるようでした。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、もう一度浮びあがったときには、まるで、むがむちゅうになっていました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、お日さまが、高いサクラの木のうしろにしずんでしまうまで、むちゅうになって、あそびつづけました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍女たちは、ブタ飼いのもらうキスが、多すぎも少なすぎもしないで、きちんと数だけもらうように、むちゅうになってキスの数をかぞえていましたので、皇帝のおいでになったことには、すこしも気がつきませんでした。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり、仕事にむちゅうになりすぎて、このとおり、かたわものになってしまったくらいだ。",
              "citation": {
                "source": "かけっこ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧嘩さいちゅうに誤って足をすべらし小川へ転落した場合のことを考慮したのであった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、そのよろこびのまっさいちゅうに、ヘンデル先生は、ふとした不注意から、ばいきんが目にはいり、それがもとで、死んでしまいました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑魚寝のさいちゅうに血なんか吐いたら、いい見世物ですわよ。",
              "citation": {
                "source": "饗応夫人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むこうがああきた、そこであすこをパチンとおさえた、それからこうきたから、こうにげたが、あれはやっぱり、こっちのところへ、こうわたるべきだったなどと、むちゅうになって、歩いてきました。",
              "citation": {
                "source": "のら犬",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇后はそれに答えて、「あの御子は、ちょうどとりでが火をかけられて焼けるさいちゅうに、その火の中でお生まれになったのでございますから、本牟智別王とお呼び申したらよろしゅうございましょう」とおっしゃいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "己は蛇の尾をしっかり攫んで、ずるずると引き出して、ちゅうに吊るした。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車ちゅうには別に語ることもなく、わたしは神戸にいったん下車して、会社の支店に立寄った。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥太郎が撃ち洩らした鳥は、果たして尾白であったかどうだか判らなかったが、ともかくもその一季ちゅうに尾白の姿を認めた者はなかった。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はずきんをとって、むちゅうになってふりまわしました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、そのいそがしいまっさいちゅうに、ランプがふっと消えてしまいました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "船員ちゅうには著るしく不満の色がみなぎっている。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "（もう来ているだろうか、この試験さいちゅうに）　彼は神中が試験にいそがしいことを知っていて、己かってな処へ呼ぶのが腹だたしくなって来た。",
              "citation": {
                "source": "雀が森の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかにはおおぜいの人間が、船乗や、コペンハーゲンの町人や二三人の本読もまじって、みんなビールのジョッキをひかえて、むちゅうになってしゃべっていて、はいって来た客にはいっこう気がつかないようでした。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "話でむちゅうになっているあいだは、これまでのことをいっさい忘れていたのです。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことで、こどもたちたれも、むちゅうになってあそんでいると、そこへ、いちだい、大きなそりがやってきました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知の通り、わたくしは釣り道楽で、鳥亀の亭主とはおなじ釣り師仲間で、ふだんから懇意にしていたのですが、どうも可哀そうな事をしまして……」　善吉の話によると、安蔵は去年の春の彼岸ちゅうに鮒釣りに出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえさんは千駄木だと仰しゃるが、御組ちゅうに光井さんという方がありますかえ」「光井さんというのはあります。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆ちゅうにも人殺しをするような奴があるんだからな」　こんなことを云いながら二人は弁天堂にゆき着くと、露路の内そとには大勢の見物人がいっぱいに集まっている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し年季ちゅうに自儘に店を飛び出したり、あるいは不埒を働いて暇を出されるような場合には、その金は主人の方へ没収されてしまうことになる。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ両三日ちゅうに十両の金子を持参いたして、あらためてお詫びの規模を立てましょう」　帰りぎわにお光を門口へ呼び出して、栄之丞はこの事をささやいて聞かせると、妹の顔色はまた陰った。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月十五日、冬のまっさいちゅうに決まっているじゃねえですかよ」「江戸は降らねえが、さだめし加賀あたりは大雪だろうね」「なにをべらぼうなこというんです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
