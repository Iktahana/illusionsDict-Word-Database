  {
    "uuid": "67dd93ea-1e2d-5120-a4c4-15dd7ce82846",
    "entry": "地異",
    "reading": {
      "primary": "ちい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
