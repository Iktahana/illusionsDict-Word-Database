    "definitions": [
      {
        "index": 1,
        "gloss": "clearness (e.g. sky)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
