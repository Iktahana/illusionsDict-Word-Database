      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "final effort",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "勿論、寓話作者としてはここで老人に掉尾の大活躍をさせて、名人の眞に名人たる所以を明らかにしたいのは山々ながら、一方、又、何としても古書に記された事實を曲げる譯には行かぬ。",
              "citation": {
                "source": "名人傳",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、寓話作者としてはここで老名人に掉尾の大活躍をさせて、名人の真に名人たるゆえんを明らかにしたいのは山々ながら、一方、また、何としても古書に記された事実を曲げる訳には行かぬ。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこの狗寺に入るを見ればことごとく住まり低頭｜掉尾すとある。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、天下の大富豪と仰がれるようになったのは全く椿岳の兄の八兵衛の奮闘努力に由るので、幕末における伊藤八兵衛の事業は江戸の商人の掉尾の大飛躍であると共に、明治の商業史の第一｜頁を作っておる。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊之助が掉尾の一振ともいうべきものは、明治三十年二月の歌舞伎座で勤めた「関の扉」の小町姫であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二番目は「文七元結」で、菊五郎の左官屋長兵衛、栄三郎の女房、丑之助の娘、家橘の手代文七という役割であったが、事実においてこれが団菊として掉尾の一振であったらしく、両優ともに予想以上に活躍して、これではまだ当分は舞台上の命脈があるらしいというのが一般の評判で、好劇家もやや意を強くしたのであった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "掉尾の爽快さも忘れられない光景であつた。",
              "citation": {
                "source": "南予枇杷行",
                "author": "河東碧梧桐",
                "note": "青空文庫"
              }
            },
            {
              "text": "掉尾の大功を惜しげもなく割愛して、後進に花を持たせた先輩の襟懐、己を空しうして官庁の威信を添えた国士の態度、床しくもまた慕わしき限りではないか。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "平氏は、福原の遷都を、掉尾の飛躍として、治承より養和に、養和より寿永に、寿永より元暦に、天暦より文治に、円石を万仞の峰頭より転ずるが如く、刻々亡滅の深淵に向つて走りたりき。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮世絵風俗画は鈴木春信勝川春章鳥居清長より歌麿春潮栄之豊国の如き寛政の諸名家に及び円熟の極度に達せし時、ここに葛飾北斎一立斎広重の二大家現はれ独立せる山水画を完成し江戸平民絵画史に掉尾の偉観を添へたり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に後者は山が日本北アルプスの中枢にあるだけに、此時代に於ける開山の最後を飾るにふさわしい掉尾の業績であった。",
              "citation": {
                "source": "山の今昔",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小生はあれが掉尾だと思って自負して居るのである。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして終には彼の両神山の奇峭を掉尾に振い起して、この大山脈を竜頭蛇尾に終らしめない所に、自然の用意の周到なることが窺われる。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲信武甲の国境を東走して来た秩父山脈は、どの道この辺でこれ位な高度の山を掉尾に振い起して、武蔵野に君臨せしめなければならない筈だ。",
              "citation": {
                "source": "秩父の奥山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども大隈伯は其の未來の短かきを感ずるに由りて、却つて一層猛烈なる現在主義の信者と爲り、勉めて其生涯をして掉尾の活動あらしめ、以て賑やかなる晩年を送らむと欲せり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども大隈伯は其の未来の短かきを感ずるに由りて、却つて一層猛烈なる現在主義の信者と為り、勉めて其生涯をして掉尾の活動あらしめ、以て賑やかなる晩年を送らむと欲せり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の北部公演であり、掉尾を飾るべく力がはいった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に二、三枚のカサルスを求める人に、私はビクター愛好家協会の第二回の掉尾の名レコードであった『コール・ニドライ』、二枚三面を算えなければなるまい。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その白兵戦のうちに各人が掉尾の勇を振った。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "掉尾の全盛　然るに、とかくいざこざの多い芝居道、女世帯はまた男と違って嫉妬や僻みの角突合いで小うるさい楽屋内、さすがの粂八もとうとう我慢ができず、また一門を伴って同座を去り、あとは笑燕と錦糸がどっちも座頭のように頑張って、桂二、千升、力代などのほかに綺麗首の沢村紀久八が加わり、相変らずの繁昌。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪責の浦里や居守酒の夕秀など大向はわいわい、この座組で六、七年の間は女芝居掉尾の全盛を続けた。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月二十四日（木曜）（なし）十二月二十五日（金曜）　今日が祭日で此処んとこ三日マチネーあり、気が重い、ほんとの掉尾的大奮闘である。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
