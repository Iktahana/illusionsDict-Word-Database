[
  {
    "uuid": "920939d9-2a8f-5b26-a449-c9d9d9a8cf72",
    "entry": "掉尾",
    "reading": {
      "primary": "ちょうび",
      "alternatives": [
        "とうび",
        "たくび"
      ],
      "is_heteronym": false
    },
    "grammar": {
