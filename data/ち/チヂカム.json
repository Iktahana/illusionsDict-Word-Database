    "definitions": [
      {
        "index": 1,
        "gloss": "to be benumbed (e.g. with cold)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
