        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "洗濯をしたら、お気に入りのセーターが縮かんでしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "寒暖差の激しい場所では、木材が縮かんだり膨らんだりする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "年月とともに、革製品は少しずつ縮かんでいくものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
