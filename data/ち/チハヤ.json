    "definitions": [
      {
        "index": 1,
        "gloss": "thin, white ceremonial haori worn by miko",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "団十郎の彦七、女寅の千早姫、いずれも好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "千早城の正成になるつもりだなどと書かれているだけであった。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "正成が千早城や金剛山に奇勝を博し得たのは、一に彼等の敏捷な山地の戦闘力に依ったのである。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "正成は、更に金剛山に千早城を築いて、寄せ手の北條氏の大軍を馳せ悩ました。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "千早、赤坂、吉野の中、赤坂、吉野は落ちたが、千早城のみは、賊の大軍に囲まれながら、金剛山に因んで、金剛｜不壊の姿を示した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "先に、千早の攻囲軍中にあつて、護良親王の令旨を戴いて、東国へ帰つてゐた新田義貞は、義兵を起して鎌倉に攻め入り、北條氏一族を討滅した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "定家卿が後鳥羽上皇に随い熊野に詣りし時の歌にも、「千早振る熊野の宮のなぎの葉を変はらぬ千代の例しにぞ折る」とあり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "金の岬を過ぎても「千早振る金の御崎を過ぐれどもわれは忘れずしがのすめ神」という歌のように夕顔夫人を忘れることができずに娘たちは恋しがった。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、健康状態は急速に悪化し、一一月二〇日朝五時、東京都豊島区千早町一の三〇番地のアパート東荘の自室で死去。",
              "citation": {
                "source": "小熊秀雄全集-1",
                "author": "短歌集",
                "note": "青空文庫"
              }
            },
            {
              "text": "千早振る神代も聞かぬ珍事なるを予しばしば目撃した。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "新学年始業式の日なので、Ｓ村尋常高等小学校の代用教員、千早健は、平生より少し早目に出勤した。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其※時は、無精者の母親がよく健の前へ来て、抱いてゐる梅ちやんといふ児に胸を披けて大きい乳房を含ませながら、『千早先生、家の忠一は今日も何か悪い事しあんしたべすか？",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『それだつてなす、毎日悪い事許りして千早先生に御迷惑かける様なんだハンテ、よくお聞き申して置いて、後で私もよツく吩付けて置くべと思つてす。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『奈何なさいましたの、千早先生、今日はお顔色が良くないぢやありませんか？",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しや詰らぬ疑ひを起されてはといふ心配から、健には妻子のあることを詳しく記した上で、『私の学校は、この千早先生一人の学校といつても可い位よ。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥様やお子様のある人とは見えない程若い人ですが、男生でも女生でも千早先生の言ふことをきかぬ者は一人もありません。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "千早先生はその百人に一人しかない方の組よ。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（遊びました）といふのは嘘で、先生は其時、「千早先生はさう騒いでも可いと教へましたか？",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は千早先生の時間だといふ時は、鐘が鳴つて控所に生徒の列んだ時、その高等科の生徒の顔色で分ります。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのペスタロツヂは痩せて骨立つた老人でしたが、私、千早先生が由松に物を言つてるところを横から見てゐると、何といふことなくあの画を思出すことがありますの。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『然し秀子さん、千早先生は私にはまだ一つの謎です。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日逢つた時、明日辞表を出すつてゐだつけが、何しろ村教育も漸々発展の緒に就いた許りの時だのに、千早先生に罷められては誠に困る。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『先生ア真箇に千早先生の辞表を受取つたすか？",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『千早先生も又、甚※御事情だかも知れねえども、今急にお罷めアねえくとも宜うごあんすべアすか？",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『千早さん、先刻は急しい時で……』と諄々弁疏を言つて、『今お聞き申して居れば、役場の方にも種々御事情がある様でごあんすゝ、一寸お預りしただけでごあんすから、兎に角これはお返し致しあんす。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生には、千早先生が何れだけこの学校に要のある人だか解らねえすか？",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "……千早先生も一旦お出しになつたのですから、お厭でせうし、それでは安藤先生もお困りでせうし、お役場には又、御事情がお有りなのですから……』と、心持息を逸ませて、呆気にとられてゐる四人の顔を急しく見巡した。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言ひながら健の方を向いて、『千早先生も、それなら可がべす？",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはやがて、そろって銭湯に出かけた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山々の草枯れの色は実に美しいと東の山ばかり見ているうちはや神島まで来て、久礼はと見たけれども何処とも見当がつかぬ。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
