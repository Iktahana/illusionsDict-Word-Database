    "definitions": [
      {
        "index": 1,
        "gloss": "charge (electrical)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "スマートフォンのバッテリーをチャージするのを忘れてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "EV車の充電スタンドで、車に電気をチャージする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "静電気のチャージで、ドアノブに触れるとパチッとくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一人で、クラースナヤ・プロスチャージ〔赤い広場〕、アレキサンドロフスキー・サードを散歩した。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、馬車でズッと河岸を廻り、クラースヌイ・プロシチャージへ抜け見物した。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "家のことを話したら、つまりここのおやじがよけいなプロシチャージ〔面積〕をとって居る為こわがって居るのだろうということ。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、これも次手に伺いたいですが、喜劇役者のチャージン――あのパーヴェル・セミョーヌィチですが、あれは今どこにいますかな？",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "（腰をおろす）シャムラーエフ　（ふーっとため息をして）パーシカ・チャージン！",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士という個人に就いて性格論や人間論を云々することは、礼を失する外に多分あまり意味がないだろうが、問題は個人のこうした個性が、超個人的な歴史的社会的な様々の形式の観念体系と、どうディスチャージするかである。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "「革命的エネルギー」という言葉があるが、それは一種のポテンシャル・エナジーで、転向・転下によって、このエネルギーがディスチャージ（？",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "「広場」つまりプロシチャージ、そういう題です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
