[
  {
    "uuid": "a5022691-c91d-51d6-9bc2-5405cb3b73b7",
    "entry": "挑発",
    "reading": {
      "primary": "ちょうはつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
