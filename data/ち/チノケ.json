    "definitions": [
      {
        "index": 1,
        "gloss": "blood (in one's face, cheeks, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　私は、はっと、むねを突かれ、顔の血の気が無くなったのを自分ではっきり意識いたしました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても子というものは、しばらく離れてめぐり会った子というものは何と人間のような血の気を神の胸にも逆上さすものであろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし前回での男とのめぐり合いののち、富士を眺め上げて、それはただ血の気の做すわざなんだか、もっと深く喰入るべきものがあるような気がしたのを想い出して、自然と抑止するものがあった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが驚いたなあ」　老妓は腕に指痕の血の気がさしたのを、縮緬の襦袢の袖で擦り散らしてから、腕を納めていった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野は血の気を失って、この世のものとは思えないほど、宗教的な顔をしていました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "西の方の野原から連れて来られた三人の雪童子も、みんな顔いろに血の気もなく、きちっと唇を噛んで、お互挨拶さえも交わさずに、もうつづけざませわしく革むちを鳴らし行ったり来たりしました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、まるっきり、血の気も失せてかけ込んで、「旦那あ、象です。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……でも貴方にはトウトウわかったのね……ホホホ……モウ随分前からの事ですからかなりの人数になるでしょう……御存じの家政婦も入れてね……ホホホホホ……」　私は見る見る血の気を喪って行く自分自身を自覚した。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の気がなくなって、奥歯がギューと締まって夏も冬もわからなくなる……それが実さんの妖気の正体だ。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は涙の泉も涸たか唯だ自分の顔を見て血の気のない唇をわなわなと戦わしている。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンヌから来たという美しい処女シャーロット・コルデーは血の気の失せた唇から「私は自分の仕事を仕遂げてしまった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてかすかな血の気をその疲れたような頬に現わした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父に似て派手で血の気の多い長男は、海外へ留学に出たままずっと帰らない。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆三は血の気で頭の皮膚が破れるかと思うばかり昂奮して、黙って座を立って行って、土蔵の中の机の前に腰かけた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、驚いたなあ」　老妓は腕に指痕の血の気がさしたのを、縮緬の襦袢の袖で擦り散らしてから、腕を納めていった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お雪は血の気を失った顔を、恐る恐る上げて仰いだが、少年を見ると斉しく身を顫わした。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬のあたりにいくらか血の気が上つて、笑つたあとの眼の中には暗い影が漂つて居る。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "西の方の野原から連れて来られた三人の雪童子も、みんな顔いろに血の気もなく、きちつと唇を噛んで、お互｜挨拶さへも交はさずに、もうつづけざませはしく革むちを鳴らし行つたり来たりしました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……血の気の多い漁師です、癪に触ったから、当り前よ、と若いのが言うと、（人間の食うほどは俺も食う、）と言いますとな、両手で一｜掴みにしてべろべろと頬張りました。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "望月と真紀子は、血の気を失った顔のまま、こそこそとホールを出て行った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、ぼくは突然、耳を塞ぎたくなる様な隣室の物音をきいて、まるで外科手術をうけているかの様に血の気を失ってしまった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋常二年の眼が、提灯にかかれた「野瀬」の二字を判読しようとしていたが、血の気が頭からすっと引いて行くような胸苦しさで、困難であった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　母は言っていたが、二日三日たっても、湯に馴染めそうには見えず、花の萎むような気の衰えが感じられるのだったが、湯を控えめにしていても、血の気の薄くなった躰に、赤城おろしの風も冷たすぎ、肺炎がまたぶり返しそうな気がしてならなかったので、五日目の晩帰ることに決め、翌日の朝電車で山をおりた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、気のせいか、王子の頬にも、血の気がさしてきたように思われました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉は毎晩々々夜更けてから、血の気のない程に蒼ざめて帰って来、私にご飯を食べさせてくれた。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　姉は、夜更けてから、血の気の失せた顔をして帰って来て、私にご飯をたべさせてくれた。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の感情はそっちのけに、養母が動揺するのを気味よしとする皮肉なところがあった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種の図太さがあって、露西亜人を相手に話しだすと、仕事のことなどそっちのけにして、二時間でも三時間でも話しこんだ。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　上等看護長は、勤務をそっちのけにして猟に夢中になっている二人を暗に病院から出て行かせまいとした。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝきみがまなざしの涯、　　　うら青く天盤は澄み、もろともにあらんと云ひし、　　そのまちのけぶりは遠き。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
