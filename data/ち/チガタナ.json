    "definitions": [
      {
        "index": 1,
        "gloss": "bloody sword (blade)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大吉笑い乍ら血刀拭う。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "小姓の波伯部が帰って来た時、戸倉は血刀を揮って切付けた。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "修羅道で敵手を喪った大将軍が、血刀を提げてクラ暗の中を見まわしているような悽愴たる感じが一パイに籠っていた。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　旗野の主人は血刀提げ、「やをれ婦人、疾く覚めよ」とお村の肋を蹴返せしが、活の法にや合ひけむ、うむと一声呼吸出でて、あれと驚き起返る。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "長範をば討って棄て、血刀提げて吻と呼吸つく状する、額には振分たる後毛の先端少し懸れり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛脚は狼の血でべとべとになった血刀を持って下の方を覗いていた。",
              "citation": {
                "source": "鍛冶の母",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "由平は腰をひねって主翁を振りはなして、逃げようとする主翁に背後から血刀を浴びせた。",
              "citation": {
                "source": "阿芳の怨霊",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平馬は血刀を掲げたまま茫然となっていた。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "折ふし向岸の諏訪下の渡船場より早船にて、漕ぎ渡し来る数十人の捕吏の面々を血刀にてさし招きつゝ、悠々として大文字山に登り隠れ、彼の大判小判の包みと、香煙の器具一式とを取出して身に着け、鞘を失ひし脇差を棄てゝ身軽となり、兼ねてより案内を探り置きし岨道伝ひに落ち行く。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚きて振上げし血刀を控へつゝ、よく／＼見れば這は如何に。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等男女こそ覿面の因果応報、思ひ知らずやと云ひも終らず、馬十の脳天を唐竹割にし、奈美女の死骸を打重ねて止刺刀を刺し、その上より部屋の中の珍宝、奇具を片端より覆へして打重ねたるまゝ本堂の下を潜りて外に出で、血刀と衣服を前なる谷川に洗ひ浄めて、悠々と方丈に帰り来りぬ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "引抜いた血刀を構えながら凜々たる声を張上げて叫んだ。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「秋月さん、あなたを助けにきた」　王は血刀を拭って鞘に収めるなり、秋月を隻手に軽々と抱いて其処を走り出た。",
              "citation": {
                "source": "蘇生",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行に交っていた壮い男が血刀を持って立っていた。",
              "citation": {
                "source": "女賊記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日温麦の打ち手というを聞き誤って、伯父の心替りと思い取って、忍んで入道を害し、寺を去り、この池に血刀を注ぐ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "金右衛門の一行は丁度そこへ通り合わせて、自分たちの眼の前でこの活劇が突然に始まったのですから、きのう見物した中村座の芝居どころではない、四人は蒼くなって立ちすくんでいると、浪人は血刀を鞘に納めて四人を見かえりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の方を殺して殺気立っている間にと思って、血刀を振りかざしながら、彼は女に近づいた。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうに、黙然とやや暫し、そこに佇みながら、血刀をさげたままで、何ごとか沈吟しているもののようでしたが、と見て、塀の上からおどりおりつつ、駈けよって来た京弥を見迎えながら、突如、わびしげに、呟くごとく言いました。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのいち人が血刀をぬぐいながら、はやてのような早さで、さッと闇の向うに逃げ走って行きました。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その血刀ひっさげたまま千之介は、隣りつづきの林田門七のお長屋目ざしつつ駈け出すと、物をも言わず躍り入りざま、そこに今別れたばかりの門七が立て膝し乍ら、灯りに油をさしていたのを見かけてあびせかけた。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その血刀をさげたまま、直人は、そぼふる雨の表へ、ふらふらと出ていった。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍女の一人は若侍の血刀を持った手をぐっと掴んだ。",
              "citation": {
                "source": "村の怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この悪人、そちは何の怨みあって、お姫様をこうした眼に逢わせたのじゃ」　若侍は血刀を手から落した。",
              "citation": {
                "source": "村の怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
