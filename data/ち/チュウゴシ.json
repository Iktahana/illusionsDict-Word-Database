    "definitions": [
      {
        "index": 1,
        "gloss": "half-sitting posture",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
