  {
    "uuid": "3ea2d6b0-bf45-5ccb-a467-111f3fee2dc3",
    "entry": "ちゃっと",
    "reading": {
      "primary": "ちゃっと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "swiftly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "うっちゃっといておくれよ。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまい、少しぐちゃっと苔にはいったけれども、まあいいねえ、それではぼくはいまこっちで桶をつるすから、そっちでとってくれ給え。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お道に聞かれて米が答えようとするのを、ちゃっと引取ったのは今両人が鍵屋の女客に引付けられて、店から出るのに気を揉んで、あとからついて出て立っている蔵屋の女。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ツェねずみはプイッと中にはいって、むちゃむちゃむちゃっと半ぺんを食べて、またプイッと外へ出て言いました。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それ、姫様、ちゃっとちゃっと。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とニヤリとして、「ちゃっとお拭きなされませい。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い土地に、数のない芸妓やによって、こうして会なんぞ立込みますと、目星い妓たちは、ちゃっとの間に皆出払います。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の間にある月をな、影で繋いで、ちゃっと行って、（是喃。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "加世子は水色のスウツを着て、赤い雨外套を和服の女中の腕に預け、手提だけ腕にかけていたが、この方はしばらく見ないうちに、すっかり背丈が伸び、ぽちゃっとしたところが、均平の体質に似ていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど、それで、ぺちゃくちゃ、ぺちゃくちゃ、ぺちゃっとね！",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "剛胆な平太郎は、「どうか、打ちゃっといてください」と、云って聞き入れなかった。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆がへんな顔をして何か云おうとすると、若旦那が押えて、「まあ、まあ、うっちゃっとけ」と云うので、皆が黙っているうちに準備が出来て、幡半の婢がそれぞれ皆、前へ肴を執りわけてくれたが、それもやっぱり五人前であった。",
              "citation": {
                "source": "とんだ屋の客",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お礼だよ」というと、手首をちゃっと握り、鉈豆のような親指と人差指とでぐり／＼と捻ります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっちゃっときゃ、まあ母子心中か餓死なんです」「ご主人は」「主人は、僕の農芸大学の先輩に当る園芸家なんですが、天才肌でまるで家庭の面倒なんか見ないんです。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁右衛門は二度睨みつけられるのを恐れるあまりに、無器用な足どりで畳の上ににちゃっにちゃっと音をさせながら場主の鼻先きまでのそのそ歩いて行って、出来るだけ小さく窮屈そうに坐りこんだ。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっちゃっときなさいよ。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "両側の家はぺちゃっとしたもので、壁みたいなものがつづいていて、そのところどころに入口だけが口をあいている。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると何でも家出してから四、五日目におかみさん宛てに手紙が来て、余儀ない事情で二、三週間家に帰らないが、決して心配する事はない、愉快に暮らしているからって、手紙の中にはお金が入っていたのですって、警察でもうっちゃっといたらしいの。",
              "citation": {
                "source": "ニッケルの文鎮",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいんでしょうか、うっちゃっといて。",
              "citation": {
                "source": "遺産",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日のことになされては……」「いやいや急ぎの用事故、わしはついちゃっと用をたしてゆく程に、其方達は此処から戻るがよい」　お春は駕籠を下り立って、いくらかの酒代を二人に遣わし、礼の言葉を後に聴いて、小走りに急ぎ乍ら、物寂しい夜半の寺内へはいってしまうのでした。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この容子じゃ駄目だな」と池田が囁くと、「黙っているなら打っちゃっとけよ」と言って沼田は座敷の方へ行って了った。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "須貝　うっちゃっときましょう。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "諏訪　でもあなただって、うっちゃっとけって、賛成したじゃありませんか。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらにはちゃっと分ってるだ。",
              "citation": {
                "source": "土地",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなしいわりに胸幅の厚い所を見ると、屹度骨の節々がくるくると太いに違いありませんし、一度一寸突っついた所では、頬辺にみっちりみがはいって、その上もちゃもちゃっとした柔かさです。",
              "citation": {
                "source": "林檎",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お仙、ちゃっと髪を結って了わまいかや」とお種は、炉辺へ来て待っている髪結を呼んで、古風な鏡台だの櫛箱だのを新座敷の方へ取出した。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
