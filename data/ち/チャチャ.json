    "definitions": [
      {
        "index": 1,
        "gloss": "interruption (e.g. of a conversation)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
