        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "凉しい風が薄寒い秋風に変って、ここの柳の葉もそろそろ散り始める頃、むざんの斧や鋸がこの古木に祟って、浄瑠璃に聞き慣れている「三十三間堂棟由来」の悲劇をここに演出した。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "木曾街道にも、杉や檜に交って咲いた山桜が散り始める夕暮のことであった。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼しい風が薄寒い秋風に変って、ここの柳の葉もそろそろ散り始める頃、むざんの斧や鋸がこの古木に祟って、浄瑠璃に聞き慣れている「丗三間堂棟由来」の悲劇をここに演出した。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹の落葉が烈しい渦を巻いて、二人の足許に乱れ散り始める。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
