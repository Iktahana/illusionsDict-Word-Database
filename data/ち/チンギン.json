    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wages",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この埋め合せには乗客の賃金を増す外はないから、要するに速力が増せば賃金が増すと思わねばならぬ。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年大西洋航路などでは速力の増すとともに賃金も著しく上がったが、それにもかかわらず争うて快速力の船を選ぶ有様だそうである。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、また私は幌無しの辻馬車が――臨終前の一時間といへども、ふだんの賃金どほりに二法で走るところの、幌をすつかり上げた、時間ぎめの辻馬車が、大急ぎでやつて來るのを一度ならず見かけたものだつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、電鈴が私の耳に亀甲町にある、綿花綿布倉庫会社の事業停止による賃金不払のため、従業員のストライキを報らせた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度別段の訳もなく崩れたのならいづれ又格別の訳もなしに崩れるかもしれない、それでもまあ仕事さへしてゐれゃ賃金は向ふぢゃ払ひますからね、いくらつまらないと思っても、技師がさうしろって云ふことを、その通りやるより仕方ありませんや。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "法外な賃金を強請って頑として動かぬ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "定めた賃金だけ持ってサッサと帰れ」　頭から浴びせ掛けられて、馬子さんブツブツいいながら帰ってしまった。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が考えついたのか、同一方面の客を割前勘定で一ツ車に詰めこめば、ガソリンが節約でき、客も順番を待つ時間がすくなく、賃金も安くつくという、いかにも大阪らしい実用的な思いつきだった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくし達は、三分間後ろ向きに歩いて、八十銭の賃金を貰う労働者です。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく、誰が考えついたのか、同一方面の客を割勘定で一ツ車に詰め込めば、客も順番をまつ時間がすくなく、賃金も安くつくという、いかにも大阪らしく実用的な合乗制が出来たので、君枝はその方の案内に、混雑時など、「△△方面へお越しの方はございませんか。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "日傭稼ぎに行ったって賃金が廉いし、なにしたって、売るもの廉ぐって、買うもの高んだから、町の奴等ばり徳さ。",
              "citation": {
                "source": "駈落",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "開墾地の人たちゃあ、開墾の賃金をほとんど貰ってねえのだからなあ」「無茶なことばかり言って、困るなあ」　敬二郎は溜息を吐くようにして言った。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船もよいし、リヴァプール汽船会社のよりは賃金も廉い。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "この漁猟期には、スコットランドの海岸地方では、労働賃金が高率を唱えるを例とする。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は、仏・中英金物株式会社の営業部長として、最低賃金五〇〇ポンドにて職務遂行することに、まったく同意するものである。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、寸法を呼びあげる時に末尾を上に切りあげてしまふので、寸法の大きさに依つて賃金の高まる橇の連中の間では絶大な好評を拍され、尊敬された。",
              "citation": {
                "source": "山を降る一隊",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一百萬圓以上ノ富ハ國有タルベキガ故ニ、工夫ハ多クノ賃金ヲ要セズ商家ハ廣キ買客ヲ欲セズト思考スル者ナシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "平日は下等の賃金片路二十七錢なるが、梅の爲に、大割引となりて、往復の賃金三十錢也。",
              "citation": {
                "source": "越ヶ谷の半日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "驛長とは、相知る仲なれば、不足の賃金の二倍を借りて、それで汽車賃をすましぬ。",
              "citation": {
                "source": "親子遠足の感",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、作の基礎になつてゐる芋とゆびわとの対照――細君にゆびわを買つてやつたために、高が土方の労働にやる賃金がやれないで留守居を使ふといふことが馬鹿々々しかつた。",
              "citation": {
                "source": "三月の創作",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀧の姿は見えないが、そのまま山に入り込んでゐる大きな道が正しくその方角についてゐるものと思はれたので、私は賃金を渡すと直ぐ大股に歩き始めた。",
              "citation": {
                "source": "熊野奈智山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、他の客の賃金を受取るのもそこ／＼にして馬車屋が直ぐ私のあとに隨いて來た。",
              "citation": {
                "source": "熊野奈智山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウェッシントン夫人は苦力らにいくらの賃金を払うのであろうか。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "今東京に出れば、仕事が多くて、賃金が高くて、生活が安い。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "賃金は東京の真中から端までが平均三四円程度であろう。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人も乗れば人力車より安いが、これにはチップを遣る場合が多いからかなり高価いものに付く上に、行きと帰りの賃金が一定しない欠点がある。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "賃金は一里三十銭位でもあろうか。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り賃金はずっと安くて、速力は私営のとあまり変らない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、仕事のないときですから、大工たちはよろこんでやすいちんぎんではたらいてくれ、なかなかりっぱな塾ができあがりました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
