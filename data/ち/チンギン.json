[
  {
    "uuid": "73622e3c-007a-5f59-ab5c-55e2711bf0a7",
    "entry": "賃金",
    "reading": {
      "primary": "ちんぎん",
      "alternatives": [
        "ちんきん"
      ],
      "is_heteronym": true
    },
    "grammar": {
