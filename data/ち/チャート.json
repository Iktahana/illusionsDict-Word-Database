[
  {
    "uuid": "f969503f-aea2-5d71-9399-d346fa3b92b9",
    "entry": "チャート",
    "reading": {
      "primary": "チャート",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
