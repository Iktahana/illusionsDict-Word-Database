[
  {
    "uuid": "d8bee27d-47dc-5bc0-a6d8-e133abba11fd",
    "entry": "町内",
    "reading": {
      "primary": "ちょうない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "neighborhood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今以てそれは不思議といへば、一度町内の子供が全部揃つて、忠臣蔵の真似をして練り歩いたことがある。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが引っ切りなしだから、町内の小火で提燈が露路に行列するようだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "町内一の財産家といふに、家内は祖母と此子二人、萬の鍵に下腹冷えて留守は見渡しの總長屋、流石に錠前くだくもあらざりき、正太は先へあがりて風入りのよき塲處を見たてゝ、此處へ來ぬかと團扇の氣あつかひ、十三の子供にはませ過ぎてをかし。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからそろそろ庭へ出て睡蓮の池の水をのんで、そうして彼の仕事の町内めぐりにとりかかるのであろう。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆるイニシアルでも、T. T. とだけでは、例えば自分と同番地の町内につい近頃まで四人もいた。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもその町内の親爺株の人の例えば三割でもが、そんな精密な地震予知の不可能だという現在の事実を確実に知っていたなら、そのような流言の卵は孵化らないで腐ってしまうだろう。",
              "citation": {
                "source": "流言蜚語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ町内に僕の將棋の好敵手がゐる。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "「町内にどうも早お似合ひの相手が見つかつたもんだなア……」　と、對局しながらフト變にをかしくなつて、そんな感慨を洩らした事もある。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、あれで若しどつちかが斷然強くでもなつたとしたら、恐らく進まぬ方は憤然町内を蹴つて去つたかも知れない。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日ほど前に家の半町ほど先に起つた女中殺しのためだが、住み馴れて既に二十六年、東京市内にもこんな閑靜な好ましい屋敷町はさうあるまいと思つてゐたほどの町内も、あの騷ぎですつかり臺無しにされた感じ。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「同町内のよしみで……」と、挨拶すると、「いや宜しく……」と、三十年に近い「白鷺」の昔ながらに一向年をとつても見えない、覇氣充ちあふれた、この不思議な名女形は齒切れのいい句調で言つて、輕い皮肉めいた微笑を口元に浮べながら、「然しお宅は上の方の町内でせう？",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "モオニングを和服にくつろいでガス暖爐の前に坐ると間もなく、これも同町内の梅原龍三郎さんから電話。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "為さんが川へ引き込まれた」　為さんというのは、町内のちいさい紙屋の亭主で、草履屋とはまったく縁のない商売でありながら、藤吉とは子供のときの手習い朋輩といい、両方がおなじ釣り道楽の仲間であるので、ふだんから親しく往きかいして、岡釣りに沖釣りに誘いあわせて行くことも珍らしくなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "町内の家台囃子の音も沈んできこえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "お化け師匠のおそろしい名が町内にひろまって、弟子たちもだんだんに寄り付かなくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは町内の経師職の伜で、弥三郎というんです」「師匠の家へ出這入りすることはねえか」「去年までは毎晩稽古に行っていたんですが、若い師匠が死んでからちっとも足踏みをしねえようです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の送葬のときに私も町内の附き合いで行ってやったから、よく知っています」「むむ、妙信寺か」　源次に別れて、半七は御成道の大通りへ一旦出て行ったが、また何か思いついて、急に引っ返して広徳寺前へ足をむけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝、半七は師匠の送葬の様子を窺いながら妙信寺へ出かけてゆくと、師匠の遺骸は駕籠で送られて、町内の者や弟子たちが三四十人ほども付いて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祭りはどうしても夜のものですよ」　老人に案内されて、わたしは町内の飾り物などを観てあるいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "御代参をたのまれたのは、町内の古着屋のおっかさんに……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり同じ町内の酒屋の下女で、今年二十一になるお伝というのが、裏手の物置へ何か取り出しにゆくと、やがてきゃっという声をあげて倒れた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "町内の医者もすぐに来たが、お作は何者にか喉笛を啖い破られているので、もう手当てを加える術もなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの詮議はそれだけにして、半七は更に同町内の酒屋をたずねた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゆうひやら／＼と角兵衞獅子、暢氣に懷手で町内を囃して通る。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両側に軒の並んだ町ながら、この小北の向側だけ、一軒づもりポカリと抜けた、一町内の用心水の水溜で、石畳みは強勢でも、緑晶色の大溝になっている。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば収賄の嫌疑で予審中でありながら○○議員の候補に立つ人や、それをまた最も優良なる候補者として推薦する町内の有志などの顔がそれである。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉服屋の豊田さんなら、私の家と同じ町内でしたから、私はよく知っているのです。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比野の家は、この町内で子供達が遊び場所にしている井戸の外柵の真向いで、井戸より五六軒｜距ったお涌の家からはざっと筋向うといえる位置にあった。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "町内のどの家と交際しているということもなかった。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
