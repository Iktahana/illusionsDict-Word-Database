        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その朝は、もう病人の爪先を紫色に染めて、チアノーゼが來てしまつた。",
              "citation": {
                "source": "彼女こゝに眠る",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうチアノーゼが薄く現われていましたし、身体もずんずん冷えて行くようでした。",
              "citation": {
                "source": "赤耀館事件の真相",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し続けてやればすぐにチアノーゼを起しそうだった。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "否既に軽微なチアノーゼは起していた。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "肝臓は充血し、腎臓は大でチアノーゼあり、他はすべて正常である」　つぎに頭部を解剖し、頭蓋骨、脳及び脳膜に、一部、不整発達、一部、慢性炎症による退行変性を認めたと言っている。",
              "citation": {
                "source": "泡沫の記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ず手足だよ」　凍傷にも三段階あって、血の気を失って白くなるのを一度、紫色のチアノーゼが二度、三度は炭化して真黒になってしまう。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "カメレオンは強烈なチアノーゼに罹つた。",
              "citation": {
                "source": "希臘十字",
                "author": "高祖保",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身痙攣が激しく起り、チアノーゼが口唇や指先に著明となる。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
