[
  {
    "uuid": "6ca5e228-4005-5414-88d4-4f61e7f4a52e",
    "entry": "仲介者",
    "reading": {
      "primary": "ちゅうかいしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
