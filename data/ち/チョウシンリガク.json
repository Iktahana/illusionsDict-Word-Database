        "examples": {
          "standard": [
            {
              "text": "超心理学は、科学界ではまだ主流とは認められていない分野だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は超心理学に興味を持ち、関連書籍を読み漁っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "超心理学の研究では、ESP（超感覚的知覚）の現象がしばしば取り上げられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "デューク大学の「超心理学」実験室長ライン博士の著書の紹介である。",
              "citation": {
                "source": "心霊現象と科学",
                "author": "――『心の領域』について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "超心理学というのは、従来の心理学の範囲を超越した心理現象を研究する学問という意味であろう。",
              "citation": {
                "source": "心霊現象と科学",
                "author": "――『心の領域』について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この超心理学に類似の「学問」は、以前からもあったので、何も珍しいことではない。",
              "citation": {
                "source": "心霊現象と科学",
                "author": "――『心の領域』について――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
