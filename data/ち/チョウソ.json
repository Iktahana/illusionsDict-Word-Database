          "standard": [],
          "literary": [
            {
              "text": "その後『文章世界』で読者から紀行文家を投票させて、最高点を得た人に、彫塑かまたは油絵肖像を贈呈するということであった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは画家や彫塑家の評論を遣る外は大抵抒情詩を遣っているのでしょうね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために前記諸氏の間で色々評議を重ねているところへ古賀得四郎氏の友人、春吉の医師松田盛氏の紹介で糸島出身の彫塑家津上昌平氏がこの評議に参加した。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "事は故翁から習ったに過ぎない一教授佐藤文次郎氏の謝恩の一念から起り、全くの赤の他人である彫塑家津上昌平氏の感激から来た犠牲的熱意によって完成された事業である。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "因に同銅像は昨秋十月旧門弟一同発起となり一月着工、胸像は福岡県糸島郡出身彫塑家津上昌平氏の献身的努力により作製されたものである。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彫塑の妙――生への執着の数万の、デッド、マスク！",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "是等の美術書の大部分は巴黎の「リブレール・ド・ボザール」や「デューシエ」や独逸の「ヘスリンク」から此頃新着したばかりのもので、各種の図案粧飾、又は名画彫塑の複製帖等、何れも精巧鮮美、目も覚めるようなものばかりであった。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その背中の下の方には現在の帝室技芸員で、帝展の審査員として日本一の有名な彫塑家、朝倉星雲氏のお名前がハッキリと彫り込んで在るのでした。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かの序にコッソリと上京して朝倉星雲先生にお眼にかかって、その彫塑の由来をお尋ねになると、何も御存じない星雲先生はアッサリとお答えになったそうです。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちこれを詩章の竜葢帳中に据ゑて、黒衣聖母の観あらしめ、絢爛なること絵画の如き幻想と、整美なること彫塑に似たる夢思とを恣にしてこれに生動の気を与ふ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏蘭西の詩はユウゴオに絵画の色を帯び、ルコント・ドゥ・リイルに彫塑の形を具へ、ヴェルレエヌに至りて音楽の声を伝へ、而して又更に陰影の匂なつかしきを捉へむとす。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち之を詩章の龍葢帳中に据ゑて、黒衣聖母の觀あらしめ、絢爛なること繪畫の如き幻想と、整美なること彫塑に似たる夢思とを恣にして之に生動の氣を與ふ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "佛蘭西の詩はユウゴオに繪畫の色を帶び、ルコント・ドゥ・リイルに彫塑の形を具へ、※ルレエヌに至りて音樂の聲を傳へ、而して又更に陰影の匂なつかしきを捉へむとす。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "女優のサラ・ベルナアル、平和論者のラ・フオレツト、彫塑家のロダン、著作家のバアナアド・シヨオ、それから今一人支那の伍廷芳――といつたやうな人達は、揃ひも揃つて皆菜食主義者である。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "銅像は彫塑家の手際で何うかすると、拙いものが出来上るが、樹木はどんな場合にも傑作となるものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い彫塑家大国貞蔵氏の父で、釜師としての伎倆は、まづ当代独歩といつて差支へあるまい。",
              "citation": {
                "source": "茶話",
                "author": "大正十五（一九二六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "青蓮堂に藤左衛門の像、護法堂の有名な彫塑大布袋、大方丈の沈南蘋の牡丹の絵などを見せて貰った。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブレークは、近代派の彫塑家で、きわめて富裕な大理石商の息子である。",
              "citation": {
                "source": "『この心の誇り』",
                "author": "――パール・バック著――",
                "note": "青空文庫"
              }
            },
            {
              "text": "護法堂の布袋、囲りに唐児が遊れて居る巨大な金色の布袋なのだが、其が彫塑であるという専門的穿鑿をおいても、この位心持よい布袋を私は初めて見た。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、ルバシュカを着た、頭に禿のある豆蔓のやうに脊丈のひよろ／＼した中年の彫塑家が編輯してゐた。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵が主であるけれど、彫塑や其他の工芸美術品も対等の取扱を受けて毫も会自身に価値を定めようとする所が無く、全く観衆の批評に一任して居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日本人に仏蘭西語を解してる人の多い様に遠からず日本語を解する仏蘭西人が沢山に出来て、自分の知りたいと思つて居る日本の芸術を紹介して呉れる事を望んで居る」と云ひ、歌麿の絵を眺めて「彫塑の行方と似た行方をして居る」と評し、又荻原君に対する批評を繰返して「彼の製作には運動があつた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁の談話中に多年｜巴里に学んで居る彫塑家藤川勇造君の製作を近頃観たと云つて激賞して居た。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文士や画家や彫塑家の寄合所になっていた、小さい酒店が幾つもあったが、それがたいてい閉店してしまって、そこに出入していた人達は、今では交際社会の奢った座敷に出入している。",
              "citation": {
                "source": "田舎",
                "author": "マルセル・プレヴォー　Marcel Prevost",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭上の紫藤は春日の光りを揺りて垂れ、藤下の明子は凝然として彫塑の如く佇めり。",
              "citation": {
                "source": "開化の殺人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "アトリエに籠って、彫塑の泥土をこねまわさねばならない。",
              "citation": {
                "source": "女客一週間",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
