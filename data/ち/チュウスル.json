[
  {
    "uuid": "e4cd6c09-1b74-59aa-b297-bb0df98eabe3",
    "entry": "注する",
    "reading": {
      "primary": "ちゅうする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to annotate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "近頃｜和蘭グロニンゲンのカプタイン博士等は、従来多年の観測の結果を綜合して精細な研究を遂げた末に、天体に散布せる諸恒星は自ずから二派の流れに分れている事を発見した、すなわち天体各部の星の運動が目指す方向を反対に延長して見るとほぼ定まった二つの星座に集注する。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしもわたくしの同棲者も元来が或る信念の上に立つと従順な人間になり生活意識や情操が一所に集注するたちと見えます。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその装幀と※画のために、彼のすべての「生命の残部」を傾注することを約束された。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベーアはできるだけエネルギーを節約し貯蓄しておいて、稀有な有利の瞬間をねらいすまして一ぺんに有りったけの力を集注するという作戦計画と見られた。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十回目あたりからベーアのつけていた注文の時機が到来したと見えて猛烈をきわめた連発的打撃に今までたくわえた全勢力を集注するように見え、ようやく疲れかかったカルネラの頽勢は素人目にもはっきり見られるようになった。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して数百数千の細流は其中心より出でゝ金環を周綴し、而して又た再び其の金環より中心に帰注するものなり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか二銭の使賃を貯蓄したのでもあるまいが、一匹の人間が持っているだけの精力を一時に傾注すると、実際不可能な事はなくなるかも知れない。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、詩作その事に対する漠然たる空虚の感が、私が心を其｜一処に集注する事を妨げた。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、詩作その事に対する漠然たる空虚の感が、私が心をその一処に集注することを妨げた。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへ自分は嫌はれてゐたとしても、あの白い肌が今では自分の物だと云ふ形になつてゐるからいいやうなものの、一度でも他の男の手に觸れたら――足に觸れたら――毀われた人形も同樣、もはや自分の愛情をそれに傾注することが出來る望みは全くなくなるのである。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が私のやうに、全力を傾注する仕事を有たない人間には、この事が何時も意識されて仕方がない。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本を読み出すと、秀麿は不思議に精神をそこに集注することが出来て、事業の圧迫を感ぜず、家庭の空気の緊張をも感ぜないでいる。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは十九のとき漢学に全力を傾注するまで、国文をも少しばかり研究した名残で、わざと流儀違いの和歌の真似をして、同窓の揶揄に酬いたのである。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、明かに矛盾した特性をことさらに並べて、対照の結果読者の注意をこの二焦点に集注するからであります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "フロレンスは、二十五歳で、看護婦の仕事こそ自分の全力を傾注するに足る社会的な事業だと思いきめたのであった。",
              "citation": {
                "source": "フロレンス・ナイチンゲールの生涯",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "経済的・政治的活動に全生活と精力を集注する大部分の組合員と、その一部にはいわゆる文学趣味も滲透している文学サークルの人々との間に、同じ働く人々ながら、現実に向う感情には、いくらかのくいちがいも生じた。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうでなければ、全心全力を傾注する、全人的な、最も眞率眞劍な、最も無餘裕な肉靈｜合致を悲痛の自我に實現することは出來ないこと。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三百六十六　明治乙亥十一月十日に森枳園が棠軒に与へた書は、既に注する所を除いて、猶枳園の壬申以後の内外生活を後に伝ふるものとして尊重しなくてはならない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る人は、それをボルゾイ犬に傾注する。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、いわゆる死点とは反対に、鐘鳴器特有の唸りを一点に集注する――。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己の訓練、作品をまとめるときの心得、手に入れることなどではなく、もう一歩、それらのあらゆるものをどの方面に集注するかと云う点。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとなれば彼らは深く深く生きてもはや彼らの生活の最大関心は罪の問題に集注するところまできた。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月三日　水“潜行８氏は□の庇護にはいってしまってもう手がつかないから、これからはもっぱら国際派――宮ケンさんに集注する方針です”そう申した由。",
              "citation": {
                "source": "日記",
                "author": "一九五一年（昭和二十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍ君は綱島梁川君の言として、先ず神を見なければ一切の事悉く無意義だ、神を見ずして筆を執るなぞ無用である、との説に関し、自身の懊悩を述べ、自分の様な鈍根の者は、一切を抛擲して先ず神を見る可く全力を傾注する勇気が無い、と嘆息して帰った。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鄭玄なども經書を注する時に、古文の禮制と今文の禮制とが符合せない場合には、多くは今文のものを殷の禮であるとして解決した。",
              "citation": {
                "source": "爾雅の新研究",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "人種の改善に力を傾注すると云ふことは『恋愛と結婚』の中に私が説明して置いた通り現在の渾沌たる恋愛の状態より単一個人的恋愛に至る橋梁を架設するが如きものである。",
              "citation": {
                "source": "恋愛と道徳",
                "author": "エレン・ケイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾妻橋両国橋等の眺望は今日の処あまりに不整頓にして永代橋におけるが如く感興を一所に集注する事が出来ない。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう気がしょっちゅうする。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "美術にねっちゅうするあまり、お嫁さんももらわず、したがって子どももなく、ただ名画の番人に生まれてきたような生活が、ずっとつづいて、いつしか六十の坂をこしてしまったのでした。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
