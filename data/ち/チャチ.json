        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "芝居裏の二枚看板、ちゃちなぽん引にうっかりつれこまれようとして、あわてて羽織｜芸妓の裾のもとをかいくぐって、食傷路地に出てくると、鶴源の板前が瑪瑙色に塗った魚類の食楽地獄だ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃちな小利巧の仲間。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小豆島と高松を往復する一〇〇｜噸足らずのボロ汽船であったが、彼の石炭のいれ方がちゃちだから船が進まんと、罐の前でへっぴり腰を蹴り飛ばされた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅん子なんて、物心地のつかないうちに、もう東京へ来て山形の見事な雪景色を知らないから、こんな東京のちゃちな雪景色を見て騒いでいやがる。",
              "citation": {
                "source": "雪の夜の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳酷、その奥底には、人間の本然の、あたたかい思いやりで一ぱいであるのだが、冷酷は、ちゃちなガラスの器物の如きもので、ここには、いかなる花ひとつ、咲きいでず、まるで縁なきものである。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたちの間抜けにしんから閉口して居ると、私の中のちゃちな作家までが顔を出して、「人間のもっとも悲痛の表情は涙でもなければ白髪でもなし、まして、眉間の皺ではない。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "折井は神田でちゃちな与太者に過ぎなかったが、一年の間に浅草の方で顔を売り、黒姫団の団長であった。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぞろりと着流しの上へ総絞りの兵児帯を結んだ男の恰好はいかにもちゃちな与太者めいていたが、歩を移すたびにその結び目が尻の上で揺れるので、うしろから見て豹一はふとおかしくなった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピエロ・ガールスに悪漢はちゃちな海賊船ほどいるがね、あのいたいけな、なよなよした、可憐な東銀子のような娘を食うのは、ピエロ・ガールスひろしといえど、貴様のような助平爺ひとりだ！",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしここだけの話、ウィンディバンクさん、これほど残酷で身勝手で心のない、ちゃちなごまかしに出会ったのは初めてです。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "投銭にはちゃちゃらかちゃんなんて古風な流行唄をやってますが、可い声で、ぞッとするような明烏をやりますんでね。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年留年して一九七六年に大学におさらばしてまもなく、日本電気の半導体屋がマイクロコンピューターにちゃちな16進のキーと８桁のＬＥＤをくっ付けて、トレーニング・キットと称するオモチャを出した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベッドは木製でひどく大きく、ちゃちなスプリングなど附いていないのが、かえってたのもしく、両側には引出しやら棚やらがたくさん附いていて、身のまわりのもの一切をそれにしまい込んでも、まだ余分の引出しが残っているくらいだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの血のめぐりもちっとばかり鷹揚かもしれねえが、これに気がつかねえたア粂五郎もちゃちな野郎だね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくよく、ちゃちな野郎だね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこからどこまでもちゃちな野郎じゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "比丘尼行者が祈祷を売り物にする住まいなら、玄関出入り口の構えなぞ、少しは神々しいこしらえでもしてあるだろうと思いのほかに、いたってちゃちな、ただのしもた屋でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "越後から米つきに頼まれたんじゃあるめえし、こんなちゃちな詮議にのこのことお出ましになりゃ、貫禄がなくなりますよ、貫禄がね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "やけにまたちゃちなお殿さまだね」「バカをいっちゃいかんよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "しごきぬすっとの元締めさんは、ちゃちな青造さんだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべ八丁堀へこかし込んだあのちゃちなおどし文のなぞが、それでようやく新芽を出しやがったわい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれはちゃちな野郎だろうが、念のために首実検しようかい」　おどろきもせず、たれのあわいからのぞいてみると、これが早い、――年のころは三十七、八、町人づくり。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方厳しいコストの切り下げを求められる電卓では、ちゃちなキーボードが生じさせるチャタリングを、ソフトウエアで判定してキャンセルしてしまう工夫が進められていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在自分の住家はどんなものであるかと云うと世間に普通一般に住家と言われているものと比較すればそれは、もう住家と云う事さえ出来ない様なちゃちなものである。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "束髪の娘は英語の教師に走り、結綿は駈落ちするところを、小僧の亀どんが見つけて騒ぎ出したので、かえっておおかめさんに叱られたのだといったが――末の子の、おっちゃちゃんが亡くなると、思い出してしようがないから、おないどしのあんぽんたんに遊びに来てくれと、贈りものをよこしては迎いにきた。",
              "citation": {
                "source": "鉄くそぶとり",
                "author": "続旧聞日本橋・その二",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあ、誰しも嫌な口の端あ御免だからのう、お前さんがひた隠しなさろうてなぁもっともだけれど、眷属さまにしちゃちっと仕事が荒っぽいぜ。",
              "citation": {
                "source": "助五郎余罪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが大きな柱だったり、鉄材に木ネジでとめてあるのだったりすれは、木ネジの方が折れてはなれてしまったことであろうが、その船は、ちゃちな艤装のために、鉄材と扉の間にすきが出来、厚さ三四センチのうすい板の柱のように間につめこんであったのだ。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちゃちゃんと実地を踏んで来ているんだもの」と、さっきまで教育に対して多大の尊敬を払っていた事はまるで忘れたような風で、無遠慮なきめつけ方をした。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "空襲の焼跡に出来たらしい狭い街路で、ちゃちなバラックの軒並だが、おでん、うどん、すいとん、みつまめ、コーヒー、煮物など、各種の飲食物の小店に、ガチャンコの遊び場まで交っていて、まばらな人影が動いている。",
              "citation": {
                "source": "ヘヤーピン一本",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃちゃん省略する手ぎわに感服。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
