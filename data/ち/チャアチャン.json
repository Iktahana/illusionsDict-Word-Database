        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ちゃあちゃん、今日のご飯なあに？」と子供が聞いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "幼い頃、ちゃあちゃんに絵本を読んでもらうのが大好きだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ちゃあちゃんの優しい声が、今でも耳に残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "母親以外の親しいものを呼ぶにも、「ちゃあちゃん」としかまだ言い得なかった。",
              "citation": {
                "source": "伸び支度",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな幼い子供が袖子の家へ連れられて来てみると、袖子の父さんがいる、二人ある兄さん達もいる、しかし金之助さんはそういう人達までも「ちゃあちゃん」と言って呼ぶわけではなかった。",
              "citation": {
                "source": "伸び支度",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
