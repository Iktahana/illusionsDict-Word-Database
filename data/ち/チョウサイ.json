  {
    "uuid": "eb258a38-8b06-5675-b9ed-b351c9fe349a",
    "entry": "冢宰",
    "reading": {
      "primary": "ちょうさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Minister of State (Zhou dynasty China)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "周王朝における『冢宰』は、宰相に相当する重責を担っていました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "周代の官制について『冢宰』の役割を詳しく調べる必要があります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "『冢宰』は、諸侯の統制や国家の運営において、王の右腕として機能した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "其次に御史であります、御史は邦國都鄙及び萬民を治むることを掌ると云ふことを書いてありまして、これは周の時の冢宰の副官になるのだと云ふことを書いてあります。",
              "citation": {
                "source": "支那に於ける史の起源",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
