  {
    "uuid": "62df7571-c08c-57a4-8342-3f190e0928eb",
    "entry": "肇歳",
    "reading": {
      "primary": "ちょうさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
