[
  {
    "uuid": "8bb3f23d-ef06-5bb5-88e6-bf15aa104275",
    "entry": "宙を飛ぶ",
    "reading": {
      "primary": "ちゅうをとぶ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
