        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すぐ背後の土間じゃ七十を越した祖母さんが、お櫃の底の、こそげ粒で、茶粥とは行きません、みぞれ雑炊を煮てござる。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝簡單に茶粥で濟ませる。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶粥二椀、牛乳一合、その用ゐ方は殆んどオート・ミイルの場合と同じだ。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良の方の寺では茶粥に里芋をまぜるといふ話をある人から聞いて、それも試みたことがあるが、すこし味が重くなるかと思ふ。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯は茶粥、大根がうまくなつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷をあらかた送り出して明日立つという前の朝、清子は久し振りで茶粥を炊いて姑と二人で味わった。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この茶粥は良人が好物だった。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "清子の茶粥は善福寺の老和尚からの直伝である。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七　茶粥　と申すのは至て淡泊なもので、これは最初によくほうじた番茶を袋に入れて水と一緒によく煎出して一旦その袋を揚げます。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "外の地方で茶飯というと前にある茶粥の通りに煎じ出した汁で御飯を炊きます。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼処の家では顔の映るような茶粥を喰べているという形容が起って来ますが、お分りですか？",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼処の家は貧乏だということをそう申します」「芭蕉の句の『馬に寝ねて残夢月遠し茶の烟』というのがその茶粥を炊く煙だそうですが、一体何んなもんですか？",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに麦を交ぜたのを麦茶粥といいます。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小豆を入れたのが小豆茶粥、芋を入れゝば芋茶粥です」「麦茶粥に小豆茶粥に芋茶粥と。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナカ／＼種類がありますな」「まだ餅茶粥というのがあります。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは主に冬分寒さ凌ぎに喰べます」「餅茶粥と。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "餅茶粥は寒さ凌ぎと。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊賀の人でしたが、この日は特に茶粥を控えました。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本さんの指金か、女中はニヤ／＼笑いながら茶粥のお給仕をした。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "距離から言うと伊賀の上野の茶粥以来大和の奈良まで一口も喰べないのだから実際空腹だったが、お蔭であれから二月堂三月堂大仏と目ぼしいところは大抵見てしまって、土地のお話を聞く下拵えが悉皆出来ていた。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶粥も……」「豆茶粥でございましょう？",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と眼鏡をかけた浮塵子は稍※驚いて、「その豆茶粥の稀薄なのをこゝの百姓は日に四度も五度も啜ります。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
