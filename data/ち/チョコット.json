        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ほらほらウィルソンの旦那、申し込みたいんだったら、ちょこっとそこに顔を出しゃいいんですが……旦那がたかが二、三百ポンドの金で出向かれることもないですよね。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は、鉄道敷地から、すぐ下の報償道路の上へ、そうっと落とそうという心算で、金挺でちょこっとこじたのだった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょこっとだけ　まどを　あけて　そこから　ものほし用　ロープの　大半を　外へ　おしだします。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやゆびトムは　ちょこっと　あたまを　つきだして　そのあと　ぴゅっと　ひっこめます。",
              "citation": {
                "source": "わるねずふたりぐみのはなし",
                "author": "THE TALE OF TWO BAD MICE",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の中にちょこちょこっとすませるからいい。",
              "citation": {
                "source": "一つ身の着物",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかもブラチが電光石火に器用な絵描きの手腕を発揮したかのようで、似顔絵を作成するのに、炭で線をちょこちょこっと引き、大胆な一筆を加え、顔を想像できないほど変化させた。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
