[
  {
    "uuid": "c2578c3b-d442-5674-b1c6-99afcafd4fa1",
    "entry": "血潮",
    "reading": {
      "primary": "ちしお",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
