    "definitions": [
      {
        "index": 1,
        "gloss": "thing of medium quality",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
