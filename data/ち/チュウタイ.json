[
  {
    "uuid": "d407a363-e565-598f-bda4-c17a29e8e319",
    "entry": "中退",
    "reading": {
      "primary": "ちゅうたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "leaving school during a term",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのくせ帝塚山の本宅にいる細君は女専中退のクリスチャンだった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして神戸大学文学部を中退して、米朝に入門。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は私の傷は一週間前までは非常に良経過にて、この様子ならば近日中退院して温泉へ行けと部長も言っていたのです。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに述べられて居る通り、彼は絵描きになりたくて、学校を中退してパリに連れていって貰った訳であるが、このパリ時代が、彼と辻潤が長時間一緒に暮らした唯一の時代である。",
              "citation": {
                "source": "え゛りと・え゛りたす",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学に飽き飽きしていたアレンは、中退してこの申し出に飛び付いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七六年十一月、アレンはＭＩＴＳから籍を抜き、翌一九七七年の一月にはゲイツがハーバード大学の中退手続きをとった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "高校を中退したあと、湾岸警備隊に潜り込み、第二次世界大戦後は機械工を経て自動車ローン関係の金融会社に籍を置いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（女中退場）みんなが、なにかを云ひ出さうとして、さて何も云ひ出すことのない、一種の気づまりな瞬間。",
              "citation": {
                "source": "歳月",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子大中退という教養もかなりの人で、こんなところで働くのがフシギと申すほかない麗人でした。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「中学校中退です。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたり前に云えば、女学校を自発的に中退したのも不真面目かも知れないし、学校中、欠課や欠席をして、映画をみたり、京都や奈良を散策したことはやはり不真面目。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『植物記』の中にうかがわれるこの言葉、植物への限りない愛情――小学校中退後貧苦と戦いながらも、独学で植物分類の世界的権威となり、八十七歳の今日｜猶日夜研究にいそしまれる老科学者牧野富太郎先生、われわれは四月十八日当地の植物採集会に臨まれた先生からいろいろのお話を聴く機会を得たのである。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "キミエは荒巻が学校を中退して故郷へひッこむということを知り、学校を卒業したら結婚するという口約の実行をせまるために彼の姿を探していたのであるが、すでに男に裏切られたことは明かであるから、顔に硫酸をブッかけて恨みをはらすのが目的であった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "業半ばに中退とはいえ、帰郷後は就職して一家をなすのであるから、やがてはめとる妻であり、彼はヒサに駈落ちを申しこんでいた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "同四十三年（一九一〇）二十五歳で岡山第六高等学校中退。",
              "citation": {
                "source": "わが愛する詩人の伝記（三）",
                "author": "――萩原朔太郎――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき女子薬専を中退したばかりの君代が、派出看護婦で来ていた。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕常に戯れて僕は三田の塾は中退したが堀口大学は卒業したと。",
              "citation": {
                "source": "分身の感あり",
                "author": "第二部　堀口大学",
                "note": "青空文庫"
              }
            },
            {
              "text": "同四十三年（一九一〇年）二十五歳で岡山第六高等学校中退。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓは郷里の中学を中退して、東京のある中学へ通っていたが、酒は一流で、時々ぼくを誘って、近所のカフェーで飲んだ。",
              "citation": {
                "source": "酒友列伝",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "素顔君は容貌も体格も立派な人であるが、中年から失明して同志社を中退し、祖先の家を守る傍ら俳句を泊雲君に手引してもらつてゐたのであつた。",
              "citation": {
                "source": "椿子物語",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、家の没落が、父自身の口からあきらかにされ、同時に、学校は中退しろ、他家へ奉公に出ろ、と突然云い渡されたのだが、その日その時まで、全然、何も知ってはいなかった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、中退して新聞社にはいったのが、明治が大正と改まる前年である。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "きいてみると、三十五円也というのは、大学卒業生の相場で、私は中退だから、というのである。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "抱琴は、虚弱のために一高を中退して外語に転じ、のちに試験を受けて東大へはいった。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、子規は中退してしまったが、同じく大学を半途でやめた私は、この手紙が身につまされてならぬのだ。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学を中退した私が、新聞社へ自分を売りこむ時「劇評も書ける」というのを一つの特技にした。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身が父親に死なれて、大学を中退したり、新聞記者になったり、まごまごしていた頃の子供だが、どこか器用なところがあって、手工では、いつも学校でほめられた。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "実科女学校中退、年もゆい子より二つ若かった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
