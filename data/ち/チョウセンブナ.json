        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "朝鮮鮒と金こと云う和鮒と鯊と、川蝦をとった。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、正吉くんは、あかずに、ちょうせんぶなのダンスをするのをながめていました。",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おじいさん、ちょうせんぶなあるの？",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さん、ちょうせんぶなを買うのだからお金をちょうだい。",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょうせんぶななんてあるのですかね。",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といって、小田くんのところで見てきたちょうせんぶなの説明をいたしました。",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "正ちゃんは、ちょうせんぶなを買ってきてどこへ入れるつもり？",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうせんぶななんか入れては金魚をみんな食ってしまうじゃないの。",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "太田さんのお家にもちょうせんぶながいたけれど、おなかがすくと、共食いをはじめて、強いちょうせんぶなが、ほかの弱いのをみんな食べてしまったというのよ。",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、いやなちょうせんぶななんかかわなければね……。",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼく、小ばこをくれれば、ちょうせんぶななんか買わないよ。",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
