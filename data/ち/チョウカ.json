[
  {
    "uuid": "9eab6c73-844a-5027-8b5f-1b568d5f2d79",
    "entry": "弔歌",
    "reading": {
      "primary": "ちょうか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "elegy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "若しや犯人は、我れと我が殺害した死人を弔う為に、横笛の弔歌を奏で、野菊の花束を贈ったのではないだろうか。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっそく陣々に喪旗を立て、弔歌を奏でて、周瑜死せりと噂するがいい」と、いった。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜩の声は、壮年期の弔歌に聞え、都を中心とする時の潮鳴りが、山の静寂とは逆に、心へ底波を打ってくる。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅なかまは、れいのはくちょうから切りとった二枚の大きなつばさを、しっかりと、肩にいわいつけました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はどうなることかと身震いをしていますと、『なんだ、こんなつまらないちょうか。",
              "citation": {
                "source": "ちょうと怒濤",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "がちょうからすこしはなれた小さなふとんの上には、一匹の白ねこが横になっていた。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
