[
  {
    "uuid": "781f206b-1ba2-5937-bdc5-f79b4de9d3f3",
    "entry": "勅諚",
    "reading": {
      "primary": "ちょくじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
