    "definitions": [
      {
        "index": 1,
        "gloss": "blood, sweat and tears",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
