[
  {
    "uuid": "8bd304a5-0b4f-5f27-8b5a-5310e34e0c40",
    "entry": "沖積",
    "reading": {
      "primary": "ちゅうせき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
