          "literary": [
            {
              "text": "」　ムシュー・ガベルはそこの宿駅長であって、他に何かの徴税吏をも兼ねていた。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は徴税吏をも兼ねている。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夏ニューポートに於いて徴税吏のスループ船リバティ号が焼き討ちにあったことに憤慨して、ウォレス提督麾下の税関艦隊は未知の船舶に対するその警戒活動を強化していた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "当然、各地とも、徴物使（徴税吏）の取立てが、苛烈を極めた。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
