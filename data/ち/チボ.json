        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まあぼちぼち行けといふほどの心持である。",
              "citation": {
                "source": "自分のこと",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜光虫が美しく光る海を前にして、Ｋ君はその不思議な謂われをぼちぼち話してくれました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まあぼちぼちだ」「落ちついているね」「例のところでまだ引っ掛かってるんだ。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふは敬坊帰省の日、きつと寄つてくれると、行乞もやめにして待つてゐた、待つて、待つて、待つたあげくは待ちぼけで寝た、――と呼び起す人がある、敬坊だ、お客がきてやつてこられなかつたといふ、酒、酒、よい酒だつた。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "デカルトあながちぼんくらじゃないと思ったのだが、「羞恥とはわれに益するところあらむと願望する情の謂いである。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると　うさぎは、「そんなら　おきょうの　かわりに、むこうの　ほそみちぼたんが　さいたと　おうたいよ。",
              "citation": {
                "source": "こぞうさんの　おきょう",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、うさぎの　おしえて　くれたように、ほとけさまの　まえで、むこうの　ほそみちぼたんが　さいたさいた　さいたぼたんが　さいたと　かわいい　こえで　うたいました。",
              "citation": {
                "source": "こぞうさんの　おきょう",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は最近また、ぼちぼち読み直してみているんですけれども。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は、どうしてそんな、ぼちぼち読み直しているなんて嘘ばかり言うんだね？",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これから、また、ぼちぼち八犬伝を読み直すのだから。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、それもたちまちぼろりとちぎれてしまいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の手は、たちまちぼうぼうと四方へ燃え広がりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つちぼたるが、そのぐるりを、空に舞っているちいさなともしびのように、ぴかりぴかりしていました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと眼瞼がかすかに震え、たちまちぼんやりとはげしい恐怖のショックが電気のように走り、血が顳※から心臓へどきどきと流れる。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私は信じよう、お麗さんは芸術の理解者なんだ、待ちぼうけを喰はすやうなことはないよ。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "集会所には朝の中から五十人近い小作者が集って場主の来るのを待っていたが、昼過ぎまで待ちぼけを喰わされてしまった。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おちぼひろひ、――とみかうみかつ涙ぐむ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おちぼひろひ、――うらびれてわが世は寂びぬ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おちぼひろひ、――見入りてはまた涙ぐむ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はものの四十分もまちぼうけをくった。",
              "citation": {
                "source": "頭と足",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃ騒ぎも大きくなって、おれがなんで死んだかもお調べがつき、そのうちにはきさまらのやっていることも、ぼちぼち世間に知れるにちげえねえんだからな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わはははは、とうとう今夜は待ちぼけくったか」「え？",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもしろくもねえ、待ちぼけくったとは何がなんですかよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こうさまのごつごうで待ちぼけくわされたんだから、おいらに文句をいったって知らねえよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "としたら、今夜は如の字の祈りをするだろうとにらんで、さっきお山の青道心に教えられたこの三ツ又稲荷のあなへ伏せ網を張ったのになんの不思議もねえじゃねえか、おあいにくなことに待ちぼけくったのは、あな違いだっただけのことさ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "「音を出しちゃならねえぞ」　伝六を伴ってずかずかとはいっていったところは、最初の夜に伏せ網を張って待ちぼけ食わされた、あの三ツ又稲荷の境内奥の、しんちんとぶきみに鬼気迫るほこらのうしろです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう小作人は地主様を当てにして、何んとかして下さるだろう、と待っていたら、百年経ったって待ちぼうけを食うのが落ちだ。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なに、君の方が僕に待ちぼうけを食はせたのぢやないか。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「え、待ちぼうけだつて。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
