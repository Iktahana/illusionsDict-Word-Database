        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてコヽアでも買つて来て立てゝあげるわ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――あゝら、ぢやあたしコヽアの方が好いんだけれど今度来る時は紅茶の方買つて来るわ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "リヽーン、リヽーン！",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "早春の淡紫に湿つた土の上で、独楽はチリチリヽヽといふ微かな音を立ててシンミリ廻つた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「フヽヽ、言ふと、みんなが呉れ呉れ言ひ出すから嘘を言ふちやつたい。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハヽヽ、君はまだ前以上に、今度は大きい意味でこだはつたのだよ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ学校のことも勉強なさいよ」「えゝ……ハヽ……」「文学のことばかりせずに……」　汽車が支線の終点駅に着いた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「来週の何曜日に来るのです」「アハヽヽヽヽヽヽ」「あゝあたし彼方から廻る電車に乗りたかつたのに……」　彼が行かうとした停留場の間際まで来てＳ子はジラ半分にさう言つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりようやく薄暗く工夫体の男｜甲走りたる声張り上げて歌い出せば商人の娘堪えかねてキヽと笑う。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源はフト郭光との話を止めて上機嫌で「アヽそうか、すぐこれへ」と口ばやに言つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源は二人の言葉の終るのを待ち遠しそうにして「アヽよし／＼両人とも大儀であつたナ」と言つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう五十の齢にも及ばうとして居る謝源も前後を忘れて「アヽ愉快だ※」と叫びたくなつた程であつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「失礼でございませうが、私は日本の酒は飲めないんで……」と言つて、「イヒヽヽヽ」と追従笑ひをした。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとせっかくの歌の口調が消えてしまって「ムヽヽヽヽ」とか「アヽヽヽヽ」とかいう妙なものになってしまう。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
