  {
    "uuid": "6dea8802-6c67-5c5f-a830-f2a52f0b0201",
    "entry": "デス",
    "reading": {
      "primary": "デス",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "death",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "アノイワレハ可愛ラシイモノデス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "デスカラ身体ヲ大事ニスルヨウニクレグレモ願イマス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "早ク見タイモノデス』という焼津の手紙でも解るように、妻と同伴することなしには、どんな旅行も楽しくないほど、夫人を熱愛していたからだった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "正にドビュッシイが言ふやうに、ベートーベンはデスクリプションした。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに彼の叫びの強烈さがデスクリプションを表現的にしたのだ。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、純粋にエステティクに言つて、デスクリプションよりも進んだものとは言へる。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに、事実歌ふ場合に、人は全然トンポエムにもなれない、又全然デスクリプションにもなれない。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでアインシュタインが出て来てコロンバスの卵の殻をつぶしてデスクの上に立てた。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アサデス　ツユノ　ヒカルミチコブヲ　トラレタ　オヂイサンツマラナサウニ　ホホヲ　ナデオヤマヲ　オリテ　ユキマシタ　瘤は孤獨のお爺さんにとつて、唯一の話相手だつたのだから、その瘤を取られて、お爺さんは少し淋しい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人がアンデスの登山を悦ぶのは、麓が永久の春であるからだそうだが、山の天国は、発達した裾野を有するところの、富士火山帯に多くあらねばならない。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "空中で雪の始めて出来る処の高さは土地によって非常の差があって、例えば南米のアンデス山あたりでは一万八千尺ほどの処にあるが極北に近くなれば千尺くらいの処もある。",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の中だし、アルキメデス、水の中だし、動く動く。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、「シーザーとカティリナとアルキビアデスとが顕著な典型を提供する」もので、ほとんど男性に限り適用される意味内容である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルダス・ハクスレーの短篇『若きアルキメデス』には百姓の子のギドーが木片の燃えさしで鋪道の石の上に図形を描いてこの定理の証明をやっている場面が出て来るのである。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても古代に溯りたいなら、せめてサイラスやアルタセルキセスなどは節約して、文化に貢献したアルキメーデス、プトレモイス、ヘロン、アポロニウスの事でも少し話してもらいたい。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ステッキはコチラデスヨー」などという極めてプロレタリアンな声が、労働階級の細君ででもあるらしい下足番の口から響いて来る。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また同台からは一隊の学者をアンデス山頂に派遣して火星の写真を撮らせたそうであるから、定めて有益な知識を斯学の上に齎す事であろう。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の片すみのデスクの上に論文の草稿のようなものが積み上げてある。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ビヂテリアンもたばこはノムデスカ。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルシビアデスは非常の美男子で雄材の人ですが、其終を令くしては居りませぬ。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼らの考えが識域の下においてまさに発酵しようとしている際に彼らがもし偶然この詩句に逢着したとしたら、そして彼らの心の窓が啓示の光に対して開放されていたとしたら、おそらく彼はデスクをたたいて立ち上がり、「ユーレーカ」を叫んだのではあるまいか。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンローによればこれはおもにツキジデスを訳したものだそうであり中には誤謬もあるそうである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にまた「国民小説」「新小説」「明治文庫」「文芸倶楽部」というような純文芸雑誌が現われて、露伴紅葉等多数の新しい作家があたかもプレヤデスの諸星のごとく輝き、山田美妙のごとき彗星が現われて消え、一葉女史をはじめて多数の閨秀作者が秋の野の草花のように咲きそろっていた。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはロベール・デスノという人の原詩を脚色したものだそうであるから、原詩をよく味わった人にはあるいはいくらかおもしろいかもしれないが、われわれにはそんな知らない原詩のある事がかえって鑑賞の邪魔になっているわけである。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワタシノゴチソウデス」　あるじは固くなって言った。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行機ハ、秋ガ一バンイイノデスヨ。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああごらん、あすこにプレアデスが見える。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
