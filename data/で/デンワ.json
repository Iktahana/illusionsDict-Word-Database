        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は五反田駅前の公衆電話で、瀬川さんの御都合を伺った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら、もっと早くから言えば何か方法もあったのに、いまさら、そんな事を言い出しても無理だとは思ったが、とにかく私は控室から料理屋の帳場に電話をかけた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話をかけて直ぐ持って来させるように。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓硝子に映つた自然の外景を、その一瞬間の姿のままで、永久に印畫しておきたいといふ夢想から、今日の飛行機や、蓄音器や、電話や、寫眞機やが發明された。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貸夜具屋が病院からの電話で持込むところと想定してみる。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの頃は共に大學生であつたが、私が本郷のおそばやなどでお酒を飮んで、お勘定のはうが心許なく思はれて來ると、津村のところへ電話をかけた。",
              "citation": {
                "source": "郷愁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶頂の郵便局から、大宮町の大山さんと電話通信をした。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "県道は、電話線の埋設工事で掘り起されてあつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "又兎も角も折角其家を目指して遙々遠方から尋ねて來た客を、どうしても收容し切れない場合なら、せめて電話で温泉旅館組合の中の心當りを聞いてやる位の便宜をはかつてやつてはどうか。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "讀まず、書かず、電話が掛からず、手紙が來ず、人に會はずの三日間で頭の疲れが直り、從つて胃の苦情もいくらか減つたやうである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明神前の交番と自働電話だけが奇蹟のように焼けずに残っている。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話機が発明されて以来は、一双の銅線に依って思いを百里の境に通わす事も出来る。",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "受信機の方ではこれを電話の受話器のごときものに接続する、受話器の薄い鉄の円板の真中に固着した針が一本あってこれが原板の写しを画くペンの役目をするのである。",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の受持の寺院で大勢の聴衆に対して説教すると、その声は同時に電話で市中の各所へ配布された。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この白金板と白金線とを連絡する電路中に電池と電話の受話器とを入れておく。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると遠くから来た電波がアンテナからこのデテクターに伝わると同時に白金の間の抵抗が減じ、従って電流が強くなって電話器で音を発する。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおこれを改良して近頃は符号などは用いず、言語をそのままに送るいわゆる無線電話が出来るようになった。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち発信器の方では不断に規則正しい波を送りそのアンテナに電話の送話器を接続し、受信器には前述のエレクトロリチック・デテクターを用うればよいのである。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠からず大洋にある船舶と電話が出来る時が来るだろう。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "受信器のアンテナに電波が来れば急速な交番電流が起る、これを白熱灯デテクターおよび電流計あるいは電話の受話器に接続すれば、ごく微弱な電波でも感じるから遠距離の通信には都合のよいものである。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐそのあとで老妓は電気器具屋に電話をかけ、いつもの通り蒔田に柚木の探索を依頼した。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話器から離れると彼女は「やっぱり若い者は元気があるね。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、これから私たちの行先が桑名見物というのを聞取って「あすこなら、私よく存じている者もおりますから、御便宜になるよう直ぐ電話で申送って置きましょう」　と言って帰って行った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日の第二限ころなんか、なぜ燈台の灯を、規則以外に間〔一字分空白〕させるかって、あっちからもこっちからも、電話で故障が来ましたが、なあに、こっちがやるんぢゃなくて、渡り鳥どもが、まっ黒にかたまって、あかしの前を通るのですから仕方ありませんや。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　ある食堂の隣室に自働電話の自働交換台がある。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "売店で煙草を買っていると、隣の喫茶室で電話をかけている女の声が聞こえる。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車や飛行機や電話や無線電信はいわば氷の中へ熱鉄を飛び込ませ、水の中へ濃硫酸を酌み込むような役目をつとめるものである。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、ミ・ム及びビから変じて出来たウは、文字では「う」と書かれているが、純粋のウでなく、鼻音を帯びたウの音で、今のデンワ（電話）のン音と同種のものであったろうと思われる。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "会のあとでプリモースへ行ってそこで始めて電話というものを実見した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無線電話で召集でもされたかと思うように一時にあちらからもこちらからも飛んで来るのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
