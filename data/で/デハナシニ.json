    "definitions": [
      {
        "index": 1,
        "gloss": "not (that), but rather (something else)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
