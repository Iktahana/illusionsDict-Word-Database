  {
    "uuid": "400f998e-e880-5c4a-94e7-b26350119e3a",
    "entry": "デコ",
    "reading": {
      "primary": "デコ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "decoration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "所でラヴェルなんてバッハが見たら苦労性なデコラトゥールだ。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "叙事は謂はば文人画風の型を作り、かくて人間的心情は所謂美――私にとつてはデコレイション――とその余りの部分とに分裂した。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "デコブラ先生にも送ってやってよろこばせてやるか、可哀そうに。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとＮ嬢が、その前に百貨店の飾窓のクリスマス・デコレーションを、私に是非見せ度いと言い張りました。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、西洋のデコルテのように、肩から胸部と背部との一帯を露出する野暮に陥らないところは、抜き衣紋の「いき」としての味があるのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのカバレット・トア・ズン・ドルの淡い憶いがネムの花に夢のように、あらわれるのだが、彼女は何もかも知らぬふりをして、私の用事を待つ、それが英国種の牝犬のように無関心な顔をして、その実細心なデコルテを内にかくしてかしこまっている。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、当代の男性にとっての理想の女性は脚部の肉色のデコルテを紊して云った。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままでソファの底に沈んで、情婦のつくってくれたあたたかいラム・パンチをのんでいた田村英介氏は四家フユ子のデコルテの紊れに強い感情を乱されて、――おまい、僕と別れたいんだろう――――ノン、あなたが妾を囲いものにするからさ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は貴方のおみ足の泥を嘗めるにも足りない哀れな者です」　とか何とか云ってオデコの上に詩集を押付けたってえ話が残っている。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "道は少しのデコボコだつたが、私は前々夜来睡眠をとつてゐなかつたので、僅かのデコボコにも足許がフラフラし、頭もフラフラした。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "皿には、デコレーションの嵩ばかりで、実になるものは極くすくない。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒョロ子も一生懸命になって豚吉を落ちないように押えておりましたが、馬車が村を出ると間もなく、そこにあった道のデコボコに馬車が引っかかってガタンガタンとはね上る拍子に、二人共抱き合ったまま馬車の屋根の上から往来へ転がり落ちました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "デコブラ先生にも送つてやつてよろこばせてやるか、可哀さうに。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番多いのが就職口と高利貸で、親の脛を噛じって野球をやったり、女給の尻を嗅ぎまわったり、豆腐屋の喇叭みたいな歌を唄ったりした功労によって卒業免状という奴を一枚貰うと、そいつをオデコの中央に貼り付けて就職の権利でも授かった気で諸官庁会社を押しまわる。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹一は寄宿舎のデコレーションを一度軽蔑して置くのもわるくないと思った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（流行らぬ寄席か化物屋敷じゃあるまいし……）そう心の中で呟いて、豹一は北寮、中寮、南寮の順に各部屋のデコレーションを見て廻った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "南寮五番の部屋まで来ると、「虎退治」とデコレーションの題を書いたポスターが貼りつけてありながら、ドアが閉っていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々はドアがなかなかあかないので、これもデコレーションの機智の一つかというつまらなそうな顔をして立去って行った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言うと、「デコが間に合わなかったんで、立っている人間がしばしばうおーッと唸る仕掛になっているんだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私なんか、悪漢のおデコさんですから、八十歳までは大丈夫よ」「そうなの？",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳のデコボコしたのも佗しければ、障子の紙の黒くよごれてゐるのも不愉快であつた。",
              "citation": {
                "source": "紅葉山人訪問記",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ノスケッチデハ私ノ感ジガドウモ出ナイデコマリマス。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だだっ広いその客車には外務省の夜会に行くらしい三人の外国人が銘々、デコルテーを着飾った婦人を介抱して乗っているだけだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大森は中央階段をのぼり、デコレイション・ケーキのような、屋上出入口の踊り場で立ちどまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、それから、お気に召さないかもしれませんけれど、よろしかったら、オーデコロンもあります」　手のひらに収まる小さなビンを、ピリオドのようにのせる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、あのオーデコロン、つけたでしょう」　慶一がとがめるようにいった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東洋の」秘密教団と、デコボコ二人組のマッドサイエンティストに狙われ、バッキンガム宮殿や、アルプスや、バハマを逃げまわるビートルズの物語のなかに――。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
