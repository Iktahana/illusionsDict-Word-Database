        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし、私にはこのアステーア、ロジャースの踊りのデュエットは見ていてやっぱりおもしろい。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じように、たとえば「炭俵」秋の部の其角孤屋のデュエットを見ると、なんとなく金属管楽器と木管楽器の対立という感じがある。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどいデュエットだったが、ほんのときおり、高音部で、ふたりの声がきれいなハーモニーを響かせた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すげえデュエットだったな。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあの宙釣りから狐忠信があらわれて、静御前の美しい旅姿とデュエットで舞う夢のような場面を初めて見た時の驚異をいまだに覚えている。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈うた：ダンとデーのデュエット〉　チードルダンとチードルデー　戦うしかない　だってチードルダンの　ガラガラ壊されたから　そこへおばけカラスが飛んできて　怖さのあまり　ケンカも忘れた　アリスがやってくる。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "前奏のメロディーが委曲をつくしてリズムがたかまり、将にデュエットがうたわれようとするときの光彩にあふれた美しさ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "このデュエットにおいてよくまだ録音されないのは低音の部だということになるでしょう、いつも。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者も優れたものであるが、わけても後者の牧歌的なデュエット・アリアは少年聖歌隊の演奏で、限りなく美しい。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯様にして真赤な光線に彩られ、桃色に見える二つの影絵は、あらゆる姿態を尽して、夢のようなデュエットを、果しもなく続けて行くのであった。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりの狂笑のデュエットが、へやいっぱいに響きわたった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二台のアクースティック・スティール・ギターのデュエットが、せつなく軽やかに美しかった。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダナ・ホワイトフィールドに、彼とよくデュエットで歌う女性、ダイアナ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
