        "examples": {
          "standard": [
            {
              "text": "経済動向を示すＤＩは、景気判断の重要な指標の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最新のＤＩ調査結果から、製造業の景況感が上向いていることがわかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アナリストは、今後のＤＩの推移に注目していると述べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ＭＩＤＩ対応のギターとキーボードをマックが仲立ちするとあら不思議、ギターからはキーボードの、キーボードからはギターの音が流れだす。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＤＩＮＡと名付けられたネットワーク技術によって、新しいシステム１００では日本電気の大型コンピューターとの接続が容易になった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "×指のさはりのやはらかな青い煙の匂やかな、好きな細巻、名はＤＩＡＮＡ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにＤＩＴＯＴと書かれている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもお二人とも最近は核兵器よりＳＤＩの方に関心がおありのようで……」「とにかく帰ってもらおうか。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "サブルーチンの最初の行はどうせＤＩＭ文を用いた配列の初期設定だから大したことはない。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
