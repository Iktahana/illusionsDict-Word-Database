        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二か月ぐらいの赤ちゃんが出べそをふくらまして横で泣きたてている。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "お臍が出べそで嫌われた。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やどりぎが、上でべそをかいたようなので、タネリは高く笑いました。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」手品師は子供の手のひらでべそをかく蝉のやうな声を出した。",
              "citation": {
                "source": "手品師と蕃山",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、なんと言ってもそこは諦めの早い江戸っ児たちのことだから、そういつまでも空を白眼んでべそをかいてばかりもいなかった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怪談抜地獄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――若尾は涙を拭き、独りでべそをかきながら、またそっと口の中で呟いた。",
              "citation": {
                "source": "みずぐるま",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉の海岸でべそをかいている僕の写真は、白い縁に囲まれた一辺が五センチほどの正方形だ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハックネス先生」　シンシア嬢は心労でべそをかいている。",
              "citation": {
                "source": "四日闇夜",
                "author": "THE FOUR DAYS' NIGHT",
                "note": "青空文庫"
              }
            }
          ]
        }
