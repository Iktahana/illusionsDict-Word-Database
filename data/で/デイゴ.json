    "definitions": [
      {
        "index": 1,
        "gloss": "Indian coral tree (Erythrina variegata)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
