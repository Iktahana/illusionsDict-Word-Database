    "definitions": [
      {
        "index": 1,
        "gloss": "in the mud or mire",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
