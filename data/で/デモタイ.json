        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この日の早朝、新宿郵便局に郵便番号自動読み取り機が搬入され、これに抗議するデモ隊は夜になっても局を取り巻いていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一応歌い終わったフォーク集会の参加者は、デモ隊に合流しようと動きはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのデモ隊列の中に、高校一年生のタケシもいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝廷に何か自分たちの不満があれば、今日のデモ隊のごとく、あの叡山の雲母坂から都へ出てくる。",
              "citation": {
                "source": "親鸞聖人について",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜ハ夜デヨカッタケレドモ、コレカラダト時間ガ時間ダカラ、必ズドコカデデモ隊ニ打ツカリマス、米国大使館ト国会議事堂ト南平台ヲ結ブ線ヲドコカデ横切ラナケレバナリマセン、ソノ積リデ早目ニオ出カケニナッテ下サイト、運転手ガ云ウ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
