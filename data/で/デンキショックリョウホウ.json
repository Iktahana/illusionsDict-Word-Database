        "examples": {
          "standard": [
            {
              "text": "重度のうつ病患者に対する治療として、電気ショック療法が検討されることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は電気ショック療法を受けることをためらっていたが、医師の説明を聞いて納得した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い映画では、電気ショック療法がかなり乱暴に描かれているものもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この婦人は山口さんの場合とちがって、電気ショック療法で治った後に、記憶を失った当時の状態を思いだしているようだ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その三　精神病診断書",
                "note": "青空文庫"
              }
            },
            {
              "text": "インシュリンや電気ショック療法のなかった一昔前の精神病院では温浴療法というものをやったそうであるし、ヌル湯の湯治場では、精神病に卓効ありとあるのが多い。",
              "citation": {
                "source": "温浴",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
