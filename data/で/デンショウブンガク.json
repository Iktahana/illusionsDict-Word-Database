        "examples": {
          "standard": [
            {
              "text": "祖母が語ってくれた昔話は、まさに生きた伝承文学の一例だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アフリカの多くの部族には、豊かな伝承文学の伝統がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "伝承文学は、文字を持たない文化において知識や価値観を次世代に伝える重要な役割を果たす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ところがその理由というものが、多くの伝承文学にあってはこれを発見することが容易でなかった。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
