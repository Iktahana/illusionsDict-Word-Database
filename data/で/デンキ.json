    "definitions": [
      {
        "index": 1,
        "gloss": "fantasy fiction",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
