[
  {
    "uuid": "97a60657-2fcf-546c-9f9d-7e8af5b62513",
    "entry": "出任せ",
    "reading": {
      "primary": "でまかせ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
