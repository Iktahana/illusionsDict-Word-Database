    "definitions": [
      {
        "index": 1,
        "gloss": "the moment of meeting (of two people, vehicles, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "Ｔ「一ッ走り見て来るぜ」　伝六走って――９＝鳥居の処で　出会い頭に衝突してひッくり返った。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通在来の着のみ着のままに、半面をかけて舞台に上るなり、行きなり放題の出会い頭にアッと云わせたり、ドッと笑わせたりするのがこのニワカ芸術の本来の面目である（註曰――現在では台本や装置、扮装に凝って、単に普通の喜劇を、博多言葉に演ずる程度にまで堕落してしまっている）。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして片手を罎の栓へかけて、出会い頭に毒薬をふりかけてくれようと、血眼で駈けまわりましたが、不思議や悪魔はどこへ行ったか影も形も無く、只｜霜風が身を切るように冷たくて、大空には星の光りが降るように輝いているばかりでした。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二度目の時は、妾が『瞬』に乗って、紅矢様のお帰り途に押しかけて、出会い頭に馬を乗りかけて怪我をさせましたので、妾はその死骸を先生の御門の処まで持って来て、放り出して逃げて行ったので御座います。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "出会い頭に、ああすみませんがと白縮のシャツの中僧さんにたのまれたりして、小一時間歩く間に私は四五度針をもった。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、私でなくっても誰かが思いがけない出会い頭に声でも立てたらどんな事になるか。",
              "citation": {
                "source": "盗難",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちも頭を下げながら出会い頭に問うた。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ程でなくとも、この種類の暗示を巧みに利用すると、出会い頭に他人を発狂させる事が出来る。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおも二人の跡を逐うて船首の方へ行こうとすると、出会い頭に二等運転手が船橋から駈け降りて来た。",
              "citation": {
                "source": "幽霊と推進機",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子戸をあけようとすると出会い頭に、「おや、姉ちゃん来てたの」　入って来たのは、順二郎であった。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に動悸しはじめたのを感じながら、サヨは丁度看護婦が階段をのぼり切ったところへ出会い頭に出て行った。",
              "citation": {
                "source": "朝の風",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が玄関からでようとすると、出会い頭に、トン子がとびだして、スイと私をすりぬけてでる。",
              "citation": {
                "source": "無毛談",
                "author": "――横山泰三にさゝぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚戸の話によると、まだほんの僅かの人工重力しか掛っていないそうだが、それでもその効果は大したもので、滑ってころんだり卓上のものが動きだしたり、栓をするのを忘れたインキ壺からとびだした雲状のインキが出会い頭に顔をインキだらけにするようなことは全くなくなった。",
              "citation": {
                "source": "宇宙尖兵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "また直接なんの恨みもない相手を出会い頭にいきなり殺すことも好かないよ。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　これは焼け跡の道で出会い頭に交わすあいさつである。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "出会い頭に便所からでてきたのは弁内。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十六　家族は六人・目一ツ半",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「野郎ッ、来やがれッ」「何をッ、お前こそ逃げるなッ」「その手を離せ、畜生ッ」「誰が離すものかッ」　絡み合い、啀み合いながら、旋風のように路地を入って来た二人の若い男、銭形平次が出かけようとする出会い頭、開けた格子の中へ二匹の猛獣のように飛び込んだのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "仏喜三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の子供の新太郎に忠次郎といって彼には甥に当る相棒がいたが、ある日忠次郎を相手に剣術を使ったら、出会い頭に胴をぶん殴られて目をまわしてしまった。",
              "citation": {
                "source": "安吾史譚",
                "author": "勝夢酔",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、彼が、その店先へ入ろうとした時、出会い頭に、襤褸を投げたように飛んで来たものがあった。",
              "citation": {
                "source": "雲南守備兵",
                "author": "木村荘十",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は出会い頭の男に、「ポンメルシーさんの家」を尋ねた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "或日、谷君が教室で赤羽君と出会い頭に、「日本アカベーン」　と言って、その通りの真似をしたら、赤羽君が突如打ってかゝった。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人も出会い頭だったと見えて、末次さんは社長に、「時に今日はアメリカの美人連中が押し寄せたそうですな」　と話しかけた。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "激しい衝撃、出会い頭だったので、本能的に両腕を前に出し、転倒を防いだ。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、出会い頭に、一人の部下にぶつかった。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "物に衝き当った蝙蝠のように、お市が、門を出て来た出会い頭に、そこの土塀にぶつかって、ばたっと仆れたかと思うと、『た、助けて下さい。",
              "citation": {
                "source": "夕顔の門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――と、或る日、『不破氏、ちょっと、顔を貸してくれないか』　背の高い、苦み走った美男子で、身装や動作にもそつのない武士が――御廊下の隅で出会い頭に囁いた。",
              "citation": {
                "source": "※かみ浪人",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あッ、殿ッ」　乱軍の中の、ぶつかり合うばかりな出会い頭、誰か、彼の前に、血槍を伏せて、ひざまずいた味方がある。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると誰か、出会い頭の武者が手を出してその鞠をついた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、出会い頭に、猫門の前で、バッタリぶつかった男が、「おい、待ちな」と、軽く腰帯を取った。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
