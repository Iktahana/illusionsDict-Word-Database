[
  {
    "uuid": "6e226e0a-8bb0-534b-8abe-96998a265f22",
    "entry": "出養生",
    "reading": {
      "primary": "でようじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
