        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いけねえ）「そりゃ又どう云う訳でかい？",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、夢中で狂気染みた沙汰を醒めて冷く指摘されたように、口｜銜り、みると額に冷汗までかいている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "円筒形の上の断面を楕円形に表わして、底面の方は直線でかいてしまう事が流行するようである。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までかいた絵の事は向うにみんな知れているんだから。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ではまた、突然の暴行の後に釈放された白い母鳥も、ほんのちょっとばかり取り乱した羽毛をくちばしでかいつくろって、心ばかりの身じまいをしただけで、もう何事もなかったように、これも瞬間の驚きから回復したらしい十羽のひなを引率してしずしずと池の反対の側へ泳いで行くのであった。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてが岩絵の具でかいた絵のように明るく美しい色彩をしている。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時には珍しいボールドなタッチでかいた絵で、子供をおぶった婦人が田んぼ道を歩いている図であった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後者において柳の枝までが顔や着物の線に合わせて音楽を奏しているのに、おそらく同じつもりでかいた前者の桜の枝はギクギクした雑音としか思われない。",
              "citation": {
                "source": "浮世絵の曲線",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の下に踏みにじられた羊歯の青くさい香を私は耳でかいでいるような気がした。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「人の笑い声、太い声でかい。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれ夜光虫派はもっとでかいスリルのあるやつを賭けようじゃないか」「ええ、スリルのあるやつ賛成ですな」　鶴雄は小田という男、案外話せるぞと思いながら言った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし、それで行こう」　小田は痩せた身体に似合わぬ、でかい声を出した。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、場末か裏街にある小さなホテルは、何か淫蕩的な雰囲気を漂わせているし、第一ホテルのような、まるで道路の延長のような感じの廊下を持った、でかいホテルは、人を気障っぽくさせるのである。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さよか」　そう言いながら、男はどぶんと浸ったが、いきなりでかい声で、「あ、こら水みたいや。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はでかい溜息をつき、「あの男にはほんまに困ってしまいます」　と、言って分厚い唇をぎゅっと歪めた。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だけど、焼くのに、なにか入れ物を持っておいでかい？",
              "citation": {
                "source": "のろまのハンス",
                "author": "――むかしばなしの再話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父さんが長岡から、こんなでかい紙鳶を、買つて来てくれたから見に来なよ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治卅四年十一月六日灯下ニ書ス東京　子規　拝　　倫敦ニテ　　　漱石　兄　此手紙は美濃紙へ行書でかいてある。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まだどこの展覧会も見ていませんが、このごろ、画をたのしんでかいている人が実に少い。",
              "citation": {
                "source": "一問一答",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次男　　でかいなあ、いまのは、二尺かもしれないよ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままでかいた絵は、みんな破って棄てました。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡釣をしていて、変な処にしゃがみ込んで釣っていて、でかい魚を引かけた途端に中気が出る、転げ込んでしまえばそれまででしょうネ。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "と胸を吐くと、さらさらさらさらと三筋に……こう順に流れて、洗面所を打つ水の下に、さっきの提灯が朦朧と、半ば暗く、巴を一つ照らして、墨でかいた炎か、鯰の跳ねたか、と思う形に点れていた。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おシンの奴もでかい腹だったっけ！",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云って順平の雑魚場行きのでかい財布をとり出して、あけた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
