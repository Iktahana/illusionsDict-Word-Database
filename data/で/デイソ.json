    "definitions": [
      {
        "index": 1,
        "gloss": "unfired clay figurine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
