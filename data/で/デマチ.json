[
  {
    "uuid": "e1a86a7c-9f7c-5fe2-a474-eaf14c1afa7d",
    "entry": "出待ち",
    "reading": {
      "primary": "でまち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "waiting (e.g. at the stage door) for performers or celebrities to exit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「わしは、今までまちがつた生き方をしてゐたことがわかつた。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その人がね、おじさんの家でまちがえて持ってきたから、返してくれっていったんだよ」「返してくれろって？",
              "citation": {
                "source": "うた時計",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆いそがしいのでまちがえたものだろうとおもっていると、今度は五人前の茶を持って来た。",
              "citation": {
                "source": "とんだ屋の客",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "良人は電話口でまち子の云ふ事を聞いて居たが、たちまち笑ひ出して、『そんな事は、ほっといたらいゝ、』といって取り合はない。",
              "citation": {
                "source": "雛鳥の夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえは、基本的なところでまちがっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それから先生、先生の前でこんなことをいつちやわるいが、わしには事務所の書記中心の農民運動はもうだめぢやといふ氣がしますが……、今の組織はその點でまちがつとるといふ氣がしますが。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この銅像のことについては世間でまちまちの噂があります。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "楠公銅像の事",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワ大学のいくつもある門を出たり入ったりする男女の学生の年は、まるでまちまちだ。",
              "citation": {
                "source": "ワーニカとターニャ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宏子ははる子自身にまけない期待でまちもうけたが、重吉は何とも云わない。",
              "citation": {
                "source": "道づれ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関室で、或るまちがいの事件が起ったため、こうしてまちがって離陸したんだ」「へえっ、機関室でまちがったのですか」「うん。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「濃度をまちがえるような耄碌はしないつもりじゃが、はて、どこでまちがったかな」　王老師は、しきりに首をひねったり、山羊髯をしごいてみたが、一向その不思議は解けなかった。",
              "citation": {
                "source": "大使館の始末機関",
                "author": "――金博士シリーズ・７――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはおかしな話だったが、私の信念はゆるぎなかったので、しんけんになって言った、「みんなでまちがっているよ。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、家庭によっては、朝食が家人の都合でまちまちになっている。",
              "citation": {
                "source": "三州仕立て小蕪汁",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "みすぼらしいようすをした老婆が、石油屋の入り口に立って、「さっき、子供が、五｜厘足りなかったので、どろぼうだといってしかられたと泣いてきたが、私が銭を渡したときに目が悪いものでまちがったのだ。",
              "citation": {
                "source": "火を点ず",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸福の島へゆけば、いまこの国でまちがっているようなことは、たとえ見ようと思っても見られない。",
              "citation": {
                "source": "明るき世界へ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "予言が実現したわけですが、かのカケコミ教は、私を犯人と見せるために、私の家の庭園中でまち子を殺したのです。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その三　魔教の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻布の馬場やしきだことの、高音とかいうおかみさんだことのと、めりはりの合わねえことばかりいっていたが、やっとあとでまちがいとわかってな、今度は、平蜘蛛のようなあやまりようよ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「初めから終わりまでまちがっておる。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを世間でまちがう人が多くいろいろの屍体を解剖学教室に運び込む者が多いので使丁等は我我の教室での解剖を大解剖と称して区別し易いようにしている。",
              "citation": {
                "source": "屍体異変",
                "author": "森於菟",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれのためにまちがいの根源を明らかにしてくれる第一のいろいろな役所も、この件でまちがいをみとめているのです。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは、ハンスの親戚たちは彼らの期待した点でまちがっていたのでしょうか。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「若い女の人夫です、普請場でまちがいがあって、腰と腹に大きなけがをしています」と半太夫が云った、「牧野さんが診たんですが、自分だけでは手に負えないから、先生に来ていただきたいと云うんですが」　去定は疲れたような顔になった。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "駈込み訴え",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでは、なにぶん被害区域が広く被害民が多数でまちまちの考えを持っていたし、なかには僅ばかりの示談金で諦めている村々も少からずある。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝のは魚の方でまちがえたんだって杉山さんがおっしゃいました」「あれはへつらい武士で困る」「しかし若様はほんとうにおじょうずです。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "試験というとすぐにあわててしまって、知っていることまでまちがいます」「始末がわるいんだね」「そこへもってきて、きみは万事において若様に花を持たせなければいけないって安斉先生がおっしゃるんです。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がどこでまちがっているのか、どのような点で私の意見に反対なのか、知らせてほしい。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやそれどころか、彼らの側にこそ当然学問知恵のお株をゆずることになり、あんなにも確実でまちがいのない自然という大先生の名誉を、いやが上にも輝かすことになるのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことは「武時申状」や「博多日記」にもあるのでまちがいはない。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
