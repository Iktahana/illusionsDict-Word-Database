    "definitions": [
      {
        "index": 1,
        "gloss": "deci-",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今アナタ忙ガシイデショウネ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "春宵一刻、――」などと、つまらぬ事を呟きながら木の虚から這ひ出ると、オヤ　ナンデセウ　サワグコヱミレバ　フシギダ　ユメデシヨカ　といふ事になるのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長さ五五・四デシメートルとあるのを換算するとまさに一丈八尺強、恐ろしく長いものである。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此菓子はまずオレンジの内莢で香をつけた牛乳四デシリットルの中に、玉子十個とフルーレットクレーム四デシリットルを混ぜる。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後にシャンパン半デシリットルを加えモスリンの布で漉す。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによく攪拌した、クリーム三デシリットルを加える。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "役所では窓に黄いろな日覆もできましたし隣りの所長の室には電気会社から寄贈になった直径七デシもある大きな扇風機も据えつけられました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ケキヨ、ヨ　ケキヨ、ヨ」　チヨウド、ソレハ　ナキジヤクリシテ　ヰルヤウニ　カナシイ　オトデシタ。",
              "citation": {
                "source": "ウグヒスブエヲ　フケバ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "コノ　ウグヒスハ　オカアサンウグヒスデ、センダツテノ　コト、ボウヤノ　ウグヒスヲ　ナクシタノデ、タイヘン　カナシンデ　ヰタノデシタ。",
              "citation": {
                "source": "ウグヒスブエヲ　フケバ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンナニ　ヤサシイ　モノガ　花タチノ　オソロシク　オモツタ　ウマダツタノデシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アラ　ドウ　シタノデシヨ、アナタノ　オベベハ　マツシロヨ」ト　オドロイタ　花ノ　ヒトツガ　イヒマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケレド　ナタネノ　ツボミト　イツシヨニ　ソダツタ　テフテフデスカラ、ナタネノ　花タチトハ　タイヘン　ナカヨシデシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「テフテフサン」ト　トブ　コトノ　デキナイ　花タチハ　イフノデシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「デンデン　蟲々　ツノ　出セヤ　ダツタカナア」ト、イロイロ　カンガヘタガ、チツトモ　ソノ　ウタハ　オモヒダセマセンデシタ。",
              "citation": {
                "source": "カタツムリノ　ウタ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "テンカン　テンカント　イサマシイ　オトガ　シテ　ヰルノデ　イツテ　ミルト　カジヤデシタ。",
              "citation": {
                "source": "カナヅチ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "センセイノ　コ新美南吉　タキクンノ　オトウサンハ　一ネン　ダンシノ　ウケモチデシタ。",
              "citation": {
                "source": "センセイノ　コ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小サナ　小サナ　スキトホルヤウナ　デンデン蟲デシタ。",
              "citation": {
                "source": "デンデンムシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "イツモハ　ナカヨシダツタノデスケレド、アンマリ　マンナカノ　ホシガ　サムイ　サムイト　イフノデ　ホカノ　二ツノ　ホシニ　イジメラレタノデシタ。",
              "citation": {
                "source": "ナガレボシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "キエテ　イツタ　ホシハ、イツマデ　タツテモ　カヘツテ　キマセンデシタ。",
              "citation": {
                "source": "ナガレボシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イツテ　ミヨウ」「ウン」　二ツノ　ホシハ　タカイ　タカイ　ソラカラ　コガラシノ　フク　マチノ　ナカヘ　オリテ　イツタノデシタ。",
              "citation": {
                "source": "ナガレボシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイヘン　シヅカナ　ムラデ　イヌノ　ナキゴヱモ　キコエズ、イエイエノ　マドハ　ミナ　カタク　トザサレ、ガイトウニハ　ヒガ　トモツテ　ヰマセンデシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソノ　ムラニモ　ヒトハ　アマリ　ヰマセンデシタガ、マダ　スコシハ　ノコツテ　ヲリマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヘノ　ナカニハ　フタリノ　トシヨリガ　ヰテ　チヨウド　ヒトツノ　パンヲ　フタツニ　キラウト　シテ　ヰル　トコロデシタガ、ハラノ　スイタ　ヲトコヲ　キノドクニ　オモツテ　パンヲ　ミツツニ　キリ、ソノ　ヒトキレヲ　ヲトコニ　メグンデ　ヤリマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカチヤンガ　ノツテ　ヰテ、カキマハシタノデシタ。",
              "citation": {
                "source": "ミチコサン",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソノ　ウチニ　オバサンハ　スツカリ　ウバグルマノ　ナカヲ　カタヅケテ、「スミマセンデシタ、ホントウニ。",
              "citation": {
                "source": "ミチコサン",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "チヤウサンハ　チヨウド、ロバガ　イツピキ　ホシイト　オモツテ　ヰタ　トコロデシタノデ、アキナヒノ　モツテ　ヰル　カゴヲ　ノゾイテ　ミマシタ。",
              "citation": {
                "source": "ウサギ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソンナ　グアヒデ　コドモノ　タヌキハ　ナカナカ　ウマク　バケル　コトハ　デキマセンデシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "サムラヒハ　ゲタノ　ヲヲ　キツテ　コマツテ　ヰル　トコロデシタノデ、「ヤ　コレハ　ウマイワイ、ココニ　ゲタガ　オチテ　ヰル」ト　イツテ、コドモダヌキノ　バケタ　ゲタヲ　ハキマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
