          "literary": [
            {
              "text": "いまにベルが鳴って、無電班長が電話に出る」「そうじゃありますまい。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "長いホールを通り電話に出ると脇村氏からだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話に出るのは、たいてい仕込さんですが、あとでは、あたしが待ちうけていて出てみましたが、そうですかとだけで切れてしまうので、ばからしくなりました。",
              "citation": {
                "source": "千代次の驚き",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "百々子が電話に出ると、女のひとの声がいきなり耳に飛びついてきた。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "その点、ミドリさまのほうもおかしいので、出なければ出なくともすむのに、イヤヨというひと言をいうために、根気よく電話に出る。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし電話に出るにはだいぶん手間どった。",
              "citation": {
                "source": "宇野浩二君を思う",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱり、おいででしたね、下で、電話に出る方はないが鍵が来ていないっていうもんですから。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつだって、熱度の計りようも知らないような女中だか家庭教師だか見たいな人ばかり、電話に出るんですのよ。",
              "citation": {
                "source": "宵（一幕）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
