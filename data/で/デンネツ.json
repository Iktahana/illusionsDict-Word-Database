[
  {
    "uuid": "132e716d-1d25-5b09-acd0-0efd5a11ff30",
    "entry": "電熱",
    "reading": {
      "primary": "でんねつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
