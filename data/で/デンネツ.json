      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "heat transfer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これはつまり金属陶器木材等の伝熱率の大小による。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――堀川君、君は伝熱作用の法則を知っているかい？",
              "citation": {
                "source": "寒さ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それを伝熱作用の法則と云うんだよ。",
              "citation": {
                "source": "寒さ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "今この男女を接触せしめると、恋愛の伝わるのも伝熱のように、より逆上した男からより逆上していない女へ、両者の恋愛の等しくなるまで、ずっと移動をつづけるはずだろう。",
              "citation": {
                "source": "寒さ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者と読者との間には伝熱作用も起らないようだ。",
              "citation": {
                "source": "寒さ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それも君、やっぱり伝熱作用だよ。",
              "citation": {
                "source": "寒さ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこの間話し合った伝熱作用のことを思い出した。",
              "citation": {
                "source": "寒さ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
