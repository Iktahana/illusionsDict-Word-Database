        "examples": {
          "standard": [
            {
              "text": "スーパーマリオブラザーズ2は、ディスクシステムで発売されたファミコンのゲームだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ディスクシステムは、ファミコン本体に接続して使う周辺機器だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの頃のディスクシステムのロード時間は、今思うとかなり長かったな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
