        "examples": {
          "standard": [
            {
              "text": "その国は長年、デスポティズムの下に置かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はデスポティズムを批判し、民主主義を訴えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史を振り返ると、デスポティズムの時代には多くの悲劇があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "――このホッブズのアブソリュティズムは、チュードル王朝特に又スチュアート王朝のデスポティズムを倫理的に合理化したものであることは、疑いを容れない。",
              "citation": {
                "source": "道徳の観念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時個人の形で現われたブルジョアジーの勢力は却って、国家の形で発現したこのデスポティズムの積極的発動を促した。",
              "citation": {
                "source": "道徳の観念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、コンミューニズムの端からファシズムの端に至るあらゆる種類の政治的プリンシプルが、現実的にデスポティズムの形をとった場合には、すべてサイミン術になる。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてなにかの意味でデスポティズムの形をとらぬ政治的プリンシプルは有り得ない。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
