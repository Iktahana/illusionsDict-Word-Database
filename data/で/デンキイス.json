        "examples": {
          "standard": [
            {
              "text": "古い映画で電気椅子による処刑の場面を見て、胸が締め付けられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は凶悪な犯罪を犯し、電気椅子の判決を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "電気椅子という言葉は、極刑の象徴として多くの物語に登場する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "電気椅子より手軽い死刑も。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリゾナ州フロウレンスの州刑務所で、ウイニイ・ルウス・ジュッド――女囚第８８１１号――が、電気椅子に掛かったのは、今年の二月二十三日の星の寒い明方だった。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてさらにもう一つ、こういう世にも幻怪な運命の犠牲者となった私を目して、殺戮者、嗜虐性色情狂と罵るならば、誰か世に殺戮者、嗜虐性色情狂たらざる人間ありやと、呼ばわらんがために、この一文を草して静かに電気椅子の上に坐る日のくるのを待とうとするからなのだ。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
