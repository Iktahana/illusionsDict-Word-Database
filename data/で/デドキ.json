          "literary": [
            {
              "text": "（初出時の表題は「マルテ・ロオリッツ・ブリッゲの手記」。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（初出時の表題は「二つの断片（「マルテ・ロオリッツ・ブリッゲの手記」から）」。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（初出時の表題は「「マルテ・ロオリッツ・ブリッゲの手記」から」。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（初出時の表題は「マルテ・ロオリッツ・ブリッゲの手記（※）」。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん降雨の時刻と人々の外出時刻との関係でこの影響はいろいろになりうる。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "言いかえれば、赤井、白崎の二人は、浪花節、逆立ちを或いは上手に或いは下手に隊長の前でやって見せると共に、外出時間を貰って、鶏、牛肉、魚などの徴発をして来なければ、一人前の兵隊とは言えない、というわけである。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで帰らねば、外出時間が切れてしまう。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "外出時間も丁度切れたと思うと、豹一は重苦しい心がすっと飛んでしまい、足取りも軽かった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　新作家輩出時代　文壇における新陳代謝は、連続的ではなくて飛躍的であり、この飛躍にはほぼ周期がある。",
              "citation": {
                "source": "文芸は進化するか、その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が支度が出来あがつて、外出しようとした時分此方も丁度退出時間だつた。",
              "citation": {
                "source": "風媒結婚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後三時過ぎ、退出時刻が近くなると、家のことを思う。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「卯飲」の一に「卯飲解酲有何物、売来蛤蜊過門渓」の句があつて、「売蛤漢自行徳浦来、毎在日未出時」と註してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮りに毛沼博士の死が夜中の一時に起ったとしても、噴出時間は最大二時間半で、二十五立方尺である。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬えば妻の処女時代、又私が不在時、或いは外出時、それらのものに科学以上の絶対の信頼の置けないことは、自明の理であります。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（初出時の表題は「詩的精神」。",
              "citation": {
                "source": "詩人も計算する",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（初出時の表題は「芸術のための芸術について」。",
              "citation": {
                "source": "詩人も計算する",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（初出時の表題は「超現実主義」。",
              "citation": {
                "source": "詩人も計算する",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（初出時の表題は「すこし独断的に――超現実主義は疑問だ」。",
              "citation": {
                "source": "詩人も計算する",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（初出時の表題は「小説の危機」。",
              "citation": {
                "source": "詩人も計算する",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "或日の事で、三田が退出時間の近づく事ばかり念じながら仕事をして居るところへ、支店長が呼んで居ると給仕が云つて來た。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくＲ瓦斯の放出時間は午後三時だ。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "退出時刻になると、私は待ちかまえていて真先に立ち上った。",
              "citation": {
                "source": "悲しい誤解",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……わしの計画は滅茶滅茶じゃないか」「博士は外出時に変装するということを貴方が僕に注意しなかったのが、そもそも手落ちですよ」「博士のラボラトリーの前から警戒監視すべきが当然だ。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "『さあ今が君の出時だ！",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、日出時の東の水平線は大抵雲に閉されていた。",
              "citation": {
                "source": "月明",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この光の変化に歩調を合わせて、露出時間を、つぎつぎと短くしていって、二秒までに縮める。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "微速度は、一こま二秒を限度としているので、これからあとは、露出時間はそのままにしておいて、レンズのほうで絞っていく。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間、刻々と露出時間または絞りをかえていくのであるから、なかなかたいへんな仕事である。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは、まるでどきどきして、頭をやけに振りました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの胸までどきどき云いやがる。",
              "citation": {
                "source": "若い木霊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
