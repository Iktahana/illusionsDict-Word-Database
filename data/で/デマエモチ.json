    "definitions": [
      {
        "index": 1,
        "gloss": "delivery person (of food)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
