[
  {
    "uuid": "4be25758-47ea-58b6-b4bb-a8f51da1efa9",
    "entry": "出稼ぎ",
    "reading": {
      "primary": "でかせぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
