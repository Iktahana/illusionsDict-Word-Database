    "definitions": [
      {
        "index": 1,
        "gloss": "working away from home (esp. abroad)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その病室にはアメリカへ出稼ぎに行つて、肺結核に罹つて、故國で死にたいと云ふ望みから重體のまま歸朝して來た中年の紳士が、その十日程前からはいつてゐたのだつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近在や近国の祭礼などに出稼ぎに行ったこともあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、向いの本土へ出稼ぎに行っている息子が時々帰ると、その土産物を御礼のつもりで心して持って行っていた。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり遊んだので首尾がわるくて上海の支店へ出稼ぎにやられた。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "天草あたりから外国へ出稼ぎする女たちよりも更に醜い。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人が堀部君を歓待したのは子細のあることで、彼は男女三人の子供をもっているが、長男は営口の方へ出稼ぎに行って、それから更に上海へ移って外国人の店に雇われている。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々出稼ぎにあちこちの病院へ出張したが、その報酬は全部自分で使ひ、寿枝には一銭も渡さず、しかも家の費用はすべて寿枝が自分の金で賄つてゐた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は逗留客としての一面を生活し、同時に、出稼ぎ人としての滞在をしているのであった。",
              "citation": {
                "source": "機関車",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子も娘もあるのだが、土地には何もする用がないので皆出稼ぎに行つてゐるのださうだ。",
              "citation": {
                "source": "樹木とその葉",
                "author": "桃の實",
                "note": "青空文庫"
              }
            },
            {
              "text": "例せば、紀州地方より海外に出稼ぐ者多きが、つねに国元へ送金するに、まずその一部分をおのが産土神に献じ、また出稼ぎ地方の方物異産を奉り、故郷を慕うの意を表す。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "輪島からは海の上を、追立てられ、漕流されて、出稼ぎの売色に出る事。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "簇つた花の上には糊をつけた白糸が三括りばかり竿に掛けて干してある、余は此邊の人は出稼ぎでもするのかと娘にきいて見たら此邊一般の鼻に掛つた言葉でうつむいたまゝ低くいつたのだからよくは分らなかつたが「出はつて居りやヘン」といふやうに聞えた。",
              "citation": {
                "source": "鉛筆日抄",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く出稼ぎに出て居た私が駈け附けた時には、薄馬鹿の妹が小さく暗い家に足を投げ出して、何か考え事をしているのを見た丈であった。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "春になり仕事が無くなると、カムサツカへ出稼ぎに出た。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――北海道では何処だって、出稼ぎは別にして、冬の内職などするものがなくなってしまっているではないか。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "こてちゃんの小鉄は十九の年に本国からこの土地へ出稼ぎに来て、去年の夏であしかけ三年目であった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それは津軽から出稼ぎに来ているまだ三十前の若い男だった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "出稼ぎに行つた先の土地の生活状態、勞働の條件、風俗、名物、女、食物、などが語られた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラジルといへば近頃日本人が続々出稼ぎに往く国で、善いものと悪いものとが、ごつちやになつて棲むでゐる処である。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "他国に出稼ぎするものにくらべると、産れ在所に残つてゐるものの方が多く長命なのは、最近の統計の証明するところで、これは男にも女にも共通の確な事実である。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "他民族の心理は内地から出稼ぎに来た人々に簡単に理解せられない。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "満州へ出稼ぎに行ったという人は、われわれ働く者のまわりにもあります。",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "満州こそ、三井、三菱、住友などという大ブルジョアが資本家・地主の政府と腕を組んでせっせと搾っているところだ、日本人が内地から出稼ぎに行って搾られているばかりではない。",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、自分が骨を折って若い男女の冬期間だけの出稼ぎを援助し、「村民の気分を作興して」例えば娘の身売りを平気でさせる「貞操に関する観念の極めて鈍感であることを」改善しなければならぬ。",
              "citation": {
                "source": "村からの娘",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は父親がハワイに出稼ぎに行ってる間に産れた子で、あちらで育ったので英語が話せた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この藪原の駅からは多く大工が出稼ぎに出る。",
              "citation": {
                "source": "木曾御嶽の両面",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "此籔原の驛からは多く大工が出稼ぎに出る。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈の薄暗い三等室には、トランシルヴァニア、モラヴィア、ヘルツェゴヴィア、ポドリア、シュワビア、カアランドなどという、聞いたこともない中世紀的な欧羅巴の隅々から、新大陸に憧憬れて亜米利加へ出稼ぎに行く移民の女達が、子供の寝顔を見守って物思いに耽っていた。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれほど寝ながら書物の印税を受け取り、寝ながら領収書を書き、また寝ながら印税でかせぎ抜いた作家も、まれであった。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "小型は早朝から日没までかせぎます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
