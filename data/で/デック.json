    "definitions": [
      {
        "index": 1,
        "gloss": "Digital Equipment Corporation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「マイクロプロセッサーを使って、コンピューターのおもちゃのようなものを作ってみよう」さらに一歩進んで「こいつで高級言語を走らせ、誰でも手のだせる個人用のコンピューターを作ろう」などという奇想天外なアイデアは、少なくともＩＢＭやＤＥＣからは、何年たってもでてこなかっただろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて大型コンピューターしかなかった時期、ＤＥＣという会社が突然「小さいことはいいことだ」と言い出した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "とすれば機械を小型で安いものにしてやれば、潜在的な需要を広く掘り起こせるのではないか」　ＤＥＣはこう考えて、ミニコンピューターというのを出した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "つごうがいいことに、モトローラという別の会社はＤＥＣのミニコンピューターの作りを意識した、６８系（６８０００、６８０２０、６８０３０と続くシリーズだ）の製品を出していた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "案の定ソニーで使っているＤＥＣのミニコンピューターＶＡＸも、背負わされた荷のあまりの重さに、息も絶え絶えとなっていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "目標は当時の安価なコンピューターだったＤＥＣのミニコンの二十分の一、二千ドルに置いた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、ミニコンピューターを押さえてきたＤＥＣが名を連ねているのか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがディジタルイクイップメント（ＤＥＣ）という新興の小型コンピューターメーカーが出したＰＤＰ―８と名づけられた機種は、検査装置のコントロールに用いるのにぴったりだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "メーカー自身とごく一部の専門担当者にマシンに関する情報を独占させるのではなく、各分野の研究者や技術者に使い道やノウハウを開拓してもらうことで利用の裾野を広げていこうと考えたＤＥＣは、自社の製品に関して徹底的に技術を公開する方針をとっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "回路図と首っ引きになってＤＥＣのＰＤＰ―８をしゃぶりつくした経験を持っていた後藤は、システムを理解してもらううえで情報の公開がいかに大きな意味を持つかを痛感していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにＤＥＣはユーザー自身が書き起こしたプログラムを集め、開発者の希望に沿って有償もしくは無償で、ソフトウエアを流通させるという手段によって、自社のマシンの使用環境を他力によっても耕そうと努めていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしたＤＥＣの流儀が、コンピューターをどれだけ使いやすくしてくれるかを体験していた後藤は、マイクロコンピューターを理解してもらうのが目的のＴＫ―80ならなおさら、徹底して情報を公開するべきだと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした一行の目の付けどころに彼らがどんなに驚かされ、また喜んだかは、この段階ではまだ遅れ遅れの発行となっていた『ＤＤＪ』の一九七六年五月号に、「ＪＩＰＤＥＣ ＶＩＳＩＴ ＰＣＣ」のタイトルでまとめられている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが数百万ドルはする大型コンピューターはとても買えず、ＤＥＣが低価格を武器に攻勢をかけていた小型のミニコンピューターにも手は届かなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで学校はＤＥＣのＰＤＰ―10を持っていたゼネラルエレクトリックと交渉し、使用時間に応じて料金を支払う契約を結んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＣＣＣはＰＤＰ―10の購入に際して、システムソフトウエアのバグを継続的に発見しているあいだは代金の支払いを猶予するという契約をＤＥＣと結んでいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカではディジタルイクイップメント（ＤＥＣ）の開発したミニコンピューターがまず研究者や技術者の注目を集め、ユーザー自身が必要とするプログラムを開発するという流儀に沿って、コンピューターの小型化の波が進んでいった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大型コンピューターを独占するＩＢＭの足下を食い荒らしはじめたＤＥＣの快進撃を受けて、日本でも一九七〇年前後、各社がミニコンピューターに参入していった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューター科学を専攻し、卒業後いったんはＤＥＣのソフトウエア技術者となった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は大学にあったＤＥＣのＰＤＰ―10で簡単な自動計算ツールを書き、自分自身を手計算の泥沼に追いやることは賢明にも回避した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＤＥＣのタイム・シェアリング・システム用のＴＯＰＳ―10というＯＳを参考にして書いたこのソフトウエアを、彼はＣＰ／Ｍ（Control Program for Microcomputer）と名付けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★「フロッピーディスク・オペレーティング・システムに関する初報告／ＤＥＣＳＹＳＴＥＭ―10に類似したコマンド言語と機能」　ＣＰ／Ｍには注文がすぐに集まりはじめ、草の根からの人気が高まっていった★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "テスト実験機（Test-eXperimental computer）を略してＴＸ―０と名づけられたこのマシンが動き始める一九五七年、オールセンは開発過程で生み出した技術をビジネスに生かそうと、ボストン近郊のメイナードにディジタルイクイップメント社（ＤＥＣ）を設立した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五〇年代のパーソナルコンピューター★に携わってきたオールセンの起こしたＤＥＣは、ＩＢＭの目の届かない新しい領域に、コンピューターの用途を切り開いていくことになる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＤＥＣの創業にいたる上記の経緯は、『DIJITAL AT WORK』に明快かつ簡潔にまとめられている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＤＥＣの創業当時、将来の可能性は感じさせてはいたものの、コンピューターはいまだビジネスの軌道に乗っていなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "投資会社の意見を入れて事業計画から〈コンピューター〉という文字を外し、ＤＥＣは組み合わせによってコンピューターや機器のコントローラーを作ることができる回路モジュールの開発から着手した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "創業した一九五七年に１００シリーズのモジュールを開発して以来、ＤＥＣはモジュール製品のラインナップを拡張していった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一方でＤＥＣは、自分たちの回路モジュールを組み合わせて、会社設立の本来の目標であった〈道具としてのコンピューター〉の開発にも着手した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンカーン研究所でＴＸ―０やＴＸ―２の開発に携わっていたベン・ガーリーが一九五九年にＤＥＣへ移り、プログラム・データ・プロセッサーを略してＰＤＰ―１と名付けられるマシンの設計にあたった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
