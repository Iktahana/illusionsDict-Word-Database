        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "乾燥した冬の日にセーターを脱ぐと、体が電気を帯びてパチパチする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "風船を髪の毛でこすると、電気を帯びて壁に貼り付く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "導体が電気を帯びることで、電気が流れる準備が整う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "例えばガラスなどは絹で摩擦すれば陽電気を帯びるがフランネルで擦れば陰電気を生ずる。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "化合物の分子は水中に溶けると、構成要素たる原子または原子の集合に分離し、この際分離したものは正負の電気を帯びる。",
              "citation": {
                "source": "墨流しの物理的研究",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
