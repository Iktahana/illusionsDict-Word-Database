    "definitions": [
      {
        "index": 1,
        "gloss": "can never be able to",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いや、私などには、一生、どんなに所謂「修行」をしても出来っこない。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰が抜けていたんでは、片盤坑まで出掛けて人殺しなど出来っこない。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程これでは、小さな浪ぐらいでは、とても全部の泡を消すことなど出来っこない。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから途中からこの有料道路へ乗り込んで走り抜ける訳にも行かなければ、又途中から有料道路を抜け出して走り去ることも出来っこない。",
              "citation": {
                "source": "白妖",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に君子が着ていた母の着物を脱いで、それを再び母の死骸へ着せるなぞと云うことは到底出来っこない。",
              "citation": {
                "source": "銀座幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互にそういう世の中にこの世をしたいからこそ、そして、それはプロレタリア、農民の社会にならなければ出来っこないからこそ、めいめいがめいめいの職務で身に応じた根づよい働きで、その日を早く来させようと闘っているのです。",
              "citation": {
                "source": "「我らの誌上相談」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父様は気が若いからね、入院でもなさらなければ休養なんか出来っこないんだもの。",
              "citation": {
                "source": "わが父",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「失業者の救済なんてどうせ出来っこないんだから、片っぱすから戦争へ出して殺しっちゃえば世話はいらないんだ」　極めて冷静な酷薄な調子で云った。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい気の毒や調子の悪さを超越しなければ、大きな仕事は出来っこないだろう、「黄銅時代」の第壱を書なおしに着手、　島田清次郎氏より来賀、あの若さで、あれ丈俗なのは何故か、自分の広告並年賀は自分に非常にいやな印象を与えた。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が生きているかぎり、日本はとてもわが米国と戦争なんか出来っこないよ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああでなくては美味いものひとつだって出来っこないんだし、あれでちゃんと一流のすしやになりきるんだと思うね。",
              "citation": {
                "source": "料理一夕話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "画をかきに来て、こんな事を考えたり、こんな話しを聴くばかりでは、何日かかっても一枚も出来っこない。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "天一でなけりゃ一人で新郎になったり牧師になったり出来っこない。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「気持が二半では、どんなことだって出来っこないよ。",
              "citation": {
                "source": "我に叛く",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃は、生活の現実の中にはまりこんでいなくては、ちゃんとした仕事なんか出来っこないとわかって来ているから、本当に何よりです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "島田の家では、子供でも出来たら、子供が集注した注意で学校の勉強の出来るような場所と空気をつくってやることが必須ですし、あすこで勉強ずきの子供なんか出来っこないもの、床が絶えずゆすれるような落付かなさで。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂々とした樹と同じ丈堂々と出来っこないのだし、しゃっちこばって堂々めかして勘ちがいしているよりも、分相当に枝もそよがぬ風にこちらの草はちょいとはためいて見たりするのも愛嬌ではないの？",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうに消えるなんて、出来っこないことだ。",
              "citation": {
                "source": "女妖",
                "author": "前篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、そんなことは出来っこない。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえにゃ、話なんぞできっこない！",
              "citation": {
                "source": "のろまのハンス",
                "author": "――むかしばなしの再話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうは言っても、なんにもないところに、なにかを見つけることは、できっこないけどね。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみたちの気まぐれに、完璧に対応するなんて、できっこないでしょう」　重なったグラスにつづいて、口を切っていないボトルがテーブルにおかれた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "君のような人間とは、友達として話すことなんて金輪際できっこない……なんら虚心坦懐なところも、誠実なところもありゃしない！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから恒三は閑人だって云われるのよ」「その代り御前の叔父さんには芭蕉の研究なんか死ぬまでできっこない」「したかないわ、そんな研究なんか。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれには貧乏なんか我慢できっこないんだ。",
              "citation": {
                "source": "妻",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おどろいたな、ぼくたちには、できっこない。",
              "citation": {
                "source": "さか立ち小僧さん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "家にたてこもっている人ではとてもこの学問はできっこない。",
              "citation": {
                "source": "若き日の思い出",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたには、こんな粗相はできっこないのね。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「子供はいつまで経ったってできっこないよ」と先生がいった。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんぼ私だってあなたにできっこないような不法は考えやしませんよ。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
