    "definitions": [
      {
        "index": 1,
        "gloss": "unlicensed prostitute (Edo period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
