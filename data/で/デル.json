    "definitions": [
      {
        "index": 1,
        "gloss": "to leave",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "死んだ宮沢は、自分が死ねば全集が出ると、果して予測してゐたであらうか。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると間もなく、彼の全集が出ると聞いて、喜んだことは勿論ですが、却て忌々しい気もしました。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れ「明治・大正詩人論」といふ書が近々出るわけですから、その中で宮沢賢治のことは、詳しく論じたいと思つてゐます。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてなが魂もいやにがき、深淵ぞ　さうに違ひない、海を見てると溜息が出る。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕なぞまだ何処にも発表しない頃のことだし、何れ高森の方が早く所謂詩壇に出るのであらうと思つてゐたが、游牧記の後では、石川道雄主宰の半仙戯、其の後は友野代三主宰の童説といつたあまり世間の表てに顔を出したがつてゐない雑誌に発表するだけで、一向に其の他に発表はしたがらないのであつた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際文壇に出ることが容易になつた此の頃は、さういつた文学青年も少くないことで、一知半解の故に却て元気がいいといつた風の元気が、本当の元気と間違へられる風景は、毎日のやうに見受けられることである）。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その通りを行き切つて、明るい旧通りへ出ると、そこから直ぐと近くにある、彼が三年前に屡々買つたり売つたりしてゐた古本屋に、チヨツと寄つてみようかといふ気が起つた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　それやおまへが出ると、また俺の嫌な人間ばかりを連れ込むからさ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの文学に出る日本婦人のモデルは、多くその妻に非ずば姑の老婦人だといわれてるが、すくなくともヘルンは、この点での好運にめぐまれていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後も新作が出る毎に、僕の意見をよく求められ、自分のデタラメな獨斷批評を、熱心によく傾聽してくれた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼、つい旅行に出る數日前に、あれほど親しく逢つて話した彼が、眞實にも自殺をしたのだ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新宿で好きなのは、あの淀橋から煙草工場の方へ出る青梅街道の通である。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冗談から駒の出る現実を。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思慮分別の深い結納のお使者は、ひどく酔いました、これは、ひどく酔いました、と言いながら、紋附羽織と白足袋をまた風呂敷に包んで持って、どうやら無事に、会津藩士の邸宅から脱れ出ることが出来たのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」奇妙に大きく出る。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三日中に、文芸春秋社から「新ハムレット」が出る筈です。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、すぐまた砂子屋書房から「晩年」の新版が出るそうです。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて筑摩書房から「千代女」が、高梨書店から「信天翁」が出る筈です。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月までには、みんな出るでしょう。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慌ててゐたので少ししか開かなかつた格子戸を、からだを横にして出る時に、女の顔が見えた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこへ二階からドヤドヤドヤと降りて来た良子の義理の兄さんが、便所に行かうとして椽側に出ると、其処に猫の食べ物を入れてやるお皿が置いてあるのを見ると、お祖母さんの眼を怖い顔で見ながら、そのお皿を庭の方へ蹴り棄てた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の肘の前にある灰皿の中の、喫ひ終つたばかりの喫殻から登る紫色の煙と、他の古い喫殻にそれが燃え移つて出る茶褐色の毒々しい煙とが、やゝもすれば彼の顔に打つ衝かつたが、そんなことには元来頓着ない彼であつた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐ行くから」　看護婦は難所を抜け出るやうに走り去つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、出しますよ、今度は出る、――揺らずにヂツと――さう／＼／＼……」彼は母親の肩に手を掛けて自分が仕事のしよい位置を取らせた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さう早く出るもんか」「だがね、今日はもう何も云つては駄目ですよ、今急病人があつてお父様は気が立つてるからね」　その時、俄然台所の方から、牛肉か何かを叩く音がして来ると、そゝくさと蒼い顔の妻君は長男の部屋をも立ち去つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら技巧とは一々の場合に当つて作者自身の関心内にあることで、殊に芸術の場合には名辞以前の世界での作業であり、技巧論即ち論となるや名辞以後の世界に属する所から、技巧論といふものはせいぜい制作意向の抽象表情を捉へてそれの属性を述べること以上には本来出ることが出来ない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それは私に変な癖があるのだが、一度私が矢張広島の頃、父が東京に出張するといつて出る時、私はそれまでは何でもなかつたが、父の俥がいよいよ玄関を出る時急に人生の大切な岐路にでも立たせられたやうな気がして来て、泣く泣く父の俥の後を二三町ばかり泣きながら夢中に追つ駆けたことがあつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして父の従兄から出る僅かの金で父はかつがつ軍医学校まで卒へた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "著実な詩の書が、ぼつぼつと出ることともなれば、文壇はもつと住心地のよい所ともなるであらう。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば今晩かなしげに、かうして沈んでゐる僕が、輝き出でる時もある。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
