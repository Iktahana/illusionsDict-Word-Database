        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "波止場へ降りると、海面の所で大きな松明がごうごうと、まるで電弧のように輝いている。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――でんこでんこの遊びではないが、一町ほど遠い遠うい――角邸から響かないのは無論である。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二｜卷の速に出でんことを待つ。",
              "citation": {
                "source": "罪と罰（内田不知庵譯）",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "預言者は幾たびも出で、聖人は幾たびも出づ、人間は幾たびも己れの秘密を歌ひ、己れに教訓を与ふべき者の出でんことを望む。",
              "citation": {
                "source": "詩人論",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は詩道のベーコンが世に出でんことを望む。",
              "citation": {
                "source": "詩人論",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯先生を中心として起った悲劇に因り御一同の大小浅深さま／″＼に受けられた苦痛から最好きものゝ生れ出でんことを信じ、且｜祷るのみであります。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時までんこぎやんしとるぎりや、ろくなこた、ありやせんえる。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "火来りて身に逼り、苦痛｜己を切むれども、心に厭ひ患へず、出でんことを求むる意無し」という火宅無常の憂いの声はひそんでいる筈である。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
