    "definitions": [
      {
        "index": 1,
        "gloss": "fresh out of (college, high school, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "奴あ死んでるぜ」　彼は監獄から出たての放免囚見たいに、青くなって云った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら、僕、中学出たての小僧だって、僕あそんな意気地無しにあ、なれません」「じゃあ、どうすればいいの」「どうも出来ません。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は学校出たての若い副手達である。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "合同資本と謂ツても、其の實田舍から出たての叔父と綾さんの父とが幾らか金を持ツてゐたゞけて、後は他の懐中を的の、ヤマを打當やうといふ連中の仕事だ。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうね、商売に出たてにはそんなこともあったようだわ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　銀子にもそんな思い出の一つや二つはあったが、彼女が出たての莟のような清純さを冒された悔恨は、今になっても拭いきれぬ痕を残しているのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "出たてには銀子の牡丹も、自分の座敷へ呼んでくれた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "出たてのころ目につくのは、大抵若いのっぺりした男なのだが、鳥居の数が重なるにつれ、若造では喰い足りなくなり、莫迦々々しい感じのするのが、彼女たちの早熟の悲哀であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この土地では出たての芸者は新妓といってね、わりかた東京ッ児の持てる処なんだよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子が芳町へ出たての時分、母は彼女をつれて町の医者に診てもらったことがあったが、医者は母親を別室に呼び、不機嫌そうに、あんなになるまでうっちゃっておいて、今時分連れて来て何になると思うのかと叱るので、母はその瞬間から見切りをつけていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "看板を書かえる隙もない、まだ出たてだという、新しさより、一人旅の木賃宿に、かよわい女が紙衾の可哀さが見えた。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたわらシャーロック・ホームズはあのお気に入りの耳垂れつき旅行帽をかぶり、油断なく熱心な顔で、パディントンで入手した出たての新聞の束にせわしなく目を落としていた。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "君たちくらいの中学校から出たての年頃が一ばん英語を覚えているものです。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "▼巡査講習所を出たての、ホヤホヤのお巡さんでも、社会政策に対しては阿部氏よりも、もつと具体的な意見をもつてゐさうである。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れて出たては至極穩かで、白山あたりから通つて來る、或｜大工と懇意になつて、其大工が始終長火鉢の傍に頑張つてゐた。",
              "citation": {
                "source": "絶望",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学を出たての医学士なんか、恐ろしくて診てもらう気がしません。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのどつちもが、毎年春には、小學校を出たての少女を求めてゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも學校出たての若い醫者らしい風格が、さうして和服姿で寛いでゐても身についてゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "專門學校を出たての若いサラリーマンといふところであらう。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "逓信省内には、大学を出たての若い学士連が虫のやうに蠢々してゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も早や東京へ出たての時のやうに髮などを長く垂れ下げて、黄八丈の羽織をヨソイキに着るやうな少年ではありませんでした。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると学校を出たての平岡でないから、先方に解らない、且つ都合のわるいことは成るべく云はない様にして置く。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、手に持つた団扇を放り出して、湯から出たての奇麗な繊い指を、代助の前に広げて見せた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議なことには、それが女学校を出たての葉子がしばらく身を寄せていたという彼女の親類の一人であった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとにわかに七匹ともまるでたてがみをそろえてかけ出したのです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある科学の雑誌に書いてあったからほんとうだと、太郎左衛門はあかしまでたてたのだそうだ。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはとみが、働いて自分でたてた家である。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と熱燗三杯、手酌でたてつけた顔を撫でて、「おかみさん。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "返辞を申し上げるつもりでたてた声が、夢に襲われた声であったから、夫人が、「まあ、どうなさいました、そんなに」　と言ったので源氏は目がさめた。",
              "citation": {
                "source": "源氏物語",
                "author": "朝顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関は細いきれいな格子でたてきってある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
