        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昨今天下を支配する生繭相場も、この地の出来値を一基とするともいふ。",
              "citation": {
                "source": "南予枇杷行",
                "author": "河東碧梧桐",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕にはねえ」私の顔をちらと見てから、口角に少し笑いを含めて、「ひとの見さかいができねえんだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "火傷つてやつも、なかなか馬鹿にできねえものだぜ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかり油断はできねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "「外じゃあ話ができねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなか油断はできねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、シズエ子ちゃんのお母さんみたいな、あんなわがまま者には、とても永く田舎で辛抱できねえだろうが。",
              "citation": {
                "source": "メリイクリスマス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕にはねえ、」私の顏をちらと見てから、口角に少し笑ひを含めて、「ひとの見さかひができねえんだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう承知できねえ」　ぼんやり外の暗闇を見ながら、ひとりごとのようにそう呟き、けれども、その男のひとの総身の力は既に抜けてしまっていました。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "千円、二千円となりゃあてめえなんか、一生かかったってできるかできねえか分かりゃしめえ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの野郎は油断ができねえんだが……」「なんでも、その浪岡をどこかへ売るらしいなあ」「なに？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、正勝さんにだって悪い顔はできねえのさ」「しかし、顔や姿は敬二郎さんのほうが立派かもしれねえが、人間の出来からいったら正勝さんのほうが上じゃねえかなあ？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、片方の目どころか両方の目が見えなくなったって、おれにはそんな大金ができねえから、村の人たちと相談してみたところ、村の人たちが全部保証人になって雑穀屋から借りてくれるって言うんで来たのですが、雑穀屋も百五十両からとなると……」　開墾地の稲吉はそこまで言って、啜り泣くようにして笑いだした。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正勝さんと紀久子さんとは、自分たちは一緒になりてえんだが、親父さんの代に、はあ、敬二郎さんという人が約束になっているので、いまさらそれができねえもんだから、敬二郎さんを殺してしまうようなことでも考えているんじゃねえのか？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこの技を極限まで発揮しようとするには、知り得る限りのあらゆる事実を推理の際に利用できねばならない。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那、もうこうなったうえは、私も卑怯な真似はいたしません、放してください、そんなにせられちゃ、呼吸もできねえのだ、まあ、ゆっくり話しましょう、何も騒ぐことはありませんよ」と運転手が冷やかに云って、その手を除けようとしたが除かなかった。",
              "citation": {
                "source": "黄燈",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「陛下、わっしの船艙の中へ、陛下が今おっしゃったその酒の四分の一でもしめえこむなんてこたあ、とてもできねえ相談というものでございましょう。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "――わっしはもう何だろうが少しも、飲みてえとも思わなければ、飲むこともできねえんですから。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私といっしょに耕作するって、ほんとに三郎さんはそんな気かしら、三郎さんがほんとにそんな気ならばいくら嬉しいか知れぬけれど……大学校を卒業した、園部の三男様が、私といっしょに耕作するって、あんだかほんとにできねい。",
              "citation": {
                "source": "新万葉物語",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥だらけのこの姿じゃあ座敷へ入れることができねえ」　半七の指図で、店の者は手桶に水を汲んで来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "てめえ達が一年や半年、夜の目も寝ずに稼いだって、女郎なんぞを請け出して来るほどの金はできねえ筈だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれたちじゃとても太刀打ちができねえから、やっぱりストキに頼むんだね」「じゃあ、今夜要求条件をこしらえて、それに全部で連印して、それを船長に提出しようじゃないか」波田がいった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "『やい見えるかい、え、これに判をつけ、さもねえと、正月は横浜じゃできねえぜ』と高飛車に出たら随分痛快だろうね」西沢はいった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことが出来ると思っているの」「表向きは無論できねえ理屈さ。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛松　親分、俺あお伴はできねえかね。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "九郎助は一枚入っているから連れて行きていが、最初いった言を変改することはできねえから、勘弁しな。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "密夫の心得がのうて、密夫の狂言ができねば、盗人の心得がのうては、盗人の狂言はできぬ訳合いじゃ。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだ、むっつり右門とたちうちゃできねえぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の気を使っていけなきゃ、お茶一つ口にすることもできねえじゃねえかよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、そのご牢内へは刃物はおろか、ハの字のつくものも持ち込むことはできねえですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
