          "literary": [
            {
              "text": "およそのことを言えば、Ｔ、Ａ、Ｏ、Ｉ、Ｎ、Ｓ、Ｈ、Ｒ、Ｄ、Ｌというのが出やすい順だ。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにあの涙の出やすい目からは涙がほろほろととめどもなく流れ出るに違いない。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりゃな、東京の金はとれやすいかも知らんが、入りやすい金は出やすいもんだよ。",
              "citation": {
                "source": "白い道",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本語より英語の方が幼稚ではあるが、使う場合が多かったものですからちょっと出やすい。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほうが話も出やすいでしょうから」　そう言って村田は立ち上がり、ファイルをかかえて日比谷に挨拶をした。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "青木堂ではあんなにもさがして居たロリアがあるのに、二十七銭でやすいと云うためか、さんざん、ありませんありませんと云った。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、仕事のないときですから、大工たちはよろこんでやすいちんぎんではたらいてくれ、なかなかりっぱな塾ができあがりました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "テンコウは砂糖のうちでやすい、赤っぽいてんこ砂糖です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三五年（昭和十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
