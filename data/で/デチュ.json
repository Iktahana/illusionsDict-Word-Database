        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "くにに「おねえちゃん、御飯まだでちゅか」という男の子の声す。",
              "citation": {
                "source": "湯ヶ島の数日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "九太の残した丼の汁までちゅうと吸うと、子供のように笑窪のある手の甲で脣のはたを拭いた。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日だったか、窓の外に雀が飛んできて、其処の窓縁でちゅちゅと鳴いては、また何処かへ飛んでいった。",
              "citation": {
                "source": "病室の幻影",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "小指の先をくわえさせると、生温い粘り気のある唇でちゅっちゅっと吸った。",
              "citation": {
                "source": "幻の彼方",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも　だんなの　しまりすハッキーは　わたしを　おいて　いえでちゅう。",
              "citation": {
                "source": "つまさきチミーのはなし",
                "author": "THE TALE OF TIMMY TIPTOES",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの　だんな、　つまさきチミーも　いえでちゅうで。",
              "citation": {
                "source": "つまさきチミーのはなし",
                "author": "THE TALE OF TIMMY TIPTOES",
                "note": "青空文庫"
              }
            },
            {
              "text": "（指さして）ほら、あっちの方でちゅくちゅく鳴いている鳥はあれはなあに？",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（指さして）じゃ、向うの方でちゅんちゅん鳴いてるのは？",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "でやっと（ふいと何かの拍子に）、ナポレオンならこんなことでちゅうちょするどころか、それが非モニュメンタルだなんてことは、夢にも考えなかったろう……いや、そこに何をちゅうちょすることがあるのか、それさえまるでわからなかったに違いない、とこう考えついた時には、僕はむしょうに恥ずかしくなったくらいだ。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "「上野ですか、ハイおツリでちゅ」ぐらいならよいが、家の中を飛び廻って裁縫する妻、洗濯している女中にも、一々聞いてまわる。",
              "citation": {
                "source": "親は眺めて考えている",
                "author": "金森徳次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤児はとびつくように口をすり寄せ、びっくりするほどのちからでおせんの舌を吸う、ひじょうな力でちゅうちゅうと音を立てて吸うが、やがて口を放すとひき裂けるような声で泣きだすのであった。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
