        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ラグビー選手がＤＫを狙ってボールを蹴り上げたが、惜しくもゴールはならなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試合の終盤、彼は劇的なＤＫでチームに逆転勝利をもたらした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ラグビーにおいて、ＤＫは試合の流れを変える重要なプレーの一つです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
