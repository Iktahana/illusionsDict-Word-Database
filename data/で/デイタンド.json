        "examples": {
          "standard": [
            {
              "text": "泥炭土は有機質に富むため、農業用土壌としても利用されることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "湿地帯の泥炭土は、炭素を大量に貯蔵している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "庭の土壌改良のために、客土として泥炭土を混ぜ込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "地下茎の上に地下茎を伸ばし、その上におのれの葉や茎を腐らかし、またその上に根を張り、葉をしげらし、枯れ頽れ、――積みあげ積み重ねた数えきれないほどの春夏秋冬が、踏めば沈むような低位泥炭土をつくっていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "樺太のツンドラは、シベリア奥地のツンドラなどとは少しちがって、むしろ高位泥炭土といった方がよいものであることも初めて知った。",
              "citation": {
                "source": "ツンドラへの旅",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
