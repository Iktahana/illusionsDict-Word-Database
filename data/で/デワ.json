    "definitions": [
      {
        "index": 1,
        "gloss": "Dewa (former province located in present-day Yamagata and Akita prefectures)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それからまた、文治五年九月に奥州の泰衡がほろびると、その翌年、すなわち建久元年の二月に、泰衡の遺臣｜大河次郎重任（あるいは兼任という）が兵を出羽に挙げた。",
              "citation": {
                "source": "かたき討雑感",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小町は近畿在住の小野家一族中に姫として出生し、直ちに宮中へ仕へたといふ説と、飽くまで伝説通り、良真が出羽守として赴任中妾腹に生れ、後京都に上つたといふ説とである。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして小町の古蹟と呼ばれてゐるものも近畿地方と出羽国との双方に多く割拠してゐる。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母と共にさまよひ、出羽を過ぎ、越後に到り直江の浦云々。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斉明天皇の御代、越の国司、阿倍比羅夫出羽方面の蝦夷地を経略して齶田（今の秋田）渟代（今の能代）津軽に到り、遂に北海道に及ぶ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "津軽蝦夷の称は、元慶二年出羽の夷反乱の際にも、屡々散見す。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奥羽とは奥州、出羽の併称で、奥州とは陸奥州の略称である。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に出羽は『いでは』で、出端の義と解せられる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出羽奥州すでに化外の僻陬と見なされてゐたのだから、その極北の津軽半島などに到つては熊や猿の住む土地くらゐに考へられてゐたかも知れない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜田博士は、さらに奥羽の沿革を説き、「頼朝の奥羽平定以後と雖も、その統治に当り自然他と同一なること能はず、『出羽陸奥に於いては夷の地たるによりて』との理由のもとに、一旦実施しかけた田制改革の処分をも中止して、すべて秀衡、泰衡の旧規に従ふべきことを命ずるのやむを得ざる程であつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木造から、五能線に依つて約三十分くらゐで鳴沢、鰺ヶ沢を過ぎ、その辺で津軽平野もおしまひになつて、それから列車は日本海岸に沿うて走り、右に海を眺め左にすぐ出羽丘陵北端の余波の山々を見ながら一時間ほど経つと、右の窓に大戸瀬の奇勝が展開する。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠅の事に就いて今挙げた片倉小十郎や伊達政宗に関聯して、天正十八年、陸奥出羽の鎮護の大任を負わされた蒲生氏郷を中心とする。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "威を示して出羽奥州一撫でに治めて終おうというのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "是に於て誰か知ら然る可き人物を会津の主将に据えて、奥州出羽の押えの大任、わけては伊達政宗をのさばり出さぬように、表はじっとりと扱って事端を発させぬように、内々はごっつりと手強くアテテ屏息させるような、シッカリした者を必要とするのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏郷が会津の守護、奥州出羽の押えに任ぜられたに就ては面白い話が伝えられている。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから関白が武威を奥羽に示すのに従属して、宇都宮から会津と附いて来たのであるが、今しも秀吉の鑑識を以て会津の城主、奥州出羽の押えということに定められたのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八万石程から一足飛に四十二万石の大封を賜わったのだから、たとい大役を引受けさせられたとは云え、奥州出羽の押えという名誉を背負い、目覚ましい加禄を得たので、家臣連の悦んだろうことは察するに余りある。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "江州日野五千石ばかりから取上って、今は日本｜無双の大国たる出羽奥州、藤原の秀衡や清原武衡の故地に踏みしかって、四十二万石の大禄を領するに至った氏郷がただ凝然と黙々として居る。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥州出羽は裏面ではモヤモヤムクムクして居ても先ず治まった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "天平神護二年六月には、大隅国神造新島、弘仁九年七月には、相模、武蔵、下総、常陸、上野、下野の諸国、天長七年一月には、出羽に地震があった。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、三河、丹波、伊豆、信濃、出羽、越中、越後、出雲にも大きな地震があったらしい。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元文元年の秋、新七の船は、出羽国秋田から米を積んで出帆した。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "近い例でこの桶狭間の役に梁田出羽守には、善き一言よく大利を得しめたと云って沓掛村三千貫の地を与えたが、義元の首を獲た毛利新助はその賞梁田に及ばなかった。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠直卿早速、舎弟伊予守忠昌、出羽守直次をして左右両軍を連ねさせ、二万余騎を以て押し寄せたが、幸村は今暫く待って戦わんと、待味方の備をもって、これに当っていた。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――左様、おれは坂崎出羽守だ！",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸奥や出羽から良馬の出たことは、『続日本紀』や『類聚三代格』などにも見えていますし、とにかく、東北地方から良馬を産出したことは早くから知られていまして、藤原俊成なども『長秋詠藻』の中で「みちのくのあらのの牧の駒だにもとればとられてなれ行くものを」と詠んでいます。",
              "citation": {
                "source": "文学に現れたる東北地方の地方色",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出羽の地もこれ限りである。",
              "citation": {
                "source": "鉛筆日抄",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は出羽と天然の境界を形つて居る關山峠である。",
              "citation": {
                "source": "旅の日記",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "『吹くのが面白いものだから、自分でわざと火を消しては、やたらに吹いた』と、夫人が追想談で話しているが、おそらくそういう場合、ヘルンの筆が行き渋り、感興が中断した時であったろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者が、読んでわからなかったら、それまでの話だ。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
