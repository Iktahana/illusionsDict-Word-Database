        "examples": {
          "standard": [
            {
              "text": "デメテルは、ギリシャ神話における豊穣の女神だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古代ギリシャでは、デメテル信仰が盛んだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ペルセポネの物語は、デメテルの悲しみと結びついている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "古欧州で馬崇拝の例、ギリシアの海大神ポセイドン、農の女神デメテル、いずれも本は馬形で、ガウル人は馬神ルジオブス、馬女神エポナを崇めた。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ地域でディオニュソス、キュベレ、デメテルなどの祭儀、とくにディオニュソスの祭儀すなわち明らかに肉欲的な性質の興奮性の礼拝が行われていた。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
