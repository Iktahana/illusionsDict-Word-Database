        "examples": {
          "standard": [
            {
              "text": "彼女は姿勢が良すぎて、少し出っ尻に見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そのモデルは、出っ尻で腰のラインが強調される服を好んで着る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の独特な歩き方は、少し出っ尻になっているせいかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その涙でかすんだ目に、小さいときから子守りばかりさせたためか、出っ尻になってしまった幼いコトエのかわいそうな姿が浮かんできて消えなかった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "石づくりの、でっちりとした重苦しい墓で、それは漱石の心に反した。",
              "citation": {
                "source": "行為の価値",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
