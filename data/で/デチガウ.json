[
  {
    "uuid": "2b6d600d-fc52-5c62-bbcf-3a9325cbf671",
    "entry": "出違う",
    "reading": {
      "primary": "でちがう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to miss a visitor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "特に正月になってからは、女に出違うことが多かったので、一層面白かった。",
              "citation": {
                "source": "微笑",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画と、小説とは、まるでちがうものだ。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点はたしかに人間と昆虫とでちがうようである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――とにかく形式はルソオのようなところはあっても味はまるでちがうと思う。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも肥料の入れようやなんかまるでちがうんだから。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分に老人から聞いた話によると、ほんとうの真剣勝負というものはこれとはまるでちがうものだそうである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、卵の中にいたときとは、まるでちがうのですから、こう言うのも、むりはありません。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こいつは、わけのわからぬやつなのだ、みんなとはものの考えかたがまるでちがう、別の人間なのだと、思いながら、みんなにたちまじっている太郎左衛門の横顔を、するどく見ていた。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその気取りかたは、そこいらの気どり方とはまるでちがう。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ対手がひろい海、力のつよい海だから海辺の女の動きも大きくて活溌で、農村の女の身ごなしとはまるでちがう逞しさが感じられるのである。",
              "citation": {
                "source": "漁村の婦人の生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜内蔵相の答えかたには、首相とまるでちがう一種の話術のようなものがあって、議席の空気はおや？",
              "citation": {
                "source": "待呆け議会風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう憤ろしい思いで雨の中をのぼり下った琴平の大鳥居の下に、こういう小道や公会堂があって、暗いやるせない信心とはまるでちがう新しい気運が、そこで開かれている会合で活溌に表現されている現在が愉快であった。",
              "citation": {
                "source": "琴平",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小原壮助が、社会機構や生活感情のすべての、まるでちがう「我国の場合」を躊躇なく例としてひいて来ていることは注目される。",
              "citation": {
                "source": "しかし昔にはかえらない",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史に働きかける力としての存在ということも、いつも立役者として舞台の真中に華々しく登場しているということとまるでちがう。",
              "citation": {
                "source": "生活者としての成長",
                "author": "――二葉亭四迷の悲劇にもふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "してみると、兄と自分との恋は、まるでちがう考えが、元になっているのではあるまいか。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "お医者さんが二十二、三と鑑定したと新聞に出ていたよ」　もしやお貞の死体ではないかと乗気になって聞いて見たが、年が恰でちがうので岸本はがっかりした。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田の土、畑の土、それは金と汗のかたまりの土、往来の泥とはまるでちがう財産ということを由兵衛に子供のうちからきかされて育った。",
              "citation": {
                "source": "昔の火事",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それが島々でちがうんで色々あるんだがね。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多く読み、ことごとくを忘れると、物の見方、考え方が公平になって行くようであるし、一旦読んで忘れたものは、読まずに知らぬのと、丸でちがう。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は昨年、女房が死んで、その当座、女房のことをよく思いだしたものだが、そういう思い出とはまるでちがう。",
              "citation": {
                "source": "南さんの恋人",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "刺子の下ではうかがいようもなかったが、昔の存八とはまるでちがう。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きるということからしてちがう意味でちがう方法であったようです。",
              "citation": {
                "source": "落ちてゆく世界",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去の人とは、まるでちがう性格だし、風貌だし、動きでした。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら結晶の形がまるでちがうという意外な結果が得られた。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで氷の結晶には、不思議な性質があって、結晶主軸の方向と、それに直角の方向とでは、機械的の性質が、まるでちがうのである。",
              "citation": {
                "source": "アラスカの氷河",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと伊豆者と尾張者は気性が合わないところへ、尾張方は一向宗、伊豆方は日蓮宗で宗旨までちがう。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとは考え方がまるでちがうので、小学校六年の義務教育というのは、六カ年在学することが義務であって、六年間いて三年生の知識で卒業しても、ちっともかまわない。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学教育というものに対する考え方がまるでちがうので、学者をつくる気は初めからない。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは日本でも大いにやったほうが良さそうなものであるが、ここで考えねばならないことは、イタリアと日本とでは、国情がまるでちがう点である。",
              "citation": {
                "source": "温泉２",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも商売がまるでちがうので、悪びれる必要もなく、藤村くらいのところがちょうどよいのだなどといってすましていたわけである。",
              "citation": {
                "source": "詩人への註文",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
