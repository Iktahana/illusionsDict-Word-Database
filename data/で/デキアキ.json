    "definitions": [
      {
        "index": 1,
        "gloss": "autumn at harvest time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "六時出立、我ながらサツソウとしてあるく、見渡すかぎり出来秋のよろこびだ（実際問題としては豊年飢饉だらう！",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来秋ぢや、出来秋ぢやと云うて米は不作。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来秋の村芝居とおなじ野趣に対して、私も少からず興味を感ずる。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "時候の挨拶や、この出来秋の噂などが済んで、長次郎はやがてこんなことを云い出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "小女郎狐",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来秋の野良仕事はまことにいそがしい、その間をぶらつく私は恥づかしかつた、私はまつたく不生産的人間だ、社会の寄生虫だ！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりは、今は彼女は出来秋の心配に移っていた。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出来秋までどうしたらいいであろうか。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来秋まで、何の心配もなく食うだけのものは貯えておきたい、おかなければならぬ。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村であれば出来秋に稲を貰う。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはなんでも昭和に入ってしばらくした出来秋のことだ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来秋までヤット食いつないで行くうちが十軒の中の九軒までだかんなあ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来秋までヤット食いつないで行く内が十軒の中の九軒までだかんなあ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘三郎は収穫がすむまで家で働いた、その年はどこも近年にない出来秋であったが、与石の田だけは手入れが届かなかったので、ほとんど三分の一がみず稲になってしまったし、夏蚕から晩秋蚕まで繭を掃かなかったから、年末にはおそろしい窮乏に見舞われた。",
              "citation": {
                "source": "藪落し",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
