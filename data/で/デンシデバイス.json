[
  {
    "uuid": "71ffeee6-d810-5819-a5d4-b7cb4dceed2c",
    "entry": "電子デバイス",
    "reading": {
      "primary": "でんしデバイス",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
