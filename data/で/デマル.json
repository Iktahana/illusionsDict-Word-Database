[
  {
    "uuid": "3c535a32-75bc-57cf-bc15-5c18306ced6c",
    "entry": "出丸",
    "reading": {
      "primary": "でまる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
