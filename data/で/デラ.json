        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ほがらかとは、恐らくは、悲しい時には悲しいだけ悲しんでられることでせう？",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "撫でられた象は、イビツな象にしか過ぎなく、一個のものではないので、つまり切り取られた自然といふものは作品、つまり「人間」の作つた物ではなく、機械的な作業に他ならぬ。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼黒くでらでらした大きい油顔で、鼻が、――君レニエの小説で僕はあんな鼻を読んだことがあるぞ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、ごみっぽい雑巾で顔をさかさに撫でられたような思いがした。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた、輕くなつた頬が朝風に撫でられるのも、惡い氣持のものではない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "實生活の生臭い風にお顏を撫でられるのが、とてもとても、いやなんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "根曲り竹も、楊の根も、樅の肌も、はた長くしな垂れるサルオガセも、その柔嫩の手に、一旦は、撫でられぬものはない。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "卵に神経があるのだったら、彼は茹でられている卵だった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時間か四時間の間に、彼は茹でられた菜のように、萎びて、嵩が減って、グニャグニャになっていた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "千里のほかまでと思ひやるに、添ひても行れぬ物なれば唯うらやましうて、これを仮に鏡となしたらば、人のかげも映るべしやなど、果敢なき事さへ思ひ出でらる。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "はだかの肌をするする撫でられるようなころ合いの酸味に、飯と、玉子のあまみがほろほろに交ったあじわいが丁度舌一ぱいに乗った具合――それをひとつ喰べて仕舞うと体を母に拠りつけたいほど、おいしさと、親しさが、ぬくめた香湯のように子供の身うちに湧いた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "咏嘆的な音楽が奏でられ、スカートの長いフランス女とアバッシュなマルセーユ男でワルツを始めました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「休んでらっしゃい。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほんとに休んでらっしゃい。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂漠でらくだがうずくまっていると飛行機の音が響いて来る、するとらくだが驚いて一声高くいなないて立ち上がる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてなでられたくない人は、自由にそれを避ける事ができる。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが自然の癖になって、紙で撫でられるとすぐに首を引っ込めるようになる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も町で飲んでらべぁな。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨夜、今朝方だ※がな、火ぁ消でらたな、覚だが。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父さん外で稼ぃでら。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「火ぁ消でらたもな。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、口｜漱げ、飯でげでら、楢夫。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそのときの、薄い刃物で背を撫でられるような戦慄を空想した。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なして泣いでら、うなかもたのが。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「又三郎吹がせでらべも。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊が行軍している途中からこの歌の魂がピーターパンの幽霊のような姿に移って横にけし飛んだと思うと、やがて流浪の民の夜営のたき火のかたわらにかなでられるヴァイオリンの弦のしらべに変わる。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし計算はますます迷宮に入るばかりで、いつそこから抜けでられるのか予想はとてもつかなくなるばかりだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "籠の中なる何某は出づるにも出でられず、命せに背かば御咎めあらむと、まじ／＼として煙草を吸へば、幼君左右を顧み給ひ、「今こそ豫て申置たる二人前の料理持て參れ」と命ぜらる。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
