    "definitions": [
      {
        "index": 1,
        "gloss": "well done",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、彼女の仕出かしたことに対してはなるだけ無関心でいようとした。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなきさまたちの出かしたこった。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一、そんな事をし出かしたアトで、救いの舟が来たらどうしよう…………という心配に打たれていることが、何にも云わないまんまに、二人同志の心によくわかっているのでした。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは、取り返しのつかない間違いを仕出かしたことを知りました。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためにあのような取り返しの附かないことを仕出かした。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハムレットが、し出かした事ですもの、ハムレットに責任を負ってもらって、一切あの子ひとりにやらせてみたらいいのに。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちの来るところではない、とは出かした。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛衞は高蹈して胸を打ち、初めて「出かしたぞ」と褒めた。",
              "citation": {
                "source": "名人傳",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛衛は高蹈して胸を打ち、初めて「出かしたぞ」と褒めた。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女にすればわたしにいつまでも自分の深い懊悩を眺めさして、わたしに幾久しく悔いさせてやるという執念深い復仇の念と、これほどの結果になるとは知らずにこの人はうっかり仕出かした事だのに可哀相にという憐みの心とが組打ちしてかの女の口を開かせなかったという。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしの牛は今まで一度もお客を落したことはねえのに、どうしてこんな粗相を仕出かしたのか。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "資金に詰まって友達の生胆を売って大間違いを仕出かしたのを幕切にして、立派にやめてしまいましたが、考えてみると私輩の一生は南京花火のようなもので……シュシュシュシュポンポンポン……ウワアーイというただけの話で……。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しからぬ事だ、不都合千萬な伜だ、貴樣の仕つけがよろしくないからかういふ事を仕出かしたのだと散々に叱られてさうして自分自身の噪ぐ心を落付けさせたいのでありました。",
              "citation": {
                "source": "白瓜と青瓜",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍女と見違へて生人形を引き寄せて、つまらぬ失策を仕出かしたといふやうなこともある。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様が学校を出て何んな処に勤めるか知らんが、その頃は私は生きてもゐまいが、金銭に目が暮れて心を売つたり分不相応なことを仕出かしたりすれば、私は墓の下から声を掛けて叱るぞ。",
              "citation": {
                "source": "祖母の教訓",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となく困つた事を仕出かした樣にも思うたが、強ひて止めるわけにもゆかず、それでいつから移るのだと訊くと、旦那がこゝを立たれる日に直ぐ移るといふ。",
              "citation": {
                "source": "山寺",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "家康は牀几に倚って諸大名の祝儀を受けていたが、忠直卿が着到すると、わざわざ牀几を離れ、手を取って引き寄せながら、「天晴仕出かした。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「出かしたぞ、出かしたぞ、いや、きつい当てられたようじゃ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "臼杵先生は大変にソワソワして昂奮しておられるようだったが、何かまたあの女が余計な事を仕出かしたのかも知れないから、早く電話をかけといた方がいいだろう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは自分が特に注意している処であるが、何者が侵入して来てあのような事を仕出かしたものであろう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして他のもの等が、その癖、結局は何もせず、ワイ／＼してゐるとき、ノソ／＼と出掛けて行つて、獨りで、とてつもない大きなことを仕出かした。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは上からの命令ではなかったが、こういう事件を仕出かした以上、三島に向ってその破却を勧告するのが親類の義務であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "向島の寮",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮りに若し、あなたが私と同じ網膜炎であらせられて、私がそれを気附かず、結婚の当夜に、その真相を御告げになったとしたならば、恐らく私は気狂いにでもなるか、さもなくば悲しみと怒りのあまり、あなたを……いえ、どんなことを仕出かしたかもわかりません。",
              "citation": {
                "source": "秘密の相似",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして僕は父や母がただあやまるだけでは済まないようなことまでも幾度も仕出かした。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も左の耳を噛まれて、握拳大の瘤を出かした。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "また必要もありませんわ、自分で困るのですもの、そんな馬鹿なことをする人があるでせうか、それは自分自身で仕出かしたことではありませんか、ところが腕を一本他人のを切つて御覧なさい、それこそ大変ですわ、直ぐ刑事問題になるでせう。",
              "citation": {
                "source": "私信",
                "author": "――野上彌生様へ",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は私かに、「こいつに氣違ひ責めにせられ、あいつには刃物責めにせられ、もとはと云へば、たとひおれの仕出かしたことにしろ、たまるものかい」と考へた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "私あなたのことを思うと、変に悲しくなって、泣いちまうんですもの……戸部　　君……冗談をいうない、冗談を……花田　　ともちゃん、でかしたぞ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると彼は、小僧でかした、その意気じゃ、と言って入門をゆるすという事になる。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でかした、ワトソン！",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
