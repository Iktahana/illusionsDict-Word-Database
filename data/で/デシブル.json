        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "貴女が、行きたがらないものだから、青木さんまでが、出渋るのですわ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝やっぱり出渋るのだ。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊の声のする暗い隅の方へとかく逡巡ばかりして、いつもの元気もなく出渋るやつを、無理無体に外へ引出しました。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、パッパッと音を立てて、火口から出渋る小さな焔の明滅を、やっと三つ数えたきりで、彼は眠入ってしまう。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢張り酔っていて出渋るのをお願い申して現場へ来て見ると、片岡君は溝の中で鼾をかいていた。",
              "citation": {
                "source": "一年の計",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはまるで人形のような女だからな」「行けばきっとアテられてよ」「仕方がない、それも親孝行だと思って、一時間か二時間アテられに行くさ」ふと要は、妻が何となく出渋るのは外に理由があるんじゃないのかな、とその時感じたが、「では今日は和服になさる？",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙ、仕事があるのでしぶる。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
