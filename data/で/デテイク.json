    "definitions": [
      {
        "index": 1,
        "gloss": "to go out and away",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女　淋しからう淋しからうつて言つといてはあなた出て行くのね、そして長い間、帰つてはいらつしやらない。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（女入口より出て行く。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "全て人間的シウ態といふものは、マイがマイセルフに楯つく所、甘んじる所から出て行く。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れて家を出て行くのがこれで二度目だつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と眞面目な顏で言つて、部屋を出て行く。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてイからウに至る間に唇は順に前方に突き出て行くものとする。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紋付を着てキチンとやって出て行くのがあたりまへだ。",
              "citation": {
                "source": "ラジュウムの雁",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "船は大きなカーヴを描いて出て行くので色さまざまの灯をちりばめた山腹の街の眺めがだんだんに変りながら遠くなって行く。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの西行のやうな牧水氏が、遠いところから訪ねて來て追ひ歸され、孤影悄然として門を出て行く姿を考へ、名状できない寂しさと、氣のすまない思ひで一杯になつた。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいか、かかり合になると五月蝿えからな」　石松、立上って七五郎に、　「出掛けようか」　お静、　「兄さん、また出て行くの？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "七五郎、落着かず部屋を出て行く。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄五郎は三次に、Ｔ「近頃決って朝早く出て行くが」　と言って、ウサン臭そうに、Ｔ「毎朝毎朝一体何処へ行くんだい？",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉も笑い乍ら出て行く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝但馬屋の店先――翌る朝　役人が主人源兵衛を引ッ立てて出て行く。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしまは、代って風呂へ出て行く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この完成が終れば氏はその方へ出て行くのであらう。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「己はもう出て行くからこんな所に用は無い」と、壁に向つて息張つてゐると云ふ風である。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともよは、表通りの目的の店近く来ると、その店から湊が硝子鉢を下げて出て行く姿を見た。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして、彼は、診断室を出て行くように、合図に手を動かした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　軍医は出て行くように手を動かした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、私が着物を纒めて中隊の前へ出て行くと、そこに、手提げ籠をさげた親爺が立っていた。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "報告がすむと、また前に出て行くことを命じられた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに老人や子供等にも一人一人｜丁寧に礼を云ってから、とぼとぼと片足を引きずりながら出て行くのであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "谿谷の極まるところには峠があって、その向う側にはまた他の谿谷が始まる、それを次第にたどって行くといつの間にか思わぬ国の思わぬ里に出て行く。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だから、あたしがお止しと云うのに、お前さん達が肯かないで出て行くからさ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしも急に老人に逢いたくなって、そのお祭りの日に赤坂に出て行くと、途中から霧のような雨が降って来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所の人達も母子が二人づれで出て行くところを見とどけたと証明した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　少佐殿はめかして出て行く。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前ら、出て行くさきに、ここへ支那人がやって来たのを見やしなかったか？",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼等は、記者が一枚の写真をとって部屋を出て行くと、口々にほざいた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
