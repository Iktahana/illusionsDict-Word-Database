[
  {
    "uuid": "4644d63c-f436-5341-8e6b-97cb6cf39c1b",
    "entry": "出来合い",
    "reading": {
      "primary": "できあい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
