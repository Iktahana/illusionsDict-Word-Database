    "definitions": [
      {
        "index": 1,
        "gloss": "roulette-like street gambling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "吉井の伝助は、無筆だったので、彼は仲よしの才助に、小声で耳打ちしながら、代筆を頼んだ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにしろ御承知のように零落して居りまして、雇人と申しては年とった小間使お種と、雑用の爺や伝助とだけです。",
              "citation": {
                "source": "すり替え怪画",
                "author": "烏啼天駆シリーズ・５",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝助も東京へ使にやって誰もおらん。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と老人は立ったまま腕を拱いて嘆声を発したが、裏木戸の方に音のするのを聞きつけ、「伝助が帰って来たらしい。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「義士伝」の倉橋伝助が、まだ長谷川金次郎といって飲む打つ買うの三道楽であった時分、江戸を食いつめて、落ちゆく先も御多分に洩れず、木更津だったと覚えている。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "上杉征伐に功のあった三河の鈴木伝助の裔で、榊原に仕えて代々｜物頭列を勤めてきたが、伝内は神田お玉ヶ池の秋月｜刑部正直の高弟で義世流の達人であり、無辺無極流の槍もよく使うので、先代政祐のとき、番頭兼用人に進んで役料とも七百石を給わるようになった。",
              "citation": {
                "source": "鈴木主水",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "めぼしいものは町役人に預け、小僧の要吉は傷が癒ったばかりで、下女のお留の外に、伝助という中年男と一緒に、淋しく留守をしております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前は伝助といいなさるんだね」「ヘエ――」「どんな係り合いなんだい」「旦那がいらっしゃる頃から、チョイチョイお手伝いに参りました」「商売の方をか？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「算盤とは縁のない人間で、ほんの使い走りか、留守番でございますよ、ヘエ」　卑屈そうに四十男の伝助は、続けざまに四つ五つお辞儀をするのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "町内の衆が十三人で、ヘエ、お蔭様で丸屋の旦那が行方知れずになっても、私にはなんの係り合いもございません」　伝助は弁解らしくそんなことまで言うのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヘエ、――そんなわけじゃございませんが、少しばかり丸屋さんには借りがございます」「いくらだ」「三十両ほどで、ヘエ」「たいそう借りたんだね」「二十両は利息でございますよ」　一瞬、伝助の顔は険しくなりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "首筋を掴んで物蔭からズルズルと引出したのは、留守番に来ていた伝助。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その三十八両の金は十年も稼いで溜めた金で、少しも怪しいものじゃございません」　伝助は両掌を合せながら、ズルズルと土間を引摺られるのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分さん、丸屋の旦那は、三年の間私から高い利息を絞ったことを考えると、それぐらいのことは当り前でございます」　伝助はわけの解らぬ泣き言を並べながら、土間に額を埋めて、言い廻るのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝助が八月十七日に、成田へお詣りに行ったことは確かなんだから、うっかり油断をして――」　清吉は口惜しそうでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はもう少し捜ってみるから――」　平次は伝助を清吉に縛らせて、惜しげもなくその手で送らせました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸屋は留守番の伝助が縛られて、下女のお留と小僧の要吉とたった二人になりましたが、事件の片付くまでは、この大事な証人を外へやるわけに行かず、五人組が交代で来て泊ることになったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "四日後に伝助が盗んだから」「どこへ行ったでしょう、親分」「何か掘りに行ったんだ、――お寺はどこだい、菱屋のだよ」「橋場の総泉寺ですよ」「行ってみよう」　平次と八五郎は、真っ直ぐに総泉寺へ行きましたが、なんの変ったこともありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "きゅッ、と博多帯を鳴らしながら、「ゆうべ、使いに行ってくれたなあ、誰だっけ」「伝助じゃねえか」「ちょっと、呼んでくんねえ」　土蔵二階、なぐさみをしていた若い者の中から、一人が降りて来て、「あ、親分で」「伝公、てめえ、ゆうべは門違いをしちまったぜ」「えッ、そうでしたか」「西の土橋から、七軒目だ。",
              "citation": {
                "source": "雲霧閻魔帳",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉橋伝助、奥田孫太夫、磯貝十郎左、赤埴源蔵、高田郡兵衛、田中貞四郎と――順々にあらわれて来る顔は、浪々の後も、決して剛毅を衰えさせてはいない。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その飯が二階へ運ばれてゆく時、倉橋伝助が、眼いろを緊張させて、ここへ訪ねて来た。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、倉橋伝助が、『――扇を落した』　と、そこらに、散らかっている人々の背を通った。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸には堀部｜父子、奥田孫太夫、田中貞四郎、倉橋伝助、これ等はたしかに同心の者』『まず、十二、三名はあるかな』『ござりますとも。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸表には、奥田孫太夫｜父子をはじめ、杉野十平次、倉橋伝助、前原伊助、その他を合せれば、十五、六は馳せ加わろう。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相生町二丁目の前原伊助の米屋五兵衛を初め、与五郎の小間物屋善兵衛、その手代や奉公人となっている岡野金右衛門、倉橋伝助。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの手代となっている、倉橋伝助。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『覗いて来ましょうか』　手代すがたの倉橋伝助が立ちかけると、『まあ、もう少し、待ってみては何うか。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――が、それの動く間を待たず、杉野十平次、倉橋伝助、赤埴源蔵、磯貝十郎左衛門、堀部安兵衛。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『――居ないか』『――居ないか』『隠居は居ないか』　間十次郎、大高源吾、倉橋伝助などが、そのそばを通りながら、口々に云ってゆく。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白昼、そのへんの大道で、でんすけ賭博とやらが堂々と横行している今日この頃もまたバカントラ第二世は颯爽と都下の高座へ君臨して、よろしくいんちき賽の秘密など曝露してくれてもいいのではなからうか。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
