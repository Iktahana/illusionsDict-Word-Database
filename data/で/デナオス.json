    "definitions": [
      {
        "index": 1,
        "gloss": "to make a fresh start",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もう二度と出直す勇氣がなくなつてそれつきりそのまゝになつてしまつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と祖母が軒先から引返して、番傘を持って出直す時、「あのう、台所の燈を消しといてくらっしゃいよ、の。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度社宅から出直す。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂清水とか言うので顔を洗って私も出直す――それ、それ、見たが可い。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はちょっと其処へ掛けて、会釈で済ますつもりだったが、古畳で暑くるしい、せめてのおもてなしと、竹のずんど切の花活を持って、庭へ出直すと台所の前あたり、井戸があって、撥釣瓶の、釣瓶が、虚空へ飛んで猿のように撥ねていた。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度と生涯を出直すにしても、一たんは根に帰るものだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生涯を出直すにしても一たんは根に帰るものだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし真の辞世の句は「梅が香やちよつと出直す垣隣」だそうである。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい男は、出直すのも早いんだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして辞儀の一つもする事を覚えてから出直すなら出直して来い。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「余り退屈したから一寸出かけたんだが――財布を忘れたんで取りに来たんだが、また出直すんだ。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かに精しく訊いてから出直すつもりでいると、その中に一と月ほど経って、「小生事本日死去仕候」となった。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "内藤新宿へもどって、いろはからまた出直すんだから、急いで駕籠を仕立てな」　飛ばして行きついたところは、そもそもの振り出しのあのお下屋敷です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度こそは一ト月だとか、夏一杯だとかと力んで出発するのであつたが、半月とつづいた験もなく、何かと面白さうな土産ばなしばかりを携へては戻り、そして出直すばかりなので、さすがに母も不安の気色を浮べ、近頃では何うやら私の旅行談にも愛想を尽かしてゐる傾きであつた。",
              "citation": {
                "source": "風流旅行",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、改めてそこから出直すのでなくては、いつまでたつても我々はほんとうの政治を持つことはできないであろう。",
              "citation": {
                "source": "政治に関する随想",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "代助は一旦引き上げて又｜改ためて、父と話を付けに出直す方が便宜だと考へた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし怠け癖のついた木山は、こつ／＼初めから出直すといふ心構へには容易になれなかつた。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は作家としては出直すより外なかつた。",
              "citation": {
                "source": "閾",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに唯今は、もう十一時をかなり廻ったから、帰ってまた銀座裏まで出直すのは億劫だし、そうかといって手ぶらでは行っても仕方がないしと、後悔しているところへ、丁度流して来てピタリと目の前に停った円のタクというのが、まるで辻占いのようにわが家の方角へ向いていた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「北海道や樺太へは、然し、出直すより仕かたがない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "殘念だから、また出直すかも知れない、さ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "自宅の門を出る時にも、何か出かたの気に入らざる時にはもう一度家へ引返し、更に出直すと言ふ位なれば、神経質なること想ふべし。",
              "citation": {
                "source": "学校友だち",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "為やうとすれば何だつて新しく始めから出直すんだからなあ、何がいゝんだか解らないんだよ。",
              "citation": {
                "source": "惑ひ",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は朝はやくおきて一たん家へかへつてそれから学校にゆかうと思つたのですが私の寝坊は学校の前を通りこして家へかへつてまた出直す程の時間の余裕をもてる程はやくは起きませんでしたので仕方なしにそのまゝ学校にゆきました。",
              "citation": {
                "source": "嘘言と云ふことに就いての追想",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "又出直す事にしませう。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに心づいて、出直す時が今なのではないか。",
              "citation": {
                "source": "民俗芸能の春",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "可愛ゆいと云っても、徒に贅沢な着物を着せるではなく、ちやほやするではなく、たとい転んで泣いても自分で起きさせ、自分で壊した玩具なら、自分でなおすなり、工夫してそれを巧く使えるようにするなり、何でも自発力で生活させようとする意識は、如何程、彼等親達の心に深い根を下しているか分りません。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分夕方Ａとかえり、夜原稿が不満なのでなおす。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの方向舵の故障は艇内でなおすわけにはいかない。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、ハヤノ商会の人がやってきて、この場でなおすことはできないからというので、われた石膏像をトラックにつんで、工場へもちかえりましたが、それが四日めに、もとのとおりにつぎあわされて、もどってきました。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
