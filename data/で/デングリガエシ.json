        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ああ、一高へはいって、たぬきの腹をでんぐり返してやりたいのだが、だめかも知れない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "惚れた女の腹の中で、じたばたでんぐり返しを打って騒ぐ、噛み合う、掴み合う、引掻き合う。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞬間に葉子の心はでんぐり返しを打った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌脱ぎになる習慣も止めて貰ひたい、運動だと称して（昼間）逆立ちをやつたり、でんぐり返しをしたり、出たら目の体操をやつたりするのも止めて貰ひたい、運動をしたければ、これも法にかなつたこと、例へば鉄亜鈴、棍棒、まだその他室内で出来るいろいろの道具がある。",
              "citation": {
                "source": "蝉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし斯の危い戲れよりも安全で、もつと少年の私の心を喜ばせたのは、低い梯子から高い梯子へ昇らうとする中途の袋戸棚の上から、逆にでんぐり返しを打つことでした。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして大切なことは、この「例」がどんなに例そのものが勝手に独り歩きして、頭の中で発展していっても、その本論の筋をでんぐり返して、とんでもない反対のところにまで連想しないように、考えに考えぬいて仕組まれなければならないことである。",
              "citation": {
                "source": "聴衆０の講演会",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ鶯の谷渡りでも、達磨のでんぐり返しでも何でも出来るね。",
              "citation": {
                "source": "渡鳥いつかへる",
                "author": "軽演劇一幕四場",
                "note": "青空文庫"
              }
            },
            {
              "text": "でんぐり返しを打って雨の中に投げ出された。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うはするりと横へ抜けると、一目散に逃げだしたが、廊下の中途で誰かにぶつかって、でんぐり返しを打ったらしい。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄棒にぶらさがっていたものは、でんぐり返しを中途で止め、それから、口を開けたまま、額に汗をかき、シャツの袖をまくり上げ、粘土のついた指を拡げたまま、地べたへ飛びおりる。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "改めてもう一度お詫びを申しますが、それにしても、でんぐり返しただけで枯れるなんざ、万年青なんてえものもいい加減なもんですな、あんまり尻ッ腰がなさすぎます。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "稲荷の使",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いた事には、自分のスタデーは蒲団の洗濯物の為めにでんぐり返してある。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてカピはわたしのあほうにあきれ返って、四つ足ででんぐり返しを打った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "カピがまたでんぐり返しを打った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくはヴァイオリンをひくこともできるし、でんぐり返しをうつこともできる」と、マチアがせかせか息もつかずに言った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日になったらてめえらの肝っ魂をでんぐり返してやる。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "強かな四十男で押にも力にも不足のないのが、こうと見込んで下手人を挙げそびれていたばかりに、銭形の平次がとんでもないでんぐり返しの種を持込んで来たのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "巨盗還る",
                "note": "青空文庫"
              }
            },
            {
              "text": "強かな四十男で押にも力にも不足のないのが、斯うと見込んで下手人を擧げそびれてゐたばかりに、錢形の平次が飛んでもないでんぐり返しの種を持込んで來たのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "巨盜還る",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん空中ででんぐり返しを打つ曲芸でも、科学的の法則に従って行っているのは事実である。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "角兵衛獅子って、私のくにでは、冬になると、よく村から村へわたってきて、おししの面をかぶったかわいそうな子どもが、さか立ちしたり、でんぐりがえしをしたりして見せるのだ。",
              "citation": {
                "source": "さか立ち小僧さん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
