        "examples": {
          "standard": [
            {
              "text": "長年の理想が、現実の厳しさに触れてディスイリュージョンした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、その経験を通して、甘い幻想からのディスイリュージョンを経験した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "多くの若者が、社会の矛盾に直面してディスイリュージョンを感じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "いちばん小さい私の子供に引っかかえられて逃げようとしてもがきながら鳴いているところを見たりすると、なおさらそういうディスイリュージョンを感じるのであった。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の感激主義に対して今の教育はそれを失わする教育である、西洋では迷より覚めるという、日本では意味が違うが、まあディスイリュージョン、さめる、というのであります。",
              "citation": {
                "source": "教育と文芸",
                "author": "――明治四十四年六月十八日長野県会議事院において――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
