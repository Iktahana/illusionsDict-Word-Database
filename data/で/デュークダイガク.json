          "literary": [
            {
              "text": "デューク大学の「超心理学」実験室長ライン博士の著書の紹介である。",
              "citation": {
                "source": "心霊現象と科学",
                "author": "――『心の領域』について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題はデューク大学およびコロラド大学その他で行なった一連の透視実験の結果である。",
              "citation": {
                "source": "心霊現象と科学",
                "author": "――『心の領域』について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "デューク大学の実験では、一番成績のよかった人は、七百回の実験で平均八枚適中という成績をあげた。",
              "citation": {
                "source": "心霊現象と科学",
                "author": "――『心の領域』について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三三年に、デューク大学で初めてこの実験が行われた。",
              "citation": {
                "source": "心霊現象と科学",
                "author": "――『心の領域』について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「デューク大学で行なった実験の一つでは、実験台になる人と骸子を二十五フィート離してみた。",
              "citation": {
                "source": "心霊現象と科学",
                "author": "――『心の領域』について――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
