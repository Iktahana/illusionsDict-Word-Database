    "definitions": [
      {
        "index": 1,
        "gloss": "introduction (from abroad)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
