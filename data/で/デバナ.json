[
  {
    "uuid": "f90f9b30-e81e-5de6-9614-a32da9a0634a",
    "entry": "出花",
    "reading": {
      "primary": "でばな",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
