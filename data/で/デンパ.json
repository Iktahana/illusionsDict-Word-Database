            },
            {
              "text": "ほのぼのと呼びける風、電波だけそれに触れてる。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大昔の電波がラジオに飛び込んできた感じを頭に置いて、貧弱な音で入れた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "村を吐き出されたひとびとは、絵のごとく、でんぱたにうごく高い空――十時。",
              "citation": {
                "source": "村へ行く",
                "author": "鶴彬",
                "note": "青空文庫"
              }
            }
          ]
        }
