[
  {
    "uuid": "a3efb8d8-cc76-5180-bbba-f3d9d937203d",
    "entry": "伝播",
    "reading": {
      "primary": "でんぱ",
      "alternatives": [
        "でんぱん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
