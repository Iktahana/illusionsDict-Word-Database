    "definitions": [
      {
        "index": 1,
        "gloss": "street with streetcar tracks",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
