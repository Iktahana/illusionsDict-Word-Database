        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "頭かきかき　市長のいうにゃ、『でんでんででむしではあるまいし、智慧だせだせと　せめつけられても、無い智慧出されぬ　面目ござらぬ、にげこむねずみの　穴ほしや。",
              "citation": {
                "source": "魔法の笛",
                "author": "ロバアト・ブラウニング",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四人の仕立屋二十四人の仕立屋がででむしころしに、えっさっさ。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃこそででむしが角だした、ちっちぇえカイロうしそっくりだ。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "ででむし角だせででむし、ででむし、角だせや、お父さんもお母さんもしんでしもうた。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわずとででむしとこいぬのしっぽでつくられた。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "ででむし、でむしででむし、でむし。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "ででむしででむし、ででむし、角だせや。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾つかの「ででむし」の謡のごとき、またほとんど同じではないか。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、「二十四人の仕立屋がででむしころしにいきました」を「二十四人の仕立屋がででむしころしにえっさっさ」とやったのもある。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "門額の大字に点す蝸牛かな主客閑話ででむし竹を上るなり明治三十九年五月三十日　大谷句仏北海道｜巡錫の途次来訪を機とし、碧梧桐庵小集。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
