[
  {
    "uuid": "5f372049-9008-5c1f-9b0f-dbbc2ed4d49d",
    "entry": "殿舎",
    "reading": {
      "primary": "でんしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "palace",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "地方官の中のよい趣味を持つ一人一人に殿舎をわり当てにして作らせていた。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "例年の新嘗・神今食並びに大嘗祭には、式に先つて、忌部が、天子平常の生活に必出入せられる殿舎を廻つて、四隅にみほぎの玉を懸けて、祝詞を唱へて歩いた。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此神の一行と見るべきものが、宮廷の主人なる天子常用の殿舎だけを呪うて廻る。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "清暑堂焼亡の後も、他の殿舎の辺りで、「清暑堂御神楽」と言ふ名で行はれてよい訣なのである。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿舎を祓へ、祝福する場合に、最重要な位置を占めるものと思はれる。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿舎を鎮めるのです。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮廷生活に於てさへ、神来臨して門におとづれ、主上の日常起居の殿舎を祓へてまはつた風は、後世まで残つてゐた。",
              "citation": {
                "source": "古代生活の研究",
                "author": "常世の国",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう正月に餘日もないので、大切な客人を迎えるために急いで工匠や園丁を雇い、殿舎の修繕や林泉の手入れにかゝつたのである。",
              "citation": {
                "source": "少将滋幹の母",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平治の頃、義朝父子が匿れたという頃には、この山中にも、四十九院の殿舎があったと古記はつたえているが、いまは野瀬とよぶ渓流に臨むそこの小部落をあわせてもそんな戸数はなかった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "董卓は、地を卜して、王城をもしのぐ大築城を営み、百門の内には金玉の殿舎楼台を建てつらね、ここに二十年の兵糧を貯え、十五から二十歳ぐらいまでの美女八百余人を選んで後宮に入れ、天下の重宝を山のごとく集めた。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "守将の李豊以下ほとんど斬り殺されるか生擒られてしまい、自称皇帝の建てた偽宮――禁門朱楼、殿舎碧閣、ことごとく火をかけられて、寿春城中、いちめんの大紅蓮と化し終った。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "六波羅｜殿舎の大屋根は墨を刷いて、内苑の篝はチロチロ衰えかけ、有明けの黒白もなお、さだかでなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして寄手は、浜辺と山の手から、北条勢のことごとくを、市街のなかへ追い込んで、鎌倉じゅうの殿舎、諸屋敷、寺院、町屋のすべてを薪木とし、四方から蒸し殺しに焼き亡ぼそうとするものらしい。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
