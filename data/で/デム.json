        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "よく見るとほとんど皆二匹ずつタンデム式につながったもので、孤独な飛行者はきわめてまれである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英米に最も盛んなゴッデム（神汝を罪す）又、デム何某（罰當りの何某）などは嚴戒の神名を呼ぶ上に、詛を兼ねた者故、極めて聞苦しい。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "北ウヱールスのデムビシャヤーのエリアン尊者の井近く尼樣の女住む。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソフト側では文書と図形のエディターに通信ソフトをあらかじめ持たせ、モデム、ハードディスクを標準で付けて文書作成と通信にガンガン使ってくれという仕立だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにこのマシンにはＦＡＸモデムというやつがついている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがＦＡＸモデムのとなりにはなんと通常のＦＡＸマシンが鎮座ましましていて、狭い机をさらに狭くしている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話に関してはこんな具合に屋上屋を重ねてその上にドームまで被せたような日々を送っているオレは、一年ほど前にオンスペック社というところがモデムとＦＡＸ、ボイスメールの機能をＰＣ用ボードにまとめたＦＡＸ―Ｏ―ＦＯＮＥという製品を出したと聞いて、指パッチンをかました。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "文面はたしか『一○ジ二一フンイイダマチツクエキマデムカイタノムキミ』となっているんです。",
              "citation": {
                "source": "山吹町の殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "長イアイダ、タベモノヲ見タコトモナカッタトコロヘ、ハジメテソウシキノオソナエモノヲミルト、モウ矢モタテモタマラズ、目ガクラクラットシテ、ソレニ小サイ弟ヤ妹ナノデ、死ンダオ母ッチャニワルイトオモイナガラ、スキヲネラッテ、ミンナデムチュウニナッテタベテシマッタンダッテ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "パトリツクと云へば、｜翼のある白馬に打ちまたがつて、地獄の魔王から「如意の剣」を奪ひとるクリステンデムの「赤靴下」だ。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はデムート館というホテルに泊っていたのである。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやくわたしが、デムート館へ出かけて、ドーリスカヤ夫人に面会を申し入れると、――彼女は四日前に死んだ、と聞かされた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛称をレンシェンとよばれたヘレーネ・デムートはイエニーの少女時代からの召使いであった。",
              "citation": {
                "source": "カール・マルクスとその夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二日　博物館、展覧会、活動、　　　十四　　グランパに招かれて若松から、リデムプションを見る。",
              "citation": {
                "source": "「黄銅時代」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父上の帽子、　十一、佃にリデムプションを見せられ、日本飯によばる。",
              "citation": {
                "source": "「伸子」創作メモ（一）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふも、いやな手紙を一通かいてだした、ゴツデム！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルファベット四〇字を八行表示できる大型の液晶ディスプレイを備えた八ビット機で、これにワードプロセッサーと通信のためのソフトウエア、モデムを組み込んでおき、外出先で書き終えた原稿をそのまま電話で送れるようにするという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはカルタフィルスと云い、あるいはアハスフェルスと云い、あるいはブタデウスと云い、あるいはまたイサク・ラクエデムと云っている。",
              "citation": {
                "source": "さまよえる猶太人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "外から明りをとっているタンデム・キャビンの式で、壁に寄せてコット・バァスが四つ置いてあった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧田に連れられて上のタンデム・キャビンへ行くと、中、少尉の七人組と浜田大尉がさかんにビールを飲んでいた。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の名はニコデムスだね。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は曰く、彼がこの国に滞在中の内乱で、『叛徒はまずデムビアを荒廃に帰しはじめており、そして南方から西方に至る平原にある一切の村を焼き払い、それをマイクルとファシル間の沙漠のようしてしまった。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "………王はしばしばその宮殿の塔の頂上に登り、デムビアにおけるその豊かな村々が焼けているのを見て、不満の極であつた。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "美容室へ行って、飯を食って、ダンスをするというのはどうだい」二　岸壁の端から車止の柵のそばまでセダンやジープがずらりと並び、舷窓からもタンデム・キャビンの窓からも明あかとあかりが洩れて、劇場の大玄関のようなにぎやかな感じだった。",
              "citation": {
                "source": "復活祭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃツルさん」　と鶴代のほうへちょっとうなずいてみせ、舞踏室を通ってタンデム・キャビンにつづく桟敷の階段をゆっくりあがって行った。",
              "citation": {
                "source": "復活祭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "一七九三年シュルツェ（G. E. Schultze）の著『エネシデムス』に対する評論を発表し、カントとラインホルトとを弁護した。",
              "citation": {
                "source": "辞典",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……ガッデム」呼吸をきらしながら、ひどい鷲鼻の少尉はズボンの上をつかんでいた。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の人力車には、肩に繩をつけた男が一人余計に加った――何のことはない、タンデム・ティーム〔竪に二頭馬を並べた馬車〕である――そして我々はいい勢で走り出した。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ同宿のニコデムスと云ふ院僧が歩み寄つた。",
              "citation": {
                "source": "パアテル・セルギウス",
                "author": "VATER SERGIUS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
