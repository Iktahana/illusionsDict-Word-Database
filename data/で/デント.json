      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "imposingly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "明治の日本人がステンショとかオーフルコートとか称したことを考え、昭和の吾々がビルジングとかブデンとか云っていることを考えればこれくらいはゆるしてもらってもいいであろう。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「上の野原の入り口にモリブデンという鉱石ができるので、それをだんだん掘るようにするためだそうです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほ心安からず、みづから我が心なかりしを悔いたりしに、次の朝に至りて更に十三の花咲けり、嬉しさいふべからず、やよや人々又シヽデンといふことなかれ、我が家のものいふ花ぞと、いとせめて愛であへりし、其の日、日曜にて宙外君立寄らる。",
              "citation": {
                "source": "草あやめ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "デンデンと三味線が太く哀調を予想させ、太夫が腹にいれた木の枕をしっかと押えて、かつて小出楢重氏が大阪人は浄瑠璃をうなる時がいちばん利口に見えるといわれたあの声をうなり出し、文五郎が想いをこめた抱き方で人形を携えて舞台にあらわれると、ああここに大阪があると私は思うのである。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、美沢さんって方、気が小さくて神経質でしょう、お姉様はデンと落着いている方でしょう。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「風俗壊乱」の文士らしく若気の至りの放蕩無頼を気取って、再びデンと腰を下し、頬杖ついて聴けば、十銭芸者の話はいかにも夏の夜更けの酒場で頽廃の唇から聴く話であった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウェーデンと日本と遠方ながら似たところが面白くて書き付けた。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "同書一九四―六頁にクヲテンの妻、パールデンと通じ夫を愛せぬ故、クヲテン怒て奸夫を殺さん迚逐ひ廻るを見て、クヲテンの母パールデン、荊棘に鈎られて留まれと詛ふと、果して棘に留められた所をクヲテンが殺した。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "パールデンと同村の住民クヲテンを懼れ皆立退き老夫婦一對のみ殘る。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "郡はロフオツデンと申しまして陰気な土地でございます。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ロフオツデンとモスコエとの中間は、水の深さ三十五ノツトより四十ノツトに至る。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "満潮のときはロフオツデンとモスコエとの間の潮流非常なる速度を有す。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ロフォーデンとモスケーとのあいだにおいては、水深三十五｜尋ないし四十尋なり。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "満潮時には潮流は猛烈なる速度をもってロフォーデンとモスケーとのあいだを陸に向って奔流す。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルリンのウンテル・デン・リンデンと云う大通りの人道が、少し凸凹のある鏡のようになっていて、滑って歩くことが出来ないので、人足が沙を入れた籠を腋に抱えて、蒔いて歩いています。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウェーデンとの平和も次いで成立した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時分に、エリカ・マンはイギリスの詩人ウイスタン・オーデンと結婚した。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この関係で知られてゐるのはルーデンとのゲーテの対話である。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピナン、コロンボ、アデンと進むその船の中では、千鶴子と久慈がいつも手を取り合わんばかりにして、甲板の影から影を愉しげに廻っていたものだったが、過ぎ去った日の悩ましさも消したくなって、矢代は、蒲団の中で寝返りうった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃、黙っては居ても、宮原氏が、我々に、一緒のバーデンとなって居ると思う。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのロシアの外交郵便夫ルオフ・メリコフ事件をはじめ、この邸で奇怪な出来事が連発してきたので、すくなくとも仏露両国のスパイは、とうからこのベルリン・ドロテイン街の大邸宅とその美しい女主人、伯爵のいない伯爵夫人フォン・リンデンとに眼をつけていたのだ。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月二十九日火曜日の夜、九時三十七分に、ルウス・ジュッドは看守マクファデンと女看守ロン・ジョルダン夫人と一緒に、郡刑務所から自動車で、アリゾナ州フォニックスへ向う。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "道具のない田舎や山の中で手軽に出来るのは手軽なカスタープデンといって牛乳と玉子の蒸物が一番軽便ですね。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはトーストプデンといって極く手軽なプデンに致します。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "テンパン即ちテンピへ入れるブリキ皿へ少し湯を注いでその中へこのベシンか丼鉢を入れてテンピの中で一時間蒸焼にしますとジャムカップカスタープデンというものが出来ます。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "前景に立つ若い一対の男女は、伝説のジョン、アルデンとメーリー、チルトンででもあろうか。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唖で口が利けぬが、挨拶をする場合には、デデンと云う声を出す。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がデデンと呼んで来れば、デデンと応ずるまでゝある。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
