          "literary": [
            {
              "text": "七月加南夏漸生、雷声送雨晩天晴、麦田薯圃茫如海、身在緑烟堆裏行。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "那山残雪白如沙、又認渓頭夏色遮、万緑叢中紅点点、麦田薯圃繞漁家。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "）雷雨洗天開暁晴、鉄車窓外夏光清、麦田薯圃茫如海、身在緑烟堆裏行。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんた隠したでんしょう？",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
