        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "出鱈目を相手に、精神的な何が得られよう？",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は馬場みたいに出鱈目を言うことはきらいですねえ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬場の出鱈目は有名ですよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出鱈目な調子をつけて繰り返し繰り返し歌っていたのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の出鱈目を何でも信じてくれる者の胸中には、しばしば何かのおそるべき惡計が藏せられてゐるものだと云ふ事を、迂愚の狸は知らなかつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この舌切雀にせよ、また前の瘤取り、浦島さん、カチカチ山、いづれも「日本一」の登場は無いので、私の責任も輕く、自由に書く事を得たのであるが、どうも、日本一と言ふ事になると、かりそめにもこの貴い國で第一と言ふ事になると、いくらお伽噺だからと言つても、出鱈目な書き方は許されまい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな出鱈目を、この私が信じると思つておいでなのですか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その不思議な宿の大きい葛籠でも脊負つて來て下さつたら、それを證據に、私だつて本當にしないものでもないが、そんな稻の穗などを持つて來て、そのお人形さんの簪だなんて、よくもまあそのやうな、ばからしい出鱈目が言へたもんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出鱈目にロープなんぞ抛り出しやがって」　彼は叱言を独りで云いながら、ロープの上へ乗っかった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻と云わず口と云わず、出鱈目に雪が吹きつけた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の手のホテルの寝床の上で米良は彼女に片足かけていまでは彼は資本主義の出鱈目な機構を利用し成金になっていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｍ街に……」と、私は出鱈目に答へた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間の群の中から出鱈目に掴まえられた男よ、記憶するがいい。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日さまが又かっと明るくなり、二人はむしろに座ってひばりもゐないのに、「ひばり焼げこ、ひばりこんぶりこ、」なんて出鱈目なひばりの歌を歌ってゐました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出鱈目をよく教える……」「なんだ、なんだ」「狐の剃刀とか雀の鉄砲とか、いい加減なことをよく言うぜ」「なんだ、その植物ならほんとうにあるんだよ」「顔が赤いよ」「不愉快だよ。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し此代稽古の男は兎角自分に出鱈目を教える男だったから、それに罵られたのが残念で残念で堪らなかった為め忘れずに居ります。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉親からの仕送りがまるで無い様子で、或る時は靴磨きをした事もあり、また或る時は宝くじ売りをした事もあって、この頃は、表看板は或る出版社の編輯の手伝いという事にして、またそれも全くの出鱈目では無いが、裏でちょいちょい闇商売などに参画しているらしいので、ふところは、割にあたたかの模様である。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階から降りて行って梯子段の上り口から小声で佐吉さんを呼び、「あんな出鱈目を言ってはいけないよ。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青んぼ」という名前も、三男がひとりで考案して得意らしく、表紙も、その三男が画いたのですけれども、シュウル式の出鱈目のもので、銀粉をやたらに使用した、わからない絵でありました。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも三箇月間ほど我慢して、そんな侘びしい、出鱈目の教育をつづけて受けて居りましたが、もう、なんとしても、沢田先生のお顔を見るのさえ、いやになって、とうとう父に洗いざらい申し上げ、沢田先生のおいでになるのをお断りして下さるようにお願い致しました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな出鱈目な調子では、とても紀元二千七百年まで残るような佳い記録を書き綴る事は出来ぬ。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロダンのバルザツク像に感激したからだと言ふのであつたが、それは彼が大家になつたとき、その經歴に輕いもつたいをつけるための餘念ない出鱈目であつて、まことは葉藏の洋畫に對する遠慮からであつた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぞれがおもひおもひに趣向こらした出鱈目を述べる。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日さまが又かっと明るくなり、二人はむしろに座ってひばりもいないのに、「ひばり焼げこ、ひばりこんぶりこ、」なんて出鱈目なひばりの歌を歌っていました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため、病気だなんていって私を呼びよせたの」　慶四郎はむきになった声音で、「僕は現実のことだと、ときどき出鱈目もいうよ。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハハァ、天狗様が祀ってあるのだな、これは御挨拶を申さずばなるまい」と、そこで髯将軍は恭しく脱帽三拝し、出鱈目の祭文を真面目｜臭って読み上げる。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "してみると、伝馬町で買つたなどと云つたのは、万一の用心のために出鱈目をならべたので、実は何処で買つて来たのか判らない。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、いや、だからして、以下の数々の話につけた「起ち上る大阪」という題も、思えばまるで見当ちがいの出鱈目なものではなかったかも知れない。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房の尻に敷かれる人はかえって出世するものだ、と母が言った言葉は出鱈目だろうか。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を書いてゐながら、私は、私の記述の下手さ加減、でたらめに、われながら、うんざりする。",
              "citation": {
                "source": "小照",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
