    "definitions": [
      {
        "index": 1,
        "gloss": "Diana (goddess)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
