        "examples": {
          "standard": [
            {
              "text": "スマートフォンの内部には、非常に複雑な電子回路が組み込まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は新しいアイデアを形にするため、簡単な電子回路を自作した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "電子回路の故障が原因で、その機械は動かなくなってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "何しろ当時の電子回路の常識からすれば、機能とは回路上に作り付けになっているはずのもので、ハードウエアにソフトウエアが加わって機能が実現されるといわれても、さっぱりピンとこない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電子回路によって人間の声に近い音を作り、機械にしゃべらせようという音声合成の研究を行っているこのベンチャービジネスのスタッフ二人も、スタンフォード大学を卒業したばかりだという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "高校二年生の夏、手作りのテレビカメラがすくい取ったいびつな世界がてのひらの調節の技によってその姿を正しはじめたとき、松本は再び、電子回路に魂を吸い取られるような一瞬を味わった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
