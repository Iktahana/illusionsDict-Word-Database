    "definitions": [
      {
        "index": 1,
        "gloss": "teaching Buddhism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
