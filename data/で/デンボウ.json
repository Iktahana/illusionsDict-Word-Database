        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "チツポケな虚栄心を持つてるに過ぎない奴等が、いつかどのきほひ肌や、伝法肌のつもりになつて得々としてるのだ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女等はきほひ肌でも伝法肌でもない！",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いなせ」「いさみ」「伝法」などに共通な犯すべからざる気品・気格がなければならない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来宣伝法の猛烈なものの中でも猛烈であったと思われるのはマホメットのコーランにおける、オラーフ王のキリスト教におけるごときがそれである。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてその、熱いところを我慢して飲み、かねて習い覚えて置いた伝法の語彙を、廻らぬ舌に鞭打って余すところなく展開し、何を言っていやがるんでえ、と言い終った時に、おでんやの姉さんが明るい笑顔で、兄さん東北でしょう、と無心に言った。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そう、」と極めてその意を得たという調子で、いそいそずッと出て、店前の地へ伝法に屈んだのは、滝太郎である。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる伝法肌で気品のある役には不適当であるといわれたが、それでもあらゆる役々を引受けて、団菊左と同じ舞台に立っていた。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "結城の藍微塵の一枚着、唐桟柄の袷羽織、茶｜献上博多の帯をぐいと緊め、白柔皮の緒の雪駄穿で、髪をすっきりと刈った、気の利いた若いもの、風俗は一目で知れる……俳優部屋の男衆で、初阪ものには不似合な伝法。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "智証大師伝法｜灌頂の道場。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の内気の人なら想像もつかないようなあくどい宣伝法を採用するなど、電機工あがりの彼を以てしてはじめて出来る芸当であった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "オランダ人で伝法肌といったような男がシェンケから大きな釣り針を借りて来てこれに肉片をさし、親指ほどの麻繩のさきに結びつけ、浮標にはライフブイを縛りつけて舷側から投げ込んだ。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山西は伝法院の塀に添うて並んだ夜店の前を通って、池の方へ往った。",
              "citation": {
                "source": "水魔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝法院の塀をはなれて池の縁へ出たところで、左の方から来る人群の中に、友禅模様の羽織を着た小女を見出した。",
              "citation": {
                "source": "水魔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その伝法院の前を来るまでは見たのですのに、あれから、弁天山へ入るまでの間で、消えたも同じに思われました。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのたんびに、勝気で伝法肌な、緑屋のおかみは、表へ飛び出して、真上の山を見上げて、「馬鹿野郎！",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝法で意地ツ張りで、棄鉢気分もあつたやうだ。",
              "citation": {
                "source": "女流作家",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "着飾った芸者たちがみがき上げた顔をびりびりするような夜寒に惜しげもなく伝法にさらして、さすがに寒気に足を早めながら、招ばれた所に繰り出して行くその様子が、まざまざと履き物の音を聞いたばかりで葉子の想像には描かれるのだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あつらえておいた衣類がまだできないのと、着具合がよくって、倉地からもしっくり似合うとほめられるので、その朝も芸者のちょいちょい着らしい、黒繻子の襟の着いた、伝法な棒縞の身幅の狭い着物に、黒繻子と水色｜匹田の昼夜帯をしめて、どてらを引っかけていたばかりでなく、髪までやはり櫛巻きにしていたのだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草の伝法院へ度々融通したのが縁となって、その頃の伝法院の住職唯我教信と懇ろにした。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿岳の住っていた伝法院の隣地は取上げられて代地を下附されたが、代地が気に入らなくて俺のいる所がなくなってしまったと苦情をいった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝法院の唯我教信が調戯半分に「淡島椿岳だから寧そ淡島堂に住ったらどうだ？",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿岳は何処にもいる処がないので、目鏡の工事の監督かたがた伝法院の許しを得て山門に住い、昔から山門に住ったものは石川五右衛門と俺の外にはあるまいと頗る得意になっていた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉山は遠くから瞻めてると女のように媚かしいただの色若衆であったが、会って見ると岩本院の稚児上りといいそうな江戸ッ子風の伝法肌であった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞いだしたとなると、鉄火というか、伝法というか、雪までがたいそうもなく江戸前に気短なところがあって、豪儀といえば豪儀ですが、ちらりほらりと夜の引きあけごろから降りだしたと思ったあいだに、たちまち八百八町は二寸厚みの牡丹雪にぬりこめられて、見渡すかぎりただひと色の銀世界でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、あたしの顔をよくごらんなさいましよ」　すると、くし巻きお由は、と見つ、こう見つ、右門のからだを上から下へ見ながめていましたが、さすがは彼女もそれと江戸に名を売ったかせぎ人だけのことはあってか、青ざめた顔に引きつったような笑いをむりに浮かべると、伝法な口調で悪びれずにいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、野郎ども、手を借しなッ」　言いざまに頭がまずまっさきにもろはだぬぎになりましたから、勇みと侠気と伝法はおよそ江戸鳶の誇りです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "と――、誰が言い出したものかその時群集の中から、残念そうに呟いた伝法な声がきこえました。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥坐舗の長手の火鉢の傍に年配四十｜恰好の年増、些し痩肉で色が浅黒いが、小股の切上ッた、垢抜けのした、何処ともでんぼう肌の、萎れてもまだ見所のある花。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知かも知れませんが、日錚和尚と云う人は、もと深川の左官だったのが、十九の年に足場から落ちて、一時｜正気を失った後、急に菩提心を起したとか云う、でんぼう肌の畸人だったのです。",
              "citation": {
                "source": "捨児",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
