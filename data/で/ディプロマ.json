        "examples": {
          "standard": [
            {
              "text": "大学を卒業すると、努力の証としてディプロマ（卒業証書）が授与される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は専門学校で特定の技術を習得し、その課程修了のディプロマを受け取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このディプロマは、国際的に通用する資格を証明するものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "残念なことに彼にはその時まだディプロマがなかった。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍に食い入っているはずの砂馬が、どういう口実でこの車を借りたのか、楕円形のナンバープレートのそのＤは外交官（ディプロマチック・サービス）の車だという印なのだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
