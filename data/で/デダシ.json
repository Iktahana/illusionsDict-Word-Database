        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "家苞に參らせん、と思ふほどに、はや出でさせ給ひにければ、と云ひさして、根もとをこなたに向けて、三把ばかり出だしけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "更けゆくまゝに燈火のかげなどうら淋しく、寝られぬ夜なれば臥床に入らんも詮なしとて、小切れ入れたる畳紙とり出だし、何とはなしに針をも取られぬ。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一刻後、東京劇場の中央の位置に人々は彼女を見出だした。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故か泣けてきて、涙が出だした。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に帰るや、炉に火を盛に燃きてそのわきに紀州を坐らせ、戸棚より膳取り出だして自身は食らわず紀州にのみたべさす。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び寂としたれば、ソと身うごきして、足をのべ、板めに手をかけて眼ばかりと思う顔少し差出だして、外の方をうかがうに、何ごともあらざりければ、やや落着きたり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふるさと　おじはわれを扶けて船より出だしつ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右の岸は新緑の光に輝き、仰げば梢と梢との間には大空澄みて蒼く高く、林の奥は日の光届きかねたれど、木の間木の間よりもるる光はさまざまの花を染め出だし、涼しき風の枝より枝にわたるごとに青き光と黒き影は幾千万となき珠玉の入り乱れたらんごとく、岸に近き桜よりは幾千の胡蝶一時に梢を放れ、高く飛び、低く舞う。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして最後に彼はおぬいさんにこの上なく深い愛と親しみとを持っていることをはっきり見出だした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々と思ひまはした末に茲まで来ると、彼はそこに生き甲斐のない自分を見出だした。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "慧鶴は自分の気のせいかと思ったが、灰の降りも少くなったらしく、そろそろ人が出だして、寺の垣外を通る話声にもそのようなことを話し合っている。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時餘經ちぬれども出でよとはのたまはず、はた出だし給ふべき樣子もなし。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰助はまず卒倒者の身体を検して、袂の中より一葉の写真を探り出だしぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　系図　病人は苦痛を忍びて語り出だしぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と衣兜を探りて、金光｜燦燗たる時計を出だし、恭しく隻手に捧げて遥に新開地に向い、陋み嘲けるごとき音調にて、「そらこれだ、これだ。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と懐より時計を出だして指示せば、「どれどれ。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大助これを見て地蹈※を踏みて狂喜し、欄干に片足懸けて半身を乗出だしつ。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾子は少しく乗出だし、「他に渡世の道が無いでもあるまい。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と先刻の包を取出だして、「あててみさっし。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、誰も……」と前後を見廻し、屹と頷き、帯の間に秘持てる紙片を取出だしつ、くるくると紙捻にして、また左右に眼を配り、人のあらぬを見定めて。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と綾子は耳を欹てたり、戸外にて喨々と二声三声、犬は疾風のごとく駈出だして、「変だ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三吉慌てて駈出だし、立停って胸を撫で、「ありゃ何だ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお丹の指揮に手空の奴等、一足先に駈出だして、派出所の前にずらりと並び、臆面もなく一斉に尾籠の振舞、さはせぬ奴は背後より手を拍きて、「鳴るは滝の水。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お丹はおもむろに説出だしぬ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と血を絞る声を立てられしが、衝と座を立ちて駈出だし、一室の戸を内より閉じて、自らその身を監禁せり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾子はまた膝を折りて端坐しつ、潸然と泣出だしぬ、たちまちきゃっと絶叫して、転げ廻りつ苦み※き、「秀、秀、私が悪かった。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "錦綵寶珠、賊等やがて意のまゝに取出だしぬ。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初の烏、また、旅行用手提げの中より、葡萄酒の瓶を取出だし卓子の上に置く。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "後の烏等、青き酒、赤き酒の瓶、続いてコップを取出だして並べ揃う。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（みずから天幕の中より、燭したる蝋燭を取出だし、野中に黒く立ちて、高く手に翳す。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
