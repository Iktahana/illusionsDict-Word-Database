        "examples": {
          "standard": [
            {
              "text": "そのオペラ歌手は、まさに時代のディーバと呼ぶにふさわしい歌声だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はロック界のディーバとして、絶大な人気を誇っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若手歌手が将来のディーバ候補として注目されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さっきむこうで、ビーディーバッジをひろったんだ。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きさまたち、おれが、ビーディーバッジをみちにばらまいておいたのにだまされて、やってきたな。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポケット小ぞうは、あなの中へおりようとしましたが、ふときがついて、ビーディーバッジをみちにばらまきました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときです、ビーディーバッジのききめがあらわれました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
