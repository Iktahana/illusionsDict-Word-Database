[
  {
    "uuid": "86d11542-a4ba-5dd5-b584-00cc4e5b3479",
    "entry": "伝統",
    "reading": {
      "primary": "でんとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
