    "definitions": [
      {
        "index": 1,
        "gloss": "quack (doctor)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
