[
  {
    "uuid": "1fa3a453-f0d3-5342-bc8e-9725c365f71f",
    "entry": "出来かねる",
    "reading": {
      "primary": "できかねる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段"
      ],
