        "examples": {
          "standard": [
            {
              "text": "昔使っていた電子手帳には、スケジュールや電話番号がたくさん登録されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は電子手帳にメモを取るのが習慣だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スマートフォンが普及する前は、電子手帳がビジネスパーソンの必需品だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "シャープの電子手帳はアメリカではウイザード（魔法使いね）という名前で出張っているが、こいつにマッキントッシュの爪の垢を飲ませて洗練させようということだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダグラス・アダムスのＳＦ、The Complete Hitch Hiker's Guide to the Galaxy では、電子手帳ほどの大きさの「銀河ヒッチハイカーズ・ガイド」という電子本が、重要な舞台回しを演じる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、スケジュール管理と簡単な表計算機能を盛り込んだ、電子手帳風の製品を手始めに出す。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
