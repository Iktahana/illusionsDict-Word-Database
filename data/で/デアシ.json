    "definitions": [
      {
        "index": 1,
        "gloss": "turnout (of people)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
