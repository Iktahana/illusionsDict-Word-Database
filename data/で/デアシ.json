        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これは市民の出足がなんとない不安のためにいくぶん止められたためかと想像された。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と走り寄って、出足を留めるように、膝を突き手に晃の胸を圧える。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "相撲なら、ここで定基の出足さえ速かったら、匡衡は手もなく推出されて終うところだったが、何も定基は勝負を争うつもりのわけでは無かったから、追窮するような態度に出無かった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "出足へ唐突に突屈まれて、女房の身は、前へしないそうになって蹌踉いた。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "厩舎の前にぐるぐると円を描いて出足の鈍っていた最後の栗毛は、胴にぐっと拍車の強い一撃を食らって急にぴゅーっと駆けだした。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かほどの処を攀上るのに、あえて躊躇するのではなかったが、ふとここまで来て、出足を堰止められた仔細がある。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "機会は何度来ても出足が遅いのでイツモ機会を取逃がしてしまう。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、半ば頃まではケープルトンの黄色がその中の先頭を切っていたが、私達の前まで来た時はデスボロは力つきて出足鈍り、大佐の馬は突進してそれを抜き、決勝点に入った時は、優に六馬身の差があった。",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "椎の小枝のように、少々出足に早い、遅いがあっても、待って貰いたいものであります」　皆吹き出した。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬は怒の為に狂うばかりになって、出足が反て固くなりました。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、この牛め」　馬は片意地な性質を顕して、猶々出足が渋ってくる。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでなくても、顔の固疾や、脆弱な体質が出足を鈍らすのであったが、着つけない服をつけ、久し振りに靴を穿いて出掛ける時には、まるで大旅行に出て行くように悲壮な気持がしたものであった。",
              "citation": {
                "source": "冬日記",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビット・インからの報告によれば、どうやらＴＫ―80、出足はかなり好調のようだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ―８００１の出足が予想に反して好調とはいっても、日本電気のまったくもって不得意とする民需製品。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、出足好調とはいえパソコン部隊はあくまで半導体とこみにしておき、たとえ赤字を出しても好調の半導体で吸収する腹を固めていたのである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳者出足の節は御懇念被下、又御見事成る御送物被下千万忝き次第に奉存候。",
              "citation": {
                "source": "手紙",
                "author": "安政三年九月二十九日　相良屋源之助あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "然ニ奴儀｜無拠要用ニ相掛居申候間、明後出足ニ而其御許迄参上可仕奉存候。",
              "citation": {
                "source": "手紙",
                "author": "安政五年十一月十九日　住谷信順、大胡資敬あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫であなた及私し家来一人〆三人ニて今日出足七ツ時頃よりも出かけ致度、其御心積ニて、先キ触大津の方迄御出し可被遣候よふ御頼申入候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年十月二十四日　岡本健三郎あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫で我等はよふ出足を急所也。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年十月二十四日　岡本健三郎あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月二日　小雪後晴　九・〇〇ブナ小屋　一・三〇弘法小屋　六・〇〇天狗平の小屋　今朝は暗いうちから出発する予定であったが、まだ雪が降っているので出足が鈍った。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月五日　小雪後晴　九・〇〇　平の日電小屋　五・三〇針ノ木峠の小屋　今日も早朝はまだ雪が降っているので出足がにぶったが、八時頃から雲が動き出して青空がときどき見え出したので、いろいろとお世話になった日電の人々と別れて平を出発する。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "客は大抵乗りものに乗って帰っては行く、人の出足は鈍る、途を歩く人も新聞など買っている余裕はない。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "延長六年八月の頃、奥州に住む、安珍という年若い美僧が、熊野詣でに出足した。",
              "citation": {
                "source": "京鹿子娘道成寺",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときたま掛かることがあっても、ザラ場の勾配のある瀬では出足が伴わぬ。",
              "citation": {
                "source": "瀞",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "出足をくらって少し不機嫌な私は父の机のそばにむっつり坐りました。",
              "citation": {
                "source": "落ちてゆく世界",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十万円ちかい大穴だの、八百長｜紛擾、焼打、そうかと思うと女子競輪などゝ殺気の中に色気まであり、百聞は一見に如かずと食指をうごかしていたが、伊豆の辺地に住んで汽車旅行がキライときているから、生来の弥次馬根性にもかかわらず、出足がおくれたのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎はまた三郎で、出足の早い友だち仲間と一緒に、新派の美術の方面から、都会のプロレタリアの道を踏もうとしていた。",
              "citation": {
                "source": "分配",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次はフンッと鼻であしらってソッポ向く。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お光はフンと鼻であしらう。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさんのほうが下手に出て何か相談しかけるとお嬢さんのほうはふんふんと鼻であしらって高圧的に出る、そういったのがよく目につく。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
