    "definitions": [
      {
        "index": 1,
        "gloss": "even (e.g. even a child)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "晩年多少日本に幻滅を感じた時でさえも、他の外人が日本を悪意的に批評する時、いつも憤然として大に怒り、さながら自分の愛人を侮辱された時の騎士のごとく、鋭い反撃の槍をふるって突き当って行った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中が蛇を追ったといって叱られ、植木屋が筍を抜いたといって怒られ、はては『おババさま』の姑でさえが、枯れた朝顔をぬいたというので『おババさま好き人です。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人でさえも書斎に入ることは許されなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "書房主山崎剛平氏は、私でさえ、ひそかに舌を巻いて驚いたほどの、ずぶの夢想家でありました。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋愛でさえも、蕪村の場合には夢の追懐の中に融け合っているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそのヒイキにした蕪村でさえも、単なる写生主義の名人としか解さなかった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "来訪客と話すことも、昔のように苦しくなく、時に却って歓迎するほどでさえもある。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「孤独は天才の特権だ」といったショーペンハウエルでさえ、夜は婦などを相手にしてしゃべって居たのだ。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを越えると、絶頂に辿りつくことになるので、ここでさえ、高さは一万三千尺近い見当である。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、（見当のつかなかった小僧）が小荷物受渡台の上に彼自身でさえ驚くような敏捷さで、飛び上った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、一人でさえも登り難い道を、一人を負って駈ける事は、出来ない相談だった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "また同じ人の名が色々な住所と結合してぱらぱらに散在しているので、どれが現住所であるか、当人でさえ時々間違えることがありそうである。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二千年来伝わった日本人の魂でさえも、打砕いて夷狄の犬に喰わせようという人も少なくない世の中である。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "良山良家の年頃の娘でさえあれば、一応、口をかけて問合わされる在り来りのものに過ぎなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにあの瀬の処では、早くにも溺れた人もあり、下流の救助区域でさえ、今年になってから二人も救ったというのです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然現象に関する言葉でさえ既にかようであるから、まして社会の特殊な現象に関する語は他国語に意味の上での厳密なる対当者を見出すことはできない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず客観的表現を研究の対象として、その範囲内における一般的特徴を索めるから、客観的表現に関する限りでさえも「いき」の民族的特殊性の把握に失敗する。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなのんびりした世界でさえも、自分の手でしっかり握っていない限り私有物の所有権は確定しないものと見える。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地味な科学者の中でさえも「新しいもの好き」がある。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "専門家でさえそうである。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように、最も問題になる憂いの少ない論文でさえも、見る人の眼のつけ処でその価値にかなりの懸隔を生じるのである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人殺しの罪人でさえも官費で弁護士がつけられる世の中に、効はあっても罪のない論文提出者は八方から虫眼鏡で瑕を捜され叱責されることになるのである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日大学の専門の学生でさえ講義ばかり当てにして自分から進んで研究しようという気風が乏しく知識が皮相的に流れやすいのは、小学校以来の理科教授がただ与えられた知識を覚えればよいというように教えこまれている結果であろう。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう種類の資料は勿論馬琴にもあり近松でさえ無くはないであろうが、ただこれが西鶴の中では如何にもリアルな実感をもって生きて働いている。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の春、民さんが嫁にゆかれたと聞いた時でさえ、私は民さんを毛ほども疑わなかったですもの。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学の事でさえそうである。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
