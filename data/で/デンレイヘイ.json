    "definitions": [
      {
        "index": 1,
        "gloss": "runner (soldier responsible for delivering messages)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "続く言葉は解つてゐるのだが、息せき切つて駆けつけた伝令兵のやうに声が出ないといふ風なのである。",
              "citation": {
                "source": "朝居の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――但し、わたしの休養とは、英国の伝令兵の声や午砲の音によって破られないところの永遠の安息であり、わたしの転地というのは、どの帰航船もわたしを運んで行くことの出来ないほどに遠いあの世へである。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　突如発せられた命令を、伝令兵は伝声管によって、艦内へ伝えた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、伝令兵を呼んで、この男を本籍地へ送り届けるようにしろ！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "』すると言下に伝令兵の姿が扉口に現われたが、七尺ゆたかの大男で、その頑丈な手が、生まれながらに馭者にでもなるように出来ているといったやつで――いわば歯医者の手先といった男なんです……。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、神の僕なる我がコペイキンは、その伝令兵と一緒に馬車へ乗せられてしまったのです。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」こう、そのとき先方から馬車を飛ばせて来た、二尺あまりもある泥鰌髭をのばした伝令兵が、喚きたてた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝令兵の持って来た赤い罫紙には、「艦隊命令第十九号。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――　愉快そうに肩をいからした清君と、心配顔の※代さんは、伝令兵の乗って来た小さいボートに乗せられて富士洞窟を出た。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝令兵は太い腕で上手に櫂を漕いで、沼のような碧海湾を、槍ヶ岳の洞窟へ急いだ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは……」　そこへ遽ただしく、伝令兵が大股で近よると、司令官の前に挙手の礼をした。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お話中でありますが」と伝令兵は大きな声で怒鳴った。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はッ」伝令兵は、左手に握っていた白い紙をツと目の前に上げると、声を張りあげて、電文を読んでいった。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝令兵は、再び挙手の礼をすると、同じ室の、一方の壁に並んだ、夥しい通信パネルの傍へ帰っていった。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「少尉殿」耳の側で、伝令兵が叫んだ。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「警備司令部との連絡電話が切断したであります」「なにッ」少尉は、駭いて、伝令兵の腕を握った。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、伝令兵が、重要なる二通の暗合報告を持ってきて、司令官と参謀長の間へ、置いていった。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオンの出現と共に青年たちは伝令兵になる。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "司令官閣下から、お電話であります」　伝令兵は忙しく、清川大尉の方へ報告をいたしました。",
              "citation": {
                "source": "太平洋雷撃戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あッ――」「やられたな、どうした伝令兵！",
              "citation": {
                "source": "太平洋雷撃戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「艦長どの、報告」　通信兵の側に立っていた伝令兵が、突然叫びました。",
              "citation": {
                "source": "太平洋雷撃戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへバタバタと靴音がして、伝令兵が飛んできた。",
              "citation": {
                "source": "空襲下の日本",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「私はもと／＼アルジェリイ駐屯軍に召集されて、沙漠のなかの支隊から支隊へ連絡する伝令兵に選ばれてゐたのです。",
              "citation": {
                "source": "亜剌比亜人エルアフイ",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺まで入ると、沙漠はまつたく際限もなく拡がつて、移動する支隊と支隊との連絡は、この頃はまだ伝令兵を走らせる方法をとつてゐました。",
              "citation": {
                "source": "亜剌比亜人エルアフイ",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、新兵の何より厭がるのはこの伝令兵になる事でした。",
              "citation": {
                "source": "亜剌比亜人エルアフイ",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は進んで模範的な伝令兵となりました。",
              "citation": {
                "source": "亜剌比亜人エルアフイ",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの前後四年間にわたる、最も忠実な伝令兵としての賞状と履歴書とが、巴里に出た時に何よりも役に立ちました。",
              "citation": {
                "source": "亜剌比亜人エルアフイ",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚鈍な伝令兵たちでさえも、広間の三方の壁添いに並んだ、白く蔽われた小卓のそばの氷桶へ、新しいシャンパンの壜を立てながら、老獪そうににやにやしたり、あたりを見廻しては、微笑の眼を伏せたりしている。",
              "citation": {
                "source": "ある幸福",
                "author": "EIN GLUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝令兵たちが白手套のまま、テエブルからテエブルへ走っては、注いで廻った。",
              "citation": {
                "source": "ある幸福",
                "author": "EIN GLUCK",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
