[
  {
    "uuid": "364961c9-e57c-5dcf-9e98-c82b754e5f2b",
    "entry": "伝単",
    "reading": {
      "primary": "でんたん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
