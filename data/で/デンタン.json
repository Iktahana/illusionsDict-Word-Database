    },
    "definitions": [
      {
        "index": 1,
        "gloss": "propaganda leaflet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いつの間にか、外塀や、電柱に、伝単がベタベタ貼りさがされていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "漫画の入った伝単が、製粉工場に振りまかれた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは蝎のように怖がられている伝単だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」厳重極まる警戒線をくぐりぬけて、いつのまにこんな伝単が持ちこまれたか幹太郎には不思議だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝単には次のようなことが書かれてあった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝単が持ちこまれた径路と出所が厳重に詮索せられた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝単は、恐らく猿飛佐助でもが持ちこんだものだろう。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "市街は、さまざまな伝単の陳列会だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹部は、城内に頑張っている南軍よりも、土匪よりも、猿飛佐助のまく伝単や高取や、工人たちと一つになった兵士の赤化を一番に、気にやんでいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私は捨てられた、若いのに姥捨山に――、仰げば、一昨年の今月今夜のこの月は政治に憑かれ伝単を持つて波打際をうろついたものだ、そして私は貫一のやうにではなくお宮のやうに政治に足で蹴とばされた。",
              "citation": {
                "source": "小熊秀雄全集",
                "author": "―３―",
                "note": "青空文庫"
              }
            },
            {
              "text": "その状態を、見事な双方の統制というのかもしれぬけれど、どの電車の内、停留場にでも貼られているのは、電気局の儀式ばった印刷のビラだけで、従業員たちが直接市民に訴えるただ一枚のビラ、伝単さえ見当らないのはどういうものであろう。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち二対対等形質説に従えば、四遺伝単位説となって、両親のどちらかにＡＢ型があれば、子供には各型のものが生れる事になっている。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "も一つの三遺伝単位説に従えば、Ｏ型とＡＢ型との間からは、Ａ型又はＢ型が生れ、ＡとＡＢ型、ＢとＡＢ型、ＡＢ型同士からは、Ａ、Ｂ、ＡＢ型が生れて、決してＯ型は生れない。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "笠神博士は熱心な三遺伝単位説の支持者で、その為に涙ぐましいような努力を払われている。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　夜みんな子供をかえして静かになると、タミノとひろ子とは、工夫してなるたけ人目をひくように、字の大小、ふちどりなどに心を配りながら、大きいのや小さい四角い伝単形やらのガリ版をきった。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯十七日信州では「陸海軍に降伏なし、日本航空隊司令官」と伝単をまいたそうな。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日遺伝を論ずる学者達が生物の身体を遺伝単位なるものの集合であると見做し、各遺伝単位は永久不変の物であると考へて居る如きは、我らから見ると、全く固形の論理に囚はれた誤りであつて、其の当て嵌まるのは、たゞ論者等の脳中に画いて居る模型だけである。",
              "citation": {
                "source": "固形の論理",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と一太郎やーい親子がおれたちの村にやって来た時や桜井肉弾大佐の講演会があった時奴はみんなの前でおっぴらに云った電柱や壁に貼られた伝単も、時々ばらまかれるアンチのビラも奴の仕事だカーキ服の憲兵もサーベルも奴を血眼に探しているが……おお　勇敢な反帝の闘士！",
              "citation": {
                "source": "アンチの闘士",
                "author": "今村恒夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "奉天の街上で銃架はひとりの同志を奪ひ去つたしかし次の日の暮れ方、おれは帰りゆく労働者のすべての拳しの中に握り占められたビラの端を見た電柱の前に、倉庫の横に、風にはためく伝単を見た、同志よ安んぜよ、君が死を以て貼り付けたビラの跡はまだ生々しい。",
              "citation": {
                "source": "生ける銃架",
                "author": "――満洲駐屯軍兵卒に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "残された同志はその上へ次々に伝単を貼り廻すであらう白樺と赤楊の重なり合ふ森の茂みに銃架の影はけふも続いて行くお前の歴史は流×（11）に彩られて来たかつて亀戸の森に隅田の岸に、また朝鮮に台湾に満州にお前は同志の咽を×（12）き胸を×（13）り堆い死屍の上を×（14）に酔ひ痴れて突き進んだ生ける銃架。",
              "citation": {
                "source": "生ける銃架",
                "author": "――満洲駐屯軍兵卒に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈松金争議二十四時間で解決す〉関東××労働組合Ｋ支部　こういう伝単が臆面もなく張り出されることすらあった。",
              "citation": {
                "source": "鋳物工場",
                "author": "戸田豊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隊長宿舎のヴェランダで中田大尉が対空監視についていたが、アメリカの伝単だと知ると、翌日の会報に、〈押収の伝単は明日会報時までに全部庶務へ一括提出すべし。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "書籍・雑誌・パンフレット・ビラ＝ポスター＝伝単等々。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝単は北京に降り、蒲東一警部は、禁門に見出だされる事　薬草採りの寝小屋らしい。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその日、南区の奉行、王という者が、一枚の伝単（ちらし）を持って、管領庁へ出むいてきた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや同時に、ここで拾ッた、かしこに落ちていたという伝単が、北奉行や町廻りの手からも、何十枚となく届け出られていた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがすでに、秋も半ば過ぎ――　梁山泊では、さきに神行太保の戴宗を走らせて、雲の上から伝単を撒き散らさせた直後において、北京出勢のしたくはしていた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
