  {
    "uuid": "7e04b828-d766-5263-b6ca-df04c7dd9c29",
    "entry": "電請",
    "reading": {
      "primary": "でんせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wire (one's government) for instructions",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……再三電報申上げし如く、皇甥李光明擁立派は、皇帝が「帝王」を帯出せられたるは、安南独立資金をうるため、日本においてそれを売却せらるる意志なりと附会して安南政庁に密訴、すでに仏国安南総督は東京｜駐箚仏国大使に右に対する事実調査を電請せり。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "台北・台南の二州及び花蓮港庁にはそれぞれ警察官応援が電請された。",
              "citation": {
                "source": "霧の蕃社",
                "author": "中村地平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
