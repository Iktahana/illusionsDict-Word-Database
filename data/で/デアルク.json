    "definitions": [
      {
        "index": 1,
        "gloss": "to go out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "で、私は異郷に遠く旅出して來ながらあんまり出歩くこともせずに、始終机に向つてはその執筆に專心した。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金がなくなっていたので出歩くにも出歩けなかった。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がこの土地へ来てから、こうして一緒に出歩くのは今夜がはじめてであった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出歩く道がわかればわなを掛けるといいそうであるがその道がなかなかわからないと言う。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　銀子の家は電車通りから三四町も入った処の片側町にあったが、今では二人でちょいちょい出歩く均平の顔は、この辺でも相当見知られ、狭いこの世界の女たちが、行きずりに挨拶したりすることも珍しくなかったが、均平には大抵覚えがなく、当惑することもあったが、初めほどいやではなくなった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには彼女も体の自由な看板借りであり、何かというと用事をつけて、出歩くのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "二里ちかくも遠くへ出歩くなどは、嫂にとつて、金木へお嫁に来てはじめての事かも知れない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は落ちついて、着物がひとりで出歩くものか、捜してごらん、と言った。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "強ひても興味を持ちたくもあるんだが、まさか綱をかついで出歩く気にもなれさうもない、その代りにその種の書籍を渉らうかと思つてゐます。",
              "citation": {
                "source": "趣味に関して",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "名前はヒュー・ブーン、その醜い顔は中心区をよく出歩く者なら誰でも見覚えがあるはずだ。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "政雄に同情を持っていた対手の運転手は政雄をカフェーへ伴れて往って饗応をしてくれたので、それがために遅くなって宿へ帰ったのは夜の十一時｜比であったが、それ以来政雄は夜も出歩くようになった。",
              "citation": {
                "source": "女の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰌とりのかんてらが、裏の田圃に毎夜八つ九つ出歩くこの頃、蚕は二眠が起きる、農事は日を追うて忙しくなる。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまあ信心だから仕方がねえとして、そのほかにも親類へ行くとか何とか云って、ずいぶん出歩くことがあるそうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "後家さんがあんまり出歩くのはどうもよくねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伊豆屋という酒屋の女房お八重は、前にも云う通り、大きい子供の三人もありながら、派手づくりで出歩くような女ですから、どうで碌な事はしていまいと思っていると、案のとおり落語家のしん吉に浮かれて方方で逢い引きをしている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを聞いて近所のものは、二人が出歩くのは、最初の其日に限らず、過ぎ去つた昔の夢の迹を辿るのであらうと察した。",
              "citation": {
                "source": "ぢいさんばあさん",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "小春の空が快く晴れて、誰も彼も出歩く頃になっても、秀麿はこのしんとした所に籠って、卓の傍を離れずに本を読んでいる。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十三年前、予米国ミシガン州アンナボアに佐藤寅次郎氏と野原の一つ家に住み、自炊とは世を忍ぶ仮の名、毎度佐藤氏が拵え置いた物を食って出歩く。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「土地馴れねえ者が独りで出歩くからいけねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "「当分だから出歩くことだけはお止めよ、ね。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それがいゝでせう、どうせあなただつてもう昔の樣にポイポイ出歩く譯には行くまいから。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それがいいでしょう、どうせあなただってももう昔の様にポイポイ出歩くわけには行くまいから」　とＳ―が勿体ぶって附け加えた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした生物の、産れてまだ間もない柔かい生命が、私の不注意な足に踏まれて、どうかするととりかえしのつかない傷を負わされまいものでもないのを思うと、滅多に外を出歩くこともできないような気持がする。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "またの名を白足和尚と呼ばれただけあつて、足の色が顔よりも白く滑らかで、外を出歩く時雨上りの泥水の中をざぶざぶと徒渉りしても、足はそれがために少しも汚されなかつたといふことだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚厭なことは、自分まで同類と思はれることだ、何一つ買物をするでもなく、何処に一処に出歩くでもなく、女中のやうに働き、……などゝ続けた時彼女は、思はず、「あの馬鹿の……」と夫を称んで、反つて情けなくなつた。",
              "citation": {
                "source": "貧しき日録",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう妻に云つたのは、Ｏは出歩くため金が又すぐ無くなつてしまふなどと妻が云ふからだ。",
              "citation": {
                "source": "嫉妬する夫の手記",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の家に住み込むやうになつては、勝手に出歩くといふことは容易に望めることではないからである。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生の余剰価値ともあるべき筈の芸術が浅墓なことであるくらゐならば、頼みもしないにそんなものを作らなくてもよいのだし、作るとすれば図々しいことである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常に根は虔しやかであるくせに、ヒヨツトした場合に突発的なイタヅラの出来る女だつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとく我儘であるくせにまた甚だしく臆病な彼は、自分で断然年賀端書を廃して悠然｜炬燵にあたりながら彼の好む愚書濫読に耽るだけの勇気もないので、表面だけは大人しく人並に毎年この年中行事を遂行して来た。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
