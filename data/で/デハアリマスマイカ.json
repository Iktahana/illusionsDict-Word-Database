[
  {
    "uuid": "1025ea74-c46d-5eb9-b414-ee8b5095fd84",
    "entry": "ではありますまいか",
    "reading": {
      "primary": "ではありますまいか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
