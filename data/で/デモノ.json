        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "首がふとく、襟脚はいやに鈍重な感じで、顎の下に赤い吹出物の跡を三つも僕は見つけた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下り坂の茶店で休んだときにそこのお神さんが色々の火山噴出物の標本やラヴァやカメーの細工物などを売付けようとしたが、こしらえもののいかものだけはわが地質学者を欺く訳に行かないのがおかしかった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも隣りの赤城山の噴出物のお裾分けかも知れない。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球の物理を明らかにしないで地震や火山の現象のみの研究をするのは、事によると、人体の生理を明らかにせずして単に皮膚の吹出物だけを研究しようとするようなものかもしれない。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外に煙突の煙からは煤に混じて金属の微粒も出る、火山の噴出物もまた色々の塵を供給する。",
              "citation": {
                "source": "塵埃と光",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は肥つてゐて、蒼白く、額に目に見えるくらゐの吹出物ができてゐた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう書物は縁のない方であるが、何か理化学方面に関する掘出物でもあるかと思ったからである。",
              "citation": {
                "source": "断片（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は男のくせに、顏の吹出物をひどく氣にするたちだつたので、こんな作品を思ひついた。",
              "citation": {
                "source": "『玩具』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処にそれ、はじめの一冊だけ、ちょっと表紙に竹箆の折返しの跡をつけた、古本の出物がある。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には些性が悪くて、骨董商の鼻毛を抜いていわゆる掘出物をする気になっている者もある。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪い奴が棒一本か鍬一｜挺で、墓など掘って結構なものを得る、それが既ち掘出物で、怪しからぬ次第だ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその掘出物を安く買って高く売り、その間に利を得る者があれば、それは即ち営業税を払っている商売人でなければならぬ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれかが「過去の産出物の内で、目に見られ、手に触れる事のできる三つのもの」の一つとして書物を数えているが、この言葉をここでしばしば思い出す。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まわりに落ち散らばっている火山の噴出物にも実にいろいろな種類のものがある。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他にもいろいろな種類の噴出物がそれぞれにちがった経歴を秘めかくして静かに横たわっている。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずり落ちた瓦は軒に這い下り、そり返った下見板の木目と木節は鮫膚の皺や吹出物の跡のように、油気の抜けきった白ペンキの安白粉に汚なくまみれている。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、金の兜は掘出物だったよ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれが真実の掘出物と云うのだろう。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "馴れて来るとつい掘出物をとの慾も出て、そんな時は五会の連中に嗤われた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　浅草ではちょうど芸者屋の出物も見つからず、小菊の主人と一直で朋輩であった人が、この土地で一流の看板で盛っていて、売りものがあるから、おやりなさいといってくれるので、松島と小菊はそこへ渡りをつけ、その手引で店を開けることにした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "深夜、裸形で鏡に向い、にっと可愛く微笑してみたり、ふっくらした白い両足を、ヘチマコロンで洗って、その指先にそっと自身で接吻して、うっとり眼をつぶってみたり、いちど鼻の先に、針で突いたような小さい吹出物して、憂鬱のあまり、自殺を計った事がある。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新造卸しの引出物の折菓子を与えられて、唇の紅を乱して食べていた雛妓が、座を取持ち顔に、「愛嬌喚き」をした。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "額の邊にあはつぶのやうな小さい吹出物がでてきた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が顏の吹出物へ、三角形や六角形や花の形に切つた絆創膏をてんてんと貼り散らしても誰も可笑しがらなかつた程なのである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの吹出物には心をなやまされた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその吹出物を欲情の象徴と考へて眼の先が暗くなるほど恥しかつた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟も私の吹出物を心配して、なんべんとなく私の代りに藥を買ひに行つて呉れた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃になつて私の顏の吹出物もどうやら直つてゐたが、それでも惰性で、私はなにかと顏をこしらへてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬ気でものを書きとばしている男。",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い婦人で小学校の先生らしいのが両腕でものを抱えるような恰好をして拍子をとっている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
