        "gloss": "telegraphic remittance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところへ、突然、れいの電報と電報為替である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が東京から電報為替で金一円也を送って来たのもその頃であったという。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして御叮嚀に附箋までして、「一寸都合がありますから、懸賞金は電報為替でお送り下さるやうに。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "重ねて申します、懸賞金を折返し電報為替で送つて下さい。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "懸賞金を折返し電報為替で送つて下さい。",
              "citation": {
                "source": "名文句",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――健から電報為替が来た、おお健よ、健よ、合掌。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "一通はＮ先生、一通は光郎、あとのはねずみ色の封筒に入った郵便局からのだ、あけて見ると電報為替だ。",
              "citation": {
                "source": "出奔",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月二十七日（日曜）　午前中、父上から来た電報為替をとりながら、古本みたいな『あらくれ』を四十八銭で買って来た。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "九時頃に起きて早速東京の弟のところへ二十円電報為替で送るやうに書いた電報を女中に頼んだが、すると早速また女中がお勘定をと云つてやつて来た。",
              "citation": {
                "source": "浮浪",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云つて電報為替の封筒を持つて這入つて来た。",
              "citation": {
                "source": "浮浪",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟はその翌日の昼頃電報為替を出したので、無論遅くもその日の中には配達になるものと思つて、別に私の方へは電報も打たなかつたのであつた。",
              "citation": {
                "source": "浮浪",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "国男がいそいで引かえし、特急に間に合わせようとしたが到頭駄目であったので、金は電報為替にして送り、紙入その他は又別に送ったりした由。",
              "citation": {
                "source": "中條精一郎の「家信抄」まえがきおよび註",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "電報為替が鳥のやうに飛んできた。",
              "citation": {
                "source": "ヒンセザレバドンス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "待つ身のつらさというが、予期し得ぬ早さのうちに電報為替がとどいた時の喜びは忘れられぬ。",
              "citation": {
                "source": "青い絨毯",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが電報為替がとどく。",
              "citation": {
                "source": "青い絨毯",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "野見　　（受取りながら）僕に……なんだ、これや、電報為替だ。",
              "citation": {
                "source": "長閑なる反目（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へ帰つて、すぐ電報為替で送るよ」　と、彼は、あやまるやうに言つた。",
              "citation": {
                "source": "山形屋の青春",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分電報為替の取り扱ひになるはずです。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく、六拾円也の電報為替が届いた。",
              "citation": {
                "source": "野宿",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、電報為替で千円送ってくれた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は電報為替で至急送金してくれるように電報を打った。",
              "citation": {
                "source": "風貌",
                "author": "――太宰治のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "電報為替が来ないので、私は重ねて催促の電報を打った。",
              "citation": {
                "source": "風貌",
                "author": "――太宰治のこと",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
