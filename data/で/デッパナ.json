          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "プロジェクトの出っ鼻で、重要な問題が発覚した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は試合の出っ鼻から素晴らしいプレーを見せ、観客を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "事業の出っ鼻で失敗したものの、諦めずに再挑戦した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
