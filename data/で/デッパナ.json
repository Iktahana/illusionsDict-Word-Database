    "definitions": [
      {
        "index": 1,
        "gloss": "projecting part (of a headland, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "海岸線の出っ鼻には、古い灯台が立っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "船は岬の出っ鼻を回り込み、小さな湾に入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その岩の出っ鼻は、絶好の釣りポイントとして知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし飛び下りるあたりに石があるか、材木があるか、それはその石垣の出っ鼻まで行かねば知ることができなかった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある雑木林の出っ鼻の落ち葉の上に風呂敷をしいてすわり込んで向かいの丘を写し始めた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、そんな処を歩いてはいけない、あぶないじゃないか」　道は山の出っ鼻を廻って往った。",
              "citation": {
                "source": "陳宝祠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのかどにあるのがそうですよ」　ぐいと大川からこっちへ切りこんでいる小堀のかどの出っ鼻に、なるほど於加田と書いたあんどんが、ゆらめく水に灯影を宿して見えました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅行者のためのホテルやペンシオネの多くは、しかし、近代様式で、町から少し低い位置の坂の中腹とか崖の出っ鼻とかに建てられてある。",
              "citation": {
                "source": "エトナ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのでっぱなに巨大な松が七、八本、あるいは立ち、あるいは這うている。",
              "citation": {
                "source": "河口湖",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "moment of departure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "出っ鼻をくじかれた彼は、何も言わずにその場を立ち去った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の出っ鼻で、チーム全体の士気が下がってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大事な会議の出っ鼻にトラブルが発生し、進行が遅れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "outset",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
