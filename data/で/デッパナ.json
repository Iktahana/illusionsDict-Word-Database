        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし飛び下りるあたりに石があるか、材木があるか、それはその石垣の出っ鼻まで行かねば知ることができなかった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある雑木林の出っ鼻の落ち葉の上に風呂敷をしいてすわり込んで向かいの丘を写し始めた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、そんな処を歩いてはいけない、あぶないじゃないか」　道は山の出っ鼻を廻って往った。",
              "citation": {
                "source": "陳宝祠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのかどにあるのがそうですよ」　ぐいと大川からこっちへ切りこんでいる小堀のかどの出っ鼻に、なるほど於加田と書いたあんどんが、ゆらめく水に灯影を宿して見えました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅行者のためのホテルやペンシオネの多くは、しかし、近代様式で、町から少し低い位置の坂の中腹とか崖の出っ鼻とかに建てられてある。",
              "citation": {
                "source": "エトナ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのでっぱなに巨大な松が七、八本、あるいは立ち、あるいは這うている。",
              "citation": {
                "source": "河口湖",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
