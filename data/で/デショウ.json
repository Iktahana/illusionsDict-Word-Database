        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なんぼ楽しいの歌でしょう』と言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、少しも西洋臭くない』と言って大満足なので、『あなた西洋臭くないでしょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "むずかしいでしょうか』『あなた、坊さんでない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白い坊さんでしょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに可愛いでしょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれを、どうお思いでしょうか。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ人が見たら、あれをどう感ずるでしょうか。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシヤ人が見たら、何と判断するでしょうか。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族は、捨ててよいものでしょうか。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理なお願いでしょうけれどもお願いしてみます。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿な親でも、とにかく血みどろになって喧嘩をして敗色が濃くていまにも死にそうになっているのを、黙って見ている息子も異質的ではないでしょうか。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、あんな有様でしかもなお日本が勝ったら、日本は神の国ではなくて、魔の国でしょう。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして、こんなに厚顔無恥なのでしょう。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまのソ聯は、どうでしょうか。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまの日本の共産党は、どうでしょうか。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの魯迅先生が、いま生きていたら、何と言われるでしょう。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、プウシキンの読者だったあのレニンが、いま生きていたら、何と言うでしょう。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またまた、イデオロギイ小説が、はやるのでしょうか。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿命と言い、縁と言い、こんな言葉を使うと、またあのヒステリックな科学派、または「必然組」が、とがめ立てするでしょうが、もうこんどは私もおびえない事にしています。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らなかったでしょう？",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえ、お逢いしたことは無いのでございますが、私が、その五、六日まえ、妹の箪笥をそっと整理して、その折に、ひとつの引き出しの奥底に、一束の手紙が、緑のリボンできっちり結ばれて隠されて在るのを発見いたし、いけないことでしょうけれども、リボンをほどいて、見てしまったのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おわかりでしょうか。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いても立ってもおられぬ、とはあんな思いを指して言うのでしょう。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉さん、あの緑のリボンで結んであった手紙を見たのでしょう？",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校のおつとめからお帰りになって、隣りのお部屋で、私たちの話を立聞きして、ふびんに思い、厳酷の父としては一世一代の狂言したのではなかろうか、と思うことも、ございますが、まさか、そんなこともないでしょうね。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽を知らない音楽家があるでしょうか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで雑誌の最後的プランをきめてしまうのだとか言っていましたが、――どうでしょう。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "進歩していない、というと悪く聞えますが、退歩していないと言い直したらどうでしょう。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさぞ、御心配だったでしょう。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄さんがいらっしゃったら、きょうは、どんなにお喜びだったでしょうね。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
