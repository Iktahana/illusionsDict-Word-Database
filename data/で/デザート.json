    "definitions": [
      {
        "index": 1,
        "gloss": "dessert",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二　卓上演説　近年いろいろの種類の宴会で、いわゆるデザートコースに入って卓上の演説がはやるようである。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはいわゆるデザートコースにはいってからがきわめて適当な時機であろうという事も了解される。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の中でお辨当を食べる、山苺がデザートだ。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "デザートには、エンドウマメが一つぶでました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下デザートを終えるまでのコースにも、何一つ不足と思えるものもなく、いわゆる善尽し、美尽しで、感嘆の中に食事を終えたことである。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女が、ほのかに匂っているオレンジに塗られたブランデーの揮発性に、けへんけへん噎せながら、デザートのスザンヌを小さいフォークで喰べていると、むす子がのそっと立ち上って握手をして迎える気配がした。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "デザートを運んで来た給仕を何気なく見て私は驚いた。",
              "citation": {
                "source": "褐色の求道",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　デザートのハネデュウ・メロンをスプーンですくい上げながら、（何かしませんか……）と、云ってくれた準之助氏の言葉を、新子はいぶかしげに、眼で訊き返した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "デザートコースになってから、貴族院議長のＴ公爵が立ち上った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "厨房一同入寮晩餐会メニューチキンコンソメ　　アスパラガスのサラダマッシュポテト　　ヒラメのソテコールドミート　　パンデザートはバニラアイスクリーム　慶一は、「厨房」という字を、とりあえず「とうぼう」と読み、コックかなんかの意味だろうと考えた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともそれは私が帰宅したアトの事で、誰もその兄の姿を見届けたものはいなかったが、ちょうど私が自宅で夕食を終ってから、何かしらデザートじみた物が欲しいと思っているところへ、病院の姫草ユリ子から取次電話がかかって来た。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて宴が始まってデザート・コースに入るや、停年教授の前に坐っていた一教授が立って、明晰なる口調で慰労の辞を述べた。",
              "citation": {
                "source": "或教授の退職の辞",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんていふ日には、一寸とお待ちつて、出掛けたでせう、あれは買つて来るわけぢやないんですよ、まだ／＼夏の時分の吾々のデザート……西瓜、桃、真くわ瓜――」「ぢや、また来年の夏になつたら来て頂戴よ、冬のうちは用がないからお帰りよ。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "デザートコースになつてから、貴族院議長のＴ公爵が立ち上つた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その白葡萄をちびりちびりやりながら、昼飯の四品を平らげて、デザートのチョコレートも済んで、また寝台の上で、こんどは葉巻きを燻ゆらしていると、初めてでもないが、とにかくうちのことを思いだした。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日は周二さんが果実一籠をお土産として下さつた、そしてみんなで頂戴した、私の食卓にデザートがあるとは珍らしかつた、といふ訳で。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事はスープと肉とデザートで、非常に高かったように思う。",
              "citation": {
                "source": "吹雪のユンクフラウ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さう、デザート・コースにはいると、お仲人の挨拶、新郎新婦の紹介、来賓の祝辞といふ順序になるわけ、まあそれは型通りつていふところだけど、世の中に、こんなつまらない型つてないわ。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "デザートは、白ジェリイといちご、もっとぜいたくすれば、コーヒーも出すのよ。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラックベリイの煮たのがデザート、コーヒは飲み放題。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "デザートになると、ルピック夫人が彼にいうのである――「このメロンの皮を兎に持ってっておやり」　にんじんは、皿をひっくり返さないように、できるだけ水平に持って、小股で使いに出かける。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろデザートを運ぼうとしている頃になって、二人連れの支那人が静かに入って来て、私の隣りの空席へ坐った。",
              "citation": {
                "source": "妖影",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わかいのは　なにゆえ　デザートを　もって　もどってこん！",
              "citation": {
                "source": "まちねずジョニーのはなし",
                "author": "THE TALE OF JOHNNY TOWN-MOUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかみは　あかい　ロブスター　２び、　ハム　１ぽん、　おさかな　１まい、　デザート　ひとつ、　そのほか　ナシと　オレンジも　いくつか。",
              "citation": {
                "source": "わるねずふたりぐみのはなし",
                "author": "THE TALE OF TWO BAD MICE",
                "note": "青空文庫"
              }
            },
            {
              "text": "デザートを　こわし、　さらには　ロブスター、　ナシと　オレンジまで。",
              "citation": {
                "source": "わるねずふたりぐみのはなし",
                "author": "THE TALE OF TWO BAD MICE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「当り前さ結論のない演舌は、デザートのない西洋料理のようなものだ、――いいか両君｜能く聞き給え、これからが結論だぜ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、すこし、めしあがれ」　デザートのマロン・グラッセをつまみながら、サト子は、白葡萄酒を、ひと口、飲んでみた。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "――チーズのないデザートは片眼のない美女の如きものである。",
              "citation": {
                "source": "時　処　人",
                "author": "――年頭雑感――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では、池田さん、どうぞ」　ふと、我にかえると、いつの間にかデザート皿が出ていて、みなの視線がうながすようにこちらへむいている。",
              "citation": {
                "source": "春雪",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "デザートのフォークを置くともう音楽が始った。",
              "citation": {
                "source": "梟の眼",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
