    "definitions": [
      {
        "index": 1,
        "gloss": "source",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「それは紙の出どころが違うんだ。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出どころの判らない匂いと笑いと唄とを引き切るように掻き分けて、物売りと、分別顔のギャルソンが皿を運んだり斡旋したりしている。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ幼ない発育不良の一人息子の教育資金も他に出どころはなし、自分たちの老後の生活費も気に懸つた。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞広告代など財布を叩き破っても出るわけはなく、看板をあげるにもチラシを印刷するにもまったく金の出どころはない。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに八百屋へ行って、この西瓜の出どころを詮議して来い。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "金の出どころ、身請け人の身許を正直に打明けませんでは、とても得心いたすまいと存じまして……」「それはよろしい。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "残るところは、どこのお寺の坊主がこの四人を欲で買ったたか、五十両包みの出どころ詮議だけだよ」「ね……！",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "むっつり右門はただのできあいじゃねえや、知恵の出どころがちっと違わあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、どこからあの駕籠が迷ってきたか、出どころの見当をつけるにしても日本橋へ行くのが事の先なんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "雛の出どころ詮議だったら、人形町は逃げも隠れもしやしねえといってるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「京金襴の出どころをかぎつけてこいといってるんだ」「そんなものを洗や、なんのまじないになるんです」「いちいちとうるせえな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、あの床の間へ降った血の出どころが不思議です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの知恵は、いつだって出どころが違うじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほしいものならやっときな――」　それを右門はあくまでもすがすがしい大腹で、微笑を含みながら見ながめていましたが、そのときはからずも、いま出どころが違うといった右門のその明知の鏡にちらりと映じ写ったものは、そこのしたくべやの明け荷の前に、腕組みをしている一人の勧進元らしい年寄りでありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつは、この金の出どころが少し不思議でござりましてな」「なにッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがひと晩やふた晩じゃねえんで、毎晩知らぬまに、出どころたれどころのわからねえ幽霊水にぐっしょりとぬれているんでね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "出どころが確かでございますから、品はお堅いと存じますが……。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "が少し音の出どころが違うようである。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもう大抵｜見当は付いたが、今度はその鬼っ児の出どころだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三河万歳",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、同じ仕事に向ふ駿介の熱心さの出どころは、駒平とはちがつてゐた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちこち見廻して声の出どころを探すと、いつの間にか、商用の重役らしい三人づれが一卓を占めて、牛鍋のアルコホル焜炉をかこんでいるのだった。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーリキイには金の出どころがない。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫妻が漸やっと笑顔を見せるようになると、またしても胸に閊える悩みの種、川上座の落成に伴う新築披露、開場式の饗宴などに是非なくてならない一万円の費用の出どころであった。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私はこの人の権威を感ずると申しましても、この権威の出どころたとえば空威張りとか、どういうようにその人が顰面をしましても、自分の権威をつくろうとしましても、そういうところからその人の権威を、私は認めることができないと思います。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この八十町歩から現に二俵供出しているそうだが、供出は水田の所有者が個人的な所有量に応じて為すものであるから、むろん村人の多くは水田を所有しておらず、八十町歩を村人全体に割れば供出どころか二三ヵ月の食い扶持にしかならない。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは命令の出どころが、情報局や内務省ではなしに、陸軍報道部である証拠だ。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、さうかその金の出どころをね……どうしても云はない……貰つたといふのかね……主人に……え？",
              "citation": {
                "source": "秘密の代償",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん、あちこちで工面はしたが、まとまつたものは、どうしても出どころがないんだ。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が与えなければどこからもお金の出どころがないのを知っていますから仕方なく、お金の代りに衣類を渡して、これを売りなさい、と申すような事も度々ありました。",
              "citation": {
                "source": "あの顔",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧洲戦が初まる前までどころか、恐らく二、三年も露都に過ごしたらクサクサしてとても辛抱出来なくなるだろう。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            }
          ]
        }
