        "examples": {
          "standard": [
            {
              "text": "半導体製造プロセスでは、微細なパターンを形成するために電子線が利用される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は電子線を使った新しい材料加工技術を開発した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "電子線の照射により、物質の表面を改質する研究が進められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "Ｘ線だと物質の内部に深く入るが、電子線は深く入らないように出来るから、浅いところからの反射像によって、浅い場所の状態を験べると云う便利があるのだ。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
