        "examples": {
          "standard": [
            {
              "text": "電気通信工学を学ぶことで、通信技術の基礎から応用までを習得できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は電気通信工学の博士号を取得し、大手通信企業の研究開発部門に就職した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "電気通信工学の分野は、5GやIoTといった先端技術の発展に大きく貢献している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "日本のパソコンをリードした二人の研究者　松本が三年から移った第一部の電気通信工学科には、生まれたばかりのマイクロコンピューターにいち早く飛びついた若手の助教授がいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『トランジスタ技術』はマイクロコンピューターの大々的な特集を組み、ミニコンピューターのノバを使ってきた電気通信工学科でも、いち早く仕入れてきた８００８を使って、安田助教授が手作りコンピューター試作一号機に取りかかっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした方針に沿って、一か月の突貫工事で進められた開発作業の中心となったのは、電気通信工学科四年の畑中文明だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
