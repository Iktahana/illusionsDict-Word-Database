          "literary": [
            {
              "text": "所でラヴェルなんてバッハが見たら苦労性なデコラトゥールだ。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、一寸そこにアール・エ・デコラシオンがあるでしょう？",
              "citation": {
                "source": "明るい海浜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月十四日に間に合うように和一郎と小枝との結婚を祝う電報をうったなかに伸子はハハノケンコウノタメアメリカケイユデコラレヨと云ってやった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（２）極めてデコラティーヴな画面ですが、昔麦僊が庭園と舞妓を描いたのとは全く異った感覚があります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は自分のデコラティーヴに扱われていることにわずらわされず、しかも少女の重みをふくんで、なかなか美しいと思います。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
