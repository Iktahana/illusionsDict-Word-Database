        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "むずかしいでしょうか』『あなた、坊さんでない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれを、どうお思いでしょうか。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ人が見たら、あれをどう感ずるでしょうか。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシヤ人が見たら、何と判断するでしょうか。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族は、捨ててよいものでしょうか。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿な親でも、とにかく血みどろになって喧嘩をして敗色が濃くていまにも死にそうになっているのを、黙って見ている息子も異質的ではないでしょうか。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまのソ聯は、どうでしょうか。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまの日本の共産党は、どうでしょうか。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またまた、イデオロギイ小説が、はやるのでしょうか。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おわかりでしょうか。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽を知らない音楽家があるでしょうか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "初版は、五百部ぐらいだったでしょうか。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此樽の中のセメントは何に使われましたでしょうか、私はそれが知りとう御座います。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の恋人は幾樽のセメントになったでしょうか、そしてどんなに方々へ使われるのでしょうか。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはもう少し誰にも分かりやすい言葉で誰の頭にもぴんと響くようなものを捕えて来るのが捷径ではないかという気がしますが如何でしょうか。",
              "citation": {
                "source": "御返事（石原純君へ）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へえ、やっぱり節約からでしょうか。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三代の実朝時代になってもまだそんなふうだったから、この時代の鎌倉の千手の前が都会風の洗練された若い公達に会って参ったのだろうし、多少はそういう公達を恋の目標にすることに自分自身誇りを感じたのじゃないでしょうか」　私はもう一度、何となく手越の里を振返った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを近頃の言葉では何というのでしょうか。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は「作楽井さんは、この頃でも何処かを歩いてらっしゃるでしょうか、こういう寒空にも」　と言って、漂浪者の身の上を想ってみた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、年齢から言ってもだいぶにおなりだったでしょうからな」「はあ、生きておれば七十を越えますが、一昨年歿くなりました。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも人間はそんなものでしょうか」　と、言った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは向う側から入って来る猿ヶ石川とこちらの水がぶっつかるためにできるのか、それとも少し上流がかなりけわしい瀬になってそれがこの泥岩層の岸にぶっつかって戻るためにできるのか、それとも全くほかの原因によるのでしょうか、とにかく日によって水が潮のように差し退きするときがあるのです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だって夏海岸へ遊びに行きたいと思わない人があるでしょうか。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風だって一体吹いていたのでしょうか。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜べには通例大きい砂も細かい砂もあるが、たいてい大きいのは大きいの、細かいのは細かいのと類をもって集まっているのは、考えてみると不思議ではないでしょうか。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "波が砂をかきまぜているのに、どうして一様に交じらないでしょうか。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は自分を見るや泣き声を絞って、何だってもう浮いていたんですものどうしてえいやらわからないけれど、隣の人が藁火であたためなければっていうもんですから、これで生き返るでしょうか……。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "）今度おかきになるものには顔のがお入用なのではないでしょうか。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうではないでしょうか。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
