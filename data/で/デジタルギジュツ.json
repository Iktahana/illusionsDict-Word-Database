        "examples": {
          "standard": [
            {
              "text": "最新のデジタル技術は、医療分野に革命をもたらしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この会社の製品は、独自のデジタル技術を駆使して開発されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "デジタル技術の進歩は、私たちの生活をより豊かにするだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "デジタル技術を経験してこなかった松本にとって、ＩＣ電卓のジャンクは格好の練習台だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アナログ一本でここまで来た自分がコンピューターを支えるデジタル技術を消化しないうちに、半導体産業は、指先の及ばない集積回路の中にＣＰＵを閉じ込めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事も一から理解できなければ満足できない自分が、セラミックパッケージの鎧を突き抜けて、デジタル技術の粋を集めたマイクロコンピューターを理解できるものなのか、松本には自信よりも不安が大きかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがマイクロコンピューターも所詮はデジタル技術の産物にすぎないことは、リセット端子の存在が雄弁に物語っているのではないか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
