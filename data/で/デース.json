        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「レデース・ファースト」と云うのであった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "えゝと、レデース　アンヂェントルメン、諸君の忠告によって僕は退場します。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "レデース・フィンガー。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシアの哲学者ヘラクレイデース常に一蛇を愛養し、臨終に一友に嘱してその屍を隠し、代りにかの蛇を牀上に置き、ヘラクレイデースが明らかに神の仲間に入った証と言わしめたと伝うるもやや似て居るが、張衡が何のために鵠の足を崖頂に縻いだものか。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりペルセウス灰色髪女を訪い、そのただ一つある歯と眼を奪い、迫って三醜女怪方への道を聞き取り、また翅ある草履と、魔法袋と冥界王ハデースの兜を得、これを冒ると自分全体が他人に見えなくなる。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて、弁士エウチアスに重罪犯として訴えられた時、その情夫の一人で大雄弁家なるフペリデースに弁護されしもややもすれば負けそうだった。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "男「アハヽヽ、このツーレデースは、パアトナア計りお好で僕なんぞとおどっては夜会に来たようなお心持があそばさぬというのだから」女「うそ。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもし生れゝば、出來るだけ早くハイデースの門を過ぎ、厚い大地の衣の下に横はるに若くはない」　どう云ふ聯想か、私は北の果の森林の中で、しかも耳の破れるやうな雷鳴の中に、ブチアーの中のデスペラアトな一章を思ひ出した。",
              "citation": {
                "source": "摩周湖紀行",
                "author": "――北海道の旅より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "このツー、レデースは。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五　ヂオメーデースの戰功。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六　敵將グローコスとヂオメーデースとの會見。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二十五日）　第十　ヂオメーデースとオヂュッシュースとの夜間の進撃、敵の間諜ドローンを屠る（二十五日夜より二十六日迄）。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヂオメーデース及びオヂュッシュースの負傷。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔人〕※アガメムノーン（アートリュウスの子＝アートレーデース）アカイア聯合軍の總大將。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "※メネラーオス（同、アートリュウスの子＝アートレーデース）前者の弟、もとヘレネーの夫、スパルテーの領主。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "※アキリュウス（アキルリュウス）、ペーリュウスの子（ペーレーデース）、母は神女テチス、聯合軍第一の猛將。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "※アイアース（テラモンの子＝テラモニデース）第二の猛將。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "※ヂオメーデース（チュウヂュウスの子＝チュウデーデース）前者と伯仲の勇將。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "アートレーデースをアートレ，デース、メネラーオスをメネラオスとしたのは他の例である。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "プリニーは、叙事詩人エピメニデースが或夏の日に、洞窟中に眠りしまま、五十七年の間目覚めざりしと云う説話を記す。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "1　詩神ムーサ（複ムーサイ）1　ペーレーデースとはペーリュウスの子の意。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "3　冥府の王アイデース或はハイデース、いつもペルソーナとして冥府を見る。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "6　アートレーデースを縮む。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "，は省略の記號、以下皆同樣、アートレーデースはアトリュウス（又アートリユウス）の子の意、アトレーデースとも他の詩歌には發音す。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホメーロスの詩に於ては必ずアートレーデース。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
