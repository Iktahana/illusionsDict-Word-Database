[
  {
    "uuid": "70384675-8f27-5f47-85b3-82d267aa3438",
    "entry": "殿中",
    "reading": {
      "primary": "でんちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
