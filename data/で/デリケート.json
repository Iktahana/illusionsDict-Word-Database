    "definitions": [
      {
        "index": 1,
        "gloss": "sensitive (person, heart, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし彼の精神生活は、反対に極めてデリケートで贅沢だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔雀のように派手なシアーレが展げてある向う側の女物屋のショーウィンドウの前へ横町からシルクハットを冠ったニグロの青年と、絹糸のようにデリケートな巴里の女が腕をからんで現われた。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにちょっとデリケートな問題が起る。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し進んだのになると、鼻や小鼻の曲線のあるデリケートな抑揚をつかまえて、これを少しアクセンチュエートする事によって効果を挙げ、あるいは手足の機微な位置によって複雑な感情を暗示するものもある。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ここにこのデリケートな問題を論じる事は困難であり、また論じようと思わない。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう六かしい問題は別として、現在日本の画界における両つの分派の作品を対照した時に感ずるあるデリケートな差別の裏面には、両派の画家の本来の素質のみならず、画家の日常生活における精神的栄養の摂取し方の差違が隠れているのではないかと疑われる。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん仕上げにかかっては、その微細な観察とデリケートな絵具の使い方に驚かされた。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道を歩く時にも、手を一つ動かす時にも、物を飲食する時にも、考えごとをする時にも、着物の柄を選ぶ時にも、常に町の空気と調和し、周囲との対比や均斉を失わないよう、デリケートな注意をせねばならない。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "また西欧人のように感情がデリケートでないためである。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下室の踊場では、タキシードの男と、夜会服から黄色い腕をだした踊子とが胸と胸の国境をデリケートな交錯で色どりながら踊った。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその時考えた事はここに書くにはあまりに複雑でそしてデリケートな、そして纏りのつきかねるものであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう仕事をしている画家と、非常にデリケートな物理の実験をやって敏感なねじをいじってはめがねをのぞいている学者と全く兄弟分のような気がしておもしろくなって来た、そしてどういうわけか急におかしくなって笑い出すとＴ君もいっしょに笑い出してしまった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには多年の修練によるデリケートな神経と筋肉の作用を要する。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、もっとデリケートな調節器官が入用であって、その大切な役目を務めるのが弓を持った演奏者の手首であるらしい。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、右は大体の原理で、実際の現実というものは、もっとデリケートな使い分けをしなくてはならないものでありましょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "喰べた人の細胞の隅々まで浸み入るデリケートな執拗な滋味である。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも自由詩にはより複雜な、よりデリケートのリズムがある。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに芸術家の詩人にあっては、智慧がいつも背後におり、デリケートなるアポロ的静観者が見ている為、観念が行動の方に爆発しないで、表現の認識の方に移って行く。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら詩の骨骼たる外形律が、既に単調を感じさせる場合に於て、内部的なデリケートな繊維律は、何等の能力をも有し得ないから。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其所にあなたの作物には、他に発見する事の出来ないデリケートな美くしさが伏在しているのでしょう。",
              "citation": {
                "source": "木下杢太郎著『唐草表紙』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "本能そのもののようにデリケートで、しかし根強い力で動くかの女の無批判な行動を、逸作はふだんから好奇の眼で眺め、なるべく妨げないようにしていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日本人は実に季節の自然を何ものにも取り入れることがうまい」　逸作はまた彼の友が、Ｋ・Ｓ氏はさすがに芸術家だけあって、西洋人にしては味覚や嗅覚がデリケートなことに感心していたと告げた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "デリケートな顔立ちのつくりに似合う浅い頭髪のウェーブ、しなやかな肩に質のこまかな縮緬の着物と羽織を調和させ、細く長めに曳いた眉をやや昂げて嬌然として居るＸ夫人――だが、葉子はＸ夫人のつい先日迄を知って居た。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからすこしつき合って居るうちに、部厚なこっくりしたＫ氏の体格のどこかに落ちつきくさったそして非常にデリケートな神経が根を保っている。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでその爺さんがおかあさんの武者振りには他には類の無い裏にデリケートな処がある。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "デリケートな裏の方が本当で、表の武威がむしろ借り物なのだ。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子よりしっかりした自分のこころなんか、デリケートな京子に打ちつける気もしなかった。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "デリケートなところでは唇がふるえたり、眼尻に漣が流れたり、眉がそっと近寄ったりします。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ程さようにデリケートな、そして或る一面から見れば暗い感じを持った鼻の表現で、時勢が進むに連れまして生存競争に打ち勝とうとするものは何人も是非共この表現の方法を一応は心得ていなければならぬものだそうでございます。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとデリケートであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
