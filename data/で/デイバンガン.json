          "standard": [
            {
              "text": "地層からは、特徴的な泥板岩が多数発見された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "泥板岩は、水に濡れると崩れやすい性質がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この地域で採掘される泥板岩は、建材としても利用されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "あらい泥板岩の上を用心ぶかく進んでゆく私の馬のそばで、キッティが笑ったり、おしゃべりをしたりしている折りから――ちょうど平原のうちに、かのシムラが図書閲覧室やペリティの店の露台に囲まれながら見えてきた折りから――私はずっと遠くのほうで誰かが私の洗礼名を呼んでいるのに気がついた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "人力車は泥板岩の崖の上に差し出ている一本の小松の下にぴたりと止まった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            }
          ]
        }
