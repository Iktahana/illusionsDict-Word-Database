        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やゝ下つて多くの家来達がグデングデンに酔つぱらつてガヤ／＼騒ぎたてて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾があの土地を買収したのも、妾はこの土地にポール商会のビルデングを建てるつもりなのよ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "東株ビルデングの石造の大建築が、人物をザンバのように呑みこんでいた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "割引電車の青い労働帽の炎のような太陽が燃えて、世が明けわたると、半開のビルデングの鎧戸を汚れた袴をはいた女事務員がくぐり、表情の失せた勤め人たちが、破れたわい襯衣から栄養不良の皮膚をのぞかせて鏡のように磨かれた石造の建物に吸いこまれた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はビルデングの窓のカーテンをひらいた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんと立派なビルデングになってるんだぜ。",
              "citation": {
                "source": "ペンネンノルデはいまはいないよ　太陽にできた黒い棘をとりに行ったよ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私はグデングデンに酔っ払ったふりをしながら朦朧タクシーを拾い直して来て、駿河台の坂を徒歩で上って、午前四時キッカリにお茶の水のグリン・アパートに帰り着いた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "よう出来た、よう出来た……」「それでも得心せねばこの刀身の油曇に聞いて見いと言うたれば、眼の玉をデングリ返して言い詰りおった処を、真正面から唐竹割りにタッタ一討ち……」「やや。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "将来、死生を共にしようと言う処まで高潮したので、とにかく今夜は俺の家に来いと言う事になって、グデングデンになっている奴を引っぱって帰ると、出迎えた細君に残りのバラ銭を一掴み投げ与えた。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の背後のはるか彼方に聳ゆるビルデングの一室が、真赤な血の色に染まっているのが、外からハッキリと透かして見える。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "有楽町のプラットホームのベンチに腰をおろして、僕は明滅するビルデングの灯を、涙で見えなくなるまで眺めていた。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "易なんぞというものは感心な奴で、初爻と上爻とが首尾相呼んでぐるぐるとデングリカエシをやッて螺線を描いて六十四｜卦だけにコロガリころがッて実はまだいくらにでもコロガリ出すことが出来るのサ。",
              "citation": {
                "source": "ねじくり博士",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "省線はかなり混んでいたが、彼は乗客を乱暴に掻きわけて、入口から吊皮を、ひいふうみいと大声で数えて十二番目の吊皮につかまり、私にもその吊皮に一緒につかまるように命じ、「立川というのを英語でいうなら、スタンデングリバーでしょう？",
              "citation": {
                "source": "女神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタンデングリバー。",
              "citation": {
                "source": "女神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかといって丸の内に建て増す足場無しに積み上げて行くアメリカ式のビルデングも排斥はしなかった。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "足が重いのは、一週間ばかり寢付いたデング熱がまだ治り切らないせゐでもある。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "デングの四十度の熱に浮かされた時の・數日前の幻覺が、再び瞼の裏に現れさうな氣がする。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "足が重いのは、一週間ばかり寝付いたデング熱がまだ治り切らないせいでもある。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "デングの四十度の熱に浮かされた時の・数日前の幻覚が、再び瞼の裏に現れそうな気がする。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "足が重いのは、一週間ばかり寝付いたデング熱がまだ治り切らないせゐでもある。",
              "citation": {
                "source": "夾竹桃の家の女",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "デングの四十度の熱に浮かされた時の・数日前の幻覚が、再び瞼の裏に現れさうな気がする。",
              "citation": {
                "source": "夾竹桃の家の女",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのビルデングの背中に高く高く突上げられた十坪ほどの灰色の平面から薄光りする雨がスイスイスイと無限に落ちて来る。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはビルデングの奥です。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはビルデングの奥ですよ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "藩閥の犬畜生にでも頭を下げに行かねば遣り切れんようになるものじゃが、そげな時に、あの月と霜に冴え渡った爽快な声を思い出すと、腸がグルグルグルとデングリ返って来る。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼球をばデングリ返いて、鼻汁垂れカブって、涎流っとる面相あドウかいナ』『アハハハ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてどうしてフォーデングブリッジから来た手紙を受け取って、驚きの余り死んでしまったのか？",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その時私は、フォーデングブリッジと云うのはハンプシャイアにあることを思い出した。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "すごい建物だなあなんて高い建物でせうこれは地｜球ホテルといふ　火星一の高いビルデングです○このホテルは　地球からのお客様を迎へるために、わざわざつくつたのですすると僕達が　最初のお客なんですね地球からの第一｜着だすごいぞ面白いわね○さあ　こゝが貴方たちの部屋ですまあ！",
              "citation": {
                "source": "小熊秀雄全集−22",
                "author": "火星探検―漫画台本",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（フフ）（クスクス）○火星では　高い大きなビルデングのやうな望遠鏡で　地｜球の出来ごとをみてゐるのですナニ？",
              "citation": {
                "source": "小熊秀雄全集−22",
                "author": "火星探検―漫画台本",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
