        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新発明の耳喇叭　スウェーデン政府の電話局で近頃発明された耳喇叭は交換手の耳にさし込んで通話をするためのものであるが、これはまた耳の遠い人のためにも重宝なものであるそうな。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画では電話局の故障修繕工夫が主人公になっている。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は気が注いて電話局へ問あわしてみた。",
              "citation": {
                "source": "長崎の電話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五百番は電話局じゃないの。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さんが中央電話局から帰って来ないので、心配だから行ってみたんだよ」「どうだったい……無事だったかい」「ウン。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話局は電源を切られたのにちがいない」　彼は仕方なく駅の方へ行ってみることにした。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んでも革命が起ると一緒に、電話局と電信局とは政府軍と革命軍との争奪の中心点になったらしいのよ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりゃ今夜だって、ここの租界の駐屯兵は一番電話局と電信局とを守っているからね。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "志野は、電話局の事務員であった。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこなら毎日通ってるわ――私、電話局に通ってるのよ、停留場んところの氷屋に間借りして……」　志野はどうせ暇だからと云って、須田の家まで房を送って来た。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話局に新設や付け替えを申し込むと、まず電電公社から元請けに仕事がまわされ、そこから下請けの作業グループに仕事が割り振られる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあといくら電話局に連絡しても、さっきの相手はふたたび出なかった。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お舟は、ダンスホールがお休みになったといって帰って来たけれど、笛坊の方は、まだ電話局から戻ってこないんだよ。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもなら、もう疾くに帰って来てなきゃならないんだがね」「うむ」亀さんは首を傾けて、去年の秋、交換手をしている娘の案内で見に行った東京中央電話局の建物を思いうかべていた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「丁度いま、磯崎の防空監視哨と東京の中央電話局との直通電話を架設して来たばかりだ。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、早く見付けて、伯父さんの拵えたこの電話機でネ、東京に住んでいる人と話をしたいの」「そうか、そうか」「さっき僕と話をした東京の人は、お姉ちゃんだったよ」「電話局の交換手さんだからネ、交換手はお姉ちゃんに極っているのだよ」「そのお姉ちゃんに僕、訊いてみたの。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま電話局で調べさせたんです。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "心配でたまらない勇少年は、電話局に問いあわせると、なんと不思議なことに、青竜王のかけた電話は、やはり竜宮劇場の中のものだった。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠅男はホテルのなかに居るのを知られないために、電話にも奇略をつかったんです」「へえ、どんな奇略を――」「それはホテルの交換台からすぐに帳場をつながないで、一旦部屋から外線につないで貰い、電話局から再び別の電話番号でこのホテルに懸け、一度交換台を経て帳場につないで貰ったんですなア。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば、同じホテル内の部屋にかけたにしろ、電話局まで大廻りして来たから、電話の声がホテル内同士でかけるよりはずっと小さくなったんです。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんさんの命令どおり、すぐ電話局へかけてみて、あんさんの話し相手が今どこから電話をかけているか調べてもろうてな、それから直ぐ署の方へ連絡しましたんや。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝電話局の工夫来り電話機を設置す。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれから電話局へ何遍か問い合せましたが、渋谷駅前の自働電話から、関東新報の編輯局へ掛けたことだけは解りましたが、それ以上はどうしても解らなかったので、到頭今日の朝刊に広告を出す段取になったことは、側で黙って聞いて居る早坂勇も大方知って居ります。",
              "citation": {
                "source": "流行作家の死",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると數日の後に、電話局から手紙が來て、「再度コントロールの結果、貴下の申出が正しく、料金は三百五十フランに訂正致します。",
              "citation": {
                "source": "デモクラシーのいろいろ",
                "author": "笠信太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めルパン等が懸命に品物の運搬をしておる間に、レオナールは余り堅く縛してなかったのを幸い、その縄を解いて電話機の傍まで転がって行って、受話器を口に啣えて床の上に下ろし、それからアンジアンの電話局へ救助を叫んだのだ。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり電話局よ、白いからね、と見ているうちに火はひろがり外へ様子見に行った菅谷君の話では電話局の前の通りで林さんというお医者もやけてしまったらしいとのこと。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお医者はこちらの古馴染でわたしも世話になり、日頃電話局の前だからあぶないものだと云っていましたから気にして居りました、見舞ったら一家無事で何よりでした。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話局の交換手をとおした、ホノルルからの電話だった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを無償で電話局へ返還すると申しでた人があった。",
              "citation": {
                "source": "発端・電話事件",
                "author": "式場隆三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
