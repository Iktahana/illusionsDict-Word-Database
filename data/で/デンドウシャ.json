[
  {
    "uuid": "3e2a25b1-e1eb-560e-9101-00e66814bdd7",
    "entry": "伝道者",
    "reading": {
      "primary": "でんどうしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
