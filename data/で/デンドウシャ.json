    },
    "definitions": [
      {
        "index": 1,
        "gloss": "evangelist",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これ等はこの島に隠れる事二十六年、熱心な伝道者であったが、嘗つては益田好次同様豊臣の恩顧を受けた者である。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の伝道者や殉教者や立教者や奉道者が、世俗から云えば堪えられない困難・凌辱・痛楚・悲哀等に堪えて、屈せず弛まず一気緊張して、一条のレールのような立派な生涯を遂げた根本のものは、多くは実に我と我が信との一致の自覚に因るのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "内田は熱心なキリスト教の伝道者として、憎む人からは蛇蝎のように憎まれるし、好きな人からは予言者のように崇拝されている天才｜肌の人だった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "破鐘のような大きな声と悲しい沈んだ声とで互いに夏期学校の講壇に立って、一方を旧約のイザヤに擬するものがあれば、一方をエレミヤに擬するものがある、声望から経歴から相対立した関西の組合教会の二人の伝道者が通った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから伝道者として世に立とうと思ってます。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年一日のように単純な信仰を守っている真勢さんは大勝の帳場で頭も挙らなかったし、伝道者をもって任ずる玉木さんのような人は夫婦して小父さんの家に食客同様の日を送った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "捨吉が幼い心の底にある神とは、多くの牧師や伝道者によって説かるる父と子と精霊の三位を一体としたようなものでは無かった。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "救世軍の伝道者のように辻に立って叫ぶか。",
              "citation": {
                "source": "余興",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、彼女はそれ等の凡てに打ち克ち、知名の伝道者として、何処までもその不屈の精神と絶倫の精力と多くの人の持つことの出来ない勇気をもつて、絶えず困難な彼女の仕事を続けてゐるのだ。",
              "citation": {
                "source": "乞食の名誉",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "露西亜語の研究につれて、若いエンマもまた革命思想の伝道者とその新思想に接近した。",
              "citation": {
                "source": "乞食の名誉",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に、更に彼女を自覚した伝道者につくり上げる多くの都合のいゝ局面が彼女の前に展開されるのだ。",
              "citation": {
                "source": "乞食の名誉",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくこれが、あの四人に関する唯一の資料と云ってもいいだろうと思うよ」そして取り上げたのは、一九〇一年二月号の「ハートフォード福音伝道者」誌で、それが卓上に残った最後だった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝道者と云ってもよいかも知れない」「妾ちっとも恐くないわ。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい校長Ｍ女史は深く物を考へる学者型の人で、決して伝道者型ではなかつた。",
              "citation": {
                "source": "Ｌ氏殺人事件",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富豪とその哀れむべき犠牲者と、律法と威権の維持者と不幸なる犯罪者と、自由思想家と虚偽なる宗教伝道者と、流行界にときめく淑女と襤褸をまとふ工女と皆な等しく社会主義者である。",
              "citation": {
                "source": "少数と多数",
                "author": "エンマ・ゴルドマン",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は若い修道司祭だ、伝道者だ。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことはおばをして結婚をあきらめさせ、一生をキリスト伝道者として送ろうと決心させ、ひいては後年ユーカラの筆録に余生をささげるようなめぐりあわせに導いた動機となった。",
              "citation": {
                "source": "おば金成マツのこと",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそのころにこの寺は熱狂的伝道者行基を出している。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またかかる人々を訪問して聖書の真理を解き明かすことは、伝道者の重要な仕事であろう。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "バプテスマのヨハネが捕えられるまでは、イエスは背後におられ、伝道者として公然世間に顔出しをされなかった。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "種を播くのは伝道者の任務ですが、育て給うのは神様です。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけが伝道者の仕事です。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはすなわち君が信徒として、また一種の伝道者として、ばてれん同様重んぜらるべき者であると認めるからじゃ。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはつまり君が信者として又一種の伝道者として、ばてれん同様に重んぜらるべき者であると認めるからぢや。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "福音の伝道者のように、彼女は亢奮を覚えた。",
              "citation": {
                "source": "加護",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カリフォルニアが、まだ闘牛士の王の支配の下にあった時分、遠いスペインから、多数の伝道者が渡来した。",
              "citation": {
                "source": "南路",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、それを見て、マリアの光栄に限りなし、と讚えた伝道者の心情も、愛すべきものではないか。",
              "citation": {
                "source": "南路",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色い髪をフサフサとたらし、半ば坊さんのような服装をした男は、砂浜の説教者としてばかりでなく、現代の世界にくまなき伝道者としてよく知られていた。",
              "citation": {
                "source": "手早い奴",
                "author": "THE QUICK ONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "無神論者、悪の伝道者、物質論者をも、その中の善良な者のみではなく、邪悪な者をすらも憎んではなりません。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ纔かに人間としてまた伝道者として知られていた関係で、一部の人に最も深い感銘を与えたという程度であった。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
