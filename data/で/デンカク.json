        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "首を昂ぐれば即ち殿閣｜斉しく呑み、腰を伸ばせば則ち楼垣尽く覆る。",
              "citation": {
                "source": "蓮花公主",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "薫風｜南より来って、殿閣｜微涼を生ず。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは殿閣の絵であったが寺に似ていた。",
              "citation": {
                "source": "促織",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "さながら、殿閣の王者みたいであった。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥殿と中殿とのあいだを渡してある唐橋の欄に立って望むと、無数の舞扇を重ねたような天守閣の五層の廂と、楼門の殿閣の大廂とは、見事な曲線を宙に交錯させている。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、天守閣、白堊の御宝蔵、西丸、山吹丸、出丸廓などの狭間が高く見えるほかは、諸門殿閣、みな樹林の底に埋ずまって、その上は模糊たる冬霞のうっすらと流れているのが、どうしても此処が江戸市街の中とは思えぬ程であります。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここには、旧い宮門殿閣があるし、城下の町々も備わっている。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "呂布はなおさら烈火の如くになって、殿閣の梁も震動するかとばかり吼えた。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　本国に帰ってからの袁紹は、冀州城内の殿閣にふかくこもって、怏憂、煩憂の日を送っていた。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
