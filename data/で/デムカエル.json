    "definitions": [
      {
        "index": 1,
        "gloss": "to meet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やっと車の音が玄関へ飛び込んで来ると思うと番頭や女中の出迎える物音がしてそうして急に世の中が賑やかに明るくなった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年の姿を見ると目出度いと言って急いで羽織袴で恭しく出迎えるような商家の主人もあった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあー」とお光をかえり見て、Ｔ「お光ちゃん　仲蔵さんよ」　「まあ、仲蔵さん」とお光いそいそと出迎える。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年の姿を見ると目出度いと言って急いで羽織｜袴で恭しく出迎えるような商家の主人もあった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小高い丘の木立の中に、森閑と雨戸を鎖した兇行の家……深良屋敷を離れた草川巡査は、もうグッタリと疲れながら、町から到着した判検事の一行を出迎えるべく、佩剣の柄を押え押え国道の方へ走り降りて行った。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "格子戸を憚って、台所の暗がりへ入ると、二階は常ならぬ声高で、お源の出迎える気勢もない。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も出迎える者がないので、真直ぐに歩いて、つき当って、右へ行こうか左へ行こうかと考えていると、やっとのことで、給仕らしい男のうろついているのに、出合った。",
              "citation": {
                "source": "普請中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　瑠璃子が、出迎えると、その男は妙な薄笑いをしながら、言葉｜丈はいやに、鄭重だった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "声もかけずに、無断で人の庭先までも押し入るとは、ふらちなやつと思いましたが、同役同僚とはいうものの、とにもかくにも先輩でしたから、何ご用かと名人みずから立ち上がって縁側まで出迎えると、こやつ、よくよく生まれながらのかたき役でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の入口では子供が出迎える。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、夕刻帰宅すると玄関へ出迎える細君へ向って大喝一声するのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "附記",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して停車場の構内には彼を出迎える子供等の影さえも見えなかった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに往復とも中宿りの接待が設けられてあり、大臣もお帰りの時は宇治まで出迎えることになっていたが、謹慎日がにわかにめぐり合わせて来て、しかも重く慎まねばならぬことを陰陽師から告げられたために、自身で伺えないことのお詫びの挨拶を持って代理が京から来た。",
              "citation": {
                "source": "源氏物語",
                "author": "椎が本",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから数日すぎて、龍子が外から帰って来ると、いつも走り出迎える寿女の姿が見えない。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお光は急いで店先へ出迎える。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――千枝子はそれを出迎えるために、朝から家を出て行ったが、君も知っている通り、あの界隈は場所がらだけに、昼でも滅多に人通りがない。",
              "citation": {
                "source": "妙な話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑛子は、永年の習慣で、朝は何かのはずみで送り出すことはあっても、帰って来た時玄関まで行って良人を出迎えるということは殆どしないのであった。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときは勇吉を出迎えるというだけで心がいっぱいで、こんなにあっけなく別れたあと、あまった一日のつかいみちに困ろうなどとは念頭に浮んで来なかった。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関に、夫を出迎える召使の声を聞いて、縫物を、押入れへ入れて、廊下へ出ようとすると、もう其処に、夫の姿があった。",
              "citation": {
                "source": "寛永武道鑑",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野駅へは冬子が出迎える筈だった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅には日本の大使館からお迎えの自動車が私を待っていましたが、ロシア人は外国人を駅に出迎えるとスパイに間違えられるので、私の出迎えは芸術の係の人達と私の通訳の婦人だけでした。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "格子が開いて、玄関に、膝をついて出迎える女中たち。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（間）とにかく玄関まで出迎えることにしよう。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私とＡ東京駅まで出迎える。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから花束を買いに出かけたところ、大してよくもないグラジオラスしかないので35Ｆの束をつくらせ、department store へ入って何かもって出迎えるおもちゃをさがした。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校から戻ったばかりの澄子が、袴姿のまま出迎えると、彼は雫の垂れる帽子を打振って水を切りながら、足が汚れてるから雑巾を下さいと云った。",
              "citation": {
                "source": "変な男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も出迎える者がない……よかった、と思うとたんに、女中が立ってくる気配がした。",
              "citation": {
                "source": "童貞",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　玄関に出迎える筈なのを、敏子は坐ったまま、冷い一瞥で彼を迎えた。",
              "citation": {
                "source": "裸木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お帰りなさいましと、出迎える顔にも暗いかげがさしている。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉左衛門なり金兵衛なりは他の宿役人を誘い合わせ、羽織に無刀、扇子をさして、西の宿境までそれらの一行をうやうやしく出迎える。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
