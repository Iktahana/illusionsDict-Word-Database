    "definitions": [
      {
        "index": 1,
        "gloss": "missionary work (esp. Buddhist)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三人同じく夢む、夢に蒋侯、其の伝教を遣はして使者の趣を白さす。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では平安朝の伝教大師の日本天台、弘法大師の真言密教をはじめ、鎌倉期になって法然、親鸞、日蓮、道元らの諸祖の新興仏教の出たのもこのためであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと前の平安朝時代から伝統が続いて来ている伝教大師の天台宗、弘法大師の真言密教は、さとりの修業と信仰の安心立命と兼用であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "太子さまの、この現実理想化の大乗精神は、後世、心ある仏教家たちの渇仰するところとなりまして、中にも平安朝の伝教大師は、太子さまの御精神を師教と仰ぎ奉り、御廟前に加護を祈りました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に平安朝に興った二大新仏教は、伝教大師の日本天台、弘法大師の真言密教であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝教大師が支那へ留学して持ち帰られた仏教は、支那天台宗の外に禅宗、密教、律宗もありました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして伝教大師は、この戒壇には日本国民残らず全部を登壇授戒せしめて、一挙に民族精神の作興を企図されたのですが、南都の旧套仏教家の妨害に遭って、生前にはその官許を得られませんでしたが、死後、比叡山にこの授戒は行われたのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝教大師と対立的に時代の仏教を開創せられた弘法大師も、国民の現実生活に留意せられたことは同じであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝教大師の円頓戒に当るものは、弘法大師に在っては灌頂でありまして、この儀式を通して人々に人格完成の希望を喚起せしめ、かつ自覚に便利な宗教的な合言葉を与えて口に唱えしめ、以て現実生活に就かしめるのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし弘法大師における灌頂は、伝教大師における戒壇ほど主力なものではなくて、弘法大師の得意とするところは、あらゆる真、善、美、の形式をまず人々に与えて、理想の匂いを感覚より浸み込ませ、現実に含める理想の価値をところを換えず即座に見出させようとする教法であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝説には此人一乗要訣を撰した時には、馬鳴菩薩竜樹菩薩が現われて摩頂｜讃歎し、伝教大師は合掌して、我山の教法は今汝に属すと告げられたと夢みたということである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈迦牟尼は畢竟愚人、苦労性なる摩訶陀の王子、天台智者は大法螺吹、まつた伝教は山師の支店。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（演説の調にて）法相｜真如といふと雖も之れ仏陀乃至伝教等沙門の頭を写したる幻の塔、夢の伽藍、どうせ人の頭より出たるほどのもの故、学んで悟られぬ筈はおりない。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天台乃至伝教はわが胸中のこの宝を盗みたる、いはば物取強盗ぢや。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば、桓武天皇は、仏教の改革に御心を用ゐられてゐたが、あたかもよし、この時代に空海（弘法大師）最澄（伝教大師）の二傑僧が現はれ、仏教自身、その宿弊を一掃した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢に蒋侯、その伝教を遣わして使者の趣を白さす。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "灸点の法を、その以心伝教で会得した。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『論衡』に雷が樹を打ち折るを漢代の俗天が竜を取るといったと見え、『法顕伝』に毒竜雪を起す、慈覚大師『入唐求法記』に、竜闘って雹を降らす、『歴代皇紀』に、伝教入唐出立の際暴風大雨し諸人悲しんだから、自分所持の舎利を竜衆に施すとたちまち息んだと出づ。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "『嬉遊笑覧』に『遠碧軒随筆』を引いて、庚申の三猿はもと天台大師三大部の中、止観の空仮中の三諦を、不見、不聴、不言に比したるを猿に表して伝教大師三猿を創めたという。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同例で庚申の三猿も伝教の創作じゃなかろう。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて日吉に二十一社ありて仏神の混合甚だしく、記録に牽強多くて事歴の真相知れがたきも、大体を稽うるに、伝教大師この社を延暦寺に結び付けた遥か以前に、二の宮この山の地主と斎かれた。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "当山の開祖｜伝教大師の遺骨を納めてあるという浄土院へゆく路と四明ヶ嶽へ行く路との分れ目の所に一軒の茶店のあるのが眼についた。",
              "citation": {
                "source": "青年僧と叡山の老爺",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一｜隅を照らすものを国宝となす」と伝教大師はいっていますが、この国宝こそ、今日最も要求されているのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿耨多羅三藐三菩提の仏たちわが立つ杣に冥加あらせたまへ　（伝教）　いとめでたき歌にて候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "失敗した宣伝教育の自己批判を通して、彼の口惜しさ、悲しみが読者の胸に浸み込むような真実さで手紙は書かれていない。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」わが伝教大師の作と考えられた『末法燈明記』もこの説を採っており、『教信行証』に引用されているところである。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は「愚が中の極愚、狂が中の極狂、塵禿の有情、低下の最澄」といった伝教大師の言葉に深い共鳴を感じた。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿耨多羅三藐三菩提の仏たちわが立つ杣に冥加あらせたまへ（伝教）　いとめでたき歌にて候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "定雄は歩きながらも、伝教大師が都に近いこの地に本拠を定めて高野山の弘法と対立したのは、伝教の負けだとふと思った。",
              "citation": {
                "source": "比叡",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
