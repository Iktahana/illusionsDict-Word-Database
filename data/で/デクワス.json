    "definitions": [
      {
        "index": 1,
        "gloss": "to happen to meet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "論理の糸を手繰って闇黒な想像の迷路を彷徨しているうちにどこかで新しい出口を見付け、そこで事実の日光にまともに出くわすまでは何事も主張する権利はない事を心得ていなければならない。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その問題は型式的には刑事探偵が偶には出くわす問題とおなじようなものかと思われた。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだとすると、まだ自分の知らない自分がどこかを歩いていていつひょっくり出くわすか分らないような気がする。",
              "citation": {
                "source": "断片（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "萌黄の背広に萌黄の柔らかい帽子を着たこういう男にたいていな所で出くわすのは不思議なくらいです。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "会いたくないと思ってつとめて避けている人に偶然出くわすような気がしばしばした。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう箇所に出くわすと自分はほっとして救われた気がするのであるが、多くの日本映画には、こうした気のする場面がはじめからおしまいまで一つもないのは決して珍しくないのである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「好く古本屋で出くわすじゃないか」と云うような事を、どっちからか言い出したのが、親しげに物を言った始である。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして出くわす度毎に、二人は互ひに一間ほど離れてから返り見合つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がつかずにいたが、毎度風呂の中で出くわす男で、石鹸を女湯の方から貰って使うのがあって、僕はいつも厭な、にやけた奴だと思っていた。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫く進むと、※々たる熔岩の崖に出くわす。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お婆さんが、お巡査さんに言ったとは、夢にも知らない私達は、ある朝、お婆さんに出くわすと、いつもの吉公が、「さあ、今日も鉄砲丸を買わなきゃならないぞ。",
              "citation": {
                "source": "納豆合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年盛夏のころにはしばしば出くわす光景である。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "注意深い者なら、綿密で体系的な調査をもってすれば、出くわすあらゆるものからおびただしいことが知りうるという。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして厩舎の戸を開け放したままシンプソンは荒野の方へ馬を連れ出していたが、途中で調教師に出くわすか追いつかれるかした。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして力も　とうとう尽きたときふと出くわす、さすらう影――　「影よ」と問う　「どこにあるというのか――この黄金郷なる地は？",
              "citation": {
                "source": "ポオ異界詩集",
                "author": "エドガー・Ａ・ポオ　Edger A. Poe",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時に好く、長い髪を項まで分けた榛野に出くわす。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "早いとこ出発しないと、晩メシまでに帰れなくなる」　県道には路線バスが走っているが、バス停までは一本道で、その途上や停留所で、教師に出くわす危険性が高い。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "また耳取り喧嘩というのは、この神が村回りをしているときに偶然二頭が出くわすと喧嘩を始めてそんなことを仕出かすと称される。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものを曳くというほうのことを考えてみても、あるいは甚だおもしろい俗信に出くわすことかもしれぬ。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の風呂にはいる、冬村君に出くわす、天満宮へ詣るといふ、嫌になつて※々帰庵。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "途上で暮羊君に出くわす、午後、同君がビールやら何やら持ちこんで来て、ＩさんＪさんもやつて来て、愉快に飲む語る。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶然こういう言葉に出くわす。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつぞや途上で話し合つた若い大黒さんと同宿になつた、世の中は広いやうでも狭い、またどこかで出くわすことだらう、彼には愛すべきものが残つてゐる、彼は浪花節屋なのだ、同宿者の需めに応じて一席どなつた、芸題はジゴマのお清！",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、「パーソナルコンピューターの革命的な進歩」などという一文に出くわすと、思わず首をひねりたくなってしまいます。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の家ではわれわれから見れば無用の重複と思われるものにしばしば出くわすことがある。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "この生ぐさきニヒリストは腹がなおると、じき腹がへるし、いい風景を見ると呆然としてしまうし、良い人間に出くわすと涙を感じるし、困った奴なり。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此生ぐさニヒリストは、腹がなおると、じき腹がへるし、いゝ風景を見ると、呆然としてしまうし、良い人間に出くわすと、涙を感じるし――。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらは上へ登ろうとする階子口で一旦降りて来た藤塚さんに出くわす――やあ――今後姿を見たのよ――大丈夫ですか、急に動かれん方がいいじゃないですか――髪をかって来ただけ　藤塚さんこの間病院でとった写真もって来てくれた。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫茶店や何かで、いい音色に出くわすと、彼は堪らなく落ちつきなく、耳にはいる音の流れを追っているのです。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶然そんななつかしい人と出くわすのは、たのしい気持でした。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
