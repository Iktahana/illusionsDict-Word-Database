        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "汝、その、胸を開けて、出来立ての乳首を見せろ、という難題だって、往生しねえじゃならねえわ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "搗てて加えて渠らは貴族という条、マダ出来立ての成上りであった。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "………連載一回分（二千字前後）欠………堕落し立てのホヤホヤ記者の友人甲「女なら今の東京だね」記者の友人乙「どうして」甲「どうしてだって、東京の職業婦人はまだ出来立てのホヤホヤだろう。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「亭主、麦熬しでもできるかい」「はい、出来立ての熬しがございます。",
              "citation": {
                "source": "小壺狩",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜平は子供の頃から出来立ての熬しのにほひを嗅ぐのが何よりも好きでした。",
              "citation": {
                "source": "小壺狩",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大浦の天主堂を見た眼では、明るく出来立てで大きく、どこかに東本願寺というような感がしなくもない。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来立ての信号ですから使い古されていないで愉快です。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "へへん、出来立ては、喧嘩のあとで環が鳴りって、とかく、痴話喧嘩と申すものは、仲がよいと、始まりやす。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄か紳士風の出来立ての町の方が私にはよつぽど似合ふわ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっと取り出して顕微鏡で覗いて見ると、この出来立ての雪は天然の雪よりも一層の見事さである。",
              "citation": {
                "source": "雪を作る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに精選した原料を用いてあっても、蒸し返しや造り直しでは味が死んでしまっていて、出来立ての品とは較べものにならぬ。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして一方は世界史的に承認された宗教であるに反して、他方はまだ出来立ての成り上り宗教に過ぎないから、というだけでもない。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来立てのほやほやだ」　彼は顔色を変えて鉄のように青くなり目を※って言った。",
              "citation": {
                "source": "狂人日記",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは産褥の枕辺に坐って、出来立ての人間の子をしげしげ覗いた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、セリフの出来立てのを、而も二枚三枚と長いのを、それ覚えろと、すぐやられるのは困る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やはり本はいいな」　できたての『パソコン創世記』を開いて、私はあらためてそう感じました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう一日分のできたてをみんな買い占めてやったんでね、ないしょに二つまけてくれましたぜ」「はしたないことをいうな！",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "できたてのホヤホヤだぜ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご覧のとおり、この名刺はできたての物とは違って、長い間紙入れか何かの中に入れられていたような状態を呈していますから、たぶん大村氏自身が作られた名刺だと考えるのが至当だと思います。",
              "citation": {
                "source": "墓地の殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "できたてのアイスクリームのやうだ」葛子はさう言ひながら、志緒乃の背中にちよつと頬を押しあてた。",
              "citation": {
                "source": "木々の精、谷の精",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんしろ、お前、キンタマを小さくちぢめて腹の中へおさめてから、おもむろに立ち合いができたてえ人物だからな。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "味噌のできたてはナマナマしく濃いので、私には田舎味噌のほうがよく、それのみを用いている。",
              "citation": {
                "source": "三州仕立て小蕪汁",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじいさんは、しばらくして、かごを引き上げると、その中には、できたてのやわらかなパンがはいっていました。",
              "citation": {
                "source": "夏とおじいさん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都では幕府政治総裁松平｜春岳は――この前年できたての改良派ブロックの幕府統御官は――宿を焼かれて国許へ逃亡し、将軍も帰東したいのだが、償金支払処置をつけてあぶなく英幕危機を脱した小笠原｜図書頭が率兵して大阪に急行するまでは、帰東することができない有様だった。",
              "citation": {
                "source": "尊攘戦略史",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやできたてじゃありません」と主人がまた云った。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あなたは、できたての自作の舞踏曲を、酒場のぼろピアノが軋むほどに熱い息吹きで奏きたてる。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これぞ、早耳早学問、いまできたてのホヤホヤという瓦版が一枚三文とは安過ぎる！",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰ってからそっと開けてみると、小判で三両、ほかにお初さんの分が一分――山吹色のできたての小判だぜ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "遠眼鏡の殿様",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつはあたふたと床を横切り、そばにあったできたての穴へと逃げ込んだ。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪解けの水にぬれたむかい屋根の雨樋にモスクワの雀がとまって、熱心に、逞しい馬の後脚の間に落ちたできたての、湯気のでる餌をみはった。",
              "citation": {
                "source": "モスクワ印象記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
