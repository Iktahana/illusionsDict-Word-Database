    "definitions": [
      {
        "index": 1,
        "gloss": "unable to resist",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……背後から追掛けて來るやうで成らないんですもの。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、デウス右近とまで成らない、彼がほんとのクリスチャンにならない辺で終ってます。",
              "citation": {
                "source": "小説のタネ",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局こんな、不得要領の原稿が出來て、Ｎさんには、お氣の毒でならない。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "線香を立てて死人扱いをするのがかあいそうでならないけれど、線香を立てないのも無情のように思われて、線香は立てた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えると何もかも届かないことばかりで、それが残念でならない。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "政夫さん、私はお民さんが可哀相で可哀相でならないだよ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいよいよ斎藤のおッ母さんに意見をして貰うということに相談が極り、それで家のお母さんが民子に幾度意見をしても泣いてばかり承知しないから、とどのつまり、お前がそう剛情はるのも政夫の処へきたい考えからだろうけれど、それはこの母が不承知でならないよ、お前はそれでも今度の縁談が不承知か。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えばそれが愍然でならない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この點だけでも、どうも室生といふ男は不思議でならない。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ弟の身の上は、心から可哀相でならない。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、一つは自分自身の爲めの感情、一つはお前の爲めの感情、その何れが必然でならないかはだんだんに私の頭に明かになつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその時の弟が可哀相でならない。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね――義兄さん、……お可哀相は、最う疾くのむかし通越して、あんな綺麗な方が最うおなくなんなさるかと思ふと、真個に可惜ものでならないんですもの。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれがかわいそうでならないから何かやって助けてやろうと思うけれども、第一私はここに立ったっきり歩く事ができない。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今となりましてわたくしは、人の世の男と女がどうしてあの程度の愛で満足出来て居るか、不思議でならないので御座います。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の頂上へ円髷をちょんと乗せた罪の無いお鹿の女房が、寂寞した中へお客だから、喜んで莞爾々々するのさえ、どうやら意見でもしそうでならない。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし本統に心配でならないから云ふのよ。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "「可哀相でならないから、委しく、いろんな話を聞いてみたいけれど、そんな、悠長な間はないんだもの。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あえて世間をどうしようなぞという野心は無さそうに見えたのに――　お供の、奴の腰巾着然とした件の革鞄の方が、物騒でならないのであった。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし原の秋篠なども芝居になりそうでならない。",
              "citation": {
                "source": "かたき討雑感",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時女が可哀相でならないのだ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それにしても、私はどうも気の毒でならないのだ。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "然うするとまた、薄氣味の惡い事ばかりが、心に浮んでならない。",
              "citation": {
                "source": "水郷",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と不思議でならない。",
              "citation": {
                "source": "水郷",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりはまだ、此樣な處で、白髮の老人に逢つたのが、更に不思議でならない。",
              "citation": {
                "source": "水郷",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "末弟には、それが不満でならない。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母は、さっきから勉強室にひとり閉じこもっている末弟を、可哀そうでならない。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "数枝、あたしは栄一よりも、お前と睦子がふびんでならない。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は不思議でならないのだ。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "川端康成の、さりげなさそうに装って、装い切れなかった嘘が、残念でならないのだ。",
              "citation": {
                "source": "川端康成へ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
