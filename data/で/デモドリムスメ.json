    "definitions": [
      {
        "index": 1,
        "gloss": "daughter who moves back to her parents after divorcing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
