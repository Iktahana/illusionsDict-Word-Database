      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(police) detective",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "競馬であてて喜び極まったところを刑事につかまったのが可哀相な浅岡である。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑事がここまで追跡する径路は甚だ不明であるが、つかまりさえすればそんなことはこの芝居にはどうでもよいので、これですっかり容疑者被告を造り上げる方の仕事が完成した訳である。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がＮ署の刑事部屋に這入ると、そこには頭髪を切った無表情な少女のかたわらに、悄然と老衰した彼女の父が坐っていた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その周囲を刑事たちが取まいて、中年過ぎた警部によって私たちは取調べられた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "戯れ絵のように、儀礼的な刑事部屋で、あぐらをかいた白毛のまじった老警部が私に言った。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "贅沢な機械でも見るやうに刑事たちが彼女を見たが、チタ子は憂鬱そうに、胯火鉢した男の破れた靴下をみつめていた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　刑事が、失神したように蒼褪めた彼女の父と、チタ子を別室に連れて行った。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "警部が黙々として去ると、他の刑事がにやにやわらいながら部屋に這入ってくると、「――おい、うまくやってるぜ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると刑事は一枚の調査を私に手渡ししながら、「――おい、しっかりしろ、あの娘はとんでもない阿魔だぞ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　警察の門を出て、私は卑猥にわらった刑事の顔を思い出しながら、渡されたチタ子が女としての売行表とも思われる一枚の紙片を読んだ――佐田チタ子、女事務員。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、このＷ刑事が私に話した處の嬉しさの味とは何を意味するものであらうか？",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食の時、妻の話に、今朝もまた新しい刑事が二人來て、出入り商人に就いて何か聞き込みはないかと尋ねたさうだ。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく刑事と警察医らしい人たちが来て、はじめて蚊帳を取り払い、毛布を取りのけ寝巻の胸を開いてからだじゅうを調べた。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "調べながら刑事の一人が絶えず自分の顔をじろじろ見るのが気味悪く不愉快に感ぜられた。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂ教授の禿頭の頂上の皮膚に横にひと筋紫色をしてくぼんだ跡のあるのを発見した刑事が急に緊張した顔色をしたが、それは寝台の頭部にある真鍮の横わくが頭に触れていた跡だとわかった。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑事が小卓のコップのそばにあった紙袋を取り上げて調べているのをのぞいて見たら、袋紙には赤インキの下手な字で「ベロナール」と書いてあった。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはりこの事変の日に刑事たちが引き上げて行ったあとで、ボーイが二三人で教授のピストルを持ち出して室の前の庭におりた。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その問題は型式的には刑事探偵が偶には出くわす問題とおなじようなものかと思われた。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじような論理の錯誤から実際の刑事事件について無実の罪が成立する恐れが万一ありはしないか。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じようなわけで、裁判所におけるいろいろな刑事裁判の忠実な筆記が時として、下手な小説よりもはるかに強く人性の真をうがって読む人の心を動かすことがあるのである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから思うと刑事巡査が正面の写真によって罪人を物色するような場合には、目前にいる横顔の当人を平気で見のがすプロバビリティもかなりにありそうだと思った。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと前に、週刊ロンドン・タイムスで、かの地の裁判所における刑事裁判の忠実な筆記が連載されているのを、時々読んでみたことがある。",
              "citation": {
                "source": "ニュース映画と新聞記事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐵縁の眼鏡を掛けた刑事は、肉の厚い額に皺を二三本もりあがらせて微笑みつつ、鬚の肩を叩いた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その刑事たちが立ち去つてから、眞野は、いそいで葉藏の室へ歸つて來た。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなるとこっちだってデパートの刑事さんじゃなし、最初から疑っているんじゃありませんから、ツイ眼を外らしてしまいますと、そこを狙っているんですね。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……只今なら構いませんから……何なりと……」　四人の刑事は眼くばせをし合ってゾロゾロと廊下の方へ出て行った。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うの隅に固まって煙草を吸っている刑事連に嫣然と一礼した。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ四十恰好の眼の鋭い、腕ッ節の強そうな刑事然たる人が羽織袴で面会に来て某名士氏の次の間にヒレ伏した。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "掏摸に金をすられた肥った年増の顔、その密告によって疑いの目を見張る刑事の典型的な探偵づら、それからポーラを取られた意趣返しの機会をねらう悪漢フレッド、そういう顔が順々に現われるだけでそれをながめる観客は今までに起こって来た事件の行きさつを一つ一つありありと思い出させられる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "但しその簡潔とは、原稿紙に臨んでからのことであるよりも、寧ろそれ以前の、凝集を謂つてゐるのである。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
