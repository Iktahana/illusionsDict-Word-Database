[
  {
    "uuid": "5ca9a655-50f3-57b1-b2e8-6c3684521745",
    "entry": "刑事",
    "reading": {
      "primary": "でか",
      "alternatives": [
        "デカ"
      ],
      "is_heteronym": false
    },
