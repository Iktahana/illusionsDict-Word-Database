    "definitions": [
      {
        "index": 1,
        "gloss": "dill (Anethum graveolens)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
