        "examples": {
          "standard": [
            {
              "text": "彼の音楽へのデディケーションは、多くの若手ミュージシャンにインスピレーションを与えています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このプロジェクトへのチーム全員のデディケーションが、成功への鍵となりました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は長年の研究に対する揺るぎないデディケーションを示しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "申す迄もない、デディケーションで、著者ジョージ・Ｄ・アブラハムはこの本を「岩の上で逢ったところの彼女に」ささげているのである。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はアブラハム氏の私生活を知らないから、「岩の上」の彼女が誰だか、もちろん判らぬが、このデディケーション、ちょっと気になる。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
