    "definitions": [
      {
        "index": 1,
        "gloss": "to go out (e.g. on an excursion or outing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――明日相談に出かけるとして今晩は一人で飲んで来よう。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十八夜を記念しようという、なんの意味もない決心を笑いながら固めて、二人、浅草へ呑みに出かけることになったのであるが、その夜、私はいっそく飛びに馬場へ離れがたない親狎の念を抱くにいたった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "など、のんきな事を考へながら山を降りて來たら、途中で、野良へ出かける息子の聖人とばつたり出逢ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、根が骨太の岩乘なからだであつたから、十日も經たぬうちに全快し、食慾は舊の如く旺盛で、色慾などもちよつと出て來て、よせばよいのに、またもや兎の庵にのこのこ出かける。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌くる日は穂高岳に上るつもりで、朝｜夙く起きた、宿の女が「飯が出来やしたから、囲炉裏の傍でやって下せえ、いけましねえか」と、畏る畏る閾越しに伺いに来る、いいとも、と返辞して大囲炉裏の前に、蝋燭を立て、猟士や宿の人たちと、車座になって飯を済ます、準備も整って出かけると、雨になった。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という寛濶な衣であろう、それをまた……おそらく、谷初まって以来であろう、燃えるような、紫の風呂敷に包ませて、出かける。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日俺の出かけるのは、工場の前のピケッチングじゃないか！",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "静岡の復旧工事の応援に出かけるらしい。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "出かけるとなって庭へおりると、髪があんまりひどいからちょっとなでつけるまで待ってちょうだいと言う。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあともかくもと美代がすかしなだめて、やっと出かける事になる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "都から連歌師が下って来ると、最寄々々の城から招いて連歌一座所望したいとか、発句一首ぜひとか、而もそれがあす合戦に出かける前日に城内から所望されたなどという連歌師の書いた旅行記がありますよ。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃は休暇毎には必ず道筋のどこかへ出かけるようにしております」　小松技師は作楽井氏に就ていろいろのことを話した。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むすこは巴里の花形画家で、おやじゃ野原のへぼ絵描き……」　こんな鼻唄をうたいながら、お父様はこの頃、何を思ったかおまえの美術学校時代の壊れた絵の具箱を肩に担いでときどき晴れた野原へ写生に出かける。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あそこではいつも一所に出かける。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一霧積は今日はおれと北の方の野原へ出かける約束だったのだ、それを白っぽい金襴の羽織などを着込んでわけもわからない処へ行ってけらけら笑ったりしやうといふのはあんまり失敬だと　おれは考へた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族連れで出かけるとその上に家族にこだわるので疲れ方が一層はげしかった。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをもって根岸の競馬に出かけるのである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえ泊れるかい」　母は猶念を押して「おまえが泊ると極ればお母さんは出かける、えいだっペねい」と云った。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田巻草千日草｜天竺牡丹と各々手にとり別けて出かける。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "若旦那も時々｜助太刀に出かける。",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも当代世相レビューの一景と思えば面白くもあったが、天下の早慶戦の日に落着いて連句などを作ろうとするものの不心得を自覚したので、ふと思い付いて二人で東宝劇場へ出かけることにした。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ招待日が来るとＹ博士の家族と同格になって観覧に出かける。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして殉教者町の骨董店のマダム・ルグランが、市の或る場所に向つて馬車で出かけるときは、巴里全體が停滯してしまふ。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は出かけるべく餘儀なくされる。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "清三夫婦が日曜日に出かけると、両人は寛ろいでのびのびと手を長くして寝た。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗本の中隊は、汽車に乗ってイイシの警戒に出かける命令を受けた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一人で出かけるのかい！",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにトーキーが始まるというので後学のために出かける。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう恐ろしい刑罰の危険を冒して彼女らを「テガイニイク」（からかいに行く）という冒険には相当な誘惑を感じる若者も多かったであろうが、中にはわざわざ彼女達につかまって田の泥を塗られることの快感を享楽するために出かける人もあるという話を聞いたことがあったようである。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その以前には一週間くらい泊りがけで出かける事にしていたが、そうするときっときまったように誰かが転地先で病気をした。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
