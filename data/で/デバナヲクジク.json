        "examples": {
          "standard": [
            {
              "text": "期待していた新プロジェクトだったが、まさかのトラブルが出鼻をくじいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の意気揚々とした挨拶も、発表会の出鼻をくじかれてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "成功を確信していただけに、出鼻をくじかれた悔しさは大きかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "最悪のシナリオを描けば、パーソナルコンピューターはアストラのアメリカ進出の出鼻をくじくだけでなく、日本でシステム１００の足下をも脅かす恐れがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
