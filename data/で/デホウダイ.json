[
  {
    "uuid": "b5648d4e-61f6-580f-99a2-121997ef1796",
    "entry": "出放題",
    "reading": {
      "primary": "でほうだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
