        "examples": {
          "standard": [
            {
              "text": "彼女は、お気に入りのデニムジャケットを着て出かけました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このジーンズは丈夫なデニム生地で作られています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ウォッシュ加工されたデニムは、ヴィンテージ感があってかっこいい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」「わたしゃソーヤと――娘はデニス、トム・デニムと結婚したもんで――かしこうて、ちゃんとした若者での、もっとも、それも海にいる間だけのことで、会社での評判はよろしいのに、陸に上がれば、女やら酒屋やらで――」「お探しの指輪です、ソーヤさん。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎モンだと思われるぞ」　慶一は、取っ手の下に派手なストライプが入った、じぶんのデニムのバッグを見おろした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年はデニムのズボンにジャンパーを着、酒の名を染めた前掛をしめ、ゴムの半長靴をはいていた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い皮の、オートバイ・ジャンパーに、14オンス・デニムのブッシュ・パンツ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "着古したデニムのショート・ジャケットの胸ポケットから、皮の名刺入れのようなものを、ひっぱり出した。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
