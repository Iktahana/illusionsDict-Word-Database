        "examples": {
          "standard": [
            {
              "text": "古いゲーム機からは、懐かしい電子音が流れてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その現代音楽の曲は、不気味な電子音で構成されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "深夜、隣の部屋から微かな電子音が聞こえ、何かの通知だと気づいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "アンプはオレのギターを成層圏まですっとばしてくれるし、奇妙な電子音も面白けりゃそれでいい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この手の電子音に初めて出合ったのは、ビーチ・ボーイズの「グッド・バイブレーション」（一九六六年のリリースだから、オレが中二の時だ）に使われたセラミンという代物だったろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムーグ社のシンセサイザーにはとても手は出せなかったが、自作のマイクロコンピューターシステムにシンセサイザーの回路を組み合わせれば、電子音楽に挑戦できるはずだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「簡単にいえば七〇年代のブリティッシュプログレとヨーロッパの電子音楽を混ぜ合わせたロックですねえ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
