[
  {
    "uuid": "f053bc2a-a273-5f97-b5d6-4be894b4a4cb",
    "entry": "田租",
    "reading": {
      "primary": "でんそ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
