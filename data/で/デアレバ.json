    "definitions": [
      {
        "index": 1,
        "gloss": "if it is (the case that ...)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
