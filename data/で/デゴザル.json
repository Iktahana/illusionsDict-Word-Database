        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "仇討で御座る」　と言って、Ｔ「憎い敵奴残念乍ら取り逃し申した」　と言う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚倉が、Ｔ「盗人で御座る」　と呼んで捕方と共に追う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何で御座ると山左。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍二人付き添って甲の侍が君江に、Ｔ「雲霧主膳様からのお迎えで御座る」　ヘッと長七と君江顔見合せた。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「如何で御座る」と団九郎。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎が、先生何で御座る、と言う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ナ……何で御座る。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学で候うの科学で御座るのと言って、自分は天地の外に立ているかの態度を以てこの宇宙を取扱う。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "憚りながら未だ三十二で御座る。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うへ行きたけりゃ手前の方からよけて通れ」という鼻の表現を和らげて、「貴殿が紳士なら拙者もゼントルマンで御座る」「御免遊ばせ」「失礼を」で行き違います。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚤のコンミニスト　　さらば、我が蚤に　　心ゆくまで　　悪態を言はしてみよ、　　蚤の悪態、ハハハハハ　　蚤―、ハハハハハ　　ハハハハハ、蚤のコンミニストいかがで御座る、見やう聴き真似で御主人のメフィストの蚤の歌にそのまゝそつくりの巧みさがあるでせう。",
              "citation": {
                "source": "シャリアピン",
                "author": "小熊秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさにひと膝五千石、切腹せいとの謎で御座るかな」「その口が憎い。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "言うも恐れ多い不義密通、上のお耳にもお這入りで御座るぞ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵にもお上よりお差し紙が参るは必定、お手討、禄は没収、家名は断絶で御座るぞ」「智恵者に似合わぬことを申しますのう。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜んで御座る喜んで御座る。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "行末は一の人となるべき人で御座るのに……』『呉葉――』『お母さまも喜びの涙にひたされてゐられます……お父さまも……お兄さまも……』『…………』　窕子はじつとしたまゝ長い間何も言はなかつたことを呉葉は今でもはつきりと覺えてゐる。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど若し其の身のある調子とか意気な調子とかいうものは如何なもので御座る、拙者未だ之を食うたことは御座らぬと、剽軽者あって問を起したらんには、よしや富婁那の弁ありて一年三百六十日｜饒舌り続けに饒舌りしとて此返答は為切れまじ。",
              "citation": {
                "source": "小説総論",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座の顔触れは、ヴイクトル・ユウゴウ、そのお弟子で始終赤いシヤツを着て、仏蘭西のロマンチストは自分で御座ると言つた風に、胸をそらして巴里の町を濶歩してゐたテオフイユ・ゴオテエ、それからそのころずつと巴里に滞在してゐた露西亜のツルゲネエフといつたやうな人達だつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚はかかる場合に誦するように定められてある経文を口にして、さてその姿に向って、お園の戒名を呼んで話しかけた『拙僧は貴女のお助けをするために、ここに来たもので御座る。",
              "citation": {
                "source": "葬られたる秘密",
                "author": "A DEAD SECRET",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、自分の小説といふものを考へた時に、その沢山な小説の行列の中から、特に、私が小説で御座ると名乗つて飛び出して来るものも見当らない。",
              "citation": {
                "source": "風変りな作品に就いて",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこをぜひ画道修業の為に、視ておきとう御座りまする」「それは御熱心な事で御座る。",
              "citation": {
                "source": "壁の眼の怪",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "歸る時に住職は、「御駕籠でも申付けるのでござるが……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「して、御祈祷をおたのみでござるか」と、式部は訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "して、こなたの母御は当年何歳で、なんの年の御出生でござるかな」「母は六十で、戌年の生まれでございます」と、半七は答えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふだんから何かの御持病でもござるか」「別にこれということもございませんが、二、三年前から折りおりに癪に悩むことがございます」「左様でござるか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "「町人、これはなんでござる」「御覧の通りでございます」「どういうわけで、かようなものを持ってまいられた」と、式部は箱のなかの品を睨みながら云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご坊様も血気に逸って近道をしてはなりましねえぞ、草臥れて野宿をしてからがここを行かっしゃるよりはましでござるに。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫗は威儀正しく、膝のあたりまで手を垂れて、「はい、申されまする通り、世がまだ開けませぬ泥沼の時のような蘆原でござるわや。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれもやれも、お達者でござるわや。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お天気模様でござるわや。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
