    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hearsay",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただ自分等より一年前のクラスで、Ｋ先生という、少し風変り、というよりも奇行を以て有名な漢学者に教わった友人達の受売り話によって、孔子の教えと老子の教えとの間に存する重大な相違について、Ｋ先生の奇説なるものを伝聞し、そうして当時それを大変に面白いと思ったことがあった。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝聞するところによると現代物理学の第一人者であるデンマークのニエルス・ボーアは現代物理学の根本に横たわるある矛盾を論じた際に、この矛盾を解きうるまでにわれわれ人間の頭はまだ進んでいないだろうという意味の事を言ったそうである。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後伊吹山に観測所が設置された事を伝聞した時にも、そこの観測の結果に対して特別な期待をいだいたわけであった。",
              "citation": {
                "source": "伊吹山の句について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "官海遊泳術というものについてその道に詳しい人の話だというのを伝聞したことがある。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし他日これを読む人があったならば、これは臆測や伝聞によって書いたものではなく、正気の、しかも教育あるわたしが、自分の眼前に現に発生したことを正確に記述しているものであることを必ず承知してもらいたい。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "その技工の妙を伝聞して、当時の藩主の命じて刻ましめた、美しき小人の木彫は、坐容立礼、進退を自由にした。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "明の方考孺（中国明代の儒学者）は、「曽子十篇、曽子の著すものではないと云えども、格言・正論がその間にバラバラに述べられていて、言説に於いて最も備わる、思うに門人弟子の伝聞から出て、そして漢儒の手に成るものなり」と評している。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "『弓馬秘伝聞書』に祝言の供に猿皮の空穂を忌む。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる事西洋になかったものか、徳川時代の欧人の書に伝聞のまましばしば書きいる。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人の華麗奔放、放縦不羈の生活を伝聞していた人々は、新聞の報道を少しも疑わなかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは何の参考書にも拠らず、単に自分の遠い記憶をたよりに、見るまま聞くままをそれからそれへと語り続けたのであるから、その中には伝聞の誤謬などがないとは限らない。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人の華麗奔放、放縦｜不羈の生活を伝聞してゐた人々は、新聞の報道を少しも疑はなかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとは貧乏士族が内職に焼いたとさえ伝聞している。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝永元年から天明五年に至る最古の一冊は題号がなく、引用書として『津軽一統志』、『津軽軍記』、『津陽開記』、『御系図三通』、『歴年｜亀鑑』、『孝公行実』、『常福寺｜由緒書』、『津梁院過去帳抄』、『伝聞雑録』、『東藩名数』、『高岡霊験記』、『諸書｜案文』、『藩翰譜』が挙げてある。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "且又手を下候者に無之同志之由を申自訴仕候者多分御座候由伝聞仕候。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「其の言ふ所は、此たび杏坪が江戸に上れる次、君側の人に請うて山陽の事を執りなし、京都より帰りて再び之を茶山の塾に托せむと欲する計画ありとか伝聞し、山陽の旧過を列挙し、己れが山陽に倦みたる所以を陳じて以て澹父の杏坪の計画に反対せむことを望みたるなり」と云ふのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "願はくはそれを見て伝聞の確なりや否やを知りたいものである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶然にも私は、難波が私の義弟の家と姻戚関係があつたばかりに、これらの事実を委細伝聞することが出来たのである。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "此者の咄、将軍家｜曽て伝聞の通り既ニ発足。",
              "citation": {
                "source": "手紙",
                "author": "慶応元年閏五月五日　渋谷彦介あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二段今日不計も三吉老翁の来杖、幸ニ諸君の無異平安なるを伝聞相賀し申候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年三月六日　印藤肇あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "男子側の保守主義者は英国婦人の参政権問題の運動を伝聞して婦人の覚醒を怖れるようであるが、我国の婦人にはまだ容易にそういう突飛な運動は起らないであろう。",
              "citation": {
                "source": "婦人と思想",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただそれは、当時の天主教徒の一人が伝聞した所を、そのまま当時の口語で書き留めて置いた簡単な覚え書だと云う事を書いてさえ置けば十分である。",
              "citation": {
                "source": "さまよえる猶太人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して此の一行に加はらざりし父老等は之を伝聞して、一人の起ちて此の暴戻なる警官に反抗防衛する者あらざりし事の、意気地なきを憤慨せり。",
              "citation": {
                "source": "鉱毒飛沫",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "去れど足一とたび其の地を踏むに及びて其の惨状の寧ろ伝聞に勝れる者あるを感じたり。",
              "citation": {
                "source": "鉱毒飛沫",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "この際に当て府下百万の人民は一時に方向を失い、固より官軍の何ものたるを知らず、仮令い東征の名義｜云々は伝聞するも、その官軍なるものが江戸に入たる上は何等の挙動あるべきや、之を測量すること甚だ易からず。",
              "citation": {
                "source": "故社員の一言今尚精神",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "試に今日女子の教育を視よ、都鄙一般に流行して、その流行の極、しきりに新奇を好み、山村水落に女子英語学校ありて、生徒の数、常に幾十人ありなどいえるは毎度伝聞するところにして、世の愚人はこれをもって教育の隆盛を卜することならんといえども、我が輩は単にこれを評して狂気の沙汰とするの外なし。",
              "citation": {
                "source": "文明教育論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "越前福井までは、まだ其御儀の仔細が、伝聞せられるに到らなかつたであらう。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、彼の生活及び性格が、記録・伝聞によつて考へられるよりも、彼の残した作物によつて組み立てる外のない今からは、作物に現れた彼を、凡彼其人と見て行くより外はないのである。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "急々一書を裁し候昨夜は数々の御厚遇大謝大謝｜然るに今朝｜承及候えばかの舞妓春どの夜前小石川南海寺にて変死を遂げ候趣き驚き入り候右御伝聞未だしきやと存じ候えばお知らせ申候……。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
