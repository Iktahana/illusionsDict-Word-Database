[
  {
    "uuid": "a419e812-c271-5574-8bd3-1d2b1433cfdc",
    "entry": "伝聞",
    "reading": {
      "primary": "でんぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
