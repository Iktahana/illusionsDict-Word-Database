        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、まず、電源スイッチをぐっと入れてみると、うまく電気がくるではないか。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっとスイッチを入れてみないか」　二宮がいったので、「よおし」と隆夫は電源スイッチを入れた。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで大急ぎで、残った部品を仮りの接続でつなぎあわせ、金網の外へ出て、パネルについている電源スイッチをおそるおそる入れてみた。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "佳子がかたわらで見守るなかを、ぼくは電源スイッチをオンにした。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "電源スイッチをオンにし、袋からレコードを抜き出し、ターン・テーブルに置いた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
