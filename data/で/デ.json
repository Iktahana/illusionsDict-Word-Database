  {
    "uuid": "946f1440-7f42-57b9-8ed4-23cc984fdbef",
    "entry": "ｄｅ",
    "reading": {
      "primary": "デ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "助詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "of (indicates possessive)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さらに日本語Ｇｕｉｄｅも用意されている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会主義者Ｅｄｅイードがファシストの第一の保護者。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お話はよくわかりましたが……フガフガどうもそういう理屈を仰有っても」とフガは私のＭａｄｅ・ｉｎ寝床英語に僻易したのかそれとも一文の得にもならん話にウンザリしたか、ニヤリと苦笑を洩らした。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "マグデブルグの半球よ、おゝレトルトよ！",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二※月くらゐして、やつぱりその同人の集りのあとで、谷君他三人ばかりが、円タクの中からオイデオイデをするから行つてみると、これから牧野さんを誘ひ出しに行くから乗れといふのである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "所でラヴェルなんてバッハが見たら苦労性なデコラトゥールだ。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔雪とひのきの坂上に〕宮沢賢治雪とひのきの坂上に粗き板もてゴシックを辛く畳みて写真師の聖のねぐらを営みぬぼたと名づくる雪ふりていましめさけぶ橇のこらよきデュイエットうちふるひひかりて暮るゝガラス屋根",
              "citation": {
                "source": "〔雪とひのきの坂上に〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルスリーヌ・デボルド―※ルモオルは千七百八十六年七月の二十日にドゥエ（Douai）に生れ、千八百五十九年七月二十三日巴里で死んだ。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "叙事は謂はば文人画風の型を作り、かくて人間的心情は所謂美――私にとつてはデコレイション――とその余りの部分とに分裂した。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "迷蒙の中ではディレッタントが屡々確固たる性格者にみえる。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術家にとつて世界は、即ち彼の世界意識は、善いものでも悪いものでも、其の他如何なるモディフィケーションを冠せられるべきものでもない。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れにしても、それは成つてみれば運命の臼の加減といふほかないのであるが、成つてみるまでは人には各々胸の混沌、直観としてのイデエがあるばかりである。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本飲み終つた頃、また後から一人来た、今度は先のよりは少し綺麗、デツプリ太つて自信がおありだ。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　新聞に拠ると、いよいよ改築を修了せんとする、日本の、ドレスデン街さ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、私の前の奴を見ると、私のよりウンとハデな蝶ネクタイを、私より五つも年取つてゐる男が持つてゐた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者がかつて評論した、有名なヘルンのエッセイ『ある女の日記』も、校本に拠るところがあるとは言いながら、実はその愛妻節子夫人を、半面のモデルにしたものと言われている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "口デ言エナイホド喜ビマシタ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドウゾ案ジナイデ下サイ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一雄ハ深イ所デ泳イデモ危イコトハアリマセン。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アノイワレハ可愛ラシイモノデス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚤ガ群ッテ集マルノデ眠ルノハ少シムツカシイ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカシ朝、海デ泳グカラ、皆、夜ノ心配ヲ忘レマス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今アナタ忙ガシイデショウネ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "大工ヤ壁屋ヤ沢山ノ仕事デ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "デスカラ身体ヲ大事ニスルヨウニクレグレモ願イマス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "巌ト一雄、丈夫デ可愛ラシイ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "海デ沢山遊ビ黒クナリマシタ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの文学に出る日本婦人のモデルは、多くその妻に非ずば姑の老婦人だといわれてるが、すくなくともヘルンは、この点での好運にめぐまれていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼の精神生活は、反対に極めてデリケートで贅沢だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "早ク見タイモノデス』という焼津の手紙でも解るように、妻と同伴することなしには、どんな旅行も楽しくないほど、夫人を熱愛していたからだった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
