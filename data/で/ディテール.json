        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これはあの三倍位の長さに引き伸ばして、もっとディテール〔細部、細目〕を書き加うべきであったと思う。",
              "citation": {
                "source": "探偵小説壇の諸傾向",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者が、新聞小説に求めている面白さの本質の問題から云わば制約の第一歩がはじまっていることも、時代風俗的なディテールへの作者の適応性が要求されていることも変りはないであろう。",
              "citation": {
                "source": "おのずから低きに",
                "author": "――今日の新聞小説と文学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分一人では言葉がよく通じないから、すべてのディテールは明日ということにして、コムナールで、キュリ、パン、イクラを買ってかえる。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "МХАТについてディテールがわかった。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○学甲庄慈済宮の古銭窓　こういうディテールは非常に面白のがあるね。",
              "citation": {
                "source": "台湾の民藝について",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り証明や論証のディテールに渡るものは、単に筆者の頭の中で構築しさえすればよいので、一々表現には及ばぬ場合もあるわけだ。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は私もそのディテールを知って居るわけです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説もそのように生活のディテールと活力の横溢したものにしたいと思います。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディテールについては又別にかきましょう、特に父について。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャーナリスティックな場合、どうしたって現象的ディテールを追って、それに対して云々する場合が多く、従って文学理論の歴史から見ても、それを或時代から時代へ発展させ押しすすめる集積としての仕事になり難い。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "性格やその高くない面や野心やそういう要素をはっきりわかって下さると、その上でのこれからのやりかたが細かいディテールにふれて、やって行く上に便利です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろのディテールを添えて。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "多賀ちゃんとの二人ぐらしで、私のくらしもいろいろ微妙にディテールが変化いたします。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはディテールまだわからず、手続きは全く簡単です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ一つのこまかい情景さえ、春のある冬、という詩のディテールが私の生活というよりも生存にしみついているとおり、私のこころに刻まれていて、冷静にみられないのよ、多分。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれだけ大規模で、あれだけディテールに充ちた小説の最後の一行が、あんなに力なく云いわけめいているというのは一つの特色です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディテールを拾っていくと日本ふうである広い庭。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中継を聴きながら、球場でおこなわれているプレーのディテールひとつひとつを頭のなかに描いていく行為に没頭することをとおして、ほんの一瞬、僕は父親とおなじ人になった錯覚を持った。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史的なディテールをこまかく散りばめれば散りばめるほど、ぼくのフィクションも、ディテールを精密に作る必要があるみたいです」「そうでしょうね。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろんな部分を拡大しては、その内部に入りこんでいき、写真のなかにとらえてあるディテールをぼくは観察していった。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "細かなディテールをくっきりと浮き立たせる西陽のしわざだ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真に撮ることによって知りつくしているディテールを、彼は観察した。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆるディテールを自分で写真に撮りました。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所を変えてこうして間近に見ると、律子が美人であることを示すディテールを、彼女の顔立ちのなかに、裕美子は数多く見つけることが出来た。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのコントのあらゆるディテールをいきなりすべて思い出して、百貨店のその売場が舞台になったような錯覚だったわ。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面のなかのさまざまなディテールを、そしてぜんたいを、何度もつくづくと見てしまう。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの雑誌をヨシオとふたりで点検し、ディテールを丹念に拾い集め、それらを深町は合成して自分の絵として仕上げた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "とんでもないかけ離れたあちこちからディテールを集め、それを僕の創作した場面のなかの、おなじく創作の人物に当てはめているだけです」　男たちは引き上げ、順子と深町はふたりだけとなった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまはコンクリートの壁とそのなかの植え込みがあるだけだが、コンパルサのドアとその周囲のたたずまいくらいなら、いまでも矢野はディテール豊かに思い起こすことが出来た。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
