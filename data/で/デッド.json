        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "吸音材を使った部屋は、音がデッドに響く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "レコーディングスタジオは、デッドな音響空間が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このコンサートホールは音響がデッドすぎて、演奏の臨場感に欠ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
