[
  {
    "uuid": "dacaa357-1fad-5ee4-ab56-ec4b1b84fde0",
    "entry": "出歯",
    "reading": {
      "primary": "でば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
