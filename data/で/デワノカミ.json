    "definitions": [
      {
        "index": 1,
        "gloss": "director of Dewa province",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小町は近畿在住の小野家一族中に姫として出生し、直ちに宮中へ仕へたといふ説と、飽くまで伝説通り、良真が出羽守として赴任中妾腹に生れ、後京都に上つたといふ説とである。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近い例でこの桶狭間の役に梁田出羽守には、善き一言よく大利を得しめたと云って沓掛村三千貫の地を与えたが、義元の首を獲た毛利新助はその賞梁田に及ばなかった。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠直卿早速、舎弟伊予守忠昌、出羽守直次をして左右両軍を連ねさせ、二万余騎を以て押し寄せたが、幸村は今暫く待って戦わんと、待味方の備をもって、これに当っていた。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――左様、おれは坂崎出羽守だ！",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "内藤｜掃部頭正成、植村｜出羽守家政、板倉｜内膳正重正ら近臣三十人ばかりが輿に従って進んだ。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「坂崎出羽守」を発表。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "松竹キネマ製作の映画「坂崎出羽守」は戯曲「坂崎出羽守」の著作権を侵害せる事実明白なるにより、劇作家協会の後援を得て社長大谷氏を訴う。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "出羽守信著の家を嗣いだ翌年に歿したのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "安永七年三月｜朔に十五歳で渋江氏に養われて、当時｜儲君であった、二つの年上の出羽守｜信明に愛せられた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」忠成は沼津の城主水野出羽守である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠居は出羽守｜信順である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "辞典によると、折峠（をりたうげ）越後岩船　　　下津（おりつ）尾張中島　　　下立（おりたち）越中新川　　　小里（をり）美濃土岐　　　折壁（をりかべ）陸中東磐井　　　折紙鼻（をりかみばな）長門豊浦　　　折敷畠（をりしきはた）安岐佐伯右の中、小里は、小里出羽守など言ふ、戦国の武人の本貫である。",
              "citation": {
                "source": "折口といふ名字",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「嬰児殺し」「同志の人々」「坂崎出羽守」等は前者に属し、「女中の病気」「海彦山彦」「西郷と大久保」等は後者に属してゐる。",
              "citation": {
                "source": "作家山本人間有三",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "参議藤原仲平、兵部大輔源嗣敬、右近衛少将藤原兼茂、藤原俊蔭、出羽守藤原経邦、兵部少輔良峰、遠視左兵衛佐藤原伊衡、平希也など僅かに八人であったのである。",
              "citation": {
                "source": "酒渇記",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちうこうになって雲州松江の松平出羽守、常陸の土浦の土屋相模守、美作勝山の三浦志摩守といったような馬鹿殿様が力を入れて、松江流、土屋流、三浦流という三つの流儀をこしらえたが、馬鹿囃子の本音は、トテモ殿様のお道楽では出て来ねえ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」〔曾テ甲山ニ入リテ大薬ヲ求メ／元メハ水府ニ遊ビテ霊泉ニ浴ス〕と言っているのと、滝川という姓氏の二事から漸くにして南谷というのは禄四千石の旗本滝川出羽守｜利雍の雅号であることを知った。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "水野出羽守様御領……。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父江出羽守の猟座、山伏山の田万里は、こうしてあくなき殿の我慾の犠牲に上げられて、一朝にして狐狸の棲家と化し去ったのだった。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの祖父江出羽守は、きゃつ、人間ではござりませぬぞ。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "出羽守行状「出羽守が人数を率いて狩猟をしたあとは、全村、暴風雨の渡ったあとのごとく、青い物ひとつとどめなかった惨状でござりました。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　血のにじむほど口びるを噛み締めながら、大次郎は、しんみりとつづけて、「これは、千浪様のまえでははばかりますが、すこしでも見目のよい若い女で、出羽守に犯されずにすんだものはありませぬ。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "土けむりを上げて、風のように馬を飛ばして来ては思う存分荒らし廻って行く出羽守主従だった。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつ上で、当時二十一――柴刈り姿が出羽守のお眼にとまって、猟りの人数が下山のとき、お側に召されて引っさらわれました。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ややあって法外は、顔を上げ、「その出羽守の暴状を、公儀へ訴え出る途もあったであろうに、なにゆえしかるべき当路者へ、差し立て願いに及ばんだのかの――上も、それだけの狼藉ぶりを耳にしては、そのままに打ち捨ておくわけにはゆかんはずだが。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「力さえあれば、早い話が、出羽守に一矢報いようと思えば、それもできるかもしれない。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　姉を拉し去り、父を殺され、母を自害させた祖父江出羽守を、大次郎が秘かに仇とつけ狙うのに、不思議はなかった。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "この三羽烏の力を合わせて、他日必ず出羽守を討ち取り、父、母、姉、村人の恨みを霽らす。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
