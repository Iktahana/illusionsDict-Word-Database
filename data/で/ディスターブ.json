        "examples": {
          "standard": [
            {
              "text": "静かな図書館で、大きな声で話すのは周りの人をディスターブする行為だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼が集中しているときは、決してディスターブしてはいけない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "寝ている赤ちゃんをディスターブしないように、そっと部屋を出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "然し彼の境遇の回顧は、十幾年かで日本へかえって、たった二月許りで、自分に仮令暫時でも別れる、ディスターブされるからと云われるのは辛いのだろう。",
              "citation": {
                "source": "日記",
                "author": "一九二〇年（大正九年）",
                "note": "青空文庫"
              }
            }
          ]
