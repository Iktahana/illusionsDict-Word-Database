        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "沼炭だぞ、泥炭があるぞ、さてこそこの平はもと沼だったな、道理でむやみに陰気なやうだ。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥炭層を水がちょろちょろ潜ってゐる。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く別の世界だぞ、　気を落ちつけて（黄のひかり）あるある、あるには有るがあの泥炭をつくったやつの甥か孫だぞ、黄のひかりうすあかり鳴れ鳴れかしは。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "スコットランドへ旅行して鳶色をした泥炭地の河水の泡に興味を感じて色々実験をしたのもこの時代のことであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "洪積期の遺物と見られる泥炭地や砂地や、さもなければはげた岩山の多いのに驚いたことであったが、また一方で自然の厳父の威厳の物足りなさも感ぜられた。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥炭層の伏流がどういふものか承知かね？",
              "citation": {
                "source": "春と修羅　第二集",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "晝間になつて日が照り出すと、人の往來する所だけはどろ／＼に雪解がして、泥炭地の水のやうな黒褐色の水が盤に踏み固められた雪路の上を逃げ所もなく漂ひ※る。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから　泥炭の　しみたれた　巫戯けだ。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな泥まみれになり、ヴェランダは愛蘭土泥炭沼の如し。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは八号の風景にかかれたもので、軽川あたりの泥炭地を写したと覚しい晩秋の風景画だった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "根雪が氷のように磐になって、その上を雪解けの水が、一冬の塵埃に染まって、泥炭地のわき水のような色でどぶどぶと漂っている。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「入地百姓――移民百姓」は、だから呉れるにも貰い手のない泥炭地の多い釧路、根室の方面だけに限られている。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　――三吾が自分のでもない泥炭地の田を、どうにか当り前にしようと、無理に、体を使った。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのふの晝間見た大原野の一部なる幌向原野は、不毛な泥炭地で、見渡す限り茅ばかりの、一面にじめ／＼したところだと思つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして多くの人々の返り見ない、こんな泥炭の大｜濕地にも、小開墾者が寂しく住んでゐるのかと思ふと、そのともし火は義雄自身の樣な一文なしの寂しみを表してゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、例の泥炭地の間になる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "幌向原野の泥炭地は一望千里の如く空しく廣がつてゐるが、早く大排水工事をやつて、地盤を乾したら、國家の爲めに多大の開墾地が出來ること。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、他にも美唄原野、雨龍原野なども同じ事情だから、來年の議會に提出する拓殖案には、こんな泥炭地排水工事費も含んでゐること、などだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は香春岳のよさを観た、泥炭山のよさも観た、自然の山、人間の山、山みなよからざるなし。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下茎の上に地下茎を伸ばし、その上におのれの葉や茎を腐らかし、またその上に根を張り、葉をしげらし、枯れ頽れ、――積みあげ積み重ねた数えきれないほどの春夏秋冬が、踏めば沈むような低位泥炭土をつくっていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手は今馬力をかけたものと見えて、汽鑵車はちょうど巨人の喘ぐように、大きな音を立てて泥炭の煙を吐きながら渋谷の方へ進んで行く、高谷の乗っている室がちょうど遠方シグナルのあたりまで行ったころ、思い出したように、鳥打帽子が窓から首を出してこちらを見た。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥炭を溶いて濃く、身の周囲に流したように、黒い色に染められた重たい霧が、目と口と鼻とに逼って来た。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥炭を含んだ渓水は、染粉を溶いたように古びた色になる。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂｜泥炭地である。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "余放吟して曰く、泥炭地耕すべくもあらぬとふさはれ美し虎杖の秋　士別では、共楽座など看板を上げた木葉葺の劇場が見えた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右は一面じめ／＼した泥炭地で、反魂香の黄や沢桔梗の紫や其他名を知らぬ草花が霜枯れかゝった草を彩どって居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また岸の崖に、泥炭の層が露出していた。",
              "citation": {
                "source": "姫柚子の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただひとり、銛師の北原だけは、暇さえあれば、沼の岸でひろった硬い泥炭の塊でコツコツと銛を作っていた。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "コムパスが傷んでいたんだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女中のお村というのが今朝になって見つけ出したんですが、師匠は黒い蛇に頸を絞められて蚊帳のなかに死んでいたんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
