        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ざま見ろ」というような痛快な感じが心のどこかから湧いて来るのであった。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉本はざま見ろ、という風に、それを持ってきた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんこのとき、煙草の火はきえていたけれど、「あははは、ざま見ろ。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までは一向気にも留めざりし鴉の鳴声も、かの大木の梢に聞付け候時は、和尚奴、ざま見ろ。",
              "citation": {
                "source": "榎物語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ざま見ろ」　そんなことをしているうちにバッハの〈平均律洋琴曲ハ長調フーガ〉はなにがなんだかわからなくなってしまった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ざま見ろ、あまり威張り腐るから殺されてしまったのだよ！",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も彼も粉々にし、ざま見ろと叫びたいほどの暴々しさ。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――ざま見ろッ、どんなもんだい。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ワハハハハハ、ざま見ろ。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チェッ、ざまみろ、いいきみだ」　女房はプンプン怒つてゐるが、マダムはたぶん部屋の中で笑ひころげてゐるだらう。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "案ずるに自分を最もみじめなものに、最も卑しげなものに貶しめて恥しさで消滅したげに狼狽へ騒ぐ自分を眺め「ざまみろい！",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チェッ、ざまみろ、いいきみだ」　女房はプンプン怒っているが、マダムはたぶん部屋の中で笑いころげているだろう。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど上手いもんで、彼は地の底へ落ちてゆくところさ、ざまみろだよ！",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつら不満だろ、ざまみろ」「私は満足よ。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
