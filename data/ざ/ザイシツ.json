[
  {
    "uuid": "848d0c91-9cc9-59d4-a77e-1567bbbac0c2",
    "entry": "材質",
    "reading": {
      "primary": "ざいしつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
