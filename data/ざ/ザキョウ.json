    "definitions": [
      {
        "index": 1,
        "gloss": "entertainment (at a party)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
