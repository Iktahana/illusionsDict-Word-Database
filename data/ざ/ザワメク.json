    "definitions": [
      {
        "index": 1,
        "gloss": "to be noisy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "次に陰性の人は蝉や蛇の抜け殻のような有様になり、陽性の人は葉が騒めくような、魚が驚いたような状態になり、中性の人は前の二相を共に交えて現わす。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵卒達の後頭部が異様に騒めく（まさか？",
              "citation": {
                "source": "動員令",
                "author": "波立一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　藤次は、格子のうちで笑っている白い顔と、清十郎を見くらべて、「諸公、怪しからぬ事なござるぞよ」「なんじゃ、何事ぞや」　連中は、わざと騒めく。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「騒めくなッ」　太刀を上げて、その切っ先で命じるようにいった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、口々に騒めく兵の声があらしのようにわき揚ッていた。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき車内なんとなく騒めくので、ふと、人々の見る方を求めると、厳島へかけて、あざらかな虹が空にかかっていた。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂の上の交叉点からの電車の軋る音が前の八幡宮の境内の木立のざわめく音と、風の工合で混りながら耳元へ掴んで投げつけられるようにも、また、遠くで盲人が呟いているようにも聞えたりした。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "客は会場の広室に溢れ、帳場にこぼれ、廊下に流れて、わやわやとざわめく中を、よけるようにして通って、一つ折曲る処で、家内総出で折詰の支度に料理場、台所を取乱したのを視ながら、また一つ細く成る廊下を縫うと、其処にも、此処にも、二三人、四五人ずつは男、女が往来う、彳む。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦横に道は通ったが、段の下は、まだ苗代にならない水溜りの田と、荒れた畠だから――農屋漁宿、なお言えば商家の町も遠くはないが、ざわめく風の間には、海の音もおどろに寂しく響いている。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "など、大笑の声あり、満場ざわめく。",
              "citation": {
                "source": "喝采",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "周圍の十字架に掛けられた花輪どもは悉く褐色に枯れ凋み、海風にざわめく枯椰子の葉のそよぎも哀しい。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲の十字架に掛けられた花輪どもはことごとく褐色に枯れ凋み、海風にざわめく枯｜椰子の葉のそよぎも哀しい。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行の両側にある岩盤にしてもかなりの急斜面のため、種々の松の木が頭上を覆うように茂っており、一陣の風が吹くだけで大きくざわめく。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は低いざわめく灌木を見下し、太古からの高い樹々を見上げ、更に高く颯々たる空と、真紅の月とを仰いだ。",
              "citation": {
                "source": "沈黙",
                "author": "――神話",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらがざわめく人の足音、潮時の往来の影。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ聞えるものは雨の音と、寺の塀から往来へ掩いかかっている大きい桐の葉にざわめく風の音のみであった。",
              "citation": {
                "source": "真鬼偽鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、どうしたんだろう」　見物のざわめく声が俄かにきこえた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人影もない知らない土地をぶらぶらするのもよい味のする旅情だが、ざわめく雑沓の人の中を、自分ひとりのけ者となりながら、当もなくぶらぶらと歩いて行くのも、悲しくわびしく何とはなしに甘やかしい涙がほろりと湧いて、実にいい味のする旅情です。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "なーんだ、と、また、ざわめく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖国のために……」　群衆のざわめく姿が、火事を照り返した空のほの明るさで、それと見られたが、かなり集っている。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大意は、「グルジヤの丘の上、夜露かかり、アラグヴァの流れ、わが前にざわめく。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音とはべつに、近くで木々が一せいにざわめく音や、又はるか遠くの谷底へでも落ちて行くやうな風の音も聞えた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋風の裏藪がざわめく。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し出て来た風にその薄のような草のすきとおった白い穂がざわめく間を、エンジンの響を晴れた大空のどこかへ微かに谺させつつ自動車は一層速力を出して単調な一本道を行く。",
              "citation": {
                "source": "女靴の跡",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "松や杉は落付いているのに恐ろしい灰色雲の下で竹がざわめくこと――このような天候の時、一人ぼっちでこの近傍によくある深い細道ばかりの竹藪を通ったら、どんなに神経が動乱するだろう。",
              "citation": {
                "source": "雨と子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時たま、松葉を渡る風のざわめく音くらいしか聞こえない。",
              "citation": {
                "source": "死生に関するいくつかの断想",
                "author": "BITS OF LIFE AND DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "行って来た処、云われたこと、自分にはこの娘のように安心して甘える母のないことなどがたたまって、房は、ざわめく夜の散歩の中で、ひどく自分を孤独に感じた。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくあたりに響いていたであろう音楽や、人のざわめく雰囲気の描写などは一切なく、桃色こはくの洋服を着てバラの花を髪にかざし、赤い房の下った扇子で折々胸のあたりをあおいでいる美しくも凜としたところのある「年のころ二八ばかり」つまり十六歳ばかりの少女。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにこっちは、応援の青年団やら好奇な弥次馬やらでやたらに人数が多いから、ざわめくばかりでも先はいちはやく物音を聞きつけて逃げてしまう。",
              "citation": {
                "source": "チャアリイは何処にいる",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁のむこうで、ざわめく音や話し声が聞えていたが、扉があいて従僕が盆に空のコップやクリーム入れやラスクの籠をのせて出て来た時には、それが急にはっきりと聞こえだした。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
