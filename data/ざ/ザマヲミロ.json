        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この意地が通されないくらいなら美術家たるはおろか、何一ツしでかすものかと、今度はけんか腰になッて、人を後ろへ向かそうッて、たれが向くか、ざまを見ろと今から思えばおかしいがほんとにそう独語を言いながら画き続けた。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざまを見ろと書きかけた答案を消し意気揚々と白紙のまゝで出した。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざまを見ろという小気味のいい感じだけで、同情の心は起らなかった。",
              "citation": {
                "source": "令嬢アユ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日、濁ったことをしたので、ざまを見ろ、文章のきたなさ下手くそ。",
              "citation": {
                "source": "悶悶日記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もがきあがいて、作家たる栄光得て、ざまを見ろ、麻薬中毒者という一匹の虫。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらはお鳥に對する熱心が段々冷えて來たのに反し、お君に向ふ馨のあの嬉しさうなざまを見ろ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざまを見ろと、彼は勝ち誇って進んでゆくと、その足はまた何物にかつまずいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "女悲しげに歌いながら、石に打たれていたが、それが一つ眉間に当るとくずれるように倒れてしまう）男達　ざまを見ろ、いい気味だ。",
              "citation": {
                "source": "世評（一幕二場）",
                "author": "A morality",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のプロレタリア作家のざまを見ろ。",
              "citation": {
                "source": "プロレタリア文学における国際的主題について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鳥も、こちらにそのざまを見ろと云はないばかりの冷淡な風を見せて、ずん／＼さきへ進んで行く。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のことなどにやア口出ししないで、手前のざまを見ろ！",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　うさぎはたぬきのあわてる様子をおもしろそうにながめながら、「ざまを見ろ。",
              "citation": {
                "source": "かちかち山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　良平は金三の叱られるのを見ると、「ざまを見ろ」と云いたかった。",
              "citation": {
                "source": "百合",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "本間さんは向うの気色を窺いながら、腹の中でざまを見ろと呟きたくなった。",
              "citation": {
                "source": "西郷隆盛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等のある者はこれを見ると、「ざまを見ろ」と云うように腹を抱えて笑い出した。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにその岩の向うでは、「ざまを見ろ、髪長彦め。",
              "citation": {
                "source": "犬と笛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「は、は、は、ざまを見ろ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "は、は、は、ざまを見ろ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三郎兵衛が、たしかに、塗り込めの中に、封じ込まれたとまで、血走った目で見届けた広海屋与平――「ざまを見ろ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざまを見ろ、と私は彼女の手紙に対して云ってやった。",
              "citation": {
                "source": "道化役",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざまを見ろ、耳を見ろ。",
              "citation": {
                "source": "道化役",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざまを見ろ、といふハッキリした意味があつた。",
              "citation": {
                "source": "孤独閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時お前の辮子は黒絹のように光っていたが、今のざまを見ろ。",
              "citation": {
                "source": "風波",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あっはっはっ、ざまを見ろ」　怪塔王は、なおもからからと笑いつづけます。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「う、ふふふふ、ざまを見ろ」　怪塔王は、さきほどのおろおろ声もどこへやら、またいつものにくにくしい怪塔王のしゃがれ声にかえって、床の上にたおれている帆村を見下しました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑いがとまると、よく知っているいやらしい声が、どうやら私の耳の近くで、聞きとれるぐらいにひそひそと話しかけた、――「おれは満足だよ、ざまを見ろ！",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京某生の來書に、芝口もと太田屋牛肉店前の道路に朝九時頃洋裝の若き女黒人の兒を分娩し苦しみゐるを、見る人大勢いづれもざまを見ろ、いゝ氣味だと云はぬばかりの面持にて、笑ひ罵るのみ、誰一人醫者を呼びに行つてやる樣子もなかりし。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもかでも彼を物質上の犠牲者にし終せた上で、後からざまを見ろ、とうとう降参したじゃないかという態度に出られるのは、彼にとって忍ぶべからざる侮辱であった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ざまをみろッ、卑怯者ッ」　ばたりとそこへ非人をのけぞらしておくと、何はともかく主水之介の安否が気がかりでしたから、取り急いで駕籠側へ駈けかえると、何とこはそもいかに！",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねらいの狂うはずもなく的確に効を奏して、くねりと黒い影の首筋にからみついたものでしたから、ざまをみろッとばかり伝六が鼻を高めて、自分のてがらででもあるかのようにそこへ引きたててきたまでは無事でしたが、しかるに少年はなんともかとも奇怪千万でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
