    "definitions": [
      {
        "index": 1,
        "gloss": "to leave one's seat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "園は欠席届書を小母さんに託し、不幸というのは父が頓死したのだということを簡単に告げて、座を立つことになった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆三は血の気で頭の皮膚が破れるかと思ふばかり昂奮して、黙つて座を立つて行つて、土蔵の中の机の前に腰かけた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤皮縅は忠綱さまの御鎧、またその葦毛の馬は、相州さまから拝領の片淵と号する忠綱さま御自慢の名馬に相違ないのでございますから、もはや争論の余地も無く、将軍家は、興覚め顔に何事もおつしやらず、ついとお座を立つておしまひになりました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れ果てたそして極めて靜かなその場の氣持を壞さない樣に、私はわざわざ座を立つてその蟲を逃がさうとした。",
              "citation": {
                "source": "樹木とその葉",
                "author": "虻と蟻と蝉と",
                "note": "青空文庫"
              }
            },
            {
              "text": "……居堪らなくて、座を立つと、――「散歩をしましょう。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "正虎は「實に殊勝な心得と存ずる、黒田家には好い家老を持つてをられる」と云つて座を立つた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして主婦が座を立つたところで、彼の子供の数や年なぞを訊いてゐた。",
              "citation": {
                "source": "水ぎわの家",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同が座を立つ時、物慣らされた物腰で、椅子を引いてくれた田川｜博士にやさしく微笑を見せて礼をしながらも、葉子はやはり事務長の挙動を仔細に見る事に半ば気を奪われていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて事務長が座を立つと、葉子は、眉をひそめて快からぬ顔をした木村を、しいてまたもとのように自分のそば近くすわらせた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お兼もそれを送つて座を立つたので、あとは吾々若いものばかり三人が殘つた。",
              "citation": {
                "source": "姉妹",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（立って舞い始める）藤十郎　（黙々として、ひそかに狂言の工夫をめぐらすごとき有様なりしが、一座の注意が連舞にひかれたる間に、ひそかに座を立つ。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃ほひに滝尾は、そつと座を立つて、ふらふらと怪しげな脚どりで蔵の階段を昇つてゐた。",
              "citation": {
                "source": "夜の奇蹟",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに次いで令嬢たちとワシリーサ・カシュパーロヴナが座を立つた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "客の減るのを計って、座を立つかと思うと、杯を持ちながら忠次郎の前へ来た。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠興は一目それを見ると、「おう、これは……」と言つたきり、そのまま座を立つて奥へ入りましたが、しばらくすると、礼服に着かへて出てきました。",
              "citation": {
                "source": "小壺狩",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに居並んでゐた連中はみんな懐中にそれ／″＼短冊を忍ばせてゐたが、何も彼も引裂かないでは承知し兼ねまじき高浜氏の顔色を見て、誰一人それを取出さうとはしないで、匆々に座を立つて帰つて来た。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　気の毒な盲法師は、迚も自分の手では出来さうにもないといつて、匆々に琵琶をしまつて座を立つた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏はやをら座を立つて座敷の真中に坐つた。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　謙道師は医者でも言ひさうな事を言つて、その三十円をも懐中に入れて座を立つた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　真木は茶の間にゐた晴代がちよつと座を立つたところで言ひ出した。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "羊三はそつと座を立つて、廊下へ出た。",
              "citation": {
                "source": "籠の小鳥",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "礼ちゃんはもじもじしながら、にこにこして、僕が座を立つのを待っているようだった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」女は座を立つて、義雄のわきへ來て坐わる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」かう云つて置いて、堀は座を立つた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく普通の話し聲になつたと思ふと、三味線の音も止んで、隣り座敷の客はドヤ／＼と座を立つたらしかつた。",
              "citation": {
                "source": "東光院",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとで何やら工合わるそうにして座を立つのだが、やがて、陽当りのいい居間の縁ばなにしゃがんで籠のカナリヤを人差指で嚇かすようなことをしている父の屈託のない姿がみうけられたりすると、茶の間の姉と紀久子はつい頬笑みかわすのだった。",
              "citation": {
                "source": "父",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども女王は座を立つて、冴々した笑ひ声と共ににげて仕舞つた。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "三田は、自分もちつとは取持役として働かなければならないのだとは感づきながら、どうしても氣輕に座を立つ事が出來なかつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃めた事をあんなに良人から善ばれた煙草だからと、さう思ふのであるが水色の煙が鼻の前に靡くのを見ると堪へ難くなつて座を立つた。",
              "citation": {
                "source": "帰つてから",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "衆議院の解散衆議院解散の号外を手にした刹那、わたしは座を立つて思はず叫んだ。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
