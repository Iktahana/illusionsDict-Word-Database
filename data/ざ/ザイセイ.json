[
  {
    "uuid": "a988652a-c159-5272-b66f-5a9d0ac69bd0",
    "entry": "財政",
    "reading": {
      "primary": "ざいせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
