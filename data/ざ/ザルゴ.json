    "definitions": [
      {
        "index": 1,
        "gloss": "game of go played by poor players",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "糟谷が芳輔を抱いて奥へあがるとざる碁仲間の老人がすわりこんでいる。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてつとめて、自分が苦労してる問題に離れた話に興を求め、ことさらにたわいもないことを騒いで、一｜晩ざる碁をたのしんだ。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日もざる碁をたのしんだ。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛想よくいつもにこにこして、葉巻きのたばこを横にくわえ、ざる碁をうって不平もぐちもなかった。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "土田氏は實業界の名士なるが、一方に田舍初段の力量ありたりとて、さまで異とするに足らざれども、專門の碁家の道破する能はざる碁の眞理を道破し、而も簡勁の筆、專門の文士をして三舍を避けしむるの概あり。",
              "citation": {
                "source": "町田村の香雪園",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ二人が唄う節の巧みなる、その声は湿りて重き空気にさびしき波紋をえがき、絶えてまた起こり、起こりてまた絶えつ、周囲に人影見えず、二人はわれを見たれど意にとめざるごとく、一足歩みては唄い、かくて東屋の前に立ちぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と嘲りながら、さもいとしさに堪えざるごとく言う下に、「若いお父さんに骨をお貰い。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "うとうとあそばすと、すぐ済んでしまいます」　このとき夫人の眉は動き、口は曲みて、瞬間苦痛に堪えざるごとくなりし。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "英臣は苔蒸せる石の動かざるごとく緘黙した。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女を猴に比する事も東西共にありて、英国の政治家セルデンは女を好まず、毎にいわく、妻を持つ人はその飾具の勘定に悩殺さる、あたかも猴を畜う者が不断その破損する硝子代を償わざるべからざるごとしと。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "（工夫付かざるごとく、書抜きを投げ出して考え始める。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "工夫ついに付かざるごとく、後へ手を突いて座りながら、低い嘆息の言葉をもらす。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやなになに、禅の修行代りでなと、いかにも空とぼけたことを言いながら、遠慮するごとくせざるごとく、鷹揚に手土産を御嘉納するあたり、おのずから品が備わって、むしろほほ笑みたい位です。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等はブルジヨアの獨裁を許し得ざるごとく、プロレタリア、つまり職業勞働者の獨裁をも許し得ざるものである。",
              "citation": {
                "source": "新日本の進路",
                "author": "石原莞爾將軍の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "（痙攣する両手で頭をかかえて砂上に伏す）康頼　（気の毒に堪えざるごとく）わしが愚かなことをしたのならわしは悔いる。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれを制することあたわざるごとく）母上の手蹟だ。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（感動に堪えざるごとく）あゝ。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊寛　（不安に堪えざるごとく。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊寛　（不安に堪えざるごとく、康頼に）康頼殿、今はわしの頼みはあなた一人となりました。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "康頼　（苦しみに堪えざるごとく）神々よ。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（愛憐の情に堪えざるごとく）あなた様のこのお変わりようは！",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊寛　（倒れんとす）有王　（俊寛を支えあわれみに堪えざるごとく）お気をたしかに！",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "親の命に服従せざるごときは人間ならずとは仰せられ候えども、そは余りに親権の過大視には候わずや。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、二人は酒甕の破片を全身に突き立てたまゝ、尚知らざるごとく人々の間を吠え狂ふと、その声を聞きつけた者達は、一斉に忘却してゐたガルタンの記憶を投げつけられて戦慄した。",
              "citation": {
                "source": "碑文",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二二―二四たとへば長者のまへに、敬ひはゞかりてものいふ人の、その聲を齊ふるをえざるごとく　二五―二七我もまた言葉を亂していひけるは。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "征韓のことは洵に豊公一代の経営なるかな、されども、この海角の荒野原を剰すにだも漸く難からむとするを看れば、英雄といへども、一たび地下に瞑するや、千古の威名、はた虚栄に過ぎざるごとし。",
              "citation": {
                "source": "松浦あがた",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも前にある母の存在を認めざるごとくである。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つの生命は自然力――それは悪魔のものである――に駆られて自らは何をなせるかも知らざるごとくに他の生命に働きかける。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも拘らず、今さら一弾も命中せざるごとくいうのは何事だ。",
              "citation": {
                "source": "不沈軍艦の見本",
                "author": "――金博士シリーズ・10――",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶南洲勤王の臣として終りを克くせざるごとし。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
