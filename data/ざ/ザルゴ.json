[
  {
    "uuid": "f7005516-5ffd-581f-9ace-1e57f3bd2a02",
    "entry": "ざる碁",
    "reading": {
      "primary": "ざるご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
