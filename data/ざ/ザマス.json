        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女史はからだを、くねくねさせて、「あの、いただけないんざますのよ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は余の起きたのを見て、佳味い梨ざます、買うとくなはれといつた。",
              "citation": {
                "source": "佐渡が島",
                "author": "波の上",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は盆踊の唄ざますといつて白い齒を出して微笑した。",
              "citation": {
                "source": "佐渡が島",
                "author": "波の上",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さっきもいう通り、来年の三月には国へ帰って身請けの金を持って来る」「ほんとうざますか」「嘘はつかない」　次郎左衛門は息が詰まるほどに苦しくなった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとうざますか」と、彼女はここでも念を押した。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「九重さん」「何ざます？",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "気のせいだよ」「いいえ、ほんとうざます。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このようなうちに住むは、もういっ刻もいやざます。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごぜん、どうざます。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "憎らしい御前ざます。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "知ってざますよ」「なに、知っている※　どこのものじゃ」「江戸町の角菱楼にいなました薄雪さんざますよ」「その者は、特に達磨がすきじゃったか」「大好きも大好きも、どうしてあんなひょうげたものが好きやら、髪飾り帯下じゅばんの模様まで、身につけるほどの品物はみんな達磨の模様でありんした」「さようか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、ついでにも一つ相尋ぬるが、もしやその薄雪とやら申す花魁に、深く言いかわした男はなかったか」「知ってざます、知ってざます。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "福沢諭吉の「窮理図解」（一八六八）「世界国尽」（一八六九）「学問のすゝめ」（一八七一）などが、新しい日本の文化をめざます鐘としてひびきはじめた。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世界史的な激動は日本にもデモクラシーの声をよびさまし、労働運動と無産階級の文化・文学運動をめざますこととなった。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこそ、わざわざますらをといふ言葉が立派さうにあるので、女にもますらをだましひの所有者は澤山にある。",
              "citation": {
                "source": "凡愚姐御考",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "内所へきて、胴巻に封印をし、印鑑の紙をみていると、「親方、瀬川ざます」　と、襖の外で声がしたから、「さあ、御入り」　女房が、煙管をはたいて、「御苦労だね、一つ御頼みしようか。",
              "citation": {
                "source": "傾城買虎之巻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「思い付いたことがござます」こう云ったのは君江である。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうしもうし花魁え、と云われて八ツ橋なんざますえとふり返る、途端に切り込む刃の光」という変な文句は、私がその時分南麟から教わったのか、それとも後になって落語家のやる講釈師の真似から覚えたのか、今では混雑してよく分らない。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一例、なんす（なんし＝軽命令形）――なます……敬語ざます（ざあます）……対話敬語……ansu（思はんす・行かんすの類）……敬語……insu（いきんす・見んす・為んす）……対話敬語……insen（いきんせん）……否定右の中、なんすは、なさんすの略形、恐らく、なはんすを経過したものだらう。",
              "citation": {
                "source": "「さうや　さかいに」",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いんす・あんす、ざますは「ござります」が故意の又は放恣な発音によつて、音韻没入を来したもので、「ござります」の与へる真摯な感覚を避けてゐるやうに見える。",
              "citation": {
                "source": "「さうや　さかいに」",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、また、いつもの、我意から踊りをいい加減に切り上げるか――または、踊りの一部を勝手にお変えになるについての私への注意に相違ないと考えたのでござます。",
              "citation": {
                "source": "京鹿子娘道成寺",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざます・ありんすは、即、其形見と考へられるのである。",
              "citation": {
                "source": "ごろつきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか一日も早く堅気になりたいものと一生懸命に気をつけているのでありますが、どうかいたすとつい口の先へそうざますのありんすのと、思わず里の訛が出そうになりまして、御新造様とお話をしていましてもそれはそれはもう心配でなりません。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
