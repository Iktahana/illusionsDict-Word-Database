          "literary": [
            {
              "text": "「もり」「ざる蕎麦」何でもよいが、あのうちの下地に特徴があります。",
              "citation": {
                "source": "蕎麦の味と食い方問題",
                "author": "村井政善",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕上げはざる蕎麦です」「あの人たちは、冷や酒を際限なく飲むでしょう」「お好きですね」　うしろの棚の置き時計を直子は見た。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか郊外のおそばやで、ざるそば待っている間に、食卓の上の古いグラフを開いて見て、そのなかに大震災の写真があった。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざるそばの赤うるしのまるい笊が重ねてあったが、にっこり笑って戸外へ出た。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやに、赤うるしのざるそばの重ねたのが眼についてはなれない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざるそばの海苔の香が素敵。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
