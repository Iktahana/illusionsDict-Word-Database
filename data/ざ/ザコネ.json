[
  {
    "uuid": "2defd9d9-dcc6-5979-9a8b-85a88a03aac8",
    "entry": "雑魚寝",
    "reading": {
      "primary": "ざこね",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
