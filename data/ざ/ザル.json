    "definitions": [
      {
        "index": 1,
        "gloss": "draining basket (traditionally made of bamboo)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "年取った祖母と幼い自分とで宅の垣根をせせり歩いてそうけ（笊）に一杯の寒竹を採るのは容易であった。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人辻本工学士に拠ると信濃越中の国境に聳えている祖父ヶ岳は、「種蒔き爺さん」が笊を持った具合に現われるので、山腹雪解の頃、偃松が先ずその形に蔓って、出るのではないかという話である、偃松の仲間入は最もおもしろい。",
              "citation": {
                "source": "雪の白峰",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "巣は小さな笊のような形をしていて、思いの外に精巧な細工である。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも或日の四時過ぎに、母の云いつけで僕が背戸の茄子畑に茄子をもいで居ると、いつのまにか民子が笊を手に持って、僕の後にきていた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まァ民さん、御覧なさい、入日の立派なこと」　民子はいつしか笊を下へ置き、両手を鼻の先に合せて太陽を拝んでいる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が一斗笊｜一個宛を持ち、僕が別に番ニョ片籠と天秤とを肩にして出掛ける。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅蜊の殻を店の前の泥に敷いていた自身番の老爺は、かかえていた笊をほうり出して、半七らを内へ入れた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "皿と笊にもられていた一ツの茹卵も、一と切れの豚肉の油煮も残っていなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　米吉は、三反歩の小作と、笊あみの副業で食っている。",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三｜枚の笊に魚鱗が光つた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君は食卓に大きな笊をのせて青い莢隠元をむしっていた。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど今ごろ五月の節句のかしわ餅をつくるのにこの葉を採って来てそうしてきれいに洗い上げたのを笊にいっぱい入れ、それを一枚一枚取っては餅を包んだことをかなりリアルに思い出すことができる。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん南が狼森で、その次が笊森、次は黒坂森、北のはずれは盗森です。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　みんなは、尤もだと思って、それから西の方の笊森に行きました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてだんだん森の奥へ入って行きますと、一本の古い柏の木の下に、木の枝であんだ大きな笊が伏せてありました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "笊森の笊はもっともだが、中には何があるかわからない。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして又粟餅をこしらえて、狼森と笊森に持って行って置いてきました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　みんなはもっともと思って、そこを引きあげて、今度は笊森へ行きました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の朝、授業の前みんなが運動場で鉄棒にぶらさがったり、棒かくしをしたりしていますと、少し遅れて佐太郎が何かを入れた笊をそっとかかえてやって来ました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐太郎もまた笊をそっと袖でかくして、耕助だのみんなに囲まれて河原へ行きました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐太郎が大威張りで、上流の瀬に行って笊をじゃぶじゃぶ水で洗いました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この老人と自分、外に村の者、町の者、出張所の代診、派出所の巡査など五六名の者は笊碁の仲間で、殊に自分と升屋とは暇さえあれば気永な勝負を争って楽んでいたのが、改築の騒から此方、外の者はともかく、自分は殆ど何より嗜好、唯一の道楽である碁すら打ち得なかったのである。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯吉の食事が済むとお源は笊を持て駈出して出たが、やがて量炭を買て来て、火を起しながら今日お徳と木戸のことで言いあったこと、旦那が木戸を見て言った言葉などをべらべら喋舌て聞かしたが、磯は「そうか」とも言わなかった。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の竈の上で、笊の目を透すまで、あか／＼と日のさした處は、燒芋屋としては威嚴に乏しい。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の中ほどに大きな荒物屋があって笊だの砂糖だの砥石だの金天狗やカメレオン印の煙草だのそれから硝子の蠅とりまでならべていたのだ。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんは赤漆塗りの鉢の上に笊を置いて、桶の中から半分｜潰れた葡萄の粒を、両手に掬って、お握りを作るやうな工合にしぼりはじめました。",
              "citation": {
                "source": "葡萄水",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　次の日ホモイは、お母さんに言いつけられて笊を持って野原に出て、鈴蘭の実を集めながらひとりごとを言いました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち自家の文体を実現し了せなかつたこの作家は、一生涯習作をしてゐたといへるし、絶えざる模索の状態は彼を鬱屈させてゐたのであつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔われかのひとをこととふに〕宮沢賢治われかのひとをこととふになにのけげんもあらざるをなにゆゑかのとき協はざるクラリオネットの玲瓏をわらひ軋らせわらひしや",
              "citation": {
                "source": "〔われかのひとをこととふに〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "訓導宮沢賢治早くもひとり雪をけりはるかの吹雪をはせ行くは木鼠捕りの悦治なり三人ひとしくはせたちて多吉ぞわらひ軋るとき寅は溜りに倒れゐし赤き毛布にくるまりて風くるごとに足小刻むは十にたらざる児らなれや吹雪きたればあとなる児急ぎて前にすがりつゝ一列遠くうすれ行く",
              "citation": {
                "source": "訓導",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
