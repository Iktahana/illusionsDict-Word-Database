    "definitions": [
      {
        "index": 1,
        "gloss": "being ashamed and angry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
