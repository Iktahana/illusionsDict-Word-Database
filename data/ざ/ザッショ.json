        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "事柄の内容のみならずその文章の字句までも、古典や雑書にその典拠を求むれば一行一行に枚挙に暇がないであろうと思われる。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ○下田川と称する名称のことを未だ説かざりしが、明治以前の雑書に時に下田川の名を記すものは、別に一水の流れをなすありて下田川と呼ぶところあるにはあらず、実に永代橋下流即ち隅田川本流の佃島近きところを指していへるのみ。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐つかいは同じくにあり、狐媚狐惑の談は雑書小説に煩らわしいほど見える。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "生花はもちろん茶道、造園、能楽、画道、書道等に関する雑書も俳諧の研究には必要であると思う。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その店頭の雑書の中に積まれていたのは、例のヘボン先生の和英字書であった。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど紛々たる雑書、何ぞ信ずるに足らん。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯様いうことが稀有では無かったから雑書にも記されて伝わっているのだ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝ふるところの談、雑書に散見するもの亦多し。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗末なガランとした室内、大きなテーブル、椅子四、五脚、多少の器具、雑書、壁に引かけた帽子、外套、極めて簡素で単純な色彩であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑書にも多く記したれど、この書に選まれたるもののごとく、まさしく動き出づらん趣あるはほとんどなし。",
              "citation": {
                "source": "遠野の奇聞",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一脚の卓子を囲んで、柳沢と差向いに同じ椅子に掛けていたが、体を捻って、背後へ手を伸すと雑書を納れた本箱の上から、一瓶の角砂糖を取って、これを二人の間に居る一｜人の美少年の前に置いた。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖人・偉人・帝王・豪傑には、星辰これに付し、雲気これに応ずると信じられていたことは歴史や雑書が我々に語るところであるから、望気の術が軍陣以外の事を包含していたことも自然と明らかである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに後世方相の形が至ってにくさげなるより、方相を疫鬼と間違えたとみえ、安政またはその前に出た『三世相大雑書』などに、官人が弓矢もて方相を逐う体を図したのをしばしばみた。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他雑書皆多少の好材料を与へざるはなし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥州のそのころには寺子屋の源平藤橘の手習い手本を除いたら、一村に一冊ぐらいのごくごく珍重された三世相大雑書があった程度でありましたでしょう。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の祖父などは百姓の暇々にその大雑書を筆写していたものでした。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう向の雑書を猟ることは、尤も、相川の目的ではなかったが、ある店の前に立って見渡しているうちに、不図眼に付いたものがあった。",
              "citation": {
                "source": "並木",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭を横截って二人で上がって行くと、書棚や椅子や額や、雑書雑誌などの雑然と積み重ねられたなかで、子供の庸太郎が、喫茶台の上と下に積んであるレコオドのなかから、彼女に向きそうなチャイコフスキイのアンダンテカンタビレイをかけてくれた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所の路次うちの悪太郎どもが、古｜板塀を破って庭から闖入し、手当たり次第持ち出して行ったらしい形跡が、板塀の破れ目から縁側まで落ち散っている雑書や何かを見ても解ったが、昔ものの手堅い古建具、古畳、建築の余材、そんなものもいつの間にか亡くなってしまった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学作品も多いけれども、はっきりそうとも云えない雑書風のものもまことに多い。",
              "citation": {
                "source": "女性の書く本",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの三畳の部屋にひとり立て籠って妄想を逞しくしたり、雑書を乱読したりすることをなによりの楽しみにしていました。",
              "citation": {
                "source": "書斎",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "又斎の子が亦斎で、家業を嫌ひ、篆刻を学び、後には所謂戯作者の群に投じ、雑書を著して自ら紫軒道人と署した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も壬申以来文部へ出仕、間もなく被免、医学校へ出、編書課に在、亦免官、朝野新聞に入、成島柳北と相交、夫より工学寮の本朝学課長となり、十月来又々被免、此節は閑無事、書肆の頼に付、真片仮名の雑書編成仕居候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雑書と題する詩（剣南詩稿巻五十二）に云ふ、枳籬莎径入荊扉、中有村翁百結衣、誰識新年歓喜事、一犬皆実事としてある。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "東西｜古今の雑書を引いて、衒学の気焔を挙ぐる事、恰もマクベス曲中の妖婆の鍋に類せんとす。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、自分もそろそろもう仕事につくことにしようと思ったが、仕事といっても矢代のは整理部だったから、ただ書籍や雑誌の整理をする傍ら雑書を読めばよかったので、いわば彼のは書籍の中の旅をつづけて行くのが仕事というべきようなものだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし意味深遠なる著書は読者の縁もまた遠くして、発兌の売買上に損益｜相償うを得ず、これを流行近浅の雑書に比すれば、著作の心労は幾倍にして、所得の利益は正しくその割合に少なし。",
              "citation": {
                "source": "学問の独立",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もしお急ぎでしたら、彼方の製本に出す雑書の中を探して頂きましょう」　鎮子に示された右手の潜り戸を上げると、その内部の書架には、再装を必要とするものが無雑作に突き込まれていて、ただＡＢＣ順に列んでいるのみだった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そうした折りには、家人に命じて庭先に火を焚かせ、それに不用な雑書類などを投げ入れるのである。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「共同椅子だすけん……よござっしょうもん」　鳥打は意味がわかったらしく、青い顔をサッと青くしたようであった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
