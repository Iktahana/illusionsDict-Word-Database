[
  {
    "uuid": "8abcb591-9a60-56d3-9ffb-4b8b09f4836c",
    "entry": "ざるを得ない",
    "reading": {
      "primary": "ざるをえない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
