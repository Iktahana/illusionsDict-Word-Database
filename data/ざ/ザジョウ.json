          "literary": [
            {
              "text": "たぶん座乗者が勝手に進行の方向を変えるための舵のようなものらしい。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "式部小町の座乗していた屋形船が、波もないのに突如左右へゆらゆらと揺れ動いたかと思われましたが、底からいちじに水でもが吹きあげてまいりましたものか、あッと思った間にぶくぶくと、吸われるごとく水中にめりこみました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "またギンネコ号の艇長スコールだと名乗って、テッド博士｜座乗のロケット第一号のなかへ変装してやってきた怪漢だった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は水師提督ペリイの座乗した三本マストの旗艦ミスシッピイ号をも目撃した人である。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
