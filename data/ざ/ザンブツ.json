        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昨夜の残物（むろん酒もある）を平げる、あゝ朝酒のうまさ、このうまさが解らなければ、酒好きは徹してゐない、敬君、樹明君どうです？",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ残物と冷たく成つた豆腐汁とをつゝいても麥の交らぬ飯が其の口には此の上もない滋味なので、女房等は其の強健で且擴大された胃の容れる限りは口が之を貪つて止まないのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三｜日の間は片口や摺鉢に入れた葬式の時の残物を喰べて一｜家は只ばんやりとして暮した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち体内の廃残物の処置は睡眠中に整えられて排泄器に付されるばかりになっているのであり、新しい活動の起されるに適した状態になっている。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて脳が血液を消費するとその消費の余りの廃残物が堆積する。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃残物はすべて毒を持つものであるから精神作用から生じた廃残物は精神作用を弛緩し遅鈍にする。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その挙句は眠くなるか若しくは不快の頭痛を起すが、或る時間の休息中にこれ等の廃残物は体内器官によって徐々に搬出されるのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃残物が搬出されて新鮮な血液が脳に充ちるに及んで脳はまた徐々に爽快に働き出す。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草公園界隈には、丁度彼等四五十人を養うだけの残物が年中ある訳で、彼等の人数が殖えも減りもしないのは、そんな原因からに相違ないと見られている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "枇杷を食べる、私には初物だ、これは恐らく、昨夜の宴会の残物だらう、といつては持つてきてくれたＴ子さんにすまないけれど。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "その残物を頂戴する。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時ごろ起床、昨日の残物を飲み且つ食べる。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分もわざと潔く立って、皆といっしょに二階を下りたが、ふところへねじこんだ古雑誌と菓子や煎餅の残物とが今夜のお礼代りかと思えば、ばかばかしいような気もして、ここでひそかに例の虎と抱き合ってしばらく何だか泣いてみたかった。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸時代の残物で、日本橋区内のコブであった汚ない町が一掃されたが、哀れな焼け出されも沢山あった。",
              "citation": {
                "source": "テンコツさん一家",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "マア云わば魚の残物のようなもので直が安い。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十日の間味噌汁はいつも、昨日の昼或は夜のあらゆる残物をぶち込んで煮なおしたものであった。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "屠手のあるものは残物の臓腑を取片付ける、あるものは手桶に足を突込んで牛の血潮を洗ひ落す、種牛の片股は未だ釣るされた儘で、黄な膏と白い脂肪とが日の光を帯びて居た。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その獅子の後に従いて、獅子の獲物の残物に、其腹を肥やすことは、土人の常に目撃する所なり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母が下女を呼んで残物を勝手へ運ばした。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしなんぞはあの残物でも貰うことにします。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは決して手を洗わず、また魚の腐った残物や子供の糞便を決して掃除しない。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが無造作な日本製の新字であったか、はたまた中代以前に外国から模倣したものの珍しい残物であるかは、独断の危険な場合が多いようである。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "適当な距離まで壁に近寄って、懐中電灯をゆっくりと注意深く動かしつつ、くたびれた彫刻の遺残物全体に光を当てた。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の気持ちや、人類誕生以前に遡ると思われる悠遠の昔からの悍ましい遺残物を目にした時の眩暈感を振り返ってみると、我々が平静を装えていたことに驚くばかりだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は漁夫の残物堆から、面白い貝を若干ひろった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "種子は油をしぼり取った残物であるが、油気があるので、泥が固くなり、太陽で焼かれる迄、防水上塗になるのである。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "民衆の記憶はそれらの過去の残物の上に漂っている。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "想像するに、それは切支丹村の切支丹族たちが、食べあました残物かも知れません。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
