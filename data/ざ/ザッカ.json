    "definitions": [
      {
        "index": 1,
        "gloss": "miscellaneous goods",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
