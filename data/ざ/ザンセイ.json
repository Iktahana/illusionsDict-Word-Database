    "definitions": [
      {
        "index": 1,
        "gloss": "the remainder of one's life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
