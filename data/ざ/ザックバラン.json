        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "頂上内院火口の西壁、剣ヶ峰の側からなぎ落されて、直線に突き切ること三里、力任せにたち割った絶壁の斜面に、墜石崩石は、ざっくばらんにほうりだされている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、工人達も、彼に対して、ほかの小山や守田に対するよりも、親しく、ざっくばらんであるように見えた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場には、悪党上りが集った場所によくある、留置場のような、一種特別な、ざっくばらんな空気がかもされていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "税務署長がまた見掛けの太ったざっくばらんらしい男でいかにも正直らしくみんなが怒るかも知れないなんといふことは気にもとめずどんどん云ひたいことを云ひました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもをかしいどうもをかしい、どうもをかしいとみんなの顔つきをきょろきょろ見ながらその割合ざっくばらんの少しずるい税務署長が思ひました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "会費について二三照会せられた方がありますから、ざっくばらんにここへ書き添えて置きます。",
              "citation": {
                "source": "雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　銀子もざっくばらんに挨拶した。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならソクラテスは、街路に立ってだれにでも話しかけ、少しも権式ぶらないざっくばらんの人物なのに、プラトンはアカデミイの学院に閉じこもって、典雅に身を持していた人物だから。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に詩と小説との比較に於て、小説を俗衆的であるという意味は、プラトンとソクラテスの比較に於て、後者の人物がよりざっくばらんで平民的に親しみ易かったという、表面上の気質や趣味性にのみ関すべきで、芸術としての本質上には別問題とすべきである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して後者の詩材は、主に恋愛その他の現世的な生活実相から取ったもので、俗にくだけた、ざっくばらんの、窮屈に四角張らない平民趣味の情操を特色していた。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、ざっくばらんに云うと、私の家には雌の金魚が一ぴきだけでしょう。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それではこちらも、ざっくばらんにぶっつけましょう。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、君枝はざっくばらんな言い方に頼もしさを感じ、ふとまじる大阪訛りになつかしさをそそられ、丁寧な口調の出る時は何か赧くなった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ざっくばらんに申上げますが……」　と私は云いました。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、ざっくばらんの話ですが」「お言葉の、その、幸福というのが、私にはよくわかりません。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう少しざっくばらんにいってくださいよきのうきょうのお交際じゃなし。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう顔馴染ででもあるかして、駈けよるとざっくばらんに言いました。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちのことであるゆえ、重大事とにらんで参ったことであろうが、実は少しばかり奇っ怪なできごとが突発いたしよってな」　思いに余ったもののごとく、すぐと事件の内容に触れてこられましたものでしたから、右門も相手が大徳川の顕職にあることも忘れて、ひざをすすめながらざっくばらんに尋ねました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し打明けて、ざっくばらんに話してくれると好いですけれど……」「どうも中国の人間はそうは行かんですけえ、人物が小さくって、小細工で、すぐ人の股を潜ろうとするですわい。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なまじい番頭さんなぞが顔を出すよりも、わっしが名代に出かけて行って、ざっくばらんにお葉に当たってみた方が無事かと思いますが……」「そこで、よもやとは思うが、若旦那とお葉とはまったく色恋のいきさつは無いのですね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "川越次郎兵衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年団の寄合で、村会議員の清助に会った時、彼はざっくばらんに自分の意見を話した。",
              "citation": {
                "source": "秋の反射",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女たちは、女学生として、自分たちの勉強のしかたを研究し、研究するための委員を組の中から選んで、先生とざっくばらんに相談し、希望もうちあけてよいのではないでしょうか。",
              "citation": {
                "source": "美しく豊な生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ざっくばらんに云えば、そこがこの作者の云わば狙いどころとしての成功であり、作品のひとくせあるところでもあるのではなかろうか。",
              "citation": {
                "source": "観念性と抒情性",
                "author": "――伊藤整氏『街と村』について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそざっくばらんに言いましょうか」　と、暫く躊躇した後、「私もあなたと同じく一人ものです。",
              "citation": {
                "source": "好色破邪顕正",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「時に御宅には赤ちゃんがおありですか」と私はざっくばらんにたずねた。",
              "citation": {
                "source": "狂女と犬",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうこうなったらわたしも、ざっくばらんに何もかも申し上げます。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうです、ざっくばらんに一つ、その話をしてくれませんか。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
