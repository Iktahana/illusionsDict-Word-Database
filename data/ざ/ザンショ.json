[
  {
    "uuid": "f2160ec3-cb2c-593c-b842-0ea8b49cc5f5",
    "entry": "残暑",
    "reading": {
      "primary": "ざんしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
