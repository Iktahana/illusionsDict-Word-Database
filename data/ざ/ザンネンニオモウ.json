[
  {
    "uuid": "37947e37-92ea-51c1-98c7-3ffd59737c60",
    "entry": "残念に思う",
    "reading": {
      "primary": "ざんねんにおもう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ウ行"
      ],
