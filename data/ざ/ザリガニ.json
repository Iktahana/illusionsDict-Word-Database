        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "サルカニ（ザリガニ）やトンギョ（トゲ魚）とり。",
              "citation": {
                "source": "忘れえぬ風景",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅鱒やザリガニを放つてあると云ふことだが、あんまり波がないので、死んだ湖のやうに見える。",
              "citation": {
                "source": "摩周湖紀行",
                "author": "――北海道の旅より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の住む矢口の渡し界隈にザリガニが繁殖しザリガニ料理は西洋では最高級のひとつだといふ話であるがどんな料理であらうか。",
              "citation": {
                "source": "大井広介といふ男",
                "author": "――並びに註文ひとつの事――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、グレーテルには、ザリガニのこうらが、わたったばかりでした。",
              "citation": {
                "source": "ヘンゼルとグレーテル",
                "author": "HANSEL UND GRETEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし伊勢えびには鋏がないが、ロブスターにはザリガニのように大きなはさみがある。",
              "citation": {
                "source": "アメリカの牛豚",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、かわいそうなヘンゼルは、いちばんじょうとうのごちそうをもらいましたが、それにひきかえ、グレーテルのほうは、ザリガニのこうらをもらったきりでした。",
              "citation": {
                "source": "ヘンゼルとグレーテル",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "図211はザリガニを、図212は鯉を示すが、この写生図は、鯉の太って曲った身体や、尾の優美な振れ方を、充分にあらわしてはいない。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
