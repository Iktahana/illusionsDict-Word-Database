    "definitions": [
      {
        "index": 1,
        "gloss": "remaining an idle spectator",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
