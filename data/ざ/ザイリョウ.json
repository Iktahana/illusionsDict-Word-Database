[
  {
    "uuid": "f958bb2b-c8e1-5ccd-8bd4-1e6decf0abcd",
    "entry": "材料",
    "reading": {
      "primary": "ざいりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
