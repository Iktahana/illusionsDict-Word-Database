        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――三の輪の知人在宿にて、双方心易く、四方山の話に夜が更けた。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、しかるに御在宿でない。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい当番たりとも在宿して火の用心を怠らぬようにいたせというのが一つ。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族と一緒に遊びに出掛けたはおろか、在宿して団欒の歓楽に興じた記事もまた見えない。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「藤阿弥は在宿か」「へえい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "退省て下宿へ帰る、衣服を着更る、直ぐ何処へか遊びに出懸けて、落着て在宿していた事は稀だという。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋ねて見ると幸い在宿、乃ち面会して委細を咄して依頼すると、「よろしい承知した」ト手軽な挨拶。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女狩殿、御在宿で御座ろうか、ちと、御意を得たく」「拙者が、右源太で御座るが」　入口を入った武士が、右源太を見て「始めて御意を得申す。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "すれば、五日の夜は必定上野介在宿に極まったというので、討入はおおよそその夜のことになるらしい大石殿の口ぶりでもあった。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりよく兄も非番で在宿していた。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "過る比福羽君に一寸御目にかゝり、御咄きゝ候間、ちと／＼三八在宿に候まゝ、御とまりがけにても御出待上候。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "在宿の事はいそがしく、前より申上かね候。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『何ですか、御在宿で御座ますか。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在宿役人を勤めてるものは、大概この地方に人望のある旧家ばかりだからね。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "「秋山要介在宿」と。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月の十日過ぎ私が上京した折、ＹＷＣＡに電話をかけてみると、丁度在宿だつたのでお婆さんを訪れたら、喜んで信州で別れて以來旅行して來た話を私にして聞かせて、日本は到る處景色のよいおもしろい處があると大喜びであつた。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "長庵さん、お在宿かえ」「居るよ。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっ、親分｜在宿かえ。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "宙に浮く屍骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皆さん、御在宿かな？",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "悲願百両",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の東風から参堂の上是非文芸上の御高話を伺いたいから御在宿を願うと云う先き触れがあったので、朝から心待ちに待っていると先生なかなか来ないやね。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二本差が二人――」「馬鹿野郎、御武家を野郎呼ばはりする奴があるものか、無禮討にされても俺の知つたことぢやないぜ」「でもね親分、立派なお武家が二人、敷居を舐めるやうにして、――平次殿御在宿ならば御目にかゝりたい、主人姓名の儀は仔細あつて申兼ねるが、拙者は石津右門、大垣伊右衞門と申すもの――てやがる。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "城の繪圖面",
                "note": "青空文庫"
              }
            },
            {
              "text": "「平次親分御在宿か、折入つてお願ひの筋があつて參つた。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美しき人質",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸い明智は在宿であった。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「筑前どのには、御在宿か。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "市中に在宿の侍たちもある。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
