[
  {
    "uuid": "2b9d5c4b-0cd2-5ea6-823c-a79d4b83f0e2",
    "entry": "残",
    "reading": {
      "primary": "ざん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "接頭辞"
      ],
