  {
    "uuid": "0bfd103d-e805-56cc-a3fe-4233d02903cd",
    "entry": "斬",
    "reading": {
      "primary": "ざん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "beheading",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "アポリネールは、前世紀的な最後の人と呼ばれてゐる位だから、此の場合格構な例ではないと思はれるかも知れないが、然らば寧ろ突飛な迄に斬新なピカビヤでもツァラでもブルトンでもアラゴンでもよろしい。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の血縁の一人は夜道で誤つて衝き當つた人と斬り合つて相手を殺し自分は切腹した。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが近頃この事について斬新な力学的の方面から説明を試みた人がある。",
              "citation": {
                "source": "卵の形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "運命に叩き伏せられたその絶望を支えにしてじりじり下から逆に扱き上げて行くもはや斬っても斬れない情熱の力を感じさせる。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "重衡、斬られて後、千手は尼となって善光寺に入り、歿したときは二十四歳。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また第二の山では牛若丸が六人の賊をめちゃくちゃにたたき斬る、そうして二つ三つに切った死骸を蓆で包んで川へ流しに行くまでを精細な数コマに描き分けたものらしい。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君を斬る必要もなく、僕が斬られる必要もない、といふのである。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は幕末の革命に飛び出したり、時には辻斬強盜などもやる方だが、犀星のは本當の古武士であつて、君主の前で禮節正しく構へてゐる。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果は却つて遺族の敵愾心を挑發し、子の正行をして「七度生れて尊氏の首を斬らん」と叫ばせたが、尊氏がもしそれを聞いたら、人生孤獨の感を深くし、一層寂しく暗然としたことだらう。",
              "citation": {
                "source": "足利尊氏",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「斬られの仙太」を大河内が演りたがッとッたが、三好氏さえよければやッてみたい。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「冗談言っちゃいけねえ清水の御貸元、それァ何かの間違いだ、俺ァ人殺しなンぞした事がねえ」　「何を言やがるんだ、言い逃れは聞かねえ、立派に証人があるんだ、小五郎ッ覚悟を決めて仕度しろッ」　小五郎、突然斬って来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝茶店の近くの道　小五郎と次郎長、斬り合う。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「斬られたなァ武井のお貸元の身内だと言うじゃねえか」　「そうだって。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人がかりで殺ったンだってね」　「いや、三人居るのは居たが、斬り合ってたのは一人さ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「先刻も武井の児分衆が来て訊ねていなすったが……誰だか判んねえ」　「斬る前に名乗らなかったのかな」　「俺の見た時はもう斬合がはじまっていたんだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝離れ　七五郎、傍の若い者に、　「おッ、兄哥さん、お前さんに訊ねるが、あれァ確か武井の御貸元で御座ンすね」　「そうだ」　石松が、　「そうか、あれが武井のども安親分か」　七五郎が若い者に、　「聞きゃ今日の昼間、町外れの街道で武井の御身内が一人斬られなすったと云う話だが。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から四年前に俺の身内の佐太郎を殺した上、金をとって逃げた神沢の小五郎を今日此の町外れの街道で俺が叩っ斬った。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　「確かに俺が叩っ斬って、首は児分が持って先へ清水に帰ってしまった」　「よッよッよくもきッきッ貴様ッ」　「何を吃りやがるんだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおども安、手前どもりゃ人を斬るって話だが、此処で一ぺん、どど、と吃って斬って見ろ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい斬れッ」　用人棒の一人が次郎長の背後に廻る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓から顔を出した吉兵衛がいきなり後から斬る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「仇討だとよ」　と言う声を三次耳にしてフト見れば、　鵜飼三四郎が棚倉伝八郎初め十余名の浪人者と斬り合っている。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "追わんとする三四郎に討って掛かる浪人者二三を斬って追う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次飛退って、Ｔ「と近え中に乗り込むからそっ首洗って待ってなよ」　馬鹿にされて怒った門弟共の斬り込むのを三次逃げ廻って表へ飛び出した。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "遂に伝八を真向唐竹割、バラリンズンと斬り下げた。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（若しくは　三四郎が伝八を斬った後、他の門弟大勢と立廻りの真最中にＦ・Ｏして下さい。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなたにてきらめく川やさてはまた遠山の雪その枝にからすとまればざんざんと実はうちゆるゝこのときに教諭白藤灰いろのイムバネス着ていぶかしく五助をながめ粘土地をよこぎりてくる",
              "citation": {
                "source": "〔洪積の台のはてなる〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "理智で切りきざんだ工合いの芸でなければ面白くないのです。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日はいよいよ鷹が貰えると思ってさんざんに待ちかねて、やっとその日になってみると鷹は今ちょうどトヤに入っているからもう二、三日待ってくれというのである。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "淺慮で惡うござんしたね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
