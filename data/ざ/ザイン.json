[
  {
    "uuid": "070ad309-0695-565f-a0c8-65ec3e9a8901",
    "entry": "ザイン",
    "reading": {
      "primary": "ザイン",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "existence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "之を要するに、物は心を予想し、心は物を予想するのがザインであり、それを展開するものが夢である、といふことである。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロケーションと書けばその場所の選択に悩み、セットと書けばそのデザインに困る。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "残念ながらわが国の書店やデパート書籍部に並んでいるあの職人仕立ての児童用絵本などとは到底比較にも何もならないほど芸術味の豊富なデザインを示したものがいろいろあって、子供ばかりかむしろおとなの好事家を喜ばすに充分なものが多数にあった。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人で劇作家で、作曲もしバンドの指揮もし、デザインをやるという奇術師のようなジャン・コクトオですら、小説を書けば極くあたり前の紋切型の小説を書いている。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし同時に、このデザインを建てた程の芸術家ならば、キットこのスフィンクスの鼻の表現を残しておく事が、永久に人類を鼻の表現に対して無自覚に終らしむる所以である事を考え得ぬ筈はありませぬ。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "統一感を持ってデザインされた印刷用の文字は、フォントと呼ばれます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "放映時間の都合で途中をカットされるのもたまらないでしょうが、丹念に一つ一つデザインしていったシーンを無理矢理ねじ曲げられるのは、映画監督にとって、身を切られるような思いでしょう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "白黒からスタートしたマック用にデザインされたハイパーカードは、当初カラー化を想定していませんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "透明なシートを一枚、背景にかぶせてデザインを仕上げる手法には感心しましたが、手直しをやりやすくする工夫がもう少しあってもいいとも感じました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来上がったブックはさっそく、「建築デザイン」、「在宅ワーキング」、「アプリケーション日本語環境」など、ニフティーで出入りしていたフォーラムに登録しました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブックのデザインやグラフィックスの処理、パッケージの仕立てとどこを取ってみても、Dairiqui の作品は、清潔な美意識に支えられた上品な手仕事で貫かれています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして先ずは机に置く気になるデザインを決め、ここで固まったアタッシュ・ケース型の筺体に図体のでかいマシンのパワーをすべてぶちこむ方針を取った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして従来のねじ回しの握りは数百年誰も文句を言わなかったのが不思議なくらいできの悪い代物と指摘し、ここで会場の聴衆に向かって「最良のデザインはどんなもんだろうね」と問い掛けた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜のタクシー運転手もかくやと思わせる無愛想な対応ぶりで、アラン・ケイに言わせれば「こんなインターフェイスのデザインはこれまでのねじ回しの握り同様、最悪」となる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしもう一度一からはじめるつもりできれいにデザインし直せば、マイクロコンピューターを使ってかなりのことができる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "行き着く先は、電脳社会をどうデザインするかとなるに決まっている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ハードウエアでは、独自に開発したＲＩＳＣタイプのマイクロコンピューター、ＳＰＡＲＣのデザインを半導体メーカーにライセンスし、ハード・メーカーにＳＰＡＲＣマシンの開発を促して、標準アーキテクチャを確立する。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "拡張本の開発チームによれば、デザインした時点での目標は「本を電子化することで何かが失われたと読者に感じさせないこと」に置かれていたという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、あらゆる世代の人間が使いこなせるようにデザインした個人のためのコンピューターのアイデアに、魂の奥の方をぐっと掴まれた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国は漢字の国だから、目に見えない正方形の枠に合わせてすべての文字がデザインされる。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをまねて、われわれの先人たちは、それぞれに大きさがいちじるしくことなるかな文字をも、同面積の、小さな正方形に押しこめてデザインしなおすことに成功し、そのことによって、かな漢字まじり文のタテ組み印刷が可能になった。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "写植詰め打ちは書体デザインの枠を正方形に固定したまま、とりあえず字間距離だけを微調整してみせるアクロバットの産物にすぎないからだ。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきおいヨコ組みが中心になると思うが、そうなったとき、あくまでもタテ書きを前提にデザインされた明朝体のままで突っ走ることができるかどうか。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "表示文字の大きさを変えてみるだけではなく、ヨコ組み、フォントの再デザイン、かな文字中心のプロポーショナル組版、行間や余白の設計しなおしといった新しい文章表示の方法が、一つ一つ、これまでの私たちの常識をひっくりかえすようなしかたで大胆にためされることになるはずだ。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり家屋に例へて云つて見れば、すべて全体の構造のデザインをやることで、もう棟梁株でなければ手を着けることの出来ない境である。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "制服なんかで街ィ歩くのは、ゴメンだからな」　夏服は、だれも見ていないところでさえ着たくないような、最低のデザインだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "円形の金色の縁どりのなかに、文字があるデザインだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっと、デザインが変わりましたね」　二羽のカササギが、円盤をかこんで立っている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、円盤はレーベルで、そのなかのデザインは変わっていない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "新潮社装幀室の緒方修一氏には、デザインのお世話になっただけでなく、決定的な場面で事態を打開する、ナックル・ボールのような数々の助言をいただいた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
