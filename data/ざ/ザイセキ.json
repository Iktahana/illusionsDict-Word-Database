[
  {
    "uuid": "a0dc46b8-a890-5936-b312-c5e4243a8e97",
    "entry": "在籍",
    "reading": {
      "primary": "ざいせき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "being enrolled (at a school)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やはり弘前高等學校の理科に在籍してゐた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ美術学校の塑像科に在籍中だった三男が、それを編輯いたしました。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝大の医学部に在籍。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大学に在籍した二年間でできた唯一の友人だった。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし在籍していた大学の図書館の一枚十円は例外的な馬鹿安で、普通の大学では三十円、町場のコピー屋では五十円ほどもしていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして天国から地獄へと真っ逆さまとなったＤＲＩ在籍当時、吉本さんは同社版のＷｉｎｄｏｗｓにあたるＧＥＭに取り組んでいた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "忌々しくてならないので、帰ると直ぐ「鴎外を訪うて会わず」という短文を書いて、その頃在籍していた国民新聞社へ宛ててポストへ入れに運動かたがた自分で持って出掛けた。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時抱一は万朝報社に在籍して黒岩の秘書のような関係であったが、読売新聞社から紅葉を朝報社へ引抜こうという献策をして、黒岩の内意を承けてその斡旋方を私に持込んだ。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "松隈内閣だか隈板内閣だかの組閣に方って沼南が入閣するという風説が立った時、毎日新聞社にかつて在籍して猫の目のようにクルクル変る沼南の朝令暮改に散三ッ原苦しまされた或る男は曰く、「沼南の大臣になるなら俺が第一番に反対運動する、国家の政治が沼南のお天気模様で毎日グラグラ変られて堪るもんか、」と。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二、三日過ぎて、偶然沼南夫妻の在籍する教会の牧師のＵ氏を尋ねると、Ｕ氏はちょっとした咄の途切れに、「Ｙはこの頃君のとこへ行くかい？",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃高谷塾以来の莫逆たる西源四郎も同じ語学校の支那語科に在籍していたので、西は当時の露語科の教師古川常一郎の義弟であったからなお更｜益々交誼を厚くした。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "面倒だから、たゞ大学生と称んでゐたが、実際では何処の大学の卒業生であるか、または在籍者であるかも知らなかつた。",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前五時十五分、北緯三十六度東経百四十三度ノ海上ニアル茨城県湊町在籍ノ鮪船第一｜大徳丸ハ有力ナルＳ国軍用機ノ大編隊ヲ発見ス、高度約二千メートル、進路ハ西南西。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、渡辺が在籍した当時、この学科では高周波加熱、現在の電子レンジの原理を応用し、木材を乾燥させたり米を乾燥させて味をよくしてみたりと、いかにも親しみやすく、逆にエレクトロニクスの常識からすれば風変わりな研究が行われていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "海軍在籍中にまとめた論文でワシントン大学から博士号を得た直後の一九七二年、キルドールは兵学校の掲示板で、インテルの４００４の「チップ上のコンピューター――二五ドル」という広告を見た。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "シモニーはパロアルト研究所在籍時、アルト用のエディターとして広く使われたブラヴォーを書いていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「高橋刑事をやって調べさせたんですが、とにかく現在の在籍者は、被害者とあの亀之介の両名だけだったそうです。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、在籍人員から出席人員をマイナスすることが容易じゃなく、報告する前に数秒かかって口の中でくりかえし計算し、電車の事故などで遅刻者が多い時など、どうしても副級長に計算してもらわねばならなかった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民の義務として、在籍しているのではない。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボストン在住の著名な権威、ライマン医師はそれを一九一九年ないし一九二〇年、モージズ・ブラウン・スクールの最終学年在籍中に過去の研究から神秘学の研究に突然転じた時点とした。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "島文教場は児童の在籍数といふ学校である。",
              "citation": {
                "source": "又三郎の学校",
                "author": "小穴隆一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おなじ部署に在籍しております。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "調査部に在籍して仕事をしたのは三年とちょっとでした。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三五年から一九三八年まで社員として在籍していたはずの、中原順子という女性についての記録が残っているなら、その記録を私に公開してもらえないか、という内容の手紙だ。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "保存してある昔の記録を見たところ、中原順子は確かに一九三五年から一九三八年まで、在籍していたという。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
