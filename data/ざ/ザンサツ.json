[
  {
    "uuid": "a0f1d30b-93c4-5f84-bcc0-f84bc590f791",
    "entry": "惨殺",
    "reading": {
      "primary": "ざんさつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
