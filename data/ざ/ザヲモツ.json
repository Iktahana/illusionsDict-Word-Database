          "literary": [
            {
              "text": "そして、何時の間にか小さな置座を持つて来てくれた。",
              "citation": {
                "source": "潮干狩",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことほぎ神座を持つて廻つて、遂に神楽と言ふ一派の呪術芸能を開いたものでも、亦「ほかひ」である点では一つであつた。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、説経太夫が座を持つて、小屋の中で語る様になるまでには、傘の柄を扇拍子で叩いた門端芸人としての、長い歴史があつたであらう。",
              "citation": {
                "source": "信太妻の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、それ／″＼座を持つてゐたので、最初は、市内の彼方・此方で演じてゐたのだが、遂に吉原に押し込められるやうになつた。",
              "citation": {
                "source": "ごろつきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、彼等が最初、座を持つてゐた時には、村々によつて、其が違うた。",
              "citation": {
                "source": "ごろつきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "只彼が京都大学で哲学講座を持つてゐる××博士を敬慕しはじめて、三高を出るとその儘大学の文学部に移つた事だけが、昔の仲間に伝はつた。",
              "citation": {
                "source": "朧夜",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての人間は星座を持つ。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
