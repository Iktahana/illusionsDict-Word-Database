        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "過失傷害致死とかいふ罪名でした。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供にも、どういふわけだか、その技師の罪名と運命を忘れる事が出来ませんでした。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "過失傷害致死とかいう罪名でした。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供にも、どういうわけだか、その技師の罪名と運命を忘れる事が出来ませんでした。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供にも、どういふわけだか、その技師の罪名と運命を忘れる事が出來ませんでした。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お紺の亭主はなんにも知らないというので、この事件に関する重い仕置を免かれたが、平生の身持よろしからずという罪名のもとに、入牢百日の上で追放を申し渡された。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男が、或る微妙な罪名のもとに、牢へいれられた。",
              "citation": {
                "source": "あさましきもの",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の罪名は、結婚詐欺であった。",
              "citation": {
                "source": "あさましきもの",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして其罪名自体が更に更に意想外であつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが自らの身の上に及んで来て、共犯者だと云はれて、否応なしに令状を執行されて、極重悪人の罪名を附せられた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに極重悪の罪名を負せられ、夜を日に継ぐ厳しい訊問を続けられ、果ては死を以て罪を天下に謝さなければならないと云ふ、そんな大胆な覚悟は、彼が心中には未だ嘗て芽を吹かうともしたことはないのであつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の左肺に故障のあるのを、その病院で発見せられ、これがたいへん自分に好都合な事になり、やがて自分が自殺｜幇助罪という罪名で病院から警察に連れて行かれましたが、警察では、自分を病人あつかいにしてくれて、特に保護室に収容しました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺人｜幇助という立派な罪名があります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺人幇助という立派な罪名があります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供心にも、どういふわけだか、その技師の罪名と、運命を忘れる事が出来ませんでした。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自殺｜幇助罪という不思議の罪名であった。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今其罪名を責むるを蒙り、其状を逼らる。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、一たい君はどう云う罪名にしようと云うんだね？",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どう云う罪名ですって？",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "レストレード君、これがすなわちこの犯人の罪名だよ。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外、自己弁護だなんぞという罪名もまだ無かった。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "重い罪名を負わされる。",
              "citation": {
                "source": "燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "耀ける金剛石と汚れたる罪名とは、孰か愛を割くの力多かる。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『十誦律』に、優波離が仏に詣り、〈比丘の呪術をもって、自ら畜生形と作り、行婬す〉、また〈三比丘の呪術をもって、倶に畜生形と作って行婬〉する罪名を問う事あり。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この前後に姓名、年齢、原籍、罪名等について、それはそれは繁雑きわまる取調べがあった。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪名は官吏抗拒、および治安警察法違犯であった。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく、職務執行妨害とでもいうような罪名で、ともかくも、警察へ拉して行こうという肚らしいのです。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
