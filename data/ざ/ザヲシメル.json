    "definitions": [
      {
        "index": 1,
        "gloss": "to take a seat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（列の人々一拝し、おのおの座具の上に座を占める。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "表半分雨戸をしめ家の中は乱雑、座を占める席もないほどである。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "与五郎はその松明を打消して、おなじく縁にあがり、両人座を占める。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふっくらいたして、なかなか坐り心地がよいわい」　気概五十四郡の主を呑むかのごとくに、どっかと座を占めると、何思ったかふいッと命じました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし座を占めると同時だった。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、私はあえて断言するが、近い将来に観念芸術の王座を占めるものは、機械と最も密接に結びついた芸術――さしずめ第八芸術としての映画だろうと思う。",
              "citation": {
                "source": "文芸は進化するか、その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だか言った、電車で女を見るのは正面ではあまりまばゆくっていけない、そうかと言って、あまり離れてもきわだって人に怪しまれる恐れがある、七分くらいに斜に対して座を占めるのが一番便利だと。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の人々は彼の後に少し離れて座を占める。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして矢張小さくはしつこいやうな身體の動かしやうで、すつと通つて、紫檀の机の向うに座を占めると、まだ挨拶も交さぬ駿介の顏を、眞正面からじろじろと見た。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "処がこのような純粋直観が吾々の 〔Gemu:t〕 に住み得る（〔dem Gemu:te beiwohnen〕）のはそれが主観の形式的な Beschaffenheit として即ち「外観一般の形式」として即ち直観形式として主観の内に座を占めることに依るのであるという。",
              "citation": {
                "source": "物理的空間の成立まで",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "云い換えれば純粋直観が主観の内に座を占めると考えられる時それがとりも直さず直観形式なのである。",
              "citation": {
                "source": "物理的空間の成立まで",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故純粋直観が主観の内に座を占めると未だ考えられない間が所謂純粋直観であり、純粋直観が主観の内に座を占めると考えられる限りが直観形式である。",
              "citation": {
                "source": "物理的空間の成立まで",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓子の中央は両側からくびれていて、そこにふたりの取締人―― Croupier が向い合って座を占める。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゐたか、ね」と云ふ勇の問ひに答へて、「島田君はゐなかつたから、あす午前に來ると云ひ置いて來た」と、渠はどツかり、玄關の立て寄せた障子に近い爐ばたへ座を占める。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて馭者がてんでに馭者台の上に座を占めると、二台の馬車がつづいて駆け出した。",
              "citation": {
                "source": "遠野へ",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生は白い金巾の幕で、硝子戸の奥が、往来から見えないようにしてあるので、私はその床屋の土間に立って、鏡の前に座を占めるまで、亭主の顔をまるで知らずにいた。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おやいらっしゃい」と御母さんは軽く会釈して、椽に近く座を占める。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い毛布に煙草盆を転がして、二人はよきほどの間隔に座を占める。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "（語る中に、そろそろと女子の傍へ座を占める。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は電車に乗ると、なるべく若い婦人の身近くを選んで座を占める。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚のアラが美味であることは浜そだちの日本人なら大がい知っているが、日本の肉屋がハキダメへ捨ててるものが獣肉中の王座を占める珍味だということは全く知られていない。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その点では、関東方面にあるやなぎがれいなど、実に特等品の座を占めるだろう。",
              "citation": {
                "source": "小ざかな干物の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言っても、松葉がれいは、その漁獲がやなぎがれいのごとくおびただしくないから、その美味さと漁獲の少なさから、いやおうなしに、松葉がれいが特等の王座を占めるといったふうな干ものである。",
              "citation": {
                "source": "小ざかな干物の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんといっても四月から当分の間、あゆが王座を占める一つの理由は、この季節には、これに匹敵するような気の利いたうまい魚が他にないからであろう。",
              "citation": {
                "source": "弦斎の鮎",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体学名では早く名づけた種名が主座を占めるので、そこでこんな奇現相を呈し決してその自然の関係を表わしていない事になる。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その入口からは、待っていた乗客が案外にすいている車と見るやなお更に先きを争い、出ようとする女房を押しかえして、われがちに座を占める。",
              "citation": {
                "source": "深川の唄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "重ねて申しますが、現代におきましては、椎茸は、食用きのこの王座を占めるものでありまして、国内の消費はもとより、海外に於ける日本シヒタケの需要激増に伴ひ、先づ中国を筆頭とし、ついで、アメリカその他の先進国も、競つてその大量輸入を計画中であります。",
              "citation": {
                "source": "椎茸と雄弁",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
