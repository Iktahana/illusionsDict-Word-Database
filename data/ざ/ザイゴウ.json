[
  {
    "uuid": "f6e6e906-b72f-509a-8913-74dda1168c2c",
    "entry": "在郷",
    "reading": {
      "primary": "ざいごう",
      "alternatives": [
        "ざいきょう"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
