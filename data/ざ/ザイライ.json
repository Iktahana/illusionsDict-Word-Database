[
  {
    "uuid": "6563a5c3-9c64-555a-9934-3fa3e2b72424",
    "entry": "在来",
    "reading": {
      "primary": "ざいらい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
