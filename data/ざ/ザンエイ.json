  {
    "uuid": "71bda44b-d9c6-507d-908e-1e2688e0aa72",
    "entry": "残映",
    "reading": {
      "primary": "ざんえい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "afterglow (of a sunset)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人は恢復期の悦びに和らぐ眸をどうしても向うに見える樹木の残映にふりむけたくなるのだ……。",
              "citation": {
                "source": "苦しく美しき夏",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "対岸には夕焼の残映が漂っている。",
              "citation": {
                "source": "小さな旅",
                "author": "富田木歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親を、破滅させて、陋巷に窮死させた、あの残忍な一味の主魁が、今や、一世の栄華を擅にして、公方の外戚らしく権威を張り、松浦屋の残映たる、自分の舞台を、幕を張り廻らした、特別な桟敷から見下ろそうとするのである。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "時雨は現在では、さまざまの思想と生活との推移から複雑な人になっているが、内心にはいつも過去の日本橋ッ子としての気魄が残映して、微妙にその感情を操作しているように見える。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "序文／自序",
                "note": "青空文庫"
              }
            },
            {
              "text": "残映が、山の上を帯のように長い雲をぼんやりと紅く染めている。",
              "citation": {
                "source": "みやこ鳥",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この、戦争のような地上に引きかえて、空は、残映から夜へ移ろうとして、濃紺と茜との不可思議な染め分けだ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "この関係こそ、上代文化の地盤をなしたところの、上代社会関係の象徴的残映であったのである。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
