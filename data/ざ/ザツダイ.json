        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（昭和11・１「文藝春秋」）夏季雑題市中の夏　市中に生まれて市中に暮らして来た私たちは、繁華熱鬧のあいだにもおのずからなる涼味を見いだすことに多年馴らされている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正13・12「女性」）新旧東京雑題祭礼　東京でいちじるしく廃れたものは祭礼である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "季以外の雑題を取り季を結んでものすべし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "又次の年壬午の「春日書事、次霞亭先生丸山雑題韻五首」の七律第二首が「憶昔両回馬首東」を以て起つてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "『枕山絶句鈔』辛丑の集に「結城雑題寓弘経寺。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」〔結城雑題弘経寺ニ寓ス〕と題する作四首がある。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅痴が「結城山寺雑題」に「山囲孤寺雪霜早。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
