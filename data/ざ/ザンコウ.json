[
  {
    "uuid": "a199d3bd-adf0-5932-8514-82a773de49fa",
    "entry": "残光",
    "reading": {
      "primary": "ざんこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "afterglow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もはや日没ちかく、残光を浴びて山の峯々が幽かに明るく、線の起伏も、こだわらずゆったり流れて、人生的にやさしく、富士山の、人も無げなる秀抜と較べて、相まさること数倍である、と笠井さんは考えた。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄ぼけた様な雲のなかに、ちらちらと饒に残光を保つ明け方の星空の元に、山刀や弁当の包を太縄で結わえ付けた幾つもの男達の空車の歯が、からからと音を立てて、やがて次の村落の方へ消えて行くと、跡は森閑として、家内の者はにわかに睡眠不足の眼をしばだたき出すのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "落日の残光がほんのりそれに当って人を夢心地にする。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹木の梢と空にだけ金色の残光が淡く照り栄えて居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺から西方｜雲煙の表に夕陽の残光を受けて立つ日本アルプスの重畳は実に雄麗壮大の眺めであった。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽は、ゆらゆら地平線に没し、まさに最後の一片の残光も、消えようとした時、メロスは疾風の如く刑場に突入した。",
              "citation": {
                "source": "走れメロス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅かに残光が窓枠の四角な形を切り出していたが、それも吸い取紙で吸い取られるように薄れていった。",
              "citation": {
                "source": "キド効果",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "春が来て、私の家の小さな庭に香のある花が咲き、夕暮の残光が長く空を照らす頃になると、私のその郷愁は愈募って来る。",
              "citation": {
                "source": "素朴な庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の残光徐々に薄らいで、この時は室内に半暗が漂っている。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車はときどき立ちどまって、水と燃料の薪を積みこみ、そうして思い出したようにまた遠い残光をさして揺ぎ出すのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、しらじらとして残光を海ぜんたいに反映する空の下を、コング・ホウコン号の吐く煙りがながく揺曳して、水を裂いたあとが一本、雪道のようにはるかに光っている。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "燦めきのない残光が空中にあって、空を建物を人物の色彩を不思議に鮮かに浮きたたせる。",
              "citation": {
                "source": "わが五月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "残光の漂った水面を掠め汽笛がまた鳴りつづけた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "西日のまだ高く雲を灼いている残光に染って、薄水色の服色に包まれた千鶴子の頬は明るく輝くようだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗く濁って、塔櫓に押し冠さるほど低く垂れ下った空は、その裾に、わずか蝋色の残光を漂わせるのみで、籬の上方にはすでに闇が迫っていた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしジェソップ氏は、からだをかがめ顔を地にすれすれにして、とおく残光が、黄麻畑の果にただようあたりに透した。",
              "citation": {
                "source": "一週一夜物語",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一、二、三、ハハハハ」「ハハハハ」　春の日は西にうすずいて、最後の残光を林に投げ、ふたりのほがらかな笑い顔に送った。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "地平にひろごる残光は暗い空と黒藍の海に吸われて、闇が平野一面に這い拡がっていた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "波の背に、さっきまでは、入日の残光がきらきらとうつくしくかがやいていたが、今はもう空も雲も海も、鼠色の一色にぬりつぶされてしまった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夕がたの日のほのかな光に鶯が鳴いている、というので、日の入った後の残光と、春野に「おぼほし」というほどにかかっている靄とに観入して、「うら悲し」と詠歎したのであるが、この悲哀の情を抒べたのは既に、人麿以前の作歌には無かったもので、この深く沁む、細みのある歌調は家持あたりが開拓したものであった。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは太陽の残光が多量の赤外線を含んで、運動場を照しているせいに違いなかった。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "入日の残光が急にうすれて、夕闇が煙色のつばさをひろげて、あたりの山々を包んでいった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は早く沈むが、残光がいつまでも見えた。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪は残光に映えて藤紫に光っていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "白い謝肉祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっとのことでどうにかロザリオをとなえ終わって、さて庭をのぞくと、雪はいつのまにか降りやんでいて、夕暮れの残光をわずかに照りかえす銀一色の庭──　ツルの姿はそこに無かった。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く風俗の改良、曰く日本音楽の改良、曰く労働者の保護、曰く盲人の教育、曰く女囚乳児の保育、是れ彼れが老夫人の熱切なる同情と協力とに頼りて、現に社会に寄与しつゝある生涯の残光なり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "上半身に残光を浴びて、千浪は、両手に湯をすくってはこぼしいつまでも無心に戯れているのだった。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "その真っ赤な残光を庭一面に蹴散らし、踏み乱して、地に躍る細長い影とともに、剣妖丹下左膳、いまし奮迅のはたらきを示している。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "水火秘文状　藍色の夕闇がうっすらと竹の林に立ちこめて、その幹の一つ一つに、西ぞらの残光が赤々と照り映えていた。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "空高く西の雲に残光が朱ににじんで鳶に追われる鳥のむれであろう、ごまを撒いたように点々として飛びかわしていた。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
