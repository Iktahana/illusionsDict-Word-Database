        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『朱欒』のむかしから親しく君達は私に君達の心を開いて呉れた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スバル、白樺、三田文学、劇と詩、朱欒。",
              "citation": {
                "source": "夜長ノート",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "輝く崖の上の麦畠、くわつと燃え立つ杉の木、松の木、朱欒の木。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "くわつと燃え立つ杉の木、松の木、朱欒の木。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之、識る人も識らぬ人も酔うては無礼の風俗をかしく、朱欒の実のかげに幼児と独楽を廻はし、戸ごとに酒をたづねては浮かれ歩るく。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭には無論｜朱欒の老木が十月となれば何時も黄色い大きな実をつけた。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして朱欒の花の白くちるかげから通つてゆく葬列を見て私は初めて乳母の死を知つた。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣かゆるに日は照り暑し湯気立てて蟶を今｜釜に煮沸す照る砂に雷管のごと花落す朱欒一木が老いてお庭に棟瓦千石船の朱と碧は正目仰ぎて深き雑草鍋二つ汲水場に伏せて明らけき夏真昼なり我家なりにし白栄に蛇奔る裏堀は水紋の動き光とありつつ我が書斎たりし隠居家は、なほ遺れども、既に久しく鎖しぬ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "茲に収められた七章八十余篇の詩は、明治四十二年の二月（邪宗門出版当時）より大正二年の四月（朱欒廃刊迄）に至る、概ね四ヶ年間の制作であつて、恰度私の青春の花期に当つてゐる。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に私は『邪宗門』『思ひ出』『桐の花』等の詩歌集を出し、また雑誌『スバル』に外部より声援し、又木下杢太郎、長田秀雄両君と都会趣味と異国情趣を基調とした雑誌『屋上庭園』を二冊発刊し、其後単独でも雑誌『朱欒』を一年有半続刊した。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して友に別れ、都門を離れ、地位も名聞も雑誌『朱欒』をも投げすてゝ、一つには彼女の病ひを療してやりたいため、一つには新らしい生活の道程に上るべく、彼女と私の一家とを挙げて、はるばると海をわたり、相州は三崎の浜辺に一時の住居を移したのである。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌『朱欒』を発刊したのはそれから帰京しての事である。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月に私は三木露風君と共に『朱欒』の特別号として詩集勿忘草を出した。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "『朱欒』の抒情小曲その他はさしづめ栗の若木の新芽である。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後はキケロの温泉の入口にて、月桂朱欒の枝繁りあひたれば、われは始より人あるべしとは思ひ掛けざりしなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之、識る人も識らぬ人も醉うては無禮講の風俗をかしく、朱欒の實のかげに幼兒と獨樂を囘はし、戸ごとに酒をたづねては浮かれ歩く。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭には無論朱欒の老木が十月となれば何時も黄色い大きな實をつけた。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして朱欒の花の白くちるかげから通つてゆく葬列を見て初めて私は乳母の死を知つた。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの陰氣な稻荷の巫女や、天狗使ひや、（Ａ＋Ｂ）２ ………などの方程式で怪しい占ひをした漂浪者や、護摩を焚く琵琶法師やを滯留さしては、いろいろな不思議を信じた行爲の閑暇にはまた七面鳥を朱欒のかげに放ち、二三百の白い鉢に牡丹を開かせ、鷄を飼ひ、薔薇を植ゑる事を忘れなかつた。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱欒のかげ弟よ、かかる日は喧嘩もしき。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの陰氣な稻荷の巫女や、天狗使ひや、(A+B)2 ………などの方程式で怪しい占ひをした漂浪者や、護摩を焚く琵琶法師やを滯留さしては、いろいろな不思議を信じた行爲の閑暇にはまた七面鳥を朱欒のかげに放ち、二三百の白い鉢に牡丹を開かせ、鷄を飼ひ、薔薇を植ゑる事を忘れなかつた。",
              "citation": {
                "source": "思ひ出",
                "author": "抒情小曲集",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽は黄熟した大きな朱欒のやうにかがやき出した。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかに白緑の葉をかがやかせてゐるのは朱欒の樹で、その葉の茂みから大きなザボンの実が二つ三つ下膨れの尻を見せてゐる。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人の文学活動の展開される場面も数多くなり『新潮』『文章世界』などのほかに、『スバル』もあり『番紅花』『詩歌』『朱欒』等のほか、片山広子のアイルランド劇研究の載った『心の花』もあるという盛観であった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　丁度その頃（明治四十四年末）北原白秋の主宰する「ザムボア」（朱欒）が創刊せられた。",
              "citation": {
                "source": "萩原朔太郎",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は先ほどの入道雲が水平線の上へ拡がってザボンの内皮の色がして、海も入江の真近までその色に映っていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きょうは君にごちそうがあるぞ、この間｜台湾の友人からザボンを送ってくれてな。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こういいながら大木は立って、そこの戸棚から大きなザボンを二つかかえ出した。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　矢野はザボンの一つを手にとって、こねまわして見る。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりでザボンを切ってしばらく笑い興ずる。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
