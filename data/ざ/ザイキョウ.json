    "definitions": [
      {
        "index": 1,
        "gloss": "being in the capital (i.e. Tokyo, or formerly Kyoto)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十五日に在京の同人が集つたとき十一月號には紙數に制限をつけない力作を持寄つて特別號を出さうかといふ話も出た。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "在京の主なる俳優は殆ど全部出演し、わが劇界空前の名誉なりと喧伝せらる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田国五郎、西川伊三郎を始めとして、在京の人形使いはすべて出演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿五日、乙酉、晴、六波羅の飛脚到著して申して云ふ、和田左衛門尉義盛、大学助義清等の余類洛陽に住し、故金吾将軍家の御息を以て大将軍と為し、叛逆を巧むの由、其聞有るに依りて、去る十三日、前大膳大夫の在京の家人等、件の旅亭を襲ふの処、禅師忽ち自殺す、伴党又逃亡すと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "永保元年の冬、在京中、讒者の為に西海に謫せらる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将門の在京中に、貞盛が嘗て式部卿｜敦実親王のところに詣つた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "将門在京中に既に此事があつて、貞盛と将門とは心中互におもしろく無く思つてゐたところから、貞盛の言も出たとすれば合点が出来るのである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之に在京中毎度話をした如く吾々は比較的多くの自由を得んが爲めに叫びつゝあるのに、反て常の人よりも不自由をより多く與へらるゝならば寧ろ叫ばぬが得策であると想ふ。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "在京の歌人と知合になつたのもこの時である。",
              "citation": {
                "source": "竹の里人〔三〕",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時の在京中藩公の御前は勿論、喜多流の能楽堪能（皆伝）と聞こえた藤堂伯邸へも度々召出されて御能、お囃子等を仰付られた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "因にこの時の只圓翁の上京問題に就ては当時在京の内田寛氏（信也氏父君）、米田與七郎氏（米田主猟頭令兄）が蔭ながら非常な尽力をされたそうである。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人の稽古振りや能の舞いぶりを筆者は在京中であったために、あまり見ていなかったが、よほど烈しいものがあったと伝え聞いている。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時在京中の慶喜悟る所あり、十月十三日在京の諸大名群臣を二条城に集めて諮問したる上、翌十四日朝廷へ奏問に及んだのである。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "対峙すること既に六ヶ年、在京の諸将が戦いに倦んだことは想像出来るのである。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢山あるからそうよろしけば、盛にやってくれ給え」　少し力を入れて話をすると、今の岡村は在京当時の岡村ではない。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "『宇治拾遺』に永超｜僧都は魚なければ食事せず、在京久しき間魚食わず、弱って南都に下る途上、その弟子魚を乞い得て薦めた。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ところで君は在京の耳鼻咽喉科の医者連中がやっている庚戌会って言うのを知っているかね。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方に秘密画さえ描けば、粗末なものでも非常に高価く早く売れるという事実は、不断に在京の画家を誘惑している。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし前髪を切って縮らした式は、在京中、只一人しか見受けなかった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "記者が在京中のぞいて見たのは、日比谷と上野と芝公園のバラックだけであったが、こんな話を聴いたあとで見に行っただけに、バラックに居る江戸ッ子が想像以上に多いように思えた。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も近代的犯罪に適した下町を選ばずに、山の手の小さい通りや、戸山ヶ原などが選ばれているのは、恐らく、作者の在京時代の経験（作者は今は大阪に住んでおられるが、東京にそうとう長く在住した人であることは容易にわかる）が大いに預っているであろう。",
              "citation": {
                "source": "日本の近代的探偵小説",
                "author": "――特に江戸川乱歩氏に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この前年の六月、新富座新築の開場式に在京の各外国人を招待したので、その時同じく招待をうけた英国公使館の外国人らが主唱者となって、外国人から何か新富座へ贈り物をするということになった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでながら今日の帝室技芸員で在京の人々の顔触れをいって置きましょう。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "帝室技芸員の事",
                "note": "青空文庫"
              }
            },
            {
              "text": "――つまりこの四五年というものは殆んど旅で暮らしていたので、在京の諸友とも従って遠ざかり勝でひどく御無沙汰をしてしまった。",
              "citation": {
                "source": "え゛りと・え゛りたす",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉石君は現在京大の支那学の教授であるが、先だって同君からその著書『支那語教育の理論と実際』という本をもらって、ふとこの読書会のことを思い出した。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "在京の方でおひまの方は少しくお話にお出下さいまし。",
              "citation": {
                "source": "編輯室より（一九一五年六月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "□二月中旬頃か三月にはいつてからか、皆様の御都合のよさうな時に在京の方々と一度集まつて見たいと思つてゐます。",
              "citation": {
                "source": "編輯室より（一九一六年二月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
