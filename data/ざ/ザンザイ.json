    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(execution by) decapitation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大阪で、船乗り業｜桂屋太郎兵衛というものを、木津川口で三日間さらした上、斬罪に処すると、高札に書いて立てられた。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪で、船乘業桂屋太郎兵衞と云ふものを、木津川口で三日間｜曝した上、斬罪に處すると、高札に書いて立てられた。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "座頭松の市、朋輩をあやめしかどにより四月四日｜斬罪のうえ梟首獄門。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "獄門番の非人は上つ方の女性を犯したうえに首を与えし罪軽からずとなして極刑の斬罪、旧罪をあばかれた小田切久之進の江戸払いは当然のことでしたが、ふたりの姉妹たちのうえには、人を騒がした罪は憎しとするも、根がかたき討ちにその動機を発していましたものでしたから、四日の入牢だけで軽く放免になりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ある事件のため、時の王様の怒りに触れて、将に斬罪に処せられんとしたのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽くても無期徒刑、重ければ斬罪じゃ」　が、万之助は、毅然としていった。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "準左衛門は天保四年十二月二十日に斬罪に処せられた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは斬罪になる者の号泣を聞いているからいやだ。",
              "citation": {
                "source": "牢屋の原",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治上の党派をことにするという故をもって斬罪となった者は、日に幾千人にものぼっているではないか。",
              "citation": {
                "source": "死刑の前",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに支那人の間に、罪人の肉を）の、不忠者は斬罪に處せらるる上に、その肉は食ひ盡されることも、又 〔Abu^ Zayd〕 の傳へる所（※）の姦通、泥棒、殺人等、民衆の怨を買ふべき性質の罪人は、所定の公罰を受けた後ち、更に民衆の爲に食ひ盡されることも、大體に於て事實を得たものである。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "となつて居るが、『明律』（卷十八、賊盜律）の強盜に對する處分は、今一段と嚴重で、概して斬罪に行ふ。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父母・父母は單に毆打するのみでも斬罪であるから、負傷させた場合は、理論上斬罪以上に處せられねばならぬ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど實際としては斬罪が極刑で、それ以上の刑罰が存せぬから、矢張り斬罪に處する。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "この不法行爲はさきに已に紹介した如く、『唐律』では十惡中でも特に重い惡逆を加へ、死罪中でも一等重い斬罪に處する（鬪訟律二）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父母・父母を毆打した子孫を、斬罪に處するのは、支那の法律の古今を通ずる大法で、上は『漢律』（民國の程樹徳『漢律考』卷四參看）から、下は『明律』『清律』に至る迄、何等の相違がない。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど父母を毆打した者を、斬罪に處するのは、單に法文上の規程である。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "王朝時代の『養老律』では、かかる行爲に斬罪を科し（『律逸』卷五及び『法曹至要抄』上參看）、徳川時代の『御定書百個條』では、死罪を科した。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治初期の『新律綱領』（鬪毆律）でも祖父母・父母を毆打した者は斬罪に處した。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "『養老律』にはその未遂たると已遂たるに論なく、すべて斬罪に處し、『御定書百個條』には、親殺しを引廻之上磔に處した。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "斬罪者不待時而殺之。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "斬者頭頸異處」（卷二百六十三、竇儼傳）が、絞罪と斬罪との輕重の岐るる所以である。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如く死罪の中にも絞罪と斬罪との二種がありまして、斬罪は立所に決するが、絞罪はすべて秋後に行ふと云ふのであります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは父母に傷を負はせようが負はせまいが問題でなく、毆くと云ふこと丈けで斬罪に處するのであります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "斬罪と云うても別に驚くべきでありませぬ。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治十二三年頃まで親を毆いた者はどんな場合でも斬罪であつた。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに明律では妻が夫の父母に對するは子が親に對すると同樣ですから詈るものは絞で、毆打すれば斬罪と云ふのでありますから、餘程重くなつて來て居ります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前と、わしと二人が、下手人になって、斬罪に処せられて何んになる。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
