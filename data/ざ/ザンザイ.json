[
  {
    "uuid": "41b2cc76-b9c0-5355-9f78-0c25b1231398",
    "entry": "斬罪",
    "reading": {
      "primary": "ざんざい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
