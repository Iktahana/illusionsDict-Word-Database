[
  {
    "uuid": "13556b97-56ab-5f04-9681-337ecf353606",
    "entry": "讒誣",
    "reading": {
      "primary": "ざんぶ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
