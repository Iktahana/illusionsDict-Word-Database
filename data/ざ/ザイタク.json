        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さいわい先生は御在宅であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『在宅るとも、何か用だろうか。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "三「もしもし、山吹先生のお宅でいらっしゃいますか」「はあ、左様でございます」「僕、三高文三丙の梶鶴雄ですが、先生御在宅でしょうか」「只今、世界文学社の方へ参っておりますが……」「そうですか」　と鶴雄はちょっと考えて、「――それでは、世界文学社の方へ参ることに致します――。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨ふりの日はいつも在宅です。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀木は、在宅でした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "チョッピリ女史は在宅だった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "津田さんは在宅だった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生は御在宅ですか。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋畫家は在宅してゐた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋画家は在宅していた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うれしや、主人は、ご在宅である。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御迷惑でも御在宅のほど御願い申上げます。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日、午後六時一五分頃お伺い致したいと存じますが、トリヴェリアン先生におかれましては、ご在宅のほどお願い申し上げます。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はい、カルヴァトン・スミスさまはご在宅です。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｄ――は在宅していて、例のとおり欠伸をしたり、ぶらぶらしたり、のらくらしたりして、退屈でたまらないというふりをしていた。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来上がったブックはさっそく、「建築デザイン」、「在宅ワーキング」、「アプリケーション日本語環境」など、ニフティーで出入りしていたフォーラムに登録しました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "プログラマーとして働いている辰野雄一さんとは、以前ニフティーの在宅ワーキングフォーラムに顔を出す人たちの集まりで会いました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方の五時からは、どんな所用があって、尋ねて行っても、在宅して居ることは、殆どなかった。",
              "citation": {
                "source": "神の如く弱し",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お峯はその翌日も必ず来るべきを懼れて夫の在宅を請ひけるが、果して来にけり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父様はお在宅でございましょうか。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「在宅すことは、在宅すが、お目にかゝれますかどうか一寸伺って参ります。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、遅く伺いました方が、御都合が、およろしかろうと思いましたものですから、お父様は御在宅でしょうか。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "中田博士は、都合よく在宅した。",
              "citation": {
                "source": "無名作家の日記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "中田博士は、いつものように在宅した。",
              "citation": {
                "source": "無名作家の日記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことによれば里見恭助という兄も在宅かもしれない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "六郎左衛門は在宅か」　うれしいほどに重々しく鷹揚でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それなる亭主は、いつごろ在宅じゃ」「さよう――ですな、夜分はいるようですが、昼のうちはたいてい不在のようでございますよ」「そうか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「リブストンの　おくさまは　ございたく？",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも　ちょうど　ご本人が　ございたく。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "きつねめさんが　えだごやに　ございたくなら、　やつは　きつねめさんの　もうひとつの　おうち、　おうし土手のてっぺんに　行ったんだ。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
