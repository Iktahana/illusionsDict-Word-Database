[
  {
    "uuid": "b815b82b-a955-5ed3-9f29-a6915e5b35f4",
    "entry": "惨死",
    "reading": {
      "primary": "ざんし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
