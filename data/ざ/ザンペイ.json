    "definitions": [
      {
        "index": 1,
        "gloss": "remnants of a defeated army",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「一言注意して置く、此の辺り一帯は尚敗残兵が徘徊している。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓は、各国の帝国主義に尻押しをされて、絶えまなく小競合を繰りかえす軍閥の苛斂誅求と、土匪や、敗残兵の掠奪に、いくら耕しても、いくら家畜をみずかっても、自分の所得となるものは、何一ツなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今川勢は丸根に対した如く、火を放って攻めたので、信平を始め防戦の甲斐なく討死して残兵｜悉く清須を指して落ちざるを得ない状態になった。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて朝鮮の武将史儒はこの役に死し、祖承訓は残兵を連れて遼陽に還ったが、明の朝廷へは、我軍大いに力戦して居た際に、朝鮮兵の一部隊が敵へ投降した為に戦利あらず退いた、とごまかして報告した。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "右に付残兵御都合次第早速御差出に相成も難計、兼而手筈いたし置候様。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日残兵御繰出相成可申、尤拙者居残、病人手厚可致旨、松軒出張被仰付。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝五時残兵青森迄出張。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして所々に固まつてゐる身方の残兵に首領の詞を伝達した。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔が合うと、美男の兵の方が、「敗残兵が帰って来たア。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「敗残兵が帰って来たア。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく僕の大家さんなんだから……」　私は、丁度そこへ来合せた井河氏に、敗残兵とやらがこの辺にまだゐはせぬかを訊ねた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの山間の部落々々には、所謂敗残兵がまだうろうろしてゐるのだと聞いてゐたからである。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「敗残兵が出たな」　誰かが囁いた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体穏かだが、なかには油断のならん奴がゐるよ」「ある砲兵隊が舎営してゐる部落で、敗残兵だか匪賊だかの襲撃を受けたところがあるつてね。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、例の通州事変の後、一時、この界隈に匪賊化した敗残兵が出没して、夜道はむろん危険ですし、何処の家でも戸を閉めて子供を外に出さないことがありました。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗残兵や便衣隊と間違へられては大変だ。",
              "citation": {
                "source": "北支の旅",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "往復をいれてわづか三週間といふ短い旅であつたが、当時、京漢線方面では、彰徳の攻撃がはじまる前であり、娘子関がまだ落ちず、保定、定県附近には敗残兵が頻々と出没して油断のならぬ頃であつた。",
              "citation": {
                "source": "後日譚",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや、かの敗残兵のいくぶん計画的とも云はれるゲリラ戦術とはどんなものか、それを見届けるためには、少し後方の辺鄙な地点を選ぶに如くはないと気づき、私は、一旦南京へ引返した。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、現在これらの水路は、所謂敗残兵の出没甚だしく、支那人は「税金」を払つて難を免れるといふことである。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとなく怪しげな挙動とも思はれるが、まさか敗残兵ではあるまい。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "御両所とも敗残兵の如しだが、自分もまた御両所以上にひどい姿である。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中で同胞の敗残兵に強奪されたり、女が強姦されることまで心配してゐた。",
              "citation": {
                "source": "戦争と一人の女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞穴に追いつめられた敗残兵が突如として総攻撃に転じたような悲痛の様が思いやられますが、行われた現象としては必ずしもそうではなくて、素人芝居の中でも一番不出来なのに似ているようなオモムキだったようです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗残兵の靴下よりも貧弱だわね」「さほどにも見えない。",
              "citation": {
                "source": "中庸",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕頃、余は残兵をまとめて善光寺に退いて集合した。",
              "citation": {
                "source": "決戦川中島　上杉謙信の巻",
                "author": "――越後守安吾将軍の奮戦記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、知らん」　升田は目の玉をむいてニヤリとして、「オレ、ちよッと、ねむりたうなつた」　とキョロ／＼あたりを見廻したが、敗残兵のやうなのが五六人、右に左に入りみだれて隅の方でねむつてゐるから、場所がない。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "森林帯のあえぎが終われば、まばら木立ちに立ち迷う霧の残兵を追って、深い熊笹の波を乗り越え、待望久しかった尾根に出る。",
              "citation": {
                "source": "二つの松川",
                "author": "細井吉造",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗残兵の自覚がもてないところが哀れでもあり、ミソでもあるというわけらしいな」　青木は安心したらしく、酒をたてつづけに呷りだした。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "残兵どもは一たん引きました。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
