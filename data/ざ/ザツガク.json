        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『搾取の谷間に咲く白百合』とたたえられた名著、「野外雑学読本」だけのことはある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、かういふ風に、雑学でも、耳学問でも何でも好いから広く且つ深く、独創的に読書から知識を得るといふことにする。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "後には座談の名人とも言はれた彼れ、其時分から一かどの※ーチュアソーで、博覧強記で、蘊蓄は和漢の雑学が六七分、西洋のそれが三四分といふところ。",
              "citation": {
                "source": "斎藤緑雨と内田不知菴",
                "author": "坪内逍遙",
                "note": "青空文庫"
              }
            },
            {
              "text": "※先生は祖父母に甘やかされて生長し、赤本を耽読して悉く之を誦じ、其他雑芸雑学に通じて衆愚に説法することを楽しむ一個の閑人であるが、胸に一物ある巧案という鍼医の画策によって文殊の再生と言い触らされ、其名も愛読書の猿蟹合戦に因んで猿蟹上人と改めて文殊菩薩直伝の智恵授所という看板を掲げることとなる。",
              "citation": {
                "source": "春水と三馬",
                "author": "桑木厳翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "天性自ら風流を解し人情の秘奥に通じ雑学の大家とある。",
              "citation": {
                "source": "金談にからまる詩的要素の神秘性に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "博識を以て知られた雑学者である。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその山中に六百年ほど代のつづいた旧家の主人で、雑学の大家でもある。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたい田舎の旧家には、雑学の大家が多い。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の義兄（私の長姉が細君）紅邨もヒマにあかした雑学家で話の泉のお客ぐらいは楽につとまる物識りであるが、田舎の雑学の大家に共通していることは、大事の心棒が一本足りないということだ。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "修業純ならず駁雑学を好む、これを中等と云う」と云々という、余り長くはないものであった。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろな種類を含む蔵書で、和漢の書籍の間には草双紙類もあって、読み放題に読んだのだが、私の雑学風の基礎はこの一年ばかりの間に形造られたように思う。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "天願氏は、何処で覚えて来るのか知らないが、雑学の大家で、つまらないことを沢山知って居る。",
              "citation": {
                "source": "風宴",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルースは広く雑学を身につけているが、世間に出たことがないし、物事を笑い飛ばすことは学んでいない。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついに雷専門の雑学者　頼まれもせんのに外国まで問合せを出すバカだから、もちろん逢う外人もって、失礼ですが御地では雷は鳴りますかね？",
              "citation": {
                "source": "雷嫌いの話",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷専門の、雑学者だね。",
              "citation": {
                "source": "雷嫌いの話",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は一種の雑学者で、何を質問しても知らぬと云った事がなかった。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
