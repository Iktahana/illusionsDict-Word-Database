    "definitions": [
      {
        "index": 1,
        "gloss": "popular music",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "其が、時勢に伴うて、雅楽を棄てゝ、雑楽・曲舞を演じたのだ。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "正舞は「まひ」と称し、雑楽は何楽と言うた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿楽・田楽は、雑楽の系統としての名である。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "がくと言ふ名に、社寺の奴隷の演ずる雑楽の感じがあつたのだ。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿楽能は山人舞の伝統を引くもので、社寺の楽舞に触れて変化し、民間の雑楽に感染してとり込み、成立後の姿からは、元の出処が知れぬ位に、変つてしまひました。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽と言ふ字のつくのは、雑楽の義で、田楽は其であり、舞の方が一段上で、正舞系統を意味するものらしい、と、かう言ふ仮説は立たないでせうか。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
