        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "若い美妓もあり、座持ちのうまい年増もあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し他の座持ちに泣き附いて、漸く興行をしてゐるのである。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく座持ちのいい乙姫さまが立ち現れて来ます。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中達には座持ちの「サービス」つまり客笑談までのことはあつても、色めいたサービスは無い。",
              "citation": {
                "source": "「いろは」の五色ガラスについて",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時一座したお歴々は、自由党の幹部会ほどの顔ぶれであったが、その中で、抜群の座持ちは吉田首相であり、諧謔に富んだ明るい応酬は、なかなかに忘れ難い。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "平次読む人読まぬ人――三人の政治家――",
                "note": "青空文庫"
              }
            },
            {
              "text": "菅田平野は聞き上手で、しかも、座持ちがうまいといわれる種類の人に属していた。",
              "citation": {
                "source": "日日平安",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美人だし気が向けば座持ちがいいから、彼女には人気があった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔だちのなかにある華やかさが、よく出来た世話女房の座持ちの良さ、といったものを思わせた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "色白細面の見本のような顔立ちの、きわめて座持ちのいい彼女は、なぜかいつも浴衣を着ていた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓠の神をくひざもちの神と言ふ。",
              "citation": {
                "source": "熟語構成法から観察した語根論の断簡",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
