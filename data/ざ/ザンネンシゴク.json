[
  {
    "uuid": "9263b263-cab6-5786-ac5d-08afef240417",
    "entry": "残念至極",
    "reading": {
      "primary": "ざんねんしごく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "形容動詞"
      ],
