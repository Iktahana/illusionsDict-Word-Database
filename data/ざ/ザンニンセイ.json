    "definitions": [
      {
        "index": 1,
        "gloss": "brutal (nature)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
