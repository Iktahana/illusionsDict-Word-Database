        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "通風筒の耳の孔が僅かに残照の紅みを反射する。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の外側に並んだ幹には残照が映って、その光が陽炎のように微赤くちらちらとしていたが、中はもう霧がかかったように暗みかけていた。",
              "citation": {
                "source": "太虚司法伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堅山南風氏の『残照』と郷倉千靱氏の『山の夜』とは良い対照である、南風氏の自然に対する向ひ方といふのは、自然を素直にうけいれ、特に自然と妥協をすることさへも恐れないが、結局は自然を自分の膝の下に組み据へてしまはなければ気が済まないといふやり方である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄幹の「残照」は変ロ調の４／４でよく調子に合った。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大東屋はいつかがらんと人気なく、肌つめたい秋の残照の中に、雁来紅の濃い色調、紫苑、穂に出た尾花など夜に入る前一息のあざやかさで浮上った。",
              "citation": {
                "source": "百花園",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "落日は巨人の魂かわが魂か炎のごとく血汐の如し　熱しきった太陽は爛々と燃え、最後の残照を西の空一面に放ったまま、落人のごとく夜の世界の彼方へ沈んでゆく。",
              "citation": {
                "source": "六甲山上の夏",
                "author": "九条武子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の裾が平野の中へ消えて来て、葉さきを曲げた芒の向うに、入日をうけた海が大きく空に残照をあげていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "海上に近く浮んだ三つの小島にあたる残照が、紗を隔てて灯を望む趣も旅中の心を和らげた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽は建築物の肩に隠れて、その残照が明るく河面に漂い、油をぬったような空と水との反映を受けて、微妙な紫じみた雰囲気をかもし出し、両岸の家々は平面がぼやけ、輪廓だけがくっきりと際立ち、泊りを求めて帰る大きな荷足船の中からは、細そり煙が立っている。",
              "citation": {
                "source": "道化役",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日没後の残照の中に夕靄がたなびき、靄が薄らぐと共に明るみも薄らぎ空の星が光りを増してくる。",
              "citation": {
                "source": "田園の幻",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう陽は沈んでいましたが、その残照を受けてる赤い雲が、千切れ千切れに、ゆるやかに西空に流れていました。",
              "citation": {
                "source": "死因の疑問",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕頃になると、西の山の端に没した太陽の残照が湖面に流れることがあった。",
              "citation": {
                "source": "山吹の花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "水面とも水中浅くともつかず、ゆらゆらちらちらと、その残照はしばし漂い、そしてあちこちに小さく別れて、次々に消え失せていった。",
              "citation": {
                "source": "山吹の花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その残照の消えがたに、いやなものの姿も見えた。",
              "citation": {
                "source": "山吹の花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今もまた、湖面の残照の中に蘇ってきた。",
              "citation": {
                "source": "山吹の花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方といっても、残照の澄んだ、よく見通しのきく一刻だった。",
              "citation": {
                "source": "秦の憂愁",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "残照が消えてしまった時、二人の肩は相接していた。",
              "citation": {
                "source": "波多野邸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "残照がまだ明るく海の上に映えて、初島がたいへん近く見え、その先は茫漠と暮れかけていました。",
              "citation": {
                "source": "高尾ざんげ",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日はすでに河内の金剛山と思うあたりに沈んで、一抹殷紅色の残照が西南の空を染めて居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時――それは朝から妙にむし暑い日だったが、夕方になって急に冷々としてきて、ぱっと明るい残照の後すぐに暗くなってしまった。",
              "citation": {
                "source": "未来の天才",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "華かな残照が西の空に残っていた。",
              "citation": {
                "source": "月明",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十九　西の空に屯してる雲のために華かなるべき残照が遮られてる、ほろろ寒い佗しい秋の夕暮だった。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「南無三、道を取り違えたか」　思わず右門がこう叫んで、立ち止まった時は秋の陽が、聳える高山の頂きへ半ば没しつつやや躊躇し、残照淡く空に映え、山々の影樹木の影、そして二人の男女の影がその残る陽に照らされて、地上に長く印するのが、寂しく思われる時刻であった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕｜靄と金色の残照に包まれ、薔薇色した黄、明るい鼠、その裾は黒い陰の青、うるおいのある清らかさ、ほれぼれとする美しさだ。",
              "citation": {
                "source": "チチアンの死",
                "author": "ホーフマンスタール　Hugo von Hofmannsthal",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れの彼方には、ルーヴル美術館の厳かな正面が広げられていて、その退屈そうな小窓には、夕陽が生々とした残照を投げていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――馬車はまだ灰色の残照のある道を、荒地の方へ向ってがたがたと走りだした。",
              "citation": {
                "source": "殺生谷の鬼火",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この残照を娘は無意識的に拾い取ると、すぐ眼の前の大きな行燈が眼にうつりますと、その行燈へ、手燭の火をうつしてしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "前首相、前財界の雄、現大臣の大物三客を招待して、時は奈良茂、紀文の世を去ること二百余年ではあったが、たとえ半日でも吉原の吉原残照をいろめかせたというのは、たいした我慢づよさだといってよい。",
              "citation": {
                "source": "紅梅の客",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕映えは彼らの行先の西空をひろく染めて、金色にふちどられた雲の峯の下から、残照のまっすぐな光が車の輻のように放射状に幾条も空へのぼっていた。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "沈みゆく太陽の残照がルースの顔に当たり、真っ青な憔悴しきった顔には涙があった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
