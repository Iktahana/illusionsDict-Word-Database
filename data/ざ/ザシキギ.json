[
  {
    "uuid": "43682240-e7fb-5535-bc39-4d6e4a5a9f0f",
    "entry": "座敷着",
    "reading": {
      "primary": "ざしきぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
