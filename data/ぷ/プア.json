        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ヴォアラ、ネスパ、セッサ、ムシュー、アラマディ、プレンプアン、ラタヽパン。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミンダナオのプアラ。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ航空燃料だといいますぜ、しまいにゃ、アップアップ、てっきりでさアね」「うん。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八九三年の暮、曾てのサモア王タマセセの遺児が、トゥプア族を率いて兵を挙げた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターの誕生にあたって活躍した多くは、社会や大学からドロップアウトした若者であった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『人類学雑誌』に、パプア人やヤミ蕃人が、以前出産の際母の腹を剖いて子を取り出したが、後に他所の女の山羊が、腹を剖かずに安全するを見て、その法を廃したと見えた。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "せいぜい、あの凸凹コンビの「アップ、アップアップアップ！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、現実においては、今日「女子の隷属の起り得ない」「原始女性は実にその活溌な労働性の故に独立的なのであり」得る原始的社会は、訳者の云われている通り恐らく「パプア島の食人種」のところぐらいにしか残存していまい。",
              "citation": {
                "source": "先駆的な古典として",
                "author": "――バッハオーフェン『母権論』富野敬照氏訳――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その婆さんが話したが、呉服橋ぎわの共同便所の処で三十七人死んだ、その片われの三人が助かった様子、中二人は夫婦で若く、妻君は妊娠中なので、うしろの河に布団をしずめて河に入れて置いたが、水が口まで来てアプアプするので、仕方なく良人も河にとび込み舟に乗ろうとすると、舟は皆やけて居る。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルトのポインティングディバイスに使われたマウスのボタンの操作によって、画面上にメニューを呼び出す方式は、ポップアップメニューと名付けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "トィンクル、トィンクル、リトルスター、ハオアイ、ワンダア、ホアツユウアール、ホエン、アップアバウト、インザスカイ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "両側は、いわゆる｜多雨の森、パプアの大湿林。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてここが、奥パプアの最終点になっているのだ。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分から他人の垣を越えようとせず、ある垣を此方からもキープアウトして居る。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、描かんとする或人物に対して作者の興味が如何に動くか、この動き方には、時代時代の流行といふか、型といふか、さう云つたほゞ一定の「プアン、ド、ヴュウ」があるやうである。",
              "citation": {
                "source": "素面の管",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "四「俺の避難所はプアだけれど安全なものだ。",
              "citation": {
                "source": "贋物",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジガレンがほしくてアプアプした。",
              "citation": {
                "source": "日記",
                "author": "一九四七年（昭和二十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはちょうど今日ボルネオのパプア人やシンガポールあたりの海岸で見かけるのと同樣、陸地との交通はたいてい小舟に乘つたものです。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした光景の中に申分なく具現されてゐるのが、あのプア・ロビンが考へてゐた仲冬の愉樂であるのだ。",
              "citation": {
                "source": "驛傳馬車",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一六八四年版『プア・ロビンの暦』）　わたしが宿屋に着いて程なく、一臺の郵便馬車が門口へ乘りつけて來た。",
              "citation": {
                "source": "驛傳馬車",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "この光景は、プア・ロビンが真冬のなぐさみについて考えたことをそっくり実現したようなものだった。",
              "citation": {
                "source": "駅馬車",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "原註　一六八四年版「プア・ロビンの暦」。",
              "citation": {
                "source": "駅馬車",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化のためとか、文明のためとか、国家や、民族のためと、漠然とは言い得るにしても、さて、具体的にわれわれの方途を解剖し、理論づけることのできないプアな状態にあったその当時の私であった。",
              "citation": {
                "source": "十五年",
                "author": "山本実彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の上で、うちのひとが、一秒でも綱を引きおくれたら、あたしはアップアップだ。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボルネオ、パプア、フィリッピン諸島に、とりまかれているセレベス海に、妾達の国土はございますので。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲掻きみだして青い池の真っ只中をアプアプ小圓太は泳いでいた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして、プアサ（インドネシア人の正月）の休みに、ブル島へ母や妹に逢いに行って帰って来ますと、村上さんが、「おい四郎、お前は小さなプラウでブル島まで行ってきたのだそうだな、えらいことをやるな！",
              "citation": {
                "source": "手紙",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャングルのない、すこしばかりの海岸に、とびとびにパプア人の部落があるだけであります。",
              "citation": {
                "source": "手紙",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は村上さんと離れたところに住み、パプアたちと飛行場をつくる手伝いをしていますうちに、パプア語がわかるようになりましたので、川向いのケクワの部落へ遊びに行き、ンブナムというスルタン（酋長）と知合いになりました。",
              "citation": {
                "source": "手紙",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
