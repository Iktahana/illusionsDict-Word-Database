    "definitions": [
      {
        "index": 1,
        "gloss": "lightly (floating)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "青ぞらをぷかぷか泳いでいると思っているんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いまこの数寄屋へ入ると同時にハッと思ったのは、大坊主が古行燈の灯を銀の俵張の煙管にうつして、ぷかぷかと吹かしていた処、脂を吸ったか、舌打して、ペッペッと憚らず蚊帳に唾を吐いた。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に竜雄は、無雑作に、火をつけて、ぷかぷかと貪り吸った。",
              "citation": {
                "source": "土竜",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金魚のやうに、ぷかぷかと煙を吸つては吹いて居る。",
              "citation": {
                "source": "爪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "高橋も初めはちよくちよく口を利いてゐるが、何時とはなしに口を噤んで了つて、煙草をぷかぷか吹かしながら、話す者の顏を交る交る無遠慮に眺めてゐるか、さもなければ、ごろりと仰向けに臥て了ふ。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は煙草をぷかぷか吹かし出すと、煙草について、会心の微笑を洩らして考へた。",
              "citation": {
                "source": "火の点いた煙草",
                "author": "一名――煙草蒐集家の奇禍",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖いぷかぷかな場席へ、所謂シークなパリの中流男女、金をつかいに来たアメリカ女が並んで、ソヴェトから買って来て骨をぬいた「アジアの嵐」を観ている。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便物の嚢がぷかぷか浮かんでいると、それでも平気でにこにこしているのです。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "その断髪のあたまが、ぷかぷかと跳ねると、やがて、さっとしぶきを上げて、満々とした海に、若鮎のように、飛込んで行った。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その間斜めに体を崩し、天井を仰ぎつつ煙草をひとりぷかぷか喫して黙りつづけていたが、また矢代の方へのり出して来るとこう云った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "金もないくせに敷島をぷかぷかふかしていた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家は、如何にも女の働いてゐる家らしく、掃除もゆきとゞかない汚れて散らかつた部屋で、太つた産婆は、煙草をぷかぷか吸つてゐた。",
              "citation": {
                "source": "あひびき",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "久助は今、岩に腰をかけて、煙管でぷかぷかと一服休んでいる。",
              "citation": {
                "source": "忠僕",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒吉は、薄く笑って、葉子の、駈ける度にぷかぷかと跳ねる断髪の背後姿を、見詰めていたが、葉子の姿が、しきりの幕に、隠れて仕舞うと同時に、又頭の中に拡がって来たのはあの奇怪な、幻影の事だった。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにもむつかしく考える必要はない――　彼は二服目をぷかぷかと吸って独りごとしながら立ちあがった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき広間では、誰も皆、煙草をぷかぷかふかして、すっかり緊張を解いていた。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼の真中に落ちる雷はひどく、ダイナマイトを投げ込んだよりも大きな音がして、魚類がみなぷかぷか浮き上るとか。",
              "citation": {
                "source": "牛乳と馬",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い眼を据えてぷかぷか烟草を吹かしている。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこんどはきちんとした旅装をととのえ、トランクをかつぐと、莨をぷかぷかとふかしながら、悠々とこの館をふらふらと出ていってしまったのであった。",
              "citation": {
                "source": "大使館の始末機関",
                "author": "――金博士シリーズ・７――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しきりに煙草をぷかぷかふかしながら、正太の話をきいていたが、たいへん熱心にみえた。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "小食堂には、先におきた艇夫たちと、それから非番の艇夫たちが、卓をかこんで、さかんにぱくついたり、茶をがぶがぶのんだり、それから煙草をぷかぷかふかしたり、まるで場末の小食堂とかわらない風景だった。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどへんなものが、波にゆられながら、ぷかぷか浮いている。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかげんの時分になると、座右からかますを取り出して、カチカチと火をきって、ぷかぷかと二三ぷく煙草をのんでしまっては、さて悠々と、老木の梢の上なんぞを上目づかいでながめて、鶯がどこへ来ているか、雀が何羽止ったかという数なんぞ読んでいる様子が、お松にとっては、いよいよ小憎らしいばかりです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い水着を着たのや、青いのや、黒いのや、さまざまで、まるでくらげのお仲間のように、ぷかぷかと浮かんでいたのです。",
              "citation": {
                "source": "海と少年",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年にとつてかうした人物は苦手なものだが、とにかくその面前で、しかもその倶楽部のサロンの重厚な空気に圧倒されながら、てれかくしに安煙草をしきりにぷかぷかやりながら十吉が受けた相談といふのは、手つとり早くいへばＪ国の商務館に勤める気はないかといふ話であつた。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は「嘘をつけ」と腹の中で言ったまま、ぷかぷか煙草をふかす。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくのあいだ、もの言わず水ぎせるをぷかぷかさせてたんだけど、やがてうでをほどいて、ふたたび口からきせるを外して、ひとこと。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくのあいだ、もの言わずぷかぷかやってたんだけど、やがてうでをほどいて、ふたたび口から水ぎせるを外して、ひとこと。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だがもう話してもいいだろう」　頭をかしげて、葉巻を短く、せわしげにぷかぷかふかしながら、叔父は一心に聞いていた。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            }
          ]
        }
