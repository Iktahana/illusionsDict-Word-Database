        "examples": {
          "standard": [
            {
              "text": "彼は韻を踏んだ詩よりも、自由な形式で書かれたプローズを好んで読んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "その作家のプローズは非常に洗練されており、まるで音楽のようなリズムを持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "翻訳の授業で、古典的なプローズを現代の自然な日本語にどう訳すか議論した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そのために人物は概ね類型的となり、筋も亦単純で大概は似たり寄つたりのものであるし、更に又、その対話の方法や、洒落や、プローズの文章法なぞも、国別に由つて特別の相違らしいものを見出すことは出来ないやうである。",
              "citation": {
                "source": "FARCE に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピネロというのは、プローズ・ドラマ（散文戯曲）を英語で書いた有名な人である。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
