        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "海洋博物館の前を西へ高架線に沿うて行くと停車場の前をぬけてスプレーの河岸へ出る。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルシャル橋や王宮橋から毎日のように眺め見下ろしたスプレーの濁り水に浮ぶ波紋を後年映画「ベルリン」の一場面で見せられたときには、往年の記憶が実になまなましく甦って来るのを感じたのであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓はターリング・プレースの花園に隣った寺の墓地の静かな片隅にある。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は空中滑走する、戦い疲れた陳独秀とビクトリア・カップよりセント・ジョウジ・プレースに至る山頂火車のなかで彼等は力なく握手して、空中の鏡の上にモーニング姿の印度人のイサックを発見するのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "早暁の町のアスファルトの上を風に吹かれて行く新聞紙や、スプレー川の濁水に流れる渦紋などはその一例である。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが既往の失敗とがめず、もいちど信じてだまって持たせて呉れたなら、私いのち投げてもプレート守ったにちがいない。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "室内の造作はプレーンでモダンな洋式を、どこか日本趣味に通じさしたものがあり、この室内とこの人間との雰囲気の醸す感じからは、東京の下町というものが一方｜洒脱でありながら一方ローカルなものを持っているのを受取らせます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その沢山のプレーキの歯止めを噛ませるうちには、どれかの歯止めが役に立つのです。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンド、アイ、ノウ、ザット、マイ、マザー、イズ、プレーイン……」と、鼻にかかった、甘ったるい声で、晴れ晴れと唄いながら、美和子が帰って来た。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二はさまざまな電子本の体裁のテンプレート集。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "特にあらかじめ用意されているテンプレートを用いれば、本作りの作業自体には頭をひねる要素はほとんどない。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワークスのプロモーションにあたって連携プレーを狙う各社からの挨拶が続いているにもかかわらず、アルコールがすでに回りはじめたのか、会場の一部からは通夜の宴の喧騒を思わせる大声が上がり始めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂村大人は一九八〇年代半ばから、さまざまな機器に組み込まれたコンピューターの連係プレーによって人の生活を丸ごと支援する電脳社会のイメージを軸に、ＴＲＯＮプロジェクトを展開してきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで電脳を孤立化させることなく情報のパイプをつけ、社会を形成して連係プレーを演じさせる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この新しいマシンの詳細は明らかではないが、いずれにしてもマックＯＳとの連係プレーを演じることだけは間違いないだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "短いつなぎで、校舎から見た寮全景、下からあおった東棟、階段ホール、部屋の扉、そのアップ（一〇二というプレートが読める）、全員がベッドで寝ている光景。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「沼　松山柾生」というプレートと、モノクロでは、ただの模様にしか見えない陰鬱な油絵。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "『二中年図』ってプレートがはってありそう」　令子は、ふたりともヒゲをそったほうがいいわね、とつけくわえて、高志のむかいに坐った。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ・Ｃのスプレーで睡魔を防ぎながらヤットここまで書いて参りましたが、もう夜が白けかかって脳味噌がトロトロになりましたから擱筆します。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井を縦断している二条のレールをワイヤー・プレーをギリ／＼と吊したグレーンが、皆の働いている頭のすぐ上を物凄い音を立てゝ渡って行った。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "横ボール盤の側に、四五人の職工とパンパン帽をかぶった職長が集って、ワイヤー・プレーを跛に吊したグレーンがガラ／＼と寄ってくるのを見ていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "グレーンがとまると、ワイヤー・プレーは余勢でゆるく揺れた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワイヤー・プレーは底を二つの滑車にのせ、穿孔機の腕にその軸と翼を締めつけて、固定された。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、あの大きなワイヤー・プレーはたった一つの音もたてずに、グイと手前にのめってくる。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲球がちっともはいらんじゃないか、五寸もプレートからはなれてるんだから、どんなにアンパイアが同情したって、あれじゃ、ストライクにゃできんからのう……」　局長は忙しいと言いながら、暢気そうに長々と野球の話をはじめるので、勝男の方がはらはらしたくらいだった。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "プレース・ド・レパプリクの噴水池は涸れ果てて、まんなかに飾られた女神の像の生白い片腕がもがれている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "プレース・ド・レパプリクの噴水池は涸れ果てて、まん中に飾られた女神の像の生白い片腕がもがれている。",
              "citation": {
                "source": "ランス紀行",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "気取って、金縁の椅子等を置いたのではなく、大きなやや古風なファイア・プレースでもあり、埋まってしまうような大椅子、長椅子があり、気持のよい出窓の下の作りつけ腰掛。",
              "citation": {
                "source": "書斎を中心にした家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "希臘語を解しプレートーを読んで一代の碩学アスカムをして舌を捲かしめたる逸事は、この詩趣ある人物を想見するの好材料として何人の脳裏にも保存せらるるであろう。",
              "citation": {
                "source": "倫敦塔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
