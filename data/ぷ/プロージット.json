        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "群集が一度にプロージット・ノイヤール、プロージット・ノイヤールと叫ぶ。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅れて来る人々もあちこちの横町からプロージット・ノイヤールと口々に叫ぶ。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査もにこにこして、時々プロージットの返答をしている。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って寝ようと思ったら窓の下でだれかプロージット・ノイヤールと大きな声がして、向こうの家からプロージットプロージットとそれに答えているのが聞こえました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺々の鐘が鳴り渡ると爆竹がとどろいてプロージット、プロージットノイヤールという声々が空からも地からも沸き上がる。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしよし、プ、プ、プロージット。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "などゝ巻舌の英語で戯れのプロージットをしたりした。",
              "citation": {
                "source": "籔のほとり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂人は、ころがっていたウィスキーの瓶を取って、こぼれ残りの酒をグラスにつぐと、「弘ちゃんのために、プロージット！",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
