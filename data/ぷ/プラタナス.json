    "definitions": [
      {
        "index": 1,
        "gloss": "plane tree (any tree of genus Platanus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
