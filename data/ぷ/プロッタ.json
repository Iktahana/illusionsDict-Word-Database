          "standard": [],
          "literary": [
            {
              "text": "ペンで図面を描いていくプロッターを、当時早水たちはディジタルイクイップメント（ＤＥＣ）のＰＤＰ―11でコントロールしていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局言語一つ載っていないＴＫ―80にはプログラムの開発環境と呼べるほどのものがないことから、二台組み立ててみただけでプロッターの制御はあきらめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "円や楕円を書く手順は、プロッターの制御用アルゴリズムとして学会誌に掲載されていた論文を参考にして組み立てた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
