        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ワークスのプロモーションにあたって連携プレーを狙う各社からの挨拶が続いているにもかかわらず、アルコールがすでに回りはじめたのか、会場の一部からは通夜の宴の喧騒を思わせる大声が上がり始めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アスキーは16ビットへの移行期、ＣＰ／Ｍの16ビット版とマイクロソフトのＭＳ―ＤＯＳの双方を競わせながらプロモーションを並行して進めたが、古川はここでＭＳ―ＤＯＳの立ち上げに努めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "２・０となってＩＢＭが懸命にプロモーションをかけるＯＳ／２もまたしかり。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＴＲＯＮのプロモーションは広告代理店にまかせるのではなく、アスキーと組んで自分たちで主体的に進めたいと後藤は考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェニファーは、自分の16ミリ映画『第57番サーフ最後の日々』のプリントを持ち、西海岸へプロモーションの仕事に出ている。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＷＳＬ局の『ナショナル・バーン・ダンス』やＷＳＭ局の『グランド・オール・オプリイ』の人気は、カントリー・ミュージックのロード・ショウとプロモーションを生んだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナッシュヴィルがあるテネシー州では、州の歴史と発展を写真と文章で説明したプロモーション用の本が、州政府から発行されている。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
