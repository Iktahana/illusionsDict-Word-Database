        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ま、こんなもんか」　高志はプレイバックを聴いて、疲れたようにつぶやいた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "このシーンのプレイバックを見ると、おそろしくわざとらしいタイミングに見える。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "プレイバックがモニター・スピーカーから静かに流れた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィナーレ総踊りの場をプレスコアリングの音を出し、プレイバックする。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食後一休みしてセットで箱根関所、舞坂の残り、プレイバック三セットと、タイトルバックを撮る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後七時より、プレイバック、自動車の中の、「ハリキリボーイ」。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「酔へば大将」のプレイバック数カット。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "野川君の家の前二カット、その附近口笛のプレイバック二カットであがり。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳶の巣山の合戦、プレイバックの豪快ぶしがまっ先、刀を抜いてエイとやったり、槍をしごいたり、いや何うもイタにつかない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月十二日（月曜）　八時起き、撮影所へ行ったのが十時、大久保邸の庭のセット、「宵待草」のプレイバック二三カットで昼めしになる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "プレイバック、小百合と恋人の歌、山根寿子と土屋伍一の二人、そこへかけつけて――といふところ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "お城の傍の松の木道、プレイバックでタラヒ登城、移動だから中々暇どる、それにタラヒ数十の行列だから、落ちる者があったりして、結局二時迄かゝる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "プレイバックの失恋の歌、クレーンでやるのでこれが又手間どり、手持無沙汰で待つ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高杉と二人のとこ数カット、プレイバックで畑を耕すところ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三里塚の農場、今日のところは多くプレイバック。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、とうもろこし畑のプレイバック。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
