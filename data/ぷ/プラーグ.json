        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一九一一年にはプラーグの正教授に招聘され、一九一二年に再びチューリヒのポリテキニクムの教授となった。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ティコは一六〇一年にプラーグで没した。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "大王はいたずらに待つ時は墺国より攻撃せらるるを察知し、再び仏・巴と結び一七四四年八月一部をもってシュレージエン、主力を以てザクセンよりベーメンに入り、九月十八日プラーグを攻略した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラーグ要塞は当時ほとんど構築せられていなかったのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大王は熟慮の後ベーメン侵入に決し、冬営地より諸軍をプラーグ附近に向い集中前進せしめた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月六日プラーグ東方地区で墺軍を破り、これをプラーグ城内に圧迫した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラーグは当時既に相当の要塞になっていたので簡単に攻略する事が出来ず、五月二十九日より始めた砲撃も弾薬不充分で目的を達しかねた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら大王軍は遂に大敗し、止むなくプラーグの攻囲を解き、一部をもってシュレージエン方向に主力はザクセンに退却した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一二年、プラーグでボルシェビキの特別の党指導部が成立して以来、特に議会フラクションの指導に忽ち現われた如く、党の独自的指導は強まった。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは多分プラーグかでオリンピックのあった時だと思います。",
              "citation": {
                "source": "現実の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の夏のパリの平和会議にも見えなかったし、プラーグの第二会場にも現れなかった。",
              "citation": {
                "source": "人間イヴの誕生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この間、何年ぶりかで「プラーグの栗並木の下で」を観て、俳優生活というものについて、これまでになく心を動かされるものがあった。",
              "citation": {
                "source": "俳優生活について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「プラーグの栗並木の下で」を見ているうちに私の心をうったのは、そんな名優とか大俳優とか一生云われることのない俳優たちが、どんなに熱心に科白を云い、扮装をし、舞台に一つの創造の世界を実現させて行こうと努力しているか、ということの感動であった。",
              "citation": {
                "source": "俳優生活について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「プラーグの栗並木の下で」を観ていて痛切に心に浮んだのはこの問いであった。",
              "citation": {
                "source": "俳優生活について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手許にプログラムがなくて正確に云えないけれども、「プラーグの栗並木の下で」に一人、生活態度のフヤフヤな若い医者が登場する。",
              "citation": {
                "source": "俳優生活について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "サーシャの呪や、番頭の盗みや、忘られぬ靴屋の主人の褐色の家が絶えず真向うに見えているという窒息的な目の前は広々と拡大せられ、プラーグやロンドンの都市の美しさが、そこで行われている生活がゴーリキイの世界の中のものとなって来た。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "法水は考証気味な視線を休めずに、「まるで騎士埴輪か鉄の処女としか思われんね、これがコペツキーの作品だと云うそうだが、さあプラーグと云うよりも、体躯の線は、バーデンバーデンのハンスヴルスト（独逸の操人形）に近いね。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたいプラーグの万国操人形聯盟にだって、最近『ファウスト』が演ぜられたという記録はないでしょうからな」「ファウスト※　ああ、あのグレーテさんが断末魔に書かれたと云う紙片の文字のことですか」レヴェズ氏は力を籠めて、乗り出した。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその半年後になって、ようやくプラーグ市の補助憲兵デーニッケによって犯人の奸計が曝露され、やはり最初の嫌疑者である、猶太人の製粉業者が捕縛されるに至った。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリー語を使ったところ、やっと片言が通じて、私の旅券にはポーランドを通過することが書いてないから、午後一時まで待っていて、チェコのプラーグまで引返して、プラーグの日本公使館でポーランド通過のビザーを記入して来い、というのでした。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも私はプラーグまで逆戻りしなければなりませんでした。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後一時の汽車に乗り、汽車の中から日本公使館に電報を打ったので、汽車がその夜九時にプラーグに着いた時、松田書記官が駅に出迎えて下さったので、地獄で仏に逢ったような気がして、私は松田さんにすがりついて嬉し泣きに泣きぬれてしまいました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーマンがオペラに始めて出たのは十八歳の時、今のチェコの首都、プラーグの歌劇場でモーツァルトの歌劇「魔笛」の端役になって出たのでしたが、主役のパミィナになったソプラノが開演直前に病気で倒れてしまった。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "一三〇四年軍をボヘミアに進め、その同士を蹂躙す〔筆〕神の筆（生命の書に書き入るゝ）〔プラーガの王國〕プラーグ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "大使のところで人見絹枝その他プラーグのオリンピックへ出かける女子競技の連中があつまり御飯。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーレムが暴れ廻ってプラーグの街をひっくりかえしたところで、ジュウタン爆撃以上にはやれないだろう。",
              "citation": {
                "source": "戦争論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィーンからプラーグ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワルシャワからウィーンへゆき、プラーグからカルルスバードをまわってベルリンには少しゆっくり滞在するというのが伸子と素子との旅程であった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
