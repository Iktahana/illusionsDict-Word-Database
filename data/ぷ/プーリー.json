        "examples": {
          "standard": [
            {
              "text": "クレーンのロープが絡まらないよう、プーリーの滑りを定期的に点検する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "エンジンルームから異音がするので確認したところ、エアコンのプーリーが摩耗していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "井戸から水を汲み上げるため、滑車となる丈夫なプーリーを新しく取り付けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "車輪とプーリー、梃子、ネジ、コード、導管、篩と濾過器、そしてさらに、角度、シリンダー、敏捷さ、打撃、抵抗、は今や医学文献で使われる言葉になった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
