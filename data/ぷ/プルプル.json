        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二｜匹の馬は、達二を見て、鼻をぷるぷる鳴らしました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある一定の調子の響きを聞き当てたとき、子供はぷるぷると胴慄いした。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その朝、父は私にも一緒に行くようにすすめて下さったのですが、私は何だか、こわくて、下唇がぷるぷる震えて、とてもお伺いする元気が出なかったのです。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎゆつと固くつぶつてみたり、ゆるくあけて瞼をぷるぷるそよがせてみたり、おとなしくそんなことをしてゐるだけなのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎゅっと固くつぶってみたり、ゆるくあけて瞼をぷるぷるそよがせてみたり、おとなしくそんなことをしているだけなのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の光がぷるぷるやってやがる。",
              "citation": {
                "source": "若い木霊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブン蛙とベン蛙がくるりと外の方を向いて逃げようとしましたが、カン蛙がピタリと両方共とりついてしまひましたので二疋のふんばった足がぷるぷるっとけいれんし、そのつぎにはたうとう「ポトン、バチャン。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二匹の馬は、達二を見て、鼻をぷるぷる鳴らしました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "穂吉はどうしたのか折られた脚をぷるぷる云はせその眼は白く閉ぢたのです。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "せなかに草束をしょった二匹の馬が、一郎を見て鼻をぷるぷる鳴らしました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブン蛙とベン蛙がくるりと外の方を向いて逃げようとしましたが、カン蛙がピタリと両方共とりついてしまいましたので二疋のふんばった足がぷるぷるっとけいれんし、そのつぎにはとうとう「ポトン、バチャン。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "穂吉はどうしたのか折られた脚をぷるぷる云わせその眼は白く閉じたのです。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こうからぷるぷるぷるぷる一ぴきの蟻の兵隊が走って来ます。",
              "citation": {
                "source": "ありときのこ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふからぷるぷるぷるぷる一ぴきの蟻の兵隊が走つて来ます。",
              "citation": {
                "source": "朝に就ての童話的構図",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいいち輪廓のぼんやり白く光つてぷるぷるぷるぷる顫へてゐることでもわかります。",
              "citation": {
                "source": "朝に就ての童話的構図",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野原のポプラの錫いろの葉をちらちらひるがえし、ふもとの草が青い黄金のかがやきをあげますと、その二つのうずのしゅげの銀毛の房はぷるぷるふるえて今にも飛び立ちそうでした。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり風がこわいのか、ぷるぷる震えている。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとに侮辱をされはせぬかと、散りかけている枯葉のように絶えずぷるぷる命を賭けて緊張している。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言ったら、下唇がぷるぷる震えて来て、涙が眼からあふれて落ちた。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、お面の両耳が、ぷるぷるッと蝉の羽根のようにふるえた。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな長火鉢に平鍋がかかって、白い豆腐が煙りを吐いて、ぷるぷる顫えている。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "１ぴきの図体のでかいワンコが、くりくり大きなお目々でこっちを見ていてね、ぷるぷると前足をのばして当てようとしてくる。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "１ぴきの図体のでかいワンコが、くりくり大きなお目々でこっちを見ていてね、ぷるぷると前足をのばしてさわろうとしてくる。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            }
          ]
        }
