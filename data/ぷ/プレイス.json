        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただ一人、部屋に籠って明々と燃えているファイヤープレイスの前に揺椅子をひき据えていました。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども勿論、そんな真暗な大雨の夜に窓から訪れて来る様な酔狂なお客様の影なぞは見とめるべくもなかったので、再びファイヤープレイスの前に戻りました。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "サリィの方はペッカム、メイフィールド・プレイス三の下宿におります。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "プレイストシーン期に、北米に棲んだ馬数種ありて南米まで拡がった。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、普通の馬と別ちがたい遺骨が、欧州とアジアのプレイストシーン層より出るを見れば、現存種の馬が始めて世に出たは、よほど古い事と見える。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "サウシーの『コンモン・プレイス・ブック』四輯に、コングリーヴの一犬ペンクリッジ寺の修繕一年に竟り誰も詣でざるに、日曜ごとに独り欠かさず詣でたと載す。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「追い出しの曲」は、予定どおり、アニマルズの〈ウィーヴ・ガッタ・ゲット・アウト・オヴ・ディス・プレイス〉（〈朝日のない街〉！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "６おれたち、ここから抜け出さないとたとえ、そんなことなど、できないとしても〈ウィーヴ・ガッタ・ゲット・アウト・オヴ・ディス・プレイス〉アニマルズ　興奮と憂鬱が同時に押しよせて、一九六六年六月が終わりつつあった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "アニマルズの〈ウィーヴ・ガッタ・ゲット・アウト・オヴ・ディス・プレイス〉のベースラインが流れ、答案用紙に鉛筆を走らせる四組を、立った視線の高さから、横移動でゆっくりと見せる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハム・ヤードで死んだ女の子とグレイト・ウィンドミル・ストリートで死んだ女の子はブロード・ストリート、デュフールズ・プレイスの学校に通っており、このポンプの水を飲む習慣があり、ネイラーズ・ヤードからの子供その他はこの学校およびブロード・ストリートに近いその他の学校に通っていた。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口から一番奥の方の壁にこれも石で出来たファイヤプレイスがあり、その右手には棚が三段ほどあって、何だか皿見たようなものが積み重ねたり、列んだりしている。",
              "citation": {
                "source": "西班牙犬の家",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "水盤の傍と、ファイヤプレイスとそれに卓に面してと各一つずつ。",
              "citation": {
                "source": "西班牙犬の家",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂のファイアプレイスのよこの棚をそういう本の棚にすればよいと云って居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがＰ――プレイスから石を投げれば届く距離で、極めて上品な街にある。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "「連れて来れば、ほんとに似合うかどうか、よくわかるから」「美人です」「ジ・イアリングス・クッド・ルック・アウト・オヴ・プレイス・オン・ア・ガール・オヴ・セヴンティーン。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
