    "definitions": [
      {
        "index": 1,
        "gloss": "(breaking) with a snap (of a thread, rope, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "が、声は、もうぷっつり聞えなかった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その拍子に柿江がぷっつりと黙った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――――　そこで彼の過去の世の記憶はぷっつり切れている。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことがあってから、私達がぷっつりと、この悪戯を止めたのは、申す迄もありません。",
              "citation": {
                "source": "納豆合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで二人の間の争いはぷっつりと消えた。",
              "citation": {
                "source": "栗の花の咲くころ",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分が放り出される所まで来ると記憶の糸はぷっつり切れてしまった。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘当むすこの宗助はどういうわけで縁を切ったんだときいてやりましたらね、あんまり芸ごとと、それから弓にばかり凝りゃがるんで、十年まえにぷっつりと親子の縁を切ったと、こういうんですがね」「なにッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆とる右腕を切ってやったら絵はかけぬはずじゃ、絵がかけなくば名声がすたるはずじゃ、名声がすたらばわたくしの恋もさめるはずじゃ、とこのようにあさはかなことを申されまして、おむごたらしいことに根もとからぷっつりとお切り取りなさいましたのでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "いううちに、けがをしたじゃねえか」　いったときは、名人の小柄が、ぷっつり眠白の右手の甲にささって、ぽろりわきざしが手のうちから床にすべったところを、近よりながら例の草香流で、すでにぎゅっと片手捕えにねじあげていたあとでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの事件は何です、と遠慮がちに聞いてみると、「つまらない女のことでしてね、つい刃傷沙汰になってしまったのです」そういったままぷっつりと口をつぐんで、自分の過去の経歴と事件の内容については何事も語らなかった。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸の声が、ここ「大地の果て」でぷっつり切れてるのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのアナウンスもやがてぷっつりと切れ、暗黒なエーテルの漂う夜空からは、内地の放送局が一つ一つお休みなさいを云って電波を消してゆき、あとには唯一つ、南京放送局の婦人アナウンサーが哀調を帯びた異国語で何かしら悠くりと喋っている声だけが残っていた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は床を踏み鳴らし、口小言をいったり、歯を喰いしばったりして力一杯鍵束を引抜いた拍子に、糸がぷっつりと切れて、錆び鉄鎖のような音響とともに、鍵も銀器も一しょくたになって床に散乱した。",
              "citation": {
                "source": "空家",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへおかあさんが、斧をもってかけつけたので、ジャックは斧をふるって、いきなり、はしごの根もとから、ぷっつり切りはなしました。",
              "citation": {
                "source": "ジャックと豆の木",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かち合っちゃうと駄目だから」「あら、私そこをねらってたのに……」「ふ、ふ、ふ、ふ」　ぷっつり切った髪の切口を青いスウェータアの背中で西日にチカチカさせながら、忍び声をして押しあっている。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「兄貴、長いことする仕事じゃあねえ、お前、ぷっつり、この道あ、よしたと考えていたが――危え、左手一本で、昔のように、上手な仕事が出来るもんけえ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでこんどわしは雷を使う研究はぷっつりやめて、あの研究所からべんりな機械を製造しますわい。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「電線があのとおりぷっつり切れています。",
              "citation": {
                "source": "千早館の迷路",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれからぷっつり、彼女の手紙はとだえてしまった。",
              "citation": {
                "source": "一つの愛情",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は、お金がほしいとか、僕はとても貧乏だとか、そんなことをしきりに云っていらしたのが、ぷっつりと、お金のことは口になさらないんです。",
              "citation": {
                "source": "千代次の驚き",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、自分で籠に乘つて、綱で高い屋の棟にひきあげさせて、燕が卵を産むところをさぐるうちに、ふと平たい物をつかみあてたので、嬉しがつて籠を降す合圖をしたところが、下にゐた人が綱をひきそこなつて、綱がぷっつりと切れて、運わるくも下にあつた鼎の上に落ちて眼を廻しました。",
              "citation": {
                "source": "竹取物語",
                "author": "和田萬吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ぷっつりと言葉を切って、眼玉をぐるりとさして、瞼を閉じました。",
              "citation": {
                "source": "三つの嘘",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の船用｜大形ナイフでぷっつりと切ってやれば、ヒスパニオーラ号はぶんぶん帆を唸らせながら潮流と共に流れ下るだろう。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は錨索がもう一度弛んだのを感じたので、ぐっと力をこめて残りの縄をぷっつりと切った。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人の心底をよく訊いてみなければならぬが、二、三日前の夜ちょっと顔を覗けた時、すげなく硝子戸を閉めたことと言い、そののちこうして硝子戸を開かなくしたことなどを思い合わしても女には私のことにぷっつり気がなくなってしまったのではなかろうか？",
              "citation": {
                "source": "霜凍る宵",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷のつき当りに右側の山がとび出して、街道がその直下でぷっつり切れていると思ったが、急に左に曲って、その麓をぐるり廻って、なお西へつづくらしい。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞬間にぷっつり息が切れて、わあっとしたどよめきになる。",
              "citation": {
                "source": "春",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いささか考えるところがあるからな」「はあ、なぜですか」「皆ここを抜けでていってしまうと、せっかくミミ族とつきあいの道ができたのに、ぷっつり切れてしまうからなあ」「でも、危険ですぞ、あとに残っておられると……」「まあいい。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とすぐ、ぷっつりきれて静寂にかえりました。",
              "citation": {
                "source": "落ちてゆく世界",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
