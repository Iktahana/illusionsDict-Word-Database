        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "墓はターリング・プレースの花園に隣った寺の墓地の静かな片隅にある。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は空中滑走する、戦い疲れた陳独秀とビクトリア・カップよりセント・ジョウジ・プレースに至る山頂火車のなかで彼等は力なく握手して、空中の鏡の上にモーニング姿の印度人のイサックを発見するのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "プレース・ド・レパプリクの噴水池は涸れ果てて、まんなかに飾られた女神の像の生白い片腕がもがれている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "プレース・ド・レパプリクの噴水池は涸れ果てて、まん中に飾られた女神の像の生白い片腕がもがれている。",
              "citation": {
                "source": "ランス紀行",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "気取って、金縁の椅子等を置いたのではなく、大きなやや古風なファイア・プレースでもあり、埋まってしまうような大椅子、長椅子があり、気持のよい出窓の下の作りつけ腰掛。",
              "citation": {
                "source": "書斎を中心にした家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見たところ四、五時間もあれば行ってこられそうなので、荷は全部ルックに詰めてビバーク・プレースに置き、ピッケル一本持って出発する。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァンデラー家はイートン・プレースに住んでゐて、自分が行かうとしてゐる處はナテイン・ヒルの近くであつた。",
              "citation": {
                "source": "帽子箱の話",
                "author": "スティーヴンスン",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし私と一緒にイートン・プレースのトマス・ヴァンデラー卿のお屋敷まで行つて下されば、きつと何もかもはつきり分ります。",
              "citation": {
                "source": "帽子箱の話",
                "author": "スティーヴンスン",
                "note": "青空文庫"
              }
            },
            {
              "text": "署長さんなら多分喜んで手前と一緒に、イートン・プレースへでもどこへでもぶらつきに行くかも知れねえ。",
              "citation": {
                "source": "帽子箱の話",
                "author": "スティーヴンスン",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは私と一緒にイートン・プレースへ行つちやくれないし。",
              "citation": {
                "source": "帽子箱の話",
                "author": "スティーヴンスン",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今はもう少しも節約といふやうな事は考へず、そこから最も近い辻馬車の客待ち場へ行つて、馬車でイートン・プレースへ向つて出發した。",
              "citation": {
                "source": "帽子箱の話",
                "author": "スティーヴンスン",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれを家のフアイヤプレースの棚にのせてきたことをはつきり記憶してゐるのだが。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国ついでに、もう一つ米国の話を持ち出すと、私のいた大学、プリンストンの寄宿舎には、全部ではないが、オープンファイアプレースを持つ部屋が沢山あった。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロイド博士が言ったのはロザーハイヅのシャルロット・プレースのことであり、１軒を除いた７軒の住人は、７軒すべての屋外便所の内容が流れこみテムズに繋がっている溝から、上水を得ていた。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コッドマン・プレースだ」と他の者が主張する。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のパル・マルにある立派な建物はまだなくて、ウォータールー・プレースの私人の家に、学者や文学者が集ったので、ファラデーはその名誉秘書になった。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウエスト（人）West.ウォータールー・プレース（地）Waterloo place.ウォーラストン（人）Wollaston. ウイリアム・ハイデ・ウオーラストン。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国ついでに、もう一つ米国の話を持ち出すと、私のいた大学、プリンストンの寄宿舎には全部ではないが、オープン・ファイヤプレースを持つ部屋が沢山あった。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
