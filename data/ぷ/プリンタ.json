        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ほとんど例外なく、コンピューターにはプリンターが付いています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにアップルはマック用に、まったく新しい高性能プリンターを開発しているという情報が、ブレイナードの気持ちを固めました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイアウトが工夫できて、いろいろなフォントが使えるソフトウエアを書いたとしても、これまでのようなギザギザの目立つプリンターしか使えないのでは台無しです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時ゼロックスは、レーザーライタなどに繋がっていく、電子プリンターの開発に取り組んでいました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字や図版、写真、イラストなどのデータを、コンピューターはワーノックの言語でまとめてからプリンターに手渡します。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この指示をもとに、それぞれのプリンターは自分の最大限の力で印字します。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "より性能の高いプリンターが使えるようになれば、これまでのデータをそのまま使って、より細密な印字が可能になるというアイディアでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マックの追い込みにかかっていたジョブスは、このマシン用に電子プリンターを開発する計画があることを明かします。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまくすればこれをプリンターの業界標準言語に仕立て、さらに印刷用機器にも幅広く食い込めるかもしれません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "印刷に比べれば多少は劣るかもしれませんが、従来のプリンターとはかけ離れた仕上がりです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカでまとめられたデータが世界各国に回線経由で流れていき、受け取った人がプリンターにかけると、雑誌の頁が打ち出されてくるのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "受け取った側は、手許のプリンターで打ち出すこともできます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "校正を経て完成したデータを、点字プリンターにかけて打ち出す。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お点ちゃん」と名付けられた、無料で利用できる点訳ソフトは、漢字仮名交じりテキストから、点字プリンター用のデータを直接生成する。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "この延長線上に、点訳ソフトを使って点字データを入力し、点字プリンターに打ち出して、「書ける」ようになった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターの頭脳部分から、文字の形や並び、絵柄をプリンターや画面に伝えるさい、全体のレイアウトをあらかじめしっかり作った上で詳しい指示書の形で渡す方法がある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなら画面で見たままが、どんぴしゃでプリンターからも出る。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏返せば、プリンターや画面の解像度（どこまで細かく表現できるかを測る目安だ）に応じて、指示の内容を一々変えてやる必要がない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "プリンタの制御方式を統一できれば、話が非常にすっきりすること。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ページ記述言語（例の一頁まるごと仕上げたレイアウトを、コンピューターが画面やプリンタに渡す方式の総称だ）への対応という新しい段階で、ポストスクリプトが統一方式の候補の一番手となったことまでは白ビットの教えの通り。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者が書くという入り口とプリンターや印刷屋が刷るという出口は、デジタル化された。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "メモリを五百十二キロバイトに拡張した第二世代機に、プリンターと外部フロッピーディスク・ドライブ一台をくっつけたバンドル特価（言うまでもなくアップル用語で、特別に高いという意味だ）は、百万円を越えていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "出版社側が電子化された文章の受け皿を全く用意していない時期は、せっかくコード化して作ってやった文章をわざわざプリンターで打ち出し、紙の上のインクの染みに変えて郵送するなりファックスするなりした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コマンドを確認し、リターン・キーを叩き、プリンターに処理をわたす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ささやかな弁解の道具として、プリンターから吐き出された紙束をもち、上着のポケットにディスクをほうりこんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今工場に出ていないので、Ｓからその編輯を引き受けて、私の手元に伊藤、須山の報告を集め、それをもとにして原稿を書き、プリンターの方へ廻わした。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "プリンター付きのレポから朝早く伊藤が受取ることになっていた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんマウスもなければ、プリンターもない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "キーボード、プリンター、紙テープパンチ、紙テープリーダーを一体にまとめたＡＳＲ―33は、本来の用途以外にも、比較的小型のコンピューターシステムの入出力機器として使われていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一部　あとがき　漢字プリンターで打ち出された校正紙を、ようやく読み終えたところです。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
