        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これからプリンス・チャーミングと呼ばせて頂きますわ。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "『その人は、プリンス・チャーミングって云うの。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ああ、あすこにプリンス・チャーミングが！",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は僕の事を何時もプリンス・チャーミングと呼んだ。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "『プリンス・チャーミング！",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "プリンス・チャーミングが妾をこんな目に遭せてからざっと、もう十八年からになるんだからね。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一枚のマントはプリンス・オヴ・ウエルスの、海軍将校としてのあの御姿を美しいと思って、あれをお手本にして造らせました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "プリンスとプリンセスと一夜の宿をたのみに来たのだ。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "プリンス、オヴ、ウェールス岬――つまり P. R. WALES はその略記号なのだ。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「デジネフ岬とプリンス・オヴ・ウェールス岬も、ごく狭い海峡を距てて向いあった両地点である。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「プリンス・オヴ・ウェールス岬とデジネフ岬のある中間でしょう」「正にそのとおり！",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニユーヨークにプリンストン出の若い銀行家があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四八年の四月、アインシュタイン、ハリソン、ブラウン、フレデリック、セイツなど六人の自然科学者が、プリンストンで警告声明を発表した。",
              "citation": {
                "source": "私の信条",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アインシュタインその他の人々のプリンストン警告声明を、きょう改めてよみかえすと、わたしたちは、そこにあらわされている偉大な科学者たちの、極めて率直・善良な責任感について感動しないではいられない。",
              "citation": {
                "source": "私の信条",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカでもプリンストン大学では、校内での運動を禁じた。",
              "citation": {
                "source": "再武装するのはなにか",
                "author": "――ＭＲＡについて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "近いうちに、市の医者がこの近所へ出張して来て、種痘をすると言って来たから、その期日をだしておかなくちゃあ――未来の労働者と兵隊がみんな疱瘡に罹って死んでしまったら、プリンス伊藤もココフツォフも困るだろう。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一プリンス伊藤を斃したところで、日本のジンゴイズムはどうなるものでもない。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて又、プリンス・オブ・ウェルスが四月十二日に来朝される。",
              "citation": {
                "source": "二つの家を繋ぐ回想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "プリンス of Wells の歓迎門などを見る。",
              "citation": {
                "source": "「伸子」創作メモ（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリー生まれのユダヤ人数学者で、ヒットラーのドイツを逃れてプリンストン大学に移っていたジョン・フォン・ノイマンは、マンハッタン計画に貢献するとともに、コンピューターの基本原理の確立においても決定的な役割を演じた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ―１００用の日本語ワードプロセッサーの仕様が最終的に固まった六月、ジャストシステムの浮川和宣と浮川初子、福良伴昭の三人はアスキー側との打ち合わせを終えて赤坂プリンスホテルの最上階のレストランで、チャンスをこの手につかんだことを互いに祝い合った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九九三（平成五）年五月十七日、新高輪プリンスホテル飛天の間に業界関係者と報道陣およそ二〇〇〇人を集めて、マイクロソフトはＷｉｎｄｏｗｓ３・１日本語版の発表会を催した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の「プリンス」（近時興亡史論刊行會に於て本書を譯し君主經國策といふ）の第十五章より第十九章に至るまで數章は、要するに君主に僞善矯飾の必要なるを説きたる者にして、其の前提は人心を以て、專ら利己主義的なりとするに往り。",
              "citation": {
                "source": "韓非子解題",
                "author": "小柳司気太",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十二日（水曜）晴　プリンスオブウェールスの着京されるのを奉迎に行くと云って居るので、早く起きる。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "切角来られるプリンスも、泥田のような街道に、黒くしょぼしょぼ雨に打たれた人間を見るのはうれしくあられまい。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、プリンスオブウェールス歓迎のアーチ、花電車を見に行く。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この音楽会は前にも申上げましたように、赤十字社主催の恤兵音楽会ですので、キング・ジョージ五世とクイン・メリーを始めプリンスとプリンセス、それに大臣や政府の高官連、各国の大公使がおいでになって、ロンドン空前のお祭騒ぎ、二万三千名を入れる客席には聴衆がぎっしりつまっているという大変な盛況でした。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面が国王席になっていて、純白のアーミンの毛氈で飾ってあって、そこにキングとクインがプリンスやプリンセス多勢といらっしゃる。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは私達のカンパニーにいたイダルゴというイタリーのソプラノがエジプトのプリンスの御寵愛を受けたのです。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "イダルゴもその悪い例で、非常に別嬪さんだったのでエジプトのプリンスをとりこにしちまったんです。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
