    "entry": "プー",
    "reading": {
      "primary": "プー",
      "alternatives": [
        "ぷー",
        "ぷう",
        "プーッ",
        "ぷーっ",
        "プーっ",
        "ぷうっ"
      ],
      "is_heteronym": false
    },
    "grammar": {
