    "definitions": [
      {
        "index": 1,
        "gloss": "suddenly in a bad mood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蜻が傘にとまっていたのが外のとんぼと喰い合って小溝へ落ちそうにしてぷいと別れた。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはぷいと外へ出た。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小川は、なお、一と時、いかつい眼つきで源作を見つめ、それから怒っているようにぷいと助役の方へ向き直った。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という不作法な仲居さんだろうか、と私はぷいと横をむいたままでいたが、あ、お勘定が足りないのだとすぐ気がつきハンドバックから財布を出して、黙ってあの人の前へおしやり、ああ恥かしい、恥かしいと半分心のなかで泣きだしていた。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は急いで夕餐を濟まして、箸を投出すと直に、螢籠をぶらさげて、ぷいと家を飛出すのであツた。",
              "citation": {
                "source": "水郷",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "周三は耐らず嫌な氣持がしたので、ぷいと立起ツて二階へ歸らうとする………と格子の外に据ゑてある花屋の籠に、花といふ花が温い眞晝の日光を浴びて、凋むだやうになツて見えるのが瞥と眼に映ツた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ぷいと窓から出てゆく）妹　　今晩はいろいろな人が来るわね。",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄蔵はしばらくお父さんが、うしろに閉めた襖を見つめてゐたが、急に踵を返すと、ぷいと家を出ていつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "惣兵衛ちやんは、まるで紙鳶には興味がないといふやうに、ぷいと横を向いてしまつたからである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしが部屋へはいると、君は、いつでもぷいと部屋から出て行きます。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言い放って、ぷいと顔をそむけた。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "定枝はぷいと出て行った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉堂はまだ三十二歳、朝日軒の末娘は二十歳で、玉堂の顔を見ると、ぷいと顎をあげて、出て行き、彼はちょっと寂しかった……。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢雄はぷいと顔をそむけ、丁度駅へ大阪行の電車がはいつて来たのを幸ひ、おい楢雄とあわてて呼び掛けた修一の声をあとに、いきなりその電車に乗つてしまつた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の手もあんな風に動いたらなあ」　そして突然そんな風に云いながら、彼はぷいと席から立つのである。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが何が気に入らなかったのかおっさんはその後、編集長をぷいと辞めてしまい、すぐに雑誌もつぶれた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ははあ、俺がねらつてゐるのを感づいたな―』『よろしい、こつちだつて手はあるさ―』　彼はぷいと子供のやうに不機嫌になつてその日は帰つた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　京子は、またぷいと向うを向いてしまった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　京子は、ぷいと立ち上った。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "口惜しければ悟った証拠を持って来いと云ってぷいと向をむいた。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つなぞが解けたかと思や、また妙ななぞをおかけになりますが、まさかあっしをからかっているんじゃござんすまいね」　しかし、右門は答えずにぷいと表へ出ていくと、行きつけの権十郎床で、何を考え出したものか、しきりと念入りに月代を当たらせました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門は探索の方針についてなによりの手づるを拾いえたので、前途に輝かしい光明を認めながら、ご苦労ともきのどくだったともなんともいわずに、例のごとく黙念としながら、ぷいと表へ出ていくと、即座に伝六に命じました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘酒でも飲んで、暖かく寝ろよ」　ぷいと表へ出ると、うそうそとひとりで笑いながら、何思ったかやにわに伝六を驚かしていったものです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し見込みがはずれたかな――というように首をひねりながら、しばらく考えていましたが、やがてぷいと立ち上がると、ややうなだれて、あっけにとられている腰元たちをしり目にかけながら、さっと引きさがってしまいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と――ぎくりとなったようにうろたえて、その腕首をあわてながらそでにおし隠したものでしたから、右門は心の底までをも見抜くようにじっと彼女の顔を射すくめていましたが、はしもつけないで突然ぷいと立ち上がりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "――なにものか胸中に明察のついたもののごとく、ぴくりとまゆを動かして考え込んでいましたが、そのまま右門はおし黙って、ぷいと立ち去りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただにぷいと城中を立ち去ったばかりではなく、実に不思議――それっきりむっつり右門の姿は、どこへ行ったものか、皆目行くえがわからなくなってしまいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿へもかえらず、おしゃべり屋の伝六もそこへ置いてきぼりにしたままで、さながら地へもぐりでもしたかのように、煙のごとく城下からぷいと消えてなくなってしまいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "にらみ合っただけで一合も渡り合わずに、突然江戸錦がぷいと立ち上がって、にたり微笑を漏らすと、「おいどんが負けでごんす」　つぶやきながら、さっさとたまりへ引き揚げてしまったからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
