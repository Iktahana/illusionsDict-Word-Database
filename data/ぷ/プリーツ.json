          "literary": [
            {
              "text": "そして、プリーツのこまかいサモンピンクのスカート。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界市民、一号から三号まで……おそろいのように、アコーディオン・プリーツのスカートをはいている。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "アコーディオン・プリーツのスカートは嫌味だが、服も、靴も、アクセサリーも、みなホンモノで、三流クラス以下のファッション・モデルなどは、足もとにも寄れないほど、かっこうをつけている。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼稚園の制服だったプリーツのあるスカートにジャケット、そして帽子や靴、靴下、鞄などをクロゼットから出して来てベッドにならべると、すべては玩具のようだった。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "膝のかなり下まである丈のプレイドの、大きなプリーツのスカートにジャケットを、今日の恵子は身につけていた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "プリーツではないし、八枚はぎなんかでもなくて」「スカート丈は？",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜の彼女は、薄い生地に細いプリーツのたくさんある、くるぶしまで届く丈のスカートをはいていた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
