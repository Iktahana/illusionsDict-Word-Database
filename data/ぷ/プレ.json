        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "海洋博物館の前を西へ高架線に沿うて行くと停車場の前をぬけてスプレーの河岸へ出る。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルシャル橋や王宮橋から毎日のように眺め見下ろしたスプレーの濁り水に浮ぶ波紋を後年映画「ベルリン」の一場面で見せられたときには、往年の記憶が実になまなましく甦って来るのを感じたのであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "燧の鉄と石の触れあう音、迸る火花、ホクチの燃えるかすかな囁き、附け木の燃えつくときの蒼白な焔の色と亜硫酸の臭気、こうした感覚のコムプレッキスには祖先幾百年の夢と詩が結び付いていたような気がする。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかこの若先生のところで顕微鏡を見せてもらって色々のプレパラートをのぞいているうちに一つの不思議な重大なアポカリプスを見せられた。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた珪藻のプレパラートを見せられ、これの視像の鮮明さで顕微鏡の良否が分かると教えられた。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "コムプレッサーでは、ゲージは九十封度に昇っていた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の子供は、コムプレッサー、鍛冶場、変電所、見張り、修繕工場、などを見て歩いたが、その親たちは見当らなかった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "純白に襞の多い着物と、頭の白い花の冠が非常によく似合い、私に持って来たクリスマス・プレゼントのチョコレートの箱の飾リボンの縁が、清楚にうつり合った色彩は、私に思わずつかつかと傍へ寄らしてしまったような、好もしい感じを与えました。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレフォーンのことはフェルンシュプレッヘルといい、ラジオのことはルンドフンクといった風であった。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人のプレイが素人目に見てもそれぞれちゃんとはっきりした特徴があって面白い。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後にコペルニカスの地動説が出て前説よりも遥かに簡単に天体の運動を説明し得る事が分り、ケプレル、ニュートンを経ていよいよ簡単な運動の方則で天体の諸現象を述べ尽す事が出来た。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとリヴァプールの船工であっただけに、木工、金工に通じていたのみならず、暇さえあれば感応コイルを巻いたり、顕微鏡のプレパラートを作ったりするような男であった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフリカでキンバーレー、ヴィクトリア滝を見てプレトリアへの途上赤痢に罹り、その報知はロンドンを驚かせた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓はターリング・プレースの花園に隣った寺の墓地の静かな片隅にある。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "テンポにもエキスプレションにも少なくも理論的には相当な振幅はあった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴォアラ、ネスパ、セッサ、ムシュー、アラマディ、プレンプアン、ラタヽパン。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "プレトリアという所に近い採掘場で地下十八フィートの穴から見出された。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを採掘したプレミアー会社社長の名を取ってクリナンダイアモンドと命名されている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は空中滑走する、戦い疲れた陳独秀とビクトリア・カップよりセント・ジョウジ・プレースに至る山頂火車のなかで彼等は力なく握手して、空中の鏡の上にモーニング姿の印度人のイサックを発見するのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国の専制のなかに宙を乗った彼等がセント・ジョウジ・プレスから汕頭人の車夫に曳かれて、銅羅湾の火薬庫の挙壁を眺めながら石塘嘴の万国館に入るのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は香港デーリ・プレスの朝刊をひらいた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "流行品店とキャバレーのあるアスファルトの露地に、黒いケープレットのついた夜の衣裳をつけて、ハイ・ヒールのエナメルの靴を穿いた都会の売笑婦。",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――じつはね、妾、君にクリスマス・プレゼントしたいのよ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハリコフでの国際革命作家拡大プレナムの決議は日本のプロレタリア文学運動が、シッカリと大衆の中に根を張り、国際的な連関において前進して行くために、もっとも重要な、さしあたって第一番に議題として我々が討議し、具体化しなければならない幾多の貴重な提案をなしている。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早暁の町のアスファルトの上を風に吹かれて行く新聞紙や、スプレー川の濁水に流れる渦紋などはその一例である。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "顕微鏡で見る場合では、眼前の顕微鏡と、その鏡下のプレパラートとの相対的の大きさがちゃんと意識されているのであるが、それがスクリーンの上に大きく写されたのでは全くそのままの大きさの怪物としか思われない。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「グルルル、グルウ、ユー、リトル、ラズカルズ、ユー、プレイ、トラウント、ビ、オッフ、ナウ、スカッド、アウヰイ、テゥ、スクール。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
