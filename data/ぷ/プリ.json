    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pre-",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "又、別様に考へてみるに、新短歌は、抒情といふより抒情的インタープリテイションといつた感じである。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本飲み終つた頃、また後から一人来た、今度は先のよりは少し綺麗、デツプリ太つて自信がおありだ。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "プリプリしながら、だがその晩は七時にはお湯屋に行き、目覚時計を四時に掛けて八時には床に這入つた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くいふは世人屡々芸術作品を以て、箒なら箒、手拭なら手拭といふ一定のテーマがあつて、それの種々なる解説（インタプリテイション）が彼是の作品だとなしがちだからである。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "インタープリテーションでなく、まづは詩であるためには、苦しいと云へば苦しい、長い道を歩いたことであつた。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は俳句の外に、いくつかの抒情詩と数十首の短歌をも作つてゐるが、それらの詩文学の殆んど全部が、上例の俳句と同じく、造花的の美術品で、真の詩がエスプリすべき生活的情感の生々しい熱意を欠いてる。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこのアマチユアの道楽芸が、それ自らまた彼の人物的風貌の表象であり、併せて文学的エスプリの本質なのだ。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりもその證據は、子供たちの悦ぶ映畫が、常に忍術使ひの出るチヤンバラ劇と、奇々怪々の夢に充ちた漫畫映畫と、ポンチ的諧謔のチヤツプリンとに限られてゐる。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に蕪村の俳句にいたっては、子規以来単なる写生主義ということで定評づけられ、一もその真の詩的精神――俳句のエスプリする哲学原理――を批判されてない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで聴いたキービッツという若いプリバート・ドチェントの空中電気の講義は始め十人くらいの聴講者がだんだん減ってとうとう二、三人になってしまった、そのせいか数時間でおしまいになった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人株ではカナル線の発見者ゴールトシュタインや、ワールブルヒなどがおり、若手ではゲールケ、プリングスハイム、ポールなどもいた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若くて禿頭の大坊主で、いつも大きな葉巻を銜えて呑気そうに反りかえって黙っていたのはプリングスハイムであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔七、〕北十字とプリオシン海岸「おっかさんは、ぼくをゆるして下さるだらうか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その白い岩になった処の入口に、〔プリオシン海岸〕といふ、瀬戸物のつるつるした標札が立って、向ふの渚には、ところどころ、細い鉄の欄干も植えられ、木製のきれいなベンチも置いてありました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学者のＭ君は積分的効果を狙って着実なる戦法をとっているらしく、フランス文学のＮ君はエスプリとエランの恍惚境を望んでドライブしているらしく、Ｍ夫人の球はその近代的闊達と明朗をもってしてもやはりどこか女性らしいやさしさたおやかさをもっているように見えた。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイヌの「ヌプリ」は「登り」に通じ、山頂を意味する「タプカ」も「峠（タウゲ）」に少し似ている。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰途プリモースに上陸し、そこからフルードの船型試験室を訪問した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーリーは五年かかってこの研究を完成し、格子のみならず、プリズムの場合をも補足した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "会のあとでプリモースへ行ってそこで始めて電話というものを実見した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」しかしずっと後になって最高の栄誉と考えられるコプリー賞牌が授与されることになったのである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この旅行の帰途ナポリでカプリの琅※洞をも見物したのであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠来の客へのコンプリメントででもあるかのように。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばカイゼルでもチャップリンでも……」と云ったそうである。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今より二十三年の昔出来たアンプリア号という当時での巨船に比較すれば実に非常の進歩である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこの最後の歐風詩、即ち僕等が普通に「詩」と呼んでるものは、西洋では「文學の精華」と言はれるほどで、西洋文藝思潮の最も本質的なエスプリを代表してゐる。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に西洋では、詩が文學の帝王として、一切文學のエスプリとして權威されてる。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このセンチメントの純潔さが、彼の詩に於ける、最も尊いエスプリだつた。",
              "citation": {
                "source": "中原中也君の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この心理を巧みに映畫で描いたものが、チャップリンの近作「街の灯」であつた。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで或る街の深夜に、ぐでぐでに醉つて死場所を探してゐる不幸な紳士が、場末の薄暗い地下室で、チャップリンの扮してゐる乞食ルンペンと邂逅する。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
