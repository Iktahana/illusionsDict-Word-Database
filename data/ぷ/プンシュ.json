        "examples": {
          "standard": [
            {
              "text": "寒い冬の夜には、スパイスがたっぷり効いた温かいプンシュを飲むのが一番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "クリスマスマーケットの屋台から、甘いプンシュの香りが漂ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "スウェーデン人の友人が、伝統的なアラック入りのプンシュを振る舞ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そして食後にあたたかいプンシュを飲んで、お菓子をかじりました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラッツのすみのほうに銅壺をすえてプンシュを売っている男もありました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その不祥事件の一つというのは、市の定期市にやって来た＊４ソリウイチェゴーズスクの商人連が、商いのすんだ後、商売仲間の＊５ウスチスイソーリスクの商人連を招いて酒盛をやった――ロシア流儀にドイツ式の工夫を加味した酒盛で、＊６アルシャードや、プンシュや、芳香酒などが出た。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
