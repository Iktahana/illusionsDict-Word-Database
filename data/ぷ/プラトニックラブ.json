          "literary": [
            {
              "text": "おれは小便臭いのは此の小屋の臭いだけで充分だ」　そうはいったものの、しかし間もなく起った「北山老人は東銀子にプラトニックラブを捧げている」という噂を、北山自身敢て否定しなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨシツネさんは突然「これはプラトニックラブだよ」と云った。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「プラトニックラブってなによ？",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラトニックラブと云った顔が、急に中学生のように見えて来る。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無理して飲む奴はないよ」「うん、プラトニックラブだから飲んだのよ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラトニックラブだよと云ったヨシツネさんの気持ちの方がいまの私にはありがたいのだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラトニックラブにやぶれた彼女は、国府津の海に入水したほど、「恋」に全霊的であり、彼女は事業も名誉も第二義的のもので、恋を生命としていたものは、それに破れれば現世に生きる意義を見出せないとまでいっている。",
              "citation": {
                "source": "遠藤（岩野）清子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
