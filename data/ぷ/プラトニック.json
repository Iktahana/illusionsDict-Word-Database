        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "プラトニックラヴね」　女って皆そう言うと思った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「プラトニックだけで済むかね」「ベーゼ……？",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一流の恋愛とはどんな恋愛ですか」「プラトニックに、お互いを向上させて行く恋愛だね。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "置手紙によれば、プラトニックラヴを双方しているそうですよ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "信じられますか」「あなたはどう思うんです」「わざわざプラトニックだと断ってますからね」「かえって、怪しい……？",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "九分九厘まで行って、ギリギリの一点を残して、あとは大いに享楽して、それでプラトニックだと称している手合いが多いんだ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルストイやゲーテのように、中年期を過ぎてまでも、プラトニックな恋愛を憧憬したり、モノマニアの理想に妄執したりするような人間は、すくなくとも僕らの周囲にはあまりいない。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）外国に於て見れば、バイロンは正義に殉じた熱血児で、ハイネはプラトニックに恋愛を歌いつつ、革命に熱した人生の戦士であった。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さんと兄さんと僕と三人、プラトニックな高い結びつきがあった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧洲の理想界に形而上派の興りてより、漸くにして古代の崇高なるプラトニックの理想的精神を復活せしめ、爾来欧洲の宗教界、詩文界に生気の活動し来りたるを見る。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは小便臭いのは此の小屋の臭いだけで充分だ」　そうはいったものの、しかし間もなく起った「北山老人は東銀子にプラトニックラブを捧げている」という噂を、北山自身敢て否定しなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダリはセザンヌを『プラトニックな石工にすぎない』とみてゐるとか、私はダリをまた『プラトニックなシンコ細工屋』と評することができる、形態の変化は芸術家の自由ではあるが、その変化が絶対的観念に於て求められるといふことなどはない、現実の変形の可変性といふことを考へることが、芸術家の良心的態度の一種である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "その変体が色々な形を取って起り、或る時はその本務的な目的から全く切り放されたプラトニック・ラヴともなり、又かかる関係の中に、人類が思いもかけぬよき収得をする場合もないではない。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には、主僧にプラトンの「アイデア」を質問してプラトニックラヴなどということを考えてみることもあった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "笹村の側に、そんなことのないのが、お銀にとって心淋しかったが、それでもそのころ温泉場にいたある女から来た手紙や、大阪で少い時分の笹村が、淡いプラトニック・ラヴに陥ちていた女の手紙は、そんなことを誇張したがるお銀のためには、得がたい材料であった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨシツネさんは突然「これはプラトニックラブだよ」と云った。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「プラトニックラブってなによ？",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラトニックラブと云った顔が、急に中学生のように見えて来る。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無理して飲む奴はないよ」「うん、プラトニックラブだから飲んだのよ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラトニックラブだよと云ったヨシツネさんの気持ちの方がいまの私にはありがたいのだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラトニックラブにやぶれた彼女は、国府津の海に入水したほど、「恋」に全霊的であり、彼女は事業も名誉も第二義的のもので、恋を生命としていたものは、それに破れれば現世に生きる意義を見出せないとまでいっている。",
              "citation": {
                "source": "遠藤（岩野）清子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、クラフト・エーヴィング教授の云うように、美しい母を持った者は、美しい女性に対して、驚くべきほどプラトニックであるとすれば、とりもなおさず儀右衛門のそれは、一種の女性恐怖にほかならないであろう。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、いかにプラトニックであるとはいえ、それは精神的｜近親相姦にほかならないからだ。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええとそうして葉末さんは、事実琢磨氏を愛していたので、西洋の言葉でいいますと――これは琢磨氏に聞いたのですが、何んとかいったっけ、プラトニック・ラヴか――心ばかりの恋をささげ、肉体は依然として処女のままで、奉仕していることでございましょう。",
              "citation": {
                "source": "怪しの館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この意味でプラトニックな要請を持っていないものは処女ではない。",
              "citation": {
                "source": "女性の諸問題",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラトニック・ラヴと称して、精神的恋愛を高尚だというのも妙だが、肉体は軽蔑しない方がいい。",
              "citation": {
                "source": "恋愛論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかに「プラトニック・フラーテーション・トウ・ソシアリズム」ということばあり。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
