        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それで、そのプロポーズはどうなったの？",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして妾にプロポーズしたのよ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人がプロポーズしたといふ噂もほんのり聞いたけれど、Ａ令嬢は現代の娘たちとはまるで違つてじつに落ちつき払つた美人であつたから、だれもその噂の真偽を伺ふことはしなかつた。",
              "citation": {
                "source": "豚肉　桃　りんご",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一服クン、去年の暮ごろから、しつこく私にプロポーズしてるのよ。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクは上野光子にプロポーズしたんですが、お光は大鹿と結婚したいと云うんです。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞子に初めて会った夜も、私はわかめのような帯を締め、泥酔の状態で、いきなり貞子にプロポーズしたという。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "操縦席で肩を寄せあっているふたりを見ながら、秋川のプロポーズを受入れれば、その日から、このひとたちは、じぶんの子供になるのだと思うと、うれしいような不安なような気持になった。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、いや、さつき、さう云つたぢやありませんか、僕がもしあなたにプロポーズするやうなことがあるとして、それを断る理由をいろいろ考へたつて……」「あゝ、そのこと？",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、寒藤先生はそう考えていたし、プロポーズしようとひそかにその機会をうかがってもいたのだ。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は晴れて、夏のように暑い日であったというが、この邸宅の庭で、親王は息女にプロポーズし、息女はこれを受けた。",
              "citation": {
                "source": "この頃の皇太子殿下",
                "author": "小泉信三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「プロポーズは、したの？",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これから」「プロポーズのあとは、どうするの？",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうやってプロポーズすべきか、ぼくはこれから考えなくてはいけない」「私のときは、突然だったわ」　と、キャロリンは言った。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼のプロポーズを受けて、砂だらけのサンダルとショート・パンツ、そしてタンク・トップといういでたちで、彼の両親に会ったの」　コーヒーを飲んだキャロリンは、佳子をさがしにいった。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
