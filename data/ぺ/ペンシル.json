        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ニューヨークを立つときにペンシルベニア・ステーションで、いきなり汽車に飛び乗ろうとすると、車掌に叱り飛ばされた。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤毛連盟に告ぐ――米国ペンシルヴァニア州レバノンの故イズィーキア・ホプキンズ氏の遺志に基づき、今、ただ名目上の尽力をするだけで週四ポンド支給される権利を持つ連盟員に、欠員が生じたことを通知する。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをもってペンシルバニア州に人の気のつかぬ地面をたくさん買った。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが今日のペンシルバニア州における石炭と鉄とを出す山でございます。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "予在米の頃、ペンシルヴァニア州の何処かに、蛇多きを平らげんとて、欧州より野猪を多く輸入し、放ちし事ありし。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "予在米の頃、ペンシルヴァニア州の何処かに、蛇多きを平らげんため欧州から野猪を多く移し放った。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一はギター・ケースのところにいき、外側の大きなポケットをあけ、スパイラル・ノートとシャープペンシルをひっぱりだし、令子のそばにもどる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一閑張の上に書物が二三冊きちんと積まれてあり、そのそばに十四金の小型のペンシルが一つおいてありました。",
              "citation": {
                "source": "祭の夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンシルバニア地方を代表したフイラデルフイア大学はタフトを、ニユーハンプシヤイア地方からのハーバード大学はマツキンレイを、そしてメリーランド地方としてはワシントン大学がルーズベルトを支持した。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」女の泣顔10・23（夕）　アメリカのペンシルヴアニヤ州のクリヤフイルド市にヘンズレエといふ今歳とつて十九になる妙齢の娘がある。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、或る日の午後、少し雨降りの日でしたが、矢張り同じ用事で其のペンシルバニア停車場へ行きますと、彼方ではホールと云う丁度東京駅の入った許りの広い処と同じような場所の片隅に、如何したのか大勢の人が立ち止まって何か聞いているではありませんか。",
              "citation": {
                "source": "私の見た米国の少年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「パン、ペン、ペンシル、ポンビキ、ペラ／＼ペラ！",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "★アメリカ陸軍の依頼を受けて、ペンシルベニア大学の電気工学科、ムーアスクールが開発した電子計算機。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三九年に第二次世界大戦が勃発して以降の戦時体制下、弾道研究所では微分解析機の改良が進められていったが、もう一方で研究所は新しい弾道計算装置の開発をペンシルベニア大学に打診した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七六年の十二月、シュレイヤーはアルテア用にワードプロセッサーのプログラムを書き上げ、これをエレクトリックペンシルと名付けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "厄介な仕事を手短にすませるために書いたエレクトリックペンシルだったが、このソフトウエアがシュレイヤーにもっとたくさんの仕事を運んできた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホビイストの集会でシュレイヤーが自分の書いたワードプロセッサーを誇らしげに紹介すると、エレクトリックペンシルは大評判を呼んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "エレクトリックペンシルの成功を睨みつつ、ディーラーからワードプロセッサーこそが求められていると繰り返し聞かされたルービンスタインは、バーナビーに指示してワードマスターの機能を強化させ、三つ目のこの製品をワードスターと名付けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ペンシルベニア大学のジョン・Ｗ・モークリーとＪ・プレスパー・エッカートは、米陸軍弾道研究所の依頼を受けて、一九四三年から真空管を使った計算機の開発に着手し、一九四六年にＥＮＩＡＣの稼働にこぎ着けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラシックの音楽教育を受け、絵を描くことにも巧みだったジェフ・ラスキンは、ペンシルベニア州立大学で「どうすればこの道具をもっと使いやすいものにできるか」という観点からコンピューターに取り組んだ★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八一四年、書をペンシルバニヤ州の知事に送り、無報酬にて法典立案の業に従事したいということを請うたが容れられなかった。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにペンシルがついている。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはあとで判ったことだけれど、彼女はあの銀鍼をシャープペンシルの軸の中に隠して持っていたのだった。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が九つ位で父上からいただいた鉄砲だまと、銀メッキのペンシルとハムとは忘れられないものだ。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポマードも入手難の時世であつたが、彼の毛髪は手入れよく光つてゐたし、ネクタイから靴の爪先に至るまで、煙草ケース、ライター、時計、ペンシル、パイプ、こまかな一々の持物にも何国の何製だの何式だのと語らせれば一々数万語の説明が用意されてゐる。",
              "citation": {
                "source": "女体",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルコット女史について、簡単に御紹介しますと、出生日は、千八百三十二年十一月二十九日、出生場所は米国ペンシルバニア州のジャーマン・タウン、父は教育家でした。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "八、要するに、巡回文庫はニユーヨークを中心として創設せられ、漸次「マッサチューセッツ」、「ウイスコンシン」、「ミシガン」、「ペンシルヴェニヤ」、「メリーランド」、「オハヨー」、諸州に普及して、既に争うべからざる成績を得たり。",
              "citation": {
                "source": "米国巡回文庫起源及び発達",
                "author": "佐野友三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
