        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ニューヨークを立つときにペンシルベニア・ステーションで、いきなり汽車に飛び乗ろうとすると、車掌に叱り飛ばされた。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "★アメリカ陸軍の依頼を受けて、ペンシルベニア大学の電気工学科、ムーアスクールが開発した電子計算機。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三九年に第二次世界大戦が勃発して以降の戦時体制下、弾道研究所では微分解析機の改良が進められていったが、もう一方で研究所は新しい弾道計算装置の開発をペンシルベニア大学に打診した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ペンシルベニア大学のジョン・Ｗ・モークリーとＪ・プレスパー・エッカートは、米陸軍弾道研究所の依頼を受けて、一九四三年から真空管を使った計算機の開発に着手し、一九四六年にＥＮＩＡＣの稼働にこぎ着けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラシックの音楽教育を受け、絵を描くことにも巧みだったジェフ・ラスキンは、ペンシルベニア州立大学で「どうすればこの道具をもっと使いやすいものにできるか」という観点からコンピューターに取り組んだ★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
