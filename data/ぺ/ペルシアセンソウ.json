        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ペリクレス（Perikles）の師であったアナキサゴラス（Anaxagoras）は紀元前約五〇〇年に小アジアで生れ、ペルシア戦争後アテンに移った人であるが、彼は以上の考えを宇宙全体に適用し、すなわち、宇宙の永遠不滅を唱道した。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　ギリシアの全盛時代はペルシア戦争（紀元前四八〇年）に続く半世紀間で、アテナイが全ギリシアを支配し、ペリクレスがそれを指導していた。",
              "citation": {
                "source": "パルテノン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "造形美術ではペルシア戦争後のアテナイの諸傑作などがその最も著しい例である。",
              "citation": {
                "source": "世界の変革と芸術",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシアで文学芸術の最も栄えたのは、ペルシア戦争後にアテナイが勢力を伸長した時のことであった。",
              "citation": {
                "source": "芸術と数学及び科学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学に興味をもつ読者はホメロス時代、スパルタとアテネの市民間の初期の争い、ペルシア戦争、におけるギリシア軍について流行病の重要な記載がなされていないことに驚く。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペルシア戦争の時にギリシアが誓いかつ守った、あの堂々たる誓約の第一箇条は、「我々の法をペルシアの法にかえるくらいならば、むしろ生を死にかえよう」ということだった。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
