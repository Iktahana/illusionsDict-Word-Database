        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "池から家へ帰ってくると、三人はこころもからだも、くたくたにつかれてしまったので、ふじだなの下の縁台に、おなかをぺこんとへこませて、腰かけていました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、やがて、坐り直すと、ぺこんと頭を下げて、「じゃ、いただきます。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴雄はぺこんと頭を下げて、階段を降りて行こうとすると、「君！",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」「下手くそやぞ、お前らの掏り方は……」「今夜はじめてだす」　次郎は蚊の鳴くような声を出して、「――かんにんしとくなはれ、大将」　と、ぺこんと頭を下げた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "永々厄介な小僧をお世話さまでしたと兄の挨拶の後で、ぺこんと頭をさげ、之はほんの心だけです、と白い紙包を差出して、家を出て行った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "池から家へ帰つて来ると、三人は心もからだも、くたくたに疲れてしまつたので、藤棚の下の縁台に、お腹をぺこんとへこませて腰かけてゐました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、失礼、よびとめちゃって」　「さよなら」　中国人はもう一ぺん、ぺこんとおじぎをして、出ていきました。",
              "citation": {
                "source": "張紅倫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "永々厄介な小僧をお世話様でしたのうと兄が挨拶したあと、ぺこんと頭を下げ、「ほんの心じゃけ、受けてつかわさい」　と、白い紙包を差し出して、こそこそ出て行った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三味を弾かせると、ぺこんぺこんとごまかし弾きをするばかり。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "永々厄介な小僧を世話でしたのうと兄が挨拶したあと、ぺこんと頭を下げ、「ほんの心じゃけ、受けてつかわさい」と、白い紙包を差し出して、何ごともなかった顔で、こそこそ出て行った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹一は周章てて振り向きぺこんと頭を下げた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやにしとやかに陽に光って、さわるとぺこんと凹みそうな、ふっくらとした水の肌――こいつは落ちても痛くないぞ。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが毎日一度は、渠の坐つてる下から、ぺこん、ぺこんと聞えた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄竜はすっかりうろたえて、へーと笑いながら首筋に手をやるとぺこんと頭を下げた。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は仏頂面で何やらぶつくさ呟いていたが、これも一度ぺこんとした。",
              "citation": {
                "source": "親方コブセ",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨を削られて耳の後はぺこんとへこみ、ガーゼがつめられてある。",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この弁当じゃあ全く遣り切れんなア――」　口鬚ひくひくさせていた守衛はぺこんと頭を低げた。",
              "citation": {
                "source": "お菜のない弁当",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」それを喚きおわるが早いか、彼はぺこんと習慣になった敬礼を残して、扉をはね開けた。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、邪魔になるからそこを退きな、川上が修身をやんだからさ、早く退きな」　川上忠一は右肩をいからかして教卓の前に直立不動の姿勢をつくり、ぺこんと頭を低げた。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐柄木の美しい方の眼がいつの間にか抜け去っていて、骸骨のようにそこがぺこんと凹んでいるのだった。",
              "citation": {
                "source": "いのちの初夜",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へえ、何の御用でがすか」　ぺこんと頭を下げる。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに汗顔の至り……」　古堀博士は大真面目で、ぺこんと頭を下げた。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "当直をやつてゐる夜など、ちよろちよろと廊下を伝つて現はれ、当直寝台の上で本など読んでゐる私を見ると、ぺこんと一つ頭を下げてニコッと笑ひ、父親の枕許へ寄る。",
              "citation": {
                "source": "続癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で、大石練吉は今も頭をまつすぐに持ち上げて仏壇の方を眺めてゐたが、間もなく千光寺の住職の剃り上げた後頭部に人並外れて骨が突出し、その下にぺこんとした凹みのできてゐるのを発見し、しきりとそれを見つめてゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と吃るやうに漸く云つてあわてて其処に坐り、ぺこんと頭を下げた裕佐の赭くのぼせた顔をちらりと見ると、かすかに苦し気な微笑をたゝへ乍ら又弟に顔を向けた。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――」まん中の布団にふん反り返って膝を立てている熊谷の右側に、洋服の浜田はズボンと下着のシャツ一枚で、痩せた体を仰向けに、ぺこんと腹を凹ましていました。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、もうふのなかのぽけっとこぞうのからだが、ぺこんとへこんでしまったのです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
