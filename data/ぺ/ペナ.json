        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（大正九年八月、渋柿）　　　　　四　ペナンとコロンボ四月十三日　……馬車を雇うて植物園へ行く途中で寺院のような所へはいって見た。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホンヤクノコトデ　タノミアルスグ　キテクレ」　彼は、わたしの部屋の壁、ライフル銃もロビンソンもオルゴールも、ペナントも、昆虫標本の額も、みんなどこかへ棄てられて、それらのものゝかゝつてゐた痕だけ白い壁に、途徹もない論文の抜き書ばかりが落書されてゐるのを発見した。",
              "citation": {
                "source": "幽霊の出る宮殿",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この分では秋のペナントはＨ村のものだといふ評判ですから、まあ精々練習して来て下さい。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも壁に“WASEDA”のペナントの下に、十字を切って懸けてあった練習用の Fencing Sword の一つであった。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "本棚の上の壁には弘雄が送つた紫地に白で抜いたワシントン大学のペナントが懸つて居り、ラツパが薄闇の中に真鍮の光りを放つてゐた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾花吹くスコール速し雲の峰ペナン行花さす客の口赤し　花の名は書ききれぬ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "同日午後四時、ペナンに入港す。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペナンの事は、あまり書く気が起らない。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ペナンへ来て私たちを案内した馬来人が、突然また叫声を発して私の洋服に感歎した。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "京に似しペナンは月の真下にて　私の好きな句は左の句。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "街に咲いた花々も、シンガポール、ペナンの方がはるかに美しい。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "久慈は時を刻むように隠顕する千鶴子の靨を見ながら、矢代をまだ知らぬころの千鶴子と、ペナンの沖に灯を連ねて碇泊していた自分の船へ、飛沫を浴びて帰ったときの彼女の靨を思い出した。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月二十五日　ペナン、コロンボ間にて　きのうから海は少し荒れている、風と雨とが間断なく、船は相当にゆれている。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペナンでは、停泊の時間が少なくて、手紙を出す事が出来なかった。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十一月廿八日）彼南　臙脂の中に濃い橄欖を鮮かに交へた珍しい曙光を浴びた我船は徐徐とマラツカ海峡の西の出口ペナン島の港に入つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十二月一日）コロムボ　ペナンから印度人の甲板旅客が殖えた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はペナンを出帆してから郵船会社の厚意で一等室へ移して貰つたが、幸ひ相客が無いので広い涼しい部屋を一人で占領する事となつた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此※田丸が此前日本へ帰る時にペナンで同行の情夫を棄てて窃に上陸し去つた女だ相であるが、今度は一人で香港から乗りペナン迄の間に早くも某外人を捕獲して仕舞つたとの評判である。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れに支那人の勢力がペナン限で此処まで及んで居ない所から不潔と悪臭とに満ちた支那人｜街を全く見ないのが好い。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　私のやうに退屈しきつた人間は、もう野球だの相撲だの、それがペナントを賭けたものでも、まだるつこくて、見てゐられない。",
              "citation": {
                "source": "散る日本",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方赤ちゃんを抱っこして大学の銀杏の木の下のベンチに腰をかけてゐると、何だかペナイサキペナイかヲカチペにいた時の事が思出されます。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペナンからコロムボの中間で、余は其思出の記を甲板から印度洋へ抛り込んだ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのイエスがカペナウムの村で、こう信者達に説いた時には、ユダは本当に怒ってしまった。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画で見るアメリカの新聞記者は、人見知りをしない go'getter で、厚顔しいほうのペナント・ホルダーばかりだった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「浜島茂か、おい、おい、あれや違うか、本部附からペナンの収容所へ行つたのは？",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか本部の当番兵だつていうことは聞いていたんですが、そうだなあ、あれはことしの初めかなあ、ペナンのふ虜収容所へ派遣されて、そこからやつぱり雑誌へ詩を送つて来ていましたつけ。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は領事館および三井物産会社支店を訪い、馬場氏に面し、日新館にて河合、甲賀両氏と手を分かち、印度支那汽船会社の便船瑞生号（Suisang）に転乗し、午後五時、ペナン（Penang）に向かって発す。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "七、ペナン遊覧　五日、炎晴。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
