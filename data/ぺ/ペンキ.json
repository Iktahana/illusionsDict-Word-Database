        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "煉瓦塀に春を発見した福助人形の影法師孤児の下駄が置き忘れてありました公園の入口ペンキのはげた立札心よ！",
              "citation": {
                "source": "（風船玉の衝突）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "校庭宮沢賢治さ霧する白き木柵幹彫れる桐のいくもと剥げそめし白きペンキの木柵に人人は倚りそのペンキあるいは剥げあるものは庭をのぞめり一鐘のラッパが鳴りて急ぎ行く港先生白堊城秋のガラスはひらごとにうつろなりけり",
              "citation": {
                "source": "校庭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのペンキはボロボロに剥げて、建物も鎧扉も、指で押せば立ちどころにメリメリツといきさうであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨催の空濁江に映りて、堤下の杭に漣※寄するも、蘆荻の声静かなりし昔の様尋ぬるに由なく、渡番小屋にペンキ塗の広告看板かゝりては簑打ち払う風流も似合うべくもあらず。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "観覧車も今は闃として鉄骨のペンキも剥げて赤※が吹き、土台のたたきは破れこぼちてコンクリートの砂利が喰み出している。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "農鳥山の赭ッちゃけた壁には、白雪がペンキでも塗ったように、べッたりと光って輝いている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "レールに近く養蚕広告のペンキ塗の看板が、鉛のような鉱物性の色をして、硬く平ったく烈しい日の光に向って立っていたが、汽車と擦れ違いさまに、仆れそうになって、辛くも踏み止まった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は昨年｜塩山の停車場で、白ペンキ塗の広告板に、一の宮郷銘酒「白嶺」と読んで、これは「雪の白酒」ではあるまいか、さぞ芳烈な味がすることであろうと思った、また他で製糸所の看板に、白嶺社とあるのを見て、この社の糸の光には、天雪の輝きがあろう、衣に織ったらばさぞ、と考えたことがある。",
              "citation": {
                "source": "雪の白峰",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ内務省と大きく白ペンキでマークしたトラックが一台道を塞いで止まつてその上に一杯に積んだ岩魂を三四人の人夫が下ろしてゐた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場の燻ぶつた車庫や、ペンキのはげかゝつたタンクや轉轍臺のやうなもの迄も、小春の日光と空氣の魔術にかゝつて名状の出來ない美しい色の配合を見せて居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年急に襲うて來た「改造」の嵐の爲に、我邦の人の心に自然なあらゆるものが根こぎにされて、其の代りにペンキ塗りの思想や蝋細工のイズムが、新開地の雜貨店や小料理屋のやうに雜然と無恰好に打建てられて居る最中に、それ程とも思はれぬ天然の風景が方々で保存せられる事になるのは、せめてもの事である。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "町はづれに近く青いペンキ塗りの新築が目に付いた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ内務省と大きく白ペンキでマークしたトラックが一台道を塞いで止まってその上に一杯に積んだ岩塊を三、四人の人夫が下ろしていた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄骨ペンキ塗りの展望塔がすっかり板に付いて見える。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンキ屋が看板の文字を書くようにそれはどこから筆を起してどういう方向に運んで行っても没交渉なもののように見えた。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "理髪店の軒先には、紅白の丸い棒が突き出してあり、ペンキの看板に Barbershop と書いてあった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝生の庭を挾んだ向うには、水色のペンキで塗つたこつちと同じやうな二階建の病室の棟が立つてゐた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷役に忙しい樺太や釧路通ひの汽船や、白いペンキの醜く剥げ落ちた帆船の中には、舷の低い捕鯨船の疲れたやうな姿が横はつてゐる。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛布をかむって寝台からペンキの剥げたきたない天井を見た。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "流を下つて行くも二三｜丁、上れば一｜丁、其中にペンキで塗つた橋がある、其間を、如何な心地で僕はぶらついたらう。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一方を見ると、大きなペンキ塗の天狗の姿が崖の上に聳えているのに少なからず脅かされた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青味がかったペンキを塗り立ててあった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白ペンキが禿げた鉄寝台、汚点だらけの藁蒲団、膿くさい毛布。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "測量をする技師の一と組は、巻尺と、赤と白のペンキを交互に塗ったボンデンや、測量機等を携えて、その麦畑の中を行き来した。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻尺を引っ張り、三本の脚の上にのせた、望遠鏡のような測量機でペンキ塗りのボンデンをのぞき、地図に何かを書きつけて、叫んでいた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、巻尺と、赤と白のペンキ塗りのボンデンを持った測量の一組がやって来た。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母車なんとかと白くペンキで書いた屋根が見える。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日私は湯槽の上にかかっているペンキの風景画を見ながら「温泉のつもりなんだな」という小さい発見をして微笑まされました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
