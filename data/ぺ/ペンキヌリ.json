    "definitions": [
      {
        "index": 1,
        "gloss": "painting (houses, fences, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "近年急に襲うて來た「改造」の嵐の爲に、我邦の人の心に自然なあらゆるものが根こぎにされて、其の代りにペンキ塗りの思想や蝋細工のイズムが、新開地の雜貨店や小料理屋のやうに雜然と無恰好に打建てられて居る最中に、それ程とも思はれぬ天然の風景が方々で保存せられる事になるのは、せめてもの事である。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "町はづれに近く青いペンキ塗りの新築が目に付いた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄骨ペンキ塗りの展望塔がすっかり板に付いて見える。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻尺を引っ張り、三本の脚の上にのせた、望遠鏡のような測量機でペンキ塗りのボンデンをのぞき、地図に何かを書きつけて、叫んでいた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、巻尺と、赤と白のペンキ塗りのボンデンを持った測量の一組がやって来た。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の降る日に二条の鉄路の中央のひどいぬかるみの流れを蹴たててペンキ塗りの箱車を引いて行く二頭のやせ馬のあわれな姿や、それが時々爆発的に糞をする様子などを思い出すことはできる。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋の二階の縁側にその時代にはまだ珍しい白いペンキ塗りの欄干があって、その下は中庭で樹木がこんもり茂っていた。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ぼくらは両方兼ねてるから」　ずんずん廊下を進んで行きますと、こんどは水いろのペンキ塗りの扉がありました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "町はずれに近く青いペンキ塗りの新築が目についた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、きっと蝉時雨の降る植物園の森の裏手の古びたペンキ塗りの洋館がほんとうに夢のように記憶に浮かんで来る。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラックだが、安っぽい荒削の木材の生なましさや、俗々しいペンキ塗り立ての感じはなく、この界隈では垢抜けした装飾の店だった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中に、それでも少し小高い処に、ペンキ塗りの新築のかなり大きな別荘があり、レコオドの音が朗らかに聞こえ、製氷会社と土地会社を兼ねた事務所があったりした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二階家の向うは総門の左側の角になって、木造の青ペンキ塗りの古いシナ人の下宿があった。",
              "citation": {
                "source": "変災序記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "車の蔭に古簾が見え出して角の中に琴という字が書いてあった油障子はペンキ塗りの硝子戸に変っているが相変らず、さらし袋のかかっている店先の山椒の木の傍で子供が転んで泣いている背中を親鶏とヒヨコがあわてて跨いで行く。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "南海通にもあくどいペンキ塗りのバラックの飲食店や闇商人の軒店や街頭賭博屋の屋台が並んでいて、これが南海通かと思うと情けなく急ぎ足に千日前へ抜けようとすると、続けざまに二度名前を呼ばれた。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、何にしても足場は、ボイラーの円いペンキ塗りの上である。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "え、船長も物好きじゃねえかなあ、いくらお正月だって室蘭でマストのペンキ塗りなんざ、万寿丸の船長でなきゃ考え出せねえ名案だぜ」西沢がガタガタ震えながらそれでも、早く降りたいばかりに、盲目が杖を振り回しでもするようにむやみに塗り立てた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "西沢と、波田とは、マストのペンキ塗りを「やりじまい」で命じられたのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき河の上流から、それは細長い格好のよい、青い青いペンキ塗りの船が一艘、静かにくだつて来ました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "小坪の鼻の崕の上に若葉に包まれてたった一軒建てられた西洋人の白ペンキ塗りの別荘が、夕日を受けて緑色に染めたコケットの、髪の中のダイヤモンドのように輝いていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し行くと古い寺の隣の杉林を切り倒して、きれいに地ならしをした上に、青ペンキ塗りの西洋館を建てている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "広田先生は寺とペンキ塗りを等分に見ていた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから間もなく、西洋人の名札の出た、白いペンキ塗りの、小さい平家だての西洋館の前を通つて一寸行くと、右手の杉垣のつゞきの中に、青木さんのお家の瓦斯燈が見えた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンキ塗りの小ぢんまりした文化住宅に、「マツイ」と小さな表札を見つけて案内を乞うと、都合よく御主人在宅であった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず暗い色のセメント壁に、白いペンキ塗りの窓がある。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は此処こそ暗い横丁だらうと思つて逃げ込むと、其処にはペンキ塗りのバーやカフエーが軒をそろえて客を招んでゐる。",
              "citation": {
                "source": "鱗雲",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その頃洋館の一般の樣式であつた青いペンキ塗りのずぼつとした西洋館に住んでゐるのだつた。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "中津・街は花見の売出しも近いペンキぬりたて　　宇平居・石に水を、春の夜にする・あなたを待つとてまんまるい月の　三月十六日　好晴、中津。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ペンキぬりをする時間がありゃしないよ」「困ったなあ、この恰好じゃ仕様がないよ。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "セットがペンキぬり立てゞ今乾かしてる最中だとある。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
