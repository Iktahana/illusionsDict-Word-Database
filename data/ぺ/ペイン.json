    "definitions": [
      {
        "index": 1,
        "gloss": "pane (area within a window)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女の遠い祖先のスペインの血は、その顔にも現れて、はげしい苦闘的なものを印してゐた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "スペインや、イタリーでは、ナポレオンの方を向いて、政界が退進した。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中の淋しい小驛の何處にでも、同じやうな乘合自動車のアルミニウム・ペイントが輝いて居た。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また我々の使っているメリヤスという語、これも古いスペインの語でありまして medias という語ですが「ディ」という音が日本にないから、それを日本にあるそれに似た音にして、メリヤスとしたのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いドイツやスペインあたりを思わせるような空気が、最も新しい西欧芸術の香と混合してそこに一種のグロテスクに近いものが生れている。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また医薬として土を用いた例はアルメニアやスペインにもある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十一月十六日『東京朝日新聞』）　　　　　　　　　三十九　　　　　　赤茄子の伝来　洋食に用いるトマトの来歴を調べた人の説によると、この植物は十六世紀の中頃に南米ペルーからスペインあるいはポルトガルに渡りそれから欧洲に拡がったものである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「悲歌」は一九一二年（ドゥイノで）著手せられ、その後スペインや巴里で一九一四年まで斷片的に書き繼がれてをりましたが、戰爭がこの私の最大の仕事を完全に中絶せしめたのでした。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからルーマニアの士官と、スペイン女のあの意気で猥雑なタンゴが始まると、人々は腰を高く振って、歓声をあげるのでした。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾達の曲芸団はマルセーユの興行を打揚げると、スペインのバルセロナの街に小屋を下しました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾達はスペイン人の巻舌の中で、真赤な衣裳の影で、恋愛のために歓声をあげたのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはスペインの十月の最後の金曜日でした。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルセロナの市長夫妻が、古風なスペイン服で高い桟敷につくと、金と紅で美装した闘牛士の群が騎馬で出て来て、司会者の前で昔ながらの武士的な挨拶をするのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は残虐な血を見て、喜びがスペインの奔流のような歓呼の中で亢奮していました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾はスペインでロダンさんに約束したことは兎角流れ勝だったのですが、ジョージ・佐野はそれについてとらえ難い不安に襲われていたようです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまでは横田はヤンキーの女達が過去スペインの愛犬に恋慕したように、無謀な愛情ときわどい婦人社会の教養をうけて裸体で近東風な機械体操や、スパルタ風の腕力を発揮したり、恐らくあの毛むくじゃらの胸を、つき出して、サロンを物好きな流行女の号令によって、自由自在に這い廻っていることだろう。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "スペイン式の女学生がいるわ、シャンパン飲まして欲しいの………。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右の陳列棚にはスペイン・ショールや夜会服が模造人形に装飾されて、その下に並べられた化粧品からは嗜好的な香が発していた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "スペイン女が、ヴェリストのアメリカ女が、権能を知る英国女が、ユーモアを感じさせるロシア女が、流行の尖端を自覚した日本女が、弛緩したような朝鮮女が、ニグロの女が、そしてノラの属する混血種の支那女が黄浦灘を横切って蘇州路へ、北京路へ、南京路へと立ち去って行く。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでもし眼かくしさえしていない男なら彼はきっとスペイン女のことを恋の標石塔と云い、アメリカ女のことをお喋べりなめかしやと云うだろう。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "筒の外側はアルミニウムペイントで御化粧をしてあるが、金属製だかどうだか見ただけでは分らない。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ人もスペイン人もそれをやった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この西洋人の車は一方の泥よけがつぶれただけですみ、われわれのバスは横腹が少しへこんでペイントがはがれただけで助かった。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し唐突ではあるが地球上における蚯蚓の分布を調べた学者の研究の結果によると、ある種の蚯蚓は、東は日本から海を越えて大陸に、欧亜大陸を横断して西はスペインの果てまで広がり、さらに驚くべき事には大西洋を渡って北米合衆国の東部にまでも分布されているのである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが昔からの土人の都ではなくてアメリカ・スペイン人の都であったとは写真で見た町のプランから明瞭だそうである。",
              "citation": {
                "source": "ロプ・ノールその他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろスペインの舞姫テレジーナの舞踊を見た。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからアスファルトの屋根材の継目に塗りつける黒いペイントを顎のとこへ大きな点につけてしばらくの間じっとそんな油や何かの乾くのを待ってたが、それがきれいに乾くとこんどは鏡台の引出しをあけてにせものの金歯を二枚出して犬歯へはめました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にあのペイントを塗った顔から黒い汗がぼとぼとに落ちてシャツを黄いろに染めたのだ。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして恐る／＼絢爛たるスペイン革の覆いを除けて、彼自身の姿と向き合った。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂの細君が、帝劇にかかったニナ・ペインのアクロバチック・ダンスの切符を二枚もってＡの細君を誘いに来た。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
