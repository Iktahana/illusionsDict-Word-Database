        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まるで、最初からお前達の不義を待ち構えて、ただそれだけの理由で、お前たちをペテンに掛けるために計画的な結婚を敢えてしたのでもあるかのような気持にさえなった。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "また彼は幾度も僕をペテンにかけるので、つい僕も酔った紛れに向っ腹を立てたこともあったが、決して蔭で云々した次第ではなかった。",
              "citation": {
                "source": "喧嘩咄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は別に生蕃小僧をペテンにかけるつもりじゃなかったんだ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "詐欺をやる、ごまかしをやる、ペテンにかける、めちゃくちゃなものであります。",
              "citation": {
                "source": "私の個人主義",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "人をペテンにかけるような、そんな。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外交をペテンにかける気だな。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペテンにかけるなんて滅相な。",
              "citation": {
                "source": "恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
