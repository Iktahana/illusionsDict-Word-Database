        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だがたいていの場合、私は蛙どもの群がってる沼沢地方や、極地に近く、ペンギン鳥のいる沿海地方などを彷徊した。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンギン鳥の恰好をした手提げのお腹には、勿論ありったけのお紙幣と銀貨とを押しこみました。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "とに角僕が坂を降り掛けようとすると、下からペンギン鳥のやうな恰好で登つてくる老人がある。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ペンギン鳥とはちがいますか。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月の静謐、　黒と白との寛洪な燕尾服の紳士、ペンギン鳥の従弟、ロッペン鳥が、その上の岩壁の突処に立っている。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正二年四月ペンギン見知らぬ海と空とに鳴いてゐる、鳴いてゐる、ペンギン、なにを鳴くのか、ペンギン、光と陰影の申子。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たい氷のうへから歌ふてくるペンギン、なにを慕ふのか、ペンギン、寂しい空のこころに。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそれも悔もない気ぶりで、あるいてくる、ペンギン、なにが楽しいのか、ペンギン、大勢あつまつて、のんきに。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺と白との燕尾服で、ものおもふペンギン、なにが悲しいのか、小意気なわかい紳士のペンギン。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらさら悲しい様子も、うれしさうにもない、ペンギン、なにを慕ふのか、ペンギン、幽かな空の光に。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "南極へ着いたものは自分がペンギン鳥と踊つてゐる心になり、シヤムに行けば象の鼻をねじり倒した画は自分の活動と思ひ、クルツプやモスコウ、イルクツク、ニユーヨークなどは、ほんとに腕に力が入つた。",
              "citation": {
                "source": "喜びと悲しみの熱涙",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、さしもに広大な円型の芝生であつたにも関はらず、まるで日向ぼつこに逼ひあがつて来たペンギン鳥か、あざらしの群が寄り集まつてゐるかのやうに、どちらを向いてもあたりは満員であつた。",
              "citation": {
                "source": "奇友往来",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああああ　ええ　ただ今からペンギン鳥の歌をはじめます　音楽がきこえて歌がはじまりました。",
              "citation": {
                "source": "ペンギン鳥の歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてペンギン鳥やペリカン鳥が食べ過ぎて腹を痛めた場合の処方箋を考へ出してみたりした。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの地球だって年中氷にとざされている南極にも、ペンギン鳥のような生物がちゃんと生きているんだからね。",
              "citation": {
                "source": "火星の魔術師",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "バー・ペンギンで木村が酔っ払った時は、おかしかった。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "バー・ペンギンとはよく名づけた。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダムの恰好が、脚はちんちくで、胴はのっぺりして、口は反っ歯で、ペンギンそっくりじゃないか。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、マダム・ペンギンが、さっと出て来て、彼を抱き起し、大真面目な顔で塵を払い落してやったりしている……。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンギンの胴体がちょっと気に入ったと見える。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かりに、マダム・ペンギンと木村とが初めに関係があって、木村が京子へ寝返ったとしたら、マダム・ペンギンのヒステリーは凄いものがあったろう。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子は女らしい皮肉を言って、バー・ペンギンから他の店へ移った。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダム・ペンギンのところか、京子のところか……それも今は億劫だし、遼子のところへはちと行きにくい。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
