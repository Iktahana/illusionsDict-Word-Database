          "literary": [
            {
              "text": "が、出来るだけ悠然と北京官話の返事をした。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし元来｜長沙の言葉は北京官話に通じている耳にも決して容易にはわからないらしい。",
              "citation": {
                "source": "湖南の扇",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「断つて置くが、僕は北京官話が少し出来るといふ廉で雇はれたので、督軍の数よりも四分五裂になつてゐる各省の方言にはまつたく通じない。",
              "citation": {
                "source": "南京六月祭",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "北京官話と苦力の用語とはちがうがあの本有益の由です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
