    "definitions": [
      {
        "index": 1,
        "gloss": "slapping on (stamp, sticker)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
