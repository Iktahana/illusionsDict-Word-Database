        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "太い弛んだ婆やの足は、ぺたりぺたり、とその上を歩いた。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "離れの六畳へ這入るや否や、婆やはかやの手を握ったまま其処へ体を投り出す様にしてぺたりと坐った。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲居さんは、あの人が財布の中のお金を取り出すのに、不自然なほど手間が掛るので、諦めてぺたりと坐りこんで、煙草すら吸いかねまい恰好で、だらしなく火鉢に手を掛け、じろじろ私の方を見るのだった。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隅の方には一組の男女がぺたりと頬をくっつけながら、踊っているのだった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、やがて電車が来て、並んでいた人々が動き出し、針助も二三歩前へ進みかけた途端、次郎は何かあわてて、いきなり針助の体を押すように、ぺたりと背中へ自分の体をつけた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくおたかはぺたりと坐りこんだまま、肩で息をし、息をし、畳の一つところを凝視めていた。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたかはぺたりと尻餅をついた。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お君の母親は、お君の記憶する限り、まるで裁縫をするために生れて来たような女で、いつみても、薄暗い奥の部屋にぺたりと坐り切りで縫物をしていたが、お君が十五の時、糖尿病をわずらって死んだ。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の気を消してしまった火鉢の上に手をかざして、張子の虎の様に抜衣紋をした白い首をぬっと突き出し、じゞむさい恰好でぺたり坐っているところを起たされ、人力車に乗せられた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "きゃらきゃらと笑い続けて逸作の傍の食卓の角へ来て、ぺたりと坐った。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさは、兄さんも僕も、手伝いどころか皆の邪魔になるばかりなので、二階に避難して、お手伝いの人達の悪口などを言っていたら、杉野さんが、こわばった表情をして、用事ありげに僕たちの部屋へはいって来て、ぺたりと坐って、「当分おわかれですわね。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北さんが、妻へ母の重態を告げて、ひとめ園子さんを、などと言っているうちに妻は、ぺたりと畳に両手をついて、「よろしく、お願い致します。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひきとめる節子をつきとばし、思慮を失った者の如く、あああと叫びながら父のアトリエに駈け込み、ぺたりと板の間に坐った。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」あさましいほどに、舌がもつれていて、そのまま、ぺたりと坐ってしまった。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秀は「きゃっ」といって桟橋へぺたりと坐りました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一文菓子屋の息子はもう孫が出来て、店先にぺたりと坐って、景品附きの一文菓子を売るしぐさも、何か名人芸めいて来た。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたかは暫時ぺたりと坐りこんだまま、肩で息をし、息をし、畳の一つところを凝視していた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日から商売でけん」　だから、日の丸湯へ顔出しする元気もなく、こうやって蒲団かぶって寝ていたのだと、ぶつぶつ言うと、君枝はぺたりと尻餅ついて、ああ、えらいことになってしもたと、子供心にこたえたようだった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿呆やな」　言いながら、いつもは奥の長火鉢の前で、頭痛膏をこめかみにはりつけた蒼い顔で、置物のようにぺたりと坐りこんでいる御寮人が、思いがけずいそいそと出て来て、「――よう来てくれはりました。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、丁度その時君枝は水道端の漆喰の上にぺたりと跣足になって、しきりに足洗っていたところ故、水の音が邪魔になって、羅宇しかえ屋の婆さんの声が聴きとれなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "君枝は立ったまま、ぺたりと尻餅ついた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そのふるえが、身体全体に移ったかと思った途端、陽子はいきなり木崎の前へぺたりと坐った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こないだ（この間）からお居しまへんのどっせ」　家出したらしいと、軽口の女中がペラペラと喋るのをききながら、魂が抜けたように料理場でぺたりとへたり込んでいると、貴子がいない失望よりも、家出したチマ子への心配が銀造をぽうっとさせ、いきなり十も老けてしまった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母にその事をいわれると、順平はぺたりと畳に手をついて、もう二度と致しまへん。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房はまるで縫物をするために生れてきたような女で、いつ見ても薄暗い奥の間にぺたりと坐りこんで針を運ばせていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "物も言わずにぺたりとそのそばに坐り、畳の一つ所をじっと見て、やがて左手で何気なく糸屑を拾いあげたその仕草はふと伊助に似たが、きゅうに振り向くと、キンキンした声で、あ、お越しやす。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
