        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「サブマリンサンド」とか、「チーズバーガー」とか、「ペストリー」とか、「ワッフル」とか、知らない食べ物ばかりだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "開いた窓の横にタペストリーで飾られた寝椅子があり、昼近い陽光が当らないようにゴーズのカーテンが注意深く巡らされていた。",
              "citation": {
                "source": "犬酸漿",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方の天井から下った、タペストリーには、カザリン二世（十七世紀）頃の香があり、死体のかけていた椅子などは、背部の木部の飾りに、ロマノフ廃朝の紋章が浮き彫され、銀の象眼が、なされていた。",
              "citation": {
                "source": "雪",
                "author": "楠田匡介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタアジュとシャリアピンを食ひ、アイスティでペストリー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "プディングとペストリー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタアジュ、ハムエグス、コーヒー、ペストリー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩が有楽座の撮影で徹夜だから、うんと食っとこうと、オニグラに、フィレソール、ミニツステーキに、アイスクリーム、ペストリーにコーヒー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事、ミネストロン、フィレソール、鳥のプリンセスにペストリー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタアジュ、チキンパイ、ハンバーグ、卵の料理とペストリー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
