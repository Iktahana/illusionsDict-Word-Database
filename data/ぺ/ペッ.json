        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "物部　「ポロペッ」大河。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "別府　「ペッポ」小河。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "別役　「ペッチャ」河「クッ」咽喉。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸波　「ペッパロ」は川口。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい近ごろになってある新聞にいろいろなペットの話が連載されているうちに知名の某家の猫のことが出ていて、その三匹の猫の写真が掲載されていた。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はかつて独逸のペッヒシュタインという画家の「市に嘆けるクリスト」という画の刷り物を見たことがあるが、それは巨大な工場地帯の裏地のようなところで跪いて祈っているキリストの絵像であった。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、膝にのせた手のさきから、燃え尽した巻煙草の灰がほとりと落ちて、緑のカーペットに砕ける。",
              "citation": {
                "source": "秋の歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "トランペットやトロンボンのはげしい爆音の林立が斜めに交互する槍の行列のような光線で示されるところもあったようである。",
              "citation": {
                "source": "踊る線条",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年研究して自信のついたころ、やはりおなじ師命をうけてペッケンにおもむくトオマス・テトルノンという人と、めいめいカレイ一隻ずつに乗りつれ、東へ進んだ。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "トオマス・テトルノンは、すぐシロオテと別れてペッケンへむかったが、シロオテはひとりいのこって、くさぐさの準備をととのえた。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "トランペットは一生けん命歌っています。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿……」　と私は思わず口走りつつ、唾をペッとその死骸の上に吐きかけた。",
              "citation": {
                "source": "線路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべからく米も電気で研ぐべし、しぼるときには水圧機を使ふべし、乳酸菌を利用し、ピペット、ビーカー、ビュウレット立派な化学の試験器械を使って清潔に上等の酒をつくらないか。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにビューレットも純粋培養の乳酸菌もピペットも何から何まで実に整然とそろってゐたのだ。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一その懦弱が伝染しては堪らぬと、吾輩はペッと吐出してしまったが、それでも背に腹は替えられずと、苦い顔をしながら食った連中もあった。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いまこの数寄屋へ入ると同時にハッと思ったのは、大坊主が古行燈の灯を銀の俵張の煙管にうつして、ぷかぷかと吹かしていた処、脂を吸ったか、舌打して、ペッペッと憚らず蚊帳に唾を吐いた。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ、人間は一匹もおらへんのンか」　豹吉はそれがこの男の癖の唾をペッと吐き捨てた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹吉はペッと唾をはいた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ、お加代か」　豹吉はペッと唾を吐いた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「素姓みたいなもン知るもんか」　豹吉はペッと唾を吐いて、「――女に惚れるのに、いちいち戸籍調べしてから惚れるくらいなら、俺ははじめから親の家を飛び出すもんか」　古綿をちぎって捨てるように言った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし「望郷」という仏蘭西映画にペペ・ル・モコという異色ある主人公が出て来たが、そのペペをもじったのか、それとも、ペッペッと唾を吐く癖からつけたのか。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ペッと唾を吐き捨てた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どんなことをして、人をあっといわせてやろうかナ」　川を覗きこんでいた顔をきっと上げて、豹吉は豹のような眼を輝かせて、いきなり振りむくと、ペッと唾を吐いた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなもん、ちゃんちゃらおかしくって、言えるか」　豹吉はペッと唾を吐いた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "隼団の龍太に、もう喧嘩はやめようと言われて、豹吉は両の頬ににやっとえくぼを浮べながら、ペッと唾を吐き捨てると、「そやなア。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹吉はペッと唾を吐き出した。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは中之島公園とちがうぞ」　と、豹吉は例の唾をペッと、Ｓ署の玄関の石段の上へ吐き捨てて小沢に言った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペッタリと土間に坐りながら片手をあげて拝む真似をした。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
