    "definitions": [
      {
        "index": 1,
        "gloss": "very hungry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私はおなかがペコペコなのだが、喫煙室のソーファに沈んで煙草を吹かしてゐるより他はなかつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝楽屋の中では　定九郎の仲蔵や座長らしい大石役者や、其他がペコペコ謝っている。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まアザッとこんな苦しいわけで……けれどつかい込みの一件は、ごく内密にお願いします」と言って立ち上がり、石井翁が何も言い得ぬうちに、河田翁は辞儀をペコペコして去ってしまった。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は真面目に、ペコペコ頭を下げ、靴を磨くことが、阿呆らしくなった。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "社員に、おべっかを使うように、ペコペコ頭を下げた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門と伝六そッと覗いて見ると、　敬四郎、お兼の前にペコペコ頭を下げて、　「ワシが言い過ぎた。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）７９＝（Ｆ・Ｉ）街道　右門と伝六とおふみの前に何と敬四郎が道の真中で土下座して両手をついてペコペコ頼んで居る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方の宿場の混乱の中に遂に二人を捕えると、宿の二階を見上げて、敬四郎ペコペコ頭を下げて、Ｔ「これで嬶ァに威張れます」　浪之助とお類、上を見ると宿の二階の手摺りに右門と伝六おふみに伊吉。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）79＝（Ｆ・Ｉ）街道　右門と伝六とおふみの前に何と敬四郎が道の真中で土下座して両手をついてペコペコ頼んで居る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿野郎……アッ、新張の奥さん……どうもありがとう御座いました」　そういってペコペコ頭を下げながら前に進み出たのは、四人の中でも一番｜年層らしい、色の黒い、逞しい鬚男であった。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "目明良助の名を知っているらしく、揃ってペコペコとお辞儀をし始めた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にせよ恵比寿講の帳合いと言うたなら、一文二文の間違いにも青筋を立てて算盤を弾き合うような吝垂れた金持連中の寄合の事で御座いますけに仮令、仕事が夜通しがかりになったにしても、出て来るものは漬物にお茶か、せいぜい握飯ぐらいで、それでもペコペコと頭を下げてお礼を言うて帰るのが普通で御座います。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラ空の旅人宿の真昼間からペコペコ三味線の音が洩れ出して来る。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ペコペコ頭をさげて、急いで自分の穴へもぐり込んで、子供のフウねずみを連れ出して、鳥箱先生の処へやって参りました。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペコペコに減った腹に鰻飯！",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつは恥かしいことだが、おなかが空いて、ペコペコだったのだ。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ああ、おなかペコペコや」　昼日散々、反吐が出るくらい豹吉に食べさせて貰ったのに、三郎はもう腹の皮がひっつきそうだった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹の皮がひっつくくらい、ペコペコになっていたせいか、涙が出るほど美味かった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも前の晩あたりから飯を食わずに、腹をペコペコにしておいて、あくる日は早くから店を閉めて、松葉杖を突張って出て来るので御座いますが、いよいよ酒の座となりますと、先ず猪口で一パイ飲んで、あの青い顔を真赤にしてしまいます。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "月のいい晩なぞは、よくその松原から浮き上るような面白い音がきこえるので、村の若い者が物好きに覗いてみると蒲鉾小舎の横の空地で、チョンガレ夫婦のペコペコ三味線と四つ竹（肉の厚い竹片を、二枚｜宛両手に持って、打ち合わせながら囃すもの）の拍子に合わせて、向う鉢巻の坊主が踊っていたりした。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして坊主がもとの木阿弥の托鉢姿に帰って、松原から出て行くと、女房は女房で、坊主と別々にペコペコ三味線を抱えて都の方へ出かける。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鯛の骨が咽喉へかかりましたので……どうかすぐに先生へ……」　間もなく真暗な室に通された松浦先生は、白い診察服を着けた堂々たる遠藤博士と、さし向いに坐りながら、禿頭をペコペコ下げて汗を拭き続けた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがわからなかったのか……今まで」　一知は寝巻の袖で汗を押拭い押拭いペコペコと頭を下げた。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣きの涙でいる新夫婦が、司法主任や刑事たちからシキリに慰められながら、何度も何度もお辞儀をするのにつれて、父親の区長や村民たちまでもがペコペコと頭を下げ初めた。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コマツタ　ヤツダナ、オレニハ　オチチガ　デナイカラ　ヤツパリ　モトノ　マキバヘ　ツレテツテ　ヤラウ」ト　イツテ、ヌスビトハ　ペコペコノ　オナカヲ　オサヘナガラ　マタ　モト　キタ　ミチヲ　カヘツテ　ユキマシタ。",
              "citation": {
                "source": "ヌスビトト　コヒツヂ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことを言うと、「風呂は入れてくれるけンど、お腹ペコペコやさかい、風呂の中で眼がまわりそうになっちゃった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おっちゃん、うちおなかペコペコや」「おっさんもペコペコや。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
