        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから自分がベッドカバーとして使っているペパーミントの葉を取って来て、ツバメの頭にかぶせました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミルテやペパーミントのかぐわしい香りもただよってきます。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか１まいで　かえる　ペパーミントぽっちにも　しはらってくれないのです。",
              "citation": {
                "source": "ジンジャー＆ピクルスのはなし",
                "author": "THE TALE OF GINGER AND PICKLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると　やまねずジョンさんと　そのむすめさんが　ペパーミントと　ろうそくを　うりはじめました。",
              "citation": {
                "source": "ジンジャー＆ピクルスのはなし",
                "author": "THE TALE OF GINGER AND PICKLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "パウリスタで思い出すのは、ペパーミントのゼリー。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
