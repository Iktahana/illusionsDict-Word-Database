          "literary": [
            {
              "text": "ペイドオフ（馘首）の食いたてなんだ」　浚渫船のデッキから、八つの目が私に向いた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あんな泥船ならペイドオフの方が、よっ程サッパリしてらあ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "スペイドの十を見損っちゃった。",
              "citation": {
                "source": "若い木霊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずどちらも同じやうにスペイド形の髪に結つた二十前後の美人である。",
              "citation": {
                "source": "鷺と鴛鴦",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "テエブルの左に並んでいるのはスペイドの一や画札ばかり。",
              "citation": {
                "source": "誘惑",
                "author": "――或シナリオ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハアトの王樣も、スペイドの王樣も、クラブの王樣も、……　ダイヤの王（立ち上りながら）さあ、どうかこちらへ。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハアトの王、女王、兵卒、スペイドの王、女王、兵卒、クラブの王、女王、兵卒、等皆犬を一匹引きながら、績々病室へ入り來る。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            },
            {
              "text": "スペイド・クーリー。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
