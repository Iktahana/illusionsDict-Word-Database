        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "幾組かの拳銃隊が街の要所々々を発砲し、欧米人によって築かれた南京路のペーブメントは要撃された。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでは一群の弥次馬がペーブメントの上から一つの窓を見つめていたが、この人達は私が見に来た一軒の家を指さしてくれた。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は足の裏の痛くなるまでペーブメントを歩いた。",
              "citation": {
                "source": "二つの失敗",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "その暑さのなかを、新宿の向うに続いたＡ町Ｂ町Ｃ町などの郊外住宅地に住んでいる若い人達が、押しあったりぶつかり合ったりしながら、ペーブメントの上を歩いていた。",
              "citation": {
                "source": "麻雀殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆村探偵は、ペーブメントの道を横に切れて、大きいビルディングとビルディングの間の狭い路を入ると、突当りに「麻雀」と書いた美しい電気看板のあがっている家の扉を押して入った。",
              "citation": {
                "source": "麻雀殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車は、広場のペーブメントで二三尺も彼方此方ずれて居る。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うと、呉服屋の陳列台の間を、ペーブメントの連続かなどのようにぐるりと通りぬけたりした。",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座のあのかたい、ペーブメントの上で、梯子乗りをして居るのを見ると、頭の後の方がいたくなって来た。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "装飾電燈をつけた五階建、六階建の宏荘な旅館が、整然として大通りのペーブメントに沿ってすっくりと立並んでいる。",
              "citation": {
                "source": "緑衣の女",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペーブメントは凹凸だらけ穴だらけ、電車の軌道も石がはね上って居るので危険。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔ペーブメントからアスフアルトへ〕櫻間中庸ペーブメントからアスフアルトへアスフアルトからペーブメントへ風が新聞紙を運ぶのか新聞紙が風を運ぶのか風と新聞紙はほいと柳の若い葉の下をぬけてお堀にすべりこんだ",
              "citation": {
                "source": "〔ペーブメントからアスフアルトへ〕",
                "author": "櫻間中庸",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なくそこの三角になったペーブメントのところに佇んでいたら夏服着た少年がちょろりと出て来ていきなり「僕傘忘れちゃった」というのよ、太郎なの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士は左手に持っていたぺしゃんこの手提げ鞄とステッキを右手に持ち替えて、鞄だけ脇に挾み、ステッキの先端でペーブメントをたたきながら、容器の中の魚類を見、その眼で土川春彦を見た。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂々空を圧する白堊の建築物と、美しく掃き清められたペーブメントと、凡て直線的な均整の中に、これは又ひどく大時代な、赤い着物を着た酔っぱらいなんて、何となく気違いめいた対照であった。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
