        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「人をぺてんにかけやがった！",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしなんの効能もないとすると、祖先の日本人は仏法伝来と同時に輸入されたというこの唐人のぺてんに二千年越しだまされつづけて無用なやけどをこしらえて喜んでいたわけである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは、ビロードのチョッキに、変り模様のネッカチーフ、鍍金の鎖に、金銀線細工のボタン、というまさにいかさまぺてん師の服装から、嫌疑のかかり易くないことこれに及ぶものなし、という物堅く飾らない牧師の服装に至るまで、あらゆる種類の服装を身につけていた。",
              "citation": {
                "source": "群集の人",
                "author": "THE MAN OF THE CROWD",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんないかさま物を持ち込んで来て、人をぺてんにかけるとは何事だと、あたまから呶鳴りつけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでぺてんですものね。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま大きな声で呼び留める人があるかと思えば、裏表の見えすいたぺてんにかけて、昔のままの女であらせようとするものばかりだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「馬の扱いもあいつぐらいになると、どうにでもぺてんの利くもんだよ」「だって君は、ブラウンに馬を預けておいて心配はないのかい？",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "平和についての口さきのぺてんは、えたいしれない、しかも人心を刺戟する策動によって、平和をあらせまいとするところまで進んで来ました。",
              "citation": {
                "source": "わたしたちには選ぶ権利がある",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことをぺてん師の鑑定家の爺と番頭とがあくどく揶揄した。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私の方にもいろいろ都合がありますので、……それに実はお米のことで二千円ぺてんにかかつたところなのです。",
              "citation": {
                "source": "災厄の日",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前たちやあ、なんかといへば慾得一点ばりで、堅気な人間を誤魔化したり、ぺてんに懸けたりばかりしてやがるんだ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあ、おつかあ、正真正銘、嘘いつはりのねえ話だが、おめえのその御面相が太鼓に見えてさ、おいらがその太鼓で朝の時刻を打たにやあなんねえことになつてよ、そうら、あの教父の話した、ぺてん師を豚面どもが何したとおんなじやうに、その……。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その何にもないちふぺてんをおれはよう知つとるぞ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを承知していながら、せっぱ詰った今になって算段つかねえじゃあ、まるで、わしをぺてんにかけたようなものだ。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、あいつはぺてん師らしかったな、まったく！",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月からわずか四ヵ月で、これだけのぺてんを組織した。",
              "citation": {
                "source": "日記",
                "author": "一九五〇年（昭和二十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ぺてんに引っかかった。",
              "citation": {
                "source": "競馬",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの先週は、神信心だのあれやこれやの呪い事だので、おれあぺてんにかけられて、可哀そうな実直な商売人めがこれまで出くわしたことのある中でも一番不仕合せな目に遭ったじゃねえか！",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、それとなくあちこちへ網を張ってその女を待っていると、間もなく思いがけないところでこの子供づれの女ぺてん師の尻尾を掴まえることができた。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "浮世芝居女看板",
                "note": "青空文庫"
              }
            },
            {
              "text": "才人は才に斃れ、智者は智に敗れ、苦沙弥君のような癇癪持ちは癇癪を利用さえすればすぐに飛び出して敵のぺてんに罹る……」「ひやひや」と迷亭君が手をたたくと、苦沙弥君はにやにや笑いながら「これでなかなかそう甘くは行かないのだよ」と答えたら、みんな一度に笑い出した。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "群衆の方へ向き直ると芝居染みた邀越な口調で、「諸君、詐欺だ、ぺてんだ！",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺をぺてんにかけておびき出す気だろう」「とんでもない、親分。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "評決は、当然ながら、ぺてんである、ということに決まった。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、意図的なぺてんという要素も除外することはできない。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "インクによる線画は無論のこと明白なぺてんだとして馬鹿にされて終わりだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら、彼に富と幸福をもって来る筈だった黄金の水――石油は、彼を果しのないぺてんの中へひっぱり込んだから」ひっぱりこむ、という字がわからなくて辞書をみていた伸子は、デスクのところで、「何故です？",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぺてんだ、ぺてん以外の何ものでもないのだ！",
              "citation": {
                "source": "火夫",
                "author": "DER HEIZER",
                "note": "青空文庫"
              }
            },
            {
              "text": "教育終了と共に帰す約束なのに、蒙古くんだりまで追いやるとは、ひでえぺてんだってね。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもぺてんにかけられたとかいう話ですがな。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
