          "literary": [
            {
              "text": "「あいつ、あのへんのインディペンダントから、何枚かレコードをだしたらしい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人服ノアクセサリーヲ売ル店デ、レースヤナイロン製ノ手袋、各種ノイヤリング、ペンダント等々ガウィンドウニ飾ッテアル。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若いころは莨入の前金具だとかキセル、簪などに素彫をするのが得意で、いちじは相当に名も知られたが、現在ではそういう品を使う者が稀になり、高級なコンパクト、帯留、簪、ペンダントなどを手がけている。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな赤いペンダントが、左右の鎖骨が出会うすぐ下で、シャツの白さと拮抗し、どちらにとっても安定を作り出していた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルに向けて、天井からペンダント・ライトが下がっていた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
