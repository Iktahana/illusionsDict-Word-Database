    "definitions": [
      {
        "index": 1,
        "gloss": "sound of something making firm contact with a flat surface",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "と大声が出て、立って居られずぺたんと草原に坐って、思い切って泣いてしまいました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人のかたわ者はかたわがなおりかけたと気がつくと、ぺたんと地びたに尻もちをついてしまいました。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りがけの霞の空の、真中を蔽う雲を抜けて、かんてらの前へ、飛出したお千世の姿は、爺さんの目には、背後の蔵から昨夜の雛が抜出したように見えて、あっと腰を抜いて、ぺたんと胡坐を掻いて、ものを言うより莞爾々々としていたのである。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "薩摩訛に、あれえ、と云うと、飛上るやら、くるくる舞うやら、ぺたんと坐って動けぬやら。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬はぱくつとそれを噛み、大きな息を一つして、ぺたんと四つ脚を折り、今度はごうごういびきをかいて、首を落してねむつてしまふ。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "通例私たちが用ゐるのは、四角で薄くて、ちよぼりとして居て、腰を載せるとその重量で、少し溢んで、膝でぺたんと成るのだが、そんなのではない。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "横土間で誂へを聞くのが、前鼻緒のゆるんだ、ぺたんこ下駄で、蹠の眞黒な小婢とは撰が違ふ。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、表門へ廻った二人は、と皆連立って出て見ると、訓導は式台前の敷石の上に、ぺたんと坐っていた。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "用もなく、厨の涼しい板の間にぺたんと坐つてゐるときでも急に顔を皺め、「ひろ子のやつめ、――ひろ子のやつめ、――」　と独り言のやうに言つてゐた。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちど、嘉七がひとり、頭をたれて宿ちかくの草むらをふらふら歩きまわって、ふと宿の玄関のほうを見たら、うす暗い玄関の階段の下の板の間に、老妻が小さくぺたんと坐ったまま、ぼんやり嘉七の姿を眺めていて、それは嘉七の貴い秘密のひとつになった。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶に時計が九時で留つてゐるとか、愛国婦人会の幹事の鼻がぺたんこであるとかすると、女史は直ぐ苦り切つた顔をして、「西洋にはそんな事は無い。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際ぺたんこな鼻の恰好から、黒味がちな円まつちい眼は、お婆さんそつくりだつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　薬罐を置いて、油井の横へ、ぺたんと坐った。",
              "citation": {
                "source": "未開な風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあさんや、姉やらに比較すると私のが一番ましでしょう、と言ってぺたんこになったというほど低くもなし、さりとてえらく高いというのでもない。",
              "citation": {
                "source": "三味線の胴",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ある時も大森駅のホームで、等身大の袋を担はうとして、ぺたんと腰をコンクリートの上に据ゑながら、身を反り返してゐる女を見かけた。",
              "citation": {
                "source": "氷花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はぺたんと椅子に腰を下すと、「撲られた」と、乾ききつた声で云つた。",
              "citation": {
                "source": "飢ゑ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の、いま寝ているところは、先程までその学生達の三段｜跳競技場であったが、いまは彼女一人、のけもののように、ぺたんとその空地へ寝ているのである。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　朝からの若やいだ私の気持ちが急にぺたんと折れ崩れて坐った。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "見かけは詰らんたゞの木彫の印形だが、届けが済んでこれが役所の台帳にぺたんと押されると、もうたゞの印形ぢやない。",
              "citation": {
                "source": "貸家を探す話",
                "author": "高田保",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、躊躇したり、あとしざりしたり、再び前へ出たりしたが、その挙句、私のびっくりしまごついたことには、ぺたんと跪いて、組み合した両手を哀顔するようにして差し出した。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "トロ族の呪いの声を聞け」　そういって彼は、僕の耳にゴムまりを半分に切ったようなものを、ぺたんとはりつけた。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "カシタンカはとびのいて、ぺたんと腹ばいになり、ねこのほうに鼻面をつきだして、わんわんほえ始めた。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいに、二つの膝がしらを揃え、ぺたんこに坐ってしまって、よくある例の手※を口に啣え、地獄から今かえってきたような顔付をして見せたときに、わたしは少し不愉快だった。",
              "citation": {
                "source": "ヒッポドロム",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　佐吉は、部屋の隅にぺたんと坐って、腕組みをして考えこんでしまった。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "汪克児はぺたんと尻餅をついて、肩で呼吸をする。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　座敷へ直るや否や伝二郎はぺたんと坐ってしまった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怪談抜地獄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」庭係の３まいはあわててぺたんとうつぶせにたおれる。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おすゑはぺたんこに坐つて、「默つて出ては困るつて言つてゐただけさ。",
              "citation": {
                "source": "蒼白き巣窟",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
