        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "急性肺炎にきく薬はペニシリンしかないというとき、和製のペニシリンはよくきかないからと云って、それを使わずに良人を死なす妻が天下にあるだろうか。",
              "citation": {
                "source": "誰のために",
                "author": "――インテリゲンツィアと民主主義の課題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "財団法人日本ペニシリン学術協議会（一九四六年九月設立）。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＧＨＱからの指令に基づいて戦争中のペニシリン委員会は解散された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい協議会は各専門家の綜合研究のために八専門部を設けペニシリンその他抗菌性物質の綜合研究と調査に着手している。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆき子の熱はまだひかなかつたので、富岡は、比嘉に教はつたとほり、ペニシリンの注射をこころみてみた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時間ごとに注射したペニシリンが、利いたのかも知れない。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで最後に昨年の暮、バカな私にも、桂子が異国製の菓子と煙草をかくし持っていたり、おまけに当時、ジフリーズで、ペニシリンの注射をさせてやっていた頃、彼女の浮気というより、その淫奔さに薄々、気づいていたので、また催眠剤を飲んで彼女と喧嘩の末、伊豆の妻子のもとに逃帰った。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、私は姉にいわれ、医者に見て貰い、その日までペニシリンの注射を続けていたので、その夜は、彼女の身体に触る元気はなかった。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペニシリン代一本二千三百円と頭にひらめく。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペニシリンだって、青黴の一種から発見されたのだ。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペニシリンの事、加藤ヨシノさんの肺炎のことなど話をする。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "神薬の話　終戦後、私が非常に恩恵に浴して有難いと思っているのは、ＤＤＴとペニシリン及びその一族の青カビ薬である。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯痛は私の持病で、これには毎年泣かされたものであるが、ペニシリンが流布してからの昨今はもう問題ではない。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これぞ文明の神器と私は大そう感激して、ＤＤＴ、ペニシリン、オーレオマイシン、クロロマイセチン、テラマイシンという神族をわが家へ勧請し、一タン緩急にそなえて崇敬をはらっている。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "目下女工の流し作業で盛大に製産されているのはペニシリン軟膏とかサロメチールまがいの薬であり、高貴薬では六神丸以上にＢ12である。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉体の条件がよければマラリヤ療法でくいとめることができるが、僕の居たとき病棟の廊下をうろついていた四十ぐらいの女の脳梅毒患者は、もう肉体力がなくて、マラリヤ療法を施し得ず、仕方なしに、ペニシリンを打ったり、人工栄養などで、ようやく生きて、痴呆状態で廊下をうろついている始末であった。",
              "citation": {
                "source": "精神病覚え書",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "天草商事の下に「天草ペニシリン製薬」だの「天草書房」だの「天草石炭商事」だのと十幾つとなく分類がある。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "天草物産、天草石炭商事、天草製材、天草ペニシリン、とね。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "コレヲ歓楽の果トイウカ、ペニシリンには感激しました。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドクター曰く、ペニシリンに狎れるナカレ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉野旅行が延び延びとなり、ついに意を決しペニシリンと注射器一式にダイヤジンをぶらさげて吉野へついたら、花の散ったあとであった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペニシリン、ストレプトマイシンのごときは最近顔を出したばかりである。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらか一方だつたら、僕は、ペニシリンだけに力を集中します。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそう思ったから担当の先生に談判して、念のため、私にも、亦、女房にも一千万単位ぐらいずつペニシリンを注射してもらいたいと頼んだ。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともペニシリンやストレプトマイシンのように、すぐ眼に見えるものについては、日本人は決してぼんやりしていない。",
              "citation": {
                "source": "老齢学",
                "author": "――長生きをする学問の存在――",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学の方も、この頃は、ペニシリンだの、ストレプトマイシンだのというものが出来たので、大分信用を高めて来た。",
              "citation": {
                "source": "ジストマ退治の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペニシリンのショック死が、その良い例である。",
              "citation": {
                "source": "科学の限界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれならば、ペニシリンの販売を禁止すべきかというと、それは間違っている。",
              "citation": {
                "source": "科学の限界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペニシリンは非常な名薬で、この薬の出現以来、肺炎の死亡率が激減している。",
              "citation": {
                "source": "科学の限界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
