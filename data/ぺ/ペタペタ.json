    "definitions": [
      {
        "index": 1,
        "gloss": "sound of a flat surface repeatedly making contact with something",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四っ角山にみんなぺたぺた一緒に座る。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥に来ているのは」　二人は帽子とオーバーコートを釘にかけ、靴をぬいでぺたぺたあるいて扉の中にはいりました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして草原をぺたぺた歩いて畑にやって参りました、　それから声をうんと細くして、「野鼠さん、野鼠さん。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、これによって、生きている人をそのままに透明な幽霊にして壁へでもなんでもぺたぺたと張り付けあるいは自由に通り抜けさせることができるのである。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥に来てゐるのは」　二人は帽子とオーバコートを釘にかけ、靴をぬいでぺたぺたあるいて扉の中にはひりました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これさ、金を出せというのに」　俯して答えなき内儀の項を、出刃にてぺたぺたと拍けり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「貴女のことをね、顔にぺたぺた白粉も塗らず、身装も堅気のようで、あんな物堅い芸者もあるのかと、飛んだところで、お讃めにあずかったそうよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いたのはお源坊、ぼうとなって、ただくるくると働く目に、一目輝くと見たばかりで、意気地なくぺたぺたと坐って、偏に恐入ってお辞儀をする。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ぺたぺたと花を引く音がしていた。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "尻をぺたぺた敲きながら、御所を出ると、足は自然に学校の方へ向いた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事の続いている間、部落の女達は「ぺたぺた敲き」の日傭に出た。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一期当時にあった煉瓦場の方の仕事「ぺたぺた敲き」や煉瓦運搬の駄賃や縄綯いなどは以前からの熟練した人々の手で沢山だったからである。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　叫び乍ら門七と大三郎が走りよって、さっと左右から障子を押し開いた刹那、――ぺたぺたと崩れ伏すように影が膝を折ると消え入るような声で言った。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっちへどきな」　今のさき求めてきた用意の生うるしを筆にしめすと、何を思ったか、血がめのそのふたのつまみ柄のまわりへ、ぺたぺたとぬりつけました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "梯子を掛けると、正三はぺたぺたと白壁の扉の隙間に赤土をねじ込んで行った。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "患者は大きな馬革のスリッパをぺたぺたいわせ、荒い赤縞に大きな花模様のついた木綿の寝間着の裾をはためかせながら、勢いよく隅から隅へ歩き廻っている。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤いジヤケツを着て、花模様の短いスカートをはいた小柄な太つた娘が出て来たが、直吉が部屋がありますかと尋づねると、直吉の後に立つてゐる里子を娘は透かして見ながら、「はい、一寸お待ち下さい」と云つて、ぺたぺたと素足で廊下の奥へ引つ込んで行つた。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ぼく達も、隅田川での恋人、「さくら」が、一足先きに艇庫に納まり、各国の競艇のなかに、一際、優美な肢体を艶やかに光らせているのをみたときは、なんともいえぬ、嬉しさで、彼女のお腹を、ぺたぺたと愛撫したものです。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をするのかと思っていると、刷毛を小缶の中に入れてかきまわし、それをいきなり画面にぺたぺたと塗りつけた。",
              "citation": {
                "source": "すり替え怪画",
                "author": "烏啼天駆シリーズ・５",
                "note": "青空文庫"
              }
            },
            {
              "text": "各｜頁には、新聞や雑誌から切り抜いた世界各国の戦車の写真が、ぺたぺたと、はりつけてある。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "汀をぺたぺた素足で歩く。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の出版界も本の奥附にぺたぺた印を押さなくても報酬を著者に贈るやうになりたいものです。",
              "citation": {
                "source": "出版屋惣まくり",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の出版界も本の奥附にぺたぺた印を押さなくても報酬を著者に贈るようになりたいものです。",
              "citation": {
                "source": "出版屋惣まくり",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは家でスリッパをぺたぺた言わせながら、俺がコーカサスにいてやるだけでも、ロシヤ政府はありがたいと思えというような顔をしている。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、なるほど潔白で思想的な男かも知れないが、単調で、二六時ちゅうスリッパをぺたぺた言わせ、爪を噛み、我儘ばかり言ってうんざりさせるラエーフスキイ自身。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の部屋からは、絶え間なしにひそひそ声と跣足でぺたぺた歩く音がした。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、　なんぎしていると　そこへ　ぺたぺた　みずかきの　あしおとが！",
              "citation": {
                "source": "ねこぬこタムのはなし",
                "author": "THE TALE OF TOM KITTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「外の空気は、部屋の中より蒸し暑く、蜘蛛の巣のやうな何かが顔へぺたぺたした。",
              "citation": {
                "source": "露伴先生と神仙道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "店店の飾り窓に猫のやうに白いボアや、青や紅や黒や紫や竪縞や碁盤や格子型やさういふありとあらゆるシヨオルが、襟首にぺたぺたと靡いて、ほつそりした顎の先をつるつると撫でながら、そとを歩いてさへ居れば惱ましく視線にまつはりついてくる。",
              "citation": {
                "source": "星より來れる者",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
