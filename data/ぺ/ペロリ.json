    "definitions": [
      {
        "index": 1,
        "gloss": "(eating up) quickly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "南京へ着いて酒保が一日開かれたので、早速一本二十銭のヨーカン五本買ってペロリと平らげて、まだ食いたい気がします。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "啓一は彼の膝に腰かけて、包んだ紙を拡げては、小さい舌をペロリと出してザラメをなめた。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでなめくぢはペロリととかげをたべました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なめくぢはこの雨蛙もペロリとやりたかったので、思ひ切っていゝ声で申しました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな弱ったやつならば五へん投げつければ大ていペロリとやれる。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀色のなめくぢは、すぐペロリとやらうと、そっちへ進みましたがどうしたのか足がうごきません。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで銀色のなめくじはかたつむりをペロリと喰べてしまいました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでなめくじはペロリととかげをたべました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なめくじはこの雨蛙もペロリとやりたかったので、思い切っていい声で申しました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀色のなめくじは、すぐペロリとやろうと、そっちへ進みましたがどうしたのか足がうごきません。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云いながら銀色のなめくじをペロリとやりました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて蜘蛛はとけて流れ、なめくじはペロリとやられ、そして狸は病気にかかりました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "表の往来で耳を澄ましていた赤猪口兵衛が、赤い舌をペロリと出した。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは処々に灰色の薄汚れの付いた、夜具か何かを包む風呂敷らしかったが、その中央の折目に近い処に付いている真黒い血の塊の痕跡と、一目でわかる片隅の刃の血糊を拭いた痕跡と、処々に粘り付いている長い髪毛を見まわすと、今一度赤い唇をペロリと出して、大切そうに折り畳んで、懐中の奥に仕舞い込んだ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "関門海峡を渡る時に、腹の中で赤い舌をペロリと出した。",
              "citation": {
                "source": "ざんげの塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "天窓の大きな、頤のしやくれた、如法玩弄の燒ものの、ペロリと舌で、西瓜喰ふ黒人の人形が、ト赤い目で、額で睨んで、灰色の下唇を反らして突立つ。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御両方無言にて頷きたまえば、再び矢島に導れ、門を出でて三拝せしが、見送る人眼のあらずなれば、ニヤニヤと笑うて、ペロリと舌。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「長いね」　小沢が言うと、娘は半泣きの顔になり、「ふん」　と、鼻の先で笑ったが、何思ったか急にペロリと舌を出して、素早くひっこめた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　冴子は急にペロリと舌を出して露悪的な口を利いた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となく倦怠を覚える（そのくせ食慾はちつとも減じないどころか、ありすぎるほどある、五合の飯をペロリと平らげる）、入浴したら、だいぶ気持がすが／＼しくなつた（湯銭が五厘不足とは笑はせる）。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘だと思うなら嘗めて見ろ」　お爺さんはすぐに舌を出して、自分の掌をペロリと嘗めて舌なめずりをしましたが、「フーン。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三人見かねて止めに這入って来たが、一番うしろの男は表の人だかりをふり返って、ペロリと赤い舌を出した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "正坊がすかさず、手のひらの丸薬を口の中へおしこむと、クロはぞうさなく、ペロリとのみこみました。",
              "citation": {
                "source": "正坊とクロ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "目白鳥は澄まして、ペロリと退治た。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂い方も、蛞蝓だとペロリと呑みたくなって危いが、蝸牛なら仔細あるまい、見舞おうと、おのおの鹿爪らしく憂慮気に、中には――時々の事――縁へ這上ったのもあって、まじまじと見て面を並べている。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世界の何処かにいて、またペロリと舌を出しているような気がしてなりません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「帰らんのか」「うん」　ペロリと舌を出した――のを見ると、木崎は思わず噴き出しそうになって、もう追いかえせなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「トラックに乗ってる間に、浴衣の縫込みへこっそり入れといたってン」　チマ子はペロリと舌を出して、素早く陽子に飴玉を渡した。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それともうひとつ想いだすのは、浜子が法善寺の小路の前を通る時、ちょっと覗きこんで、お父つあんの出たはるのはあの寄席やと花月の方を指しながら、私たちに言って、きゅうにペロリと舌を出したあの仕草です。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
