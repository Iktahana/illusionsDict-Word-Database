    "definitions": [
      {
        "index": 1,
        "gloss": "cold night",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蕪村はいつも、寒夜の寝床の中に亡き母のことを考え、遠い昔のなつかしい幼時をしのんで、ひとり悲しく夢に啜り泣いていたような詩人であった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我を厭ふ隣家寒夜に鍋を鳴らす　霜に更ける冬の夜、遅く更けた燈火の下で書き物などしているのだろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒夜の凍ったような感じと、主観の侘しい心境がよく現れている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の寒夜に火桶を抱えて、人生の寂寥と貧困とを悲しんでいた蕪村。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れを厭ふ隣家寒夜に鍋を鳴らす葱買ひて枯木の中を帰りけり易水に根深流るる寒さかな古寺やほうろく棄つる藪の中月天心貧しき町を通りけり　此等の俳句に現はれる、抒情味の本質は何だらうか。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば冬の寒夜に、隣家で鳴らす炊飯の鍋の音。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに百詩が年十五の時の或寒夜の事であつた。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まるで寒夜に千鳥でも聴きに来たようだ」　とか、「元禄の頃、こゝから斜の向う河岸の辺に深川の芭蕉庵があったらしいんだよ」　とか池上は、話の継穂に困ったらしく、娘のわたくしには何の興味もない事柄を不揃いに喋ります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに百詩が年齢十五の時の或る寒夜の事であった。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "予はこれを知らず高山に寒夜平臥して足を不治の難症にしおわったから、記して北荒出征将士の参考に供う。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏は比較的こらえやすいが、寒夜になると、たいへんしのぎにくい。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然がその内ぶところに秘めてゐる孤独感が、をりからの朝寒夜寒に凝り固まつて咲いたらしい、この花の持味は、自然の使者として、その閑寂と侘心とを草庵にもたらすのに充分なものがあらう。",
              "citation": {
                "source": "侘助椿",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてシンプソン病院を辞去したのであるが、彼は寒夜の星を仰ぎながら、誰にいうともなく、次のようなことを呟いたのだった。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然がその内ぶところに秘めてゐる孤独感が、をりからの朝寒夜寒に凝り固まつて咲いたらしい、この花の持味は、自然の使者として、その閑寂と柁心とを草庵にもたらすのに充分なものがあらう。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "水量がぐつと落ちた川尻の塩と淡水との入り交るあたり、朝寒夜寒のきびしさに、ともすれば季節が後退りしようとするこの四五日、芦の切株に張りつめた薄氷のなかから、逸早くも春をめざして躍り出さうとする小さな生命の動きは、これなのか。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その例、嵯峨へ帰る人はいづこの花に暮れし一行の雁や端山に月を印す朝顔や手拭の端の藍をかこつ水かれ／″＼蓼かあらぬか蕎麦か否か柳散り清水｜涸れ石ところ／″＼我をいとふ隣家寒夜に鍋をならす霜百里舟中に我月を領す　そのほか調子のいたく異なりたるものあり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、　　　ひとり寒夜に※うつ月　　　　　　　　　維駒　維駒は召波の子なれば脇を着けたるなり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "・秋風の腹たててゐるかまきりで（再録）・かまきりよいつ秋のいろがはりした・糸瓜ゆつたりと朝のしづくしてゐる・重荷を負うて盲目である・家いつぱいの朝日がうらの藪までも・風に眼ざめてよりそふ犬の表情で・這うてきたのはこうろぎでぢつとしてゐる　九月廿三日朝寒夜寒。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬らしい冷たさ、朝寒夜寒であるが。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝寒夜寒、山の谷の宿はうすら寒い、もう借衣ではいけないらしい、どなたか、綿入一枚寄附してくだされ、ハイカシコマリマシタ、呵々。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の話はなしつゞけて袋貼りつゞける　　　　　　　　　　　　　　　　　　（隣室の若者に）　袋貼り貼り若さを逃がす・ラジオ声高う寒夜へ話しかけてゐる　二月一日　降つたり霽れたり、夜はおぼろ月がうつくしかつた。",
              "citation": {
                "source": "行乞記",
                "author": "三八九日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつさい寒くなつた、朝寒夜寒、障子をしめずにはゐられないほどである。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸は小さい時から長歌が好で、寒夜に裏庭の築山の上に登って、独り寒声の修行をした。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "たうときものは寒夜の炭。",
              "citation": {
                "source": "雑筆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした大店の棟つづきで、たてならべた門松などが、師走末の寒月に、霜に冴えかえって黒々と見える時は、深山のように町は静まりかえって、いにしえの、杉の森の寒夜もかくばかりかと思うほど、竦毛の立つひそまりかただった。",
              "citation": {
                "source": "鬼眼鏡と鉄屑ぶとり",
                "author": "続旧聞日本橋・その三",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀れな少年猪之さんは寒夜の火事と、重い葛籠が災いして死んでしまった。",
              "citation": {
                "source": "テンコツさん一家",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本で、足利時代に作られた「鉢の木」という最も通俗な能の舞は、貧困な武士がある寒夜に炉に焚く薪がないので、旅僧を歓待するために、だいじに育てた鉢の木を切るという話に基づいて書いたものである。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから言文一致とやらも、ちよい／＼やらかしてみるが、こいつなか／＼便利ぢや）そこで、寒夜ならずとも、鍋を叩いて、大に文字禪を提げ、天晴一小手進上申し度候ところ、どう考へても、筆ボラは舌ボラの妙には不如、儉約して葉書に相場を卸し申し候。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから寒夜頸筋の寒きに惱む。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "（中略）至今風雨陰寒夜。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
