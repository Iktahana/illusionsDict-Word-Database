  {
    "uuid": "1dc0142c-6f53-534b-80e7-d40d8a63f72f",
    "entry": "頭",
    "reading": {
      "primary": "かぶし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
