        "examples": {
          "standard": [
            {
              "text": "エジプトのピラミッドの石灰岩には、多くの貨幣石の化石が含まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地層から発見された貨幣石は、数千万年前の海洋環境を示している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "顕微鏡で見ると、貨幣石の内部構造は非常に複雑で美しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、この変わった形の石は何だろうと思って、貨幣石の図鑑を眺めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地質学者は、貨幣石の分布から古代の海の広がりを推測する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
