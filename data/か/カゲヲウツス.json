[
  {
    "uuid": "e7967c52-1795-59ea-9ae4-af30892e0f69",
    "entry": "影を映す",
    "reading": {
      "primary": "かげをうつす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
