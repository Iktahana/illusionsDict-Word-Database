        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "母が亡くなる前に、「家訓を忘れるな」と私に言い聞かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "私たちの家には、「正直であれ」という家訓がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祖父は、家訓に書かれた言葉を毎朝音読していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この家訓は、何代にもわたって我が家を支えてきた教えだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "代々の家訓で、生き物を殺さないことになっているので、大きい家に一匹の猫をも飼わなかった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち富足り、家栄え、家訓行われ、敬神の念｜盛なりというべき有様であったのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "金石を歴史の考證に應用することは前からあり、秦權を以て史記の中の文字の誤を考證したことが顏氏家訓に見えてゐる。",
              "citation": {
                "source": "支那史學史概要",
                "author": "――史記より清初まで――",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ『顏氏家訓』や『南史』『北史』等を材料として當時の南北の風尚を比較すると、南方では茗を飮み魚を食つたが、北方では酪を飮み肉をくらつた。",
              "citation": {
                "source": "晉室の南渡と南方の開發",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "梁時代の王僧辯の如きは、當代の名臣であつたが、年四十を踰え、官將軍に至つても、猶ほその母魏氏の機嫌を損じた時は、從順にその笞を受けた（北齊の顏之推『顏氏家訓』教子）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "族譜は家訓・家範・家禮・家約等の内容をもつて居りまして、先づ同じ祖先から出た所の系圖を書いて居ります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "物堅い儒家に生れた彼は、容儀は堂々たるべく正々たるべしとの家訓は受けておりましても、容貌が美しいとかあでやかであるとか、すべてそうしたことは人の口からも聴かなければ、我が身で悟ったこともなかったのであります。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗を造り、旗を樹て、又其持ち出す際の斎戒謹慎の有様や、又其｜蝉口には、必、神符を封じ籠める（軍用記）故実も、少弐氏の旗の横上に、綾藺笠をつけたのは、眷属の御霊の影向あつて、蝉口に御座あるからとの家訓がある（梅松論）といふのも、支那風模倣とは言はれぬ程、古い種を有して居るではないか。",
              "citation": {
                "source": "幣束から旗さし物へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは顏之推といふ人の顏氏家訓といふ書に見えて居ります。",
              "citation": {
                "source": "近代支那の文化生活",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお安藤君は、顔氏家訓などに傀儡子を俗に「郭禿」とあるから、その支那音の転訛からだとの仮定説も立ちうるが、それは取らないと言っておられる。",
              "citation": {
                "source": "くぐつ名義考",
                "author": "古代社会組織の研究",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大伴佐伯の祖先以来の家訓に、海行かば水漬く屍、山行かば草生す屍、大君の辺にこそ死なめ、のどには死なじ。",
              "citation": {
                "source": "本州における蝦夷の末路",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや時代の下るもののうち注目すべきは、『多胡辰敬家訓』である。",
              "citation": {
                "source": "埋もれた日本",
                "author": "――キリシタン渡来文化前後における日本の思想的情況――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『辰敬家訓』として述べるものも、実はこの父の教訓にほかならない。",
              "citation": {
                "source": "埋もれた日本",
                "author": "――キリシタン渡来文化前後における日本の思想的情況――",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがってこの家訓は、学問と道理とに対する関心のもとに、主として学問の心得を説いたものだといってよいのである。",
              "citation": {
                "source": "埋もれた日本",
                "author": "――キリシタン渡来文化前後における日本の思想的情況――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、『辰敬家訓』の一層顕著な特徴は、「算用」という概念を用いて合理的な思惟を勧めている点である。",
              "citation": {
                "source": "埋もれた日本",
                "author": "――キリシタン渡来文化前後における日本の思想的情況――",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上の三つの家訓書は、目ぼしい戦国武士がみずから書いたものである。",
              "citation": {
                "source": "埋もれた日本",
                "author": "――キリシタン渡来文化前後における日本の思想的情況――",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に多胡辰敬の家訓のなかから、おのれを卑下すればわが身の罰が当たるという言葉を引いたが、この心持ちはこの書では非常に強く説かれている。",
              "citation": {
                "source": "埋もれた日本",
                "author": "――キリシタン渡来文化前後における日本の思想的情況――",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛利家には、元就の家訓があった。",
              "citation": {
                "source": "茶漬三略",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "城を築く時、土台石に、その家訓を刻ませた。",
              "citation": {
                "source": "茶漬三略",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは毛利家の家訓を思い出して、その力だと頷いた。",
              "citation": {
                "source": "茶漬三略",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛利は強国といっても元就以来の家訓を守って、自己の領有を固守するものに過ぎず、その志は天下万民にない。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人なら何でもできる」「なら、どうして一緒に暮らして組まないの」「俺の家訓は自分以外誰も信用するなだ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻野家には古くから、初めに女子が生れたらそれを男としてそだてるという家訓のようなものがあった。",
              "citation": {
                "source": "菊千代抄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ階級同士で結婚するのがダッシュウッド家の家訓なのです。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "家訓を知る前に会っていればよかった。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "究極の手札を持ち、完全に勝ちゲームであり、メアリは家訓に縛られているにもかかわらず自分を好きになり始めている。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダッシュウッド家の紋章と家訓を浮き上がらせている。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "その紋章と家訓こそ、進退窮まったこの男のものであり、誤解されバツの悪い男のものだった。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "名門の家訓では認めない。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "家訓だからこんな羽目になる。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
