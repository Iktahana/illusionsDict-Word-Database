        "examples": {
          "standard": [
            {
              "text": "「この報告書は、現在のプロジェクトとは全く関係ないよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ねえ、この話はメインの話題と関係ある？」「いや、関係ないよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「彼の私生活は、彼の仕事のパフォーマンスとは全く関係ない。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あ、それ？関係ないから、心配しないで。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "――お前のする仕事とお父さんとは関係ないぞ！",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の仕事はお父さんと関係ないぞ！",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が男に対する魅力とは、全然こういう資格や能力とは関係ないのか。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、下品はそれ自身媚態と何ら関係ないことは上品と同様であるが、ただ媚態と一定の関係に置かれやすい性質をもっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "対他性上の対立は価値とは関係ない対立で、対立者は積極的と消極的とに分れた。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの言語を言語として識別させるに必要な要素としての母音や子音の差別目標となるものは、主として振動数の著しく大きい倍音、あるいは基音とはほとんど無関係ないわゆる形成音のようなものである。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとも秋に関係ない、そんな言葉まで、書かれてあるが、或いはこれも、「季節の思想」といったようなわけのものかも知れない。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学内のその、生理学教室に居って研究をされつつある……」　と真顔にお孝に打傾いて、左の手の自脈を取りつつ、「まるでこの方には関係ない。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この触感を性に関係ないと誰が言えるだろうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "州の名士はこの件に関係ないという頭があったためです。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん日本のＭＳ―ＤＯＳユーザーには、「わしには世界標準なんて関係ないもんね」との声もあるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅家の巨典である五灯会元の序に、一貫の趣旨を引いているが、それは禅家の言葉であって、孔子の言葉は禅家の言葉には関係ない。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "関係ない奴にあたっちゃいけません」「クソー、だいたい、高志がまじめな顔してるのが、クセモノだったよな」「そういうこと。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "原題はフランス語なので読めませんが、たぶん、ぜんぜん関係ないタイトルでしょう」　高志はまったく平然としている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの連中がやったかどうかは関係ない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、慶一の頭のなかで、高志のいう「コウノトリとは関係ない子どものつくり方」と、令子の顔がむすびついた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でもさ、ギター、メッチャクッチャうまいよ」「ギターのうまいへたは、関係ないだろうに」　高志はソファから立ちあがり、ステレオのところへいく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなのは、慶一と片桐にしか関係ないけど、とにかく、あいつは無神経な野郎でさ、いろいろバカやって、もう、話にならなくて――」　といいかけて、高志は奥に目をやる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすの点呼に遅れたら、このメンバーはみんな、外泊延期だ」「どうせ、雨が降ってるから、関係ないじゃん」「点呼時にじぶんの部屋にいない奴が、ひとりでもいたら、このメンバー全員、同罪だ」　そういい捨てて、芝は外に出た。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "関係ないじゃん、家族とかなんとかは」「おまえになくても、おれにはあるんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たしかに、片桐みたいには弾けないけどさ、そんな悪くもないと思うけどな」「ギターのうまいへたなんて、関係ない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへいくんだ」「そんな、だって、寮があるんだから、地球上どこだって、関係ないじゃん！",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "令子は関係ない」「じゃあ、なんで」「時間はたっぷりやるから、ゆっくりじぶんで考えればいいだろう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "クレジットはなんであれ、あれは純粋にサー・ポールの曲で、ジョンはまったく関係ない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれたちには関係ない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしたちは関係ないわ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
