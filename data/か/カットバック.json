        "examples": {
          "standard": [
            {
              "text": "景気悪化により、わが社も来期は予算のカットバックを検討している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "政府は公共事業のカットバックを断行し、財政健全化を目指す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回のカットバックで、部署の人数が大幅に減ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（半次と拍子木のカットバックよろしく、追々急速になって遂に、フラシュバックになった時）　拍子木チョンチョンチョンチョン……で幕が開いたらしい。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上のカットバック追い追い急激に物凄きスピードとなり、結局――　＝五郎蔵の家の表　バラバラと半次の一行、飛び込んで行く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（両者カットバック適当に）　＝柳島の妙見――　見張の児分「来た！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝走る馬　カットバック、若干。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "カットバック、若干。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅びた主家の家臣らが思い思いに離散して行く感傷的な終末に「荒城の月」の伴奏を入れたのは大衆向きで結構であるが、城郭や帆船のカットバックが少しくど過ぎてかえって効果をそぐ恐れがありはしないか。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆるカットバックの技巧で過去のシーンを現在に引きもどすことが随意にできるのもおもしろくないことはないが、これは言わば「フィルムの記憶」の利用であって、人間の脳の記憶の代用に過ぎない。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "単にフィルムの断片をはり合わせるだけで、一度現われたと寸分違わぬ光景を任意にいつでもカットバックしフラッシュバックすることもできる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアノの鍵盤とピアノの音とが、銅鑼のクローズアップとその音とに交互にカットバックされるところなどあったように記憶する。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "映畫のカットバックでも見さされたように、びつくりしたり恐怖を感じたりしている暇も無かつたのである。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
