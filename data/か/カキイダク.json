        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "母は、久しぶりに会った息子を強くかき抱いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供は、お気に入りのぬいぐるみを見つけて、ぎゅっとかき抱いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「おかえり！」と、彼女は友人を抱きしめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "心配でたまらない様子で、犬をかき抱いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「さあ、かわいいお坊っちゃん、お拭きしましょかなも」「いやだ」という裸のを、きゅっとかき抱くようにする。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランシスの眼は落着いた愛に満ち満ちてクララの眼をかき抱くようにした。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子をかき抱く倉地の腕の力は静かに加わって行った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（渡、後より立ち上つた袈裟を、後より手を差し伸べて、かき抱くやうにしながら、簀の子の上に出て來る）渡。",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（妻の首級をかき抱くやうにしながら）お前の菩提を弔うてやりたい！",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう感動の刹那、朝子はいつも自分の素肌の胸へわが生とともに歴史の明暗をかき抱くような激しい情緒を経験するのであった。",
              "citation": {
                "source": "広場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手で吊革につかまりながら、片手でやたらに肱を張って、金魚入れをかき抱くようにした。",
              "citation": {
                "source": "金魚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は両袖を胸もとに合せて、なにか大切な思いをかき抱くような気持でいた。",
              "citation": {
                "source": "渡舟場",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もったいない……それではかえってあなた様が……」　とお艶は軽く争ったが男の羽織が、ふわりと肩に落ちると同時にされるがままにもたれてくるのを、栄三郎はかき抱くように引きよせて、「お艶」「若殿さま」　眼と眼。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それら仕事の道具を両腕にかき抱くようです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "劬りかき抱く思いの、問いかけだったのである。",
              "citation": {
                "source": "いさましい話",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、両手で力いっぱい抱き緊める代りに、眼でかき抱く、といったような感じの、まなざしであった。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この争いより勝ち出できたれる女は、身をひるがえして燃えさかる火の中にとびこみ、燃ゆる唇をつけてその夫の屍をかき抱く。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "（c）想像は、そのこれから尋ね求めようとするものを、我々の手が容易にとどくものよりも一そう熱心に・一そう不断に・かき抱く。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう見る山はもっと素直な大きさと豊かさとをもって静かに君をかきいだくように見えた。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
