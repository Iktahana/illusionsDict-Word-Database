        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は複雑な人間関係にかかずり合うのを避けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一度、あの会社の不正にかかずり合ってしまったら、簡単に手は引けない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "なぜかいつも、ややこしい事件にかかずり合ってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "……自分はお納戸向きのお使番馬廻りの家柄……要らざる事に拘り合うまい……。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
