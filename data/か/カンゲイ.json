[
  {
    "uuid": "5149e664-b6e1-5719-9481-5c75592ba1c9",
    "entry": "歓迎",
    "reading": {
      "primary": "かんげい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
