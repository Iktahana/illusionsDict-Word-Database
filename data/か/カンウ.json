  {
    "uuid": "71898801-d78c-5e88-85a7-4976b11bca7c",
    "entry": "寒雨",
    "reading": {
      "primary": "かんう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cold winter rain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝から晩まで降り続く寒雨が、街を灰色に染めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "窓の外で、寒雨がしとしとと音を立てて降っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "山道を歩いていると、やがて寒雨が身にしみるほどになってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "コートの襟を立てて、冷たい寒雨の中を急いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この様に明軍も奮戦したけれどもやがて寒雨到り行動は益々敏活を欠くのに対して、日本軍は左右の高地から十字火を浴せたのでついに支うべくもなくなった。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕、家人余がために赤飯をたいてくれる秋風就縛度荒川　　秋風縛に就いて荒川を度りしは、寒雨蕭々五載前　　寒雨蕭々たりし五載の前なり。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏘々然として、床に落ちる黄白の音が、にわかに、廟外の寒雨の声を圧して、起った。",
              "citation": {
                "source": "仙人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩間寒雨瀟瀟として落葉に滴る。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之一大正六年丁巳九月起筆",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜深更より寒雨凍りて雪となる。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒雨夜に入りて纔に歇む。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒雨霏身にしみ／″＼と感ぜらるゝ所あり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその時、彼等と前後して寒雨泥濘を冒して和泉橋へ行つたのであつた。",
              "citation": {
                "source": "雨",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、若松屋に頼むことはない」　　　　寒雨　　　　　　一　自分を忘れたお高だ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒雨降りそゝげる中の枝垂梅冬｜麗ら花は無けれど枝垂梅十二月二十四日　鎌倉俳句会。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪い虫のつかんうちにお祖父やんのこれと見込んだ男と結婚しなはれ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪い虫のつかんうちに、お祖父やんのこれと見込んだ男と結婚しなはれ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはいかんうっかりしていて、また探偵小説論を書いていた。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その返事もまだ聴かんうちから、よその家へ黙って入ってきやして、警察へ訴えて出たら、あんたはん罪人やおへんか。",
