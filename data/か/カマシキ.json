        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "熱いお鍋を置くために、可愛いデザインの釜敷を買った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この南部鉄器の釜敷は、重厚感があってテーブルのアクセントになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "うっかり釜敷を使い忘れて、テーブルに焦げ跡をつけてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このティーポットには、竹製の釜敷がよく似合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "どういう訳で、かく家庭問題が八釜敷なって来たのであろうか。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此復読をすることは小学校へ往くようになってからも相替らず八釜敷いうて遣らされました。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "考へた結果、まあ年長だけに女房が分別して、「多分釜敷の事だらう、丁度新らしいのがあるから持つておいでよ。",
              "citation": {
                "source": "廓そだち",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然うすると、きいちやん曰、「釜敷？",
              "citation": {
                "source": "廓そだち",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "因で、その娘が、恭しくお盆に載せて、その釜敷を持つて出る。",
              "citation": {
                "source": "廓そだち",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が其頃内閣が変つて、著書の検閲が急に八釜敷くなつたので、書肆は万一を慮つて、直接に警保局長の意見を確めに行つた。",
              "citation": {
                "source": "『煤煙』の序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに親父が八釜敷い、論語とか孟子とか云ふものでなくつては読ませなかつた。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お品はおつぎを平常から八釜敷して居たので餘所の子よりも割合に動けると思つて居るけれど、與吉と巫山戯たりして居るのを見るとまだ子供だといふことが念頭に浮ぶ。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯た雀枝を採ることは何處の林でも持主が八釜敷いはなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも餘りに人の口が八釜敷ので主人は只幾分でも將來の警めをしようと思つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは八釜敷勘次に使はれて晝の間は寸暇もなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは卯平を勦るには幾ら勘次が八釜敷ても一々｜斷りをいうては出なかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は八釜敷い爺さんの躾を受けて幼少の時分から農作に我が趣味の全部を奪はれて居たのであります。",
              "citation": {
                "source": "白瓜と青瓜",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "此店だつてね隨分やつて行けるんですが、身持が修らねえで――尤も此頃はお上で八釜敷から打つこたあ止めたやうですが、前々からサガリもそつちこつちあつて居憎いも居憎いんでせうしね、それにおんなじものなら口の利ける者の方がいゝに極つてますからね。",
              "citation": {
                "source": "おふさ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも今は親方と往復はあるのかい」「なに時々來ますがね、八釜敷ことばかりいつて仕樣がねえんでさ、とつくからもう喧譁するやうなことはありませんがね。",
              "citation": {
                "source": "おふさ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜番の鳴子が遠くから聞こえてやがて横町へはひつたと見えてがらり／＼と急に大きな八釜敷い響を立てた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "『みなかみ』が出ると世間で例の破調問題が八釜敷くなり、短唱だの何だのといふものが行はるゝ樣になつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "野蒜の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『其細目といふ矢釜敷お爺さんに、代用教員は教壇以外にて一切生徒に教ふべからず、といふ事か、さもなくんば、學校以外で生徒を教へる事の細目とかいふものが、ありますか。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『其細目といふ矢釜敷お爺さんに、代用教員は教壇以外にて一切生徒に教ふべからず、といふ事か、さもなくんば、学校以外で生徒を教へる事の細目とかいふものが、ありますか。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「相手は東京帝国大学々生だよ」「いくら学生だつて、君の様に金に掛けると呑気なのが多いだらう」「なに善意に払はないのは、文芸協会の方でも八釜敷は云はない筈だ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに政府の當局者で勿論均しく進歩的の傾向があつても支那の學問が根底となつて居る連中はこの風潮に對して危懼の念を抱き一方には種々の改革をして新政を布くと同時に國粹保存と云ふことを、矢釜敷言出した。",
              "citation": {
                "source": "支那近世の國粹主義",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝる反對論が矢釜敷かつたから、折角出來た新刑法も再び修正を加ふることゝなり、遂に宣統元年正月を以て「惟是刑法之源。",
              "citation": {
                "source": "支那近世の國粹主義",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "近來支那の學者間に此書を矢釜敷云ふ樣になつたのもこれからである。",
              "citation": {
                "source": "日本國見在書目録に就いて",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今日まで徳島港が駄目であると云ふことを聞かなかつた』　増田は運送業者である為めに、特別に浚渫問題に八釜敷いのである。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞記者連は何か八釜敷く笑ひ合つて居る。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "議場には三十八人しか出席が無いが、まるで何処かのクラブへ行つた様に八釜敷い。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり栄一の教室が八釜敷しいので、隣の四年の教室を受持つて居る師範出身の沢村と云ふ男が覗きにくる。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "教室は毎日八釜敷かつた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵式体操と修身だけは八釜敷かつた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し彼は今は外部の形式や教条を八釜敷く云つて居れなかつた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
