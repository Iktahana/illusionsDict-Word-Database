        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ゴルフ場では、キャディが選手のかばん持ちとしてコースを共に回る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "撮影現場では、アシスタントがかばん持ちをして、機材や小道具を運んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "荷物が多いから、誰か私のかばん持ちをしてくれないかなと、思わず呟いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "コンサート会場で、ファンがスターのかばん持ちに羨望の眼差しを送っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
