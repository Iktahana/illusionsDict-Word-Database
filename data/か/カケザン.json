        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "小学校ではまず、九九の掛け算から習います。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この割引率だと、元の値段の70%の掛け算で計算できますね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "簡単な掛け算なら頭の中でできますが、複雑になると電卓を使います。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ほら、この掛け算を解いてごらん」と先生は子供に問題を渡した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "また、わたしは自分が気が違っていないということをしっかりと頭に入れようと思って、出来るだけ早く掛け算の表をさえくりかえしてみた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "）さあ、こうなって来ると、わたしは現在と過去との区別がつきかねたので、また少なくとも自分は気が狂っていないということをたしかめるために、路ばたの石の欄干の上に両手を置いて、掛け算の表をくりかえさなければならなかった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "７８４５６２−　８７１８３―――――――　６９７３７９　次は掛け算の場合である。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛け算だからといつて別にやり方が根本的にちがふわけではないが、一つの方針をごらんにいれておきたいと思ふ。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "加へ算、引き算、掛け算、割り算と全部揃つてゐます。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛け算だからといって別にやり方が根本的にちがうわけではないが、一つの方針をごらんにいれておきたいと思う。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "加え算、引き算、掛け算、割り算と全部揃っています。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "足し引きに加え、掛け算や割り算の機能を備えた計算機作りに取り組んでいたウォズニアックを見て、マッカラムは軍用の電子装置を作っていた会社のコンピューター室で勉強できるように、手はずを整えてくれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "数学では小学校の全課程中一度だって頭をひねるほどの問題にぶッつかった覚えがないくらいよく出来て、十一、二の時には四ケタと四ケタの掛け算を頭の中で計算し得たくらいだ。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "数学掛け算はしちめんどう、割り算は因業、比例は人なかせ、応用問題気がちがう。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生の営みは、すべて足し算と掛け算で行きたいものです。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "つつましく、謙遜に犬馬の労をとるというのが、甲野さんの処世方針で、それを甲野さんは「足し算と掛け算」の人生と呼んでいたのです。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに、引き算や割り算をやらないで、足し算と掛け算で行くことですよ。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲野さんの人生の理想は、むろん足し算よりも掛け算の方でした。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "足し算では二と三とでは五にしかなりませんが、掛け算では六になるからであることはいうまでもありません。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが掛け算の人生になると、甲の人の力は乙の人の中に、乙の人の力は甲の人の中に溶けこんで、おたがいに力を強めあうのです。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり自分を忘れ、他を生かそうとするところに、二と三が五にならないで六になる、掛け算の秘密があるのです。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれには、お互いに自分を忘れて他を生かす、掛け算の人生を送ることが大切です。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ところで、甲野さんは、掛け算の人生を礼讃するにあたって、その掛け算に作用する二つのおそろしい力があることを忘れてはいませんでした。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「掛け算の人生において一に相当するのは孤立主義者です。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで甲野さんは、掛け算の人生においては、誰もが少くとも二以上の力をもたなければならないということを、しきりに主張しました。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この言葉でわかりますように、甲野さんの掛け算の人生というのは、つまるところ愛の人生なのです。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「掛け算の人生は、人と人との間に生かされるだけでなく、人と物との間にも生かされなければなりません。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そういう方でも、たいていは足し算程度で、まだ掛け算にはなっていないように私には思われます。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛が足りないから、足し算までは出来ても、掛け算が出来ないのです。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛け算の人生が、人と人の間だけでなく、物と人との間にも生かされなければならない――という理由は、ここにあるのです。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲野さんがこの世を去ってすでに十数年になりますが、私は、甲野さんとその小さなそろばんとの間に結ばれた掛け算生活の功徳を、今更のように思い出さずにはいられません。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "森鴎外氏の『水沫集』に至っては、一厘にも満たない僅か八毛であることを、割り算や掛け算の式によって見せてくれている。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "主のおいのりをしようと思っても、あたまにうかんでくるのは、かけざんの九九ばかりでした。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえは、まだ小さかったからおぼえてもいまいが、お父上はな、さむらいの子が金かんじょうなどならうものじゃないといって、わたしがかよっていた手ならいの先生が、かけざんの九九をおしえたら、そんな先生のところへ子どもをあずけられないといって、おこられたことがあるくらいだ。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
