    "definitions": [
      {
        "index": 1,
        "gloss": "desolate field",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "厳しい冬将軍の到来とともに、先月まで青々としていた草原は一晩で茶褐色の枯れ野へと姿を変えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わあ、見渡す限りの枯れ野の中に一筋の砂利道が続いていて、なんだか古い映画のワンシーンみたいだね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "松尾芭蕉が最期に詠んだという、夢が枯れ野を駆け巡る句を思い浮かべながら、寂寥感の漂う夕暮れの道を歩く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "水瀦に映る雲の色は心｜失せし人の顔の色のごとく、これに映るわが顔は亡友の棺を枯れ野に送る人のごとし。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉の辞世と称せられる「夢は枯れ野をかけ回る」という言葉が私にはなんとなくここに述べた理論の光のもとにまた特別な意味をもって響いて来るのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "途次、彼の世に聞えた鬼門關を過ぎようとして、不案内の道に踏迷つて、漸と辿着いたのが此の古廟で、べろんと額の禿げた大王が、正面に口を赫と開けてござる、うら枯れ野に唯一つ、閻魔堂の心細さ。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其三　頃は十月の末、ところは荒凉たる境なれば、見渡す限りの景色いともの淋しく、冬枯れ野辺を吹きすさむ風｜蕭と聳えし彼峯ならめ、さては此あたりにこそ御墓はあるべけれと、ひそかに心を配る折しも、見る／＼千仭の谷底より霧漠し初め、空やゝ暗くなりしばかりなり。",
              "citation": {
                "source": "二日物語",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "船頭歌　春は世に出る、草木もあるに、わたしゃ枯れ野のきりぎりす。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども彼の恩人に対する絶望の帰依心というものは、いまも歴史の枯れ野原のなかで、懐かしくかんばしい。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、そこで、四五日まをおいて見ると、なにかしら足りないものがある、――人影のない枯れ野、というのが彼の覘いで、動くものは野茨の枝の鶫一羽だけであった。",
              "citation": {
                "source": "扇野",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若きもの、清を学ばば潔きを得て命長し、霊魂も肉体も命長し」　更にそのあとへ一首　――老いの身の、腕を扼せば骨高く、声も枯れ野のすごきありさま。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼朝の兵は、枯れ野の火のように、武蔵を焼き、常陸へ入る。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちらと、近くで見たところでは、それは、河原や枯れ野などによく寝ている物乞いか、菰僧の類であるらしかった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ来いっ、官軍っ」　露八は、血槍を持って、魔か、狂人のように、枯れ野を跳躍して走った。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら燃え拡がっても、京都中は焼けッこない」　枯れ野の一端に放けた火は、音を立てて、四十人以上もいる人々の顔を焦した。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……花のお江戸も、私にとっちゃ、枯れ野の芒しか見えやしない。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう町に近い枯れ野だった。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんの因果でと、嘆きの声は枯れ野や冬山に充ち充ちても、血まなこな武者ばらには、何と無用な生き物の多さよと、かえりみられもしないのか。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十米レエスならば、まず今世紀、かれの記録を破るものはあるまい、とファン囁き、選手自身もひそかにそれを許していた、かの俊敏はやぶさの如き太宰治とやらいう若い作家の、これが再生の姿であろうか。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか新聞で、かれの自戦記を読んだが、あの文章は、忘れがたい。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれが、ひとりの門弟と論爭して、お膳のかながしらの頭をがりがり噛んで食べた、ことなど、かれの人となりを知るに最もよきエピソオドであらう。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの生前、二三の人が、それを知つて居るのみであつた。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その部屋は、かれの晝寢の部屋であつた。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世人はこれを、雀大臣と呼んで、この出世も、かれの徃年の雀に對する愛情の結實であるといふ工合ひに取沙汰したが、しかし、お爺さんは、そのやうなお世辭を聞く度毎に、幽かに苦笑して、「いや、女房のおかげです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛をもとめる心は、かなしい孤独の長い長いつかれの後にきたる、それはなつかしい、おほきな海のやうな感情である。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには青白い顔をした病身のかれの子供が立つて居た。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの心も姿もあまりに変り果てた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの静かな心にうつつてくるのは、かれの病みつかれた顔や手足にまつはる悩ましい蜘蛛の巣である。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その幻覚はかれの魂を慰める。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの祈祷は詩の形式であり懺悔の器でもあつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの詩は子供がははおやの白い大きい胸にすがるやうにすなほな極めて懐しいものも其疾患の絶え間絶え間に物語られた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時は、彼はいつも身のまはりから離したことのない、下僕や、小間使や、犬などを殘らず引きつれて、階上へ昇り、そして家扶が先に立つて、今は亡きかれの母の逝去の部屋の中へはひり込まなければ承知しなかつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの声も少しふるえていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
