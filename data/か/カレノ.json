[
  {
    "uuid": "de7fbbec-6375-5ca1-9406-edae6c7f3f47",
    "entry": "枯れ野",
    "reading": {
      "primary": "かれの",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
