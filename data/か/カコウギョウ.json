        "examples": {
          "standard": [
            {
              "text": "地域経済を支える主要産業の一つが、農産物を扱う加工業だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "加工業の工場では、多くの地元住民が雇用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国は、食品加工業の海外展開を支援する政策を打ち出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔ながらの加工業者は、手作りの味を守り続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "出版企業は、作家を原料加工業、読者を市場としてみるにすぎない。",
              "citation": {
                "source": "ある回想から",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁港都市の人口は加工業の労働で主として支えられているのだから、イワシがとれないと市全体が参るのだね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの人口が加工業でうるおッているわけですよ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            }
