        "examples": {
          "standard": [
            {
              "text": "森の奥深くで、珍しいかぐや蝙蝠が発見されたとニュースで報じられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「えっ、あれがかぐや蝙蝠なの？思ったより小さいんだね」と子供が双眼鏡を覗きながら言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "かぐや蝙蝠の生態を研究するために、調査チームが現地へ派遣された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夜の帳が下りる頃、かぐや蝙蝠が餌を求めて飛び立つ姿が見られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
