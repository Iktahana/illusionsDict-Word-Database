        "examples": {
          "standard": [
            {
              "text": "近松門左衛門の心中物には、当時の情緒豊かな上方語が散りばめられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "江戸の武家言葉と違い、上方語はやんわりとした響きを持っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「昔の上方語って、響きがすごく優雅で素敵じゃない？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古典落語の演目によっては、上方語を完璧にこなす技量が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "染色の問答に続いて、三馬はこの二人の女に江戸語と上方語との巧みな使い別けをさせている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず「すつぽん」と「まる」、「から」と「さかい」などのような、江戸語と上方語との相違について口論をさせている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」と「粋」との相違は、同一内容に対する江戸語と上方語との相違であるらしい。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "笹村は奥まった二階の座敷で、燭台の灯影のゆらぐ下で、二、三杯の酒に酔いの出た顔を焦らせながら、たまには上方語のまじる女たちの話に耳を傾けた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「浮世風呂」でなくても、上方語と江戸語とを対照させて考へた人の頭に、すぐ浮んだえどつこのからと上方のさかいとは、語の根幹から言へば、非常に近かつたのもおもしろい。",
              "citation": {
                "source": "「さうや　さかいに」",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治盛期、上方語が一つの方言としての自覚を持ち出した頃の選択が、かう言ふ所から現れた。",
              "citation": {
                "source": "「さうや　さかいに」",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
