        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この道路は現在、工事のため片側しか通れないんだ。迂回路を探さないと。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "テーブルの片側だけ、ピカピカに磨かれてる。誰か掃除してくれたのかな？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼はいつも、自分の机の片側だけをきれいに整頓しているんだ。不思議だよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この山道は道幅が狭いから、片側が崖になっている場所では、特に慎重に歩かないと危ないよ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "街の片側は翳り、片側は日射しをうけて、あつたかいけざやかにもわびしい秋の午前です。",
              "citation": {
                "source": "死別の翌日",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来の片側の店にはみんな夕陽が射し込んでゐる。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "片町に更紗染めるや春の風　町の片側に紺屋があって、店先の往来で現に更紗を染めているという句であるが、印象としては、既に染めた更紗を、乾燥のために往来へ張り出していると解すべきであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側の大名邸の高い土堤の上に茂り重なる萩青芒の上から、芭蕉の広葉が大わらわに道へ差し出て、街燈の下まで垂れ下がり、風の夜は大きな黒い影が道一杯にゆれる。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸袋のすぐ横に、便所の窓の磨硝子から朧な光のさすのに眼をうつすと、痩せたやもりが一疋、雨に迷う蚊を吸うとてか、窓の片側に黒いくの字を画いていた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同座敷の片側へ一列にならんで順々拝が始まる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "客車の中は白塗りのがらんどうで、ただ片側の壁に幅の狭い棚のような腰掛があるだけである。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その線路の右端の下方、すなわち紙の右下隅に鶯横町の彎曲した道があって、その片側にいびつな長方形のかいてあるのがすなわち子規庵の所在を示すらしい。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レールの片側には、真ッ黒に火で焦がされた、太い木杭が立ち並んでゐて、レールを慰めてゐるやうなのでありました。",
              "citation": {
                "source": "夜汽車の食堂",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸壁が海の方へせり出して、その内側が陥没したので、そこに建て連ねた大倉庫の片側の柱が脚元を払われて傾いてしまっている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨牌のような札の片側には「自」反対の側には「他」と書いてある。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "追分の通りの片側を田舎へ避難する人が引切りなしに通った。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は河鹿の鳴く渓流に沿った町の入口の片側町を、この老婦人も共に二三人と自動車で乗り上げて行った。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側は墨で片側は朱で書いてあるのを、出勤したときは黒字の方を出し、帰るときは裏返して朱字の方を出しておくのである。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　ある家の告別式に参列して親類の列に伍して棺の片側に居並んでいた。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの予言はどうなるか分らないが、ともかくも今まで片側だけしか見る事の出来なかった世界は、これを掌上に置いて意のままに任意の側から観る事が出来るようになった。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十　四、五月頃に新宿駅前から帝都座前までの片側の歩道にヨーヨーを売る老若男女の臨時商人が約二十人居た。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には、養子に行く前に深く言いかわした女があった、いよいよ養子に行くときまるや五円で帯の片側を買って、それを手切れ同様に泣く泣く別れた。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "人がその理由を尋ねたら「せめて片側だけでも自由がほしい」と答えたそうである。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側は滑かであるが、裏側はずいぶんざらざらして荒筵のような縞目が目立って見える。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは豪雨のときに氾濫する虞れの多い溪の水からこの温泉を守る防壁で、片側はその壁、片側は崖の壁で、その上に人々が衣服を脱いだり一服したりする三十畳敷くらいの木造建築がとりつけてあった。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "席を片側へ十五ぐらゐ一杯に劃つた、たゞ両側に成つて居て、居ながらだと楽々と肘が掛けられる。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてただ現象の片側に過ぎない流体だけの運動をいくら論じてみても完全な解釈がつきそうにも思われない。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の片側へ机を並べて、皆一同の贈物が陳列してありました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りの片側には八百屋物を載せた小車が並んでいます。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋の中の片側には数日分の薪材に付近の灌木林から伐り集めた小枝大枝が小ぎれいに切りそろえ積みそろえられていかにも落ち着いた家庭的な気持ちを感じさせる。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "月が家並の後ろの高い樫の梢まで昇ると、向う片側の家根が白ろんできた。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しんたのむねを下りたところに、かたがわには椿の木がありました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらっておいて、罪を隠すためにそのかたがわたくしをおどしつけ、このようなにせの書き置きを書かせたのでござります」「だれだ、あの矢で殺された若侍か」「いいえ、あのかたこそ、ほんとうにおかわいそうでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "卿の戀の盟約は内容の無い空誓文、なりゃこそ養育まうと誓うた戀をも殺してのけうと爲やるのぢゃ、卿の分別は姿や戀の飾ぢゃが、本體が善うないので不具となり、愚な卒が藥筐の火藥のやうに、扱ひかたがわるいので爆發し、我れと我が武器で身を滅す。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
