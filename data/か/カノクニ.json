[
  {
    "uuid": "1eb9dc53-68f8-53a4-b6fa-65e1cdd0318f",
    "entry": "かの国",
    "reading": {
      "primary": "かのくに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
