    },
    "definitions": [
      {
        "index": 1,
        "gloss": "that country",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は旅行で訪れたかの国の話をするのが大好きだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ニュースでは、かの国の政治情勢について報道されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「かの国は景色が綺麗だと聞いたよ」と彼女は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「誅戮」「討伐」「征伐」「征討」などと、武張ったどこかの国のジャーナリストなら書きたい所であろう。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来アメリカにジャズ音曲とナンセンス映画とが流行する事実は、かの国に古い意味での哲学と科学と芸術の振るわない事実の半面であって、そのかわりに黄金哲学と鉄コンクリート科学と摩天楼犯罪芸術の発達するゆえんであろう。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反してドイツに古い意味での哲学科学の発達したのは畢竟かの国民の「頭の悪い」ため、容易に要領を得ないため、万事オーケーイ式でないためであろう。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際鶏卵や牛乳や靴の欠乏は聞くも気の毒な状態であるらしいが、ただ驚くのはかの国の科学者、特にペンと紙のほかには物質的材料を要しない種類の科学者が依然としてきわめて重要な研究の結果を着々発表している事である。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィーゼ氏の話によると数年来かの国の気象学者たちは、気圧その他の気象学的要素の配置から夏期における北氷洋上の氷の分布状況を予報することを研究し、それがだいぶうまく的中するようになった。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの国の有名な画廊にある名画の複製や、アラビアンナイトとデカメロンの豪華版や、愛書家の涎を流しそうな、芸術のための芸術と思われる書物が並んでいて、これにはちょっと意外な感じもした。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ年少の夢よ、かの蒼空はこの夢の国ならずや、二郎も貴嬢もこのわれもみなかの国の民なるべきか、何ぞその色の遠くして幽かに、恋うるがごとく慕うがごとくはたまどろむごとくさむるがごときや。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの国の「語りもの」に似ているといわれる義太夫も、おそらく他のヨーロッパ人に比べては、いくらかよりよくロシア人に理解される可能性がありはしないか。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、また、僧都の言われるには、白衣に緋の襲した女子を馬に乗せて、黒髪を槍尖で縫ったのは、かの国で引廻しとか称えた罪人の姿に似ている、私の手許に迎入るるものを、不祥じゃ、忌わしいと言うのです。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "清らかな衣を着、新に梳って、花に露の点滴る装して、馬に騎した姿は、かの国の花野の丈を、錦の山の懐に抽く……歩行より、車より、駕籠に乗ったより、一層｜鮮麗なものだと思う。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば私が、印度かどこかの国から、突然、鷲にさらはれ、すとんと日本の沼津あたりの海岸に落されて、ふと、この山を見つけても、そんなに驚嘆しないだらう。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ君がヘルメットにステッキで、硬直しきりの、後ろからどっかの国の侍従武官兼警視総監というところだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはきっと、どこかの国の王子さまだろうと思っていました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもし、北の国が気にいらなかったら、どこかほかの国へいってみたいとおもっていました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "外人より見れば、かの国公園内の雪隠か動物園内の水茶屋ほどの※爾たる軽き建築ゆえ、わざわざこんな物を見に来るより、自国におりて広重や北斎のむかしの神社の浮世絵を集むるがましと長大息して、去りて再び来たらず。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂人だつてどこかの国の人間だから、どんなに切れ切れにどなつても、声が詞にはなつてゐる。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "スパニッシュ・メイン（15）の海賊がこの種の秘密を書くとすればたいていそのどちらかの国語だろうからね。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂人だってどこかの国の人間だし、その言葉は、たとえ一語一語がどんなに切れ切れでも、音節はいつもちゃんとくっついているはずだよ。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この酒場の名前は、何処かの国の言葉で、細君がブツ／＼言ふといふやうな意味なんだつて――」「まあ、変な名前だわね――あたしも、少しブツ／＼云ふやうなことに出遇つて見たいわ。",
              "citation": {
                "source": "川蒸気は昔のまゝ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　おお風が凪いだ、あの怖ろしい雄叫びは綺麗に何処かの国へ逝つてしまつて、清新な朝陽がうらうらと私の頬を撫でた。",
              "citation": {
                "source": "「学生警鐘」と風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルクスに依ると、風力が誰に属すべきであるか、という問題が、昔どこかの国で、学者たちに依って真面目に論議されたそうだ。",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧き宗教を維持せんとするの結果、フランス国が失いし多くのもののなかに、かの国にとり最大の損失と称すべきものはユグノー党の外国脱出でありました。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの国のある学者が、クラークが植物学について口を利くなどとは不思議だ、といって笑っておりました。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "因ってかの国にも、古来蛇、蜥蜴などを誇張して、竜の属の想像動物を拵えあったと知った。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの国人で、只今大英博物館人類学部長たるリード男の直話だった。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃わが邦へ渡ったかの国人が、奥羽地方で合歓木をかかる難地へ植えて砂防を完成すると聞き、帰国の上官へ告げて試むると果して竣功したという。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつてアイルランド人に聞いたは、かの国で最も強く臭う烟草の烟を、驢の鼻へ吹き込むと、眼を細うし気が遠くなった顔付して、静まりおり、極めて好物らしいと。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでにひらけしほかのくにの、いつはりてなすところの別離の情よりは、よく心にてつしてかなしかりき。",
              "citation": {
                "source": "南嶋を思いて",
                "author": "――伊波文学士の『古琉球』に及ぶ――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
