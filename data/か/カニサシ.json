    "definitions": [
      {
        "index": 1,
        "gloss": "crab sashimi",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "分け合うために、新鮮なカニ刺しの盛り合わせを注文した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "カニ刺しの繊細な甘みは、シンプルに味わうのが一番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "カニ刺しは生で食べても安全なの？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "わーい、カニ刺しだ！私の大好物！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "『錨健次は、もとの指揮者江戸昌の命令で団員の誰かに刺し殺されたのだ。",
              "citation": {
                "source": "獏鸚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "道也の言葉を聞いた妻君は、火箸を灰のなかに刺したまま、「今でも、そんな御金が這入る見込があるんですか」と不思議そうに尋ねた。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子越しの燈が竹藪にほのかにさして居る。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二間三間、段々に次第に奧へ深く成ると……燈火の白き影ほのかにさして、目の前へ、颯と紅の簾が靡く、花の霞に入る心地。",
              "citation": {
                "source": "麥搗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月は今は真上から静かにさしかけていた。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "細い頸をゆるやかにさしのべて、土の香を嗅いだりしてゐるのも可愛かつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、広小路で、電車の口から颯と打った網の末が一度、混雑の波に消えて、やがて、向のかわった仲見世へ、手元を細くすらすらと手繰寄せられた体に、前刻の女が、肩を落して、雪かと思う襟脚細く、紺蛇目傘を、姿の柳に引掛けて、艶やかにさしながら、駒下駄を軽く、褄をはらはらとちと急いで来た。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家の窓は、たいそう高くて、赤いのや、青いのや、黄いろの窓ガラスだったので、お日さまの光はおもしろい色にかわって、きれいに、へやのなかにさしこみました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うの長い丘には、まだ夕日の影が微かにさし残つてはゐたけれども、冬の日脚の短かさ、それも忽ち消えてなくなつて了ふであらうと思はれた。",
              "citation": {
                "source": "船路",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "電灯の光の微かにさしわたつてゐるプラツトフオムのところには、大勢の人達が混雑して、その他にも二人づれの男女達が三組も四組もあつた。",
              "citation": {
                "source": "アカシヤの花",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日の微かにさし始めたところに、何十羽と限りなく集つて、楽しさうに白くなつて泳いでゐる。",
              "citation": {
                "source": "初冬の記事",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "不圖私は自分の眼の前にこまかにさし交はしてゐるその冬枯の木の枝のさきに妙なものゝ附いてゐるのを見つけた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "自然の息自然の聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "十　戸が軋って、雪明りがほのかにさしこんだ。",
              "citation": {
                "source": "吉良上野の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今小さい畠の彼方の栗の木には、段々と傾いて行く日足が、黄色い灯を点したやうにしづかにさしてゐる。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "早うひけいッ」　鶴の一声、とびかかった御近習の刀の下げ緒でくくしあげられた腰本治右衛門、まことあわれ千万なその姿は、おりからほのかにさしはじめた月明りの中を、一味ともども伝馬町の大牢の方へひかれて行きました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お礼でもいわっしゃい」　駕籠からふたりをつれ出すと、静かにさしつけていいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして汐の靜かにさしてくる日没後の傾斜面は沈着いた紫色の光を帶びて幽かに夕づつのかげを浮べる。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして汐の靜かにさしてくる日沒後の傾斜面は沈着いた紫色の光を帶びて幽かに夕づつのかげを浮べる。",
              "citation": {
                "source": "思ひ出",
                "author": "抒情小曲集",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして頭上遙かの空から、ほのかにさして来る星の光、それが後脳を輪取っている。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間生活への思意が複雑明瞭になって来る度につれて、さながらしずかにさしのぼる月の運行に準じてあたりの山野が美しい光に溢れて来るように、人間の美しい精神の輝きとしての責任の感情もひろく、深く、大きいものとなってゆくのである。",
              "citation": {
                "source": "女の歴史",
                "author": "――そこにある判断と責任の姿――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして花やかにさし昇った朝日に向かって手を合わせました。",
              "citation": {
                "source": "安達が原",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "広間には唯朝日の光が、うららかにさしてゐるばかりで、葦原醜男も須世理姫も、どうしたか姿が見えなかつた。",
              "citation": {
                "source": "老いたる素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "向いの山影から弓絃をはりきった如き月が鮮かにさしのぼった。",
              "citation": {
                "source": "女流俳句を味読す",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はもう食を得ることよりほかにさしあたりの目的はない。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙な」「半分はお嫁に行きたいし半分はお嫁に行っても下らないと思う人があるだろうから……」　こんな事を云って二人は何だか自分達のまぢかにさしせまって来て居る事の様なかおをして居た。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "出口の光がほのかにさし込むと、歓声は再び揚がる。",
              "citation": {
                "source": "四谷、赤坂",
                "author": "宮島資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め彼の顔は、穏かにさしてる日脚のようなもので、村尾の精神的嘔吐物を静に受け容れていたが、中途から、次第に能動的な尖端を示すようになった。",
              "citation": {
                "source": "慾",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜のことで、燈火がほのかにさしてる庭の植込から先は、ただ闇の空間だった。",
              "citation": {
                "source": "田園の幻",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂の上に立つと、彼方の門灯の明りがかすかにさしてるだけで、御影石の敷石がほんのりと白み、コンクリート造りの崖とコンクリート造りの塀との間に、陰湿な気が深く淀んでいる。",
              "citation": {
                "source": "猫捨坂",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が朗らかにさし、縁側に坐って庭を見て居ると、日の光が魂を吸い出す。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
