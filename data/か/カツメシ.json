        "examples": {
          "standard": [
            {
              "text": "「今日のランチはガッツリカツ飯にするぞ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この定食屋のカツ飯、ボリューム満点で味も最高なんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "部活帰りに友達と寄ったお店で、みんなでカツ飯を囲んだのが懐かしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「はー、疲れた。帰りに駅前のカツ飯でも食べようかな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "三時半に出て、銀座へ、エスキーモでカツ飯を食って、座へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一回終って食事、カツめし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三益愛子と二人で万才、早大学生のオーケストラで「お嫁をもらへば」「モンパゝ」と模写のストトンをやり、中学時代にカツめし食った浩養軒でカツめし食って座へ帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            }
