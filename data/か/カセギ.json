[
  {
    "uuid": "c763b81a-d9e3-595a-8cbc-35f1112536e9",
    "entry": "稼ぎ",
    "reading": {
      "primary": "かせぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
