      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one sleeve",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あれ、片袖だけまくってるよ。もしかして新しいファッションのつもり？」と友人にからかわれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "激しい稽古を繰り返した末、長年愛用していた柔道着の片袖がボロボロに引きち切れてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "左右非対称なデザインが特徴のこのドレスは、あえて片袖をなくした大胆なカッティングが美しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "コートの片袖にだけソースをこぼしてしまい、慌ててクリーニング店に駆け込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "）といって片袖を前歯で引上げ、玉のような二の腕をあからさまに背中に乗せたが、じっと見て、（まあ、）（どうかいたしておりますか。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と向うへ突いた、男の身が浮いた下へ、片袖を敷かせると、まくれた白い腕を、膝に縋って、お柳は吻と呼吸。",
              "citation": {
                "source": "木精（三尺角拾遺）",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し試用――一｜回限り……」と二｜行に最一｜度読みながら、つひ、銀の鍋を片袖で覆ふて入つた。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と心着くと、これを嫗に握られた、買物を持った右の手は、まだ左の袂の下に包んだままで、撫肩の裄をなぞえに、浴衣の筋も水に濡れたかと、ひたひたとしおれて、片袖しるく、悚然としたのがそのままである。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "些と凹凸なく瞰下さるる、かかる一枚の絵の中に、裳の端さえ、片袖さえ、美しき夫人の姿を、何処に隠すべくも見えなかった。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁を分けた艶なる片袖、浅葱の褄が船からこぼれて、その浴衣の染、その扱帯、その黒髪も、その手足も、ちぎれちぎれになったかと、砂に倒れた婦人の姿。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　その若い妓は、可愛い人形を抱くように、胸へ折った片袖で、面を蔽う姿して、「堪忍して下さいな。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……上衣無しで、座敷着の上へ黒縮緬の紋着の羽織を着て、胸へ片袖、温容に褄を取る、襲ねた裳しっとりと重そうに、不断さえ、分けて今夜は、何となく、柳を杖に支かせたい、すんなりと春の夜風に送られて、向うから来る姿。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その左右の欄干の、向って右へ、嫋娜と掛って、美しい片袖が見える。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そのまま衝と膝を掛ける、と驚いて背後へ手を支く、葛木の痩せた背に、片袖当てて裳を投げて、「そんなに姉さんが恋しいの。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛木は、人に揉まれて、脱け落ちた笠のかわりに、法衣の片袖頭巾めいて面を包んだ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩を細く、片袖をなよ／＼と胸につけた、風通しの南へ背を向けた背後姿の、腰のあたりまで仄に見える、敷居に掛けた半身で帶と髮のみ艷やかに黒い。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……美しさは其のみ成らず、片袖に手まさぐつた團扇が、恰も月を招いた如く、弱く光つて薄りと、腋明をこぼれた膚に透る。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と向うへ突いた、男の身が浮いた下へ、片袖を敷かせると、まくれた白い腕を、膝に縋つて、お柳は吻と呼吸。",
              "citation": {
                "source": "三尺角拾遺",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "パー先生は片袖まくり、布巾に薬をいつぱいひたし、かぶとの上からざぶざぶかけて、両手でそれをゆすぶると、兜はすぐにすぱりととれた。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　また奇妙に、片袖をポンと肩に掛けて、多津吉の眉の前へ、白い腕を露呈に、衝とかがみ腰に手を伸ばして、ばさりと巣を探る悪戯のように――指を伏せても埒あく処を――両手に一つずつ饅頭を、しかし活もののごとくふわりと軽く取った。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は一倍群ったが、向側が崖沿の石垣で、用水の流が急激に走るから、推されて蹈はずす憂があるので、群集は残らず井菊屋の片側に人垣を築いたため、背後の方の片袖の姿斜めな夫人の目には、山から星まじりに、祭屋台が、人の波に乗って、赤く、光って流れた。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり片袖なかったもの。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "召したる薄色の羽織の片袖｜血※を浴びて紅の雫滴る。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はらりとかけたり羽織の片袖。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小盾も見えず、姿見を傍に、追って出る坊主から庇うのに、我を忘れて、帷子の片袖を引切りざまに、玉香を包み、信女を蔽うた。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる時にも、片袖きれた不状なるよりは……とや思う、真三は、ツと諸膚に払って脱いだ。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "みどり児を、片袖で胸に抱いて、御顔を少し仰向けに、吉祥果の枝を肩に振掛け、裳をひらりと、片足を軽く挙げて、――いいぐさは拙いが、舞などしたまう状に、たとえば踊りながらでんでん太鼓で、児をおあやしのような、鬼子母神の像があった。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "客は、陽の赤蜻蛉に見愡れた瞳を、ふと、畑際の尾花に映すと、蔭の片袖が悚然とした。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見向いた時、畦の嫁菜を褄にして、その掛稲の此方に、目も遥な野原刈田を背にして間が離れて確とは見えぬが、薄藍の浅葱の襟して、髪の艶かな、色の白い女が居て、いま見合せた顔を、急に背けるや否や、たたきつけるように片袖を口に当てたが、声は高々と、澄切った空を、野に響いた。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と釣込まれたように、片袖を頬に当てて、取戻そうと差出す手から、ついと、あとじさりに離れた客は、手拭を人質のごとく、しかと取って、「気味の悪かったのは只今でしたな――この夜ふけに、しかも、ここから、唐突だろう。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かよわいその人の、一人、毛氈に端坐して、城の見ゆる町を遥に、開いた丘に、少しのぼせて、羽織を脱いで、蒔絵の重に片袖を掛けて、ほっと憩らったのを見て、少年は谷に下りた。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づきてとくと視れば、浅葱地に白く七宝｜繋ぎの洗い晒したる浴衣の片袖にぞありける。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "内儀は白糸の懐に出刃を裹みし片袖を撈り得てて、引っ掴みたるまま遁れんとするを、畳み懸けてその頭に斫り着けたり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん遣りかねますまいよ」「その晩橋場の交番の前を怪しい風体のやつが通ったので、巡査が咎めるとこそこそ遁げ出したから、こいつ胡散だと引っ捉えて見ると、着ている浴衣の片袖がない」　談ここに到りて、甲と乙とは、思わず同音に嗟きぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
