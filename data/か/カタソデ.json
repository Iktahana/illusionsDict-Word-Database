[
  {
    "uuid": "97f983a6-1e89-587d-b19e-83d751887f85",
    "entry": "片袖",
    "reading": {
      "primary": "かたそで",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
