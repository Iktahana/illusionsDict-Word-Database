    "definitions": [
      {
        "index": 1,
        "gloss": "with the skin on",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「このリンゴ、皮ごと食べたほうが栄養を余さず摂れるんだって」と言ってかじりついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新じゃがは皮ごと素揚げにして、粗塩を軽く振るだけで最高のおつまみになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お弁当の彩りに、皮ごと食べられる種無しのシャインマスカットを添えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「えー、スイカを白い皮ごと食べるの？」と、彼の独特な健康法に驚愕した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "林檎の皮ごとぼりぼり※り歩いている女学生も交じっていた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮ごと食ったというので、これも笑われた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は愈狼狽して、又｜真紅になって、何だか訳の分らぬ事を口の中で言って、周章てて頬張ると、「あら、皮ごと喰べて……皮は取った方が好いわ。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩き乍ら　青いすっぱい林檎を皮ごとたべる。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "林檎を皮ごと噛じつてゐたり、キヤラメルの紙を剥いてゐることを除けば。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "林檎を皮ごと噛じっていたり、キャラメルの紙を剥いていることを除けば。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "金井も、眞木も、そのほか十人ばかりの連中が、ことごとく正體もなくなつてきて、各々、手を振り動かし、歌ふもの、議論するもの、リンゴを皮ごと噛つてぺつぺつとはき出してゐる者……。",
              "citation": {
                "source": "雪の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "口がおそろしく大きいんでりんごを皮ごと二口で食ってしまいます。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜜柑の方はジャムの下拵のようなもので皮ごと薄く切って一晩水へ漬けてその水で沢山のお砂糖と一所に始終掻き廻しながら一時間ばかり煮詰めたのです」と一々講釈の付いた御馳走、小山も応接に疲れたり「なかなかお講釈が沢山で一度には覚え切れません。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "信子は手にしていた林檎を皮ごと一口かじつた。",
              "citation": {
                "source": "恋をしに行く（「女体」につゞく）",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、谷村は林檎を皮ごとかじる習慣をもたないのである。",
              "citation": {
                "source": "恋をしに行く（「女体」につゞく）",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮ごとかじりつく歪みと変化の美しさを信子は意識してゐるのである。",
              "citation": {
                "source": "恋をしに行く（「女体」につゞく）",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婦人　　〔Il ya de ces passions violentes qui font les grands hommes et dont je n'avais pas l'e'toffe.〕アンリエツトの声　　お祖母さま、収兄さまがね、柿を皮ごとたべますよ……。",
              "citation": {
                "source": "落葉日記（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "……夕方、奈良への帰途　海竜王寺を出ると、村で大きな柿を二つほど買って、それを皮ごと噛りながら、こんどは佐紀山らしい林のある方に向って歩き出した。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮ごと塩で長く煮込むのですから、寒中などはよく持ちます。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはまぐろの砂摺りを皮ごと分厚に切って付け焼きにするのである。",
              "citation": {
                "source": "鮪を食う話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊にわとりは皮ごとやわらかく食えるものにかぎる。",
              "citation": {
                "source": "料理メモ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　先刻叩き割ってきた椿の実を、皮ごと土瓶に投り込んで、竈の上の自在鈎に掛け、上から水をじゃあと注ぎ込んだ。",
              "citation": {
                "source": "特殊部落の犯罪",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、土佐づくりは皮付きを手早く焼き、皮ごと食うところに意義があるのだろう。",
              "citation": {
                "source": "いなせな縞の初鰹",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "じやがいもの残りいもで、指の頭ぐらゐの小つぶの物を捨てずに皮ごと油でいためて味噌をすこし入れて炒りつける、「味噌つころがし」と言つて主食の足しになる。",
              "citation": {
                "source": "ともしい日の記念",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その子は私に當てつけるつもりで皮ごと一つ噛つたが、澁かつたのか顏を歪めて吐き出した。",
              "citation": {
                "source": "避病院",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、大変……弘兄さま、そら、真つ赤よ、もう……」　梨枝子はおどかしたが、弘はいい気持で、林檎を皮ごと齧つてしまひ、腹ができたところで、林の奥へ探険にでかけた。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘いのがいけるのは、私とおさの姐さんだけで」「その安倍川餅の残りはどうした」「竹の皮ごと川へ捨ててしまいましたよ」「…………」　平次は舌打ちをしたい心持でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金の鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮ごと竪に二つに割って、横に薄く切り、醤油を滴らして食うと、酒の肴に珍無類、仙気を帯びた異味となる。",
              "citation": {
                "source": "九年母",
                "author": "青木正児",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちは酸っぱいと言って軽蔑し、あの香気の素晴しさを説いて、皮ごと食えと教えても決して食わない。",
              "citation": {
                "source": "九年母",
                "author": "青木正児",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれはその皮におどろいて果肉をすててはならないし、さればといって、皮ごとうのみにしてもならない。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹の皮ごと持って行きなんし。",
              "citation": {
                "source": "鈴が通る",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日まで食べたものは丸子揚とチューインガム一枚とみかん二個、みかんは僕は病院に居る時から皮ごと食べています。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "脆い白瓜子は、噛むと真中から折れて、皮ごとくだけてしまう。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
