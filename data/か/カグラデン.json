      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "kagura hall (at a shrine)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祭りの夜、提灯に照らされた神楽殿で、面をつけた舞い手が静かに踊り始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "神社の神楽殿は歴史を感じさせる重厚な造りで、古い檜の香りが漂っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わあ、神楽殿の方から笛の音が聞こえてくる！もう奉納が始まったのかしら」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "伝統的な神楽を継承するため、若者たちが神楽殿の舞台で熱心に稽古に励んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "神楽殿の傍には、周囲六丈四尺、根廻りは二丈八尺、と測られた神代杉がそそり立って、割合に背丈は高くないけれど、一つ一つの年輪に、山の歴史の秘密をこめて、年代の威厳が作り出す色づけと輪廓づけを、神さびた境内の空気に行わたらせている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うの神楽殿には、ぼんやり五つばかりの提灯がついて、これからおかぐらがはじまるところらしく、てびらがねだけしずかに鳴っておりました。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太鼓橋｜欄干橋をわたるとき幼子我は足あげ勢ひし三柱宮水照繁なる石段に瑪瑙の小蟹ささと音あり神楽殿砂吹きあぐる白南風に小蟹ちり走る鋏立てたり宮地嶽神社は、その裏参道にあり。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "考へて見ると、あの釣鐘型のスヾメ蜂の巣は恰度今自分が立つてゐる頭上の神楽殿の軒先にさがつてゐたことに気づいたので何気なく仰向いて見ると同時に、私は思はず、「アツ！",
              "citation": {
                "source": "夜見の巻",
                "author": "「吾が昆虫採集記」の一節",
                "note": "青空文庫"
              }
            },
            {
              "text": "――前の年の夏、私はここの神楽殿の軒に釣鐘大のスズメ蜂の巣を発見して、隣り村から山を越えて観察に通つたことがある――いつものやうに神前に向つて熱心なる合掌をなした後に、池のふちに来て蜻蛉を視守つてゐる時、あの痕は何うなつてゐるだらうと思ひ出した。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しどうも空鳴りではなくて、神楽殿の裏手のあたりから、ピツピツピツ！",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私は神楽殿に登つて蜂の巣の痕が、全く拭はれてゐるのを軒合によぢて確かめたりしてゐるうちに、一時止絶されてゐた笛と合唱が、今度は実にも明瞭に、然も神楽殿の楽屋の床下あたりから、賑々しく湧き上つたのに驚いた。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とばかりに叫ぶや、天狗のやうな羽ばたきをたてて、神楽殿の楽屋から、池のふちへ飛び居りたのだ。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると神楽殿の楽屋の軒先から池の上へ翼を伸してゐる百日紅の枝に、白つぽい浴着が一枚ふはりと懸つてゐるのを発見した。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　デモスゼネスの弁舌を聞きながら思はず不平を洩したのは、アポロの神楽殿の入口で、この喜劇の先祖の像を務めてゐる憂鬱な若者だつた。",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、この寒さも厭はず、この村社の急拵への神楽殿にも似た部屋に、幕を引き回らせて、筒抜けたやうな顔をして閑ぢ籠つてゐた。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "張り出した神楽殿の三方をとり巻いて、野天の座席で見物人はギッシリと詰まっていた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治の初年にわたくしは桜木天神の神楽殿に並んだ裏二階に下宿してゐたが、当時の薬師の縁日は猶頗殷盛であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽殿の舞姫として清浄なる役目を勤めていたのであったが、五年前の暗闇祭の夜に、荒縄で腹巻した神輿かつぎの若者十数人のために、乳房銀杏の蔭へ引きずられて行き、聴くに忍びぬ悪口雑言に、侮辱の極みを浴びせられたのであった。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて能舞台の構造に関する従来の諸説中、神楽殿の影響を深く見過ぎる説は、私はあまり賛成致しません。",
              "citation": {
                "source": "能舞台の解説",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽殿でニワトリがないている。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽殿に灯がともり白衣の人々が起きて働きだしている。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "石の鳥居をくぐって社殿までの右側に、お神楽殿があって、見上げる欄間には三十六歌仙の額が上げてあったかと思います。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本社は大工が誰で、蒔絵が円斎、拝殿、玉垣、唐門、護摩堂、神楽殿、神輿舎、廻廊、輪蔵、水屋、厩、御共所……等、それぞれ持ち場持ち場にしたがって、人と仕事がこまかにわかれている。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　反り橋の袂と神楽殿の前で、思わせぶりなポーズをしながら行きつ戻りつしていたが、三時近くまで、いちども声がかからない。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "その麗しい星明りと火光に煙ってうごく群衆は、神楽殿を繞って、この山上の寒さを知らぬ人いきれにしていた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった今、いたのに」　笛や太鼓が、山風に谺を呼んで人足もいよいよここへ流れ集まっては来るが、神楽殿にはまだ、静かに、灯影と帳が揺れているのみで舞人はあらわれていなかった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽殿の大鼓が、その時、急に高く鳴り出した。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして神楽殿の前へ来て、伊織の姿を探すと、伊織は群衆の後ろにいた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く放心して、神楽殿の舞に見恍れている。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽殿の床を見ているのであるが、周りの人々のように舞楽に陶酔している眼ではない。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽殿の上で、太鼓をたたいている舎人の二本の撥の手――二刀の真理をその音に聞いたのだった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽殿の早拍子が、黒い杉木立の奥に今、旺んだった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、気懸りでならないので、宵の手すきに、別当の玄関を窺っていると、ちょうど、武蔵と伊織が、神楽殿の方へ出て行った。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
