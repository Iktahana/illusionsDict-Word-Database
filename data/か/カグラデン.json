[
  {
    "uuid": "1899ae08-60a9-5d92-b564-baef2037f788",
    "entry": "神楽殿",
    "reading": {
      "primary": "かぐらでん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
