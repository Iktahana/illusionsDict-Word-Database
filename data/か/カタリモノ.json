[
  {
    "uuid": "6c2c769e-0b3e-52b6-8910-a8fe6f76b911",
    "entry": "語り物",
    "reading": {
      "primary": "かたりもの",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
