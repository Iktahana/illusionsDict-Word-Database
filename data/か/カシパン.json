    },
    "definitions": [
      {
        "index": 1,
        "gloss": "baked sweet goods (e.g. Danish pastry, melon bread)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「昼休み、購買の菓子パン争奪戦に出遅れて、何も買えなかったよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最近のコンビニの菓子パンは、パン屋さんに負けないくらいクオリティが高いよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "焼き立てのチョココロネとか、甘い菓子パンの匂いがするとつい足が止まっちゃう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今日の朝ご飯、コンビニの菓子パンで済ませちゃった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このパン屋の菓子パン、中身のクリームがずっしり入っていて食べ応えがあるね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「朝　ヌク飯三ワン　佃煮　梅干　牛乳一合ココア入リ　菓子パン　塩センベイ……」こういう記事が毎日毎日繰り返される。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仰臥漫録」から「ヌク飯」や「菓子パン」や「マグロノサシミ」やいろいろの、さも楽しみそうに並べしるしたごちそうを除去して考える事は不可能である。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりか、ほしブドウではちきれそうな菓子パンまでも、ぶらさがっているのです。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛乳一合、紅茶同量、菓子パン五、六箇、蜜柑五箇。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "よつて仰臥のままにて牛乳一合、紅茶ほぼ同量、菓子パン数箇をくふ。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "末子は家へのみやげにと言って、町で求めた菓子パンなどを風呂敷包みにしながら、自動車の中に私たちを待っていた。",
              "citation": {
                "source": "分配",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "この内から袋代を払い、ガラスの器物の破損をも償い、また菓子パンのローズとして売物にならないものが出来てきて、かれこれ損害の分を差引き、平均一割の儲けとなればごく上出来である。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種の菓子パンはほとんどすべての竈で毎日、そして純粋な小麦粉やライ麦とトウモロコシ粉のパンよりもせっせと焼かれ、一層確実に捌けていく。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "半｜片の菓子パンとコーヒーを貰いたいと彼は几帳面に言った。",
              "citation": {
                "source": "見えざる人",
                "author": "THE INVISIBLE MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "半片の菓子パンの様に重大なんですよ。",
              "citation": {
                "source": "見えざる人",
                "author": "THE INVISIBLE MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "菓子パンのように金子もかかるし、不消化だし、それに損害を与えるしね」　若い女は黒い眼を男からはなさずに、しかし彼を一生懸命に鑑察してるように見えた。",
              "citation": {
                "source": "見えざる人",
                "author": "THE INVISIBLE MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな半片の菓子パンを食うなんてちと残酷じゃないだろうかね？",
              "citation": {
                "source": "見えざる人",
                "author": "THE INVISIBLE MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "また彼の母の消息を告げてくれ、一｜籠のりんごと一片の菓子パンとを送ってきて、それを自分のために食べてくれと言ってよこした。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しパシエンカは引き留めて、食パンや、菓子パンや、バタをセルギウスに遣つた。",
              "citation": {
                "source": "パアテル・セルギウス",
                "author": "VATER SERGIUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、ひからびた大きな菓子パンが二つ、くしにささっているではありませんか。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は大きな菓子パンを持っていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供はまだ食い終えないでいるかじりかけの菓子パンを持ったまま、もう腹いっぱいになってるような様子だった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そのうちに子供は、菓子パンをかじったが、それをまた吐き出し、急に泣き出した。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして市民にも菓子パンにも気がつかなかった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "二羽の白鳥は何か浮いてるのを見つけ、まさしく船のように岸へ方向を変じ、菓子パンの方へ静かに進んできた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "白鳥はまだ菓子パンに達していなかった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、白鳥と同時にふたりの浮浪の子供が菓子パンに近寄ってきた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄はその菓子パンを、大きいのと小さいのと二つに割り、自分は小さい方を取り、大きい方を弟に与えて、こう言った。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャンディや菓子パン、クッキー、そして自動車のための小さな部品、日用のこまごました雑貨の奇妙にかたよった一部分、釣りの道具などがケースの内部に入っているが、ならべ方は雑然としていて、たいていのものは色あせ、ほこりをかぶっている。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありとあらゆる菓子、そしておなじくありとあらゆる菓子パンを売っている店だ。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしパンが一日一ドルだからな。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしパンなくては生きられぬ人間は、パンのみでも生きられぬ存在です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしパンの神の額の下には赭い鉢に植ゑたゴムの樹が一本、肉の厚い葉をだらりと垂らしてゐた。",
              "citation": {
                "source": "或阿呆の一生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしパンを斥けたのは現実的欲望を斥けたのに過ぎない。",
              "citation": {
                "source": "西方の人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふかしパンをつくる。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
