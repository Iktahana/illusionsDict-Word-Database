[
  {
    "uuid": "5a779466-e635-57b4-9683-e1c90e98aa4d",
    "entry": "菓子パン",
    "reading": {
      "primary": "かしパン",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
