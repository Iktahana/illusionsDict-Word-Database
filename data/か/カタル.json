        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ふぅ、この静寂が、かつての繁栄を無言で語っていますね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古びた時計の傷跡が、この家が重ねてきた年月を静かに語っている。",
              "citation": {
