        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ラスベガスのカジノでは、一晩で大金を失う人もいると聞く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "豪華客船の中には、小さなカジノが併設されているものもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいIR施設には、国際会議場とカジノが誘致される予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "もし同じ人が六回まで張り通したら、カジノは七十万円ばかりの損になる勘定であった。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「聖母マリアがもし現代に生れていたら」とカジノ・ド・パリの興行主は言った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あなた、カジノの賭博から、フランス政府はいくら取上げるのだと思って？",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――カジノでやる賭博で、「シュマン・ド・フェル（賭博の一種）」は五パーセント、カジノでテラ銭を取るのよ。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろカジノは国内に増すばかりである。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボーイの答えによると彼女は今しがたカジノからホテルへ乗馬服と着替えに帰って来て、鞭を持って出て行った。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男は、前夜小田島がカジノの切符台に納って居るのを見た勘定係の四十男だった。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が二十年間、カジノの切符台から女を見た経験から云いますと、あの娘さんはまず見て味う女でしょうな。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本公演だって、ジョンは、あのトレイドマークの黒いリッケンバッカー３２５ではなく、サンバーストのエピフォン・カジノを弾いていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかに、　仏国の「｜瑠璃の浜辺」にある辟寒地で、二万人を入れるカジノの中に、世界の遊民が、一杯の珈琲に安閑として居るのを見て、アリストートルと希臘文明に顕れた幸福主義の結果だと論じたという事は、私に重大な反省を与える。",
              "citation": {
                "source": "無題（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カジノの前のカフェーの此の傘が、ステキに美くしく並んでいる。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前側が大きな弓型の道路で岸の中央に、海に突出して八角の建物のカジノ・ド・フォリーが夢の竜宮のように青ばむ夜を、赤々と灯を水に照りかえしている。",
              "citation": {
                "source": "モルガンお雪",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カジノへ行って見ましょうか、あたしでも賭に勝つかしら。",
              "citation": {
                "source": "モルガンお雪",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜は柏亭とゲエテ街のカジノ・ド・モンパルナスと云ふ寄席へ行つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　東京にだつて近頃はこんなに面白いものがあるんだぞ、是非見てみたまへ、とむりやりに洋行歸りの友人を連れてきた、水族館のカジノ・フォリイも、ただ彼を苦笑させただけだつた。",
              "citation": {
                "source": "噴水のほとりで――",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　東京にだつて近頃はこんなに面白いものがあるんだぞ、是非見てみたまへ、とむりやりに洋行帰りの友人を連れてきた、水族館のカジノ・フォリイも、ただ彼を苦笑させただけだつた。",
              "citation": {
                "source": "噴水のほとりで――",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはカジノの踊り子たちに夢中になつてゐる彼の友人たちから來た。",
              "citation": {
                "source": "聖家族",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る晩、扁理は友人たちと一しよにコツク場のやうな臭ひのするカジノの樂屋廊下に立ちながら、踊り子たちを待つてゐた。",
              "citation": {
                "source": "聖家族",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずカジノ・ベバというのに案内してもらった。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "他にもヨーロッパ風のカジノやオペラはいろいろあるけれども、カイロではカイロらしい土俗を見たいと思った。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カジノ・ベバは浅草か本所あたりのさかり場といったような感じのする区域にあって、あまり広くもない土間にはアラビアの若者たちがぎっちり詰まっていて、綺麗な少年や少女が唄ったり踊ったりするのを囃し立てていた。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝塚の可愛いいレヴィウから、カジノ・フォリー、プペ・ダンサントと進み、北村富子一座などというエロ・ダンスへ移り、アパッシュ・ダンスを観た。",
              "citation": {
                "source": "恐しき通夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはカジノの踊り子たちに夢中になっている彼の友人たちから来た。",
              "citation": {
                "source": "聖家族",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る晩、扁理は友人たちと一しょにコック場のような臭いのするカジノの楽屋廊下に立ちながら、踊り子たちを待っていた。",
              "citation": {
                "source": "聖家族",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日の夕方、公園のカジノで、彼がルーレットに興じてゐると、いつの間にか、そばにゐた二人の姿が見えなくなつてゐた。",
              "citation": {
                "source": "ある夫婦の歴史",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それはそれとし今日に至って私たちの構成したこの軽演芸そのものについて考えてみると、当時は浅草オペラ亡びて数年、代わるにカジノフォーリーもプペダンサントとてもなかった。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "……するとなんだね、三日もカジノへ通ったら、モナコ公国の国庫は破産することになりはしないかね」　タヌは快心の笑をもらしながら、「そうよ。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "南風吹かば　――モンテ・カルロの巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、あきれて、声もなく顔を見合わしている二人のそばへ、四方八方から駆け寄って来たのは、空色の家令服に白い長靴下をはいたカジノの給仕達、およそ二十人あまり、「｜何か御用で？",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "南風吹かば　――モンテ・カルロの巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はカジノの正面にある、朱塗りの床几に腰を掛け、鼻っ先に截り立った白堊の山の断面が、おいおい赤から濃い紫に変ってゆくのをわびしげに眺めながら、言葉もなく鼻を突き合していたが、コン吉はやがて力なく、「日モナ戦争は日本の敗けだ。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "南風吹かば　――モンテ・カルロの巻――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
