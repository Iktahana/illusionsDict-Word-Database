[
  {
    "uuid": "fad38c9d-2d8b-525b-9334-b8138e1f1ef3",
    "entry": "かくの如き",
    "reading": {
      "primary": "かくのごとき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
