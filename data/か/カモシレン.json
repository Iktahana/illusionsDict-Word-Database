        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "まあ、あいつの言うことも一理あるかも知れんな。少し様子を見てみよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "今はこんなに晴れてるけど、夕方から一雨来るかも知れんぞ。傘を持っていけ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この難解な事件を解く鍵は、案外身近なところにあるのかも知れん。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "あいつが今さら謝りに来るなんて、何か裏に別の魂胆があるのかも知れんぞ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "――いや、ひょっとしたら、なんでもない俗な男なのかも知れん。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或ひはかういふ調子でもって、政治の実といふものを、容易に了解するかも知れん。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴樣達はあの時の中根の行爲を笑つたかも知れん。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　もう今日か明日のうちに腹から仔豚が出て来るかも知れんのだが、そういうやつを野ッ原へ追い放っても大丈夫だろうかな、無惨に豚を殺すことになりはしないか。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつはいいかも知れんがさし当たって田地がない。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "集って来た死者の肉親は、真蒼になって慌てながら、それでもひょっとすると、椀のように凹んだ中にでも生きているかも知れん。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何室でも明いている部屋に勝手に陣取らっしゃい、その代り雨は少し漏るかも知れんよ。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経衰弱かも知れん」　と答えます。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うん、どだいあの野郎には、趣味が無いのかも知れん。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も、そうかも知れん。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへ行っても軽蔑されるし、懐中も心細いし、Ｄのところへでも行ったら、あるいは気が晴れるかも知れん、と思ってやって来たのでしょう？",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、おおきにそうかも知れん。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうかも知れんな。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「心配しなくてよいかも知れんな。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお島どんがなあ……御存じかも知れんが、当寺の本堂の……ホラ……あすこの裏手に住んでおりまする非人の処へイツモ立寄って行きましたそうで……これは寺男の話で御座いまするが……」「ハハア。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "お話の途中かも知れんが、その日田のお金奉行というものは初めて聞くが一体、何様なお役人かいなあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ずそこいらかも知れんがなあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "身構えをしておらにゃ今頃は蔵元屋のお熊さんに追付いとるかも知れん」「ハハア。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれでも相当の悪党じゃったかも知れん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "お徳はどうかすると譏謔を言い兼ないがお源さんにそんなことでもすると大変よ、反対に物言を附けられてどんな目に遇うかも知れんよ、私はあの亭主の磯が気味が悪くって成らんのよ。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　うっかりして立ったのが、小店の方に目を注いで、「ああ、そうかも知れん。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手だ、酔覚しじゃと言わるるかも知れん。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀と違って、ものがものだし、ちょっと嵩は有るしするから、宵の人目を憚ったのが、虫が知らしたのかも知れんのだね。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "但礼をおっしゃるかも知れんというから、其奴は困ったと思いましたけれども、此処を通らないじゃ帰られませんもんですから。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十と十四ぢや少し違ひすぎるかも知れんね。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とまるかも知れんが、とにかく二時だ、御空腹と云う処だ。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "と事も無げに謂う顔を警部は見遣りて、「君、鰒でも食って死よったのかも知れんが。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥方の人を離れた美しさを見るにつけても、天がこの村のために、お百合さんを造り置いて、鐘楼守を、ここに据えられたものかも知れん。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と、主人が、どたりと寝て、両脚を大の字に開くと、（あああ、待ちたまえ、逆になった方が、いくらか空腹さが凌げるかも知れんぞ。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "団子が欲しいのかも知れん、それだと思いが可恐しい。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
