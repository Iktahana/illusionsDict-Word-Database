        "examples": {
          "standard": [
            {
              "text": "彼は上司の無理な要求に従い、火中の栗を拾うはめになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人を助けるためとはいえ、火中の栗を拾うような行動は避けるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あのプロジェクトは火中の栗を拾うようなものだから、関わらない方がいい」と先輩に忠告された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ペルシャならあの衣装のために、いくらでも払うだろうし、俺にとっても単なる商取引だ」「わたし火中の栗を拾うわよ」「美人に、指をヤケドさせるなんて絶対させないよ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "火中の栗を拾うまいとするならば、恬然と、傍観してもいられる位置にあったのである。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿ご自身が、伊吹へまいって、道誉と話し合わんなどは、火中の栗を拾うに似たもの。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
