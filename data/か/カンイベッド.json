        "examples": {
          "standard": [
            {
              "text": "オフィスでの徹夜作業が続いて、ついに会社の倉庫から簡易ベッドを引っ張り出してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ほら、急な来客で泊まる場所がないから、リビングに簡易ベッドを広げておいたよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "災害時の帰宅困難者向けに、体育館には段ボール製の簡易ベッドがずらりと並べられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "診察室の隅にある簡易ベッドで、点滴が終わるまで少し休ませてもらうことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私が負傷し逆上した態なのを見た彼はボイル博士を呼び、二人で私を簡易ベッドに乗せ落ちつかせてくれた。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがまた次に、みんな一緒に木製の簡易ベッドに寝ていた最上階の納屋みたいな大部屋のことを思い出させた。",
              "citation": {
                "source": "秘密礼拜式",
                "author": "アルジャナン・ブラックウッド",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
