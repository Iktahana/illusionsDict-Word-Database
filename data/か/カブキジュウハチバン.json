        "examples": {
          "standard": [
            {
              "text": "『暫』は、歌舞伎十八番の中でも特に豪快な見せ場が多い演目だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "歌舞伎十八番をすべて制覇するのが、役者にとっての悲願らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "今回は、歌舞伎十八番から『勧進帳』が上演されると聞いて、チケットを取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "○十一月、歌舞伎座にて団十郎は歌舞伎十八番の「暫」を勤め、連日売切れの大入りを占む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○九月、歌舞伎座にて市川猿之助は二代目段四郎と改名して、歌舞伎十八番の「鎌髭」を勤む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞伎十八番なぞはその一例で、平生の芝居でも、誰の何々はこうこう……なぞいうところに観衆のこうした観賞欲が含まれている。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "古人の先蹤を追った歌舞伎十八番のようなものでも椿岳独自の個性が自ずから現われておる。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「暫」と「助六」　明治二十八年から二十九年にわたって、歌舞伎十八番の「暫」と「助六」とが歌舞伎座で上演された。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにから何まで磁力とは、まるで歌舞伎十八番の「毛抜」みたいなことになったものである。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴衣の腕をまくり、その頃はまだ珍らしい腕輪を見せ、やや長めの断髪の下から、水入りの助六（九代目市川団十郎歌舞伎十八番）のような鉢巻を手拭でして、四辺をすこしもはばからなかった。",
              "citation": {
                "source": "明治大正美女追憶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "御存じでもございましょうが、この長唄は、歌舞伎十八番勧進帳の、いわば、伴奏曲でございまして、この芝居が天保十一年の三月五目、河原崎座で初めて上演された際に、作曲されたものだそうでございます。",
              "citation": {
                "source": "ながうた勧進帳",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治二十五年頃のこと、団十郎は歌舞伎十八番を自分の似顔の人形として家に遺すつもりで、その製作を当時活人形の名人であった初代安本亀八に頼んだ。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "成功すれば、新しい歌舞伎十八番物になるかもしれない。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
