        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大地震の後、多くの被災者が仮家での生活を余儀なくされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい家が完成するまでの間、彼は隣に建てられた仮家で暮らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは庭にシートで仮家を作り、秘密基地だと喜んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "片手でも押し倒せそうな小さい仮家で、柊や柘植などの下枝に掩われながら、南向きに寂しく立っていた。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "火本は樋口富小路とかや、病人を宿せる仮家より出で来たりけるとなん。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の隠れていた所は油壺の狭い入江を隔てた南岸の森の蔭、そこにホンの形ばかりの仮家を建てて、一｜族の安否を気づかいながら侘ずまいをして居りました。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般に、近頃の小説はつまらないという声の高いのがとりも直さず文学に対する関心がうすれたとばかりいえるかどうか。",
              "citation": {
                "source": "「大人の文学」論の現実性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあ、な」「百万からの借金で二進も三進も行かねえとなりゃ、こりゃァやり兼ねないもんでもない」　酒月は、ふいと顔をあげ、「ところが、そうとばかりいえない訳がある。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生には叱られるかもしれないけれど、今朝の打ちかただって、頭かぶせにわるいとばかりいえないんじゃないかしら。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロマン・ロランがこの小説をもってトルストイ作中の第一に挙げたのも、あながち奇をてらった言葉とばかりいえないかも知れぬ。",
              "citation": {
                "source": "クロイツェル・ソナタ",
                "author": "解題",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それが前にもいいましたように、まだその時分は光子さんと物いうたこともなかったほどでしたさかい、出鱈目も出鱈目、ひどいばっかりいえたもんや思て、あんまり馬鹿々々しいて腹も立てしませなんだ。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちがいに親不孝とばかりいえません。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　憐れな老人は思ってることをすっかりいえなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "ロマン・ローラン",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
