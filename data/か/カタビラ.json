[
  {
    "uuid": "8b7cbae5-f577-597a-b54d-028b32b7bc2d",
    "entry": "帷子",
    "reading": {
      "primary": "かたびら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
