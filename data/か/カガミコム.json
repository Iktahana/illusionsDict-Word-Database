[
  {
    "uuid": "32b481f1-c532-593c-8fac-a3693c2276f1",
    "entry": "かがみ込む",
    "reading": {
      "primary": "かがみこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
