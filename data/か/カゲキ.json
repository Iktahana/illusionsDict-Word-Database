        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "久しぶりに運動したら、過激なトレーニングで全身が筋肉痛になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "医者から、心臓に負担をかけるので過激な運動は控えるように言われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "連日の過激な労働で、彼はすっかり疲れ切ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
