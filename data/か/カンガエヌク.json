        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "一晩中考え抜いた末に出した答えだから、もう迷いはありません。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「これでもかというほど考え抜いて、ようやくこのコンセプトにたどり着いたんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "細部まで考え抜かれた設計図には、設計者の執念のようなものすら感じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "何度もシミュレーションを重ね、極限まで考え抜いた戦略で試合に挑む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "思想を考え抜くことこそ本来の意味に於けるその具体性でなくてはならぬだろう。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想の具体化とはまず第一に考え抜くことと撚りをかけることだ。",
              "citation": {
                "source": "ひと吾を公式主義者と呼ぶ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
