    },
    "definitions": [
      {
        "index": 1,
        "gloss": "silent movie narrator",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔の無声映画のイベントで、活弁士の語りが最高に面白かったんだ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの頃の活弁は、映像以上に観客を魅了したんだよ」と祖父が昔話をしてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "静かな映画館に響く活弁の声、なんだか不思議な感動を覚えたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「寒い」と上衣を着る「おい、俺の上衣じゃ」「儂のは」「お前のは……」○芝居の台詞を活弁の口調で言う兵「近衛後備歩兵第一聯隊長須知源二郎聯隊を代表して謹んで奏上し奉る。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして始めていわゆる活弁なるものを聞いて非常に驚いて閉口してしまって以来それきりに活動映画と自分とはひとまず完全に縁が切れてしまった。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも自分には活弁の存在理由がどうしても明らかでないのである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえって、下手な活弁を労したり、不つりあいな日本文字のサイドタイトルなどをつけられるよりも、ただそのままにわからぬ言葉を聞くほうがはるかにパリの真実、日本人の見たパリの真実がよくわかるのではないか。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はまるでじやれ附く猫のやうに、おんつぁんの上にのしかゝつて行つて、芝居のせりふや活弁の文句でかき廻してしまふのだ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方にその後、警官や刑事諸君が遊びに来ての話によると、彼女は向家の蕎麦屋にいる活弁上りの出前持を使って電話をかけさせておったものだそうで、白鷹助教授に化けて東京から電話をかけたのもその弁公だったそうである。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一は最初から生活難の背景、又は商売的の意味を持ったもので、男性では俳優その他の芸人、外勤員、祈祷師、各種の治療師、活弁、呉服屋、ボーイ等の男淫売式？",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "不良少年で一番多いのは矢張り学生で、その次が会社員、ボーイ、活弁、俳優、苦学生の順らしい。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本映画の発祥が明治三十年、神田錦町の錦輝館の活動写真にあることも、今では映画史の第一頁に、例の「すこぶる非常」で売った活弁元祖の駒田好洋の名と共に必ず記されることになった。",
              "citation": {
                "source": "神田界隈",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "活弁もやって見るとナカナカ楽じゃないね。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで吾輩みたいな田舎活弁の、しかも新米の映画説明の口上から「御座います」を抜いてしまったら、何の事はない素人の書いたシナリオの朗読みたいなものになるだろう。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこに鯖がいるんだ」　とキョロキョロする者もいれば、眼の前の山々に猥雑な名前を附けながら活弁マガイの潰れ声で説明するヒョーキン者もいる。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に屋根の反ックリ返った、破風造のお化けみてえな台湾館が赤や青で塗り上って、聖路易の博覧会がオッ初まる事になりますと、今のノスタレとオーム・シッコが二人でフロッキコートてえ活弁のお仕着せみてえなものを着込んで入口の処へ突立って、藤村さんから教わった通りの英語を、毎日毎日大きな声で怒鳴るんです。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時古川緑波君、いまだ早大の学生服を着て来演、二十余名の活弁の物真似（声帯模写という新名称を、同君はこの時もう考えているのだったろうか）を演じて大喝采を浴びたのだから、前述の華やかな宝塚出演はこれから何年ののちだろうか。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "この動坂亭の興行はなかなかに有望だったが――と書いて今小憩し、ラジオへスイッチを入れたら、山野一郎君の「なつかしの活弁ジンタ」が音楽入りで「ラジオ東京」から放送され、私は目裏を熱くして聴いた。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "お半二度｜左褄取る気やらまた晴れて活弁と世帯でも持つかその後の事はさっぱり承知致さず。",
              "citation": {
                "source": "雨瀟瀟",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "活弁に血道を上げるとは実にお話にならない。",
              "citation": {
                "source": "雨瀟瀟",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "活弁の一件がないにしてもあの女は行末望みがないようだ。",
              "citation": {
                "source": "雨瀟瀟",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし審に此等の問に答得るの学力あらば誰か亦活弁とならんや。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "活弁既に警察の試験を受く芸者俳優落語家講談師浪花節語も宜しく試験すべし。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "金語楼が落語界の新型であったころ、芸界では、もっとケタ違いに花々しい流行児があり、それが無声映画であり、活弁であった。",
              "citation": {
                "source": "“歌笑”文化",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手と云ふものの存在にも亦活弁（前文にすぐつづいてかう書くと何だかへんだが、徳川君よ許せ）と似た大正的な魅惑があつた。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央では土木課長の本田時彦と『活弁』事楠本春次が寺島派の井上、結城、中立の三谷の三人と格闘をやつて居る。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "楠本は富田遊廓第一級選出の議員で、公民派のあばれ者であるが『活弁』と云ふあだ名を取つたのは彼の演説が活弁の句調とそつくりだと云ふ評判があるためである。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうすると、活弁事楠本春次が、土木課長を救うてやるのは今だと立ち上つて、『何の謝罪だか薩張わからんぢや無いか？",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "『黙れ、活弁』『引込め、女郎屋の亭主！",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どう見ても女団長だね」「あたしが女団長なら、みんなあたしの部下なんだよ」「白浪四人男じゃねえか」「それじゃあたしは弁天小僧よ」「エエ、女団長河合ナオミは、………」と、熊谷が活弁の口調で云いました。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画の初興行と活弁ヴァイタスコープ時代から　今全盛の活動写真、初めはヴァイタスコープとかいって明治二十六、七年頃。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論まだ活弁はいない。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
