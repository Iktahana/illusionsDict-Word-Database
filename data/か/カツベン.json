[
  {
    "uuid": "53737cef-4173-56ae-8236-bb3c88e73cc4",
    "entry": "活弁",
    "reading": {
      "primary": "かつべん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
