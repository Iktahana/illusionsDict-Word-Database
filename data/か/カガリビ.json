[
  {
    "uuid": "4732c42e-91dc-5e13-a7b1-ab192a596a71",
    "entry": "かがり火",
    "reading": {
      "primary": "かがりび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fire built in an iron basket (watch fire, fishing fire, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長良川の鵜飼いでは、夜の闇を照らすかがり火が幻想的な雰囲気を醸し出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "闇夜の海上にかがり火を焚き、魚をおびき寄せる伝統的な漁法がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "山頂の見張り台から、敵の接近を知らせるためのかがり火が上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "宿屋の店頭には、かがり火をたき、白木の金剛杖をたばに組んで、縄でくくり、往来に突きだしてある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは庭の祭りのかがり火であった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かがり火は、薪木の性と見え、時折、ぷちぱちと撥ね、不平そうに火勢をよじりうねらすが、寂莫たる天地は何の攪き乱さるる様子もなく、天地創ってこのかた、たそがれちょうものの待つ、それは眠るにも非ず覚めたるにも非ざる中間に於て悠久なるものを情緒に於て捉えようとするかれ持前の思惟の仕方を続けている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水のいろをかがり火のまわりに浸して静に囲んでいる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かがり火も張合いがなく、まもなく火勢をもとの蕊立ちの形に引伸し焔の末だけ、とよとよとよとよと呟かしている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩秋の夕の露気に亀縮んだ山の祖神の老翁は、せめてこのかがり火に近寄ってあたりたかったが、それは許されないことである。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵のこの庭のかがり火は純粋な神のみが使う資格のある聖なる祭の火であった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "神の道しるべの庭のかがり火は精気を増して燃えさかっている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の祖神の翁は、泣いていいか笑っていいか判らない気持にされながら、かがり火越しに幄舎の方を観る。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "炎々と燃えているかがり火も美の神を祭っているとしか思えない。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "かがり火も、どんどんたきました。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが信長が二十七日の夜敵陣にたくかがり火を見て、敵に進撃の気配あるを察し、それならばこちらから、逆撃しようと云うので、姉川の左岸に進出していたから、浅井朝倉軍が展開するのを見るや、先ず織田徳川の軍から、弓銃をもって、挑戦した。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭のかがり火のようで、一面真っ赤に燃えるに至っては、目にしたものの雄大さに逃げる一行の心も癒され、力も湧き上がる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "かがり火の光りでそれが男であることを知ると、彼はすぐに流そうとした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "かがり火を昼のやうにあかるく、船腹をづらりとならべて、鼻歌をうたひながら釣針を海に投げました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつと若い人達のものを読んで見たいと思つて、「新小説」に出てゐる川端康成の『かがり火』と金子洋文の『狼』とを読んだ。",
              "citation": {
                "source": "三月の創作",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "『かがり火』は『狼』とは正反対だ。",
              "citation": {
                "source": "三月の創作",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばらばら松の下では二ヵ所ばかりのかがり火を焚いて、大勢の人影が黒く動いていた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お島さんはもう気が気でないらしい、僕を途中に置き去りにして、夏の虫のようにかがり火の影をしたって駈け出した。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、僕の想像通りに真っ白な雛子の顔がかがり火の下に仰向けになっていた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かがり火の下の死骸を遠巻きにしている人達は思い思いの推量をくだして、がやがやと立ち騒いでいた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がかがり火のそばへ近づいた時に、お島さんは又どこからか現われて来て、僕にからだを摺り付けるようにして立っていた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かがり火の影からだんだんに遠くなると、お島さんは暗いなかで僕にささやいた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「月のあるうちに急いで置かないと、後はかがり火だけじゃ仕事が出来なくなるからな。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのかがり火を村里の灯とでも思って慕い寄ったことなのだろう。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし」というとその人影、かがり火を目がけて走り出した。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かがり火に映じて杯のふちが、血でも垂れそうにぬれて見える。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かがり火に照らされてカッと赤い。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かがり火が水に映り、衣裳の金絲銀絲が火に照らされて―それを見てゐると子供の私には、これはまるで幻夢の世界だった。",
              "citation": {
                "source": "広島の牧歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケメトスが飛び下りる塔の下の場所には、もうせんが敷きつめられ、まわりにはかがりびが焚かれました。",
              "citation": {
                "source": "彗星の話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "brothel-keeper (Edo period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「よぉ、かがり火。今宵も賑わっているじゃねえか。」と、男は店の主人に声をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "江戸時代の遊郭では、かがり火と呼ばれる男たちが店の経営を取り仕切っていたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "その小説には、抜け目のないかがり火と、彼に翻弄される遊女たちの姿が生き生きと描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      }
