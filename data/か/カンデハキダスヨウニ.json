        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は質問に対して、まるで噛んで吐き出すように短い返事をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "店員は客のクレームに対し、噛んで吐き出すように冷たく言い放った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "上司は部下の提案を、噛んで吐き出すように一蹴した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "……」「……よけいな事を……」　私は思わず噛んで吐き出すようにこう云った。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこの眼で見たので……」「よし……行け……」　と志免警部は噛んで吐き出すように云った。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "噛んで吐き出すように、ハッキリと云った。",
              "citation": {
                "source": "芝居狂冒険",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "会見の結果を心配して、聞きに出て来た彼の妻にも一言噛んで吐き出すように、「何でもないさ」　と云っただけだった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ、陸軍機か」　彼等は、噛んで吐き出すように、云った。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、噛んで吐き出すように言いました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをいちいちこんなに鳴物の手助けを借りやがって、名人も提灯袋もあるもンけえ」　噛んで吐き出すように今松は言った。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と藤吉が噛んで吐き出すように言った。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "宇治の茶箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　侍は噛んで吐き出すようにこう言った。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怪談抜地獄",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮本夫人ともあろうあなたが、そんな浅間しい真似をしちゃいけません』　噛んで吐き出すように小田切さんがいいました。",
              "citation": {
                "source": "情鬼",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すっかり綺麗になったのねえ、そうして居ると、三ちゃんは紳士のように立派よ」「何をつまらない」　私は噛んで吐き出すように顔を反けました。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第七夜　歓楽の夢魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは別ですよ、叔母の隠密だから」　久太郎は噛んで吐き出すように言い切ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死相の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵馬は、二人をなだめる役に廻り、「どうだ、これで実証が出来たからひとつ、下りてみようではないか」「いやいや、あんな奴の通った路や、汚した滝壺なんぞ、見たくも無え……」　噛んで吐き出すように丸山がいう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれはポックリです――女物の、二十歳前の女の子でなければ穿きません」　噛んで吐き出すようにお角さんが言う。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの眼には私たちの崇敬する王女殿下のお姿も土人の娘としか映ってはいないのでしょう」と噛んで吐き出すように言った。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――」私が返辞に困っている間に、「それ見たことか」と云う顔つきで、ナオミは噛んで吐き出すように云うのでした。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……どうじゃ、その頼みなら聞いてくださるであろうが」「……置いて行けっ」年景は、噛んで吐き出すようにいった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただそれだけだ」　噛んで吐き出すように又四郎は酬う。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　信長は噛んで吐き出すように、やがていった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざと、噛んで吐き出すように、「なに、叱られに来たと。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩は、実は先日の好誼にむくいるため、ふたたび来て、君のために一大事を教えたいと思っておるのに」「やめたがいい」　周瑜は噛んで吐き出すように、「――汝の肚の底は、見えすいている。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、噛んで吐き出すように、趙雲は下をのぞいていった。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うむ、失敗だッ」　怪紳士は、かんではきだすようにいったが、そのときしまった、そんなことをいうんじゃなかったという顔つきになり、道夫の方に鋭い目を走らせ、「いや、一度や二度じゃうまくいかないだろう。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
