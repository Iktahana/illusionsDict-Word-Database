        "examples": {
          "standard": [
            {
              "text": "「サーバーの仮想化を進めることで、物理的なハードウェアの台数を大幅に削減することに成功した。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ひとつの物理PC上で、WindowsとLinuxを仮想化技術を使って同時に動かしているんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ネットワーク機能の仮想化によって、柔軟なシステム構成の変更が短時間で行えるようになったね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "』『弁当をやらかそうか。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "わからん……そうかそうか……そんならその女に金を貰うたのはどこいらか教えてくれんか……エエ……コラ……どこで貰うたんか……今、お前が左手に握っている……その金を……」　昂作は白いホコリにまみれた左手の拳をソロソロと開いて見た。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、帳尻の合っております証拠で……いつもの事です」「そうかそうか。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつ歌でもやらかそうか」　と彼が言ったので私は二重に、ほっとした。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうかそうか、結構だ。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "野々宮さんはべつだんこわい顔もせず、といって、優しい言葉もかけず、ただそうかそうかと聞いている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかったわかったそうかそうか。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうかそうか新吾だったのか。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へえ」「その夢を話して聞かそうか」「へえ」　なにを云うのかと、清吉は相手の顔をながめていると、半七はやはり笑いながら話しつづけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一寸おどかそうかな」　若い人はひとりごとのように含み笑いして、「奥さん、宿やは、あの位のところですよ」と言った。",
              "citation": {
                "source": "琴平",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに……米も、それから味噌も生憎切らしているのでねえ」　女は、そうかそうかという風に、わざと剽軽な面を作って肯いた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "狃染の芸者が風邪を引いているのを過って盛り殺した奴で……」「……そうかそうか……あの医者にかかっちゃ堪まらん……フムフム。",
              "citation": {
                "source": "骸骨の黒穂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかそうか、それは色の黒い、茶の中折を冠った、背の高い男だったろう。",
              "citation": {
                "source": "近眼芸妓と迷宮事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その折角の最新芸術様式によって日本の何者を生かそうかと考える時、生きそうな何者も容易に発見出来ないことがある。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "何うともしてくれってんだ」　庄吉は、南玉の方へ、肩を聳やかして「おいらあ、これで、男の一分が立ったから、おさらばってことにして――一つ、仲間の奴へ、奉加帳を廻してさ、二三十集まったら、何か、こう小商売でもやらかそうかと思うんだが。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、博士は、科学に関しては、世界の人間宝庫であるともいわれている」　私が最大級の讃辞を博士に捧げていると、ロッセ氏は、そうかそうかと、ペルシャ猫のように澄んだ瞳をくるくるうごかして、しきりに感服の面持だった。",
              "citation": {
                "source": "のろのろ砲弾の驚異",
                "author": "――金博士シリーズ・１――",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、ムーッと弁才坊……」「そうかそうか、斃ったのか？",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうかそうか、恋仲か！",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とらえましてござります」「そうかそうか、それはよくした。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "須貝　ああ、そうかそうか。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの大将が、なんでも洋行を永くしていた医者や云う話や」「ああそうかそうか。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "検事はそうかそうかと肯いた。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴨下ドクトルは今手洗所に入っているから、間もなく来るであろうと村松氏が云えば、先生は大きく肯き、そうかそうかといって、急いで村松氏の手をとり、室内へ入れ、扉をピタリと閉じた。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長は、「ウンそうかそうか」とうなずきながら、「一体、きみは、どうしてメリー号からほうりだされたのかネ」「それがハッキリおぼえていないのですが、なんでもあれは、船内の夕食がすむかすまぬうちのことでした。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "できるだけゆっくりねかしておきたい、でないと、姉は衰弱がひどくて、重態に陥る危険があるのだ」　というと、隆夫は、なるほど、そうかそうかと合点して、ややおとなしくなった。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵団と言うと、日中戦争の時によく言ったじゃないか、柳川兵団だとか、徳川兵団だとか言うあの兵団、つまり兵隊さんの集っている大きな部隊のことだよ」「ああ、そうかそうか」「お父さん、『火星兵団』の意味がわかった？",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、なんだかおじさんが来るような気がしていたよ」「ああそうかそうか」　おじさんはにこにこ顔です。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしらせしたいと思ったですが、なかなか見張がきびしくて、とても近づけませんでした」「おお、そうかそうか」　ダン艇長たちも、この話をきいて、おどろいたり、感心したりだった。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうかそうか」だの「それは面白い点だ」などと兄はところどころに言葉を挟みながら、私の報告を大変興味探そうに聞いていました。",
              "citation": {
                "source": "崩れる鬼影",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
