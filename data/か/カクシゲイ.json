[
  {
    "uuid": "9ce21058-92dd-58df-95b0-be14429e974f",
    "entry": "隠し芸",
    "reading": {
      "primary": "かくしげい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
