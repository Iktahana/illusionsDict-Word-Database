        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夕焼けに染まる空が、まるで唐紅の絵のようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "秋の山々は、紅葉で唐紅に染まり息をのむ美しさだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は唐紅の着物を身にまとい、祭りの人ごみの中でひときわ目を引いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの唐紅色の花は、情熱的な恋を象徴している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その姿が、毛氈の赤い色、毛布の青い色、風呂敷の黄色いの、寂しい媼さんの鼠色まで、フト判然と凄い星の下に、漆のような夜の中に、淡い彩して顕れると、商人連はワヤワヤと動き出して、牛鍋の唐紅も、飜然と揺ぎ、おでん屋の屋台もかッと気競が出て、白気濃やかに狼煙を揚げる。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、床、壁、天井にまでも血が飛び散つて一面に凄慘な唐紅だつた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その言葉の終りは唐紅の血となりて初花の鼻と唇より迸り出づる。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくするとまた唐紅の天道がのそりと上って来た。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "床上に横たわった杉窪の銅兵衛、胸の繃帯唐紅だ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手繰るに連れて一丈二丈｜唐紅の絹が延びる。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、老人は左右の手を、物でも掬うように円く曲げ、ドップリと胸腔へ差し込んだが、肘の付け根から爪の先まで、唐紅に血に染めて、それを再び引き出した時には、軟いドロドロした変な物を、掌一杯に捧げて持っていた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "颯と白紗の蚊帳に血飛沫が散って、唐紅の模様を置いた。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "カズ子さん、このままあなたがこの小路を奥へ駆込めば、あなたの首はすっとんで、あたり一面はそれこそ唐紅ですぞ」「まあ、恐ろしいことを仰有る」「これを見てごらんなさい」　帆村は前へ三歩進んで、洋杖を前方へ斜に突出し、それから徐々にその洋杖を奥の方へ深入りさせた。",
              "citation": {
                "source": "千早館の迷路",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのとき帆村がすぐ手を伸ばして自分を引停めてくれなければ、自分の前の小路の床を唐紅に染めていたことであろう。",
              "citation": {
                "source": "千早館の迷路",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、次々に深紅の血汐が、ポカリポカリと水面へ浮かび、その辺一面見ている間に緋毛氈でも敷いたように、唐紅と一変した。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "未来を覗く椿の管が、同時に揺れて、唐紅の一片がロゼッチの詩集の上に音なしく落ちて来る。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊間に販売する染色料の唐紅は多量の砒石を含有するを以て最も危険なり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも倒れているその周り、時ならぬ胡粉の雪の白皚々へはベットリながれている唐紅の小川があった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "折柄、烈しい物音がしてにわかにこの辺り空も水も船も人も圓朝もお糸も、猩々緋のような唐紅に彩られそめたとおもったら、向こう河岸で仕掛花火の眉間尺がクルクルクルクル廻りだしていた（下略）。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に入つて再び二階へ上がつて見ると怖しい火勢は最早浅草学校の長い黒い建物の背後を一めん唐紅に塗潰してしまつてゐて、その火影を浴びて瓦屋根に生えてゐるぺん／＼草の二、三本の赤く黒く揺いでゐるのが、はつきりと見えた。",
              "citation": {
                "source": "異版　浅草燈籠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽん、すぽん、ぽん――折から烈しい物音がして、にわかにこの辺り空も水も船も人も圓朝も、お絲も猩々緋のような唐紅に彩られそめたと思ったら、向こう河岸で仕掛花火の眉間尺が、くるくる廻り出していた。",
              "citation": {
                "source": "圓朝花火",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋風や唐紅の咽喉仏という句はむしろ実況であるが、何だか殺気があって含蓄が足りなくて、口に浮かんだ時からすでに変な心持がした。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "水を求めあぐねて、ついに張り裂けるばかりの咽喉を抑えて、もしやと掌を池の中へ入れてみたが、ベトベトとして餅のようにからまる水は見るからに唐紅、口へ持って行けば火になりそうだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "御覧の通り葉の形から花の恰好まで白い方の分とソックリで御座いますが、ただ花の色だけが御覧の通り血のように真赤なんで……昔からくれないの花と申して珍重されていたものだそうで御座います。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の蒼白い頸筋からくれないの血が流れ出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下の句に、からくれないに水くぐるとはとあるではありませんか。",
              "citation": {
                "source": "千早館の迷路",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "からくれないとは、正面奥の、あの真赤に塗った壁です。",
              "citation": {
                "source": "千早館の迷路",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "からくれないの壁にぶつかり、左を見ると、「戸ろ」に並んで、果して「戸は」と記した扉があった。",
              "citation": {
                "source": "千早館の迷路",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「千早ふる、かみ代もきかず、たつた川、からくれないに水くぐるとは……」　分らない。",
              "citation": {
                "source": "千早館の迷路",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "満顔ただからくれないの一コの首。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
