        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「まあ、可愛な赤ちゃんね」と、通りすがりの老婦人が微笑みかけてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女の仕草はどこか可愛げがあって、性別を問わず誰からも好かれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "可愛さ余って憎さが百倍、なんていう言葉が身に染みる出来事があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「岡宮さん、あゝ、岡宮さん――岡宮さんはほんとにあんたを可愛がつたものだ。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護衣のまゝで抱かれるのは少しいやでもあつたけれど、心底可愛さうに抱いてるのにそんなことも云へなかつた……」と、母の話はマストの次には岡宮さんである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなくして、何だか堪らないやうに隣室に行く）男　「可愛くもあり、可愛くもなし」………あゝさうか、あれは「鴎」の中の台詞だ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――可愛くもあり、邪魔でもあり………？",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――可愛くもあり、面倒でもあり………さうだ可愛くもあり、面倒でもあり、可愛くもあり、面倒でもあり、可愛くも………（女コーヒーを立てゝ持つて来る）女　（優しく）お飲みなさいな。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "小サイ可愛イママサマ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨク来タト申シタイアナタノ可愛イ手紙、今朝参リマシタ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アノイワレハ可愛ラシイモノデス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼津　八月十七日パパカラ可愛イ子ニ、ソレカラ皆ノ人ニヨロシク。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "小泉八雲　小サイ可愛イママサマ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分ノ身体ヲ可愛ガルヨウニ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "巌ト一雄、丈夫デ可愛ラシイ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "サヨナラ、可愛イママサマ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "オババサンニ可愛イ言葉。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻を愛称して『小サイ可愛イママサマ』と呼んでるヘルンは、同時にいかにまた子煩悩であったかが解る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいつも手紙の終りに『オババサマニヨロシク』とか『オババサマニ可愛イ言葉』とか書いている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに可愛いでしょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンにとっての夫人は、この世にただ一人の愛人であり、永久に『可愛い小さいママさま』であったと共に、またその仕事の忠実な助手でもあり秘書でもあった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来のいい子は、出来のいい子で可愛いし、出来の悪い子は、いっそう又かなしく可愛い。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて、妹さえ丈夫でございましたならば、私も、少し気楽だったのですけれども、妹は、私に似ないで、たいへん美しく、髪も長く、とてもよくできる、可愛い子でございましたが、からだが弱く、その城下まちへ赴任して、二年目の春、私二十、妹十八で、妹は、死にました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君は独り息子であるから、ずいぶん可愛がられて、十年ほど前にお母さんが死んで、それからは厳父は、何事も大隅君の気のままにさせていた様子で、謂わば、おっとりと育てられて来た人であって、大学時代にも、天鵞絨の襟の外套などを着て、その物腰も決して粗野ではなかったが、どうも、学生間の評判は悪かった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は叔母に可愛がられて育ちました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯殿でまだ沸き切らぬ湯をチヤブチヤブさせて遊んでゐる四人の小さな子供等こそは、実は一番喧しかつたのだが、長男に就いての一件の起こつてる時なので、他の四人の子供は何だか可愛い気がして、何時ものやうにとても「やめろ！",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、親といふものは誰でも子が可愛いからさうなるのですよ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし……』と言って悲しげに『かわいそうです。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわいそうな虫』と寂しげに言い、この頃の暖かい日に、そっと草むらの中に放してやれ、と家人に言いつけた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "末子であるから埒もなくかわいいというわけではないのだ。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕もただ話の小口にそう云うたまでであるから、民子に泣きそうになられては、かわいそうに気の毒になって、「僕は腹を立って言ったでは無いのに、民さんは腹を立ったの……僕はただ民さんが俄に変って、逢っても口もきかず、遊びにも来ないから、いやに淋しく悲しくなっちまったのさ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子が両手を赤くしているのを見た時非常にかわいそうであった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "意地曲りの嫂にこきつかわれるのだから一層かわいそうでさ」「そりゃ政夫さん私もそう思って居ますさ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
