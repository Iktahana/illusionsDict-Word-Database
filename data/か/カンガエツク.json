[
  {
    "uuid": "75921c04-4ca6-5155-bdee-10a844b54547",
    "entry": "考えつく",
    "reading": {
      "primary": "かんがえつく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
