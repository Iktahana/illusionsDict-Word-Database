[
  {
    "uuid": "9ae46554-2929-546d-8680-4464e3c05eff",
    "entry": "風を切る",
    "reading": {
      "primary": "かぜをきる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
