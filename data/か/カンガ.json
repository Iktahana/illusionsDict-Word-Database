    },
    "definitions": [
      {
        "index": 1,
        "gloss": "refined",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この日本庭園は、手入れが行き届いていて、閑雅な雰囲気が漂っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の静かな話し方と穏やかな表情は、閑雅さを感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古都の町並みを歩くと、閑雅な趣のある古い家々に出会う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この茶室の設えは、まさに閑雅の一言に尽きるね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "生垣で囲われた藁屋根の家が、閑雅に散在している郊外村落の昼景である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち例へば「古池」といふ言葉は、日本人の連想からは直ちに古い寺院の池や、庭園などにある閑雅で苔むした小さな溜水の池をイメーヂするが、温気のない西洋にはそんな古池が無いのであるから、西洋人のこの語から連想するイメーヂは、アルプスやスヰスの山中などにある、青明に澄んだ大きな湖水であるだろう。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に言つたやうな特別の注文さへなければ、だれも閑雅な好い感じをもつことができる温泉である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋草を日本趣味といふ意味での、おとなしい閑雅さから、伊香保を日本趣味といふのは適評である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "掃き浄めた朝の座敷で幽寂閑雅な気分に浸る。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娼家らしい家が並んで、中庭のある奥の方から、閑雅な音楽の音が聴えて来た。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ少しも物音がなく、閑雅にひっそりと静まりかえって、深い眠りのような影を曳いてた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "春埃の路は、時どき調馬師に牽かれた馬が閑雅な歩みを運んでいた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その椅子につくことは僕の閑雅なたのしみであり矜りであつた。",
              "citation": {
                "source": "『亞』の回想",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田川の中、水道橋辺より○御茶の水橋下流に至るまでの間は、扇頭の小景には過ぎざれども、しかもまた岸高く水｜蹙りて、樹木鬱蒼、幽邃閑雅の佳趣なきにあらず。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち「幻の寢臺」、「憂鬱なる櫻」、「さびしい青猫」、「閑雅な食慾」、「意志と無明」、「艶めける靈魂」他詩一篇である。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑雅な食慾松林の中を歩いてあかるい氣分の珈琲店をみた。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には白い雲が浮んでたいそう閑雅な食慾である。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑雅な食慾松林の中を歩いてあかるい氣分の珈琲店をみた遠く市街を離れたところでだれも訪づれてくるひとさへなく松間の　かくされた　追憶の　夢の中の珈琲店である。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "をとめは戀戀の羞をふくんであけぼののやうに爽快な　別製の皿を運んでくる仕組私はゆつたりとふほくを取つておむれつ　ふらいの類を喰べた空には白い雲がうかんでたいそう閑雅な食慾である。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辮髪は、支那人の背中の影で、いつも嘆息深く、閑雅に、憂鬱に沈思しながら、戦争の最中でさえも、阿片の夢のように逍遥っていた。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度その時、辮髪の支那兵たちは、物悲しく憂鬱な姿をしながら、地面に趺坐して閑雅な支那の賭博をしていた。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての版畫を通じて、空は青く透明に晴れわたり、閑雅な白い雲が浮んでゐる。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして鋪道のある街街には、靜かに音もなく、夢のやうな建物が眠つてゐて、秋の巷の落葉のやうに、閑雅な雜集が徘徊してゐる。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして家家の窓からは、閑雅なオルゴールの音が聞えてくる。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何物の卑劣にすら、何物の虚僞にすら、あへて高貴の寛容を示し得るやうな、一つの穩やかにして閑雅なる徳はないか。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は喪心者のやうに空を見ながら、自分の幸福に滿足して、今日も昨日も、ひとりで閑雅な麥酒を飲んでる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は喪心者のやうに空を見ながら、自分の幸福に滿足して、今日も昨日も、ひとりで閑雅な麥酒を飮んでる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて我々の昔の詩人は、好んでかかる風流閑雅の趣味を愛し、自然の詠吟を事としていた。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は喪心者のやうに空を見ながら、自分の幸福に満足して、今日も昨日も、ひとりで閑雅な麦酒を飲んでる。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　旅人の「山」　万坊ヶ原の一本松は、暁の暗に隠れた、那須野ヶ原あたりの開墾地にありそうな、板葺小舎から、かんがりと燈がさす。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分がここまで述べて来た事は正にこの点について疑いを解かんがためである。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはあるいやなことをかんがへこんでゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは恐ろしく不吉なかんがへだ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはまたあのいやのことをかんがへこんだ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
