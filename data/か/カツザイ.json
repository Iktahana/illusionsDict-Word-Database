          "standard": [
            {
              "text": "機械の部品には、定期的に滑剤を塗布する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この製品は、肌に優しい滑剤を使用しているので、安心して使える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ベルトがキーキー鳴るから、ここに滑剤を差しておこう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "降雨――雨量が少量の場合は湿雪の降ったのと同様、概して雪崩を誘起しないが、多量のときは積っている雪の中まで浸潤して、その雪を湿潤雪とし最後には粒子のあいだを流れて滑剤となり、恐るべき雪崩発生の原因となる。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばしば筋肉や関節の機械的運動のための単なる潤滑剤であると考えられた。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            }
          ]
        }
