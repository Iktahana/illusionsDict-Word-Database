        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この作家の『歌論』は、短歌の歴史的変遷を深く考察していて面白い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "授業で習った『歌論』を読み返してみたら、当時の歌人の思想がよく理解できた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "（昭和六年十一月渋柿）　　　　　七　短歌の連作と連句　近ごろ岩波文庫の「左千夫歌論抄」の巻頭にある「連作論」を読んで少なからざる興味を感じたのであるが、同時に連作短歌と連句との比較研究という一つの新しい題目が頭に浮かんで来るのであった。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃大分「日本」紙上の歌論は喧びすしかつたが、他の歌よみ專門の連中はうんだとも潰れたとも云はない。",
              "citation": {
                "source": "竹の里人〔二〕",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちその作歌及び歌論について価値を定めねばならぬ。",
              "citation": {
                "source": "正岡子規君",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "正岡子規が有名な「歌よみに与ふる書」という歌壇革新の歌論を日本新聞に発表したのは明治三十一年であった。",
              "citation": {
                "source": "「土」と当時の写実文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窪川鶴次郎の『短歌論』をおもちでしょうか。",
              "citation": {
                "source": "歌集『仰日』の著者に",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶、もうすこしで完成しようとしてゐたものに、　　一、日本詩歌論　　一、小泉八雲に關する研究　の二つの著作をあげることが出來る。",
              "citation": {
                "source": "萩原朔太郎",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌論の上の慣例を追うたに止る事の多い事を思ふべきだ。",
              "citation": {
                "source": "古代民謡の研究",
                "author": "その外輪に沿うて",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした論難の癖は、恐らく、平安京の初頭にも既に、行はれたらうと思はれる――或は其以前からも――「歌合せ」の席上の討論の風が理論化せられて、歌式となり、歌論となり、更に、勅撰集撰者の態度批評とまでなつて来た。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌学・歌論は喧しくなつても、文学製作階級は、短歌に興味を失ひ出して居た。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚、歌論義と言ふ書物さへあつた。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう言ふ文芸的故実家の伝統は、存外早く現れないで、王朝も末一世紀半の中頃から、目について来るが、此までの歌論家・歌学者は、大抵、公卿の中位以上の人であつたが、文芸を愛好する階級も段々下つて行つた此頃になると、さうした故実家は、公卿の末席か、其以下のものに多くなつて行つた。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが文学評論の初歩と見る可き歌学・歌論は、歌合せの席上から生れたのである。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい歌合せは、歌評から見ても、前代の歌学書・歌論書よりは、用語も、態度も、論理も、鑑賞も、文学的になつてゐる。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌式が段々力を持つて来るに連れて、至上の為、或は皇子の為の歌式・歌論・標準歌集などが出来る。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は、歌合せに新様、御歌会には旧調、勅撰集入選の為には、両様に通じて置く必要があつた為であらうが、歌合せにおける歌論の素養として、さうした理会力と記憶と、其運用の自在を尊んだのであらう。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体に、顕輔統には、歌学・歌論が多く、俊頼統には、尠かつた。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌ことばを集めるということが、歌論、歌学と一つになってきて、歌学の一つの内容になってきた。",
              "citation": {
                "source": "辞書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌垣・歌論義など言ふものが、其である。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄憲の説経には、歌論義・問答・頓作めいた処が讃へられた様に思はれる。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "白拍子・歌論義、其等から科白劇化した連事、其更に発達したのが宴曲である。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢村専太郎氏が、ふた昔も前に発表せられた、短歌様式の論（明治四十年頃の新小説）は、それまでの歌論の、ゆきつく処まで、ひき上してゐる。",
              "citation": {
                "source": "短歌様式の発生に絡んだある疑念",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰の蔵書だったのか、西村の方から来たものだろう、定家の歌論を根拠としている。",
              "citation": {
                "source": "日記",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌論に対する先生の自信はおそらくすべての人々が異常な感をもってそれに対したほどであった。",
              "citation": {
                "source": "左千夫先生への追憶",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツから送った私の歌に対して、「アララギ」第六巻第三号で「歌の潤い」という歌論のもとで、大いに褒められ、それが先生の最後に近い歌論ともなったことは、私にとってまことに感銘のふかいところである。",
              "citation": {
                "source": "左千夫先生への追憶",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "（この順序を決めるには久曾神昇氏「二四代集と定家の歌論書」〔『国語と国文学』昭和十年七月〕という名研究報告に安心してたよれるのである。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実朝へ送った方は『群書類従』和歌部に入っているし、後で歌をつけ換えた方は自筆本が残っていて、久松潜一博士校訂の『中世歌論集』（岩波文庫）中に収められている。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌論はすべて自家擁護の武器となっており、しかもせまい歌壇内での党派的対立における自家擁護の武器となっているのである。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長じて、種のために生をかろんずるにいたるのも、自然である。",
              "citation": {
                "source": "死刑の前",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざとく跪き手を合すべし、見よこれ神の使者なり、今より後汝かかる使者等をみむ　二八―三〇見よかれ人の器具をかろんじ、かく隔たれる二の岸の間にも、擢を用ゐず翼を帆に代ふ　三一―三三見よ彼これを伸べて天にむかはせ、朽つべき毛の如く變ることなきその永遠の羽をもて大氣を動かす。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリストの甦りて死に勝ち給へるをいふと、但し特に指せる聖歌ありや不明なり一三〇―一三二〔目〕ベアトリーチェの〔かろんじ〕歌を聞くの喜びがベアトリーチェの目を見るの喜びにもまさるごとく聞えしめ一三三―一三五〔生くる印〕諸天。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
