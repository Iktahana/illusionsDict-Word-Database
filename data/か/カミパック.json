        "examples": {
          "standard": [
            {
              "text": "飲み終わった紙パックは、内側をきれいに洗って切り開いてからリサイクルに出してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、冷蔵庫の紙パックの牛乳、賞味期限が今日までだ。早く飲んじゃおう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "給食の時間、紙パックの角をストローの先できれいに刺すのが地味に得意だったんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このオレンジジュース、紙パックのままだと味気ないから、お気に入りのグラスに注ごうかな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "駅の入口の横にケンタッキー・フライドチキンを見出すと隼人は中に入って６ピースパックを注文し、赤と白の縦縞が入った紙パック片手に駅の階段を降りた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "麹町の駅前で買った紙パックを開け、もうすっかり冷えてしまったフライドチキンをたちまちのうちに全部平らげてしまう。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
