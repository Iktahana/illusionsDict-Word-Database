        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "シルクロードの要衝として知られる甘粛省は、歴史的な遺跡が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人が甘粛省を旅行し、美しい砂漠の風景と独特の民族文化に感動したと話していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "甘粛省産のメロンは、その糖度の高さで全国的に有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "中国の地理の授業で、甘粛省の年間降水量が非常に少ないことを学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一九二〇年のシナ甘粛省の地震には十万人の死者を生じた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "成吉思汗が、甘粛省のトルメカイで死んだというのみで、その後彼の墓がいずこか分らないのも、おそらく此処へ運ばれたのではないかといっている。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "北京版の甘珠爾は甘粛省敦煌の雷音寺（千仏洞）の経窟におさめられているが、毎年、五月初めの灌仏会大法要には、一切経を拝むために、青海のツァイダン王や、甘粛新彊の端郡王までが、はるばる敦煌まで出かけて行くくらいのものである。",
              "citation": {
                "source": "新西遊記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "董卓、字は仲穎、隴西臨※（甘粛省岷県）の生れである。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大権転々一　西涼（甘粛省・蘭州）の地方におびただしい敗兵が流れこんだ。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「西涼州（甘粛省・陝西奥地一帯）の太守｜馬騰をお召しになり、彼の擁している匈奴の猛兵や、今日まで無傷に持たれている軍需資源をもって、玄徳を討たせるのです。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "西涼ふたたび燃ゆ一　忽然と、蒙古高原にあらわれて、胡夷の猛兵をしたがえ、隴西（甘粛省）の州郡をたちまち伐り奪って、日に日に旗を増している一軍があった。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――遼東｜鮮卑国（遼寧省）の兵五万が、西平関（甘粛省・西寧）を犯して四川へ進攻して来るもの。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして南安郡（甘粛省・蘭州の東）の城中へ入り、これへ諸方の大軍を吸って堅固を恃んだ。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてこの大軍が、やがて蜀境の西平関（甘粛省）へ近づいていた頃、寝耳に水、いま祁山と渭水のあいだに在る孔明の所へ、「西部の動きただならず、急遽、援軍を仰ぐ」との早馬があった。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "祁山（甘粛省・鞏昌附近）一帯の山岳曠野を魏、蜀天下の分け目の境として、まさにその第一期戦はここに展開されようとしている。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
