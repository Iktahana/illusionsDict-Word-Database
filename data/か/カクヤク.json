[
  {
    "uuid": "00d62991-6676-525d-aec6-7962ecd6607d",
    "entry": "確約",
    "reading": {
      "primary": "かくやく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
