      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "firm promise",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「社長から直々に次期プロジェクトのリーダーを任せると確約を貰い、身の引き締まる思いだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「契約書を交わすまでは、口頭での確約だけで安心するのはまだ早い。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「彼は一度も確約を破ったことがなく、その誠実な仕事ぶりには定評がある。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「融資の確約を取り付けるために、何度も銀行へ足を運んで事業計画を説明した。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてその手落ちによって、つまり彼がエスパニヤ国王に提出した条件中にオランダとの断交を確約する文章がなかったために、彼の最も希望する新エスパニヤ（今のメキシコ）との通商は拒否せられてしまった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある一瞬にわたしが遭遇することを確約されてゐる感覚の消滅といふ現象を、その肉体ではつきり捉へ得るチャンスは、なんといつても、貴重で、魅力的だ。",
              "citation": {
                "source": "カライ博士の臨終",
                "author": "人生の最も厳粛であるべき瞬間に、わたくしがもし笑ひの衝動をおさへることができぬとしたら、いつたいどんな罪に問はれるであらう？",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、陛下を制限から除外する確約を得ないうちに、無条件降伏したことを不満に思うものがこの艦にもいて、不穏な空気が出来かけ、司令部から島野参謀が説得に来られたのですが、馬鹿なやつのために怪我をなすったのです。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に記者は、では来月号に執筆する確約をうけとると、やっと座を立った。",
              "citation": {
                "source": "芥川の原稿",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "才なくとも才なきままに救われる道が確約されているのである。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく機械文明で人間の幸福が確約されない事も充分反省されてよい。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで、伝統は充分なる報酬をそれらの人々に確約致します。",
              "citation": {
                "source": "益子の絵土瓶",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてモルガニの記しているところによるとこの男はこの手紙を非常に喜んで絶えずもっともっとと要求し「彼は私が70才になるまで引っぱり、……内容を改訂するから返して欲しいと言っても返してくれず、ついに最後には内容を簡単にはしないと私に確約させた。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、第六部はどうするか、ときかれても、それは第五部の場合のこともあり、確約は差控えたい。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう確約もしてもらったのです。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして最後に、お役所式の仕事がすでに終ってしまっていること、何かの理由からあの確約を取り下げてしまったのであり、バルナバスはもう制服をけっして手に入れないということを意味するのかもしれません。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがどんな歌だったかは詳らかではありませんが、智慧の到来を確約する何か、完全なる日が近いことを確約する何かで、その要旨は地上の全ての国にとっての希望でありました。",
              "citation": {
                "source": "夕映えのむこうの国",
                "author": "時代を超えた童話",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして、しかも確然たる現実的効果があるか、つまり救ひは確約されるか否か――もとより「私」のはからひとすべきことではない。",
              "citation": {
                "source": "帰依と復活",
                "author": "龜井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やり方さえ分かれば簡単なはずだ」　俺なら現場で衝突せずうまくやると、あわててリスキに確約した。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "メアリが熱く確約してくれたのは非常にありがたいが、そんな厚い信頼も揺らぐのは、錠前に比べて鍵がちんけに見えるからだ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ以上確実なことはありません、トリガーセンはルースとは結婚しません」　メアリが冷静に断定したので、トリガーセンさえびっくりして、権力が確約され不死身であるということから目が覚めた。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、松平伊豆守が（ひそかに）各方面に運動し、老中筆頭の松平定信、若年寄の安藤対馬守、溜間詰の大久保加賀守、板倉左近らを説得、さらに水戸宰相治保からも援助の確約を得た。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧臘のこと青山学院の寄宿舎にいる栗原彦三郎が本田庸一院長の紹介状をもって訪れた結果、津田は栗原に案内させて日帰りで被害地を一巡し、その惨憺たるありさまに感奮して「田中正造を山師だと思いこんでいたのは自分の誤であった」と述懐するとともに、今後の尽力を確約したということだった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "「明日の一番でゆくから案内を頼む、必ず行く、多少の雨や雪にはかまわん」　そうした確約を得たので、一同はよろこんで事務所へ帰り、関口、山田等が被害地に於ける出迎えの準備のために現地へ出発した。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "またラケダイモンの立法者は、一生かかって、自分の布令がただの一カ条といえども変更されないという確約を、その市民から得たのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしが十分動けることを確約させますから、ジェシ・ハーコートとしてあなたの家まで馬車で参ります。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、確約できかねます。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食には戻ってくるつもりだが、全く確約できない。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩レッジポイントに戻られたら、本官の見立てを説明しましょう」　グラントは確約できなかったが、警部は自説に酔って、帰って行った。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日とか、明日とか、来週に行う必要はありませんが、アブサラムに出走取り消しを確約すれば、きっと差し押さえが止まり、たぶんあなたの借金も帳消しにするよう取りはからうでしょう。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢さんからまだ確約をもらっていません。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "確約してもいいですが、出走すれば勝つでしょう。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "その点は確約できません。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ長いか短いかだけだ』『いくら精鋭な衛林の軍と高い城壁で守ってもだめかね』『そんな事に力を入れれば入れるほど滅亡の日を確約するだけのことさ。",
              "citation": {
                "source": "人間山水図巻",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰌の五感は鳴り響けり、彼らは粗野なり、真に驚く、鰌のをどるは苦しきなり、彼いま燦爛かくやくたる光に飛ぶ。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
