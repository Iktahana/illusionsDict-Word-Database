          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "The traveler, having arrived late in the port town, was directed to the district where houses of pleasure, often referred to ambiguously, were located.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "In certain entertainment quarters, the term \"川竹\" might have been used to refer to women who offered companionship, though the practice itself was subject to strict regulations.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "Old tales sometimes speak of clandestine meetings in teahouses near the river, hinting at liaisons that were part of the city's hidden life.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
