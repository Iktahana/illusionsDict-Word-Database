          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "The landscaper chose Simon bamboo for its graceful appearance, planting it to create a natural screen around the garden.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "Its slender culms and dense foliage make Simon bamboo ideal for decorative hedging and creating a sense of privacy.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "During the rainy season, the water droplets clinging to the Simon bamboo leaves glistened like tiny jewels.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
