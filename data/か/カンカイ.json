[
  {
    "uuid": "a2061a40-78c1-5685-9c6f-a29870988926",
    "entry": "官界",
    "reading": {
      "primary": "かんかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bureaucracy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は官界に身を置きながらも、常に現場主義を貫いて改革を訴え続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "官界と財界の癒着が明るみに出ると、世間からは厳しい批判の目が向けられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長年勤めた官界を去り、第二の人生として故郷での農業を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若きエリートたちが官界の古い慣習に立ち向かい、組織を刷新しようとしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それゆえ学窓を出て官界に入り、身辺の世のなかの現実に触れた時、勝手がまるで違ったように、上官や同僚がすべて虚偽と諂諛の便宜主義者のように見えて仕方がなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでは如何に才学が有って、善良な人であっても、世間を危気無しには渡って行かれなかったろうと思われるから、まして官界の立身出世などは、東西｜相距る三十里だったであろう。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "調子のよいときの武帝は誠に高邁闊達な・理解ある文教の保護者だったし、太史令という職が地味な特殊な技能を要するものだったために、官界につきものの朋党比周の擠陥讒誣による地位（あるいは生命）の不安定からも免れることができた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "官界に出ないのなら、どうしても実業界に行かなければうそだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この貴重な秘庫を民間奇特者に解放した一事だけでも鴎外のような学術的芸術的理解の深い官界の権勢者を失ったのは芸苑の恨事であった。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "局長が官界の逸民たる高橋健三で、翻訳課長が学界の隠者たる浜田健次郎、その下に古川常一郎、陸実等、いずれも聞ゆる曲者が顔を列べ、而して表玄関の受附には明治の初年に海外旅行免状を二番目に請取って露国の脳脊髄系を縦断した大旅行家の嵯峨寿安が控えていた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "揃いも揃って気骨稜々たる不遇の高材逸足の集合であって、大隈侯等の維新の当時の築地の梁山泊知らず、吏臭紛々たる明治の官界史にあっては恐らく当時の官報局ぐらい自由の空気の横流していたはけだし類を絶しているだろう。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥田は東京市の名市長として最後の光栄を柩に飾ったが、本来官僚の寵児で、礼儀三千威儀三百の官人｜気質の権化であったから、豪放｜洒脱な官界の逸人高橋自恃庵が作った放縦自由な空気は忽ち一掃されて吏臭紛々たる官場と化してしまった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々、かつて尾崎さんが二階借りしていた家の前を通るのだが、朽ちかけた、物干しのある部屋で、尾崎さんは私よりも古く落合に住んでいて、桐や栗や桃などの風景に愛撫されながら、『第七官界彷徨』と云う実に素晴らしい小説を書いた。",
              "citation": {
                "source": "落合町山川記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文壇と云うものに孤独であり、遅筆で病身なので、この『第七官界彷徨』が素晴らしいものでありながら、地味に終ってしまった、年配もかなりな方なので一方の損かも知れないが、この『第七官界彷徨』と云う作品には、どのような女流作家も及びもつかない巧者なものがあった。",
              "citation": {
                "source": "落合町山川記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……のみならず、その復讐事件の真相なるものをモウ一つ奥の方へ手繰って行くと、現在、内地朝鮮の官界、政界、実業界に根強い勢力を張り廻わしている巨頭株の首を珠数繋ぎにしなければならぬという、日本空前の大疑獄が持ち上って来る事、請合いだ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　支那人の妥協性（二）　妥協の流行は官界でも民間でも相違はない。",
              "citation": {
                "source": "支那人の妥協性と猜疑心",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治五年の夏、和上は官界を辞してぶらりと帰つて来た。",
              "citation": {
                "source": "蓬生",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は本多子爵が、今でこそ交際嫌いで通っているが、その頃は洋行帰りの才子として、官界のみならず民間にも、しばしば声名を謳われたと云う噂の端も聞いていた。",
              "citation": {
                "source": "開化の良人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "官界にも政界にも空間が足りなかった。",
              "citation": {
                "source": "古木",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争犯罪の摘発が行われ、官界や政界から公職追放者が続出しそうな形勢になった頃から、この文化研究所は既に発足していた。",
              "citation": {
                "source": "波多野邸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく官界の連中が総出というのだそうだからねえ」　彼女は焦燥たそうな眼つきをして、「貴郎は一体私に何を着せて下さるおつもりです？",
              "citation": {
                "source": "頸飾り",
                "author": "モウパンサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の堕落こゝに至る、私が暗然として昔の救世軍本部を仰いで祖国のために暗涙を流したのもムベなるかな、今日つひに敗北し、戦争十年の日本の腐敗、官界軍閥の堕落のあとを眺めれば、郡山などは最もマトモな紳士であつたではないか。",
              "citation": {
                "source": "足のない男と首のない男",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、二十六日の爆弾の破片から身をのがれるためではなくて、博士が十五年前に装填した長期性時限爆弾に関して、問い合わせに殺到した官界財界その他ありとあらゆる職業部面の、概算三千人の群衆からのがれるためであった。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが社は最近政界官界財界の裏面をバクロしたバクダン的手記を出版することになったのでね。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりボクが使い走りにでるとぶん殴られる怖れがあるし」「誰がぶん殴るんですか」「政界官界財界のボスのコブンだな」「社員ならぶん殴られないのですか」「そうでもないらしいがね。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今日の我々が「官場現形記」を読むと、官界の腐敗堕落の諸相は清朝のものではなくて、そッくり日本の現実だ。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本官界の現実は亡国の相であり、又、戦争中の軍部、官界、軍需会社、国策会社も、まったく清朝末期の亡国の相と異なるところがない。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "政界、官界、財界などの裏面のカラクリというものは、巷談のタネではなくて、「真相」というバクロ雑誌などの対象だ。",
              "citation": {
                "source": "安吾巷談",
                "author": "巷談師退場",
                "note": "青空文庫"
              }
            },
            {
              "text": "「真相」の記事は、政界、官界、財界などの裏面については、相当正確だということである。",
              "citation": {
                "source": "安吾巷談",
                "author": "巷談師退場",
                "note": "青空文庫"
              }
            },
            {
              "text": "政界、官界、財界などのカラクリにくらべれば、邪教のカラクリなどは無邪気なものだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "巷談師退場",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「地主よ、地主に目がつかんかい、地主に。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕が友人の未亡人さん達の世話を焼いてるのを、何とか言つてる人もあるさうなが、君は聴かんかい。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "トッパと綽名の大阪の円タク助手出身の、万年一等兵が、岡田という良家の子で、大学出の初年兵にムリヤリ剣つき鉄砲を握らせ、「それッ突かんかい、一思いにグッとやるんじゃ」と喚き散らし、大男の岡田が殺される相手の前で、同様に土気色になり眼をつぶり、ブルブル震えているのを見ると、業をにやし、「えエッ。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間の方はいくらでもありますが、この洋服は今日限御返納に及びたいです」「ハハハハいかんかい。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
