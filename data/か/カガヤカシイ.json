[
  {
    "uuid": "c12433fa-443b-50b9-8804-1a0069ace149",
    "entry": "輝かしい",
    "reading": {
      "primary": "かがやかしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
