    "definitions": [
      {
        "index": 1,
        "gloss": "kama (desire, wish, or longing; one of the goals of life in Hindu tradition)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この人のアインシュタインに対する関係は、一見ボスウェルのジョンソン、ないしエッカーマンのゲーテに対するようなものかもしれない。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーマ・スートラ・レコードは、やっと日本の配給会社が決まったばかりで、まだシングルしか発売になっていない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "序文に揚げましたる文献に名の出てゐるアッカーマン氏は、ロンドン大學出の工學士であります。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "序文に揚げましたる文献に名の出ているアッカーマン氏は、ロンドン大学出の工学士であります。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏訳になった印度のカーマストラが堂々たる新刊屋の店頭の一線に立ててある。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が婦人作家の新しいタイプとして認めているメアリー・カーマイクルの文学の世界は、メアリーが女性としてこの社会に既に獲ている有利な諸条件の認識から出発しているであろうか。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーマイクルの現実がそうであったように婦人と文学との歴史の過程で重大なのは、寧ろまだ獲ていないものに対して、その世代及び個人がどういう評価と認識をもって、獲て行こうとしたかという点である。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてウェールズにおける第一回の演説は反抗心に満てる聴衆を前にしてカーマーゼンといえる所にて催されしが、当時における彼の精神は、次の一句の中に活躍していると思う。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "たといあすからはこのカーマーゼンに一人の友人もなくなろうとも。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "パオロ・カーマンセラー嬢。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しさすがは、カーマ・スートラを所有する印度のことだ。",
              "citation": {
                "source": "「沈黙」の話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この博覧会に、カーマンセラ嬢電気の舞というのがあった、これを何うかして見たいが見せてくれそうにない。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、カーマンセラなるものを見に行った。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "スカートを大きく拡げるカーマンセラに、色電気を当てるだけの事である。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は童貞のころ、カーマスットラを読み、アナーガランガを読んだ。",
              "citation": {
                "source": "余はベンメイす",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も、もし、カーマスットラを読んだ頃のこの現実に絶望しない童貞の頃だつたら、まつさきに、これらの雑誌を読んでみたに相違ない。",
              "citation": {
                "source": "余はベンメイす",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり淫乱の国天竺には現実を化して詩たらしめんとする聖なる輩が現れて、ここにカーマスツトラを生みアナアガランガをつくり常にリンガ・ヨオニに崇敬を払って怠ることがないから法悦極るところなく法を会得し、転じて一方には聖なる苦行断食の徒を生み出して彼等には幻術の妙果を与えるに至ったのじゃよ。",
              "citation": {
                "source": "木枯の酒倉から",
                "author": "聖なる酔っ払いは神々の魔手に誘惑された話",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり淫乱の国｜天竺には現実を化して詩たらしめんとする聖なる輩が現れて、ここにカーマスットラを生みアナアガランガをつくり常にリンガ・ヨオニに崇敬を払つて怠ることがないから法悦極るところなく法を会得し、転じて一方には聖なる苦行断食の徒を生み出して彼等には幻術の妙果を与へるに至つたのぢやよ。",
              "citation": {
                "source": "木枯の酒倉から",
                "author": "――聖なる酔つ払ひは神々の魔手に誘惑された話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその花は恋の象徴すなわちシムボルで、それを恋愛の神であるカーマ（Kama）に捧げられる。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事をいっていたんでは何の事やらお判りになるまいから、ちょっとあと戻りして事の次第を叙述しように、昨夜古市加十と宗皇帝が「巴里」を出て行くと間もなく、明元日から日本座で開演する生粋のアメリカレビュー団「カーマス・ショオ」の男女優が舞台稽古を終えてドヤドヤと乗込んで来た。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "事のついでにちょっと「カーマス・ショオ」について述ベると、これは紐育の大ジーグフェルドに次ぐ世界的レビュー団とあって、まだレビューらしいレビューを見たことのない日本では、この一座が来朝するという評判だけでもう大変なのぼせ方。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の優しいのも道理、このカーマス・ショオはブロードウェイ生粋のレビュー団でも何でもなく、実は上海から香港の間で駆り集めた田舎廻りの寄席芸人の一団で、中には昨日まで大馬路の闇に咲いていたなどという劇しいのもいた。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……御承知の通り、昨夜カーマス・ショオと引ッつるんでお道楽を致しましたのはわれわれ六人だけじゃない。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへまた有明荘住人の一人、「ホヴァス」通信社のハッチソンが、「カーマス・ショオ」の団長なる相棒のバロンセリを尋ねてやって来て、今朝有明荘六人の住人が全部明石署へ便宜拘束された次第を物語る。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒月の娘、すなわち幸田の愛妾悦子はとめ婆を連れて今日初日の「カーマス・ショオ」の見物に出掛け、酒月は自然に留守居の形になってここに坐り込んでいるんだが、それにしても幸田が出かけてからもう五時間になる。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "外套の襟を掴んでグイと引き寄せると、「おいバロンセリ、なんで逃げ隠れする」　読者諸君も御存知でしょう、例の「カーマス・ショオ」。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "合図された男は一歩出ると、簡単明瞭な口調で、「有明荘の居住者、岩井通保、印東忠介、ジョン・ハッチソン、山木元古、村雲笑子、川俣踏絵の六名は「カーマス・ショオ」の六名と共に三台の自動車に分乗し、三時十分に「巴里」を出発し、同三時廿分に築地小田原町の待合「すず本」に到着しております。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カーマス・ショオ」の六名を取調べましたが、有明荘の六名は臨検の時間まで一人も外出しなかったと申立てております。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……昨夜、笑子の酒場でわれわれ六人が有明荘の忘年会をやり、「カーマス・ショオ」のバロンセリがぜひ口明けをしてくれというんで、われわれ六人とショウの六人とひッつるんで「巴里」を出たのが午前三時ごろ。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一旦警視庁にとって返すと、例の四銃士を呼び寄せて、今暁有明荘の六人が「カーマス・ショオ」の六人とつるんで泊り込んだ築地の待合「すず本」の検証、現警視総監すなわち前京都府警察部長と松谷鶴子の身元調査、並びに元日の午前三時五十分から四時五十分までの総監の行動調査を命じた。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
