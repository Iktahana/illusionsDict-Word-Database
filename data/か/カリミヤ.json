        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "社殿が落雷で焼失したため、急遽プレハブ小屋を仮宮として遷座祭が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「遷宮が終わるまでは、こちらの仮宮にお参りいただくことになります」と巫女が案内する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "奈良の山奥には、かつての皇族が隠れ住んだという伝説の仮宮跡がひっそりと残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祭りの期間中だけ砂浜に建てられる仮宮に、潮風に乗って波の音が響く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その鷺宮の仮宮へ、高倉テル君が罹災者の姿で訪れてきた。",
              "citation": {
                "source": "三木清を憶う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "故、出雲に到りまして、大神を拝み訖へて、還りのぼります時に、肥河の中に黒樔橋を作り、仮宮を仕へ奉りて、坐さしめき。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日は、お札の降ったところの原の真中に、白木造りの仮宮が出来ました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩には仮宮の前へ、誰がするともなく、おびただしい鏡餅の供え物です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中心地、小金ヶ原へ一夜のうちに出来た仮宮の宮柱も、みるみる太くなりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮宮は何の神様であるか知らないが、その御本体を大切にするよりは、茂太郎と弁信の御機嫌を取ることが大事であるらしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分は、母の帝が板蓋宮炎上のあとで、暫く仮宮に使つてをられた川原の古宮に黙々として起居しながら、妃の莵野ノ王女の眼をぬすんでは通つてくるのだつた。",
              "citation": {
                "source": "鸚鵡",
                "author": "『白鳳』第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "本殿から仮宮までの十町の道には、一間幅にずっと白砂が敷いてあるので、道筋だけはようやくわかるくらいなもの。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "猫眼の男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――氏経様は、その中を、時の権力や貧苦とたたかい、諸人を説きあるいて、やっと明応の六年ころ、仮宮の御遷宮をすることができたというのです。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "後で聞けば、輿の上※は、吉野の仮宮に仕える内侍所の女性で、何かのお使いで東条の城へ見えた途中であったという。",
              "citation": {
                "source": "日本名婦伝",
                "author": "大楠公夫人",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の正行が出陣の折、吉野の仮宮まで、行を共にして、そこから別れて城寨へ帰って来た三男の正儀は、戻るとすぐ、母の居間に姿を見せて、「母うえ。",
              "citation": {
                "source": "日本名婦伝",
                "author": "大楠公夫人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仮宮も出来あがったから、とりあえず、太牢を供えて、宗廟の祭を営もう」　袁紹は、諸侯の陣へ、使いを派して、参列を求めた。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぜひもありません」　董承は、頭をたれて、「――この上は、再び、仮宮をお捨てあって、曹操が方へ、お落ちになられるが、上策かと思われますが」　すると、楊奉、韓暹の二人がいった。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、曹操は、さして驕らず、すぐ帝にまみえて、しかも、帝のおゆるしのないうちは、階下に低く屈して、貧弱な仮宮とはいえ、いたずらに殿上を踏まなかった。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "山頂だけに、小雨をもった烈風が蔀や廂を吹きなぐり、仮宮にしろ、これが天皇の御寝ある皇居かと怪しまれるほどだった。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮内庁三階の仮宮殿南ノ間が私たちの控えで、そしてそこの廊下を右折した西ノ間がすぐ授与式にあてられていた。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出された鮨には手をつけず、それをすっかりみやげに持ってゆくと主張しました。",
              "citation": {
                "source": "落雷のあと",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私らは吾妻橋から上手の隅田川にばかりみやこ鳥がいて、大川にはいないものと思ってきた。",
              "citation": {
                "source": "みやこ鳥",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
