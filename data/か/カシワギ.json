          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "公園の隅にある柏木は、秋になると見事な紅葉を見せる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "柏木から落ちた葉が、歩道を一面に敷き詰めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "柏木の根元には、小さな野花がひっそりと咲いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "雪枝、言いにくそうに、Ｔ「柏木先生なら　たった今、親分の　処へと仰有って……」　半次が不審そうに、Ｔ「柏木先生……？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うんじゃ　ないでしょう」　雪枝も不審そうに、Ｔ「確か昨夜　柏木と仰有ったが」　聞いた半次愈々訳分らぬ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二の時に、柏木の叔父さんが、私の綴方を「青い鳥」に投書して下さって、それが一等に当選し、選者の偉い先生が、恐ろしいくらいに褒めて下さって、それから私は、駄目になりました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、そのすぐ次に、やっぱり柏木の叔父さんにすすめられて、「春日町」という綴方を投書したところが、こんどは投書欄では無しに、雑誌の一ばんはじめのペエジに、大きな活字で掲載せられて居りました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柏木の叔父さんにおだてられて、うっかり投書したのが、いけなかったのでした。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柏木の叔父さんは、母の弟です。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまはまた違うようになりましたが、その頃は、私のたわいも無い綴方が、雑誌に二度も続けて掲載せられて、お友達には意地悪くされるし、受持の先生には特殊な扱いをされて重苦しく、本当に綴方がいやになって、それからは柏木の叔父さんから、どんなに巧くおだてられても、決して投書しようとはしませんでした。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、柏木の叔父さんだけは、いつまでも、うるさく私を、からかうのです。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と泣きたい気持で、父の顔を見上げたら、父も、それはちゃんと見抜いていらっしゃった様子で、小さく首肯き、「柏木の弟も、わるい気でやっているのではないだろうが、こちらでは岩見さんへ、なんと挨拶したものか困ってしまう。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は前から、柏木の叔父さんを、あんまり好いてはいなかったようでした。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て、木下さんの柏木の邸の、矢張り庭の池の蛙を捉へて、水掻の附元を（紅い絹絲）……と言ふので想像すると――御容色よしの新夫人のお手傳ひがあつたらしい。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その友を集えた席は、長谷川町の梅の家、万町の柏木亭等であった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "淀橋の柏木成子町に井戸屋という古い店がある。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹角みちのくの谷の若人、牧の子は若葉衣の夜心に、赤葉の芽ぐみ物｜燻ゆる五月の丘の柏木立をたもとほり、落ちゆく月を背に負ひて、東白の空のほのめき――天の扉の真白き礎ゆ湧く水のいとすがすがし。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知の通り、ここは青梅街道の入口で、新宿の追分から角筈、柏木、成子、淀橋という道順になるんですが、昔もなかなか賑やかな土地で、近在の江戸と云われた位でした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十四年（一九二五年）二月二十四日東京市外柏木において内村鑑三夏期演説　後世への最大遺物第一回　時は夏でございますし、処は山の絶頂でございます。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十四年（一九二五年）二月二十四日東京市外柏木において内　村　鑑　三夏期演説　後世への最大遺物　　　　　　第　一　回　時は夏でございますし、処は山の絶頂でございます。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一〇年六月二十三日東京市外柏木において内村鑑三回顧三十年　この書今年を以て発行満三十年に達す。",
              "citation": {
                "source": "基督信徒のなぐさめ",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌年の早春に、淀橋・柏木。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同朋町、和泉町、柏木、私は二十四歳になっていた。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の長兄に、出鱈目な事を言ってやって、二箇月分の生活費を一度に送ってもらい、それを持って柏木を引揚げた。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間の新聞などでは、幸徳君らとわたしらとを一まとめにして柏木団（かしわぎだん）と呼んだりしていた。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際その連中の多くは柏木、淀橋あたりに住んでいて、それが一団となって金曜会というを作り、毎週神田で講演会をやったりしていた。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ近所の或る口利きの男は、これも大杉と私と友人関係であるのを知らないで、「柏木には危険人物がある、大杉一味の主義者を往来へ列べて置いて、片端からピストルでストンストン打ったら小気味が宜かろう」とパルチザン然たる気焔を吐いてイイ気持になってるものもあった。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大杉は一時は米塩にも事欠いた苦境に苦んでいた事もあったが、最後の柏木に落付いた時は八十円の家賃を払い、奉公人も置き、夫婦から児供までが洋装でかなり贅沢な生活をしていた。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大杉が柏木へ移転して来て久しぶりで会った時、私が第一に訊いたのはまたこの洋行費の出処であった。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田お玉ヶ他に徳川様のお大工｜棟梁をしていた柏木稲葉という人の養子になって柏木貨一郎と名乗っておった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大隈綾子刀自の思い出",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人もまた美術愛好家であって、夏雄さんの彫り物では鏡蓋、前金具、煙管など沢山に所持しており、また古いものにも精通しておられ、柏木貨一郎というとその頃の数寄者仲間には知られた人で、同氏が所持していたものといえば、それを譲り受けるにも人が安心した位、信用のあった人でありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大隈綾子刀自の思い出",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
