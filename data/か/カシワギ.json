        "examples": {
          "standard": [
            {
              "text": "源氏物語のかしわぎは、高貴な身分でありながらも苦悩を抱える人物として描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "平安時代の宮中では、かしわぎの職に就くことは大変な名誉だったという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はかしわぎとして、天皇の警護にあたる重責を担っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
