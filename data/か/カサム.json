[
  {
    "uuid": "3817583a-3ae1-589a-80d7-bf6d13f5377e",
    "entry": "嵩む",
    "reading": {
      "primary": "かさむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
