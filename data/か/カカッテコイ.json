        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「何でも来い！かかって来い！」と彼は叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「そっちがその気なら、こっちだって負けないぞ、かかって来い！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "（ゲームで）「よし、次のボスだ！かかって来い！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「これくらいで怯むと思うなよ、かかって来い！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "さあ、次郎左衛門に意趣遺恨があるなら、まともに向いてかかって来い」　その権幕が余りに烈しいので、栄之丞は煙にまかれた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "冥途急ぎのしてえ奴からかかって来い！",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとういちばんおしまいに金太郎が土俵のまん中につっ立って、「さあ、みんなかかって来い。",
              "citation": {
                "source": "金太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんないっぺんにかかって来い。",
              "citation": {
                "source": "金太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「よし、残らずかかって来い。",
              "citation": {
                "source": "猫の草紙",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、来いっ、かかって来いっ」　六人の内、三人は、棒を持っていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "怨みがあるなら尋常に宣って、真っ正面からかかって来い！",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "口惜しくば立ち上がってかかって来い！",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかって来い勘兵衛、この天国の剣で真っ二つにいたしてくれるわ！",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……俺を父親の敵と思い――事実それに相違ないし……その敵を今討つのだと、こう思って真剣にかかって来い」「うむ。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実戦の意気込みでかかって来いと、いわば挑戦をされたようなものだ。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人一緒にかかって来い。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものの五間ほど飛び退ってから、やや暫らくして、「やい、出て来い、かかって来い、隠れていちゃあ相手にならねえ」　ようやくのことで米友は、これだけの言葉を出すの余裕を持つことが出来ました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "如法闇夜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつになったら元服するのか、もう二十三、四歳にもなろうというのに、相変らず前髪を捨てず、片肌ぬぐと、眼を奪うような桃山｜刺繍の襦袢を着、掛け襷にも、紫革を用いて、「枇杷の木で打たれると、骨まで腐ると申すから、それを覚悟でかかって来い。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "死にたけれや、かかって来いっ」　公孫勝も道士の持つ無反の戒刀をかざして構えた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「受けた、みんなかかって来い。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ来い」「そんな足拍子はやめて、てめえからかかって来い」「こころえた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この虚無僧には、少し縁引のある某、義に依って助太刀するから、束になってかかって来い」「や、御曹子の新九郎だとッ」「その男なら、こっちから尋ねていたところ、事ついでに素ッ首を刎ねてやるから覚悟をしろ」「何を」　と、雄叫びを揚げるや否、右に大剣、左に小剣、バラバラと斬って廻った。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理に、彼を拉して来た若侍たちは、そこへ来るといきなり、「それッ、木剣でも、槍でも持って、かかって来い」　と、日吉の背を、突き放した。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「槍を持て」「はい」「いつものように構えて、父を父と思わず突ッかかって来い」　小六も槍を向けた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "さッ、かかって来いッ！",
              "citation": {
                "source": "鳴門秘帖",
                "author": "木曾の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、そっちのひょうげた野郎もいっしょにかかってこい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きみはぼくをなぐったね」「無論だ、文句があるならかかってこい」「柳君！",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕相撲をやるから、かかってこい」「それはいけません。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳生一刀流にはむかう気なら、かかってこい」　なんかと、駕籠かきと長屋の人々と、ワイワイいう騒ぎだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "木剣のつもりでかかってこい！",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野郎共束になってかかってこい、拳骨壮太さまがお相手だ、サア来い※」　怪しい支那人に取巻かれた真中に仁王立になって、喚いているのは拳骨壮太だ。",
              "citation": {
                "source": "謎の頸飾事件",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ豚共、かかってこいっ※」　叫びざま、いきなり取巻いている支那人の荒くれ男の一人に跳掛っていった。",
              "citation": {
                "source": "謎の頸飾事件",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だめですよ」「さあ、かかってこい」「かないませんよ」　と正三君は逃げ出そうとした。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにをする」「家来、正三位、くやしければかかってこい」「僕は喧嘩はきらいだよ」　と正三君は相手にならない。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
