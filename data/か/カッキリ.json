    "definitions": [
      {
        "index": 1,
        "gloss": "exactly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この二つの絵は、色がかっきり同じで、見分けがつかないほどだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の説明は、複雑な状況をかっきり整理してくれて、とても分かりやすかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "二人の意見がかっきり対立し、議論は平行線をたどった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "峰には未だ、残の雪がかっきりと、白く浮き上って見えるほどである。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "足もとは暗いが、木の梢だけは、夜の空にかっきりと黒く張って、穂高の輪廓は、ボーッと、物干棹でも突き出したように太く見える。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あゝ、十一時かっきりには着くんだよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとあの鳥捕りは、すっかり注文通りだといふやうにほくほくして、両足をかっきり六十度に開いて立って、鷺のちぢめて降りて来る黒い脚を両手で片っ端から押へて、布の袋の中に入れるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その正面の青じろい時計はかっきり第二時を示しその振子は風もなくなり汽車もうごかずしづかなしづかな野原のなかにカチッカチッと正しく時を刻んで行くのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　時計の黒い針は、かっきりと夜中の四時を指し、窓のガラスはすっかり氷で曇ってゐました。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく他家の雑煮を食うときに「我家」と「他家」というものの間に存するかっきりした距たりを瞬間の味覚に翻訳して味わうのである。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、十一時かっきりには着くんだよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとあの鳥捕りは、すっかり注文通りだというようにほくほくして、両足をかっきり六十度に開いて立って、鷺のちぢめて降りて来る黒い脚を両手で片っ端から押えて、布の袋の中に入れるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その正面の青じろい時計はかっきり第二時を示しその振子は風もなくなり汽車もうごかずしずかなしずかな野原のなかにカチッカチッと正しく時を刻んで行くのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "裾のぼやけた、そして全体もあまりかっきりしない入道雲が水平線の上に静かに蟠っている。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとあの鳥捕りは、すっかり注文通りだというようにほくほくして、両足をかっきり六十｜度に開いて立って、鷺のちぢめて降りて来る黒い脚を両手で片っぱしから押えて、布の袋の中に入れるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その正面の青じろい時計はかっきり第二時を示し、風もなくなり汽車もうごかず、しずかなしずかな野原のなかにその振り子はカチッカチッと正しく時を刻んでいくのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "では今日は練習はここまで、休んで六時にはかっきりボックスへ入ってくれ給え。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小十郎は自分と犬との影法師がちらちら光り樺の幹の影といっしょに雪にかっきり藍いろの影になってうごくのを見ながら溯って行った。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもの会社ももうかっきり今日ぎり解散いたしまして酒は全部私の名義でつくったとして税金も納めます。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口は思い切り大きい両開きの木の扉が左右に裏板を見せて、ほの暗い内部を透かした向うにかっきりした長方形の雨空と緑との画面がうち明っていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫紺の波、波、うねり波、　光、光、光、光、金の閃光、運動、　かっきりした水平線、　鳥だ、あ、ロッペン鳥だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "樫の木の葉のついたままのを、かっきり畳一枚敷位の広さに編んだ。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、今度はかっきり、奴の鼻の先きを目がけて流してやったが、何と、その山女魚奴！",
              "citation": {
                "source": "信濃の山女魚の魅力",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳がまさに汚濁せる潮水のために浸ろうとする時、まさにその時期にかっきり達している彼の妻君は、生理上の法則に従って、赤ん坊を分娩した。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、糧食は、かっきり予定航海日数だけが、積み込まれていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、かーっといってお吐きなさい……それもう一度……どうしようねえ……八っちゃん、吐くんですよう」　婆やは八っちゃんをかっきり膝の上に抱き上げてまた脊中をたたいた。",
              "citation": {
                "source": "碁石を呑んだ八っちゃん",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十秒ごとにこれを繰返し、かっきり三分間にして号令のもとに一斉に湯から出るのである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれかこれかと選み始めたが、サテそうなると多い様でもかっきり都合のいいのになかなか行き会わなかった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾城買にかけては日本無類の藤十郎様を、今度はかっきりと気を更えて、密夫にしようとする工夫じゃ。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰と日向の段落がかっきりして――顔だけでも非常におもしろい変化がある」「いや皆御当人のお好みだから。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「かっきり十時に出ました」「それから真直に家へ帰ったか？",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "社を出たのがかっきり十時、それで君が家の門口まで帰ったのは今朝の一時二十分過ぎだ。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
