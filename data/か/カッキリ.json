        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "会議は9時開始と決まっていたので、皆かっきり時間通りに集まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "電車はかっきり終電の時刻に発車したので、乗り遅れるところだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "約束の時間はかっきり正午。遅れるわけにはいかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "clearly delineated (of boundaries, etc.)",
