[
  {
    "uuid": "33bdfaa1-b0ed-5d79-bcbc-97a887b802e2",
    "entry": "悲しむ",
    "reading": {
      "primary": "かなしむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be sad",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "試合に負けて、選手たちは皆悔しそうに肩を落とし悲しんでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遠く離れて暮らす家族を思い、時折一人静かに悲しむことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子どもが転んで泣き出したので、一緒に悲しんで慰めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は友人の不運を自分のことのように悲しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "議論の内容如何に拘わず、議論することそのことが癪だといふ、女ならでは夜の明けぬ、悲しむべきことではあるまいか。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しむ、私よろこばないです。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの男について言つてみれば、この男はその悲しむ段となつてはまるで無意識家と同しなのです。",
              "citation": {
                "source": "小林秀雄小論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、悲しむ段となつてだけ無意識なんてことがありませうか？",
              "citation": {
                "source": "小林秀雄小論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがどんなに悲しむべきことであるかは、知る人ぞ知る、とても悲し過ぎて、今茲で簡単にその証明をするわけには行かぬ。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何で年よる」という言葉の響に、如何にも力なく投げ出してしまったような嘆息があり、老を悲しむ情が切々と迫っている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更らしく死んだ人を悲しむのでもなく妹の不幸を女々しく悔やむのでもないが、朝に晩に絶間のない煩いに追われて固く乾いた胸の中が今日の小春の日影に解けて流れるように、何という意味のない悲哀の影がゆるんだ平一の心の奥底に動くのであった。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しむときは、鳴沢に小石が滑り落ちる音が止めどもなくしくしくと聞えて来る。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日様はもえる宝石のように東の空にかかり、あらんかぎりのかがやきを悲しむ母親の木と旅にでた子どもらとに投げておやりなさいました。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対にまた、心の自由を得ない人間の憐むべく笑うべくまた悲しむべき現象を記録したものが非常に沢山に収集されていて、それがまたこの随筆集中の最も面白い部分をなしているのである。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家は悲しむわけがない。",
              "citation": {
                "source": "室生犀星君の飛躍",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでゐて彼の魂が詩を思ふ時、彼は乞食の中に自己の眞實の姿を見出し、漂泊のルンペンと抱擁して悲しむのである。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その声は街へ遊びに行くのがおじゃんになったのを悲しむように絶望的だった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また不完全ながらも心の調子が整うていればまだしもですが、さらにいびつになってできているのですから、様子がよほど変です、泣くも笑うも喜ぶも悲しむも、みな普通の人から見ると調子が狂っているのだからなお哀れです。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五　科学を奨励する目的で、われわれが誠心誠意でやっている事が、事実上の結果において、かえって正しく科学の進歩を妨害しているような悲しむべき場合が、全くないとは言われない。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学を奨励する目的で作られた機関が、自己の意志とは反対に、一生懸命科学の進歩を妨害しているという悲しむべき結果になる事もあるようである。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫婆の死を悲しむよりも、母をうしなった七之助の悲しみを思いやって、長屋じゅうの顔は陰った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "――同様に悲しむ親や子供を持っているのだ。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　トシエは悲しむかと思いの外、晴々とした顔をしていた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ、佐藤次信忠信兄弟の妻、二人都にて討死せしのち、其の母の泣悲しむがいとしさに、我が夫の姿をまなび、老ひたる人を慰めたる、優しき心をあはれがりて時の人木像に彫みしものなりといふ。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は焦るような緊張した顔になって、羨しげに、また少しは自分の鉤に何も来ぬのを悲しむような心を蔽いきれずに自分の方を見た。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "死後に自分の死を悲しむべき第二の我れは存しないからわが死は我れにとって悲しみでない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "コカイン芸術やモルフィン文学があまりに多きを悲しむ次第である。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「悲しいから」と言うのを「悲しむべき事情が身辺に迫ったから」という意味に解釈する、たとえば自身に最も親しい者が非業の死をとげたからというふうに理解すると、それはたしかに泣くことの一つの条件にはなるが、それだけでは泣くための必要条件は決してそろわないのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日様は燃える宝石のやうに東の空にかかり、あらんかぎりのかゞやきを悲しむ母親の木と旅に出た子供らとに投げておやりなさいました。",
              "citation": {
                "source": "いてふの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その形小さく力無い鳥の家に参るといふのぢゃが、参るといふてもたゞ訪ねて参るでもなければ、遊びに参るでもないぢゃ、内に深く残忍の想を潜め、外又恐るべく悲しむべき夜叉相を浮べ、密やかに忍んで参ると斯う云ふことぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その形小さく力無い鳥の家に参るというのじゃが、参るというてもただ訪ねて参るでもなければ、遊びに参るでもないじゃ、内に深く残忍の想を潜め、外又恐るべく悲しむべき夜叉相を浮べ、密やかに忍んで参ると斯う云うことじゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しむ者は皆吾に従え」　といったような熱烈な調子で、人類全般に、あらゆる悪事をすすめる文句がノベタラに書いて御座います。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる言葉もてもこれを言い消すことあたわず、大空の星の隕ちたるがごとし、二郎はその理由のいかんを見ず、ただ光の失せぬるを悲しむ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛児を失いし人は始めて死の淵の深きに驚き悲しむと言い伝う、わが知れる宗教家もしかいえり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
