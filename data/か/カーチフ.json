        "examples": {
          "standard": [
            {
              "text": "祖母が首元に巻いていたカーチフは、使い込まれて生地が柔らかくなっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "強い日差しを避けるため、彼女はリネン製のカーチフを頭に軽く載せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「まあ、素敵なカーチフね」と隣の奥さんがその細やかな刺繍を褒めてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "泥を拭うのに使ったからか、その白いカーチフには落ちない汚れが染み付いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ほの暗い電燈の光のとどかぬ駅のプラットフォームの隅で連れの男と熱心に何か話しているお前の背後に紫色のカーチフを眼深かにかむって、ションボリと立っていた、くたびれたダンサアか女給が眼につかなかったの？",
              "citation": {
                "source": "殺意（ストリップショウ）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
