    "definitions": [
      {
        "index": 1,
        "gloss": "so",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は斯く迄も情熱的に自分の夢を語るので、周りの者も引き込まれていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "斯く迄の長旅になるとは思ってもみなかったよ。もう足が棒だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "まさかあの名作が斯く迄も不評を博するとは、誰も予想できなかっただろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「え、斯く迄安くしてくれるの？ありがとう！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あゝ天は何とて斯く迄無情なると、私は暫時眞黒な雲を睨んで、只更怨んだが、然し後に考へると、世の中の萬事は何が禍となり、何が幸福となるか、其時ばかりでは分らぬのである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、天上から地獄の底へ蹴落されたとて、人間は斯く迄失望するものではあるまい。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、斯く迄極度に悄然とした風采は、二十一年今初めてである。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありふれたる此花、狭くるしき此庭が斯く迄人を感ぜしめんとは曾て思ひよらざりき。",
              "citation": {
                "source": "小園の記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しそうでなかったら、女が斯く迄強い事を云う筈が無いからである。",
              "citation": {
                "source": "偽刑事",
                "author": "川田功",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論知らぬ同志であるから多少気まずい点はあろうと考えていたが、斯く迄に排他的であろうとは全く予想しなかった。",
              "citation": {
                "source": "黒部川を遡る",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても後年尾瀬の名が斯く迄に喧伝されようとは、読んだ私は元より、書いた武田君も恐らく思っていなかったであろう。",
              "citation": {
                "source": "尾瀬の昔と今",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく今後と雖も斯く迄圖版の多數なるものは容易に得難いことであらう。",
              "citation": {
                "source": "大植物圖鑑",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "土噐の形状｜紋樣に至つては多言を要せず、實物を見たる人は更なり、第七回の挿圖のみを見たる人も、未開の人民が如何にして斯く迄に美事なるものを作り出せしかと意外の感を抱くならん。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが曰ふ如く人にして只チューヂュースの子なりせば、神助なくして斯く迄に猛きを得まじ、神明の　185あるもの彼の側に立ち、雲霧に彼の肩を掩ひ、彼に當りし勁箭を別の道にと外らしめぬ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "智謀恰も神に似し＊ペーリトオスを産めるもの、イキシーオーンの＊愛妻をわれ斯く迄は愛でざりき、アクリシオスの娘たる脚美はしきダナエーも、（勇士すべてに勝れたる＊ペルシュウスは其子息）　320高き譽のポイニコス其娘にてわが爲めにラダマンチュース、ミーノース生みたる＊彼もかばかりは。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "船のそば厭へる部下を抑へ留む、波浪｜劈く船に乘り、むしろ故郷に立ち去らむ、　205不祥の怒り斯く迄も君の心を領すれば」屡※かくも汝らは集議の席に述べたりき。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野の停車場に文太郎を迎へに行つた春三郎は自分の兄が斯く迄に田舍者だとは思はなかつた。",
              "citation": {
                "source": "續俳諧師",
                "author": "――文太郎の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は、また速達で校正刷が來て、十二時ちかくまで、それにかかつてゐた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくまで私心が長じてきてどうして立派な口がきけよう。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞬間の嬉びが永遠に悲しみとなってしまう、チャイコフスキーの狂気音楽がかくまで近代を支配する。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、あれだけ農民、農村を知りながら、かくまで農民が非人間的な生活に突き落され、さまざまな悲劇喜劇が展開する、そのよってくる真の根拠がどこにあるかを突きつめて究明し、摘発することが出来ないのは、反都市文学のらち内から少しも出なかった農民文学会の系統を引いた作家的立場に原因していると思う。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔かくまでに〕宮沢賢治かくまでに心をいたましむるは薄明穹の黒き血痕新らしき見習士官の肩章をつけなが恋敵笑ひ過ぐるを",
              "citation": {
                "source": "〔かくまでに〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は桂の容貌、かくまでにまじめなるを見たことがない。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "げに平壌攻落せし将軍もかくまでには傲りたる色を見せざりし。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "神戸なる某商館の立者とはかねてひそかに聞き込みいたれど、かくまでにドル臭き方とは思わざりし。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊吉はしばらく杉の杜の陰で休んでいたが、気の弱いかれは、かくまでに零落れてその懐かしい故郷に帰って来ても、なお大声をあげて自分の帰って来たのを言いふらすことができない、大手を振って自分の生まれた土地を歩くことができない、直ちに兄の家、すなわち自分の生まれた家に行くことができない。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今、全然失敗して帰ッて来た、しかしかくまでに人々がわれに優しいこととは思わなかった。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "げに治子の姉妹なりと言わんもわれいかでたやすく疑い得べき、ことに最初わが方を振り向きし時のまなざしは治子のと少しも違わず、かの美しき目とかくまでに相｜肖たる眼を持つ少女のまた世にあらんとは思わざりしに。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めよりかれが恋の春霞たなびく野｜辺のごとかるべしとは期せざりしもまたかくまでに物さびしく物悲しきありさまになりゆくべしとは青年今さらのように感じたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは救助の遅くして、下枝等は得三のために既に殺されしにあらざるか、遠くもあらぬ東京に住む身にて、かくまでの大事を知らず、今まで棄置きたる不念さよ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かくまでしたらば我を折らんとかねてより思いしには似で、飽くまで老婦人の剛情なるに、後へ退かれぬ羽目になり、止むことを得ず手を下しつ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さらぬだにこの風采を、まして、世に、かくまで清き媛やある。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、姿見に映った不思議は、わが膚のかくまで白く滑らかだった覚えはない。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と更に拝んで、「手足に五寸釘を打たりょうとても、かくまでの苦悩はございますまいぞ、お情じゃ、禁厭うて遣わされ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
