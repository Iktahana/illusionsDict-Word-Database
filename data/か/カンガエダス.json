[
  {
    "uuid": "0102b20a-be01-5749-ac10-0bc342359431",
    "entry": "考え出す",
    "reading": {
      "primary": "かんがえだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
