      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "increase",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "手柄を立てた武将に対し、殿様は三千石の加増を申し渡した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「プロジェクトを成功させたら、来期の予算を加増してもらえるよう交渉してみるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "領地を加増されたことで、家臣たちの士気は一気に高まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "出荷量の大幅な加増に対応するため、工場のラインを増設することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこでその野西から取上げた調書と、証拠の風呂敷を松倉様の手から差出いたら、大目付では大層なお喜びで、松倉さんは直ぐに御加増の沙汰と聞いた」「ヘエ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋で使を肥前名護屋に遣はし、秀吉の陣を犒ひ、三年正月には従四位下右京大夫となり、慶長五年関ヶ原の役には、兵を出して徳川家康の軍に従ひ、西上して大垣に戦ひ、上野国大館二千石を加増す。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時はじめて氏郷は莞爾と笑って、好い奴だ、汝は此の乃公に能う勝ったぞ、と褒美して、其の翌日知行米加増を出したという。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏郷は此時も功が有ったので、前後勲功少からずとて七郡を加増せられ、百万石を領するに至った。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三年四月赤松殿｜阿波国を併せ領せられ候に及びて、景一は三百石を加増せられ、阿波郡代となり、同国｜渭津に住居いたし、慶長の初まで勤続いたし候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "家臣にはそれぞれ新知、加増、役替えなどがあった。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "光尚も思慮ある大名ではあったが、まだ物馴れぬときのことで、弥一右衛門や嫡子権兵衛と懇意でないために、思いやりがなく、自分の手元に使って馴染みのある市太夫がために加増になるというところに目をつけて、外記の言を用いたのである。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "落城ののち、忠利は数馬に関兼光の脇差をやって、禄を千百五十石に加増した。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "高見権右衛門は三百石、千場作兵衛、野村庄兵衛は各五十石の加増を受けた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "年の暮れに軍功のあった侍に加増があって、甚五郎もその数に漏れなんだが、藤十郎と甚五郎との二人には賞美のことばがなかった。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "要は期せずして偶合したので、久しい歳月の間に、こんな事は多くあろう（宝永五年板『風流門出加増蔵』（『西鶴置土産』の剽窃物）三ノ二、伊勢町の大盃といえる大尽云々、六十を過ぎて鬢付嗜み女郎と討ち死にと極めて銀使いける云々）。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚兵衛も惣八郎も、百石の加増を賜った。",
              "citation": {
                "source": "恩を返す話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして殿から五十石の加増があった。",
              "citation": {
                "source": "恩を返す話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "先手の者が馳せ帰って、「青木新兵衛大坂城の一番乗り仕って候」と注進に及ぶと、忠直卿は相好を崩されながら、「新兵衛の武功第一じゃ――五千石の加増じゃと早々伝えよ」と、勇み立とうとする乗馬を、乗り静めながら狂気のごとくに叫んだ。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三百年近く太平の世が続いたために、彼等の大部分は加増を受ける機会もなく、只夢のように生れては死んだ。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "このやうに一国一城よりも、骨肉の生命よりも、茶器の価値が重く見られた時代ですから、名器の発見は、その大名にとつては、所領一箇国の加増といふことにもなりました。",
              "citation": {
                "source": "小壺狩",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "辰盛は宝永三年に信政に随って津軽に往き、四年正月二十八日に知行二百石になり、宝永七年には二度目、正徳二年には三度目に入国して、正徳二年七月二十八日に禄を加増せられて三百石になり、外に十人扶持を給せられた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "抽斎の父允成が四月｜朔に二人扶持の加増を受けて、隠居料五人扶持にせられたのは、特に寧親に侍せしめられたためであろう。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋で阿部家では榛軒を目附格に進め、禄卅石を加増した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "公私略に「五月三日御加増御祝金七両頂戴被仰附」と云ふものが即是である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "手柄があっても加増も出来ぬとあれば、当藩士の意気組は腐るばっかり。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今二百石ばかり加増して取らせい」「ハハッ。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に中津藩では減禄をしないのみならず、平均した所で加増した者がある。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "当節、百石の加増など、一生かかっても、有りつけんぞ」　玄関際の、詰所――小さい庭から、差込む明りだけで、薄暗くて、冷たい、部屋の中で朋輩の一人がいった。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "右源太を、平常から軽蔑していた上に、今度の加増で、反感と、嫉妬とをもっていた人々は、右源太に、こういわれて、じっと、横から、その顔を睨みつけていた。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "百石の御加増はいらんが、命はいる。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大殿、斉興公から、多少の加増があるくらいで、己の命をちぢめてまで、この呪法を拡めようとはしたくない。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "綱利は甚太夫を賞するために、五十｜石の加増を命じた。",
              "citation": {
                "source": "或敵打の話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿のお父上右近将監様は、御老中におわすこと三十八年、その間にご加増をお受け遊ばしたこと、わずか六千石でございました。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにご忠正でご謙謹で、お身をお守り遊ばすことが、お固すぎるほどお固うございましたことか」「将軍家が田沼をご寵愛のあまり、度々ご加増遊ばされたが、ある時のご加増に田沼は憚り、私のお父上に意見を訊いたそうだ。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
