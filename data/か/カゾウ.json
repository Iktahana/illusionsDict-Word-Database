[
  {
    "uuid": "1bd72cd4-bad7-5122-a66f-842424d6afb1",
    "entry": "加増",
    "reading": {
      "primary": "かぞう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
