        "examples": {
          "standard": [
            {
              "text": "長年にわたる国境付近での小競り合いに耐えかねた国王は、ついに干戈を動かす決断を兵士たちに下した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "和平交渉が土壇場で決裂し、ふたたびこの肥沃な大地で干戈を動かす事態となったのは歴史的な悲劇だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "どちらの陣営が先に干戈を動かして開戦の口火を切ったのかについては、現代の歴史家の間でも意見が分かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで大変な騒動が起り、干戈を動かすやうな事が出来た事が古い歴史にあります。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "臣おもえらく干戈を動かすは和解に若かずと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "春来、国事多端、ついに干戈を動かすにいたり、帷幄の士は内に焦慮し、干役の兵は外に曝骨し、人情恟々、ひいて今日にいたる。",
              "citation": {
                "source": "中元祝酒の記",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
