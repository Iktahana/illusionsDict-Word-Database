        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "賑やかなダンスパーティーの片隅で、彼女はずっと壁の花として過ごしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「せっかくのお祝いなんだから、壁の花になってないで輪に入りなよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自分から話しかける勇気がなくて、交流会ではいつも壁の花になってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」　とこう不意に云って久慈はまた壁の花模様に眼を上げた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯波といふ男は、――「あいつはまるで壁の花みたいな奴ですよ。",
              "citation": {
                "source": "聖家族",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯波という男は、――「あいつはまるで壁の花みたいな奴ですよ。",
              "citation": {
                "source": "聖家族",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いはば会の欠くべからざる壁の花のやうだつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "南壁の花を持って立っている姿などは、アマゾンの像といってもいいほどに強靱でそうして艶めかしい。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
