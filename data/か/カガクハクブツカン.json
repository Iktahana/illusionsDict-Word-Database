        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "週末は子供と約束していたので、国立科学博物館へ恐竜の骨格を見に行きました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プラネタリウムがある科学博物館は、大人も楽しめる場所だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "来週の遠足は、新しくできた科学博物館に決まったらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "科学博物館で買った宇宙食、意外と美味しかったよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それは上野の科学博物館とその裏側にある帝国学士院とが意外に遠く離れて見えるということである。",
              "citation": {
                "source": "観点と距離",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちど先生に連れられて、クラス全部で、上野の科学博物館へ行ったことがございますけれど、たしか三階の標本室で、私は、きゃっと悲鳴を挙げ、くやしく、わんわん泣いてしまいました。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日上野の科学博物館裏を通ったら、隣の帝国学士院の裏庭で大きな白犬の写真を撮っていた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所は上野科学博物館の陳列函の中であった。",
              "citation": {
                "source": "最小人間の怪",
                "author": "――人類のあとを継ぐもの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏休みには植物採集をさせますとか、科学博物館へつれてゆきますとか云う、それだけが厚みの全部ではないと思われる。",
              "citation": {
                "source": "市民の生活と科学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽という芸術が、音響学の面から扱われて興味ふかい試みの一歩を示した東宝の文化映画のことや、つい先頃偶然みたドイツの「池中の秘密」ミュンヘン科学博物館の実写なども思い出される。",
              "citation": {
                "source": "市民の生活と科学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この科学博物館の映画からも原理を形象的に啓蒙してゆく方法がいかに多様で自由で人間的で具体的であり得るかということを考えさせられた。",
              "citation": {
                "source": "市民の生活と科学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学博物館編の「江戸時代の科学」という本は、簡単ではあるが、近代科学に向って動いた日本の先覚者たちの苦難な足跡を伝えている一つの貴重な本である。",
              "citation": {
                "source": "科学の常識のため",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィンジャマーは、きょう折竹の連れである自然科学博物館の、ケプナラ君とは熟知の仲である。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ自然科学博物館の名鳥獣採集者として、非番でも週金五百ドルはもらう至宝的存在だ。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物から一夜のうちに時計台を盗んでいったり、科学博物館から剥製の河馬の首を盗んでいったり、また大いに変ったところでは、恋敵の男から彼の心臓を盗んでいったりいたしました」「残酷なことをする。",
              "citation": {
                "source": "すり替え怪画",
                "author": "烏啼天駆シリーズ・５",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして十二月一日から五日まで、上野の科学博物館へ日参して博物の標本をたんねんに見てきたそうである。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在ある科学博物館などは小っぽけなもので、あんな僅かな費用では手も足も出ない。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はこれらの書籍、標本はみな遺愛品となって遺るに至ったが、遺族の方はこれを日本科学博物館に献納したと聞いた。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学博物館へでも行かないと、一寸見られない。",
              "citation": {
                "source": "南画三題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この魚の本名は、Lepisosteus tristoechus というのだそうで、銛をはね返した話も、シカゴの自然科学博物館発行の専門的な小冊子に出ていた話である。",
              "citation": {
                "source": "異魚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京科学博物館刊行の『江戸時代の科学』には、『雪華図説』の著者として、土井利位の代りに鷹見泉石の名が挙げられているくらいで、あるいはこの研究は主として泉石によって為され、刊行の際にその殿様であった土井利位の名を冠したものではないかと疑われるくらいである。",
              "citation": {
                "source": "『雪華図説』の研究後日譚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたは上野にかういふものがあるのご存じですか」　見ると、「東京科学博物館」といふ標札がかゝつてゐた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さつき先輩を訪ねたのは、こゝなんです」六　ほんたうのところ、素子には、科学博物館などはどうでもよかつた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすぐそばの江津良つていふところに、最近行幸記念としてできた自然科学博物館があるんです」「紀州……へえ」　と、彼女は眼をみはつた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "渚に沿つて江津良の部落へ通ずる小径がついてゐるけれども、繁華な白浜の温泉街がすぐ丘のうしろにあるとは思へぬ閑静さで、「行幸記念自然科学博物館」の白い標柱が、蘆の生ひ茂つた道ばたに建つてゐるほかは、一望はるかな磯の風景がたゞ日の強い南海の特殊な趣を見せてゐるだけである。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、翌日は、先づ大沼博士を訪ね、それから上野の科学博物館へ寄つて仕事の上の打合せをし、昼は銀座でトンカツを食ひ、夕刻近く、麻布の安藤の家へ出掛けて行つた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察で当夜の行動を訊ねられると、はじめ佐治さんは、その時刻に、上野公園の科学博物館前のベンチにいたのだと申立てたそうで、しかしそれが、私との媾曳のためだったと苦しい弁明をしたとのことです。",
              "citation": {
                "source": "偽悪病患者",
                "author": "大下宇陀児",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来るだけ秘密の媾曳を遂げるため、人に姿を見せぬようにしていたのだという弁解だったそうですが、科学博物館の前で佐治さんを見たということを、誰一人、申出るものもありません。",
              "citation": {
                "source": "偽悪病患者",
                "author": "大下宇陀児",
                "note": "青空文庫"
              }
            },
            {
              "text": "「科学博物館の動物標本室にこんなのがあったっけ。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか科学博物館で、こういう鏡を見たことがあります。",
              "citation": {
                "source": "虎の牙",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
