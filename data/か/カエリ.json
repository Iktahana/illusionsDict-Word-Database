[
  {
    "uuid": "be78241f-36f6-51cb-9ee0-e174d1394f1e",
    "entry": "帰り",
    "reading": {
      "primary": "かえり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
