        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "初夏になると、庭の唐桃が甘い香りを放ち始める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このジャムは、旬の唐桃をふんだんに使って手作りしたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、夏休みに食べた唐桃の甘酸っぱさが忘れられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "先生には又自筆「唐桃集」の倭歌があるが、所謂花鳥風月歌、理窟歌、言語の綾の弄びの類多くその漢詩と風を異にしてゐる。",
              "citation": {
                "source": "頼杏坪先生",
                "author": "中村憲吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫は南葵の花であり、紅きは唐桃の花であり、黄なるはオランダ美女草の花で、それらの薬草の花の敷物を、抽んでて空に聳えている木々の葉は紅葉し黄葉して、エメラルド色の空を飾り、崖には滝が白布をかけ、谷には谷川が銀線を延べ、それを昼の日が照らしていた。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が家へ来てからももうかれこれ十五六年になるが、おれが酒さえ飲むといえばどんな時でも必らずあの猪口で飲むでいたが、談すには及ばないことだからこの仔細は談しもしなかった。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "通だとか粋だとかいうことは、からももんじいで分らないけれども、意気だといって、この寒中、綿の入らない着物を着ていりゃ、体に毒だということは知ってるんだ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が遁世の望みを持ち始めた時からももう三十年たっている。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ、この山峽六十戸ばかりの小さい村のなかにも、滿洲移民の話が華やかに持ちこまれてゐた折なので、血氣にはやる若い男や、小作ばかりして生涯を過してきた土地のない老人達まで滿洲行きをぼつぼつ志望してゐて、この村からももう三家族ほどは家や畑を賣つて出掛けてゆくものがあつた。",
              "citation": {
                "source": "うき草",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "強権主義や共産党の内部の者は、その内部からしか物を見てはいけないだろうが、外部に立っている吾々は、外部からもものを見る権利が許されている。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはうちの旦那様からももてて、すごいじゃないの」　南原杉子は、蓬莱和子が、しきりに自分を観察していることを愉快に思った。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然私がそんな考へに住してからももう一年半になる訳である。",
              "citation": {
                "source": "落葉降る下にて",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれを痛く感心して、殊に画面に沢山円柱があって、靴下からももまで足の形の通りぴったりと付いた服を着ている、その足の人が沢山並んでいます。",
              "citation": {
                "source": "少年の食物",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれはめいめい桶を一つずつ持って、廊下の突きあたりの庖厨場のほうへ行きかけると、向いの部屋の床の切穴からももやもやと煙が出ている。",
              "citation": {
                "source": "フランス伯Ｎ・Ｂ",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、あの若松屋の女番頭のお高というのがそれだと知れると、すこし細工がまずくなるのだけれど、お高はじぶんでいいっこないし、若松屋惣七という盲人はお高を想っているのだから、このことは、あいつからももれる心配はあるまい。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は城にいろいろ重要な関係者たちをもっているし、これからももっと重要な関係者たちをもつようになるでしょう。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "けっしてそんなことはなく、少なくとも訴訟が敗けたと認める決定的な理由はないのであって、ただ、もう訴訟のことは全然わからないし、これからももうそれについて何もわかることはなかろう、というだけのことなのだ。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれからももう手紙が来なかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはこんな意味のことは一度だってイワンに話したことがないし、イワンのほうからももちろん、そんなことは一言半句だって、おれに匂わしたことはないのさ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "「白」は桃色の膚がなまめかしく、高い鼻、赤くて薄いくちびる、二重まぶたの目が女のように優しく、ふっくらとして、しかもよく締まったしりからももの線が、うっとりするほど美しかった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼の主張は公正に見て問題性に富み、これからももっとも重要な手がかりとして扱われていくことであろう。",
              "citation": {
                "source": "「世界文学大系58　カフカ」解説",
                "author": "原田義人",
                "note": "青空文庫"
              }
            },
            {
              "text": "本気になって勉強していなさい」「来年からやります」「お母さんからももっと言って貰うし、高円寺の兄さんにも頼んで見る」「あれは角張りだから駄目ですよ」「何あに、学校の先生だから話が分る。",
              "citation": {
                "source": "嫁取婿取",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれが一足歩くたびに水は足からひざ、ひざからもも、ももから腰、腹、胸と、のぼってきて、いまは水面から首が出ているばかりになりました。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ひざからもも、腰、腹と、すべるようにズルズルさがってきたかと思うと、いつのまにか、二本の手で天井にぶらさがり、器械体操でもするように、はずみをつけて、ヒラリと部屋の中へとびおりました。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
