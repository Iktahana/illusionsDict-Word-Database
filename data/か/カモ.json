  {
    "uuid": "a0cffc9f-459c-5970-85aa-d0d2fdd1bce8",
    "entry": "氈",
    "reading": {
      "primary": "かも",
      "alternatives": [
        "せん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
