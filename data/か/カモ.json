    "definitions": [
      {
        "index": 1,
        "gloss": "duck",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "公園の池で、優雅に泳ぐ鴨の群れを見かけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わぁ、あの鴨、首がとってもきれいな緑色だね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "冬になると、渡り鳥の鴨が越冬のために日本にやってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "妻が鴨鍋を作ってくれた。出汁が効いてて美味しい！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "眩しくなった眼を室内へ移して鴨居を見ると、ここにも初冬の「森の絵」の額が薄ら寒く懸っている。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "画はやはり田舎の風景で、ゆるやかな流れの岸に水車小屋があって柳のような木の下に白い頭巾をかぶった女が家鴨に餌でもやっている。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん目に止るのは足の方の鴨居に笠と簑とを吊して笠には「西方十万億土順礼　西子」と書いてある。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の庭に向いた方の鴨居に水彩画が一葉隣室に油画が一枚掛っている。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも鴨猟場で「鴨をしゃくう」のに比べると猟者の神経の働かせ方だけでも大変な差別があるような気がするのである。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴨が沢山ついていて、釣船もボツボツ見える。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "繪具箱へスケッチ板を一枚入れて、其れと座蒲團代りの古い布切れとを風呂敷で包み隱したのを抱へて市内電車で巣鴨迄行つた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に著しいのは千鳥や海鴨などのである。",
              "citation": {
                "source": "卵の形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに述べるムーア灯は正にこの注文に応じて出来たもので、室ならばその鴨居の後ろに隠れた長い管が、一面に光を放って天井を照らし、室内は不夜の境となるのである。",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "国府津と小田原の中間に「雀の宮」という駅があったようだと子供達と話していたら、国府津駅の掲示板を見ていた子供の一人からそれは「鴨の宮」だという正誤を申込まれた。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし雀と鴨では少し大きさが違い過ぎると云って笑った。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあいずれにしても私の大根裁培法が巣鴨の作兵衛氏に笑われる事だけは確かだろうと思った。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その少し前にこの夏泊った沓掛の温泉宿の池に居る家鴨が大きな芋虫を丸呑みにしたことを想い出していた。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い芋虫と真紅の肉片、家鴨と眇目の老人では心像の変形が少しひど過ぎるが、しかしこの偶然な一と朝の経験から推して考えてみるとフロイドの「夢判断」の学説も、そのことごとくが全くの故事付けではないかもしれないという気がして来るのである。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時僕が怒つたのは、家鴨の卵から鷄が生れたと言つて腹を立てたやうなもので、今思へば我ながら認識不足の滑稽である。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき食卓の日本料理の美味のうちに急に鳴物の入った三味線を土人街の坊主頭の幇間が弾き出すと、香港あたりでよく歌われる鴨緑江節を女達が噛むようにうたいだした。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵は靉河右岸に沿い九連城以北に工事を継続しつつあり、二十八日も時々砲撃しつつあり、二十六日｜九里島対岸においてたおれたる敵の馬匹九十五頭、ほかに生馬六頭を得たり――「どうです、鴨緑江大捷の前触れだ、うれしかったねえ、あの時分は。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴨長明の方丈記を引用するまでもなく地震や風水の災禍の頻繁でしかも全く予測し難い国土に住むものにとっては天然の無常は遠い遠い祖先からの遺伝的記憶となって五臓六腑にしみ渡っているからである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く死滅しないまでも山椒魚か鴨の嘴のような珍奇な存在としてかすかな生存をつづけるに過ぎないであろう。",
              "citation": {
                "source": "俳句の型式とその進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば郷里の家の前の流れに家鴨が沢山並んでいて、夕方になると上流の方の飼主が小船で連れに来るというような何でもない話でさえ、何かしら一種の夢のようなものを幼い頭の中に描かせると見える。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巣鴨から上野へと本郷通りを通るときに、また新しい経験をした。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "池に家鴨がただ一羽いる。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家鴨は群れている方が家鴨らしく、白鳥は一、二羽の方が白鳥らしい。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年この家にいた家鴨十数羽が今年はたった雄一羽と雌三羽とだけに減っている。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き残った家鴨どもはわれわれには実によく馴ついて、ベランダの階段の一番上まで上がって来てパン屑をねだる。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日、※口の沼へ鴨打ちに行ったら、土匪がツカ／＼っと、六、七人黄河の方からやって来たんですよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔萌黄いろなるその頸を〕萌黄いろなるその頸を、　　　直くのばして吊るされつ、吹雪きたればさながらに、　　家鴨は船のごとくなり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうあるべきがよかつたかも知れない多くの元気な顔たちの中に、私は容易におまへを見付ける。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹌踉めくままに静もりを保ち、聊か儀文めいた心地をもつてわれはわが怠惰を諫める、寒月の下をゆきながら、陽気で坦々として、しかも己を売らないことをと、わが魂の願ふことであつた！",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもおまへはわがままに親しい人だと歌つてきかせる。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "easy mark",
