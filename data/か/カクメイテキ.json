    "definitions": [
      {
        "index": 1,
        "gloss": "revolutionary",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の発明は、エネルギー問題の解決につながる革命的なものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女のデザインは、従来の常識を覆す革命的なアイデアに満ちていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "インターネットの登場は、コミュニケーションのあり方を革命的に変えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "革命的左党は右党派軍隊に絶滅され、国民党は共産分子を除外して孫文の国民党はブルジョワ階級の走狗となった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は心持ち昂奮して床を靴尖で叩きながら立上ると、リー・シー・ツワンは遥かビクトリア・ビークの絶景の化粧された文明の礎を一瞥して、　――上海に於ける陳独秀のコムミュン騒動、また広東事変の失敗によって俺には熱狂的同志に対して俺自身に課せられた革命的任務の自覚が眼覚めたのだ。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは今暁飛行機で香港にくると陳独秀の革命的遺産をうけついだのだ！",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、革命的プロレタリアートに対しては、徹底的に弾圧の手をゆるめやしないのだ。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、兵営内に於ける組織を作りそれから、革命的な、サークルや、グループを組織化することに努めねばならぬ。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍隊内における組織的活動、軍国主義と資本主義のためにする軍隊の使用に反対する啓蒙的な宣伝は、兵営に這入ろうとする革命的な青年たちのやらねばならぬ仕事である。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "而シテ諸君ハ、支那ノ労働者、農民、兵士達ト手ヲ握レ、諸君ガ革命的連帯ノ固キ握手ニ達スルタメニハ、如何ナル犠牲ヲモ辞スルナ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「諸君が、革命的連帯の固き握手に達するためには、如何なる犠牲をも辞するな。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう革命的の仕事は、おそらくアカデミックな学者の手によってではなく、意外な方面の人の自由な頭脳によってなし遂げられはしないかという気がする。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し唯それだけでは、あの革命的色彩に富んだ文學者の胸中を了解するに、何となく不十分に思はれて爲方がなかつた。",
              "citation": {
                "source": "硝子窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはこの事件にも、はた又無政府主義そのものにも、別に關係するところのない事ではあるが、かの愛すべき露西亞の青年の長く且つ深い革命的ストラツグルが、その最初如何なる形をとつて現はれたかを知ることは、今日の我々に極めて興味あることでなければならぬ。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにこの裏店に革命的変動が起った。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "又一方からは、足利末期の形式化された生活に対する革命的な精神の発露と見られる点もあるのである。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等に依つて、わが国の建築、造船、裁縫、鍛冶、機織、製陶などの技術は、全く革命的な進歩を遂げたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "言語は流水の如きものであつて必ず變遷する、そこで之を文語として固めてしまふと云ふと、池水のやうになつて腐る、それが腐つてしまふと云ふと、初め排斥せられた方言が何處かに殘つて居て、下行水と云ふやうな風に、何處かに殘つて居つて、そのものが何時か頭を持上げて革命的に新しい文語が起つて來る。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のやうに腐敗して來て革命的なことが出て來ると云ふことを防ぐには、新しい貴族を作れば好い、新華族を作るやうにして、ぽつ／＼腐らないやうにして行けば宜しいかと思ふ。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから僕はその男とつき合うようになったんだが、その白水という男は全く珍しく意志の強固な、感情を理知でたたき上げて、火のような革命的な思想を持ち、それを僕らが飯でも食うように、平気で、はた目からは習慣的に見えるほど、冷静に実行する男だった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日新説と称し革命的思想と唱えて得々としてあるいはこれを口にし、あるいはこれを筆にする者が多い。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "−−−−−−−−−−−−−−−−−−−−−−−−−−新日本画の名コンビ　福田と吉岡　　　　――『松』と『馬』に就いて――　第二回新美術人協会展の福田豊四郎氏の『松』は従来の日本画の様式に対して新しい革命的な手段を加へたといふ意味で相当に問題となつていゝ作品である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本改造法案ノ起草者ハ當然ニ革命的大帝國建設ノ一實行者タラザルヲ得ズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "之ニ反對シテ露西亞ノ革命的思想家ノ多クハ國民平等ノ土地分配ヲ主張シテ又別個ノ理論ヲ土地民有制ニ築ク者多シ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地ノ國際的分配ニ於テ不法過多ナル所有者ノ存在スルコトニ革命的理論ヲ擴張セズシテハ、言論行動一瞥ノ價値ナシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "而シテ歐米ノ革命的團體ハ大戰ノ遙ニ以前此レヲ以テ國際語トセント決議セシ程ノ者。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼ノ者ト考フルガ上院制ヲ否ム革命的思想家ハ、人類ノ進化程度ヲ過上ニ評價セル神學者的要求ニ發足スル者ナリト見ルベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "改造セラレタル合理的國家、革命的大帝國ガ國際的正義ヲ叫ブトキ之ニ對抗シ得ベキ一學説ナシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子の多感な心は、自分でも知らない革命的ともいうべき衝動のためにあてもなく揺ぎ始めた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果が意外な根柢ある革命的｜煽動が下層社会に初まったり、美くしいヒューマニチーが貧民の間に発現されたりする。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
