    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fruit tree",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖父の家の庭には様々な果樹が植えられており、夏には甘い実をたくさんつける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域は果樹栽培が盛んで、収穫期には多くの観光客が訪れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "温暖な気候が、この果樹園のリンゴの生育に最適だと聞きました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい品種の果樹を試験的に導入し、収穫量の増加を目指している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "果樹園や畑の見えるだらだら下りの裾野平の果に、小唄で名高いＹ――山の山裾が見え、夏霞がうっすり籠めている中に浪がきらりきらり光った。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから果樹がちらちらゆすれ、ひばりはそらですきとおった波をたてまする。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は来たりぬ、われ再びこの暗く繁れる無花果の樹陰に座して、かの田園を望み、かの果樹園を望むの日は再び来たりぬ。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "油絵の風景画などでも、破れた木柵、果樹などの前景に雑草の乱れたような題材は今でもいちばんに心を引かれる。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそのあとに豊富な果樹の収穫の山の中に死んで行く「過去」の老翁の微笑が現われ、あるいはまた輝く向日葵の花のかたわらに「未来」を夢みる乙女の凝視が現われる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほこりっぽい、乾苦しい、塩っ辛い汗と涙の葬礼行列の場面が続いたあとでの、沛然として降り注ぐ果樹園の雨のラストシーンもまた実に心ゆくばかり美しいものである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その向うの荒れ果てた小さな果樹園、そこには果ばかりになつた林檎の樹が十本ばかり淋しく離れ合つて立つてゐる。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎の害を防ぐ爲めに魚の腸の腐つたのに浸して結びつけられた古藁は、果樹の幹に物臭く垂れ下つてゐる。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは、きまって自分の家の周りに、一番手近かに飲食料の貯蔵所、家畜、野菜畑、果樹園を置き、次に穀物畑、葡萄畑、次に牧場、最後に小さな灌木の密林（野鳥獣を棲息させて、時折りこれを捕ったり、家具を作る木材を得る）という順に置いて、一幅の風景画のように、各家庭が散在しております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　そこで二人は手をつないで果樹園を出てどんどんそっちへ走って行った。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからとうとうあの果樹園にはいったのだ。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一果樹｜整枝法、わかったか。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "果樹整枝法であります。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "果樹整枝法、その一、ピラミッド、一の号令でこの形をつくる。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "果樹整枝法、その一、ピラミッド。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "果樹整枝法その二、ベース一。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大将「次は果樹整枝法その三、カンデラーブル。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "果樹整枝法その三、カンデラーブル、はじめっ一、二、一、二、一、二、一、二、やめい。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "果樹整枝法その四、又その一、水平コルドン。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "果樹整枝法、その四、又その二、直立コルドン、はじめっ、一、二、一、二、一、二、一、二、一、やめい。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "果樹整枝法その五、エーベンタールであります。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "果樹整枝法、その五、エーベンタール、はじめっ、一、二、一、二、一、二、一、やめい。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大将「次は果樹整枝法、その六、棚仕立、これは日本に於て梨葡萄等の栽培に際して行われるじゃ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "」兵士十「果樹整枝法第六、棚仕立であります。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "果樹整枝法第六棚仕立、はじめっ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さいながら果樹園もあれば、羊を飼う柵も出来ています。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実習地とでもいふのか、津軽の各部落から選ばれた模範農村青年たちの作つた畑や果樹園、水田などが、それらの建築物の背後に、実に美しく展開してゐた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一株の果樹は霜虐雪壓に堪へさへすれば、必ずや、或時間に於て無より有を生じ、地の水と天の光とを結んで、甘美芳香の果實を生じ出す。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィナスが白鳥に曳かせた二輪車に乗り、森や果樹園のなかを駈けめぐって遊んでいると、怪しからぬ望を持った数十人の神々たちは、二輪車の濛々たる車塵を浴びながら汗を拭き拭き、そのあとを追いまわした。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからおなかじゅうをめっちゃめちゃにこわしちまうんだよ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
