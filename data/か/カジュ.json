[
  {
    "uuid": "fada9bbc-c21e-53df-8c59-3b57d7807554",
    "entry": "果樹",
    "reading": {
      "primary": "かじゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
