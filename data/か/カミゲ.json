[
  {
    "uuid": "cc6f8ad0-b941-593f-87b0-89f102c0ecf6",
    "entry": "髪毛",
    "reading": {
      "primary": "かみげ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
