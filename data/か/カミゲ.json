    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hair (on the head)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "白髪が目立ってきたので、そろそろ染め直そうと思っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "赤ちゃんの小さな髪毛が、枕に数本落ちていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の黒く艶やかな髪毛は、太陽の光を反射して輝いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "赤い攣れた髪毛が額に迫り、その下で紅と栗との軟い顔がほつとり上気してゐる。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は母の少なくなつた髪毛をみた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪毛もみんな総々としてゐないのかと考へた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに泰子、今こそはおまへの髪毛なよぶころ花は香炉に打薫じ、羊の歌羊の歌　　安原喜弘に※　祈り死の時には私が仰向かんことを！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "気圏の松藻だ、ひのきの髪毛。",
              "citation": {
                "source": "女",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「太陽は、　丘の髪毛の向うのほうへ、　かくれて行ってまたのぼる。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして日あたりのいい南向きのかれ芝の上に、いきなり獲物を投げだして、ばさばさの赤い髪毛を指でかきまわしながら、肩を円くしてごろりと寝ころびました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お日さんは丘の髪毛の向うの方へ沈んで行ってまたのぼる。",
              "citation": {
                "source": "若い木霊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほういまねえあの女の子がたうもろこしの娘さんの髪毛をむしってねえ、口へ入れてそらへ吹いたよ。",
              "citation": {
                "source": "畑のへり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからいかにもむしゃくしゃするといふ風にそのぼろぼろの髪毛を両手で掻きむしってゐました。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからいかにもむしゃくしゃするという風にそのぼろぼろの髪毛を両手で掻きむしっていました。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の髪毛は砂にまみれ、私の腹は岩に押しつけられております。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "崩れてはおったが……」「ところがあれが普通の島田では御座いませなんだので……私はズット以前からあの娘の外出姿に気を付けておりましたが、あの娘は普通よりもズット髪毛が長くて多い方で、どのようにでも大きく結われるものを、惜し気もなくグイグイと引詰めて結うておったもので御座います。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、そればかりなら宜しゅう御座いますが、その外出頭の鬢から髱のあたりに気を付けてみますると、一度、毛がピッシャリと地肌に押付けられたものを、又掻き起いて恰好を付けた痕跡が、そのまま髪毛の癖になって、両鬢から髱を一まわり致しておりまする。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは処々に灰色の薄汚れの付いた、夜具か何かを包む風呂敷らしかったが、その中央の折目に近い処に付いている真黒い血の塊の痕跡と、一目でわかる片隅の刃の血糊を拭いた痕跡と、処々に粘り付いている長い髪毛を見まわすと、今一度赤い唇をペロリと出して、大切そうに折り畳んで、懐中の奥に仕舞い込んだ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪毛の艶と、ラムプの金との夕まぐれ庭に向つて、開け放たれた戸口から、彼は戸外に出て行つた。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして日あたりのいゝ南向きのかれ芝の上に、いきなり獲物を投げだして、ばさばさの赤い髪毛を指でかきまはしながら、肩を円くしてごろりと寝ころびました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私は冬によくやる木片を焼いて髪毛に擦るとごみを吸い取ることを考えながら云いました。",
              "citation": {
                "source": "鳥をとるやなぎ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までは些とも眼に注かなかったが、綱は人間の髪毛に因て固く編まれたもので、所謂「毛綱」の類であった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが総て人間の髪毛であるかと思うと、市郎は何となく薄気味悪く感じた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで拾った人間が、御前へ差出して処分方を伺い上げたものであったが、開かせて御覧になると、中には古こけた髑髏が五個と、女の髪毛が散らばっていたので、皆、肝を消して震え上った。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪毛をテカテカと二つに分けて大きな黒眼鏡をかけている。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことをすると喰い付くぞ、この野郎」　と云うと、イキナリ豚吉はヒョロ子の髪毛を捕まえました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見ると、豚吉は慌ててヒョロ子の髪毛を放しながら、「ソレ、捕まるぞ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様の処には髪毛や髭を蓬々と生やした真裸の怖い顔の男と、背の高い女と低い男の三人が昨夜から泊まっているだろう」「ヘヘイ」　と、宿屋の主人は寝床の上に手を突いて、ふるえながら返事をしました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍛冶屋のお爺さんは不意に門口から笑うものが居るので吃驚して顔をあげて見ますと、髪毛と髭を蓬々とさした真裸体の男が鞄を一つ下げて立っておりますので、大層腹を立てまして怒鳴り付けました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその下に胴を作り、足を作ってしまいますと、今度は髪毛をたたき出し、眼鼻を刻みつけ、耳から手足の指から爪まで作りつけて、まるで女神のように美しい女としてしまいました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、うつむいていた若い男が、濡れた髪毛を右手でパッとうしろへはね返しながら、キッと顔をあげて巡査を仰いだ。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中でも取りわけて恐ろしかったのは、蓬々と乱れかかった髪毛の中から、真白くクワッと見開いていた両眼であったという。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白い糸のような身体に、髪毛をバラバラとふり乱して、眼の玉を真白に剥き出して、歯をギリギリと噛んで、まるで般若のようにスゴイ顔つきであったが、慌てて抱き止めようとする西村さんを突き飛ばすと、踊りを止めてボンヤリ突立っているハイカラ美人に、ヨロヨロとよろめきかかった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
