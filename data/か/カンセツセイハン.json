          "standard": [
            {
              "text": "状況証拠から、彼が部下を操った間接正犯であると検察は主張した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "刑法における間接正犯の成立要件は、常に議論の対象となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "自ら手を下さずとも、他人を利用して犯罪を実行した場合、間接正犯となり得る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "……ねえ、あたしのような小供を利用して強盗を働くのは間接正犯といってね、よしんばあたしは助かっても、君は絶対に助からないよ。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
