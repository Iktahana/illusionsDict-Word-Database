[
  {
    "uuid": "776a132a-88f1-52b9-ace7-cfb3ce1cdf80",
    "entry": "仮名文",
    "reading": {
      "primary": "かなぶん",
      "alternatives": [
        "かなぶみ"
      ],
      "is_heteronym": false
    },
    "grammar": {
