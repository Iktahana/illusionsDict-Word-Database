        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖母から届いた手紙は、いつも優しい仮名文で書かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "外国人に日本語を教える時、まず仮名文で手紙を書く練習から始める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の恋文は、相手への配慮から仮名文で書かれることもあったらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
