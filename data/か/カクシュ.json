[
  {
    "uuid": "c141e280-592c-50ea-b948-b381ee840688",
    "entry": "各種",
    "reading": {
      "primary": "かくしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
