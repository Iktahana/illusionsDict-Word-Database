        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "動物園で子供がカンガルーの跳躍力に目を輝かせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "オーストラリアの広大な大地で、野生のカンガルーが群れで草を食べている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カンガルーの赤ちゃんはお母さんのお腹の袋から顔を出す仕草がとても可愛い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの店のマスコットキャラクターは、いつも元気に跳ね回るカンガルーだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また、桃太郎が生まれなかったらそのかわりに栗から生まれた栗太郎が団子の代わりにあんパンかキャラメルを持って猫やカンガルーを連れてやはり鬼が島は征伐しないでおかないであろう。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンガルーとエナメルの高価い靴を買わされたのも同時であった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の片隅の洋服掛に美事なタキシードが掛けてあって、その上下にベロア帽とカンガルー皮の靴と銀頂のスネーキウッドの杖が置いてある。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはカンガルーなどと同じく、袋獣類の物で平猴（コルゴ）と縁がない。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと三本脚になったように見えますが、カンガルーや、尾長猿などは、太い尻尾をたいへん巧みにつかえますねえ、あのように活用するといいと思いますよ。",
              "citation": {
                "source": "特許多腕人間方式",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その紳士は四十ばかりに見える髪の黒い、鬚のない、灰色の外套を着て、カンガルーのエナメル靴を穿いた方で、最前キチガイのように騒いで、ハドルスキーさんに抱き止められた人でしたが、嬢次様はその人を指さして、あの紳士が叔父様の狭山九郎太氏と教えられました」「えっ」　とストーン氏は思わず身を乗り出した。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "白茶気た羅紗の旅行服に、銀鼠色のフェルト帽を眉深く冠って、カンガルー皮の靴を音もなく運んで来た姿は、幽霊さながらの弱々しい感じである。",
              "citation": {
                "source": "人間レコード",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはカンガルーの燻製でございます」「カンガルーの燻製？",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを下されば、このカンガルーの燻製を置いてまいります。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "下さらなければ、折角ですが、カンガルーの燻製は、再び私が背負いまして……」「わかったよ、もうわかった。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンガルーの燻製はどうだ」「いや、カンガルーは動物園のような臭いがしていけません。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴は、おれたちのところから、カンガルーを何頭、盗んでいったかわからない。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりカンガルーの尻尾とおなじところについていた。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「燻製も、一番うまいのはカンガルーの燻製ですな。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "器用な早業で、カンガルーの股燻製を一｜挺、上衣の下へ隠しやがった。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも道理、今、博士は燻製のカンガルーを喰べることに夢中になっている。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャーチルも申しとりましたが都合によっては、カンガルーの産地オーストラリア全土を博士に捧げてもよいと申して居りますぞ。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンガルーの燻製が、悉く博士の胃袋に収るまでは、まず何にも言わないつもりらしい。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき、いやというほどカンガルーの燻製を喰ったよ。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩山のかげからとびだした火星兵のむれは、ぴょんぴょんとカンガルーのように軽く、そうして早くとんでいく。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今、ミドリ大溝を、カンガルーの如く飛び越えたところ”　だとか、“第二斥候隊報告。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　カンガルーとまちがえてる。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄造は、彼女がカンガルーのやうに腹を膨らして、切なげな眼つきをしてゐるのを見ると、「阿呆やなあ、そないに何遍も腹ぼてになつたら、お婆さんになるばかりやないか。",
              "citation": {
                "source": "猫と庄造と二人のをんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄造は、彼女がカンガルーのように腹を膨らして、切なげな眼つきをしているのを見ると、「阿呆やなあ、そないに何遍も腹ぼてになったら、お婆さんになるばかりやないか。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物カンガルーの高さ五尺、目方二十四貫目なるものありと聞く。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろこんどは、室代が倍だもの」　素子はカンガルーの毛皮をつけた新調の外套を着てきていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
