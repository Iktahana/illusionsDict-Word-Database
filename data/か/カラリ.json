    "definitions": [
      {
        "index": 1,
        "gloss": "with a clatter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "棚から落ちた皿が、床に落ちてからり！と割れる音が響いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "雨戸が風で揺れて、からり、からりと不気味な音を立てていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古い引き出しを開けようとしたら、中身がからり、と音を立てて散らばった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "蛙は寧ろラードのようなものでからりと揚げた方があっさりしていてよくはないだろうか。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後は奈々子が一昼寝してからであった、雪子もお児もぶらんこに飽き、寝覚めた奈々子を連れて、表のほうにいるようすであったが、格子戸をからりあけてかけ上がりざまに三児はわれ勝ちと父に何か告げんとするのである。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の午後――もう夕方近くになつて雨がからりと晴れて、雲切の間から夏らしく澄んだ紺青の空が見え出した。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "境内の変にからりとしている訳もこれで合点が行って、あるべきものが亡せているのだなと思いながら、庫裡へと入った。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "感謝である、とその日から四、五日間は、胸の内もからりとしていたのであるが、また、いけなかった。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの橋でも真新らしい日和下駄の前を橋板に突き当てて、こんと音をさせ、その拍子に後歯を橋板に落してからりと鳴らす必要があった。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こん　からり　足を踏み違えて橋詰から橋詰までこの音のリズムを続け通させるときは、ほんとにお腹の底から橋を渡った気がして、そこでぴょんぴょん跳ねて悦んだ。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　吾妻下駄をからりと鳴して、摺下る褄を上衣の下に直した気勢。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と呼ぶ、……本を讀んでたとは、からりと調子が變つて、引入れられさうに滅入つて聞えた。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "からりと廂を鳴らしたのは、樋竹を辷る、落たまりの霰らしい。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "からりと鳴って、響くと斉しく、金色の機の梭、一具宙を飛落つ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時｜向こうのにわとこの陰からりすが五｜疋ちょろちょろ出て参りました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからりすは、夕方までに鈴蘭の実をたくさん集めて、大騒ぎをしてホモイのうちへ運びました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しや忌々し何奴ぞと得三からりと部屋の戸開くれば、かの声少し遠ざかりて、また、「赤城様、得三様。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白魚をからりッと煎り上げて、鷹の爪でお茶漬が、あっさりとして異う食わせる。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子の外には人気勢して、くすくす笑い、三太夫は大粒の涙ほろほろ、刀をからりと投棄てて、「切った割に血の出ぬは、むむ、今日は血を流すと、荒神様が祟る日だ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　からりと笑って、「私等の氏神様だ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――九月の二十日前後に、からりと爽かにほの暖かに晴上つた朝、同じ方角から同じ方角へ、紅舷銀翼の小さな船を操りつゝ、碧瑠璃の空をきら／＼きら／＼と幾千萬艘。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと中六の通りの南外堂と言ふ菓子屋の店の、この處、砂糖氣もしめり氣も鹽氣もない、からりとして、たゞ箱道具の亂れた天井に、つゝみ紙の絲を手繰つて、くる／＼と※りさうに、右の車麩のあるのを見つけて、おかみさんと馴染だから、家内が頼んで、一かゞり無理に讓つて貰つたので――少々おかゝを驕つて煮た。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "晃　（からりと鎌を棄て）いや、身代りなら俺を縛れ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、敵は血に染みたる洋刃を揮って、更に市郎を目がけて飛び蒐って来たが、其の眼前に恰も燐寸の火が溌と燃ゆるや、彼は電気に打たれたように、猝に刃物をからりと落して、両手で顔を掩ったまま、霎時そこに立縮んで了った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、呟いた咄嗟に、道子の心はからりと晴れた。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、産声が空に響くようなからりと晴れた小春日和だったが、翌日からしと／＼と雨が降り続いた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "からりと晴れた夕空、はじめてみん／＼蝉が鳴いた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の所得（銭七十九銭、米二升一合）今日の買物　一、五銭　キセル　　　　　　一、三銭　シヤモジ　　　　　　一、四銭　ハシ　　　　　　一、弐十四銭　サケ　八月十三日からりと晴れてゐる、身心もさつぱりしてゐる、今日は昨日の分まで行乞しなければならない。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "改作・からりと晴れたる法衣で出かける　　　追加二句　みんな寝てしまつてゐるポストのかげがはつきり　見おくるかげは見えない松むし鈴むし（樹明君に）　八月十五日晴、宿酔ほがらかである、昨夜、最後の一片まで賞味した鮒のあらひのうまさがまだ残つてゐる！",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "・寒空のからりと晴れて柿の木・ふくらうがふくらうに月は冴えかへる・よつぴて啼いてふくらうの月・冴えかへる月のふくらうとわたくし・恋のふくらうの冴えかへるかな　二月十五日雪、雪はうつくしいかな、雪の小鳥も雪の枯草も。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "風のなか酔うて寝てゐる一人・木の芽、いつもつながれてほえるほかない犬で・つながれて寝てゐる犬へころげる木の実・春風のはろかなるかな鉢の子を・からりと晴れたる旅の法衣の腰からげ　三月十三日折々降るが、ぬくいので何よりだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "with a fling (opening a door, window, etc.)",
