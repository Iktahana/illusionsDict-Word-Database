    "definitions": [
      {
        "index": 1,
        "gloss": "skipjack tuna (Katsuwonus pelamis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「今日のランチは鰹のたたき！脂が乗ってて最高！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "初鰹の時期は、旬の味覚を求めて多くの人が市場に集まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わー、この鰹の刺身、全然臭みがなくて美味しい！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔は、鰹の一本釣り漁が盛んだったらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "飢えに泣いているはずの細民がどうかすると初鰹魚を食って太平楽を並べていたり、縁日で盆栽をひやかしている。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら資本主義の統治下にあって、鰹節のような役目を勤める、プロレタリアであったにしても、職業を選択する権利丈けは与えられているじゃないか。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリアは「鰹節」だ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰ってから用心に鰹節、梅干、缶詰、片栗粉などを近所へ買いにやる。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土佐の貧乏士族としての我家に伝わって来た雑煮の処方は、椀の底に芋一、二片と青菜｜一とつまみを入れた上に切餅一、二片を載せて鰹節のだし汁をかけ、そうして餅の上に花松魚を添えたものである。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また塩魚類｜鰹節の乾燥とか寒天の凍結とかいう製造方面の事柄にも物理学応用の範囲は意外に広大であるように見受けられる。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがある時台所で出入りの魚屋と世間話をしながら、刺身包丁を取り上げて魚屋の盤台の鰹の片身から幅二分くらい長さ一尺近い細長い肉片を巧みにそぎ取った。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、さんまじゃ、いくらも値段がとれないからね」「おとッつあん、なかなか商売を知っている」　その他、鮨の材料を採ったあとの鰹の中落だの、鮑の腸だの、鯛の白子だのを巧に調理したものが、ときどき常連にだけ突出された。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "肝油その他の臓器製薬の効能が医者によって認められるより何百年も前から日本人は鰹の肝を食い黒鯛の胆を飲んでいたのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういえば、春過ぎて若葉の茂るのも、初鰹の味の乗って来るのも山時鳥の啼き渡るのもみんなそれぞれ色々な生化学の問題とどこかでつながっているようである。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うむ、大丈夫さ」　だが、力の強い、鰹船に行っていた川井がすぐ、帯剣だけで立ち上った。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ白石の在所うまれなる、宮城野と云ひ信夫と云ふを、芝居にて見たるさへ何とやらむ初鰹の頃は嬉しからず。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者知るや、さんが、オムレツを啣んで、あゝ、うまい、と嘆じ、冴返る身に沁々とほつき貝と、芥川さんが詠じて以来、――東京府の心ある女連は、東北へ旅行する亭主の為に鰹のでんぶと、焼海苔と、梅干と、氷砂糖を調へることを、陰膳とゝもに忘れない事に成つた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「これは、しやぼん、鰹節以上ですな。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日も、毛唐がどんなに威張っても、この鰹の塩辛ばかりは嘗める事が出来まい、けれども僕なら、どんな洋食だって食べてみせる、と妙な自慢をして居られた。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰹節を半分に切って買うみたい。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからＴは国のみやげに鰹節をたった一本持って来たと言って笑われたこともある。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勃凸は着物を腰までまくり上げて、粗い鰹縞のやうな綿ネルの下着一つで胡坐をかいてゐた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二一課　橋は流れて水は流れず　私たち鰹節をナイフで削るときには、鰹節を確と握り押えてナイフの方を動かして削ります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰹節を橋とし、ナイフを水としますと、この場合は、この章の標題とは反対の「水は流れて橋は流れず」であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、鰹節削りの鉋が出来て鰹節を削るときには、今度は鰹節の方を動かします。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合には橋に譬えた鰹節の方を動かし、水に譬える鉋は動かさないのですから、「橋は流れて水は流れず」です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰹節を削るのには必ず鰹節を握り押えて削るもの、すなわち「水は流れて橋は流れず」の一方ばかりの考え方に凝り固まっている人は、折角鰹節削りの鉋箱が出来ても、どこまでも鰹節の方を動かしてはならぬものとして、鉋箱を逆にして鰹節に宛てがうでしょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛸氏はグイグイと麦酒をあほり、傲然たる態度を示してゐたが、突然席の向ひ側に坐つて飲んでゐたカツオ氏の顔へ、蛸氏は手にしたコップの麦酒をかけた、カツオ氏はグッと癪に触つたが、酒の上のこととして勘弁し、鰭をもつて顔にかゝつた麦酒を拭つた、すると又もや蛸氏はコップの麦酒をカツオ氏の顔へかけた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "度々のことにさすがの温厚なカツオ氏も、非常に腹をたて、さてその復讐の方法としてカツオ氏は、食卓の上の醤油の容器をパッと蛸氏の顔にかけ、次にその傍の砂糖の容器をなげつけ、つゞいて酢の入つた容器を投げつけたので、蛸氏は醤油と砂糖と酢とをあびて、はからずも蛸の三杯酢ができてしまつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中大兄」は、考ナカツオホエ、古義ナカチオホエ、と訓んでいる。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外に〕　賤ハタ、なみ、髪結新三、「カツオは半分貰ってゆく」有名な文句を始めて見たが、あれは、前あてでよろしからず、菊の新三、あすこで俄に痴呆となる。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉田組の持船は二十四隻ありまして、十五トンから四十トンぐらいまでゞすが、カツオ船や棒受け網やキンチャク網や色々とあって、禁漁水域へ密漁にも出かけているように取沙汰されております」「それでは久七をつれてきたまえ」　久七は体格の立派な、見るからに力の強そうな若者であった。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "カツオとマグロはカンヅメになって米国へ輸出されるが、これが七面鳥の味に似ているので大モテだそうだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がむかし京都伏見の天下に稀れな安食堂の二階に下宿してゴロゴロしていたころ、毎日のようにボイルしたカツオ、これをナマリと云うそうだが、毎日々々食わされたネ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
