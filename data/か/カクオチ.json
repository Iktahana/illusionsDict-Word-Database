[
  {
    "uuid": "9d97e711-910b-5d9d-bd35-d49c4e251f7d",
    "entry": "角落ち",
    "reading": {
      "primary": "かくおち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "game of shogi in which the stronger player plays without the bishop",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼がハンデとして角落ちで指すなら、私も本気で臨むよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "プロ棋士がアマチュアに角落ちで勝つのは当然のことだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "友人との将棋は、いつも角落ちのハンデ戦になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "角落ちのハンデは、初心者にとっては非常に厳しいものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "筋がいゝのか最初歩三つが一月経つと角落ちになり、二月目には平手で指せるようになった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "筋がよいのか最初歩三つが一日経つと角落ちになり、やがて平手で指せた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "角落ちで、見事に三番棒でさア」「そうだってな」「マキは運んでいいでしょうね」「うるせえな。",
              "citation": {
                "source": "町内の二天才",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし、どこかの壁にかけて見たところが、調子はずれになって折角落ちついている室の空気が掻き乱される。",
              "citation": {
                "source": "芸術と社会",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "南極の凍りついた海底ふかくおちこんだうえに、人間の幽霊のほかに、林檎の幽霊にまで、くるしめられるとは、なんという情けないことだろう。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一巻第二十一章でも、それはむしろ我々自身の想像力の結果で、見えもしないものを見てさわいでいるのだと考え、凡俗の者がとかくおち入りやすい迷いにすぎないと言っている。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の推理がとかくおちいりがちな誤謬迷蒙を補填修正するためには、経験すなわち事実の中に強力な拠点を見出そうと言う。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
