        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔ながらの祭りのために、特設の掛け小屋が建てられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その劇団は、各地を巡業しながら移動式の掛け小屋で公演を行っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夏祭りの夜、掛け小屋では賑やかな演劇が上演された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「さあ、いよいよだ！」と、掛け小屋の幕が開くのを待った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "下谷の仲町に住んでいて、おくやま（浅草）の掛け小屋しばやとかの道具方をやっているというねたが上がりましたからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "小芝居、手品、見世物、軽業、――興行物の掛け小屋からは、陽気な鳴り物の音が聞こえ、喝采をする見物人の、拍手の音なども聞こえて来た。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、一つの掛け小屋が、彼の好奇心を刺戟した。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり酷い悪口を云うと、この掛け小屋をぶち壊すぞ！",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八ヶ嶽の山男」　――こういう看板を上げている、その掛け小屋の太夫達であった。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遥か彼方の境内の外れに、菰張りの掛け小屋が立っていた。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "興行物の掛け小屋であった。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "窩人達の出演ている掛け小屋であった。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その掛け小屋の入り口の辺に、豆のような灯火がポッツリと浮かんだ。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛け小屋へ帰って武器を取れ！",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊廓というのも気恥ずかしいような、そんな遊廓を中心にして、煮売り屋、小茶屋がゴチャゴチャあり、江戸両国の盛り場を真似た、掛け小屋なども出来ており、手品、軽口、不具の見世物、そんなものをやっていた。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "阪東米八の掛け小屋は、かなり立派で大きかった。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははあ芝居の看板か」　坂東米八の掛け小屋が、旗や幟で飾られて、素晴らしい景気を呼んでいたが、そこに懸けられた、絵看板に、宿場女郎らしい美女の姿が、極彩色で描かれていた。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "看板を貫いたその余勢で、掛け小屋の板壁を貫いていた。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「府中の火祭り賭場は有名、関東の親分衆が、駒箱を乾児衆に担がせ、いくらともなく出張って来、掛け小屋で大きな勝負をやる筈。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽業、落語、女義太夫――などの掛け小屋もかかっている。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両国広小路の掛け小屋から、抜け出たところから想像すれば、蛇使いの女太夫、組紐のお仙が商売がら、蝮捕り姿に身をやつし、恋しい男を追っかけて木曽路へ行くに違いない。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "立派な掛け小屋の舞台に立ち、鍛えに鍛えた真髄の芸！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子権現境内の手妻使い、日本一太郎と申すものの掛け小屋に失火がございまして――」「これこれ」忠相が、ちょっと声を高めると、次の間との襖を背に、ぼんやり控えて殿と木甚との会話を聞いていた用人の伊吹大作が、かしこまって、耳を立てた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子権現の祭で、日本一太郎と名乗るお高の父相良寛十郎の掛け小屋で火事があって、磯屋五兵衛が焼死して、お高が自由の身になったというのである。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験室は北側の差し掛け小屋にしつらえられ、その屋根は地上すれすれまで延びていた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "――三河のくに岡崎城下の西のはずれにある光円寺の境内で、「岩本新之丞一座」というのが掛け小屋の興行をした。",
              "citation": {
                "source": "みずぐるま",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "興行の掛け小屋は、丸太で組み蓆と幕で囲ったもので、楽屋と舞台は床があげてあり、客席の半分も桟敷になっているが、大半は立ったまま見物するようになっていた。",
              "citation": {
                "source": "みずぐるま",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたし庄太夫を見にいってるけど、誰にも教えないでね」　梯子をおりたすぐ裏に、やはり蓆で囲った掛け小屋がある。",
              "citation": {
                "source": "みずぐるま",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときに、なぐりつけるように、風速二五メートルもの突風が、トタンの看板を飛ばし、屋根瓦をはぎ、掛け小屋を倒した。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは浅い谷間の湯治場で、宿は三軒あるが、二軒は自炊客だけの、掛け小屋同様のものであり、一軒だけは二階造りで、部屋数も三十ちかくあった。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "たやすく記せないかずかずの苦労があったけれど、その年の冬には小坂井の里に小あきないの掛け小屋をはじめることができ、どうやらふたりの口はすごせることになった。",
              "citation": {
                "source": "日本婦道記",
                "author": "箭竹",
                "note": "青空文庫"
              }
            },
            {
              "text": "四天王寺の日除地、この間までの桃畑が、掛け小屋御免で、道頓堀を掬ってきたような雑閙だ。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつぞや七条河原の田楽舞の掛け小屋へ入った折、人気者の花夜叉とかいう田楽役者が唄った唄の一と節を……」「ははあ、花夜叉のあれですか」　右馬介も思いうかべた。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
