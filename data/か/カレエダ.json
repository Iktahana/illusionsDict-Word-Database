    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dead branch (or twig, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭の木から落ちた枯れ枝を拾い集めて、焚き火の燃料にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "強風で、大きな枯れ枝が電線に引っかかってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この枯れ枝、そのまま飾っても雰囲気が出るね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "別に怪しい者でなく三人の小娘が枯れ枝を拾っているのでした。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "山路で、大原女のように頭の上へ枯れ枝と蝙蝠傘を一度に束ねたのを載っけて、靴下をあみながら歩いて来る女に会いました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯れ枝がブラ下ったり、杉の木が傾いたりして、だんだんと廃墟じみた感じをあらわし始めた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この近在の百姓が御料地の森へ入って、枯れ枝を集めるのは、それは多分禁制であろうが、彼らは大びらでやっているのである。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句の全然わからなかったらしいチャンバーレン氏の言ったように、それはただ油絵か何かの画題のようなものに過ぎなくなり、芭蕉の有名な句でも「枯れ枝にからすのいる秋景」になってしまうであろう。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして枯れ枝から古池へと自然のふところに物の本情をもとめた結果、不易なる真の本体は潜在的なるものであってこれを表現すべき唯一のものは流行する象徴による暗示の芸術であるということを悟ったかのように見える。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁の下には枯れ枝や竹切れがほうり込んであるので、父は手ごろの枝を持ち出して静かにあるき始めた。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "くちつけのあとのとれもろ麥の芽の青またその色は藍で金石のてざはりぶらさがつた女のあし茶褐で雪の性土龍の毛のさみしい銀鼠黄の眩暈、ざんげの星まふゆの空の飛行機枯れ枝にとまつた眼つかち鴉。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからすこし森の奥の方へ進み入りますと、芝草が無くなって、枯れ葉と、枯れ枝ばかりの平地になりました。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつれて身体中の毛穴から沁み入るような冷たさ、気味わるさが一層深まって来るようで、その枯れ葉や枯れ枝が、私の掌や膝の下で砕ける、ごく小さな物音まで、一ツ一ツに私の神経をヒヤヒヤさせるのでした。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれで枯れ枝などを切ると刃が欠けるという主人の言葉はほんとうらしかった。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わりに大きく長い枯れ枝の片を並べたのが大多数であるが、中にはほとんど目立つほどの枝切れはつけないで、渋紙のような肌をしているのもあった。",
              "citation": {
                "source": "簔虫と蜘蛛",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「併し、それにあ、開墾場の最初から話さねば判らねえから……まあ、火でも焚いてあたりながら……馬鹿に寒くなって来たから……」　雄吾は倒れている大木に猟銃を立て掛けて、時雨に濡れた落ち葉の間に、枯れ枝を探し歩いた。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こう言って雄吾は、焚き火に屈み込んで枯れ枝を重ね直した。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に二、三の問答を終って二人は庫裏の方へまわって見ると、納所の了哲と小坊主の智心があき地へ出て、焚き物にするらしい枯れ枝をたばねていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はそこらに落ちている枯れ枝を拾って叩き付けた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾州侯の山荘以来の遺物かと思われる古木が、なんの風情も無しに大きい枯れ枝を突き出しているのと、陸軍科学研究所の四角張った赤煉瓦の建築と、東洋製菓会社の工場に聳えている大煙突と、風の吹く日には原一面に白く巻きあがる砂煙りと、これだけの道具を列べただけでも大抵は想像が付くであろう。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "庫裏をのぞくと、寺男の銀蔵おやじが薄暗い土間で枯れ枝をたばねていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "小女郎狐",
                "note": "青空文庫"
              }
            },
            {
              "text": "何が困るんだ」と、長次郎はそこに束ねてある枯れ枝の上に腰をおろした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "小女郎狐",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して今日の様に枯れ枝を、「可哀そうにお爺さんの木や。",
              "citation": {
                "source": "小さい子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お釜に重しをしてしまうと、こんどはまた、お庭から枯れ枝をたくさん集めて来て、小さく折っては、お釜の下に入れました。",
              "citation": {
                "source": "山姥の話",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴしりぴしり枯れ枝を折る音が、寝ている山姥の耳に聞こえたとみえて、山姥はお釜の中で、「雨の降る夜は虫が鳴く。",
              "citation": {
                "source": "山姥の話",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "山姥がいい心持ちそうに、ぱちぱちいう枯れ枝の音を雨の音だと思って聞いていますと、その間に馬吉は枯れ枝に火をつけました。",
              "citation": {
                "source": "山姥の話",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬吉はかまわずどんどん枯れ枝を燃やしながら、「馬喰うばばあはどこにいる。",
              "citation": {
                "source": "山姥の話",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "但、儀作は、最初の場面に現われた時よりも一畝ほど余計に畠を作っているが、傍に居る痩せた少女も、その半分の処まで、枯れ枝や瓦の破片を植えつけている。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯……最前から歌を唄って踊りまわっていた筈の、舞踏狂らしいお垂髪の女学生が、私たちの立っている窓のすぐ下に、肩まで手が這入るような砂の穴を掘って、ボール紙の王冠と、松の枯れ枝を利用しながら、小さな陥穽を作りかけているのが、少々脱線しているように思われるだけである。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「斬るぞ」「まあ、まあ」　岩の上に立ちすくんでいた頬かむりの男は、枯れ枝の先をつかんでおそるおそる向き直った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
