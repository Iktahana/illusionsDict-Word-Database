[
  {
    "uuid": "61e429e1-1738-5812-a4e2-4d505314c3d2",
    "entry": "枯れ枝",
    "reading": {
      "primary": "かれえだ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
