        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔の印刷所では、職人が一つ一つ活字を並べていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "活字のフォントやサイズを変えることで、本の印象は大きく変わる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この博物館では、貴重な活字コレクションを展示している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "自分も時に応募していたが、自分の書いた文章が活字になったのは多分それが最初であったと思う。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "入学証書と云ったような幅一尺五寸｜長二尺ほどの紙に大きな活字で皇帝や総長の名を黒々と印刷したものを貰ったが文句はラテン語で何の事か分らない、見ていると気の遠くなるようなものであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちよつと座談では言へるのであるが、ことごとしく純文學雜誌に「昨日、朝顏を植ゑて感あり」などと書いて、それが一字一字、活字工に依つて拾はれ、編輯者に依つて校正され、（他人のつまらぬ呟きを校正するのは、なかなか苦しいものである。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、葛原勾當日記の、假名文字活字日誌を土臺にして、それに私の濁創も勝手に加味し、盲人一流藝者の生活を、おぼつかなく展開してみたものでした。",
              "citation": {
                "source": "文盲自嘲",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御住所を搜し、こちらからお訪ねして、なほ精しく故人の御遺徳をも伺ひ、それから、私ごとき非文不才の貧書生に、この活字日誌の使用を御許可下さるかどうか、改めてお願して、そのおゆるしを得て、はじめて取りかかるべき筋合ひのものであるとは、不徳の小文士と雖も、まづは心得て居りました。",
              "citation": {
                "source": "文盲自嘲",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その氷河で思い出したが、私が桑港にいるとき、一九二四年九月十八日の夕、新聞の号外売りが、声高く「ラッセン火山大爆裂、シャスタ氷河大融解」と、大の字｜尽くしで呼んでいるので、耳寄りに思って買って見ると、いかにもシャスタ山の、氷河融解、大洪水来と、拳大の活字で見出しがついている。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴム長靴の脛だけの部分、アラビアンナイトの粟粒のような活字で埋まった、表紙と本文の半分以上取れた英訳本。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルの上へ、まだ活字が揮発油で濡れているパリ・ミデイの一版を抛り出して、キャフェの蕭条をまづ第一に味わいに来たのは Boulevardier（界隈の人、或は大通漫歩の人と訳すべきか）と呼ばれている巴里の遺物である。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはその人の卓子の足もとから一つの小さな平たい函をとりだして向ふの電燈のたくさんついた、たてかけてある壁の隅の所へしゃがみ込むと小さなピンセットでまるで粟粒ぐらゐの活字を次から次と拾ひはじめました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは何べんも眼を拭ひながら活字をだんだんひろひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六時がうってしばらくたったころ、ジョバンニは拾った活字をいっぱいに入れた平たい箱をもういちど手にもった紙きれと引き合せてから、さっきの卓子の人へ持って来ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "円満に解決」と例の大きな活字の見出しが出ている。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その世界では現在あるような活字で印刷した書物の代りに映画のフィルムのようなものが出来ていて、書庫の棚にはその巻物がぎっしり詰っている。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての仕掛けはこの車の同時調節によって有効になるので、試みにわざとちょっとばかりこの調節を狂わせると、もう受信機の印刷する文句はまるきり訳の分からぬ寝言にもならない活字の行列になってしまうのである。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでは何度読んでも結局はただの活字の行列を見物しているのもたいしたちがいはなさそうである。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッチのペーパーや活字の断片がそのままに眼につくうちはまだ改良の余地はある。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると第一通は英文で温泉へ宛てた四十人宿泊準備の依頼状で特に食事は白米の飯と大根の味噌汁と香の物だけを仕度してくれ但し価格は一日十円以内といふ　第二通は仲間へ出した活字の通知状であった。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはその人の卓子の足もとから一つの小さな平たい函をとりだして向うの電燈のたくさんついた、たてかけてある壁の隅の所へしゃがみ込むと小さなピンセットでまるで粟粒ぐらいの活字を次から次と拾いはじめました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは何べんも眼を拭いながら活字をだんだんひろいました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "国定教科書の肉筆めいた楷書の活字。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう意味から言えば、新聞記事に現われた除幕式は純然たる概念的公式的の除幕式であって、甲のものと、乙のものとは人名などの活字面が少しちがうだけであって、どれもこれも具象的内容においては全く同じものである。",
              "citation": {
                "source": "ニュース映画と新聞記事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなのに、活字の大小の使い分けや、文章の巧妙なる陰影の魔力によって読者読後の感じは、どうにも、書いてある事実とはちがったものになるのである。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "活字本だと、もしか九年の誤植であるかもしれない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ英文活字に若干遺憾の点があるが、これもある意味ではこうした限定版の歴史的な目印になってかえっておもしろいかもしれないのである。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、そのすぐ次に、やっぱり柏木の叔父さんにすすめられて、「春日町」という綴方を投書したところが、こんどは投書欄では無しに、雑誌の一ばんはじめのペエジに、大きな活字で掲載せられて居りました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、それが雑誌の一ばんはじめのペエジに大きい活字で印刷されて、たいへんな事になりました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また沢田先生だって、本当に私の綴方に感心なさっているのではなく、私の綴方が雑誌に大きい活字で印刷され、有名な岩見先生に褒められているので、それで、あんなに興奮していらっしゃるのだろうという事は、子供心にも、たいてい察しが附いて居りましたから、なおのこと淋しく、たまらない気持でした。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「帝国・米英に宣戦を布告す」という活字の大きいこと。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはその人の卓子の足もとから一つの小さな平たい函をとりだして向こうの電燈のたくさんついた、たてかけてある壁の隅の所へしゃがみ込むと、小さなピンセットでまるで粟粒ぐらいの活字を次から次へと拾いはじめました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで会話は、どうにかつじつまがあいました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
