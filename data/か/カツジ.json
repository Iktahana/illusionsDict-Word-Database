        "examples": {
          "standard": [
            {
              "text": "電子書籍も便利だが、やはり紙媒体の活字の温かみも捨てがたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は寝る前に、いつも小説の活字を目で追うのが習慣だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "図書館には、数え切れないほどの活字が詰まった書物が並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
