[
  {
    "uuid": "99626a86-24ad-57b9-8ecd-46b2d26c7b91",
    "entry": "風音",
    "reading": {
      "primary": "かざおと",
      "alternatives": [
        "かぜおと"
      ],
      "is_heteronym": false
    },
    "grammar": {
