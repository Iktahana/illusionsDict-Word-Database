    "definitions": [
      {
        "index": 1,
        "gloss": "patient's chart",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "病院の受付で、新しいカルテを作成してもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医師は患者のカルテを確認しながら、今日の診察内容を説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "前の病院からのカルテが届き、治療方針の参考にされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "看護師が誤ってカルテを別の患者のものと取り違えてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "電子カルテの導入により、情報共有がスムーズになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "トリオやカルテットの仲間がよくできては解散し、解散してはまた別の組ができるのであるが、事情を聞いてみると皆仲間の間の個性の融和がつきにくいのに帰因するようである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリオやカルテットぐらいならば別に指揮者を必要としないが、少し楽器が多くなって管弦楽の形をとるようになれば、もはやそれは一人のちゃんとした指揮者なしには進行することができなくなる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉は定食でいいという、歌麿はア・ラ・カルテを主張する。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "競技は、そのうえ、私の得意のエカルテ（10）だった。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君はたしかに、今夜グレンディニング卿からエカルテで大金をまき上げた人間の本性をご存じない。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の袖の裏から、エカルテにもっとも肝心なあらゆる絵札が発見され、ラッパーのポケットからは、たくさんの骨牌札が発見された。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "積極的ニ見ルトキ大資本ノ國家的統一ニヨル國家經營ハ米國ノ「ツラスト」獨逸ノ「カルテル」ヲ更ニ合理的ニシテ國家ガ其ノ主體タル者ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ツラスト」「カルテル」ガ分立的競爭ヨリ遙カニ有理ナル實證ト理論ニヨリテ國家的生産ノ將來ヲ推定スベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "其ノ外國同業者トノ競爭能力等ハ「トラスト」「カルテル」ヨリ推論シ得ベク、以下ノ各省皆同ジ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "工業ノ「トラスト」的「カルテル」的組織ハ資本乏シク列強ヨリ後レタル日本ニハ特ニ急務ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と極つたやうに汚れたカルテへ間違だらけの独逸語を走り書する。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代日本の文化を進めるには、麺麭にジヤムをつけて噛じるのもよい、また覆盆子に牛乳をぶつ掛けて啜るのもよいが、それよりもずつと効力があるのは、羅馬字を普及させる事だと信じてゐる博士は、カルテは無論の事、手紙から日記に到るまで、すべて羅馬字で書く事に定めてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のカルテュアは多方面で、しかもそれ／″＼に理解が行き届いている。",
              "citation": {
                "source": "兄貴のような心持",
                "author": "――菊池寛氏の印象――",
                "note": "青空文庫"
              }
            },
            {
              "text": "細川三之助は、一向そんなことには頓着なく、奥でカルテを見ている白衣を着た禿頭の老人の所に行くと、しばらく何かぼそぼそと話しあっていたが、やがて、その二人は、何か頷きながら中野を麾ねいた。",
              "citation": {
                "source": "地図にない島",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "成河副院長は、懶げにカルテを流し見て聴診器を耳に差込んだ。",
              "citation": {
                "source": "※の囁き",
                "author": "――肺病の唄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外、ピョートル・セルゲイヴィッチとムーシャの間に政治的意見の相異からもつれがあり、又革命につれて出入するうさん臭き分子も描出され、なかなか多くのものを十八カルティンにまとめようとして居る。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "十万分ノ一スウィス地形図に、ドゥフール・カルテ Dufour Karte と云うのがあるが、私は好まない。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルテル、トラストが自由通商主義の資本主義としてはすでに矛盾形態であるように、それを背景として成立する芸術はもはや発生期個人主義と矛盾せずにいられない。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この場合の集団主義は利潤を目標とするところの集団であって、ちょうどトラストおよびカルテルがみずから資本主義形態としては自己矛盾であるように、かかる利潤的集団主義は天才的独創的唯美的ロマン主義の芸術にとってはすでに自己矛盾なのである。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はい」　出て来た妻に、「すんだから、カルテに書き込みをしなさい」　妻美津子は、更めて警官の方に腰をかゞめた。",
              "citation": {
                "source": "髪の毛と花びら",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "心理学、性格学の立場からこの問題を取扱ふこともある程度できるかも知れぬが、私はさういふ専門に精しくないし、極めて常識的ではあるが、ひろく人間の性情、知能、風俗習慣、時代色といふやうなものを含めて、そこに現代日本、及び日本人の、いはゆる「精神的畸形」を診断するいくつかのカルテを作つてみようと思ふ。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、僕が麻薬中毒だという説がとび、警視庁の三人の麻薬係が現れ、千谷さんはカルテを見せて説得するのに二時間もかかったとこぼしておられた。",
              "citation": {
                "source": "精神病覚え書",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がひそかに盗み見た僕のカルテには、封建主義的｜羞恥症と記載してあつた。",
              "citation": {
                "source": "わが心の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから現在の病状を聞き、それをカルテに書き入れてから、医師は言った。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "助手がそれをカルテに記入する。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いっそ取ってしまったって、いいじゃないか」「以前から、×××（ドイツ語）はないようですが」「じゃ、暫く様子を見ることにしましょう」　教授はその先がコの字型になっている測定器で、私の首筋の痼の大きさを測り、カルテに記入させた。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "院長の後にしたがつたり、あるひは院長の代理で、あの重たい目蓋の垂れかかつた切れの長い眼に、どんより睡さうな色をたたへて、重病人のカルテを取つたり、さも厭々さうに聴診器を当てがつたり、そんな動作だけ繰返してゐれば、よしんば幸福でないまでも、とにかく不幸ではなかつたはずの人なのだ。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽壇人の「無軌道蹂躙戦法」に相呼応して、読売新聞は昭和九年三月十五日の其の紙上に、プラーゲはパリの著作権聯盟（カルテル）の真正の代理人に非ずして贋者なりとの趣旨の記事を掲載して、楽壇人の著作権侵害を声援し且つ煽動した。",
              "citation": {
                "source": "「プラーゲ旋風」の話",
                "author": "山下博章",
                "note": "青空文庫"
              }
            },
            {
              "text": "○社団法人東京音楽協会では著作権使用料問題からパリ著作権聯盟（カルテル・デ・ソチエテー・ドツエル）の代理人ドクトル・プラーゲの代理人たることを拒否する旨通告したのに対して去る十月四日パリのカルテルから東京音楽協会宛に次の如き入電があった。",
              "citation": {
                "source": "「プラーゲ旋風」の話",
                "author": "山下博章",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
