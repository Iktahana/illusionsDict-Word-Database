        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大学を卒業したら、実家に戻って家業の酒屋を継ぐつもりです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "兄は家業には興味がないと言って、都会でIT系の仕事に就きました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "家業を畳むという決断は、父にとっても苦渋の選択だったようです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、そういえば君の実家って家業で旅館を営んでいるんだっけ？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
