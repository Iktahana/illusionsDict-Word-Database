[
  {
    "uuid": "211e78fb-628d-57b5-83e4-2f09da354384",
    "entry": "か行",
    "reading": {
      "primary": "かぎょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the \"ka\" column of the Japanese syllabary table (ka, ki, ku, ke, ko)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "娘は今、ひらがなのか行を練習しているところだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "日本語の動詞には、か行で終わるものが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この辞書は、見出し語をあ行、か行、さ行の順に並べている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "又、之の欠乏する限り、判断といふものもひどく相対的にしか行はれないのではあるまいか。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "短歌詩人は、せいぜい汎神論にまでしか行き得ない。",
              "citation": {
                "source": "河上に呈する詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "美々しい回しをつけた力士が堂々としてにらみ合っていざ組もうとすると、衛士だか行司だかが飛び出して来て引き分け引き止める。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処の学校だか行軍に来たらしい。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天上へなんか行かなくたっていゝぢゃないか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時自分の感じた事は、その鉛筆画が普通のアカデミックなデッサンとはどこか行き方が違っているという事であった。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、一月に七八｜回が二三｜回になり、やがて一｜度行くか行かないかになると、練習不足で腕も鈍くなつて來た。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「天上へなんか行かなくたっていゝぢゃないか。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那、支那、何事か行われているが、収拾しきれない支那！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「嫌いなら、なんにも、社宅へなんか行かなくってもいゝんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天上へなんか行かなくたっていいじゃないか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚とめて、Ｔ「貴女は奇蹟を信じませんか」　傍からお類が、Ｔ「嘘か本当か行って見なければ判らないわ」　と云う。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもての方さざめきて、いずくにか行きおれる姉上帰りましつと覚し、襖いくつかぱたぱたと音してハヤここに来たまいつ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば一つの自動車を作ってその機械の自己の作用で向かう所にどこまでも向かわせる場合には便宜とか選択の問題は起こらぬ、車は行く所にしか行かぬのであるが、これが解析的な数学の行き方とすれば物理学のはそうでない。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はアインシュタインやド・ブローリーがルクレチウスを読んだであろうとまでは思わないが、彼らの仕事に最初の衝動を与え幾度か行き詰まりがちの考えに常に新しい活路を与えたのは、私に言わせれば彼らの頭の中にいるルクレチウスのしわざである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "町はば、せまく、家々の軒は黒く、根強く低く、家の中の電燈は薄暗く、ランプか行燈でも、ともしているよう。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんたうに、僕はそこのバアへ三度、いや四度しか行かなかつたよ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天上へなんか行かなくたつていいぢやないか。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「否、死んだのなら却て斷念がつきますが別れた限、如何なつたのか行方が知れないのですよ。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、死んだのならかえってあきらめがつきますが、別れたぎり、どうなったのか行き方が知れないのですよ。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい近頃になって「Ｂ教授の追憶」を書くときにふとそのＢ教授の手紙を想い出すと同時にこの抽出しとＳ先生の手紙を想い出したのであったが、今ではもう昔の教室の建物はすっかり取毀されてしまって、昔の机などどうなったか行衛も分らず、ましてやその抽出しの中の古手紙など尋ねるよすがもなくなってしまった訳である。",
              "citation": {
                "source": "埋もれた漱石伝記資料",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日自殺者の多いこと、これなどもその原因を全部突き止めて絶無に予防するところまでには、なかなか行っておりません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ずかずか行っちゃ不可んじゃないか。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "冗談じゃないや、アラスカなんか行くとこはありゃしない。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に行ったのは二番目の娘であったが、此娘は姉様より更に臆病なので、森林の側まで行くか行かぬに早や身慄いがし矢張り姉様と同じ様な狡猾い事を考え、一目散に家に帰って来た。",
              "citation": {
                "source": "黄金の腕環",
                "author": "流星奇談",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分にはこの二つの途しか行く処が無いのである。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の魂はどこへか行つてしまつたのではあるまいか。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　とそういって、かさねがさね恩を謝して、分れてどこへか行っちまいましたッて。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……オヤ、アッ、大へん……」　なにを見たか、にわかぎょうてんしてうろたえだした蛾次郎、さようならともいわず、クロにとび乗って、ツーと空へ逃げてしまった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
