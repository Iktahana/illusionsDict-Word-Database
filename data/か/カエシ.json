          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "釣りの針の返しが鋭く、指に刺さってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一度魚が掛かると、この返しのせいでなかなか外れない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "返しがない針は、魚に優しい設計だと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "返しを潰した針で練習している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 4,
        "gloss": "mixture of soy sauce, sugar and mirin",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
