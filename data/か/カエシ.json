    },
    "definitions": [
      {
        "index": 1,
        "gloss": "reversal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "試合の終盤、見事な返し技で逆転勝利を収めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "相手の質問に対し、皮肉な返しが飛んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は言葉の返しが早く、いつも周りを驚かせている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "予想外の返しの言葉に、一瞬言葉を失った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ア、バアバアバアバ、僕は赤ン坊の時したことを繰返した。",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も記者が簡単に云へるものと考へてゐるとは思はないけれど、それを一般世間が可なりオーム返しに信じたりする風景は、なさけなく思はれるのである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいかオイ……あんな奴と共同で仕事をして好いことがないのは分りきつてらあ……いいかオイ、俺が出来るだけは助けてやるからなあオイ」「うんうん」　それから猶暫らく彼は同じやうなことを繰返してゐたが、やがて其処を出ようと云ひだした。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその他の者は、相変らず古典的な美文で、古典的な、熱のない脩辞を繰返して居るにすぎなかつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私と北原白秋氏とは彼の最初の知己であつた――あまつさへ、私自身しばしば彼の表現を模倣しようとして、愚かな失敗を繰返したことさへある。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し私共二人が、互にその思想や主張の上で自己を押し立てようとするならば、私共はとくに血を流すやうな争論を繰返して居なければならなかつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "繰返して言ふ、私はこの書物の著者及びその人の生活に関しては、世の何ぴとよりも深徹な智識をもつてゐるものである。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "私あの家、面白いの家と思いました』と幾度も繰返して口惜しがった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は前から、室生君と共に氏を訪ねる約束になつてゐたので、この突然の訪問に對し、いささか恐縮して丁寧に禮を返した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "話が餘事にそれたが、最後に、別れる時、前言の一切を取り消すやうな反語の調子で、彼は印象強く次の言語を繰返した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先客が歸つたあとで、彼は再度、前の日の鋭い質問を繰返した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに最近、再び兩者の詩を讀み返して見て、やはり藤村の方がよく、眞の本質的なポエヂイをもつたところの、眞の純粹の詩であるといふことを強く感じた。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたたび私は、すごすご出発点に引返して、全身くたくたに疲れ、ぜいぜい荒い息を吐きながら、スタートラインに並んだ。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出鱈目な調子をつけて繰り返し繰り返し歌っていたのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから私は繰返していふ、座標軸を、概念を、偶像を、他人の眼を忘れよ！",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術、技術等の世界では、道具とか形式とかの相違が非常に大きい役を演ずるのだといふことは茲でも繰返し想起される必要がある。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、短歌、俳句とはどう違ふかと云ふに、その最も大事だと思はれる点は、短歌・俳句よりも、度合的にではあるが、繰返し、あの折句だの畳句だのと呼ばれるものの容れられる余地が、殆んど質的と云つても好い程に詩の方には存してゐる。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "繰返し、旋回、謂はば回帰的傾向を、詩はもともと大いに要求してゐる。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「困つたものだ……」　再び今の様に頭を撫でるから繰返して、不図頭を上げた時さう思つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "叱り飛ばされた妻君は引き返したその足を直ぐに長男の書斎に運んだ。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "目的もない空間の或一点を、蜘蛛の巣のやうな鈍い眼光で見入りながら、自分が今何を話したかも忘れて、「さう、なくちや――なくちやならぬ」と繰返した。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四度繰返した頃にフイと意識すると見えて、襲はれるやうな顔付になる。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物の背後の、ブランコのある所を見たいと思つて建物の横を廻りかけたが、何しろ休暇中だし、朝の五時半であつたし、小使の女房か女学部の舎監であつたか知らないが、炊事場の小窓から一寸顔をのぞけて、ケゲンさうにこちらを見たから、諦めてコソコソと引返した。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄が湯から上つて来ると、耕二がボールをグラムに投げ込んではまたボールを手に取つて投げ込む――それを殆んど無意識に繰り返してゐるらしい音が、三畳の間でしてゐた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　父は必ずその時はさう返した。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからも――部屋の方へ上つて来る夫の後を追つかけながらやつぱり今のやうなことを自分自身聞いて貰はなくとも好いつてな風に繰返してゐた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "「で僕があの歌を歌つたからつて、さう大した如何いふ影響があつたんですか……」　彼は訊き返した。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの、君が幼な時汽車で通りかゝつた小山の裾の、春雨に打たれてゐたどす黒い草の葉などを、また窓の下で打返してゐた海の波などを……　　　　　　　※　実生活は論理的にやるべきだ！",
              "citation": {
                "source": "Me Voila",
                "author": "―― a Cobayashi",
                "note": "青空文庫"
              }
            },
            {
              "text": "年年歳歳、我れは昨日の悔恨を繰返して、しかも自ら悔恨せず。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たったいま教ったばかりのフランスの叙情詩とは打って変ったかかる無学な文句に、勝手なふしをつけて繰りかえし繰りかえし口ずさみながら、れいの甘酒屋を訪れたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
