          "standard": [
            {
              "text": "漢字制限論は、日本語の表記の簡素化を目指す一方で、伝統文化の継承との間で常に揺れ動いてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国語審議会では、新しい常用漢字表の改定にあたり、漢字制限論について活発な議論がなされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "特定の専門分野では、漢字制限論の影響を受けずに専門用語に多用な漢字を使用する傾向にある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "妄想また妄想、終に漢字制限論に移る。",
              "citation": {
                "source": "明治卅三年十月十五日記事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
