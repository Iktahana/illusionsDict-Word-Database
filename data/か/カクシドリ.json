        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は駅のエスカレーターで、小型カメラを使い隠し撮りを行っていたところを現行犯逮捕された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "週刊誌が掲載した俳優の隠し撮り写真は、プライバシーの侵害であるとして大きな議論を呼んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "探偵はターゲットの不貞の証拠を押さえるため、慎重に隠し撮りを続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
