    "definitions": [
      {
        "index": 1,
        "gloss": "tightly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このコードはかっちり書かれているから、バグが少ないだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "スーツケースに衣類をかっちり詰め込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "二つの部品がかっちりとはまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は仕事にとてもかっちりしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "細長いかっちりした薄紫の鈴――桐の花です。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙ったい暗黒の中に丁子だけがかっちりと燃え残っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "喰べたがらして置き乍ら、いざ取って喰べようとなると歯にかっちりだ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸気の陽気に暑がって阿弥陀冠りに抜き上げた帽子の高庇の下から、青年の丸い広い額が現われ出すと、むす子に似た高い顎骨も、やや削げた頬肉も、つんもりした細く丸い顎も、忽ち額の下へかっちり纏ってしまって、セントヘレナのナポレオンを蕾にしたような駿敏な顔になった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方には二階の明るさを想わせる、やや急傾斜の階梯がかっちりと重々しく落着いた階段を見せている。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、かっちり、つらつらと石を合せる。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "数々の羞を知らぬ放埒な女を見て来続けている山口には、お杉の滑らかに光った淡黒い皮膚や、瞼毛の影にうるみを湛えた黒い眼や、かっちり緊った足や腕などは、忘れられた岩陰で、虫気もなくひとり成長していた若芽のように感じられた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだかっちりと若々しくて、黒い耀いた眼ざしをしているそのひとは、指にたこのようなものがあって、ちゃんとした装などのときは袂のかげにそっちの手を置くようにしているのであった。",
              "citation": {
                "source": "鼠と鳩麦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さよは、せめてかっちり、要点だけは受けとめて欲しかった。",
              "citation": {
                "source": "心の河",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翼の合わせめがかっちりとした根つけ細工のようだ。",
              "citation": {
                "source": "一九二七年八月より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かな、闊やかな、充実した自然がかっちり日本的な木枠に嵌められて由子の前にある。",
              "citation": {
                "source": "毛の指環",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かっちりと電燈が台所じゅうを照らしている。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今南国の小倉辺では深緑の葉かげにまっ青な橙がかっちり実のり垂れ、街の人々はふぐやちぬが手に入る度びに、庭のだいだいをちぎって来ては湯豆腐々々としきりにこのき酢の味をよろこぶ時候となってきた。",
              "citation": {
                "source": "朱欒の花のさく頃",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "此人は奥羽にすみ、元禄の秋色や千代に比して世間的名声はじみであるが、其句集を見ると、中々かっちりした、佳句が沢山ある。",
              "citation": {
                "source": "桜花を詠める句",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、いつのまにか掃除人が戻ってきたとみえて、大きな鉄の蓋がかっちり閉め切られています。",
              "citation": {
                "source": "不思議な帽子",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その色が、マテリアルの重みを加えて、古び、かっちりと建っているから何か日本人の胸に迫る美、懐しさがあるのが面白い。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "統一も押しどころもよくつかめて居ず、第一演出法がイディオロギッシュに云ってちっともかっちりして居ず。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "光線の工合で樫や青木やの葉の茂みが藍のこい緑に重なって見える間に、乙女椿の桃色の花が、平常よりはこれもいくらか、涼やかなかっちりと少しやきものめいたつめたさで大変美しい。",
              "citation": {
                "source": "日記",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くのびた樹の姿は、いかにも粗製の感じで、かっちりとした印象を与えない。",
              "citation": {
                "source": "京の四季",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲冑の材料である鉄板の堅い感じ、その鉄板をつぎ合わせている鋲の、いかにもかっちりとして並んでいる感じ、そういう感じまでがかなりはっきりと出ているのである。",
              "citation": {
                "source": "人物埴輪の眼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "理由の詮議はともかくとして、これを成化万暦時代の赤絵にその表現を比べてみるならば、当時の所謂中国の誇りとしていた中国趣味の、かっちりした感じとは全く相違していることに驚異せざるを得ない。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "――記憶のあちこちをさぐっていた伸子は、一つのことにかっちりとせきとめられた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山上元のくるみのようなかっちりさ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今死のうとする眼と眼が、かっちりと火花を散らして結び合った。",
              "citation": {
                "source": "美しき月夜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大気は、かっちり燦いて市街をとりかこんだ。",
              "citation": {
                "source": "シナーニ書店のベンチ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふしぎなことは、網盥のなかから町人内儀のつかう塗櫛が一枚、網盥をうごかしたのでかっちりと音を立てた。",
              "citation": {
                "source": "蛾",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆるかっちりやでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "思っていたあなたのお顔と一寸見ちがえるようにかっちりと厚みが出ていらして本当にうれしゅうございました、よかったわね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬれ縁ぎわに机を出して、かっちりとした若い男が物をかいている筆をやすめ、その手で頬杖をつき一寸笑をふくんで外に立っている女に何か云っています。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
