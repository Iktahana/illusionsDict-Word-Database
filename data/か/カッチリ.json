        "examples": {
          "standard": [
            {
              "text": "新しいスーツは体にかっちりフィットして、とても格好良く見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女のシャツはサイズがかっちりしすぎているように見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この制服、かっちりしすぎると動きにくいんだよね。",
              "citation": {
