    "definitions": [
      {
        "index": 1,
        "gloss": "Chinese classical writing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
