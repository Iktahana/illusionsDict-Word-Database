        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "水平線の彼方には、まだ見ぬ大陸が広がっているだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遠い彼方の故郷を思い、彼は静かに涙を流した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の視線は、人々の想像を絶する彼方を見据えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの丘の彼方には、きっと美しい花畑が広がっているはずだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "机の上には当時まだ珍品であつたペン軸型の万年筆や硯箱の彼方には、硝子の中に昆虫の這入つた文鎮が置いてある。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こつちはイライラするけれど、彼方は親切に何やかと訊ねなさるから、牧代（姉娘）はどうしたか、生れた子供は丈夫かと訊ねなさつて……」とニコニコしながら呼吸をつきながら、仰向き勝なその顔の、アザヤかな色の唇がさういふのである。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今な奥さん、坊ちやが隣り下駄屋から――あれ何言ふか、野球手袋な、あれお主婦さに出して貰ふ彼方駆けたで。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「来週の何曜日に来るのです」「アハヽヽヽヽヽヽ」「あゝあたし彼方から廻る電車に乗りたかつたのに……」　彼が行かうとした停留場の間際まで来てＳ子はジラ半分にさう言つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "無限に遠き空の彼方續ける鐵路の柵の背後に一つの寂しき影は漂ふ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛ぶがごとく駈け寄った要太の一と捻りに、この小さな生命はもう超四次元の世界の彼方に消えてしまったのであった。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "嵐のやうな心の歴史は終焉つてしまつたもののやうにそこから繰れる一つの緒もないもののやうに燃ゆる日の彼方に睡る。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その地平線の彼方には活動していた日の目立った出来事の峰々が透明な空気を通して手に取るように見えた。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、未だ見ぬ遠い彼方の別世界へこれから分けのぼる途中の嶮しさを想はせるのであつた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯元迄行つた頃にはもう日が峯の彼方にかくれて、夕空の殘光に照らし出されて雜木林の色彩が實にこまやかに美しい諧調を見せて居た。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように、颱風は大陸と日本との間隔を引きはなし、この帝国をわだつみの彼方の安全地帯に保存するような役目をつとめていたように見える。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、まだ見ぬ遠い彼方の別世界へこれから分けのぼる途中の嶮しさを想わせるのであった。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それへも骨肉を分けて血の縁を結んだなら自分の性格の複雑さも増す思いで、分身を雲の彼方にも遺す思いで、自分はどのようにかこの世に足り足らいつつ眼が瞑れることだろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面は昼間温かい太陽に向って九千三百万マイルの彼方から来る光熱を浴びているが、夜になると冷たい死灰のような宇宙の果に向き変ってしまう。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝庭　「清水の御貸元、裏口がこっちにあります」　「そうか、有難てえ」　石松、次郎長を庭の彼方の裏口へ案内する。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（歩き乍らのアクション）　彼方の――大地に落ちる紙入れ。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "フト彼方を見れば、てっきり鉄五郎がのこのこやって来る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝坊遙か彼方を指して「ずッと向う」と答える。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次素早く紙入れを彼方へ投げる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "違ったので舌打ちと一緒に彼方へ捨てる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、中の一人が彼方見て「まァ親分が」　と云えば他の二人も出て来て三人揃って「親分お久し振り」　半次を伴った五郎蔵の親分然たるところ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店の女の一人が、フト彼方見て、誰かを見とめたらしい。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店の柱に凭れて居たお光が彼方を見てオヤッと言った顔（大吉を見とめたからだ）。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "はるか彼方の木蔭で様子を見て「アッアッ」　と云った顔の進藤と若侍。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼方で、　団九郎と文六、すれ違った。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "中隊はラープの彼方に駐屯してゐた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがぐつと遠ざかり、遙か彼方に見えるのみならず、全く手に屆かないやうにさへ見えるのだ。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "渾沌未分…………　渾沌未分…………　小初がひたすら進み入ろうとするその世界は、果てしも知らぬ白濁の波の彼方の渾沌未分の世界である。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇の調子が高まって妾の情人の哀切な心を表した舞姿に異国人が海の彼方の歌劇的な情味を感じた時、若い武士になった佐野が舞台に現れました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳独秀は虹のように地面に這入った彼の腕から拳銃をとると、虚空に一発打ち放して花火のように彼方に舞下りる弾丸を見つめながら、――何故死なねばならないのだ！",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
