    }
  },
  {
    "uuid": "25e098d4-7ccf-5692-a83e-153b77cab578",
    "entry": "華冑",
    "reading": {
      "primary": "かちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "aristocracy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "かつて華冑の屋敷が立ち並んでいたこの通りも、今では庶民の住居が増えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は華冑出身でありながら、常に庶民の生活に寄り添おうと努力した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "革命によって、長きにわたる華冑支配の時代は終わりを告げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "唐土の昔、咸寧の時、韓伯が子某と、王蘊が子某と、劉耽が子某と、いづれ華冑の公子等、一日相携へて行きて、土地の神、蒋山の廟に遊ぶ、廟中数婦人の像あり、白皙にして甚だ端正。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神社はもっとも皇族に関係深ければ一切保存して徐々に詮議すべきに、無茶苦茶に乱滅しおわるは、あたかも皇族華冑の遺跡が分からぬうちに乱滅するは結句厄介払いというように相聞こえ、まことに恐懼憤慨の至りなり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐土の昔、咸寧の吏、韓伯が子｜某と、王蘊が子某と、劉耽が子某と、いずれ華冑の公子等、相携えて行きて、土地の神、蒋山の廟に遊ぶ。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "君ならでは人にして人に非ずと唱はれし一門の公達、宗徒の人々は言ふも更なり、華冑攝※の子弟の、苟も武門の蔭を覆ひに當世の榮華に誇らんずる輩は、今日を晴にと裝飾ひて綺羅星の如く連りたる有樣、燦然として眩き許り、さしも善美を盡せる虹梁鴛瓦の砌も影薄げにぞ見えし。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "君ならでは人にして人に非ずと唱はれし一門の公達、宗徒の人々は言ふも更なり、華冑攝平家の世と覺えたり。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわたくしは維新後における華冑家世の事に精しくないから、もし誤謬があったら正してもらいたい。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れ不似と雖も、身華冑の首班に列し、任重く途遠し。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、華冑の子弟によくある型の、交際上手な、話の面白い、趣味の広い人で、自ら芸術家を以て任じている天成の呑気屋さんであるから、当人は一向そんなことを苦に病んでいない。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞之助はまだそうはっきりと妻の口から聞いてはいなかったが、幸子にして見れば、御牧その人の人柄に魅了されたこともあろうし、何と云っても華冑の子弟を縁者に持つと云うことが内心｜嬉しいに違いないので、もしこの話を貞之助が破談にして帰ったりすれば、落胆の程度は思いやられるのであった。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃｜痳疹が流行りよるけに何かよい禁厭はないかちゅう話から、わしが気休めに書いて遣った、意味も何もない出放題じゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、僕かて石油がなんぜ肺にきくかちゅうことの科学的根拠ぐらいは知ってまっせ。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その都度樫の実などを少々賞与せぬと、労働は神聖なりと知らぬかちゅう顔してたちまちそのトルーフルを食いおわり、甚だしきは怠業してまた働かぬそうだ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう一つの傾向に対して正当に批評を組織してゆくどころか、正面からその問題にふれることさえなぜだかちゅうちょされているように見える状態が続いた。",
              "citation": {
                "source": "近頃の感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナニ負けるもんかちゅう気どしてなア、ホホホ、どこへでも男のお方と行きました。",
              "citation": {
                "source": "絵だけ",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや……う……姐さん、ゆうべ云うたでねえかよ……う……わしさ城内に部屋を見附けれや、う……来てくれるかちゅうんだよ……わっしあ……これから行って捜すだで」「まあ、爺ったら」婦はうすら笑いを浮べて溜息をついた。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供を仰山連れとるさかいに大丈夫やろうけれど、あんまり遅いさかいまた子供を放っといて飲んで歩くのやないかちゅうて心配しながら行った。",
              "citation": {
                "source": "恭三の父",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ちゅうて訴えを起したかちゅうと、和秋は和行の本当の子やない、戸籍では本当の子になっとるが、実は貰子を実子のようにして、戸籍に入れたんや、それにはこれ／＼の証拠があるちゅう訳なんだす。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれまあ、気持のわるい」「これこれ、早く待避せんかちゅうのに。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、そんなら誰モデルにしたかちゅうことは、はっきりしてたのんではあれしません。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
