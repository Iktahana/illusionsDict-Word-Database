  {
    "uuid": "16c08a40-be47-5efe-b723-c0726b5372a3",
    "entry": "火中",
    "reading": {
      "primary": "かちゅう",
      "alternatives": [
        "ほなか"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "in the fire",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "燃え盛る火中から、彼は子供を救い出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "先祖代々の家宝が火中に入ってしまい、取り出すことができなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は危険を顧みず、火中に飛び込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また、「キ、ヒ、ミ」も「月」が「月夜」となり、「火」が「火中」となり、「神」が「神風」となり、「身」が「むくろ」（骸）となり、「木」が「木立」になります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、ひとりの人間に自信をつけて救ってやるためには、どんな傑作でもよろこんで火中にわが身を投ずる。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで全き心を捧げて恋の火中に投ずるに至るのである。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "（老女は銅刀で乳房を裂き、白蓮華の一枚々々に乳房の血を塗り、炉の火中にくべる。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚無を重んじ無為を尚ぶも畢竟この理に外ならず、施為多く思想豊かにして而して高遠なること能はざるは、寧ろ彼の施為なく思想なくして、石火中の大頓悟を楽しむに如かじとすらむ。",
              "citation": {
                "source": "心機妙変を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "橘媛が生前に歌った歌に、さねさし、さがむの小野に、もゆる火の、火中に立ちて、問いしきみはも。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "貫一は例に因りて封のまま火中してけり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "遽に人の騒立つるに愕きて顔を挙れば、座中｜尽く頸を延べて己が方を眺め、声々に臭しと喚はるに、見れば、吾が羽織の端は火中に落ちて黒煙を起つるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫これを見て怖れ入り、明日道人に何卒妻を除く法を授けたまえと乞うと、道人教えて、妻をして麪麭を焼かしめ竈に入れんとて俯くところを火中に突き落し、石もて竈口を閉じ何ほど哀願しても出でしむるなかれ、出ださば汝は必ず殺されんと言った。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "私陀固くその身に※なきを知るから、進んで身を火中に投ぜしも焼けず。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山名殿は塩冶の追っ手、又わたくしはお前さま方の追っ手、たがいに大事の役目をうけたまわって参りましたに、山名どのは塩冶の奥方を捕り損じて、やみやみと火中させ、わたくしも又おめおめと手を束ねて戻りましては、殿の御不興いかばかりか、恐れながらお察しくださりませ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "読後火中」　とだけしたためて葉子へのあて名も自分の名も書いてはなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれほどの悪人ではあったけれど、かれに秘法を伝えてくれた、島原一揆の総大将――もっとも黒幕ではあったけれど、イマニエル司僧が落城と共に、表に立った総大将の天草四郎｜時貞と共に、焔々たる火中に飛び込んで、殉難したと聞いた時には、さすがに懺悔心を起こしたものである。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも眞黒になつた頃、駒平は木の枝を取つて、火中を突つき、かきまはしなどした。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真は火中にくべたも同然、今や安全である。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "終には自分の身をも合せてその火中に投じた。",
              "citation": {
                "source": "恋",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫁子ネズミの話　ネズミの話は、日本の神代史のあたりにも、かの有名な大国主神を火中からお救い上げた話など、ふんだんにあります。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なしに眼の前で開いてみると、指井の名があつたから吃驚して、よくも讀まずに火中したのださうだ。",
              "citation": {
                "source": "媒介者",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると指井が非常に憤慨して『何も火中なさらなくても宜い、私は別に覗きもせねばお見せなさいとも云ひはせぬ』と恐ろしい權幕で詰め寄つて、凄い顏をしたとのこと、『今一度如那いふことがあらうものなら私は眞正に殺されて了ふ、あんな怖いことはなかつた。",
              "citation": {
                "source": "媒介者",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、そのひとが、まさに火中に身を投じて、必死の活躍をしている時、何を考えていたろう。",
              "citation": {
                "source": "祭日ならざる日々",
                "author": "――日本女性の覚悟――",
                "note": "青空文庫"
              }
            },
            {
              "text": "只々見る幾隊の六波羅武者、蹄の音高く馳せ來りて、人波打てる狹き道をば、容赦もなく蹴散し、指して行衞は北鳥羽の方、いづこと問へど人は知らず、平家一門の邸宅、武士の宿所、殘りなく火中にあれども消し止めんとする人の影見えず。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれは発見されたというばかりで、発見者が火中から取出そうとして長い木片を探しに行った遑に、どこかへ行って見えなくなってしまった。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "手首だけが火中に投げこまれるというのは可笑しいことであって、前後の模様から察すると、亀井戸の魔窟の附近で殺害された四ツ木屍体は、この油倉庫の火事場に投げこまれて全身灰になってしまったのであろう。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅の言葉に、「火中の蓮華」ということがあります。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙大姉　をにおふさま龍馬皆火中なり。",
              "citation": {
                "source": "手紙",
                "author": "慶応元年九月か　坂本乙女あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "拝火教徒が火中に迎えたものは、「すべてを呑噬するもの」の影であった。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実の世界では、生きた人間同士で、お互ひを理解すると云ふ事は、どんなに激しい恋愛の火中にあつても、むづかしいのであらう。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿が火中の栗を探って手を焼いたような顔だった。",
              "citation": {
                "source": "急行十三時間",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃｜痳疹が流行りよるけに何かよい禁厭はないかちゅう話から、わしが気休めに書いて遣った、意味も何もない出放題じゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、僕かて石油がなんぜ肺にきくかちゅうことの科学的根拠ぐらいは知ってまっせ。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "burning (something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
