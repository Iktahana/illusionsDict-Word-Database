[
  {
    "uuid": "bc4c1fbd-94bd-5ab2-8a97-ae241289f84e",
    "entry": "帰り際",
    "reading": {
      "primary": "かえりぎわ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
