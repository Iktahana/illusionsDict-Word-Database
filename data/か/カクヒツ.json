    "definitions": [
      {
        "index": 1,
        "gloss": "stopping writing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "構想から十年、ようやく長編小説を擱筆することができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "病状の悪化を受け、彼は残念ながら週刊誌での連載を擱筆せざるを得なかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "本稿をもちまして、一旦擱筆とさせていただきます。長年のご愛読ありがとうございました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "あの作家は次回作の完成を目前にして擱筆し、そのまま帰らぬ人となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "紙数に余裕があるので、何かのために、左の言葉を手帖より抜書きして擱筆することとする。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この問題に関しては述ぶべき事はこれに尽きないが、与えられた紙幅が既に尽きたから、これで擱筆する外はない。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結語　科学と文学という題のもとに考察さるべき項目はなお多数であろうが、まずこのへんで擱筆して余は他の機会に譲ることとする。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはいずれ機を得て追々発表することとし、今度はひとまずこれで擱筆。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（五月三十一日、早曉擱筆）",
              "citation": {
                "source": "たべものの木",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら著者は十九章を以て擱筆しなかった。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九一七、六、一三、鶏鳴を聞きつつ擱筆）",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ・Ｃのスプレーで睡魔を防ぎながらヤットここまで書いて参りましたが、もう夜が白けかかって脳味噌がトロトロになりましたから擱筆します。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱線してきたからこの辺で擱筆。",
              "citation": {
                "source": "ヂユパンの癖とヴァンスの癖",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者附記――こゝで擱筆しては竜頭蛇尾のそしりを逃れぬが、都合上止むなく中断する次第である。",
              "citation": {
                "source": "早春のひところ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　あのまゝ死にもしないで息づいてゐる私については、こゝで小説らしく擱筆するまでもなく一言の附記を要するだらう。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この外、白銅貨の効用は甚だ多種なるも約束の紙数に達したれば擱筆する。",
              "citation": {
                "source": "白銅貨の効用",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "回を重ぬる六十回、時歳末に際して予期の如く事件を発展せしむる能はず茲に一先づ擱筆するに到れるは作者の多少遺憾とする所なり。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "時歳末に際して豫期の如く事件を發展せしむる能はず、茲に一先づ擱筆するに到れるは作者の多少遺憾とする所なり。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其故、擱筆当時に見てさえも、最初の部分は、旧作の感があった。",
              "citation": {
                "source": "序（『伸子』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何かまだ申上度儀御座候やうながら、あまり長事故、まづ是にて擱筆、奉待後鴻候頓首。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、そうなれかしと祈りつつ擱筆いたします。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居の本文は他の連中へ譲って私はこれで擱筆する。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく雑然と書いていると長くなるので擱筆する。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ玉杯に花うけて、緑酒に月の影やどし、治安の夢にふけりたる、栄華の巷低く見て……」　読者諸君、回数にかぎりあり、この物語はこれにて擱筆します。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは最早八月八日分の日記ではなくなるから、ここで擱筆する。",
              "citation": {
                "source": "今昔ばなし抱合兵団",
                "author": "――金博士シリーズ・４――",
                "note": "青空文庫"
              }
            },
            {
              "text": "與へられた枚數が盡きたから、こゝで擱筆する。",
              "citation": {
                "source": "新詩發生時代の思ひ出",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ御話し致したきこともあれど、目下研究に忙殺され居り候間、これにて擱筆いたし候。",
              "citation": {
                "source": "ゼンマイの戯れ（映画脚本）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜深く相成候故｜擱筆仕候。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人格と技能を兼ね具えた上に、特に美の含有量の多い良寛様の書は、私の知る限り徳川期の第一人者であることを大声疾呼して擱筆したい。",
              "citation": {
                "source": "魅力と親しみと美に優れた良寛の書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "85　　　注意事項貴下よりいづれ御通信あるべきことを期待しつゝ、貴下の忠實なる僚友 S. W. として擱筆す。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて、この案内者を、彼の家にまで送り届けて擱筆しなければならない。",
              "citation": {
                "source": "案内人風景",
                "author": "百瀬慎太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで擱筆することにしよう。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正三年二月十三日夜十一時半擱筆）",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかでもむかふの足袋屋の息子なぞは伯母さんがぼんやりしてると後ろからだしぬけに人の横ずつ面をはつつけては逃げて行き行きしたもので私はひどくおぢけてとかくひつこみがちになつてしまつた。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
