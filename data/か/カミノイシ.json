[
  {
    "uuid": "95f08bc3-0132-572f-94b6-a130745be346",
    "entry": "神の意志",
    "reading": {
      "primary": "かみのいし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
