        "examples": {
          "standard": [
            {
              "text": "週末のバーベキュー中に突然雨が降ってきたけれど、カーポートの下だったので中断せずに楽しめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "来客用の駐車場として、庭の一部に簡易的なカーポートを設置する予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬場の霜から車を守るため、新築の家に大きめのカーポートを建ててもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の家は、自転車やバイクも置けるように、奥行きのあるカーポートが備え付けられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "カーポートには、一九五二年モデルのキャデラックが、いまでも置いてある。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
