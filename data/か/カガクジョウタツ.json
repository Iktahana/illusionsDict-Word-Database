        "examples": {
          "standard": [
            {
              "text": "難しい専門書に手を出す前に、まずは身近な現象の観察から始めることが下学上達の近道ですよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は日々の単調な計算練習を疎かにせず、下学上達の精神で着実に数学の深淵へと近づいていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あせらなくていい、まずは基礎を固めよう」という恩師の言葉は、まさに下学上達の教えそのものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "派手な技術ばかり追い求めず、下学上達を旨として地道な努力を積み重ねた者だけが、真の達人に至る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
