    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be bulky",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅行の荷物が嵩張るので、圧縮袋を使おう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このプレゼントは大きくて嵩張るから、手渡しにした方がいいかも。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬用のコートは嵩張るので、クローゼットがすぐにいっぱいになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女が持っているぬいぐるみがかなり嵩張って、電車内で周りの目が気になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "見ると、何か嵩張る箱のようなものを背負って、額に汗を掻いて大分｜疲労れた体である。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "好き狆のモデルを得たはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "受取るには受取つたが、三百円といへば一円紙幣で三百枚、五十銭銀貨で六百枚の事だとばかし思つてゐた中村氏は、「随分｜嵩張るだらうからな。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう物が、少し嵩張ると、父は「宗一、手伝うて」　と、云って、私に半分、背負わせて、持って行ったり、持って戻ったりした。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど嵩張る割に軽いもんだね。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんそういう廃物を集めに来る男があるが、あまり嵩張ると、大分チップを奮発しないことには、持って行ってくれないという。",
              "citation": {
                "source": "紙の洪水",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲板を何か嵩張るものでも引摺る様子だ。",
              "citation": {
                "source": "グーセフ",
                "author": "ГУСЕВ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一荷いくらの水代を拂ふのは、洗濯好きの主婦のゐる私の家は、米代よりも水代が嵩張る譯なので、天水の利用はいゝ思ひ付きであつたのだが、その代り、大雨が降り出すと大變だ。",
              "citation": {
                "source": "水不足",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし穀物の場合には、三、四箇月遅延しても最も複雑な窮乏が生ずるのであり、また穀物は嵩張るので、国王は一般にほとんど完全にその忿怒に出ずる目的を達することが出来るであろう。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "「荒壁へ叩込むやうに小判をメリ込ませて、上塗をすると、一坪に千三十二枚で、あの小さい離屋に七千兩の小判を隱すのは何んでもないことになるね」「へエ――驚いたね」「小判といふと、千兩箱の事ばかり考へて嵩張るものと思つたからいけなかつたんだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "桐の極印",
                "note": "青空文庫"
              }
            },
            {
              "text": "時平が重くて美しい肩の荷物を持て扱いながら、喘ぎ／＼車の際まで辿り着くと、雑色や舎人たちが手に／＼かざす松明の火のゆらめく中で定国や菅根やその他の人々が力を添え、両側から掬い上げるようにして辛うじてその嵩張るものを車へ入れた。",
              "citation": {
                "source": "少将滋幹の母",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手土産の果物籠が嵩張るから円タクで行った。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際軽いけれどこんな嵩張るものとは思いがけなかった。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "模様や字様のものの細々と彫っている大きな玉板であるとか、あまり風懐に富んでもいない石仏とか、いずれは考古学上にはそれぞれ由緒あるものであろうが、おかしな言い方であるが、妙に重いもの、かさばるものばかりであるといった感じだった。",
              "citation": {
                "source": "中支遊記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "興奮がしなやかさを奪った指でかさばる箱を開け、部品を引っ張り出したドンピアは、ただちに組み立てにかかって、三〇時間後には電源を入れる段階にまでこぎ着けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大盥へザアザア湯をくみ出して、その中へかさばる洗物をつけ、ギッギッと押えつけた。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不安でかさばる感じがあるのだ。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙は半紙、糊入、封筒、巻紙、花紙、すこし持たせてもかさばる物、そのほかの小物となれば数限りなく、細かく考へるとどうしても七荷のお荷物になるから、考へない方が無事なのである。",
              "citation": {
                "source": "よめいり荷物",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして書きつけるとひどくかさばるけれど、昔の母親たちはみんな心がけて娘の着物や小物類は三年も五年もの時間をかけて揃へる、そして嫁入りの時には礼服やよそゆきの好い着物、諸道具だけ買へば間に合つたのである。",
              "citation": {
                "source": "よめいり荷物",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、きょう、午後三時二十七分に北停車場から立つという昼ごろになって、そのかさばる人形をどうやって手荷物の一つとしてもってゆくかが問題になった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国なんかの眼に、かさばる面ばかりしか見えないのねえ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云っても寒いところに行くのだからかさばるわねえ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士たちから買うヒット・キットも新曲の全部がそろうというわけではなく、しぜん写譜が多くなって、楽譜の包みは重くかさばる一方だった。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとかさばるし、重いけれども、ふろしきづつみを二つにして、両手でさげれば持てないことはない。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「かさばるものは、そのまま、のこってますが、持ちはこびのできる目ぼしいものは、すっかりなくなっています。",
              "citation": {
                "source": "天空の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
