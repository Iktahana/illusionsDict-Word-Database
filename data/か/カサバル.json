[
  {
    "uuid": "ecc3e194-7c2e-5a07-8941-b659953e72cc",
    "entry": "嵩張る",
    "reading": {
      "primary": "かさばる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
