        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "現場の安全を確保するため、作業中止の命令が直ちに全作業員へ下達された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "官公庁では、上層部の決定事項が公文書によって厳格に下達されるのが一般的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "指示の下達が遅れたせいで、プロジェクト全体に大きな支障が出てしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "軍隊のような組織において、命令の下達は絶対的な重みを持って受け止められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "今のフォワイヨの建物の前身がその時のヨセフの監視事務所になり配下達が宿泊して居た。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝になって聞いてみると、その出来事は私達が船から去った後、プレンダーガストと、その手下達が、残った五人の捕縛者を打殺そうとして起きたことらしかった。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方山塞の手下達はなにほど待つてゐても、大将が山に帰つて来ないので大騒ぎとなつた、それまで手下達は手分けをして一探しにでかけた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　武一や竹下達のことを滝本が訊ねると、皆なは森の家で歓迎宴の支度をして待つてゐる――。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と竹下達を指して、小声で囁いだ。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一体、機関庫助役の片山と言う人は、もう部下達も相当期間｜交際ってたんですが、どうもまだ、時々人を不審がらせる様な変な態度に出るのが、彼等には甚だ遺憾に思われてたんです。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はパイプを握った方の手をあげて、部下達の方へふり向いた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――貴下達は何の目的あって、地球へ来られたのか。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "われら地球人類は、極力貴下達の希望に応ずる用意がある。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――貴下達はそこで何をしているのか。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴代の支那政府は、水旱毎に救恤を怠らぬが、中間に介在する官吏の私利によつて、上惠が多く下達せぬ。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　声に応じて六人の部下達は、忽然姿を消してしまった。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六人の部下達は、追っかけ追っかけ、馳せ違い行き違い切り仆す。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……覆面をした水夫の群こそ、その臣下達でござりました」「浮沈自由の奇怪の船、その後何んと致したな？",
              "citation": {
                "source": "赤格子九郎右衛門",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肝心な二品を横取られてしまって」　女勘助の手下達が、へまをやったことを女勘助が、館林様へ詫びているのであった。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず使者を遣わして彼らと一応商議しようと思う」「賛成」　と部下達は一斉に叫んだ。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで二十人の部下達は、後備少佐ゴルドンという勇敢な軍人に引率され湾を指して出発した。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "部下達はバタバタと地へ伏した。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど玄王の部下達も、玄王が人質になっているので、思いきって攻め寄せることもできませんでした。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、部下達の幾人かが、苦笑いをして射なかった。",
              "citation": {
                "source": "沙漠の美姫",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と幾人かの部下達は、遠慮をして射なかった。",
              "citation": {
                "source": "沙漠の美姫",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまた部下達は遠慮をして、愛妾を射ようとはしなかった。",
              "citation": {
                "source": "沙漠の美姫",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、部下達は一人残らず、頭曼単于の冠を射て、その冠を落としてしまった。",
              "citation": {
                "source": "沙漠の美姫",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生犀星の名をかたつて、僕を欺きに來た詐欺師ぢやないか？",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、何分間かたつと、せいのひくい、毛並のきたない、支那馬にまたがった白露兵がぐったりして、長靴を、地上に引きずりそうに、だらりと垂れて、薄暗い街燈の光の中に姿を現わした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度蜘蛛が林の入口の楢の木に、二銭銅貨の位の網をかけた頃、銀色のなめくぢの立派なうちへかたつむりがやって参りました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたつむりは「なめくぢさん。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ひながらかたつむりはふきのつゆをどくどくのみました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ひながらかたつむりはも少しのみました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とかたつむりが云ひました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
