[
  {
    "uuid": "7a48bcbe-df32-5ec1-b550-13dbb208f7cd",
    "entry": "呵呵",
    "reading": {
      "primary": "かか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(laughing) loudly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その滑稽な失敗談を聞いて、皆は呵呵と笑い出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「まさかそんなことになるなんて！」と、彼は呵呵と笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちの無邪気な笑い声は、まるで「呵呵」と響くようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "呵呵　附記　敬首和上の傳は淨土宗全書第十卷、略傳集中に在り就て見るべし。",
              "citation": {
                "source": "敬首和尚の典籍概見",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦地に向ふ前の米国将校と来たら、こんなことぢやすみません」　大佐は、そこで、鷹揚に、天井を仰いで呵呵大笑した。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "潤一郎と同衾するやうな気がして」と云つたのが感じがあつて面白かつたので、僕は潤一郎に朔太郎の言葉をありのままで伝へると、潤一郎も呵呵大笑した。",
              "citation": {
                "source": "朔太郎の思ひ出",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の中は暗くつて、顔には蜘蛛の巣が一杯かかつた。",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧野さんの近くにゐる四五人の者が、何かかゝ牧野さんに話してゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "みなつらなめて逃れゆく、黎明の林を出づる旅びとら、その足竝に音はなけれど、水ながれいでて靴のかかとをうるほせり。",
              "citation": {
                "source": "黎明と樹木",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくばかり我に信なきともがらに、なにのかかはりあるべしやは、空しく坐して祈り、遠き遍路に消え殘る雪を光らしむ、いのちはひとりのもの、ただ我が信願をかくるにより、木ぬれにかかり、有明の月もしらみてふるへ悲しめり。",
              "citation": {
                "source": "黎明と樹木",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（女の顔を見入りながらからかふやうな眼付になる）コーカサス型で以て、鼻筋だけは独逸女のやうに何処かかうキリツとしたところのある顔、と言へば好いのかな。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕が開くと、「ああ好いですわねえ」とその一人が云つた、「先代萩の序幕……あの舟はしつかり出来てますわねえ、かかりますでせうねえ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この侘しく灰色なる空の下に私たちの心はまづしく語り　孤獨になやみて重たくよりそふ少女よあの遠い空の雷鳴をあなたは聽くかかしこの空にひるがへる浪浪の高いひびきをあなたは聽くか。",
              "citation": {
                "source": "眺望する",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大風の吹く城の向うで化猫草の穗のゆらゆらとうごいてゐてなにものかかなしい追憶の敵が笑つてゐる。",
              "citation": {
                "source": "敵",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何となく陰気に薄暗くじめじめして、妙に気味の悪い厭な感じがしたので、夫人が直覚的に反対したにもかかわらず、ヘルンは一見して大いに気に入り、『面白いの家』『面白いの家』と、子供のように嬉しがって、是非それを買おうと言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度小説の價値批判が、描寫（表現）の巧拙にかかるやうに、詩についても同じ描寫の效果性（即ち表現技巧）について求めた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "イザといへば總がかりで、私に掴みかかつてくるのだと思つた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がどんな生意氣を言ひ、屁理窟をこね、憎々しく突つかかつて行く場合にも、彼は寛大に情意を理解し、決して腹を立てることがなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして秋の落ちかかる日の光で、人々は石碑の文字を讀むであらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三昼夜かかって、やっと秋田県の東能代までたどりつき、そこから五能線に乗り換えて、少しほっとした。",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、あれには十年たっぷりかかりまして、と殊勝らしく伏眼でいったら、諸兄は、どんな顔をするだろう。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一文にとりかかるため、私は、三夜、熟考した筈である。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の恋の相手というのは逢うのに少しばかり金のかかるたちの女であったから、私は金のないときには、その甘酒屋の縁台に腰をおろし、一杯の甘酒をゆるゆると啜り乍らその菊という女の子を私の恋の相手の代理として眺めて我慢していたものであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たったいま教ったばかりのフランスの叙情詩とは打って変ったかかる無学な文句に、勝手なふしをつけて繰りかえし繰りかえし口ずさみながら、れいの甘酒屋を訪れたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場はときたま、てかてか黒く光るヴァイオリンケエスを左腕にかかえて持って歩いていることがあるけれども、ケエスの中にはつねに一物もはいっていないのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "The Yellow Book の故智にならい、ビアズレイに匹敵する天才画家を見つけ、これにどんどん挿画をかかせる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水禽の大鉄傘を過ぎて、おっとせいの水槽のまえを通り、小山のように巨大なひぐまの、檻のまえにさしかかったころ、佐竹は語りはじめた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりかかれば、一通りはうまくできるのが判っている。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさ、ラジオのニュウスで聞いた」「あいつ、うまく災難にかかりやがった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの凄惨な一声で、この団欒が滅茶々々になるのだ、と思ったら喉まで出かかった「助けて！",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふ號令がかかつて、私たちは捧げ銃をして、みると、校長は、秋の日ざしを眞正面に受けて、滿面これ含羞の有樣で、甚だ落ちつきがなかつた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君の厳父には、私は未だお目にかかった事は無いが、美事な薬鑵頭でいらっしゃるそうで、独り息子の忠太郎君もまた素直に厳父の先例に従い、大学を出た頃から、そろそろ前額部が禿げはじめた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、どうやら無事に言い納めた時に、三十歳を少し越えたくらいの美しい人があらわれ、しとやかに一礼して、「はじめてお目にかかります。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
