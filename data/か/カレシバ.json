        "examples": {
          "standard": [
            {
              "text": "冬になると庭の芝生は枯れ芝になってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "公園の隅に、手入れされていない枯れ芝が広がっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "春には、この枯れ芝も緑に戻るだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "枯れ芝の上を歩くと、カサカサと音がした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゴルフ場のフェアウェイは、部分的に枯れ芝が見られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "枯れ芝の中に花さく蕗の薹を見いでて、何となしに物の哀れを感じ侍る。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いんじゃねえの、ベースなんだから、なんでも」　服部は枯れ芝をつまんで、下のテニスコートにむかって放り投げた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "峠などからふり顧ると、必、うしろの枯れ芝山に、ひなたと陰とをくつきり照しわける、早春の日があたつて居た。",
              "citation": {
                "source": "山のことぶれ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば私がカサカサした枯れ芝生の上に仰臥して光明遍照の蒼空を見上げる。",
              "citation": {
                "source": "「自然」を深めよ",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の日ざしの、まねくおよびぬ朝山に　あひてすぎたる妹と夫の　よすぎを思ひ、暫し歩みぬ日曜の夜枯れ芝の庭に明れる月読を　見つゝとざして、幾ほどもなし寒の空　うすく曇りて、月読は高くわたれり。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
