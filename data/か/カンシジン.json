[
  {
    "uuid": "7ebf1f35-84b7-5f0a-8c4e-5cb8d9cef813",
    "entry": "看視人",
    "reading": {
      "primary": "かんしじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
