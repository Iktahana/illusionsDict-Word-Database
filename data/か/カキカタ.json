    "definitions": [
      {
        "index": 1,
        "gloss": "way of writing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "敬語の使い方に自信がないので、上司へのメールの書き方をネットで調べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この申請書、書き方がよく分からないんだけど、誰か教えてくれない？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "履歴書の自己PRの書き方一つで、採用担当者に与える印象は大きく変わる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は独特な文字の書き方をするので、一目見ただけで彼の手紙だと分かる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "（ローマ字論者以外の人々の中にも、近頃かうした書き方をする人が多くなつた。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この舌切雀にせよ、また前の瘤取り、浦島さん、カチカチ山、いづれも「日本一」の登場は無いので、私の責任も輕く、自由に書く事を得たのであるが、どうも、日本一と言ふ事になると、かりそめにもこの貴い國で第一と言ふ事になると、いくらお伽噺だからと言つても、出鱈目な書き方は許されまい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこのことはしばらく別にして、平仮名の場合について考えてみても、現代において変体仮名を使いますから、同じ音をいつも同じ文字では書かず色々違った書き方をしております。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、今日の普通の書き方によれば「キヤウ」と書いても「キヨウ」と書いても「ケウ」と書いても「ケフ」と書いても「キョー」であります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一つはこの書物の書き方が甚だ粗略であって、かような、誰にも思い掛けない全く新奇な事実を伝えるのに不十分であり、また一方、余り独断的に見えるような所もあって、その本当の性質を理解することが困難だったからでありましょう。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字の使い方や歌の書き方もいろいろになっております。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また書き方が如何にも整然としていて、粗雑な点が少しもない。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は作者のかういふ風な書き方に同感を持つ者だ。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、ばらの葉につくチューレンジ蜂の幼虫を駆除するに最も簡易で有効な方法を知りたいと思って、いろいろな本を物色してみたが、なるほど、多くの本にはこれに関する簡単な記載はあるが、書き方がたいていきわめて概念的で、本を読んだだけで、具体的に正確に直ちに実行に移しうるものはほとんど見つからなかった。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで一見いわゆるはなはだしく末梢的な知識の煩瑣な解説でも、その書き方とまたそれを読む人の読み方によっては、その末梢的問題を包含する科学の大部門の概観が読者の眼界の地平線上におぼろげにでもわき上がることは可能でありまたしばしば実現する事実である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はよくアヤ子を生徒にして、聖書の言葉や、字の書き方を教えてやりました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちが生れてから物心がつき、人から教えられて箸を持つ術、着物を着る術、学校通い、読み方、書き方、算術――みな「智」の方に属します。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一口に海岸といったところで、海岸にもいろいろあるから困るわけですが、だんだんそういう書き方の脚本が殖えて来ましたから舞台装置家も随分難儀なことがあるだろうと思う。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この舌切雀にせよ、また前の瘤取り、浦島さん、カチカチ山、いづれも「日本一」の登場は無いので、私の責任も軽く、自由に書く事を得たのであるが、どうも、日本一と言ふ事になると、かりそめにもこの貴い国で第一と言ふ事になると、いくらお伽噺だからと言つても、出鱈目な書き方は許されまい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くどくどと、あちこち持ってまわった書き方をしたが、実はこの小説、夫婦喧嘩の小説なのである。",
              "citation": {
                "source": "桜桃",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長塚君の書き方は何処迄も沈着である。",
              "citation": {
                "source": "『土』に就て",
                "author": "――長塚節著『土』序――",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに貴方の書き方は絹漉し豆腐のように、又婦人の餅肌のように柔らかなのです、上部ばかり手触りが好いのかと思うと、中味迄ふくふくしているのです。",
              "citation": {
                "source": "木下杢太郎著『唐草表紙』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは文面の終いの方に同じ淡々とした書き方ではあるがこういうことが書いてあった。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのような社会的な、また政治的な意図をもった読物は、あのような書き方をせざるを得ないのであろう。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオのアナウンスみたいな手紙の書き方をお許し下さい。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、ああ、気取った書き方をして了った。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず無難な書き方だ。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから大阪弁の「そうだ」は文字には書けず、私など苦心惨憺した結果「そうだ（す）」と書いて、「そうだす」と同じ意味だが、「す」を省略した言葉だというまわりくどい説明を含んだ書き方でごまかしているのである。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、これとても十分な書き方ではなく、一事が万事、大阪弁ほど文章に書きにくい言葉はないのだ。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、大阪弁だけではない、小説家は妙に会話の書き方を無視するが、会話が立派に書けなければ一人前の小説家ではない。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その作家たちの書いている大阪弁を読むと、同じ書き方をしている作家は一人もいない。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が伊藤君に會つた最後は、六月二十七日ホトトギスの催能に招待されて上京した時でしたが、其の時も私は伊藤君に、君の叫びについては、論旨には聊かも反對の意見を持たないが、其の書き方が如何にも粗雜だ。",
              "citation": {
                "source": "知己の第一人",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のが餘に亂雜な書き方であつたので讀あげてみた。",
              "citation": {
                "source": "竹の里人〔三〕",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "日蔭者自殺を図るなどと同情のある書き方だった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えてみると彼は別に返事を要求するようなふうの書き方をしたわけではなかった。",
              "citation": {
                "source": "球根",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "penmanship (esp. used in old textbooks)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
