    "definitions": [
      {
        "index": 1,
        "gloss": "formal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "式典は型通りに、滞りなく進行した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は代表者として、型通りの挨拶を述べた後、自身の思いを語り始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "型通りの祝辞ではなく、彼自身の言葉で語りかけた方が、気持ちが伝わるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女は茶道の作法を型通りに美しくこなしてみせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "彼女の売出しごろには舞台の背景に巴里の場末の魔窟を使い相手役はジゴロ（パリの遊び女の情人）に扮した俳優を使い彼女自身も赤い肩巻に格子縞の Basque という私窩子型通りの服装をして彼女の唄の内容を芝居がかりで補ったものだが、このごろは小唄専門のルウロップ館あたりへ出る場合にはその必要は無い。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柚木は額を小さく見せるまでたわわに前髪や鬢を張り出した中に整い過ぎたほど型通りの美しい娘に化粧したみち子の小さい顔に、もっと自分を夢中にさせる魅力を見出したくなった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓際の紫檀の卓を挾んで腰を降し、お互に疲れ顏でぼんやり煙草をふかしてゐると、女が型通り瓜子と茶を運んでくる。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると面と装束を着た骸骨が、型通りに謡い舞っているように見えたり、又は何処かの拳闘の選手が、昔の大家の霊に魘されながら、醒めよう醒めようと苦悶しいしい演じているようにも見える。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりに昔の型通りな恋愛譚の発端なので、拵え話だとする人もあるだろうと思うが、それでもよいと思う。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代は型通りの黒紋付に前帯で、扇を持って出ます。",
              "citation": {
                "source": "米国の松王劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、詩人としての私の生活が、過去にそのインテリの通有性を、型通りに経過して来た。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の売出しごろには舞台の背景に巴里の場末の魔窟を使ひ相手役はジゴロ（パリの遊び女の情人）に扮した俳優を使ひ彼女自身も赤い肩巻に格子縞の Basque といふ私窩子型通りの服装をして彼女の唄の内容を芝居がゝりで補つたものだが、このごろは小唄専門のルウロップ館あたりへ出る場合にはその必要は無い。",
              "citation": {
                "source": "ダミア",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜さり呼びつけて、えらい済まなんだけど、話言うのはな、実はおまはんのその孫のことやがな……」　型通りのおくやみを述べたあと、笹原はそう切りだした。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」などゝ、よく或種の中年者が云ひたがる型通りな伊達に自ら酔つて「まあ、内密でね。",
              "citation": {
                "source": "白明",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "親不孝をする程個人性が強い女でないことは勿論私は認めて居るのですが、照子もその通りで、私がこんな出たらめを言ふと、一種のお転婆娘にある型通りな虚栄で、ある華かな性格を認められたかのやうな遊蕩的の野蛮な誇りを感ずるのです。",
              "citation": {
                "source": "愚かな朝の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう型通りにゆくわけのものではあるまいが、效能の強いのは事實であらう。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう型通りにゆくわけのものではあるまいが、効能の強いのは事実であろう。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "天文のこと以外では極端に気短かな大ちやんだから、そして常々吾家のしきたりに歯がみをしてゐるのだから鶴を追ふにしてもまさか祖父のしたやうな真似をしてゐるわけではあるまいと樽野は思つてゐたのだつたが、見ると彼は全く祖父の型通りであつた、それより他にはどんな方法も知らないやうに。",
              "citation": {
                "source": "鶴がゐた家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し自分が、女に生れて、そして年を取つたら、古めかしい型通りに卑屈で強情な、さぞさぞ意地の悪い鬼姑が出来あがることだらう――彼はそんな空想に走つたりした。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤村は、実家を追はれて（勿論、型通りに古風な放埒と古風な親の譴責から――）、これもまた殆ど同じ状態で、この町に追はれてゐる私の寓居に二ヶ月ばかり前から滞留してゐるのであつた。",
              "citation": {
                "source": "環魚洞風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は苦労も不安もないらしく、艶の好い、型通り青年紳士の顔を、悠々居間の灯の下に浮上らせているのだ。",
              "citation": {
                "source": "心の河",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自殺に相違ない、とあって警察も型通り前後の模様を聴取しただけで、手を引く。",
              "citation": {
                "source": "ロウモン街の自殺ホテル",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "一應型通り、町長も助役も役を退いて、かつかうをつけたのだけれども、何時の間にか、勝手な輿論をつくつて、また、それぞれ、もとの役にもどつて知らん顏で、げらげら笑ひながら、役場の神棚を手荒くはづしてゐるのであつた。",
              "citation": {
                "source": "雪の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判長は型通りの質問をした後きっとなって、証人と被告との関係を尋ねた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、江戸時代の作者の、女に対する理会、言ひかへれば、女と言ふ者はかう書かなくては面白くないと言ふ、昔の文学の型通りの女の書き方から生れて来たのだとも言へる。",
              "citation": {
                "source": "玉手御前の恋",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "登場人物は、何れも型通りの白をしやべりつゝ、それが活々と動いてゐるのはどうしたわけか。",
              "citation": {
                "source": "戯曲二十五篇を読まされた話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、ウケル、とか、ウケナイ、ということが身上で、これはどこの芸人でも、そういうものであろうけれども、浅草のウケル型というものがきまっていて、これは浅草でウケル型、これは新宿でウケル型、そういう型があり、その型と狎れ合って、型通りの芝居をすればよかったのだ。",
              "citation": {
                "source": "モンアサクサ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "名代部の最初の主のつぎには、其人の生れた様から、嫁とり、戦ひ、さうして死に到るあり様まで、色々の事を型通りに伝へて行くであらう。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の神主など見ますと、皆昔の型通り書いてゐる。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治屋だの社長などゝいふ型通りの商売人は家庭でヤリクリ算段の女房みたいなもので、闇ブローカーといふものは定まる家もなく定まる商売の筋もないパンパンガールのやうなもので、人生到るところ青山、青空、愉快な人間に見えるのである。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "或能役者がカゲ清をし、おちぶれて娘に会い落涙するところで、型通り手を顔にかざしただけだのに見る者をして泣かせた。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべては古いしきたり通りに、一定の型通りに行はれ、それが乱されたことはなかつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生温い、暑さのぶり返しを思はせる蒸し蒸しした空気、雨、それから青空、微風、快い乾いた空気、――こんな風にためらひ、一寸後もどりをし、又急ぎ足で駆け、季節は人々に型通りの見込をさせまいとするかのやうに見える、がその足どりの中には何か大まかな順調さが、あの自然といふものの単純な変化が歴然と現れて来る。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きぬを　すんぽう　取って、　くるくる　回して、　大ばさみで　かたどおりに　切りととのえていきました。",
              "citation": {
                "source": "グロスターのふくやさん",
                "author": "THE TAILOR OF GLOUCESTER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
