        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は幼い頃からの夢を叶え、有名な歌劇団に入団した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ミラノ・スカラ座歌劇団の来日公演のチケットは、発売後すぐに完売した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "その歌劇団は、古典的な演目だけでなく、現代的な創作オペラにも意欲的に取り組んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "数時間後、僕は岡山で下車すると、巡業中の歌劇団のポスターを横眼で見ながら、車を硝子張りの、「金髪バー」の前でとめて、酒杯の中に沈んで行った。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾も、歌劇団を抜け出すつもりなんです。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、当時、ひと頃はずいぶんと人気を呼んだ暁星歌劇団のテノール歌手をやっていたのですが、戦争終局と共に、ばたばたとやって来た大不景気のために最も有力な金主を失ってしまった結果、おまけに肝心な客足はゲッソリと減るし、到頭一座はご多聞に洩れず、何れあじけない旅烏とならなければなりませんでした。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワルシャワ帝国歌劇団のプリマドンナ、うむ。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "惨めな礦夫の生活をかいたもの、北海道の終身刑囚の脱獄、金龍館で、一時あれほど盛っていた歌劇団の没落と俳優たちや周囲の不良群の運命、等々――そのなかでも、離散した歌劇団の歌手たちに絡んだ、頽廃的な浅草の雰囲気を濃い絵具で塗り立てた作品の、呼吸の荒々しさと脈搏の強さには、庸三もすっかり参ってしまった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして大山鉱業者は街角に靴をみがき、大将軍は貨物自動車を運転し、大僧正が倉庫の番人をつとめているわけで、陸軍中将の御者、大公爵の番頭、帝室歌劇団花形の売子、すべて由緒ある亡命者をもってハルビンは充満している。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶太人、陸軍士官、この辺を打って廻る歌劇団、金ぴかの指輪だらけの手で安煙草をふかしつづけるその一行のプリ・マドンナ。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いてちょうど泊り合せていた露西亜の歌劇団の女優連が、寝間着姿のしどけないなりで、青い瞳に憂鬱な恐怖を浮べ、まるでソドムの美姫のように、赤い電灯の点いた非常口へ殺到した。",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその多くは年少気鋭の学生連であったそうで、いまそうした年頃の、青春の人は多く浅草の歌劇団にと行き、高級の人は音楽会を待ちかねて争ってゆくようである。",
              "citation": {
                "source": "豊竹呂昇",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の奥さんの話、訪問記者の話、それから俊吉と見に行つた或外国の歌劇団の話、――その外愉快なるべき話題が、彼女にはまだいろいろあるらしかつた。",
              "citation": {
                "source": "秋",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では、たまに外国の歌劇団などを迎へて大騒ぎをしてゐますが、巴里には、楽劇を何時でもやつてゐる劇場が沢山あり、そのうちでも、オペラ座と、オペラ・コミツク座とは国家が利益を度外視して経営してゐるのです。",
              "citation": {
                "source": "ふらんすの芝居",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近では、ワルシャワ歌劇団のソプラノ花形のリル・デ・メル嬢と、ルツェルンの美容師で、六十七歳になるお婆さんとが加盟しました。",
              "citation": {
                "source": "踊る地平線",
                "author": "長靴の春",
                "note": "青空文庫"
              }
            },
            {
              "text": "北村季晴氏作　歌劇「ドンブラコ」本居長世氏作　喜歌劇「浮れ達磨」宝塚少女歌劇団作　ダンス「胡蝶の舞」　このように上演脚本も選定せられて、配役も決定し、公演の練習に没頭した。",
              "citation": {
                "source": "宝塚生い立ちの記",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この苦況と闘う宝塚少女歌劇団の努力に、先ず最初に深い理解と同情を示したのは大阪毎日新聞社であった。",
              "citation": {
                "source": "宝塚生い立ちの記",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで関西における舞踊界の新人、楳茂都陸平氏を振付に、また作曲者として三善和気、原田潤の両氏を歌劇団の教師に招いた。",
              "citation": {
                "source": "宝塚生い立ちの記",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその少女歌劇団にお伽のものを遣らせて少年少女を歌劇趣味に導きつつ徐々に社会の新趣味を向上させようとの思いつきは頗る適当な方法だと思う。",
              "citation": {
                "source": "宝塚生い立ちの記",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌劇に就いての研究家等も、昨今では、先ず先ず喜歌劇ぐらいから社会に広めて行くのが今の場合適度だろうと論じて居るような折柄だから、愛らしいこんな少女歌劇団も賛成されるに違いない。",
              "citation": {
                "source": "宝塚生い立ちの記",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄国亡命の歌劇団、この日午後トスカを演奏す。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつぞやイタリヤの歌劇団が旅のついでにＳ市に立ち寄ったことがあるが、その歌姫の一人がみまかってここに葬られ、この記念碑が建立されたのであった。",
              "citation": {
                "source": "イオーヌィチ",
                "author": "JONYCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬方のほかにＢ家の主人、歌劇団の俳優、神戸の犬屋、その他村の人たちが証人として調べられたが、彼等の陳述は小栗の言葉と一致していた。",
              "citation": {
                "source": "日本に於けるクリップン事件",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当歌劇団が株式会社であることなど大衆は知らない。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからサットン・バスコム歌劇団の会計係は内心不安だ。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "サットン・バスコム歌劇団に拾われたのは、ちょうど荷物係の助手が欠員していたからだ。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌劇団がセンディゴ近くで二晩公演したとき、事件が勃発した。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆるホテルは歌劇団の貸し切りとなった。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "残念ながら、歌劇団の男性員も同じようにせざるを得ない。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "居ながら本場物のイタリア歌劇団を見られるなども今日の歴史だ。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
