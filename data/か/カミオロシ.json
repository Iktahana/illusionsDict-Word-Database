    "definitions": [
      {
        "index": 1,
        "gloss": "invoking a deity during a festival held in that deity's honor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "秋祭りの夜、かがり火に照らされた厳かな雰囲気の中で、本殿にて神降ろしの儀が執り行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "村の古老から、昔はこの社で夜通し神降ろしの神楽を舞って豊作を祈ったと聞いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「神降ろしの最中は、私語を慎んで静かに見守るのがこの地の古くからの決まりです」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "┌外界（幽霊、狐狸等）妖怪┤　　┌他人（巫覡、神降ろし等）　　└内界┤　　　　　└自身（夢、夜行等）　今、外界とはわが目前の物質世界をいい、内界とはわが体内の心性世界をいう。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、夢、夜行等は心性の変動より生ずるはもちろん、巫覡、神降ろし等も心性の作用にほかならざれば、これを内界に属するなり。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "┌外界（幽霊、狐狸等）妖怪┤　　┌他人（巫覡、神降ろし等）　　└内界┤　　　　　└自身（夢、夜行等）　今、この外界とはわが目前の物質世界をいい、内界とはわが体内の心性世界をいう。",
              "citation": {
                "source": "妖怪玄談",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、夢、夜行等は心性の変動より生ずるはもちろん、巫覡、神降ろし等も心性作用の上に直接の関係を有するをもって、ここにこれを内界に属するなり。",
              "citation": {
                "source": "妖怪玄談",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "medium's invocation of a deity to take possession of her (to receive his divine message or revelation)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
