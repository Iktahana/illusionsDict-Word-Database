        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夜中に物音がして、何だろうと思ったら、戸棚の奥でねずみがかさこそ動いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "落ち葉の上を歩くと、足元からかさこそと心地よい音が響いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "図書館で本をめくる音が、静かな室内に、かさこそと響く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プレゼントの包み紙を、子供がかさこそと開けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "海峽の霧の夜に朧ろな月が差し入る時、または靜かな秋の夜にポプラのわくら葉がかさこそと散るのを聞く時、彼等は密かに床の上にぬかづいて、心から神に祈るのであらう。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かさこそと雑木の葉が、ばさりと朴の木の広葉が、……朴の木の葉は雪のように白く曝らされていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が身を倚せてゐる若木の楡の梢からは、秋の野葡萄のやうに色づいて卷きちゞれた葉が、そよとの風もないのに、果てしもなく散りつゞいて、寒さのために重くなつた空氣の中を靜かに舞ひ漂つて、やがて霜の上にかさこそと微かな音をたてゝ落着くのだつた。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時ならず、花屋が庭｜続の藪の際に、かさこそ、かさこそと響を伝えて、ややありて一面に広々として草まばらな赤土の山の裾へ、残月の影に照らし出されたのは、小さい白い塊である。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "森として、神寂びた森の中の、小さな鳥居に階子をかけて、がさり、かさこそと春の支度だろう。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かさこそと、落葉と落葉が擦れ合うて、それを二人で集めてゐれば、今はもう秋も限りと思はれる。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かさこそり、櫟の枯葉わがかたへまた声立てぬ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほうほうと立てる雑木の岨路ゆき、別れ径ゆき、当処さへ果てはわかねど、風のまま歩みのままに、行き行けばただ落葉なり、前うしろただ落葉なり、かさこそと、また、はらはらと、空にも地にも声ばかりして。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "前うしろただ落葉なり、かさこそと、また、はらはらと、空にも地にも声ばかりして。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはじつにしずかで、あるいて行くじぶんの足音もきこえるくらいでしたし、足の下で枯れッ葉のかさこそくずれる音もきこえました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "シリベシ川の川瀬の昔に揺られて、いたどりの広葉が風もないのに、かさこそと草の中に落ちた。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かまきり　秋草のなかにどかりと腰をおろして、両足を前へ投げ出したまま日向ぼっこをしていると、かさこそと草の葉を伝って、私の膝の上に這いのぼって来るものがある。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は屋敷の前に近づいて、忍ぶように内を覗くと、軒に張り渡された注連縄が秋風に寂しくゆらいで、見おぼえのある大きい桐の葉が蝕ばんだように枯れて乾いて、折りおりにかさこそと鳴っていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "半時あまりも息を殺していると、うしろの小さい丘を越えて、湿った落葉を踏んで来るような足音がかさこそと微かにひびいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "小女郎狐",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕凝の岸のくづれに、かさこそと、河原菅菜のこれや、はた老いにし夏の夢のひびき。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが坐っていると、頭の上の、すっかり暗くなった茂みの中で、小鳥が一羽しきりにかさこそいわせていた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "みそつちよも寒さうにそこらをかさこそ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴さんは床についてからも、白い細長い手を出して、今朝から見るひまもなかった新聞を、かさこそ音を立てて、彼方かえし此方返しして読んでいるらしかったが、するうちに、それを投りだして、枕につくかと思っていると、ぱちんと云う音がして、折鞄を開けて、何か取出したらしかった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから、かさこそ音をさせていて、給仕？",
              "citation": {
                "source": "一週一夜物語",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山峡にかさこそと降り積った雪は手ごたえなく軽かった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井の隅や額のふちで、かさこそと銀の響の羽ざはり……わたしは俯向いて物を書きながら、心のなかでかう呟く、其処には恋に疲れた天使達、此処には恋に疲れた女｜一人。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯のきえた邸の中は闇につつまれ、門前のあけびの葉がかさこそと音を立てた。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い百合草にかくれた白い百合花のすがたは見えないがあまいにほひをたてるのですぐにありかが見つかつて金の羽蟲が五匹づれかさこそ分ける草のなか。",
              "citation": {
                "source": "歌時計",
                "author": "童謠集",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
