        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "複雑なプログラミング課題に丸一日取り組んだが、結局兜を脱いで助けを求めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "登山で悪天候に見舞われ、山頂アタックを断念し、兜を脱いで引き返すことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は頑固に自分の意見を主張していたが、周囲の説得に兜を脱ぎ、最終的に譲歩した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
