        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "次の車を買うために、カーセンサーで最新の情報をチェックしているんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "カーセンサーには、中古車の価格相場からレビューまで、役立つ情報が満載だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの特集記事、カーセンサーで見たよ！まさに探してた情報だったんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "すぐに点滅にもどったカーソルを、慶一は腹立たしげに見た。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり消してしまうと、カーソルと呼ばれる明滅を繰り返す輝点が、画面の左上のすみの位置にもどる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来なら原点にあたるこの位置から、カーソルは右方向と、下方向に動く。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、原点にもどったカーソルをさらに上の方向へ動かそうとすると、自動的にモードが切り替わってグラフィック記号を呼び出せるようにしようと試みたのである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面上を自由に動くカーソルと呼ばれる記号を操作するために、彼らは膝を上下左右に動かして操作する装置や首で操作するタイプ、机の上を前後左右にすべらせて使うマウスと名付けた小さな石鹸箱のような装置を試みた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "またカーソルキーだけを押せばカーソルは隣に移動するが、シフトキーと組み合わせればより遠くへ、コントロールキーと組み合わせればさらに遠くへ飛ぶというアイディアを提案するなど、ゲイツがインターフェイスの改良と統一に関して貢献したのも事実であると鈴木は証言する。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "削除を示すハサミのアイコンを選べば、それまでは矢印だったカーソルがハサミの形に入れ替わり、作業の内容によってピンセットやナイフに変化するといったインターフェイスの方向付けが、アスキーとジャストシステムの繰り返しの打ち合わせを経てまとめられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
