        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古式ゆかしい神業が厳かに執り行われ、境内には凛とした空気が漂った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "代々伝わる秘蔵の神業を継承するため、若手の神職たちが懸命に修行に励んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "秋祭りのクライマックスとして行われる神業を一目見ようと、多くの村人が集まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
