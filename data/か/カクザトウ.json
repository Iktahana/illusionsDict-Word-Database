        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あ、角砂糖もう一つ入れてもいい？」と彼女はコーヒーカップを差し出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ティータイムのために、アンティークのシュガーボウルに角砂糖を補充した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわっ、角砂糖がゆっくり溶けていくのを見てるだけで癒やされるな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔ながらの純喫茶では、トングで角砂糖を掴む感触がどこか懐かしく感じられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それから元気よく口笛を吹きながらパン屋へ寄ってパンの塊を一つと角砂糖を一袋買ひますと一目散に走りだしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は角砂糖を買ってきたよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日庭に角砂糖をいくつか出しておいたら、やがて一群の蜜蜂がこれにとまってしきりに骨折っていたが、堅くて喰い欠く事が出来ぬと見えて一時飛び去ってしもうた。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うなぎの蒲焼（鑵詰）ライスカレー（同上）あずきようかん（同）栗のきんとん（同）ほーじ茶、ココア、角砂糖（斯うたくさんは食えんわい）小包は厳重にして置いて呉れ。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから元気よく口笛を吹きながらパン屋へ寄ってパンの塊を一つと角砂糖を一｜袋買いますと一目散に走りだしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーヒー糖と称して角砂糖の内にひとつまみの粉末を封入したものが一般に愛用された時代であったが往々それはもう薬臭くかび臭い異様の物質に変質してしまっていた。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから元気よく口笛を吹きながらパン屋へ寄ってパンの塊を一つと角砂糖を一｜袋買いますといちもくさんに走りだしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さん、今日は角砂糖を買ってきたよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから元氣よく口笛を吹きながらパン屋へ寄つてパンの塊を一つと角砂糖を一袋買ひますと一目散に走りだしました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さん、今日は角砂糖を買つてきたよ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それくらいの事は百々心得ているという風に……それから眼の前の冷たくなった紅茶に、角砂糖を二つとも沈めた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その何家だか知らないが、御支配人がズツと先生を導くと、一つゑぐらうといふ數寄屋がかりの座敷へ、折目だかな女中が、何事ぞ、コーヒー入の角砂糖を捧げて出た。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女の見て居る前で、私は角砂糖の一つを壺から出した。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時私はまた一つの角砂糖を壺から出した。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人はそれを物慣れた手附きで三つの大コップへ分けて入れ角砂糖と水を入れた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなびてコーヒーに入れる角砂糖の数を訊いて呉れるこども。",
              "citation": {
                "source": "愛よ愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉は、相変わらずニコニコしながら、一片の角砂糖をコーヒーの中に落として、じっと見つめている。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "指の間に煙草を挟んだ婦人の手は、魚のように敏捷に角砂糖を撮んだ。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに角砂糖鋏がある。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一脚の卓子を囲んで、柳沢と差向いに同じ椅子に掛けていたが、体を捻って、背後へ手を伸すと雑書を納れた本箱の上から、一瓶の角砂糖を取って、これを二人の間に居る一｜人の美少年の前に置いた。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳沢は斜に卓子に凭れて、小刀の柄で紅茶に和した角砂糖を突きながら、「そりゃある、その材料のあることはちょうど何だ、篠塚が小まさの浄瑠璃の中から哲理を発見するようなもんだ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に後者については、諸君は何故に最少のエネルギーを取出すことに苦心するかと思われるだろうが、抑々原子崩壊によって生ずるエネルギーはものすごく強大であって、僅か角砂糖ほどのものを崩壊することによって生ずるエネルギーで、わが国の全艦隊を天空一｜哩の上へまで吹き上げることが出来るのである。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに対して彼女は、二つの角砂糖のあいだへ食卓の花挿しから薔薇の花びらを一枚採って挟みながら、言いはじめたのである。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　ここでフランシス・スワン夫人は玩具にしていた角砂糖と薔薇のサンドウィッチを口へ入れようとした。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの方は一遍、活動写真に映されてから、御自分の美しさに急に気がつきなすったんですよ」　一つの角砂糖を噛んでステパン・ステパノヴィッチは三杯の茶を干した。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
