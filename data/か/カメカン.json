        "examples": {
          "standard": [
            {
              "text": "「へえ、弥生時代にはこんなに大きな甕棺に遺体を納めていたんだね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "吉野ヶ里遺跡の展示エリアには、発掘された当時のままの甕棺が整然と並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわっ、この甕棺、大人の男性が入るにはかなり窮屈そうだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "甕棺の表面に残された指跡から、千年以上前の職人の息遣いが伝わってくるようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし既に白骨が甚だしく腐蝕されずによく保存されたという事から考えると、もしそれが墳墓であったならば、必ず多少の木棺存在の形跡があるとか、甕棺が存在するとかいう事実がなければならぬのではあるまいか。",
              "citation": {
                "source": "人身御供と人柱",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
