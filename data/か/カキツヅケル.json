[
  {
    "uuid": "865f2f1f-25a3-5fa0-83bf-13314f0d4bca",
    "entry": "書き続ける",
    "reading": {
      "primary": "かきつづける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
