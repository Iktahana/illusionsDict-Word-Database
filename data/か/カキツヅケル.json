    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to continue writing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は朝から晩まで、休むことなく小説を書き続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "たとえ誰にも読まれなくても、私は日記を書き続けるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "スランプに陥っても、彼は筆を折ることなく書き続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "集を追うて余白がある毎に書き続けるつもり）（「三八九」第弐集）",
              "citation": {
                "source": "私の生活",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は終日、年に似合はぬ意味も判らぬ難字――その方が感情を載せるのに収容力の余地があるやうな気がして――を書き続けるのであつた。",
              "citation": {
                "source": "私の書に就ての追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の前では、まつたく人間界の饒舌などほしいまゝにしてはすまないやうな冷厳な感じにうたれますのね、まして恋する身には……まだ以上、このラブレターの続きはあるのですが、もはや書き続ける根気もありません。",
              "citation": {
                "source": "或る男の恋文書式",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙の代筆が済むと、相変らず帯封を書き続けるのだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、そんなわけだったかと、豹一はもう書き続けるのがいやになった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "パワーブックのキーを叩いてマシンを起こすと、ディスプレイにかろうじて書き続けることのできた原稿が蘇った。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『パソコン創世記』を書き続ける作業は私にとって、あるところで当然けりを付けるべき〈仕事〉では、なくなりかけていたのかもしれません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このコラムだけを、かろうじて書き続ける時期が長く続き、書籍化が決まってからも、各項への言い訳がなかなか用意できなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖かさと厳しさ、知性とを兼ね備えた彼女の真っ直ぐな視線に包まれていなければ、この間唯一継続しえたこのちっぽけなコラムさえ、私には書き続けることができなかったと思う。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、また、昨夜は、それを書き続ける前に――と思つて、彼の単行本「夜ふけと梅の花」及び「なつかしき現実」の二部を取りあげて読みはじめたところが、凡て雑誌に発表された当時読んだものばかりでありながら、更に感興を強ひられること切りで、とう／＼通読してしまひ、感想の続きを書く余裕を失うてしまつた。",
              "citation": {
                "source": "彼に就いての挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに考えると子年だから鼠の話を書くなど誠に気の利かぬ咄しだが、毎歳やって来たこと故書き続ける。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "――余技は別として小説と詩とはワガマヽな心の起らぬ限り心から流れ出す儘なれば出来得る限り「真実」に源いて書き続ける決心です。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一二枚書き出した原稿を破いて仕舞はうか、と思つて更めて手に取つて見ると、破くにも当らない、と思はれるので、またもとの通りに置いたが、頭はいつの間にか全々空虚になつてゐて到底それを書き続ける程の勇気はなかつた。",
              "citation": {
                "source": "若い作家と蠅",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れに添つた温泉宿の一室で、現在の頭の中には夢にもないやうなことを切りに書き続けるであらう自分の姿が花々しく想ひ浮ぶ。",
              "citation": {
                "source": "冬の風鈴",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "）「うむ、書き続ける気だ。",
              "citation": {
                "source": "蝉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても此の女性は、その文面に現れた淑やかさと、これはまた全然別に、いつまでも見知らぬ男に手紙を書き続ける大胆不敵な能力とを持ち合せてゐる所から押して見ると、その桃色の封筒は、あながちただの桃色ではなく、何か意想外の火の車でも吐き出して来さうに思はれてならなかつた。",
              "citation": {
                "source": "火の点いた煙草",
                "author": "一名――煙草蒐集家の奇禍",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何となれば君たちはきっと、中毒から逃れようと、もがくであろうから――けれども、手記を完成して置かないことは気がかりになるから、僕は書き続けるのだ。",
              "citation": {
                "source": "ある自殺者の手記",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、元来が寂光院事件の説明がこの篇の骨子だから、ようやくの事ここまで筆が運んで来て、もういいと安心したら、急にがっかりして書き続ける元気がなくなった。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "平岡へ手紙を書いて、会見の都合を聞き合せ様として、筆を持つて見たが、急に責任の重いのが苦になつて、拝啓以後を書き続ける勇気が出なかつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が専念に真剣になった時、心に燃え上る焔の明るさに総てを委せて、此を書き続けるのでございます。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな雑文を長々と書き続けるのは面白くない気がしてきたから、ペンをおいて煙草でも吹かそう。",
              "citation": {
                "source": "交遊断片",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そのときそれを焼く前に一度読み返しておこうと思って、それすらためらわれているうちに焼く機会さえ失ってしまった位で、よもや自分がそれを再び取り上げて書き続けるような事になろうとは夢にも思わなかったのである。",
              "citation": {
                "source": "楡の家",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平岡へ手紙を書いて、会見の都合を聞き合せ様として、筆を持ってみたが、急に責任の重いのが苦になって、拝啓以後を書き続ける勇気が出なかった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "家にかえると、帆村は黙々として、また白紙のうえに、鉛筆で文字を模様のように書き続けるのだった。",
              "citation": {
                "source": "獏鸚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……こんなことを考え出したら、もうこの手紙を書き続ける気がしなくなりました。",
              "citation": {
                "source": "美しい村",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一日八日――暫く日記を止すつもりだったが、また書き続けることにする。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、特に面白く思うことはその内容がまことにダイナミックであって、一擢きかいてスーと出た、そのところで又次の一擢きが要求されている種類のものであり、ただその一擢き一擢きを必然にしたがい、かきつづける気力が人間にあるかないかというところがある。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月二日　〔巣鴨拘置所の顕治宛　駒込林町より（封書）〕　次の日かきつづけるつもりであすこ迄かいたら、三日休業になってしまいました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリス人はベッドにあおむけに寝たまま、手帳を開いて、胸の上に立てるように持って、熱病にふるえる手で、まずい絵をいくつもかきつづけるのです。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
