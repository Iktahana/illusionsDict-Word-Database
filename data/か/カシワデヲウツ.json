        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ああ、やっと願い事が言えた」と、彼女は二拝二拍手一拝の作法で柏手を打った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試験の合格を祈願して、友人と一緒に神社で柏手を打った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "柏手を打つ前に、一度深く頭を下げるのが正しい作法だと教わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい事業の成功を祈って、会社の皆で近くの社に参拝し柏手を打った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それが拝殿の前でやむと、母はまず鈴を鳴らしておいて、すぐにしゃがんで柏手を打つ。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣性も身體も引緊つた四十男、そのくせお店の新造といはれてゐる萬兵衞の妾のお常の豐滿な魅力には、妙に誘惑を感じてゐるらしく、席を立つて女の背後に行くと、頬と頬とが觸れるやうに欄干に凭れて、パンパンと柏手を打つのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "棟梁の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "気性も身体も引緊った四十男、そのくせお店の新造といわれている万兵衛の妾のお常の豊満な魅力には、妙に誘惑を感じているらしく、席を立って女の背後に行くと、頬と頬とが触れるように欄干に凭れて、パンパンと柏手を打つのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "棟梁の娘",
                "note": "青空文庫"
              }
            }
          ]
        }
