        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "マーカーのキャップを開けっぱなしにしていたせいで、インクがカスカスになって書けないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "冷蔵庫に放置していたケーキを食べたら、すっかり水分が飛んでカスカスだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "朝から何件もクレーム対応をして、もう気力がカスカスで何も考えられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "このファンデーション、もう底が見えてカスカスだから新しいのを買わなきゃ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ぐずりと鼻をならして、手紙から顔を上げると、カスカスした低い声で、「浅川のためだ。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、カスカスな声を絞り上げた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのくらいの固さがよいかはむずかしい問題で、固いのになるとカスカスしている。",
              "citation": {
                "source": "高野豆腐",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "カスカスがよいというひとも、やわらかいのがよいというひともある。",
              "citation": {
                "source": "高野豆腐",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "五目寿司には少しカスカスした高野豆腐でないと使い甲斐がないから、割合に固めのものを用いるように。",
              "citation": {
                "source": "高野豆腐",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、重曹をたくさん入れると、まったく元の豆腐になってしまうから、中間だけが少しカスカスした程度の固さが適当だろう。",
              "citation": {
                "source": "高野豆腐",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十二になる眼の見えない祖母が、たったひとりでひっそりと暮しているの」「たいへんね」「土地馴れない山の手なんかへ越して、ご近所の世話になって、カスカスに生きるのかと思うと、しみじみとしちゃう。",
              "citation": {
                "source": "虹の橋",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "パパの書斎にあるやつは古びたりといえども〈トゥ・フランス〉型の六球だからカスカスぐらいには入るだろう。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノアの方舟　スラバヤを出帆してから四日、海洋性の滝のような豪雨がやみまもなく降りつづくのに、赤道特有の絡みつくようなひどい暑気で船艙はさながらの蒸風呂になり、蚕棚へ長く寝てカスカス呼吸をしているという辛い船旅になった。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "生じつかカスカス生活の立つやうな家に生れたからいけないんだわ。",
              "citation": {
                "source": "新婚旅行",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎　……（咽喉がカスカスになつた様な声で）在る。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりでこのひとの書いたものをよみ、ちびた細筆で不足の絵具でカスカスにかかれているスケッチを見た感じでした。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "barely",
