        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭に侵入する動物を防ぐため、低い金網を張った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "運動場のフェンスは、ボールが外に出ないように高い金網で囲われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "パンを焼くとき、粗熱を取るために金網の上に乗せて冷ます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "工事現場では、落下防止のため仮設の金網が設置されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "教室の窓々には金網が張られてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気の導体ですっかり包んだ中へは外からの電気作用が及ばぬというのは定則で、ある学者はこれを証するために自身で金網の中へはいり外から恐ろしい強い電気の火花をポンポン飛ばしたが中に居た先生には何の事もなかったという事である。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "方法はやはり水溜りに石油を撒き、井戸やタンクには金網を蔽うのである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "透明な水のなかで鼠は左右に金網を伝い、それは空気のなかでのように見えた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし僧正｜遍照は天狗を金網の中へ籠めて焼いて灰にしたというが、我らにはなかなかそのような道力はないから、平生いろいろな天狗に脅されて弱っている、俳句天狗や歌天狗、書天狗画天狗｜浄瑠璃天狗、その上に本物の天狗に出られて叱られでもしたら堪らないから筆を擱く。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時のために今から用心したいと思う人は、簡単に金網で囲んでおけばいいと思うが、なんでもあすの用心をするということはおよそ近代的でないらしい。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時おりのら猫がねらいに来るので金網のふたをかぶせてあったのがいつとなくさび朽ちて穴の明いているのをそのままにしてあった。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金網の破れから猫が手を入れて引っかけそこなったものと思われた。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画ではまた金網で豹や大蛇をつかまえる場面もある。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓に張った投身者よけの金網のたった一つの六角の目の中にこの安全地帯が完全に収まっていた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このランデヴーのほほえましい一場面も、この金網のたった一つの目の中で進行した。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁の欄干から軒にかけて一面に張りつめた金網にはナスターシャムと honey-suckle とが細かくからみ合って花をつけながら、卵黄ほどな黄金の光を板や壁の所々に投げ与えていた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "声は、金網越しに「ばか」と怒ったときの声に似ていて、似てもつかぬ、しっかりした声だった。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五位鷺飛んで星移り、当時は何某の家の土蔵になったが、切っても払っても妄執は消失せず、金網戸からまざまざと青竹が見透かさるる。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "古色の夥しい青銅の竜が蟠って、井桁に蓋をしておりまして、金網を張り、みだりに近づいてはなりませぬが、霊沢金水と申して、これがためにこの市の名が起りましたと申します。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、もう床が取ってある……　枕元の火鉢に、はかり炭を継いで、目の破れた金網を斜に載せて、お千さんが懐紙であおぎながら、豌豆餅を焼いてくれた。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "古新聞で火をつけて、金網をかけました。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便局へ出かけたついでに、冬村君の仕事場に立ち寄る、君はもう快くなつて金網機をセツセと織つてゐる、よかつた／＼。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "小径の途中の土の層から大溝の浸み水が洩れ出て、音もなく平に、プールの葭簾を撫で落し、金網を大口にぱくりと開けてしまっている。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "復一はかっとなって、端の綴じが僅か残っている金網を怒りの足で蹴り放った。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の夕刻、熱海梅林の鶴の金網前に葉子は停って居た。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前年、この渓流に添って豊に張られた金網のなかに雌雄並んで豪華な姿を見せて居たのが、今は素立ちのたった一羽、梅花を渡るうすら冷たい夕風に色褪せた丹頂の毛をそよがせ蒼冥として昏れる前面の山々を淋しげに見上げて居る。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "声は、金網越しに「ばか」と怒つたときの声に似てゐて、似てもつかぬ、しつかりした声だつた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "客を接する人も居らず、岑閑とした霧の暮に、あらい金網を張つてゐる危ふげな突端にいたると、一谷｜呀然として開けて、たゞ白煙蒼霧の埋めてゐるかなたに、恐ろしい瀧の音が不斷の響きを立てゝゐるばかりであつた。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓に金網が張つてあるのでせう。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかつき、小用に立つて、アパートの便所の金網張られた四角い窓から、富士が見えた。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の下のアスファルト路を、さかなやの自転車が疾駆し、おう、けさは、やけに富士がはつきり見えるぢやねえか、めつぽふ寒いや、など呟きのこして、私は、暗い便所の中に立ちつくし、窓の金網撫でながら、じめじめ泣いて、あんな思ひは、二度と繰りかへしたくない。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄格子と、金網と、それから、重い扉、開閉のたびごとに、がちん、がちん、と鍵の音。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "花屋敷の焼け跡には一疋の猿が金網の中にきょとんとしており、十二階は地震のために上の三階が堕ちて九階になっていた。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園の横の金網の目から、春のシーズンの名残りらしく野球の球が白く往き来しているのが透けて見えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
