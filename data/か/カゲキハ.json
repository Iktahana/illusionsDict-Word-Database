        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "デモ隊の一部が過激派と化し、機動隊と衝突した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は学生時代、過激派の活動家として知られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "警察は、空港の警備を強化し、過激派によるテロを警戒している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "その政治団体は、過激派と見なされ、常に公安の監視下にある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "水島君は私の中學時代の同窓で、外國語學校露語科の出身者で、Ｋ商事會社の支店員だつたが、互に仕事の餘暇を誘ひ合せて、大正――年の秋、反過激派の勢力が衰へて過激派の勢力が次第にシベリアを南下してくると共に不安騷然たる空氣に包まれてゐるハルピンの町を、日となく夜となく彷徨ひ歩いたのであつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白軍の頭領のカルムイコフは、引渡された過激派の捕虜を虐殺して埋没した。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士達は、始終過激派を追っかけ、家宅捜索をしたり、武器を押収したり、夜半に叩き起され、やにわに武装を整えて応援に出かけたりしなければならなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふふむ、君は一体、支那人かね、ロシヤ人かね、――過激派の。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "工人が、北伐兵の過激派と策応しないとも限らない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隊長は、ここがユフカで、過激派がいることだけを耳にとめた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "過激派討伐を命ぜられた限り、出来るだけ派手な方法を以て、そこらへんにいる、それに類した者をも鏖にしなければならない。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日赤色｜露西亜の過激派政府は、盛んにボリシェヴィキーの宣伝芸術を出してるけれども、吾人のこれに対する批判は、宣伝効果の有無を問うのでなく、ひとえに芸術としての価値に於ける、魅力の有無を問うのである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "過激派の主義から見ればコンナものは、まるで麦の中の泥粒と同様なものかも知れませんけれども……ペトログラードでは、ダイヤや真珠が溝泥の中に棄ててあるということですけれども……僕にとっては生命にも換えられない大切なものなのです。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "分隊の仲間がいつになくまじめになって、何かヒソヒソと話をし合っているようですから、何事かと思って、耳を引っ立ててみますと、それは僕の両親や同胞たちが、過激派のために銃殺されたという噂だったのです。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ニコラス廃帝が、その皇后や、皇太子や、内親王たちと一緒に過激派軍の手で銃殺された……ロマノフ王家の血統はとうとう、こうして凄惨な終結を告げた……という報道があったことを逸早く耳にしているにはいたのですが、その時は、よもやソンナ事があろう筈はないと確信していました。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら過激派でも、あの何も知らない、無力な、温順なツアールとその家族に対して、そんな非常識な事を仕掛ける筈はあり得ない……と心の中で冷笑していたのです。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのニコリフスクから五六里離れた村に過激派のクラネクと云う警察署長がいた。",
              "citation": {
                "source": "警察署長",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "有一館は政府の圧迫を受けて、解党を余儀なくせられた自由党の過激派の手で経営せられた壮士の養成所であった。",
              "citation": {
                "source": "雨夜続志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長はこの無邪気な、彼の便所を彼の居室よりも、金具などきれいにみがき上げるこのきれい好きな、忠実な青年が「過激派」であろうとは思わなかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "トボリスクで過激派の厳重な監視の下に居る皇女が、無事に脱出して、長い西伯利亜鉄道の各駅を、見咎められる事なくして、通過したと云う事は、有り得べからざる不可能事のように思われました。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに、タチアナ姫が脱出に苦心をしたと云っても、過激派の眼を眩ます為に、幼児を携帯して居るなどは、想像も及ばないことでした。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "露廃帝が過激派の為めに、弑逆されたと云う電報が、世界の耳目を駭かしました。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "露廃帝の一族が、エカテリンブルグのある家の地下室で、獣の如き過激派の手に依りて惨殺された実相が、可なり精細に書かれて居ました。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい昨日迄は、内親王であった人達が、名もない過激派の番兵の為に、辱しめを受けた上に、豚の如く撲殺されたと云うことは、何う考え直しても諦めが付きませんでした。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の皇女が、過激派の手で苛なまれるのを見て居た廃帝の、心持ほどの心持を持たされた人が、世界にそれほど沢山存在したとは思われませんでした。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間中、この悲惨事に対する何等かの云い訳、それは過激派の為の云い訳でなくして、人間性そのものに対する云い訳を求めて居ました。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、友人の一人が、「露国の皇女達は、皆過激派の為に、ヒドイ目に逢ったのだね。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "露西亜の過激派のやうに腹が減つてるらしい蝦蟇が、草の間からむつくり顔を出したり、自由恋愛家のやうな蝗が雄と雌と抱き合つて跳ね合つたりする度に、二人は仰山さうに声を立てて吃驚した。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "露西亜人は冬｜外套の襟を立てるのでそのために特にこう出来てるんだそうだが、私の考えでは、これは例の過激派｜鬚を焼かない用心だと思う。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "確に過激派だ」　すっかり理解が出来たと云うのではなくても、思って居たこと丈は兎に角云って、少しは心も溶けたと云う風を見、其日は帰った。",
              "citation": {
                "source": "二つの家を繋ぐ回想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "露西亜の過激派の行動は一見して非常識であり、その手段において極端不法であることは勿論ですが、しかしその精神は全人類的の愛から出発していることを否むことは出来ません。",
              "citation": {
                "source": "三面一体の生活へ",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケレンスキイ一派の第一革命にしても、過激派の今回の暴挙にしても、昔の仏蘭西革命が酸鼻の跡の多いのに反して出来るだけ流血の悲劇を示さずに目的を達することに一致しております。",
              "citation": {
                "source": "三面一体の生活へ",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "露西亜人はどの国よりも逸早くこの点に覚醒して平和の解決を望んだので、その目的は極めて善いのですが、惜しいことに適当な指導者を持たなかったために、無知と短気とから不自然な過程を取って、過激派のような暴状を現出するに至りました。",
              "citation": {
                "source": "三面一体の生活へ",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
