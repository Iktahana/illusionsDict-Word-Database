[
  {
    "uuid": "559a6d55-e99c-55b9-8c11-1680cf797ede",
    "entry": "果肉",
    "reading": {
      "primary": "かにく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
