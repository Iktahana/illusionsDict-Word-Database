[
  {
    "uuid": "dd1b2f1c-cd39-5cc9-a1cc-f45573aa4a9b",
    "entry": "仮漆",
    "reading": {
      "primary": "かしつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
