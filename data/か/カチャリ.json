        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "鉄骨がぶつかり合って、かちゃりと大きな音がした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "風で窓枠が揺れ、かちゃりと小さく鳴った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い時計の振り子が、かちゃり、かちゃりと規則的に音を立てる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その時、列の中の一人の兵士が、かちゃりと剣を鳴らして二人にわざとらしい挙手の礼をした。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大将は太い剣をかちゃりと鞘に収めた。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "かちゃりと源内があけたあとから、物静かにはいっていくと、調べ方にむだがない。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いものがちらりと見えたり、かちゃりと鎖の音がしでもすると、私は矢を禦ぐ楯のようにいそいで傘を右に低く傾ける。",
              "citation": {
                "source": "吠える",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "円鈕を前に押しながら、開く戸に身を任せて、音なき両足を寄木の床に落した時、釘舌のかちゃりと跳ね返る音がする。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねて差し込んである鍵をかちゃりと回すと、錠は苦もなく卸りた。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び上りものだ」　かちゃりと入口の円鈕を捩ったものがある。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋏はかちゃりと床の上に落ちた。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "畏まった御坊は自分の手で封印を切って、かちゃりと響く音をさせながら錠を抜いた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "かちゃりと、小刀があたるたびに、赤い味が笊のなかに隠れる。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
