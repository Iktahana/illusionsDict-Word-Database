    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Chinese design",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この茶室は、壁の装飾から柱の組み方まで、見事に唐様で統一されているね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の着物は、大胆な花柄と金糸の刺繍が施された、いかにも唐様といった豪華なデザインだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "庭園の石灯籠は、繊細な彫刻が施された唐様で、静かな趣を醸し出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "真国は唐様の手を見事に書いた。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆跡は巻頭に掲ぐる通り、二川様に、お家様、定家様、唐様等を加味したらしい雅順なものである。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれども御三代の当主と来ては、いやはや何と言うか、売家と唐様で書く三代目どころの騒ぎではござりませぬわい。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "元義の筆跡を見るに和様にあらずむしろ唐様なり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬えば上等士族は習字にも唐様を学び、下等士族は御家流を書き、世上一般の気風にてこれを評すれば、字の巧拙を問わずして御家流をば俗様として賤しみ、これを書く者をも俗吏俗物として賤しむの勢を成せり。",
              "citation": {
                "source": "旧藩情",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が倭様の字よりも、唐様を愛して、而も其が次第に移つて行つたのである。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此はどうしても、唐様を本格とした所にあるのだ。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其飛鳥都すら、高天原広野姫尊様の思召しで、其から一里北の藤井个原に遷され、藤原都と名を替へて新しい唐様のきら／＼しさを尽した宮殿が建ち並ぶ事になつた。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其飛鳥の都も、高天原広野姫尊様の思召しで、其から一里北の藤井个原に遷され、藤原の都と名を替へて、新しい唐様の端正しさを尽した宮殿が、建ち並ぶ様になつた。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其飛鳥の都も、高天原広野姫尊様の思召しで、其から一里北の藤井｜个原に遷され、藤原の都と名を替えて、新しい唐様の端正しさを尽した宮殿が、建ち並ぶ様になった。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この所謂弘仁期直前に製作せられた一木造りの如来像は世間普通には晩唐様式の模倣であってむしろ日本的性格の甚だ少いそれゆえ其様式もあまり永続きしなかったものとして考えられている。",
              "citation": {
                "source": "美の日本的源泉",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩唐様式の影響というのは唯わずかに衣襞の線条の形式や全体の様式の形骸にとどまっていて、その生命とするところは晩唐のだらけた駄作とは根本的に正反対である。",
              "citation": {
                "source": "美の日本的源泉",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐様で書く三代目として、彼等の小賢しい態度を笑わざるを得ないのである。",
              "citation": {
                "source": "アーニイ・パイルの前に立ちて",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "余笑つて曰く、是れ即ち緑雨が冷罵に長ずる所以なり、緑雨は写実家の如くに細心なれども、写実家の如くに自然を猟ること能はず、彼は貞之進を鋳る時、既に八万の書生を罵らんことを思ひ、駒之助を作る時に、既に唐様を学得せる若旦那を痛罵せんとするのみにて、自然不自然は彼に取りて第二の問題なればなりと。",
              "citation": {
                "source": "「油地獄」を読む",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "五尺の身体が完全に発達し終わってからも、なお親の脛をかじって安逸に世を渡る息子、祖父の造った身代を受け継ぎながら道楽をつくして、ついに売家と唐様で書く孫などは、実に人間社会の特産物である。",
              "citation": {
                "source": "動物の私有財産",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自薦他薦の養子の候補者は、選りどり見どりだが、苦労を知らない大家の次男三男を養子に貰ったところで、よくいう、初代が『初松魚伊勢屋の前をすぐ通り』二代目へ来て『二代目の伊勢屋の前に初松魚』、三代目となると『売家と唐様で書く三代目』という川柳の通りに、悪くすると家の落目を招くにきまっている。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "中宮寺観音とシナ六朝の石仏との間に著しい相違を認める人は、この画が初唐様式の画でありながらしかも気韻においてそれと相違することをも認めなくてはなるまい。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天平美術の様式は通例初唐及び盛唐様式の輸入ということによって説明せられている。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "推古様式より天平様式への展開は、六朝様式より初唐様式への展開の特殊化にほかならぬとともに、またその展開を最も鋭く、最も純粋に遂行したものと考えてよい。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実隆の入木道の妙を得、在来の御家流に唐様を加味した霊腕を揮ったことは、その筆に成れりという『孝経』によっても徴し得らるることであるが、彼が何人からしてこれを習い伝えたかは、予の不敏いまだこれを明かにしない。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二代目の主人学「売家と唐様で書く三代目」と川柳にもありますが、どうも二代目三代目は難しい。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば中古禅宗の和尚が寺の境内に十境とか十二景とかを設けたり、近くは東京の金持奥某が塩原の山水に唐様の地名を附けたりしておるが、元来不自然な事業であるから、久しからずして湮滅する。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん和様には遠く唐様の分子がまさつてゐて、明末｜清初あたりの某々の書に、いくらか似たのがないでもないが、それにしても小味な個性とはちがつて、茫漠とした気宇が横溢してゐる。",
              "citation": {
                "source": "秋艸道人の書について",
                "author": "吉野秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御免下さい」「ど――れ」　響きの音に応ずるように、物々しい返事と一緒に戸口の障子を開けたのは、四十五六とも見える青髯の武張った浪人、門札を見ると、岩根半蔵と唐様の四角な文字で書いてあるのも人柄が忍ばれます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "竹光の殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "番頭の文六は唐様の達筆、手代の幸吉は職業的な器用な字で封筒の稚拙味は真似てもできそうもなく、娘の幾代の仮名文字の美しさも、下女のお道の金釘流も、小僧の鶴吉のたどたどしい筆跡も、およそ白紙脅迫状の封筒の文字とはかけ離れたものだったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "白紙の恐怖",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国人が唐様で書く三代目になったのかも知れない。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は広沢と菱湖が好きであり、唐様も和様も本筋に習った。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお城の構成を見ると、どこやらに南蛮の風を取り入れたらしい趣があると思えば、唐様のよいところもとり容れ、しかもそれをみな日本化しておられる」　しきりと、遠くからその結構に感心している僧侶があった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうふうにしてできあがった部分品を今度は組み立てて行く「総合」「取り付け」の仕事がこれからようやく始まる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぬいは大急ぎで書物をしまい、机を片づけ、台所に出て、白いエプロンを袂ごと胸高に締め、しばられた袂の中からようようの思いで襷をさぐりだすと、それをつむりに潜らせようとしたが、華やかなその色が、夕暗の中で痛いように眼に映った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
