[
  {
    "uuid": "f6ee3413-4365-56ba-9ecb-577bf2376745",
    "entry": "唐様",
    "reading": {
      "primary": "からよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
