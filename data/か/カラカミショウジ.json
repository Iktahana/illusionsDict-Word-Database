        "examples": {
          "standard": [
            {
              "text": "客間には、落ち着いた色合いの唐紙障子がはめ込まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は唐紙障子の張り替え作業を、毎年欠かさず行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "縁側から差し込む光が、唐紙障子を通して柔らかく部屋を照らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "中塗もせぬ荒壁は恣に崩れ落ち、床の下は吹き通し、唐紙障子も足らぬがちの家の内は、火鉢の火位で寒さは防げなかった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸と云う戸、障子と云う障子、窓と云う窓を残らず開放し、母屋は仕切の唐紙障子を一切取払うて、六畳二室板の間ぶっ通しの一間にした。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を唐紙障子に向って座らせて、障子を次から次と左右から引いて開けると、奥の正面にその高僧が座っておられた。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
