        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大雨で増水し、川路が荒れて危険な状態になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "探検隊は険しい川路を遡り、源流を目指した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地図で確認すると、この小道を進むとすぐに広い川路に出るはずだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私がその詩を読んで驚いたことには、それが川路柳虹君の詩そつくりの模倣であつた。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして当時川路君は、ヱルハーレンの詩を盛んに訳してゐたのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの窓には詩話會の親しい友人、室生や佐藤や川路や福田や、それから就中百田宗治の四角な笑顏がのぞいてゐることを想像してゐた。",
              "citation": {
                "source": "大船驛で",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "導かれた車室の中には、白鳥省吾、千家元麿、川路柳虹等の諸君が、いつもの親しい顏ぶりでそろつてゐた。",
              "citation": {
                "source": "大船驛で",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボルシェヴィキに反対する白系露人が工部局のロシア義勇兵に続々加盟して、ガーデン・ブリッジ、四川路橋、蘇州橋等の橋上に哨兵小屋を急造して警戒を始めた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女がつぎに撰んだ職業は北西川路のムーン・パレスの踊子であった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば僕が、自由詩に於ける韻律観念を排斥し、川路｜柳虹君等の形式論者に反対する時、読者の方ではこれを解して、僕を詩の破壊者と見、詩の音律を不用視して散文的に低落させるところの、邪道的暴論者流のように考える。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四川路の十三番八号の皆川よ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしまだこの上永らえるようなことでもございましたら、北四川路のジャウデン・マジソン会社の小使、陳に王の御名でお訊ね下さいませ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは北四川路八号の皆川だ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その石黒氏の話によると、自分を偉くしたのは半分以上川路左衛門尉聖謨の力だと言つてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "川路左衛門尉といへば、人も知つてるやうに仙石騒動を裁いた名代の傑物だつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、川路左衛門尉の前へ連れて往く事に定めた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "TERREこれは詩人川路柳虹君の紹介により、佛國巴里の佛日協會にて發行する『フランス・ジャポン』誌に寄書したもの。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼食はそれでも船の中で終えて、それから上陸すると上海北四川路にある新亜細亜ホテルに落着いた。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「横浜開港五十年史」はこれを引いて正弘を陋としてゐるが、渡辺修次郎さんは「川路聖謨之生涯」を引いてこれを反駁した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「川路聖謨之生涯」に正弘、小栗｜忠順、川路聖謨等の説として、洋医は経験乏しく、且西洋に於る此学の真訣未だ伝はらざるが故に洋医方は信じ難しと云つてあるのは、榛軒が引く所の桂嶼の説と全く同じである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつしよの船に乘りあはせたわけのわからない女の世話で、四川路底にある日本人旅館に宿をとることが出來たけれど、もんは、あの時の男のこゝろの頼りなさをいまだに忘れることが出來ない。",
              "citation": {
                "source": "秋果",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もんは、船で知りあつた女のひとの世話で、賑やかな四川路底の日本人の旅館に拜みこむやうにしてやつと小さい部屋をとつた。",
              "citation": {
                "source": "秋果",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また四川路あたりには、街路の壁に立てかけた掛枠に草双紙類がずらりと並んでる周囲に、子供たちや中には大人まで集まって、僅かな料金でその貸本を借り、自動車や黄包車や通行人の雑沓のなかに街路に屈みこんで、一心に読耽ってるのが見られる。",
              "citation": {
                "source": "上海の渋面",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘇州河の数ある橋のうちでも、ガーデン・ブリッジは自動車の往来が最も頻繁であり、南北四川路をつなぐ橋は人間の往来が最も頻繁であり、この後者の橋の袂には、早朝から深夜に至るまで黄包車が群がっている。",
              "citation": {
                "source": "上海の渋面",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本警備区域内では、北四川路の森永菓子店のすぐ近くに難民区があるのには驚かれる。",
              "citation": {
                "source": "上海の渋面",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月三十日（水曜）晴　暖「南路」　川路柳虹氏来訪、五日まででよろしいとの話。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、川路氏が来られ、原稿をきかれる。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は※い二杯の老酒に酔つて更に諸友と馬車を駆り、日本人の多く住む米租界の呉淞路を過ぎ、北四川路の新公園を観、白石六三郎氏の別墅六三園に小憩した。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその話を聞いた後、北四川路を歩いていると、向うへ来かかった自動車の中に、三人か四人の日本の芸者が、一人の西洋人を擁しながら、頻にはしゃいでいるのを見た。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
