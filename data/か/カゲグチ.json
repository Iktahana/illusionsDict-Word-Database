[
  {
    "uuid": "214d4dac-c2e7-5820-af93-4529fff148cb",
    "entry": "陰口",
    "reading": {
      "primary": "かげぐち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
