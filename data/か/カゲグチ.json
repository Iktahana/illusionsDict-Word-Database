    },
    "definitions": [
      {
        "index": 1,
        "gloss": "malicious gossip",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "誰かが私の陰口を言っているのが聞こえて、とても不快な気分になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女は決して他人の陰口を言わない、信頼できる友人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "職場で陰口が横行しており、チームの雰囲気が悪くなっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "けれども、私から見れば、そんな陰口は、必ずしも当を得ているとは思えなかった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、れいの安易な氣分本位で、やたらと人の陰口をきく。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも裏の事実は一人の例外なしに、堂々、不正の天才、おしゃかさんでさえ、これら大人物に対しては旗色わるく、縁なき衆生と陰口きいた。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は親友の陰口をさへ平氣で吐く。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に學生時代の葉藏が、その教師たちの陰口をきくときの燃えるやうな瞳を愛した。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間は案外敏感で、小笹屋の暖簾も、と噂する陰口は河岸ばかりでなく、遊びつけの日本橋、柳橋あたりの遊里にまで響き、うっかりしたお雛妓の言葉使いにも隠されぬ冷淡さがあった。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを考えてくれたら、鼻の上に汗をためて――そんな陰口は利けなかった筈だ。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、れいの安易な気分本位で、やたらと人の陰口をきく。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私などそんな女達や陰口の上手な麻川氏等に何を云われて居るのかと時々たまらなく神経に触る。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "処がまた追々日がたつに従って私は赫子がやはりありきたりの女性の誰でもと同じように一寸した言葉の間の負けず気や周囲の同性の身なりのほんのつまらない動静にまで皮肉や陰口で意地悪くこせこせするのを見聞するようになり、もはや赫子という女に全然興味を無くして仕舞って居た。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　店の小僧や番頭が、主人宗右衛門のこんな陰口を囁き合ふやうになつた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の奥座敷でお辻の死体をそれに入れる時「出し惜しみが急に気張つたのでお辻さんは風邪をひくわい」と兼々気まづかつた親類の一人が、わざと聞えよがしの陰口をきいた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、それまで二年、あなたと暮して、あなたが人の陰口をたたいたのを伺った事が一度もありませんでした。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たったいま迄、あの御立派な先生の前で、ぺこぺこしていらした癖に、もうすぐ、そんな陰口をたたくなんて、あなたは、気違いです。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、先王を軽蔑し、憎み、わからずやだと陰口をきき、先王を手こずらせているでしょう。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分で借りて肩身が狭く、お前をけむったいものだから、必ずどこかで、お前の陰口をたたきます。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハムレットが他人の陰口を言わない子だという事も、あなたから伺ってはじめて知りました。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "めめしいとでも申しましょうか、ひとの陰口ばかりを気にして、いつも、いらいらなさって居ります。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でも、お父さんは年中お祭りみたいにそわそわしている、あんなのをお祭り野郎ってんだと陰口たたいていた人があったわよ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "求めもせぬに、私に、とめどなき告白したる十数人の男女、三つき経ちて、必ず私を悪しざまに、それも陰口、言いちらした。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにが不足で、あがくのだろう、好き好んで苦しみを買っているのだ、人生の、生活のディレッタント、運がよすぎて恐縮していやがる、あんなたちの女があるよ苦労性と言ってね陰口だけを気にしている。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は友の陰口を言ったことさえない。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けっして、人の陰口をきかず、よその人の消息をお話申しあげても、つまらなそうにして、私の商売のことのみ、たいへん熱心に御研究でございました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩下ら三人の未熟を笑ったのか、あるいは我れならばきっと仕留めてみせるという自信の笑いか、いずれその一つとは察せられたが、弥太郎は組内の古参といい、鉄砲にかけても老練の巧者であることを諸人もよく知っているので、さすがに正面から彼を詰問する者もなかったが、その不快が陰口となって表われた。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よっぽど悋気深い女だよ」と、妻は僕に陰口を言ったが、「奥さん、奥さん」と言われていれば、さほど憎くもない様子だ。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お雪さんは、わしらとは違ってる、あれは人間じゃないよ」　村の女たちは陰口を利きあった。",
              "citation": {
                "source": "雪女",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊には村落の若者の間へは寸毫も遠慮の無い想像に伴ふ陰口を逞しくせしめる好箇の材料を提供したのであつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような無智な陰口が、微風と共に、ひそひそ私の耳にはいって来る。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "依怙贔屓をするなどという陰口もうるさい。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と夫の作造はのんきに構えこんだのだが、女房は――家付娘としてこの村の習慣に骨の髄まで囚われてしまっているお島としては、隣同士で招んでも来なかった、とあとでかげぐちをきかれるのが、死ぬほど辛かったのである。",
              "citation": {
                "source": "おびとき",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
