  },
  {
    "uuid": "070dd4e1-eaca-5217-834b-b1b626ad073a",
    "entry": "華人",
    "reading": {
      "primary": "かじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ethnic Chinese (living abroad, esp. with non-Chinese citizenship)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "東南アジアの経済発展において、各地の華人ネットワークが果たした役割は大きい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はシンガポール出身の華人で、英語、中国語、マレー語を自在に操る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "旧正月になると、華人街は赤い飾り付けと爆竹の音で賑わいを見せる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父の代に日本へ渡ってきた彼は、華人としての誇りを持ちつつ日本社会に溶け込んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "支那商業団体の各路商会聯合会、納税華人会、総商会の総ては、一致団結して罷市賛成に署名を終えたのだ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "広大なその地域と、これもまた広い中華人民共和国との間にはさまっているために、せまいように見える蒙古人民共和国があります。",
              "citation": {
                "source": "新しいアジアのために",
                "author": "――アジア婦人大会によせて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェト同盟の国境、朝鮮、満州をふくむ中華人民共和国、ビルマ、シャム、マライ、印度支那、フィリピン、とアジアの地図に描かれているどの国々をみても、こんどの戦争で日本の軍隊が侵略しなかった土地はありません。",
              "citation": {
                "source": "新しいアジアのために",
                "author": "――アジア婦人大会によせて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国の人々が、日本その他の国の帝国主義を排除して中華人民共和国となったばかりではありません。",
              "citation": {
                "source": "新しいアジアのために",
                "author": "――アジア婦人大会によせて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "中華人民共和国の輝やかしい一九五〇年の新春を慶賀いたします。",
              "citation": {
                "source": "宋慶齢への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、一九五〇年は世界最大の人口をもつ中国が、中華人民共和国として発足しているという驚歎すべき事実によって、広大なアジアに全く新しい歴史の頁をもたらしました。",
              "citation": {
                "source": "宋慶齢への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しく採択された中華人民共和国の大憲章が、その第一章第六条、第五章第四十八条に「婦人を束縛する封建制度を廃止」し、母性福祉を約束していることは当然といいながら、その現実的な価値ははかりしれません。",
              "citation": {
                "source": "宋慶齢への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五〇年における中華人民共和国の発展を祝し、革命の母たるあなたの一そうの健康と活動とを切望いたします。",
              "citation": {
                "source": "宋慶齢への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国は中華人民共和国になって、旧い年号というものを廃止しました。",
              "citation": {
                "source": "国際婦人デーへのメッセージ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェト同盟、中華人民共和国、朝鮮、ヴェトナム、これらの民族は、それぞれ近代帝国主義の発展とともに、屈辱と辛苦とをなめつくして、ついに新しい人民の運命の戸口を開いた。",
              "citation": {
                "source": "「人間関係方面の成果」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年はアジアにとってきわめて意味深い大きな出来ごとがあって、遂に中国は新しい中華人民共和国として誕生しました。",
              "citation": {
                "source": "今年こそは",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際に世界の平和と日本の自立の為には、日本管理に関係のあるソヴェト同盟、中華人民共和国、その他オーストラリヤ、イギリスその他の国々の同意がなければなりません。",
              "citation": {
                "source": "今年こそは",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月には新しい中華人民共和国の北京で、アジアの平和のために婦人大会がもたれ、そこへ日本からの代表もゆこう。",
              "citation": {
                "source": "「未亡人の手記」選後評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中共の確定的勝利」は、地球上もっとも大きい人口をもつ中華人民共和国の誕生によって、日本人民をこめるアジアの未来の運命の方向が決定的に変革された人類史上のできごとである。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四五年に東ヨーロッパに人民民主主義政権が確立し、北朝鮮の共和政権が生れ、一九四九年十月には中華人民共和国が出発した。",
              "citation": {
                "source": "文学と生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国は中華人民共和国となりアジアとヨーロッパに民主勢力が拡大した。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私も、Ｍサンも、一〇年二〇年と日本帝国主義のアジア侵略、アジア植民地支配という負い目を背負おうとしてきて、その罪悪感は左翼イデオロギーで倍化されて、おもりの反対側に、それだけ大きなユートピアを、中華人民共和国なり、朝鮮民主主義人民共和国なりにもっていたのですね。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "行き届いた男だが、しかし中華人一流の要らざる心配だよ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "華人因之作『化胡經』也。",
              "citation": {
                "source": "老子化胡經",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなはち、「接吻」の語は中華人の造つた飜訳語で、日本人はその儘採つて来たにすぎないとかう思つたのである。",
              "citation": {
                "source": "接吻",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "盤に向うのは、その他の日華人少数だった。",
              "citation": {
                "source": "秦の出発",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳という中華人の家ですから、ちょッとうるさいかも知れませんがね」　表門へまわって案内を乞う。",
              "citation": {
                "source": "南京虫殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは公園の入口に「華人不可入」と書いた建札が、厳めしく立っているからだ。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の李彩は、昭和廿年三月九日の戦災で歿した中華人の先代李彩で、木村錦花氏の『明治座物語』に拠ると、彼このときはじめて日本へ来朝したのだらう明治卅五年十一月九日から七日間、「清国人李彩一行の曲芸」を興行したと記されてゐる。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "日貨排斥がはじまってから、伸子はパリの中華人たちが、日本の帝国主義にひっくるめて、日本人一般に反撥をもっていることを当然だと考えていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アジアの平和は、とりもなおさず、世界平和の問題であることは、中華人民共和国の宣言で云われているとおりである。",
              "citation": {
                "source": "婦人デーとひな祭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁義人倫によって立つ中華人のこの我だが、イヤこの壮漢の語った話を聞くにつけ、ほとほと我が身を恥じたぞ。",
              "citation": {
                "source": "戦争",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国においては、六億八千万の各位が中華人民共和国を作りあげておるのであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本はこの中華人民共和国とのあいだに国交を回復しなければなりません。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また中華人民共和国が国際連合に加盟することも当然と信じます。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
