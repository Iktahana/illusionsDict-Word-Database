  {
    "uuid": "9492d202-eb8a-57b2-90f3-a80a324a7343",
    "entry": "寡人",
    "reading": {
      "primary": "かじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "代名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "I",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「寡人の不徳の致すところにより、民を苦しめてしまった」と王は嘆いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "諸侯を前に、若き君主は「寡人に力を貸してほしい」と力強く訴えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古典小説の中で、皇帝が自らを寡人と称して臣下に語りかける場面がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「寡人の命に従えぬと言うのか」と、威厳に満ちた声が広間に響いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "此時までお定は、まだ行くとも行かぬとも言はなかつたが、兎も角も明日｜決然した返事をすると言つて置いて、も一人お末といふ娘にも勸めようと言ふお八重の言葉には、お末の家が寡人だから勸めぬ方が可いと言ひ、此話は二人｜限の事にすると堅く約束して別れた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時まではお定は、まだ行くとも行かぬとも言はなかつたが、兎も角も明日｜決然した返事をすると言つて置いて、も一人お末といふ娘にも勧めようかと言ふお八重の言葉には、お末の家が寡人だから勧めぬ方が可いと言ひ、此話は二人｜限の事にすると堅く約束して別れた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "民権論派はもと民選議院論に促されて起こりたるの姿あれども、これただその民権説に促されたるのみ、いわゆる寡人政府の専横というに同意したるのみ、民選議院設立を急務とするの点に至りてはこの論派あえて熱心にこれを唱道せざるがごとし。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "『陛下、寡人はこの二の褥が、あなたに仇をする二人の巨人であればよいと思ふ。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "寡人は即座に其頸を※切つて御眼にかけたい。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "『寡人はあなたを愛してゐるからです。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでバルタザアルは両腕を女王の方へのばしながら『寡人にあなたの頸に落ちた小さな羽を下さるなら、寡人は其代に寡人の王国の半を差上げる。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "『寡人の名はガスパアと云ふ。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "『寡人の名はメルキオルと云ふ。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『寡人も卿等の行く所へ行かなければならぬ。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "寡人は楽欲に克つた其の為に、星が寡人に言をかけてくれたのだ』とバルタザアルが云つた。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "『寡人は驕慢に克つた。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "寡人の召されたのは其為ぢや』とメルキオルが云つた。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "『寡人は虐行に克つた。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "其故に寡人は卿等と共に行くのだ』とガスパアが云つた。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "秦王（始皇帝）偶※之を覽て、大に其才を賞嘆して曰く、寡人もし此人と與に遊ぶを得ば、死すとも恨みずと。",
              "citation": {
                "source": "韓非子解題",
                "author": "小柳司気太",
                "note": "青空文庫"
              }
            },
            {
              "text": "寡人得見此人與之游、死不恨矣とさへいうた程である。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "定公がこの處置を執るに當つて、寡人嘗學斷斯獄矣と公言する所を觀ると、これが一時臨機の處置でなく、古來傳統の處置に本づいたものと認めねばならぬ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "寡人政治の風を廢して、人民一般に參政の權を附與し、多數を以て公明正大の政を行ふは、國會の開設に在ることならんと雖ども、之を開設して隨て兩三政黨の相對するあらば、其間の軋轢は甚だ苦々しきことならん。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの三府五港はもちろん、各都府においてみずから誇称して紳商と称し、みずから商業世界の寡人政府を組織したる人々を見よ。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "寡人政治がいかんから、代議政体にする。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉王、臺上より觀、（孫子ガ）且に愛姫を斬らんとするを見、大に駭き、趣かに使をして令を下さしめて曰く、『寡人已に將軍の能く兵を用ふるを知る。",
              "citation": {
                "source": "國譯史記列傳",
                "author": "孫子呉起列傳第五",
                "note": "青空文庫"
              }
            },
            {
              "text": "寡人、此二｜姫に非ざれば、食、味を甘しとせず。",
              "citation": {
                "source": "國譯史記列傳",
                "author": "孫子呉起列傳第五",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉王曰く、『將軍、（一一）罷休し（一二）舍に就け、寡人、下りて觀るを願はず』と。",
              "citation": {
                "source": "國譯史記列傳",
                "author": "孫子呉起列傳第五",
                "note": "青空文庫"
              }
            },
            {
              "text": "秦王、孤憤・五蠧の書を見て曰く、『嗟乎寡人、此人を見之と遊ぶを得ば、死すとも恨みじ』と。",
              "citation": {
                "source": "國譯史記列傳",
                "author": "老莊申韓列傳第三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に佳人水上行を解してかじんすいじやうにゆくとはうつくしき女の水の上をあゆむがごとくわがなすほどのことはあやふく心もとなしとのたとへなりとあり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
