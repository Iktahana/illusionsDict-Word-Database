        "examples": {
          "standard": [
            {
              "text": "夕陽を浴びて、鶴翼が黄金色に輝いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "傷ついた鶴は、鶴翼を広げることもできずにうずくまっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "鶴翼の一振りで、鶴はふわりと大空へ舞い上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
