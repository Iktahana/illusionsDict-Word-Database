        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "明日の歓迎宴では、社長からの祝辞がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新任の外国籍職員のために、盛大な歓迎宴が催された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「いやー、こんなに立派な歓迎宴を開いていただき、恐縮です。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」　武一や竹下達のことを滝本が訊ねると、皆なは森の家で歓迎宴の支度をして待つてゐる――。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　京城到着当夜の歓迎宴は、京喜久というので開かれた。",
              "citation": {
                "source": "淡紫裳",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この公会堂に於て故伊藤博文公が、ハルビン駅頭で鮮人に暗殺される三日前、盛大極まる歓迎宴が開かれたことがあるそうだ。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また彼は「新時代」紙の社主スヴォーリンと一緒に、ヴォローネシ県に視察に出かけたが、これは県当局の歓迎宴などの連続で、彼はすこぶる自嘲的な苦笑をうかべて退散せざるを得なかった。",
              "citation": {
                "source": "チェーホフ試論",
                "author": "――チェーホフ序説の一部として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに彼は『新時代』の社主スヴォーリンと一緒にヴォローネシ県を視察したが、これは県当局の歓迎宴などの連続で、彼は自嘲的な微苦笑をうかべて退散せざるを得なかった。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は料亭春木楼で松本知事主催の歓迎宴が吾々のために設けられた。",
              "citation": {
                "source": "全羅紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルージェール伯は、その年二月下旬、信任状を捧呈せられたばかりの新大使であったが、当時帝国ホテルで朝野の歓迎宴を張った際、鷲尾侯も出席して、今日の御訪問も、その時からの御約束が延び延びになっていた訳だ。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "川村からは折返し返事があって「私如きものの為に、Ｓ市一流の名士方が歓迎宴を張って下さるとは、実に実に光栄の至り、御指図の通り停車場よりすぐ様会場へかけつけます」と云って来た。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一言の挨拶もせず、歓迎宴の席を立去ろうとするのだ。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "曹操はあいそよく、「ご健勝でよろこばしい」と、会釈の礼を交わし、兵馬は府外に駐屯し、その後、駅館の歓迎宴では、劉玄徳も同席して、袁術討伐の気勢をあげた。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日目には彼のための歓迎宴が成都宮の星雲殿にひらかれた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
