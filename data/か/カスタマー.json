        "examples": {
          "standard": [
            {
              "text": "今回の新しいサブスクリプションプランは、主に20代から30代の若年層カスタマーをターゲットとして設計されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "長年自社ブランドを愛用してくださっているロイヤルカスタマーへの還元策として、新製品の先行体験会を企画した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "カスタマーの生の声や隠れたニーズを商品開発に取り入れるため、定期的にオンラインでのグループインタビューを実施している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "競合他社に乗り換えられてしまうのを防ぐには、既存カスタマーの満足度を継続的に測定し、不満の芽を早めに摘む必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「日本電気のパーソナルコンピューターが伸びてくるにあたっては、カスタマー、そしてサードパーティーの力が大変大きく働いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "サードパーティーとカスタマーに引きずられ、彼らのエネルギーが注ぎ込まれたからこそここまで伸びてきたんでしょうね」　日本電気副会長、大内淳義は今そう語る。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
