        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昨夜の台風で、大切に育ててきた庭のヒマワリが根元から風折れしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわっ、あっちの街路樹、太い枝が風折れして歩道を塞いでるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "収穫間際の稲が風折れを免れたのは、まさに奇跡と言っていいだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "強風に煽られ、キャンプサイトのタープの支柱が風折れする鈍い音が闇に響いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その地方にある山林の枯れ痛み、風折れ、雪折れ、あるいは枝卸しなどの見回りをしているような人であった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、谷へ来る野鳥の類なら、そのなき声をきいただけでもすぐに言い当てるほど多くの鳥の名を諳記じていて、山林の枯れ痛み、風折れ、雪折れ、あるいは枝卸しなどのことには精通していた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
