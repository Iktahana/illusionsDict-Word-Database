  {
    "uuid": "4df24ec2-bd54-52bd-bb9e-11c94565d360",
    "entry": "絣",
    "reading": {
      "primary": "かすり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "splash pattern (e.g. on a kimono)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夏祭りで着る浴衣は、伝統的な絣模様のものを選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この手ぬぐいは、涼しげな絣柄が気に入って買った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供用の甚平も、かすりの優しい色合いで揃えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "久留米絣を来てゐて、既に酔つてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "中の字を星形にした徽章のついた制帽を冠って、紺のめくらじまの袴をはき脚絆に草鞋がけ、それに久留米絣の綿入羽織という出で立ちであったと思う。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源は派手な琉球絣の薄ものをたつた一枚身にまとひ、郭光の酌で泡盛の大杯をチビリ、チビリと飲んで居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何といふ古風な紫の上品な色調、それがやや鼠がゝつた白と中柄の矢はづ絣を組み合せてゐる柄。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店の床几で鼠色羽二重の襦袢の襟をした粗い久留米絣の美少年の姿が、ちらりと動く。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "縞の或る部分をかすり取る場合に、かすり取られた部分が縞に対して比較的微小なるときは、縞筋にかすりを交えた形となり、比較的強大なるときは、いわゆる絣を生ずる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぶつぶ絣の単物に桃色のへこ帯を後ろにたれ、小さな膝を折ってその両膝に罪のない手を乗せてしゃがんでいる。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "絣の単物に、メリンスの赤縞の西洋前掛けである。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の中村氏は白地の勝った絣を着ていたような気がする。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いゝ年をして、生若い、紺絣の青年のようなことを云ってら！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "染め絣、モスリン、銘仙絣、肩掛、手袋、などがあった。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これ、品の羽織にしてやろうと思うて……」　と彼女は銘仙絣を取って清吉に見せた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は番頭に黙って借りて帰ったモスリンと絣を、どう云ってその訳を話していゝか思案している。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "絣合羽の巡礼に、　　　　　　五厘報謝の夕まぐれ、わかめと鱈に雪つみて、　　　鮫の黒身も凍りけり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　などと間伸のした、しかも際立って耳につく東京の調子で行る、……その本人は、受取口から見た処、二十四、五の青年で、羽織は着ずに、小倉の袴で、久留米らしい絣の袷、白い襯衣を手首で留めた、肥った腕の、肩の辺まで捲手で何とも以て忙しそうな、そのくせ、する事は薩張捗らぬ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふもとのほうから迎いに来た自動車の前面のガラス窓に降灰がまばらな絣模様を描いていた。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺絣に角帯というのもまた珍妙な風俗ですね。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "絣の着物に袴をはいて、小さくなって坐っていた。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのふの新患者は、紺絣の袷をきちんと着て籐椅子に坐り、海を眺めてゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大きい絣の単衣を着ていると、私は角力の取的のようである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は、自分の衣服を買う事に於いては、極端に吝嗇なので、この三、四年間に、夏の白絣一枚と、久留米絣の単衣を一枚新調しただけである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばいま、夏から秋にかけての私の服装に就いて言うならば、真夏は、白絣いちまい、それから涼しくなるにつれて、久留米絣の単衣と、銘仙の絣の単衣とを交互に着て外出する。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銘仙の絣の単衣は、家内の亡父の遺品である。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上唇を弾丸で横にかすり取られた者がある。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　軍医は、上唇を横にかすり取られた幼なげな男に、こうきいた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中間はくくりつけられるまでに散散の打擲をうけたらしく、頬にはかすり疵の血がにじんで、髪も着物もみだれたままで、意気地もなく俯向いていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、半身を落盤にかすり取られていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな宿屋などの三助ででもあれば、あたりまえなら接近する事も困難なような貴顕のかたがたを丸裸にしてその肢体を大根かすりこぎででもあるように自由に取り扱って、そうしておしまいには肩や背中をなぐりつけ、ひねくり回すのである。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「灰汁桶のしずくやみけりきりぎりす」「あぶらかすりて宵寝する秋」という一連がある。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また灰汁のしずくが次第にその流量を減じてとうとう出なくなってしまう、その量対時間関係が「油かすりて」欠乏する感じに照応するのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
