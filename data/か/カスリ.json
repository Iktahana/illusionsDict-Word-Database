        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は、友人の弱みにつけ込んで、しつこく金銭をかすめていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ぼったくりバーで、法外な料金をかすめ取られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
