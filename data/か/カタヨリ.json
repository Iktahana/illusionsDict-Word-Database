        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "磁石は、その両端で強い偏りを示し、鉄を引きつける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "世論の偏りが激しく、建設的な議論が難しい状況だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "偏りが生じないよう、常に複数の情報源を確認する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
