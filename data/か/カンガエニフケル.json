    "definitions": [
      {
        "index": 1,
        "gloss": "to be absorbed in thought",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "窓の外をぼんやり眺めながら、彼女は長い間、昔の思い出について考えにふけっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おーい、さっきから考えにふけってどうしたんだ？ コーヒー冷めちゃうぞ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "静かな書斎で一人、これからのキャリアについて深く考えにふける時間は貴重だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は顎に手を当て、深刻な面持ちでチェスの盤面を見つめながら考えにふけっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "船長は無言で考えにふける。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、自分では気がつきませんでしたが、私はいつも考えにふける時のように人を寄せつけないムズかしい顔をしていたのです。",
              "citation": {
                "source": "ある思想家の手紙",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "というわけで夫人は、横になっていなければならぬ時のほかは、シュパッツ夫人を相手に、じっと静かに坐っていて、なにか手をつけぬ手仕事を膝にのせたまま、様々な考えにふけるのであった。",
              "citation": {
                "source": "トリスタン",
                "author": "TRISTAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がもし自分の考えにふける隙があったら、落胆か遊蕩かに陥ったかもしれない。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はまだ八歳にしかなっていなかったが、種々な苦しい目に会ったので、あたかも年取った女のような痛ましい様子で考えにふけるのだった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士はふたりを、玄関まで見おくっておいて、ふたたび地下室にひきかえし、テーブルのまえに腰かけて、そこにおいたままになっていた、ふしぎな、かな文字をしるした紙を、じっとみつめながら、しきりと考えにふけるのでした。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
