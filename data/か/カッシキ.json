        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "能面展で、喝食の面が持つ独特の表情に見入ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "舞台の上で、喝食の面をつけた役者が軽やかに舞う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の家には、代々伝わる貴重な喝食の能面が飾られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
