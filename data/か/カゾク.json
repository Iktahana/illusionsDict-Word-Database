[
  {
    "uuid": "8ebbbbc7-5a44-55a4-9da4-628ba5d8e334",
    "entry": "家族",
    "reading": {
      "primary": "かぞく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "family",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長年飼っていた犬が亡くなり、大切な家族を失ったような喪失感に襲われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "週末は実家に帰り、久々に家族全員で食卓を囲んで鍋をつついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "お彼岸の時期には、家族揃って先祖の墓参りに行くのが我が家の恒例行事だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "家族旅行と木箱との過剰は最早、世界をして理知にて笑はしめ、感情にて判断せしむるなり。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして国籍を持たない家族が、財産上にも生命上にも、日本の政府から保護を受け得ないことを考えた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその他の場合では、罪のない笑談を言ったりして、妻や子供の家族を笑わせ、女中までも仲間に入れて、一家｜団欒の空気を作った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしたヘルンの日本語は、ヘルンの家族以外の人々には、容易に意味がわからなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族の人々は、それを『ヘルンさん言葉』と呼んで面白がった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "化物屋敷の一件以来、おそらくは『面白いの家』という言葉などが、一種の反語として家族中に流行し、すべての不潔の家、陰気な家などを指す代名詞になったであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ家の中に住んでる家族の者にさえも、ほとんど全く解らない不思議な言葉で、何時間も倦きずに睦じく語り合ってた二人の男女こそ、この世における最も理想的に幸福な夫婦であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人や家族の者たちは、彼の左右に侍って酌をしながら、その日の日本新聞を読んできかせた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中が二人、書生が一人、老僕が一人、他に抱車夫が一人という大家族であったので、家も相当に広く、間数がいくつもあって廊下続きになっていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことあつて後、まもなく自分等の家族は田端を去り、鎌倉の方へ移轉してしまつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族は、捨ててよいものでしょうか。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「長女の婿は三、四年前に北支で戦死、家族はいま小坂の家に住んでいる筈だ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所の方からは、――三十人に近い此の家族の夕飯仕度で騒がしかつた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔦かずらの這う古く懐かしい家の中で、薪の燃えるストーヴの火を囲みながら、老幼男女の一家族が、祖先の画像を映す洋燈の下で、むつまじく語り合うことを言うのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気象輪講会は何となく上品にのんびりしていたし、地球物理輪講会は生真面目でしかも家族的な気分であったが、地理の輪講会には何となく物々しい人間臭い気分があった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族一同の写真を送ってくれたが、四十年前の亀さんの面影が今日でもそっくりそのままに残っているのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会に対し、政府に対し、同胞に対しまた家族に対してあらゆる種類の不平不満をいだいている人は、この原始的楽器を原始的の努力をもってたたきつけるのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、家族の者たちに遠慮しながらも、どうしてもお酒を飮まざるを得ないやうな氣持になるのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、あのお酒飮みのお爺さんも、また、その家族も、または、劍山に住む鬼どもだつて、少しも惡い事はしてゐない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜の波止場で、家族と友人の出迎えを受け、久しぶりで逢いたい顔に逢ったが、ただ一つ逢えない顔があった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "本田家の当主は、家族の者と主治医とに守られて、陶製のもののように、何も考えることも感じることも出来なくなった頭を、氷枕と氷嚢との間に挟んでいた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族の人たち、当主の妻と、その子供である、二人の息子と三人の娘とは、何かを待つような気持を、どうしても追っ払うことが出来なかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、家族のものは、泣きながら食卓の前に坐らされている、腹の空いた子供のような気持を、抱かない訳には行かなかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族の者とても、取調べを受けない訳には行かなかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "厄年に入る前年に私は家族の一人を失ったが、その後にはそれほど著しい不幸には会わなかった。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五七五七七という音数律そのままのものは勿論現在では日本特有のものであろうが、この詩形の遠い先祖となるべきものが必ず何処かにあったであろうと想像し、その同じ先祖から出た他の家族が何処かにありはしなかったかと想像するのはそれほど唐突な空想とは思われない。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓄音機と云へば、宿へ着いた時につい隣りの見晴らしの縁側に旅行用蓄音機を据ゑて、色々な一粒選りの洋樂のレコードをかけてゐる家族連の客があつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "市中の堀などでよく見かけるやうな、船を家として渡つて行く家族の一つである。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆んど感傷的になつて見惚れて居る景色の中には、こんなに日が暮れかゝつてもまだ休まず働いて居る農夫の家族が幾組となく居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは平生幾度となく家族に云い含めてあったことの効果があったのだというような気がした。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
