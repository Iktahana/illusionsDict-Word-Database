[
  {
    "uuid": "d6a2eb25-61f0-538d-8a96-78384b465198",
    "entry": "感興",
    "reading": {
      "primary": "かんきょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "interest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その絵画は、見る者に深い感興を呼び起こす力を持っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "秋の紅葉は、私の感興を大いに刺激し、詩を書きたい気持ちにさせられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古い寺院の静寂な雰囲気は、訪れる人々に静かな感興を与えます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このドキュメンタリー映画は、普段あまり関心のない分野だったが、非常に大きな感興を抱かされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "家内のちょっとした物音や話声にも、感興を破られたといって苦情を言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『吹くのが面白いものだから、自分でわざと火を消しては、やたらに吹いた』と、夫人が追想談で話しているが、おそらくそういう場合、ヘルンの筆が行き渋り、感興が中断した時であったろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに芸術とは、自然と人情とを、対抗的にではなく、魂の裡に感じ、対抗的にではなく感じられることは感興或ひは、感謝となるもので、而してそれが旺盛なれば遂に表現を作すといふ順序のものである。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、認識能力或は意識によつて、己が受働する感興を翻訳する。",
              "citation": {
                "source": "河上に呈する詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時「自然詩人」は感興の対象なる事象物象をセンチメンタルに、あまりにも生理作用で書き付ける。",
              "citation": {
                "source": "河上に呈する詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああした種類の風景は、もはや時代遅れの趣味に属するもので、近代の若い人には感興がない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、見馴れない吾々にはどうもあまりひねり過ぎたと思われるような、あるいは無用に誇張したと思われるような辞句が目に立って、却って感興をそがれるような気のするのもありました。",
              "citation": {
                "source": "御返事（石原純君へ）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは平凡な織物の帯地を見ているようなもので、綺麗は綺麗だがそこに何らの感興も起らなければ何らの刺戟も受けない。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大観氏の四枚の絵は自分には裾模様でも見るようで、絵としての感興が沸いて来ない。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る人にとっても釣り込まれるような感興が起ろうはずはない。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは一つには自分がだんだん年を取ってすべてのものに対する感興の強度を減らしたためもあるかもしれないが、一つにはまた実際に近頃の二科会の絵の傾向が自分の好みに背馳して来たように思われたためもある。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も僕は、以前から幾度も室生君のことを書き、むしろ書きすぎてゐるほどであるが、最近彼が大森へ移轉して來て、田端以來の舊交が大に温まつたので、また新しく書く感興が起つたのだ。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもあの生活を背景にした主人公があゝいふ風な感興を持つたロシアの女のイメイジである。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外に寫眞、音樂、園藝などと各種の趣味をあさつたが、勝負事にも相當に感興を持つた方で、撞球は二十四五歳の頃百五十點突いた。",
              "citation": {
                "source": "自分のこと",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃、歐米では一｜時の麻雀熱がさめてブリツヂ・ポオカアの遊びに歸つたと言ふし、日本でも花合せの技法がずつと深奧複雜でより感興深いことを説く人もあるが、麻雀には遊びの魅力は魅力として、外にあの牌に觸れるといふ不可思議な魅力がある。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、讀書人夏目漱石は勝負事には感興を持つてゐなかつたのであらうが、それは麻雀競技の甚だ漠然とした、斷片的な印象を數行綴つたのに過ぎない。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくこの人にとつては津輕海峽の霧も、美しいポプラの林ももう何等の感興を與へないのであらうと密かに思つた時、今までの自分の感じや印象のすべてを疑ひたいやうな氣持がした。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全體旅をしながら何物をも見ず、見ても何等の感興も起さず、起しても其を折角の同伴者と語り合て更に興を増すこともしないなら、初めから其人は旅の面白みを知らないのだ、など自分は獨り腹の中で愚痴つて居ると『あれは何でしよう、そら彼の山の頂邊の三｜角の家のやうなもの。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何をしに自分は来たのだ」　それは彼のなかに残っている古い生活の感興にすぎなかった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜湯へ来ていた娘ですよ」　私は若い母が感興を動かすかどうかを見ようとした。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この葛藤に伴なう多くの美しい感傷の場面の連続によって観客の感興をつなぎつつ最後の頂点に導いて行く監督の腕前はそんなに拙であると思われないようである。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治時代の「風俗画報」がわれわれに無限の資料を与え感興をそそるのもそのためであろう。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉を換えていえば、田舎の人にも都会の人にも感興を起こさしむるような物語、小さな物語、しかも哀れの深い物語、あるいは抱腹するような物語が二つ三つそこらの軒先に隠れていそうに思われるからであろう。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "無窮無限という事実も貴様には何等、感興と畏懼と沈思とを喚び起す当面の大いなる事実ではなく、数の連続を以てインフィニテー（無限）を式で示そうとする数学者のお仲間でしょう。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちあの時はただ愛、ただ感ありしのみ、他に思考するところの者を藉り来たりて感興を助くるに及ばざりしなり。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは偶然に読んだ詩編か小説かの中である感興に打たれたような場所に決めてしまう。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内記が系統的に完備しているという事と、それが読む人の感興をひくという事とは全然別な事で、むしろ往々｜相容れないような傾向がある。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒谷や金閣寺の案内の小僧でも、始めてあの建築や古器物に接した時にはおそらくさまざまな深い感興に動かされたに相違ない。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ誤謬に立脚した変態の俳句などは、自分の皮膚の黄色いことを忘れた日本人のむだな訓練によってゆがめられた心にのみ感興を呼び起こすであろう。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリ娘を見ても何の感興も起りません」　それから間もなく青年は再びロンドンへ帰って来た。",
              "citation": {
                "source": "マロニエの花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
