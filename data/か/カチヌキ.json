        "examples": {
          "standard": [
            {
              "text": "今年の全国大会は、完全に勝ち抜き形式で行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "柔道の試合は、一度負けたら終わりの勝ち抜き戦だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "勝ち抜き形式のトーナメントは、最初から全力を出さないと次に進めない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "革命児ダイナブックの背後に潜む目玉パワーの真実　パーソナルコンピューター業界の関係者を集めて勝ち抜きにらめっこ大会を催す企画は、どう考えてみても魅力に乏しい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いんちきばくち勝ち抜き秘法」　と、そういう文字が読まれたからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふとんを売っ払って金をつくって、このいんちきばくちの勝ち抜き秘伝書をとっくり覚え込んでから、千葉のおしろうとだんなをむくどりにしようと出かけていったにちげえねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからミドル級の勝ち抜き戦になり、終りのヘビー級となると一対一か、せいぜい三者対立くらいで勝敗を争うことになる。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、勝ち抜きでは勝敗に果しがないから、おのおの一番勝負として、点数勝越しのほうのものが咲耶子の身を引きとるというやくそくを条件にかぞえてある。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔明の一短を挙げたついでに、蜀軍が遂に魏に勝って勝ち抜き得なかった敗因がどこにあったかを考えて見たい。",
              "citation": {
                "source": "三国志",
                "author": "篇外余録",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはこのたたかいを必ずかちぬきたいと考えるわけであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
