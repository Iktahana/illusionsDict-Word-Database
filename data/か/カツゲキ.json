    "definitions": [
      {
        "index": 1,
        "gloss": "action film",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この映画は手に汗握る活劇で、最後まで目が離せなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "久しぶりに痛快な活劇を見て、スカッとした気分になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、チャンバラの活劇に憧れて、よく真似をして遊んだものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その止まり方がまた実に突然で今までの活劇がまるで嘘であったように思われた。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかに、たとえば、飲んだくれの亭主が夜おそく帰って来て戸をたたくと女房のクサンチペがバルコンから壺の中の怪しい液体をぶっかけ、結局つかみ合いになるという活劇をもわずかな小道具と背景を使って映し出して見せた。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち眼の前に一つの争闘の活劇が起った。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくこの活劇は私に色々な事を聯想させたが、しかし自然の事実からは人間の都合のいいモラルは必然には出て来なかった。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "５７＝密室　敬四郎この大活劇にすっかり有頂天で悦にいる。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "57＝密室　敬四郎この大活劇にすっかり有頂天で悦にいる。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがせっかくのこのおもしろい場面をつまらぬこしらえものの活劇で打ちこわしてしまっているのは惜しいことである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど数年前の時代活劇から比べるとだいぶ進歩したものだと思われる点はいろいろある。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "拷問の後にほうり込まれた牢獄の中で眼前に迫る生死の境に臨んでいながらばかげた油虫の競走をやらせたりするのでも決してむだな插話でなくて、この活劇を生かす上においてきわめて重要な「俳諧」であると思われる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる名優の活劇でも、これに比べてはおそらく茶番のようなものである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで第三者たる観客はまさに起こらんとする活劇の不安なしかも好奇な期待に緊張しながら、交互にあちらを見たりこちらを見たりして、そうして自分も劇中の一員となってクライマックスへの歩みを運んで行くのである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長は周章てゝ起上つたが、怒氣滿面、けれど自己が醜態に怒る事も出來ず、ビール樽のやうな腹に手を當てゝ、物凄い眼に水夫共を睨み付けると、此時私の傍には鬚の長い、頭の禿た、如何にも古風らしい一個の英國人が立つて居つたが、此活劇を見るより、ぶるぶると身慄して『あゝ、あゝ、縁起でもない、南無阿彌陀佛！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "規律正しき軍艦の甲板、かゝる活劇の間でも决して其態度を亂す樣な事はない。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に朝日島紀念塔設立の顛末――あの異樣なる自動冐險車が、縱横無盡に、深山大澤の間を猛進したる其時の活劇。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "月界の活劇　目指す秋山の姿はいずこと、四辺を見廻したがまだ出発した形跡はない。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は何か、そんな危険な活劇物でも撮ろうって云うのですか――だが、それにしてもちっと可笑しいじゃありませんか。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまここで、この親友を怒らせ、戸障子をこわすような活劇を演じたら、これは私の家では無し、甚だ穏やかでない事になる。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この宏壮限りもなき活劇詩の主人公や誰。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人は初めより惟へらく、この日露両国を主人公とする大活劇は、旅順の陥落に第一幕を終り、波羅的艦隊の全滅に第二幕を終らむと。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひがけない活劇に、私は欄干に凭つてかたづを呑んだ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も亦のんびりとパイプの煙をふかしながら、映畫でも見るやうに樂しげに海の活劇を見下してゐた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、活劇の伴奏のつもりなのであろうか、如何にも気取ったポーズで首を振り足踏をしながら、此の烈しい執拗な闘争の間じゅう、ずっと軽快なマーチを吹き続けていた。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いがけない活劇に、私は欄干に凭ってかたずを呑んだ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼もまたのんびりとパイプの煙をふかしながら、映画でも見るように楽しげに海の活劇を見下していた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "観客のどよみも同じく空間を描き出す効果があるのみならず、その音の強弱緩急の波のうち方で土俵の上の活劇の進行の模様が相撲に不案内なわれわれにもよくわかるような気がする。",
              "citation": {
                "source": "相撲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもう一人は、全く見知らぬ無言役者、――すなわち今夜の大活劇に、最も重要な役目を演じた、私の友人の蝋色の胸像――なるほど実に驚異すべきまでに、その真を模写していた。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "一望開豁な荒野の中に、一方は自転車の上に、すっとその美しいフォームを立ててゆく若い美しい女性、一方はハンドルの上に低く身体をこごめて、これを追っかけてゆく、――何かしら意味のありそうな、好奇心をそそらせる一場の活劇場の光景であった。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "アヌンチヤタこの活劇を眺めたるが、遽に我に向ひていふやう。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等は亭に入りて、當※の女をして良酒を供せしめ、續けさまに數杯を傾けて、此自然の活劇を翫べり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "お夏さんは定子になって殺されようという、――まだもっとも、他に暗号も極めてあったんではありますがな、髪を洗って寝首を掻かせた、大時代な活劇でさ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
