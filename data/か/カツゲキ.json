        "examples": {
          "standard": [
            {
              "text": "デパートのバーゲン会場は、まるで活劇のような騒ぎだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "サッカーの試合で、応援席が一点物の活劇と化した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちの誕生日パーティーは、プレゼント開封で大活劇になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
