[
  {
    "uuid": "7fec4275-7b41-50fe-9d56-37049fd6036f",
    "entry": "赫々",
    "reading": {
      "primary": "かくかく",
      "alternatives": [
        "かっかく"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "brilliant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の赫々たる功績は、歴史書に深く刻まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その企業は創業以来、赫々たる発展を遂げ、業界のリーダーとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遠くに見える夕日が、赫々とあたりを照らしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして私は赫々とした炎天の下で、烈しく鋭い精神を私の裡に感じたのである。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "岬の端には煉瓦工場が、工場の庭には煉瓦干されて、煉瓦干されて赫々してゐたしかも工場は、音とてなかつた煉瓦工場に、腰をば据ゑて、私は暫く煙草を吹かした。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "木橋の、埃りは終日、沈黙し、ポストは終日｜赫々と、風車を付けた乳母車、いつも街上に停つてゐた。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その側に下女のおすめは、一かかえもあるほどな大きな七輪へ、赫々と炭をおこして、長い鉄串へ幾切もの粕漬の塩鮭を並べて居る、焼けて溶け落ちる塩鮭の油が炭火に焦げて、ぷんぷんと香ばしい匂をたてるのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時、太陽は雲間を洩れて赫々たる光を射出した。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "頓て雨が全く霽れると共に、今度は赫々たる太陽は、射る如く吾等の上を照して來た。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "其翌日は、漂流以來はじめて少し心が落付いて、例の雨水を飮み、沙魚の肉に舌皷打ちつゝ、島影は無きか、る日よりは餘程元氣もよく、赫々たる熱光の下、日出雄少年は私の顏を見詰めて『おや／＼、叔父さんは何時の間にか、黒奴になつてしまつてよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しも波浪に揉まれて、此方に廻りし其艦尾には、赫々たる日輪に照されて「日の出」の三｜字が鮮かに讀まれた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "形怪しき火取虫いと大きやかなるが、今ほど此室に翔り来て、赫々たる洋燈の周囲を、飛び廻り、飛び狂い、火にあくがれていたりしが、ぱっと羽たたき火屋の中へ逆さまに飛び入りつ、煽動に消える火とともに身を焦してぞ失せにけり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで無くってさえ、お通りがかりをお呼び申して、真個に不躾だ、と極りが悪うございましてね、赫々逆上ますほどなんですもの。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "のぼせて、頭ばっかり赫々と、するもんだで、小春さんのいい人で、色男がるくせに、頭髪さ、すべりと一分刈にしている処で、治兵衛坊主、坊主治兵衛だ、なあ、旦那。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「今度は赫々とほてるんだがね。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其国の徳衰え沢竭きて、内憂外患こも／″＼逼り、滅亡に垂とする世には、崩じて諡られざる帝のおわす例もあれど、明の祚は其の後｜猶二百五十年も続きて、此時太祖の盛徳偉業、炎々の威を揚げ、赫々の光を放ちて、天下万民を悦服せしめしばかりの後なれば、かゝる不祥の事は起るべくもあらぬ時代なり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして其の詰らぬ事にさへ全氣全念を以て打對はるゝ健全純善の氣の習は、やがて赫々たる功業徳澤を成さるゝ所以なのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日と違つて日は赫々と海、波、岸の草原を照射した。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そこが縁起じゃ、禁厭とも言うのじゃよ、金烏玉兎と聞くは――この赫々とした日輪の中には三脚の鴉が棲むと言うげな、日中の道を照す、老人が、暗い心の補助に、烏瓜の灯は天の与えと心得る。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "３旭日ののぼるごとく、揚げよ国威、天皇の大陸軍、風あり、軍旗燦たり、大陸の血河すでに、征戦、赫々の誉高し、忠勇曾つて、曾つて範あり。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛国家の心霊を鼓舞して、天下蒼生の為に、赫々たる功業を奏せしむるものもこの熱意なり。",
              "citation": {
                "source": "熱意",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "画に於ける仙崖、東圃、学に於ける南冥、益軒、業に於ける加藤司書、平野次郎、野村望東尼は尚｜赫々たる光輝を今日に残している。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "滴るばかりの緑の野に金光｜赫々として輝くファラオの武威は、各王の死後の住家である三角塔と、その功績を地表高く捧ぐる方光塔と、迷い入ったら最後、容易に出口を発見し得ぬという螺堂を生みました。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この兵力に加うるに当時｜赫々たる西郷の威望があるのだから、天下の耳目を驚かせたのは当然である。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上武威｜赫々たる信玄の遺臣として、その時代に畏敬されていたのであろう。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分もその会員である）の先祖たる菊池氏も亦、五百年間勤王｜一途の忠勤をつくした家柄で、山陽をして「翠楠必ずしも黄花に勝らず」と云わしめたが、活躍の舞台が、近畿でないから、楠公父子の赫々たる事蹟には及ばない。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は赫々たる未来ある有為の人物だったが、その後咽喉病に犯されたために夭死した。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "この雑多の仕事の中では、もちろんその大部分は、赫々たる成功を収めているのであったが、しかしまたその二三のものでは、全く避けがたい、不可能な失敗に終ったものもあった。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然街の角を曲ると、赫々たる光がぱっと眼に射し、私たちは、あの大きな場末の放縦の殿堂――悪魔ジン酒の宮殿――の一つの前に立っているのであった。",
              "citation": {
                "source": "群集の人",
                "author": "THE MAN OF THE CROWD",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には、げに、天の、地の、大海の、――また海と地と高き天とを支配した魔神の、赫々たる歴史がある。",
              "citation": {
                "source": "沈黙",
                "author": "――神話",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて今日あの谷に立ち入る旅の者が　赫々たる窓二つから目にするは狂いうごめく無数の大影、　外れ調子の旋律に乗りながら。",
              "citation": {
                "source": "ポオ異界詩集",
                "author": "エドガー・Ａ・ポオ　Edger A. Poe",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「豪儀だな、そいつあ、」とくるりと廻った、頭の法然天窓は竈の陰に赫々して、「よ、まあこっちへ来ねえ、松の鮨の兄哥、入れッてことよ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時朝鮮政府に大改革ありて、一時日本に亡命の客たりし朴泳孝氏らも大政に参与し、威権｜赫々たる時なりければ、日本よりも星亨、岡本柳之助氏ら、その聘に応じて朝廷の顧問となり、既にして更に西園寺侯爵もまた勅を帯びて渡韓したりき。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
