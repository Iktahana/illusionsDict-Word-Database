        "examples": {
          "standard": [
            {
              "text": "「博物館には、かつて酪農家が使っていた年季の入った撹乳器が展示されている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「電動の撹乳器を導入したことで、バター作りの重労働から解放された。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この古い撹乳器は、ハンドルを回すと中の攪拌翼が回転する仕組みだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "幻影全てが晴れ、撹乳器にかけたかのような乳白色の輝きになった時、我々は再度地上に目を向け、旅の終わりがほど遠からぬ事を知った。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
