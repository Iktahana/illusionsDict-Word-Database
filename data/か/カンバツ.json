        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "疫病は干ばつ、洪水、星の影響、噴火、または神の罰、によって始まると考えられた。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "かてて加えて、干ばつが長引き、予備の貯水池も容赦なく引水された。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            }
          ]
        }
