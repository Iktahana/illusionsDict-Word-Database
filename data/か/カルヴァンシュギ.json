        "examples": {
          "standard": [
            {
              "text": "プロテスタントの歴史を語る上で、カルヴァン主義の教義は非常に重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、カルヴァン主義の予定説について熱心に説明してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "スコットランドの長老派教会は、カルヴァン主義の影響を強く受けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ルター派とは異なり、カルヴァン主義は聖餐の解釈において特徴的な立場をとる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "資本主義の精神がＭ・ヴェーバーに於てのようにカルヴァン主義などであるなら、資本主義はプロテスタントの信仰から生じた所産にされて了うかも知れない。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
