      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "government secretariat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "文化庁長官官房著作権課が中心になってまとめたこの素案の段階で、著作隣接権の延長は、優先すべき課題からは落とされた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで教授は、極秘裡に白亜館官房を訪問して大統領に面会を求めた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日知事は県庁へ出ると、官房主事を喚んで訊いた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "折原知事と官房主事とに、こつそり内証で耳打ちをする。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてしばらく、また初めの時と同じような身体検査や何かでひまどって、昼頃になってようやく官房主事のところへ行って、そこで内務大臣からの即刻追放の命令を受けた。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は幾度も官房主事のところへ使いをやったが一向要領を得ない。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時頃になって、ようやく官房主事からの迎いが来た。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉村君はちょっと官房主事と挨拶したあとで、僕と話ししたいのだが許して貰えようかと尋ねた。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "苫米地の事件をはじめとして平野元農相の資格失墜問題、西尾官房長官の資格についての疑点等が党内の勢力争いとともに公表された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　翌二日に加藤を停車場二階の官房に訪ふと、きのふは要領を得なかつたから失敬したが、今しがたきまつて、現金が手に這入つたからとのことで、それを義雄は受け取つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしなべて官房とか連隊とか事務局とか、一口にいえば、あらゆる役人階級ほど怒りっぽいものはないからである。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもある九等官は、とある小さな局長に任命されると早速自分だけの部屋を仕切って、それを【官房】と名づけ、扉口には赤襟にモールつきの服を着せた案内係を置いて、来訪者のあるごとに、いちいち把手をとって扉をあけさせたものである。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその【官房】たるや、ありきたりの書物机が一脚、どうにか無理やりに置けるくらいのものであったとのことである。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は後に身を誤ったが、世話好きな豪傑肌の男だったと見え、よく友人の尻拭などをしてやったもので、或る時友人の一人が酔った余り乱暴を働いて警察に留置され、事が面倒になったので、山田は母校の先輩である当時警視庁の官房主事をしていた庄司氏を訪ねて、援助を乞うた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度も肝心の元署長で今は警視庁の官房主事をしている庄司氏は許可されなかったが、司法主任と、支倉の逮捕には最初から奔走した石子、渡辺両刑事とが喚問せられる事になったから、彼等をあくまで追求して、前後矛盾の答弁でもあったら、直ちに突ッ込んで局面を有利に転回せしめようと手ぐすね引いて待ち構えていた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又官房主事があらゆる書類を隠して偽証させ、罪なき者を無実に陥れたと云う事も之までにない事だ。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又官房主事がアラユル書類を隠して偽造、罪ない者を無実の罪に陥れたと云う前例もない。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄司氏を罵って姦謀（官房）主事と称えたなどはその一つの現われで、官憲も狂人としては扱わなかった所以である。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、帰りがけに、あなたは、各国人を包んだモウニング・コウトの長列が、手に手に、官房主事の発行した、大型封筒の面会許可証を、切符のように握って、クイリナアレ政庁の長廊下に、忍耐深く待っているのを見かけるでしょう。",
              "citation": {
                "source": "踊る地平線",
                "author": "長靴の春",
                "note": "青空文庫"
              }
            },
            {
              "text": "特高課の部長級が種々な口實を設けて、わたしを官房主事または總監に引き合はせようとしたことは幾度か知れないが、ある時は、官房主事が自ら來訪したことさへありました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お松は、駒井の不在中の官房をあずかること、その在舎中と変りはありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして官房研究所と北大とがそれを援けるという話になった。",
              "citation": {
                "source": "凍上の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「津村は、スマトラでどんなことをやっていたんだ」「官房長になって、大理石づくりの官邸で威張っていた……浴衣がけでソファに大あぐらをかいて、ひどい椰子酒をあおりながら、おれはここの王様だ。",
              "citation": {
                "source": "蝶の絵",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "土侯をおさえつけるのが司政長官で、司政長官をおさえつけるのが官房長だから、おれはさしずめキング・オブ・キングスというところさ……なんて、あられもない発揚状態なんだ。",
              "citation": {
                "source": "蝶の絵",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も内部にも東交と日交との区別はあるらしく、市当局が最後会見を申し込んだ時、日交代表だけはノコノコ出かけて行ったし、又同じくこの日交の幹部三人が、争議の真最中に独立に警視庁官房主事を訪問などしていて、意味の通じない談話を新聞に載せるなどしてはいるが、争議団大衆は極めて組織的であるように見受けられる。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "働く者が満足しているということこそ、私の関心事であります」　署名は読めなかったが、署名のそばに「Ｘ官房長」と印刷されていた。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンスの生きていたころ、まだ、ほんのあかんぼうだった人たちが、今はもう、かみの毛が雪のように白くなって、まごたちのおもりをしていました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、きょ年の夏、兵太郎君と川あそびにいって、川からあがったばかりの、ぴかぴか光るおたがいのはだかんぼうを、おいしげった夏草の上でぶつけあい、くるいあって、たがいに際限もなくわらいころげたことだった。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄金の舟に、黄金の水、はだかんぼうな赤鬼はその上を走り廻って居る。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所のわきのせまい部屋にあおむけにねかされて、枕もとに、さっき店でみたおやじさんがすわっていて、そのうしろにはあかんぼうをおぶったおかみさんが、立っていました。",
              "citation": {
                "source": "清造と沼",
                "author": "宮島資夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
