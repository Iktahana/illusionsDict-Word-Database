[
  {
    "uuid": "0b188d90-83f9-5417-b309-6952ecf512df",
    "entry": "官房",
    "reading": {
      "primary": "かんぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
