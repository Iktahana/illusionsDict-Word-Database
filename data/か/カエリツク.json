[
  {
    "uuid": "74b90033-1c17-5f47-adb0-a50be7d57298",
    "entry": "帰り着く",
    "reading": {
      "primary": "かえりつく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
        "動詞-自動詞"
      ],
