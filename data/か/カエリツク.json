    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to arrive home",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長旅の末、ようやく見慣れた我が家に帰り着いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "山道で迷い、暗くなる前に無事にキャンプ地へ帰り着けて安堵した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "深夜、残業を終えて電車に揺られ、ぐったりと自分の部屋に帰り着く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私はスルメをあきらめてお家に帰る途々、できるだけ、どっさり周囲の美しい雪景色を眺めて、眼玉の底だけでなく、胸の底にまで、純白の美しい景色を宿した気持でお家へ帰り着くなり、「お嫂さん、あたしの眼を見てよ、あたしの眼の底には、とっても美しい景色が一ぱい写っているのよ。",
              "citation": {
                "source": "雪の夜の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞穴へ帰り着くと夜が明けはなれました。",
              "citation": {
                "source": "人蔘の精",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へ帰り着くまでに再び火の玉にも盆燈籠にも出逢わなかったが、かれの着物は冷汗でしぼるようにぬれていた。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五日もかかって遡った急流｜激潭を、タッタ一日で走り下って、エサウシ山下の谷山別荘に帰り着くと、人知れずホットしいしい、ウイスキーを飲んで眠ったものだそうです。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝家は越前に帰り着くと、直ちに養子伊賀守勝豊に山路将監、木下半右衛門等を添えて長浜城を受取らしめた。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "……帰り着くまで降り出さなけあいいが……。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて自分の住む宿に帰り着く。",
              "citation": {
                "source": "妄想",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一町ばかりで堀川の館へ帰り着くというところで、足早に来る若侍に出逢った。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "千枝松はまだ胸が晴れないらしく、自分が知っている限りの軽蔑や呪詛のことばを並べ立てて、自分たちの家へ帰り着くまで、憎い、憎い、陶器師の疫病婆を罵りつづけていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿舎へ帰り着くころには日も暮れ切って、床の下にはこおろぎが寒そうに鳴いている。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車を利用する事で、安藤夫妻は、毎週土曜日の課業が済むと、一人は京都から、一人は東京から汽車に乗つて、静岡で落合ひ、日曜日一日を思ふ様楽しく過して月曜日の朝までにはそれぞれ学校へ帰り着くといふ寸法だ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとらはお島に御飯を食べさせると、脱いで傍に畳んであった羽織を自分に着たり、青柳に着せたりして、やがて其処を引揚げたが、町へ帰り着く頃には、もうすっかり日がくれて蛙の声が静な野中に聞え、人家には灯が点されていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は落ち着いた調子で「穴川さん、貴方は馬車で此の家へ帰り着くまで、有難いの、命の親だと私を拝まぬ許りで有ったのに、短銃を以てその謝意を表するのですか」穴川は余の顔を打ちながめて、「エ、エ、貴方ですか、大場医学士が貴方だとは云わぬ者だから」と言訳の様に云いつつも猶短銃を下げようとはせぬ。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこれから長い日数を海上に送らねば成らないことを思い、倫敦を発つ時にはまだ外套を欲しいくらいの五月初旬の陽気でも国に帰り着く頃の旅仕度も考えて行かねば成らないことを思い、そんな心づかいをするだけでも実に国の方の空の遠いことを思った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分もこの前伺った二三日前から少し弱っていたので、昨日は父の御供をして病院から帰りかける途中で歩かれなくなってしまった、尤も無理に押して出掛けたことではあったが、半分夢中で谷中の家に帰り着くことが出来たと書いてよこした。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は漸く故国に帰り着くことが出来たかのような心でもって、葉と葉の奥に日の映った庭の見える縁先へ行った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間内びっちり働いても、アパートに帰り着くのは八時、九時となる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "イクラ行ったって、おしまいにはキット日本へ帰り着くんだから」「ヘエ、誰か見た者がおりますかえ」「見なくたってわかっている。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に帰り着くと、彼の友達らはアウレリウスの様子が変わっているのに驚いた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "ラザルス",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはできるだけ、強い感動を家の人達に与えないようにして家へ帰り着くことが必要である。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の慣例として、新住職が村へ帰り着くところは寺の山門ではなくて、まず本陣の玄関だ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて家へ帰り着くと、彼にとっては長い、不思議な、甘い、そしてまどろみのように朦朧とした一日が訪れた。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも松山に帰り着くまでに表六句が出来ぬかであった。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………われ果して、家に帰り着くを得るならんか。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、駕籠を飛ばして道場へ帰り着くが早いか、まず、ソッとこのほうをうかがって、このようすならめったに起きる心配はない。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが向うの暗い四つ角を曲ってふっと消えた時、三沢は自分を顧みて「帰り着くまで持てば好いがな」と云った。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに屋敷へかえりつくや、うなじ迄も赤く染めている菊路の方へ、これも一面の紅葉を散らしている京弥をずいと押しやるようにすると、至って粋な言葉をぽつりとひとこと、愛撫のこもった揶揄と共に言いました。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋敷へかえりつくと、ゆうべの膝枕を楽しみでもするかのようにそのまま横になって、かろやかな鼾すらも立て初めました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "火星のボートが、火星へかえりつくのには、どんなに早く天空を飛んでいったにしろ、一週間や二週間はかかるであろう。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "くさい監禁室　潜水艦が、海底要塞にかえりつくと、太刀川は、大勢の衛兵たちにつれられて、臨時一号監禁室に放りこまれた。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
