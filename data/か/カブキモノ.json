        "examples": {
          "standard": [
            {
              "text": "江戸時代、派手な服装で街を闊歩した傾奇者は、しばしば粋な悪童と見なされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この小説は、傾奇者たちの生き様を描いた異色の時代劇だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その集団は、奇抜な髪型と派手な着物で、まさに傾奇者と呼ぶにふさわしい風貌だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "町奴の称が出来たのは、旗本奴が出来たからであつて、もとは、かぶきものと言うた。",
              "citation": {
                "source": "ごろつきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗本奴もかぶきもの・かぶき衆などいはれたのであつた。",
              "citation": {
                "source": "ごろつきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
