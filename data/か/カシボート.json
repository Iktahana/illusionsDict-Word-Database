        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "貸しボートの受付に『本日強風のため営業中止』の看板が出ていてガッカリした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「30分500円の貸しボートで、湖の真ん中まで漕ぎ出してみよう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "足漕ぎ式の貸しボートなら、カップルでも疲れずに景色を楽しめるね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "初めて貸しボートを漕いだんだけど、思っていたより真っ直ぐ進むのが難しかったよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "貸しボート屋やつてゐるかな？",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十三年ごろ、木更津の橋のたもとに、貸しボートと餌を売っている爺さんがいた。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてボートも」「貸しボート屋さんがある湖は、人がたくさんいるはずだから、だからそういうところではナナエが望んでいたような雰囲気は望めないわね」「夏の観光シーズンのまえだから、人のことはそんなに心配しなくてもいいのではないかしら。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手紙には、さっきのランチのかたちや、色をくわしくしるしたあとに、「両国橋のそばの、ミナトヤという貸しボート屋へ、いそげ。",
              "citation": {
                "source": "探偵少年",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしボートは、――彼はそれを繋いだろうか？",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしボートから水を真下に見おろすといくつかの非常にちがった色をもっているように見える。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしボートルレ少年が、ああして眠ってしまったすぐ前のことを種々と尋ねてみるが、何を聞いてもその時だけは爺さんはけろりとしている。",
              "citation": {
                "source": "奇巌城",
                "author": "アルセーヌ・ルパン",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしボートルレ少年は堅く決心して、毎日シャレル爺さんを訪れた。",
              "citation": {
                "source": "奇巌城",
                "author": "アルセーヌ・ルパン",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしボートルレが熱心に調べたところ、種々の事件の中に一つの繋がりがあることを見出した。",
              "citation": {
                "source": "奇巌城",
                "author": "アルセーヌ・ルパン",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしボートルレ君、我がアルセーヌ・ルパンは決してこの宝石に手をつけなかった。",
              "citation": {
                "source": "奇巌城",
                "author": "アルセーヌ・ルパン",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
