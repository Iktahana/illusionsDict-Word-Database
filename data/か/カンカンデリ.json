    "definitions": [
      {
        "index": 1,
        "gloss": "scorching heat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夏の真っ盛り、カンカン照り（かんかんでり）の太陽が容赦なく照りつける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うわー、外はカンカン照り（かんかんでり）だね。熱中症に気をつけよう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "カンカン照り（かんかんでり）の日差しの中、アスファルトがじりじりと熱を放っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "今日はカンカン照り（かんかんでり）だから、日陰を選んで散歩しよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「まだいいよ、君」「でも、今日夏帽子を買うから」「買うまでかぶっていたまえ、おかしいよ」「なアに、すぐそこで買うから」「足元を見られて高く売りつけられるよ」「なアに大丈夫だ」　で、日のカンカン照りつける町の通りを清三は帽子もかぶらずに歩いた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがやっぱり真昼間のカンカン照りの午後二時という刻限、私の目は日光にぎらぎらしていたと云っても真冬の小春日の事である。",
              "citation": {
                "source": "怪談",
                "author": "平山蘆江",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、彼は烈日の下にあつてカンカン照りつけられてゐたのだが、恰も、自分はクタクタに使ひ古された布片であるかのやうな感を抱き、広茫たる田園の一隅へ忽ちヘタヘタと崩れ落ちて、凋むかの如き残酷な無我を覚えたのであつた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "上高地から槍ガ岳の肩までの路にしても、カンカン照りに重い荷を負って行った時の印象の方が、秋の初め、時雨を番傘でよけて行った時のそれよりも、はるかに生々と記憶に残っている。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑いのはあながち横日にカンカン照り付けられた為ばかりではなかったらしい。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑い日がカンカン照りつけるので、止度なく汗が流れる、私は先に立ってグングン急いだ。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋らしい様子になって来て、ゆうべ等は月の光が射しているのに、雨が降る音がしたりして虫の音もしますが、庭をひるまカンカン照りつける日光には辟易です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも、それはカンカン照りの暑い夏の昼だった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽は高く、カンカン照りだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、六月末のカンカン照りだ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
