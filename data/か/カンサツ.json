    "definitions": [
      {
        "index": 1,
        "gloss": "inspection",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "不祥事の疑いがある部署に対し、本部の監察チームが立ち入り調査を行う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おい、監察が入るらしいぞ」と、署内には朝から緊張した空気が漂っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "警察内部の規律を正すため、抜き打ちの監察が定期的に実施される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "皇道を行きて入り、陛に登りて拝せざる等、不敬の事ありしかば、監察御史曾鳳韶これを劾せしが、帝曰く、至親問う勿れと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝は猶北方憂うるに足らずとして意を文治に専らにし、儒臣｜方孝孺等と周官の法度を討論して日を送る、此間に於て監察御史韓郁（韓郁｜或は康郁に作る）というもの時事を憂いて疏を上りぬ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "揚州の守将｜王礼と弟｜宗と、監察御史王彬を縛して門を開いて降る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "監察御史葉希賢、臣が名は賢、応賢たるべきこと疑無しと白す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年、監察御史、陳郡の袁は、しかし、供廻りの多勢なのを恃み、驛吏の言葉を斥けて、出發した。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年、監察御史、陳郡の袁は、しかし、供廻りの多勢なのを恃み、駅吏の言葉を斥けて、出発した。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その案内者が親しい同僚だけであればなんでもないが、しかしその中に学界の監察官のようなかたが一人でもいて来客の肩の後ろで厳粛な顔をしていられると自分の口は自然に膠着してしまって物が言えなくなる。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした監察官も日本の名誉のために必要かもしれない。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "継いで吏部戸部礼部兵部刑部工部の給事中、各道の監察御吏、及び九卿が、それぞれ曾の罪悪を上奏弾劾した。",
              "citation": {
                "source": "続黄梁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだ、もう一時間経っても確とした報知がないなら、僕はコリンス方面監察といっしょに現場へ急行しなければならないだろう。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　かくてその夜、駅長のブランド氏は、探偵長として鉄道会社に聘せられているコリンス方面監察と共にケニヨンへ向って出発した。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に、しかし、コリンス方面監察の報告書によると――それは現在記者の卓上に置かれてあるのだが――解明の可能性は決して思ったほど乏しいものではないようだ。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "――大目付は芙蓉の間詰、禄は三千石、相役四人ともに旗本ばかりで、時には老中の耳目となり、時にはまた、将軍家の耳目となり、大名旗本の行状素行にわたる事から、公儀お政治向き百般の事に目を光らす目付見張りの監察の役目でした。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "絞盤旋盤工（最低一八〇）承軸旋盤工（同…………）　所得は一ヵ月三百ルーブルから百五ルーブル仕上工（最低一六〇）組立工（最低一八〇）　所得一ヵ月三百五十ルーブル　その他鎖孔工、研工、製粉工、捲き手はおなじ割合で監督係、製図工、および監察員には少しばかりだが増俸がある。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陽の「尋特召之東邸、給三十口、准大監察」と書したのが是である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陽は「尋特召之東邸、給三十口、准大監察、将孥東徙、居丸山邸舎」と書してゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「母公」と云ふより見れば、病者は席順の「大監察、渡辺造酒丞、五十七」の母であらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "……眉が保寿官、眼が監察官、鼻梁が審弁官、口が出納官、そうして耳が採聴官。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は日独防共協定や保護監察法案で、自分たち転向被告はますます手も足も出なくなつたと、顔を見るなり訴へはじめた。",
              "citation": {
                "source": "現代詩",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまく行けば副知事を、さもなければ、どこか重要な省の監察官あたりを狙っていたのである。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを出ると、かねがね副知事の椅子を、それが駄目なら監察官の口をとしきりに奔走していた省の役所へ赴いた。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう表情は役所へ上司が監察にやって来る時、官吏連の顔によく現われるもので、どうやら最初の恐怖も消え去り、大体のところはお眼鏡にかなったとみえ、長官がしまいに軽口を叩いてニコニコしながら、何か一言二言いわれたりすると、ぐるりを取りまいている側近の役人連はそれに答えて二倍も笑う。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "然ニ佐々監察ニも申置度事も在之候得バ、御ひま御座候得バ、御出可被下候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年八月二十三日　岡内俊太郎あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩下と重野の両人、それから幕府の外国方から鵜飼弥市、監察方から斎藤金吾と云う人が立会い、いよ／＼書面を取換して事のすっかり収まったのが、文久三年の十一月の朔日か二日頃であった。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "目付に目をつけるがために目付を置き、監察を監察するがために監察を命じ、結局なんの取締りにもならずしていたずらに人の気配を損じたるの奇談は、古今にその例はなはだ多し。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "守は文治を、尉は兵事を掌り、監はその監察をする。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、監察御史や起居舎人知制誥を経て、とんとん拍子に中書門下平章事になりましたが、讒を受けてあぶなく殺される所をやっと助かって、驩州へ流される事になりました。",
              "citation": {
                "source": "黄粱夢",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
