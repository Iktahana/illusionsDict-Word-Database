          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "図書館のカウンターでは、本の貸出と返却の手続きが同時に行える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "銀行は地域経済の活性化を目的として、中小企業向けの貸出を強化している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "イベントで使用する機材の貸出リストを作成し、担当部署に提出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "それに貸出の方なる事業者から徴すべき担保物の調査も届いて居ない。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "されども慧き畔柳は事の密なるを策の上と為して叨に利の為に誘はれず、始よりその藩士なる鰐淵｜直行の一手に貸出すのみにて、他は皆彼の名義を用ゐて、直接の取引を為さざれば、同業者は彼の那辺にか金穴あるを疑はざれども、その果して誰なるやを知る者絶えてあらざるなりき。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝大のは偶然館外に貸出してあった一冊が震火を免かれて今残っている。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば銀行が沢山の鉄工業者に多大の貸出しをしている場合、自分の利潤から云っても、それ等のもの相互間に競争のあることは望ましいことではない。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、蔵書家には門外不出を標榜している人が多く、自宅へ来て読むというならば読ませてやるが、貸出しはいっさい断わるというのである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、蔵書家には門外不出を標榜している人が多く、自宅へ来て読むというならば読ませて遣るが、貸出しは一切断るというのである。",
              "citation": {
                "source": "読書雑感",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "本は殆ど買へなかつたから、町の圖書館の館外貸出を利用したり、志村に借りたり、東京の友達に云つて送つてもらつたりしてゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして人のいい夫を其方退けにして、傭い人を見張ったり、金の貸出方や取立方に抜目のない頭脳を働かしていたが、青柳の顔が見えると、どんな時でも彼女の様子がそわそわしずにはいなかった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "この後者のために、新聞の朝刊三行案内欄に「手軽金融　あづま商会」の広告を出してゐるが、これは貸出の回収不能なんかで手間取るよりもと、簡単に「調査料」詐取の方法を採つてゐる。",
              "citation": {
                "source": "日本三文オペラ",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは朝貸出した金が夕方には利子をくはへて元の巣へ飛戻つて来る。",
              "citation": {
                "source": "釜ヶ崎",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、共済基金の涸渇から、貸出規定の改正などの点になると、彼は明らかに反動的な立場に身を置いていた。",
              "citation": {
                "source": "立枯れ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "社長は一寸額に皺をよせて考えたようだったが、別に穿鑿もせずに、その担保貸出を取計らってくれた。",
              "citation": {
                "source": "道化役",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も社員だというので特別に、抽籤期はまだ遠いにも拘らず、額面高の貸出をしてくれた。",
              "citation": {
                "source": "道化役",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はて、そんなものはここにはございませんが、もし特に御入用でございましたら、早速博物館へテレビジョン電話をかけまして、旦那さまのお好みのものを貸出してもらうことにいたしましょう」　僕はそれを聞いてびっくりした。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷里に居る正太の知人で、叔父の請判があらば、貸出しそうなものが有る。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "紐育市中の騒々しくいそがしい生活の中で、私の記憶している事は町のところどころにカーネギイの図書館があって、市民の証明書があればすぐ誰にも貸出しをしてくれる事です。",
              "citation": {
                "source": "亜米利加の思出",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "図書館の書物が貸出しをして無事に返って来るようになるまでには相応の年月を要する事でしょう。",
              "citation": {
                "source": "亜米利加の思出",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる地金取引は、もし銀行が、流通している紙幣の絶対量を顧慮せずに、私がかくもしばしば挙げた指標すなわち本位たる地金の価格によって、その貸出及び紙幣発行を左右するならば、その数は極めて少いであろう。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って吾々は、市場利子率が、銀行が一律に貸出す率たる五％を超過する時には、割引課は貸付請求者によって包囲され、反対に市場率が一時的であるといえども五％である時には、この課の事務員には仕事がないことを見出すのである。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "来年は停年で、三十万円近くの退職金の積立があるが、会社の規定で、貸出しは三万円が限度になっている。",
              "citation": {
                "source": "一の倉沢",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペルシア王の官吏及び私的所有者がその土地を農民に貸出す仕方は、最もよく勤労を鼓舞するが如きものではない。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし我国ほどの大きさの肥沃な土地が不意に合併され、それが小区域に分って売られまたは小農場として貸出されるならば、事情は一変し、一般人民の状態は不意に著しく改善されるであろう。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の暗黒の混迷を完成させたのは司書たちで、貸出前の検査と当該書籍の貸出簿からみて、これらの注記はすべて第二状態の私自身が行ったものに相違ないと請け合ってくれた。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは最初から空室だったが――長期間住もうとするような借り主が一人もいなかったからだ――ポーランド人の大家はそれを貸出すことに警戒心を募らせていた。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫イラズが無駄だったことに半狂乱になったドンブロウスキは、ここを貸出そうという考えをきっぱりと捨て、一週間のうちに昔からの店子ともどもウォルナット街にある見窄らしいがもうちょっと新しい家に引っ越してしまった。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーロッパの買占人、紐育ウォール・ストリートでは、アスファルトとギャソリンくさい空気の中で著名なる経済学者ベブソン氏を不安ならしめつつ、未曾有の貸出と買占が行われている。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは雲の峯がみんな崩れて牛みたいな形になり、そらのあちこちに星がぴかぴかしだしたのです。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「悪人を生け置いてたまるか、悪人は生け置かんぞ」　そして、また引っくり返って手足をびくびくと動かしだした。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何んとも、何人も云はないやうですが、」「さうかね、空耳だつたらうか、」　省三はまた箸を動かしだしたが彼はもう落ち着いたゆとりのある澄んだ心ではゐられなかつた。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の方はそれを見て叫びながら縛られている手足を動かしだした。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
