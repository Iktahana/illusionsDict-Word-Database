[
  {
    "uuid": "4fc2cefd-3768-56a5-9ba6-33ebebec8eea",
    "entry": "川尻",
    "reading": {
      "primary": "かわじり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
