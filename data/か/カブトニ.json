    "definitions": [
      {
        "index": 1,
        "gloss": "simmered fish head (oft. sea bream)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "居酒屋のおすすめメニューに「真鯛のかぶと煮」があったので、迷わず注文した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ひゃあ、このかぶと煮、目の周りのゼラチン質がぷるぷるで最高！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "甘辛いタレがしっかり染みたかぶと煮を、白いご飯に乗せて豪快に頬張る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "浜作や鶴の家などでも、あら煮とか鯛のかぶと煮などというものはよく売れるらしいが、鰹の中落ちを箸でセセリ食うおもしろさと味にはしょせんかなうまい。",
              "citation": {
                "source": "舌のすさび",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎧かぶとに身を固めた。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かぶとにつけてある電灯のスイッチを入れるんだ」　博士の声が、超音波を使った水中電話器にのって、聞こえてくる。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼく、大将の着た赤い鎧がほしいなあ、かぶとに竜のとまった。",
              "citation": {
                "source": "海からきた卵",
                "author": "塚原健二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄かぶとについている、まるいガラスののぞきまどの、すぐ前を、いろいろなさかなが、すいすいと泳いでいきます。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きなサメなどが、ヌーッとあらわれて、鉄かぶとに、ぶつかってくることもあります。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「卑怯っ」　追ッかけた途端に、秦明のかぶとにカチンと矢が刎ね返り、朱い房が切れて飛んだ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "燦々と、その旌旗や甲かぶとに旭光がきらめいて、群集は眼もくらむような心地に打たれた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
