        "examples": {
          "standard": [
            {
              "text": "「エメラルドグリーンの水をたたえた火山湖が、霧の向こうにうっすらと見えてきたよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "蔵王のお釜のような火山湖は、強い酸性を示していて魚が住めないほど特殊な水質なんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「昔の噴火口に雨水が溜まってできた火山湖は、カルデラ湖とはまた違った趣があるね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「カルデラの中に広がる大きな火山湖の周りを、天気のいい日にゆっくり一周ドライブしてみようか。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "三つ續いた火山湖のうちの大尻沼がそれであつた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つ続いた火山湖のうちの大尻沼がそれであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろにも湖水を前にせざるものあらざる草の早くうら枯る　同じ時裏磐悌の火山湖地帯にも遊んだが、その時の作。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "琵琶湖もそこまで來ると、若狹、越前の國境に連なつてゐる山脈の餘脈が直ちに湖岸に迫つてゐて、廣い水は其等の斷崖によつて圍れてゐるので、中禪寺湖や葦の湖などの火山湖と少しも異らない感じを與へてゐる。",
              "citation": {
                "source": "湖光島影",
                "author": "琵琶湖めぐり",
                "note": "青空文庫"
              }
            },
            {
              "text": "火山湖のつめたい油がかれの脊髄の川に沿うて流れる。",
              "citation": {
                "source": "希臘十字",
                "author": "高祖保",
                "note": "青空文庫"
              }
            },
            {
              "text": "山梨県西山梨郡国里村国玉）　九州の南の端、薩摩の開聞岳の麓には、池田という美しい火山湖があります。",
              "citation": {
                "source": "日本の伝説",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
