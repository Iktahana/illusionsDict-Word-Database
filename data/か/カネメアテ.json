        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はどうも金目当てで近づいてくる感じがするんだよね。信用できないな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あのドラマの登場人物、金目当てで行動するから見ててイライラするわ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女が結婚を決めたのは、相手の財力、つまり金目当てだったんじゃないかって噂されてる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "結婚するに際して持参金目当てとか、家門のため、子孫繁栄のため、生活能率増進のため、放蕩防止のために結婚しようとするのは浅はかな考えであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その男は自分よりかなり年上の女と金目当てで結婚した。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "穿つて云へば、賞金目当ての苦心がありありと文字の間に滲み出てゐます。",
              "citation": {
                "source": "青年の矜りと嗜み",
                "author": "――力としての文化　第四話",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時はちょうど欧州大戦後であったので成金目当てにこんな値段を吹いたものであろう。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "召使いたちの中には、見るに見かねて意見めいたことを言う者もありましたが、そんなことがあれば、すぐさまお払い箱で、残っている者共は、ただもう法外に高い給金目当ての、さもしい連中ばかりでした。",
              "citation": {
                "source": "鏡地獄",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お金目当てじゃありません。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "金目当てじゃないから医者に診せたのです。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
