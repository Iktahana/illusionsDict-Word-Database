        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "試験に落ちてしまい、クラスメイトに合わせる顔がなく肩身が狭い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "近所の人から迷惑行為について注意され、すっかり肩身が狭くなってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社の業績が悪く、他部署の人と話すときも肩身が狭い思いをする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "妻の活躍が目覚ましく、夫である私は正直、少し肩身が狭い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」　と若山は花屋の奥に端近く端座して、憂苦に窶れ、愁然として肩身が狭い。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊やがかすがいで、まずそれッきりで治まったがね、私ゃその時、ああ、執念深い人だと思って、ぞッとして、それからというものは、何だか重荷を背負ったようで、今でも肩身が狭いようなの。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "よ、貢さん、人に後指さされちゃあ、お前さんの肩身が狭いだろうと思ったし、その上また点を打たれる身になるとね。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった、半月かそこら、お世話になった前川さんに対して、あんなご恩になることだって、随分肩身が狭いじゃないの。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんもお前に背広も着せない母親だと言はれたら、どんなに肩身が狭いか判りませんよ。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ以来、こちとらは胸の前に掲げて拍手した手のやり場に困って実に肩身が狭い。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも身から出た錆というような始末だから一層兄夫婦に対して肩身が狭い。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "林之助は自分の不人情が急に恥かしくなって、肩身が狭いような心持ちで病人の枕もとにそっと坐ると、お絹はもう正体がなかった。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとうさんがいらっしゃればお互いにこんないやな目にはあわないんだろうけれども（こういう場合葉子はおくびにも母の名は出さなかった）親のないわたしたちは肩身が狭いわね。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「伊達より少ないと、肩身が狭いぞ」「第一評判が悪くなる」と、人々がいっている時、「吉良上野介様あ！",
              "citation": {
                "source": "吉良上野の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分の妹や母親のことでは、どの位阿部や伴に肩身が狭いかわからなかった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "清吉は好い男で、若い江戸っ子でしたが、可哀そうに刺青がないから、どうも肩身が狭い。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "清三はまたいっそう快活になった友だちに対してなんだか肩身が狭いような気がした。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理もないことで、参加しなければ、成功したとき肩身が狭いし、成功しなければ口が干あがるんだから、彼奴等としても実は向背に迷ふんだ。",
              "citation": {
                "source": "籠の小鳥",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "小野さんは肩身が狭い。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは東京に育つたものの甚だつまらぬ「感じ」であらうが、その「田舎」は、どういふ場合にでも、肩身が狭いわけではなく、「言葉」といふ厄介な市場以外では、「都会」なるものと何等その価値に於いて相違があるわけではない。",
              "citation": {
                "source": "「語られる言葉」の美",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、お父さんがほんとに病気とすれば、喜ばれない見舞人は、招かれざる客と同様、ちと肩身が狭いね。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人中へ出るのが嫌いだと言って断わろうとしたのを、殿様が御主人役で晴れの催しであるこの流鏑馬へ、一日もお面をお出しなさらなくては、殿様へ対しても失礼であろうし、自分たちも肩身が狭いから、ぜひぜひおいであそばせと言って、左右の女たちがせがみました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "人からあなたの所のご二男は、大学を卒業なすって何をしてお出ですかと聞かれた時に返事ができないようじゃ、おれも肩身が狭いから」　父は渋面をつくった。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "重役の令嬢と平社員の結婚だから、何うしても婿側の肩身が狭い。",
              "citation": {
                "source": "女婿",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となく肩身が狭い。",
              "citation": {
                "source": "女婿",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「就職にも兼ねているからね」「纒まりが早くて宜いよ」「その代り少し肩身が狭い」「何あに。",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私一人肩身が狭いわ」「お友達が拵えて戴くようなら、お母さんだってお前に引けを取らせたくありませんからね。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕達の肩身を狭くしようってんだ」「実際肩身が狭い。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓造が月々学資を出して貰う丈けでも、おれは好い加減肩身が狭いんだ」「兄さんは何うせ詰まらないことに使ってしまいますよ。",
              "citation": {
                "source": "村の成功者",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "外人客や新橋停車場への送り迎え、そのほか臨時用として貸馬車も相当繁昌、築地の川西商会が元祖で、後には築地馬車商会となったが、最初はとかく口の悪い東京ッ子、あれは貸馬車だぜとお里をあばくので、乗る人もなんとなく肩身が狭い。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
