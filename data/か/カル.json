[
  {
    "uuid": "6fcb1a8b-cf9a-5d9e-8512-cea8d0e10009",
    "entry": "刈る",
    "reading": {
      "primary": "かる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to cut (grass, hair, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "梅雨が明けると、裏庭の雑草があっという間に伸びてしまうので、早めに刈る必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「来月は成人式だから、襟足をすっきり刈って整えてもらおうかな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "黄金色に輝く田んぼで、コンバインがリズムよく稲を刈っていく光景は秋の風物詩だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "放牧地の羊たちが、芝生を綺麗に刈り取るかのように草を食んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "冬ざれや北の家陰の韮を刈る　薄ら日和の冬の日に、家の北庭の陰に生えてる、侘しい韮を刈るのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪を切る意味の cheirein は「切る」「刈る」に通じる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼう／＼となった髪を刈ることが出来なかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあみんなよっく火にあだれ、おらまた草刈るがらな。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻を刈ると題したが、紡ぎ織り縫ひもせぬ、これは浴衣がけの縁臺話。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのバリカンはもう五六年前から、ひどく調子がわるく、ときどき、ぐわツと大きく噛みついて、とることもどうすることもできなくなつてしまふやうなしまつでしたので、二人は、家で髪を刈ることをあまり好んではゐませんでした。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早くから百姓達は、麦を刈るだけの力のあるものは、みんなひきつれて、野に出ていつてしまふ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "其代り又｜手苛い領主や敵将に出遇った日には、それこそ草を刈るが如くに人民は生命も取られれば財産も召上げられて終う。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一杯飲んでいる内には、木賊刈るという歌のまま、研かれ出づる秋の夜の月となるであろうと、その気で篠ノ井で汽車を乗替えた。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、お宅もやはり人の頭を刈る職人でっしゃろ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "波の音にもうち消されないで、その音が四辺に響き返る、さく／＼、……刈らずにゐられないで刈る、鎌が触りさへすれば火が出さうに動いてゆく。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "向日葵を刈る間も主へかよふくちつけ。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その薄刈る人もあり、また負ひて降り来るもあり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "西は追分だとか、今の小諸出て見りゃだとか、小諸出て見りゃ浅間の嶽にけさも三筋のけむり立つさまが来ぬ夜は雲場の草で刈る人もなしひとり寝る浅間山から鬼や尻出して鎌でかっ切るような屁を垂れた　あはは。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その薄刈る人もあり。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "刈る一方から実を落した。",
              "citation": {
                "source": "蕎麦餅",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それを刈るのアまだ早いのですよ」と、千代子は聽き付けて勝手の方から飛び出して來た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の末の晩稻を刈る頃から、夕日の射し加減で筑波山は形容し難い美しい紫を染め出す。",
              "citation": {
                "source": "寫生斷片",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "利鎌もて萱刈る如く。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "をしね刈る裾曲の田居ゆ。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌筑波嶺に後來む人も吾如くこゝだ欲る可き串もちひこれ三月のはじめ下總神崎の雙生の岡より筑波山を望みて詠ずる歌并反歌十握稻ふさ刈る鎌の。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれは手や指を使うというよりもむしろ頭を使うためらしく思われた、芝を刈るというような、機械的な、虚心でできる動作ならばおそらくそんな事はあるまいと思われた。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝を刈る鋏と言えば一通りしかないものと簡単に思い込んでいた私は少し当惑した。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど芝を刈るにはどうしても専用のものがぐあいがいいという事は自分にも明白に了解された。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ芝を刈り始めるのか、刈る時には手伝わしてくれとか、今夜はもう刈らないかとか、そんな事をのべつにしゃべっていた。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が自分で芝を刈るという事がよほど珍しいおもしろい事ででもあるように。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば私は自分で芝を刈る事によって、植木屋の賃銀を奪っているのではないかという問題に出会った。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝を刈るのがいいといっても文明を刈り取るがいいという証拠にも何もならない事は明らかであった。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文明の葉は刈るわけにも焼くわけにも行かない。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "感傷の塔萩原朔太郎塔は額にきづかる、螢をもつて窓をあかるくし、塔はするどく青らみ空に立つ、ああ我が塔をきづくの額は血みどろ、肉やぶれいたみふんすゐすれども、なやましき感傷の塔は光に向ひて伸長す、いやさらに伸長し、その愁も青空にとがりたり。",
              "citation": {
                "source": "感傷の塔",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
