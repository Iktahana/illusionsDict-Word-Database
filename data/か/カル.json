  {
    "uuid": "0bce4c2f-af13-574d-ba30-78e24ccf7c12",
    "entry": "駆る",
    "reading": {
      "primary": "かる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to spur on",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "若き日の彼は、未知の世界への強い好奇心に駆られて、あてもなく旅に出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "締切が明日に迫り、焦燥感に駆られながらキーボードを叩き続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あいつを驚かせてやろう」といういたずら心に駆られ、彼はこっそり部屋に忍び込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "正義感に駆られた彼は、危険を顧みず燃え盛る建物の中に飛び込んでいった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "つまり窓の眺めというものには、元来人をそんな思いに駆るあるものがあるんじゃないか。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲を駆る　支那の言葉づかひには、また我が邦のと異りたるおもしろみあるにや。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "はらふといふにては駆るといふより弱くしておもしろからぬなり。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔者カーライル、弊衣を着、破帽をいたゞいて、一日馬車を竜動街頭に駆る。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るがまに焼酎の泡しぶきひたぶる歎くそが街よ、立てつづく尖屋根血ばみ疲れて雲赤くもだゆる日、悩ましく馬車駆るやから霊のありかをぞうち惑ひ窓ふりあふぐ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰ぞ、また、けたたましくも、朱の息引き切るるごと、狂気なす自動車駆るは。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに、裸馬を駆る技術に至っては遙かに陵を凌いでいるので、李陵はただ射だけを教えることにした。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後トムソンの家族にハリーが加はり郊外へ馬車を駆る。",
              "citation": {
                "source": "サフランの花",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "御存知には違ひなからうがスカウツ・ペースといふのは一哩を十分強で駆るハイキングの術語である。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は世を恨むる余その執念の駆るままに、人の生ける肉を啖ひ、以つて聊か逆境に暴されたりし枯膓を癒さんが為に、三悪道に捨身の大願を発起せる心中には、百の呵責も、千の苦艱も固より期したるを、なかなかかかる寛なる信用と、かかる温き憐愍とを被らんは、羝羊の乳を得んとよりも彼は望まざりしなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ずや私達の「悦びの歌」は空を駆る鳥も海に眠る人魚の群をも驚かすことであらう。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎はこの不安の念を駆るために、二人の談柄をふたたびほじくり出してみたい気がした。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三は空虚な心のやり場をどこに求めようかと考えるまでもなく、いつも行きつけの同じ大川ぞいの小夜子の家へタキシイを駆るのであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "信じられないかも知れないが、いくら「アドルフ・マンジュウ」だって、「法律による自分の妻」とともにこうして自動車を駆ることも、たまにはあるのである。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "タキシがないので大学通りのホテルまで古風な馬車を駆る。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていつも何かのイデアルがあなたを創作に駆るの機となるのではないかと思われます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちを徳へと駆る原動の力は、私たちの心の内に働く、罪や、刑罰や、羞恥や、後悔や、すべて道徳的の苦痛の感じ――それは享楽と観照のできない直接な意識――です。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "）小説家たらんとするものは自動車学校を卒業せざる運転手の自動車を街頭に駆るがごとし。",
              "citation": {
                "source": "小説作法十則",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の諸公を暗殺せず、敢てペンを駆る所以は――原稿料の為と言ふこと勿れ。",
              "citation": {
                "source": "文部省の仮名遣改定案について",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、いうところが「死体駆る橇」とともに、「｜冥路の国」探検の大眼目になっている。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "死体が、橇を駆るように招かれてゆく途中、あの奇怪な無電をうったのではないか※　しかし、その考えはその場かぎり消え、彼は、別のことを訊きだした。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その葬儀に列なったものは、宮廷合唱長のアントニオ・サリエリー、友人ジュスマイエルほか四人に過ぎなかったが、柩が墓地門に着いた頃は、それ等の人も一人去り二人去りして、残ったのは、僅かに柩車を駆る馭者一人のみ。",
              "citation": {
                "source": "「黒死館殺人事件」著者之序",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半島の中央の小山は公園であり、半島の幾つもの岬も公園であり、それらの公園をつないで、海岸から小山へかけて、自動車を走らせるのもよく、馬車を駆るのもよい。",
              "citation": {
                "source": "北京・青島・村落",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "情緒はそれに伴う不安と焦躁とからわれわれを限りなき盲目的な運動にまで駆るに反して、感激はそれに随う安静と平穏とからわれわれを光に照らされた、限りある従って完全な活動にまで赴かせる。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "心理的個性に目覚めてなにより第一に自我を他と異なったものとして感じまた主張する時代、自己の周囲に漂う雰囲気を真の自己と思い誤る時代、それらのことよりもいっそう根本的には虚栄心と功名心とが内向的な活動を忘れさせて限りを知らぬ外向的な運動に駆る時代が私の中学時代の後の二年間を占めていた。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　東京の路の様で無く、目まぐるしい程自動車や其他雑多な車の行交ふ巴里の大道を巧に縫つて自動車を駆る滋野君の手腕は感服すべき物であつた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一尺の地歩を占むるにも幾百の勇士の血に代へて猶難しとした当年の戦跡に、かく軽快に車を駆ることは、まことに相済まぬ気がするのであつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "志雄山の平軍既に破れ、義仲行家疾馳して平軍に迫る、無人の境を行くが如く、安宅の渡を渉りて篠原を襲ひ、遂に大に征北軍を撃破し、勇奮突破、南に進むこと、猛虎の群羊を駆るが如く、将に長駆して京師に入らむとす。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "感傷の塔萩原朔太郎塔は額にきづかる、螢をもつて窓をあかるくし、塔はするどく青らみ空に立つ、ああ我が塔をきづくの額は血みどろ、肉やぶれいたみふんすゐすれども、なやましき感傷の塔は光に向ひて伸長す、いやさらに伸長し、その愁も青空にとがりたり。",
              "citation": {
                "source": "感傷の塔",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水部の線宮沢賢治きみがおもかげうかべんと夜を仰げばこのまひる蝋紙に描きし北上の水線青くひかるなれ竜や棲みしと伝へたるこのこもりぬの辺を来れば夜ぞらに泛ぶ水線の火花となりて青々と散る",
              "citation": {
                "source": "水部の線",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to drive at high speed (e.g. a car)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
