    "definitions": [
      {
        "index": 1,
        "gloss": "kakina (green leafy vegetable of the genus Brassica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「今日のかき菜、すごく柔らかくて甘いから、サッとお浸しにしましょうか。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "直売所で新鮮なかき菜を見つけたので、油揚げと一緒に甘辛く炒めて晩酌の肴にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スーパーの野菜売り場に鮮やかな緑のかき菜が並ぶのを見ると、春の訪れを感じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "鈴虫はふり出てなく声のうつくしければ、物ねたみされて齢ひの短かきなめりと点頭かる。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "笛あふげば高き松が枝に琴かけ鳴らす、をゆびに紅をさしぐみて、ふくめる琴をかきならす、ああ　かき鳴らすひとづま琴の音にもつれぶき、いみじき笛は天にあり。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかきなされば好いでしょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方をおかきなさるの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "画かきなら画架に向く。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日絵をおかきなさいますでしょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "）そこでおかきなさったのでございますわ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざと大袈裟に頭をかきながら、夫は鞠を追つた。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一兵卒の死の原因にしても、長途の行軍から持病の脚気が昂進したという程度で、それ以上、その原因を深く追求しないで、主人公の恐ろしい苦しみをかきながら、作者は、ある諦めとか運命とかいうものを見つけ出そうとしている。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後都へ出て洋画の展覧会を見たりする時には、どうかすると中学時代の事を思い出し、同時にあの絵の具の特有な臭気と当時かきながら口癖に鼻声で歌ったある唱歌とを思い出した、そうして再びこの享楽にふけりたいという欲望がかなり強く刺激されるのであった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は自画像をかきながらいろんな事を考えてみた。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自画像をかきながら思うようにかけない苦しまぎれに、ずいぶんいろんな事を考えたものである。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かきながら楊枝を縦に口の中へ立てたのをかむ癖があった。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして梨を作り、墨絵をかきなぐり、めりやすを着用し、午の貝をぶうぶうと鳴らし、茣蓙に寝ね、芙蓉の散るを賞し、そうして水前寺の吸い物をすするのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくがおこしに行く前に、ポチは離れに来て雨戸をがりがり引っかきながら、悲しそうにほえたので、おとうさんもおかあさんも目をさましていたのだとおかあさんもいった。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼をさましてみると、母は背面向きになってはいるが、自分のすぐ側に、安らかな鼾を小さくかきながら寝入っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "崩せるだけ崩してみてやれという気がむらむらと起ってきて、彼はいきなり胡坐をかきながら。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬくらいなら俺は画をかきながら死ぬ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むぐらは土の中で冷汗をたらして頭をかきながら、　「さあまことに恐れ入りますが私は明るい所の仕事はいっこう無調法でございます」と言いました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、どれだけ眠ったか、斧をふるって小郷を殺している夢に驚いて、ぐっしょり汗をかきながら眼をさました時は、もうひる近かった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、女の著物なんです」　小沢は頭こそかかなかったが、頭をかきながら――と言った気持で言った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、ちょっと……」　こんどは本当に頭をかきながら、「――たすけると思って、貸していただけませんか」　道子は急に立ち上って、茶の間を出て行った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が大きな図体に汗をビッショリかきながらまるで番頭の様に立働いている容子をみると、ぼくは、そんなにまでぼくが彼の宿に移ることをよろこんで、親切にしてくれるのに、ぼくを試しているなどと疑ったことが何か済まないことをしたように思った。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、わたしの話すことを、絵におかきなさい」と、月は、はじめてたずねてきた晩に、言いました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "新太郎ちやんが息を切らして、ベソをかきながら戻つて来ると、惣兵衛ちやんはまたいつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　新太郎ちやんは、ベソをかきながら立つてゐるだけで、謝罪りもしなかつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　良寛さんは頭をかきながら、草の中を探しまはつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "君文章をかきたいならどん／＼御かきなさい。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに博士は、ひどい汗かきなのに、今夜は、ハンカチを忘れて出て来たので、いっそう惨めなことになりました。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
