        "examples": {
          "standard": [
            {
              "text": "重力波の検出には、巨大なレーザー干渉計が用いられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この干渉計を使えば、表面のわずかな凹凸もナノメートル単位で測定できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "光の波の性質を利用した干渉計は、精密計測の分野で欠かせない装置だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "天文台では、複数の電波干渉計を組み合わせて遠方の天体を観測している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この隧道の一端で、水面による干渉縞の実験や、マイケルソン干渉計の実験が行われた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
