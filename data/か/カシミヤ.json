        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「わあ、このコート、カシミヤ100パーセントなの？ ちょっと触らせてもらってもいい？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "おばあちゃんから譲り受けたカシミヤのストールは、何十年経っても色褪せない上品さと温かさがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「カシミヤのセーターは洗濯機で洗えないから、シーズンが終わるたびに丁寧に手洗いしているんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "胸も腰もつくろわない少女じみたカシミヤの制服を着て、有合せの男下駄をカランカラン引きずって、客へ茶を運ぶ。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白のカシミヤの手袋を用い、厳寒の候には、白い絹のショオルをぐるぐる頸に巻きつけました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カシミヤの白手袋を、再び用いました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カシミヤの白手袋が破れて、新しいのを買おうとしても、カシミヤのは、仲々無いので、しまいには、生地は、なんであっても白手袋でさえあればという意味で、軍手になりました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の五人の印度女の内で一段｜際立って見えるカシミヤ代表の秘書の夫人は細くすんなりとした体に桃色絹のインド服を頭や腕や腰にはめた黄金造りのバンドで締めつけ、同じ色絹のべールを頭から背へかけて居た。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国ではイエーツが一番好きで、其の次ぎにはシェリー、キーツが好きです」　カシミヤ夫人は景子が期待して居たように同じ東洋人を懐かしいとも言わない。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その室の閾をまたいだとき、私は自分と同じくらいの背の高さで、自分がそのとき着ていたもののように最新流行型に仕立てた白いカシミヤのモーニング・フロックを着た、一人の青年の姿に気がついた。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代紫の紬地の着物に、カシミヤの袴を裾みじかにはいて、その袴は以前葉子が発明した例の尾錠どめになっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹はと見ると、まだ十五か十六だろう、青味がかった棒縞のお召にカシミヤの袴を穿いた姿が、質素な周囲と反映してあざやかに美しかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の女は直ぐウラスマルへ斯う呟いたのである――「お約束のカシミヤブーケは之だけしか上げられませんよ。",
              "citation": {
                "source": "アリア人の孤独",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "所で、ウラスマルはあの野暮な、何の取り柄もない体を飾る唯一のものとして、カシミヤブーケを選んだとは何たる気の毒な分別だらう。",
              "citation": {
                "source": "アリア人の孤独",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、突然、私の鼻を打つたものは、若葉の匂ひから明確に分離してゐる、あのカシミヤブーケの高い香りであつた。",
              "citation": {
                "source": "アリア人の孤独",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その母親が生前、儀式の時に限り、好んで身へつけたのがカシミヤブーケであつた。",
              "citation": {
                "source": "アリア人の孤独",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "天が彼女に、ふだんは焦茶いろの細かい襞をとつた婦人服を身に著け、復活祭と自分の命名日には赤いカシミヤのショールを纒ふやうに運命づけたのは、大きなあやまりであつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹はと見ると、まだ十五か十六だらう、青味がかつた棒縞のお召にカシミヤの袴を穿いた姿が、質素な周囲と反映してあざやかに美しかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間のねうちは着物ではないと云って、小学校の四、五年ごろ菫色のカシミヤの袴の色のさめたのを、仕立て直して、襞のひろい方へもと上の方だった狭い褪せたあとの出たのを穿かされたのも覚えている。",
              "citation": {
                "source": "親子一体の教育法",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私はカシミヤの上衣に、春頃新調の冬ズボンをはいて、モオニングの上衣だけを、着換への和服と一緒に古いスウトケースに詰めた。",
              "citation": {
                "source": "町の踊り場",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といつて、例の冬ズボンにカシミヤの上衣を着て外へ出ると、通りつけの道を急いだ。",
              "citation": {
                "source": "町の踊り場",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いストッキングが少くなり、カシミヤやセルの袴の下から肉づきのよい二三寸の脛をのぞかせて行く職業婦人が多くなった。",
              "citation": {
                "source": "階段",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は玉羅紗とかアルパカだの、カシミヤだのの、いゝウール地が澤山あつたものだが、この頃は手に取つてみると、ぞつとするやうな寒い手ざはりのウール地ばかりであつた。",
              "citation": {
                "source": "玄關の手帖",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "セルでも、昔は柔かい薄地のカシミヤと云うのがありましたが、あれは着心地がよかったものです。",
              "citation": {
                "source": "着物雑考",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、カシミヤは大変高価だったので、清貧楽愁の私の家では、私に紺絣ばかりを着せてくれました。",
              "citation": {
                "source": "着物雑考",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺色のカシミヤの手袋をはめて、白い大きな皮のえり巻をして行ったんでした。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の襟の白かつた如く、彼の洋袴の裾が奇麗に折り返されてゐた如く、其下から見える彼の靴足袋が模樣入のカシミヤであつた如く、彼の頭は華奢な世間向きであつた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻き納めぬ手紙は右の手からだらりと垂れて、清三様……孤堂とかいた端が青いカシミヤの机掛の上に波を打って二三段に畳まれている。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "がらりと障子を明けて、赤い鼻緒の上草履に、カシミヤの靴足袋を無理に突き込んだ時、下女が来る。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると忰は親譲りの背広をだぶだぶに着て、カシミヤの靴足袋だけに、大なる通をきめている。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "白っぽい竪縞の銘仙の羽織、紫紺のカシミヤの袴、足駄を穿いた娘が曾て此梅の下に立って、一輪の花を摘んで黒い庇髪の鬢に插した。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれは三十トアーズほど下にある泉から水を汲んで駆けあがって行くと、ロング・ウッドの正面の入口から赤いカラーとカフスのついた緑色の上着を着てカシミヤ織の白いズボンを穿いた小づくりの人が片手を後へまわして悠然と出て来た。",
              "citation": {
                "source": "フランス伯Ｎ・Ｂ",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
