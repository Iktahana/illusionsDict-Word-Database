        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「先代の急な隠れにより、当主の座を継ぐことになりました。何分若輩者ですが……」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "名君として慕われた王の隠れを悼み、国中の人々が喪に服した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「まさか、あの方がこれほど早くお隠れになるとは。信じられません」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
