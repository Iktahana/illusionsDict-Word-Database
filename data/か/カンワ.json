    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Qing Mandarin (standard variety of Chinese spoken by official classes during the Qing dynasty)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "が、出来るだけ悠然と北京官話の返事をした。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし元来｜長沙の言葉は北京官話に通じている耳にも決して容易にはわからないらしい。",
              "citation": {
                "source": "湖南の扇",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに近年版の広東話もしくは官話の漢訳聖書には、「接吻」ではなくて、「親嘴」としてある。",
              "citation": {
                "source": "接吻",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「断つて置くが、僕は北京官話が少し出来るといふ廉で雇はれたので、督軍の数よりも四分五裂になつてゐる各省の方言にはまつたく通じない。",
              "citation": {
                "source": "南京六月祭",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り官話は達者だそうだ。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「忘八蛋」　後ろの方で秀才が官話を用いて罵る声が聞えた。",
              "citation": {
                "source": "阿Ｑ正伝",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "北京官話と苦力の用語とはちがうがあの本有益の由です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そやけど、あかんわ」　小さい方の三郎は悲しい顔もせずに、簡単に諦らめていた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへつるしたら鳴くやろ思たけどあかんわ」籠をもって店の中へはいる。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「がしょう、がしょう、と思うて、おれも八人斬ったが、天下国家とやら、このおれには、とんと夢で踏んだ屁のようなもんじゃ、匂いもせん、音もせん、スウともピイともこかんわい。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも私は嘘をつくことはこの上なく下手で、（もっとも絶対に嘘をつかんわけではなかったが）すぐに顔の表情によって相手に嘘であることを看破されてしまうことを自分でよく意識していた。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつは若い癖して、いやに気が永くていかんわい。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "茂兵衛　もう、なんぼ嘆いても取り返しがつかんわ。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉は一寸彼の顔を見ると俯向いて、「あかんわ。",
              "citation": {
                "source": "悲しめる顔",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつ今の間にどうにか禦いで置かなきゃいかんわい……それにはロシア語が一番に必要だ。",
              "citation": {
                "source": "予が半生の懺悔",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とかせんといかんわ。",
              "citation": {
                "source": "罠を跳び越える女",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この間も、選名術の先生に私のことを見て貰うた序に聞いてやつたら、福島福造といふ名と四十四といふ年を言うただけで、先生は直きに、『この人はあかんわい、放蕩者で、其の放蕩は一生止まん。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小剣",
                "note": "青空文庫"
              }
            },
            {
              "text": "「強うならな、あかんわい。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいつ、作らんちう譯にもいかんわいな、小前のもんが弱りよるよつて。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んぼえらさうにしてもあかんわい。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほえから元氣出さないかんわいおもて、持つていたかんてきに火一杯いこして、鍋に魚入れてグツ／＼たきながら、火燗の熱いやつをやつてたんや。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角持って来なすったが、これは死亡診断を書く訳にいかんわい。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚※々々してゐたら埓があかんわ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせられましたか」「いかんわい。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "常連どもは大よろこびで、「この碁席はノンビリしてまんなア」「碁はコセコセしたらあかんわ」　コセコセしとらんわけである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の隅でできたシチョウが左の隅の壁にぶつかってオダブツと定まってから、「ウーム、やっぱりシチョウか」「もうちょっと早う分らなあかんわ」　なぞとやってる。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨメは山の人には来てくれないから、お前はどうしても町に住まねばいかんわい」　約束をむすんで、山を降りた。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "神伝魚心流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こういう山の寝床はおれには向かんわい」とリップは考えた。",
              "citation": {
                "source": "リップ・ヴァン・ウィンクル",
                "author": "ディードリッヒ・ニッカボッカーの遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「夕食後はいかんわい。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十二　愚妖",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　小秀『新見さん、あなた、まだ帰つちやいかんわ、私はまだすつくり話をして居らないんですよ』　然し栄一は拗ねたやうに帰ると云ひ張る。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
