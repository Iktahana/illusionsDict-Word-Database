[
  {
    "uuid": "e638bc31-6f18-5559-a72c-949b4a4d60d5",
    "entry": "官話",
    "reading": {
      "primary": "かんわ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
