[
  {
    "uuid": "698cb6a0-a15a-574d-a289-6bf24e6bb008",
    "entry": "貸し切り",
    "reading": {
      "primary": "かしきり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
