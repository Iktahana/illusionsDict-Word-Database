    },
    "definitions": [
      {
        "index": 1,
        "gloss": "emotional",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「そんなに感情的にならないで。まずは落ち着いて、事実関係を整理しましょう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "議論が熱を帯びるにつれ、彼は次第に言葉を荒らげ、感情的な批判を繰り返すようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「もう！ どうしてそんなに感情的な言い方しかできないの？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "理性では分かっていても、どうしても感情的な納得がいかず、彼女は首を縦に振らなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "とまれ、必要以上に真摯だ、つまり、感情的に真摯だといふことが云へるのではありますまいか。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡはＢの百倍の理性を持つてゐても、ＡはまたＢの百五倍の我執を持つてゐれば、ＡはＢより「所謂感情的」である）。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に‥‥」と、感情的な高岡軍曹は躍氣となつて中根を賞讃した。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇敢で、単純で、感情的な重藤は、自分の扱っている兵卒の要求と、本能を直感的に見抜く鋭敏な才能を持っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かがここに立って見ていればやはりあんなふうに消えてゆくのであろう」という感動なのであったが、消えてゆく男の姿はそんなにも感情的であった。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの場合劇中人物のあらゆる事件│葛藤は観客自身の利害と感情的にはとにかく事実的になんの交渉もないのであるから、涙の中から顔を出して来るような将来への不安も心配も何もないのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし感情的でない泣き方もいろいろあるのであって、その一特例としては、疲れたときにあくびをすると涙が出る。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは感情的にさうだと云ふよりも寧ろ生理的にさうなのだらう。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――刃物、縊死、鉄道往生、その他いろいろ自殺の方法を、このあまりに感情的だった動物は考え出した。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち言語の字義が抽象する概念のみが重要であつて、言葉の人格とも言ふべき感情的の要素――音律や、拍節や、氣分や、色調や、――が閑却されて居る。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがつて自由詩は、本質的に主觀的、感情的、象徴的、音樂的である。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに温熱の感の所在は、それ自ら感情（意志を含めて）である故に、すべて主観的態度と言われるものは、必然に感情的態度を意味している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち「自我を離れる」という意味は、感情的な態度を排して、理智的な冷静の態度を取ると言う意味である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対に「自我に執する」とは、感情的な態度を取ることを意味している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに主観的なるものは、必然に皆感情的である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば前の例において、西行の歌やユーゴーの小説やが、外界の自然や、社会を題材としたものであるにかかわらず、それの批判が、いつも主観的と評するのは、表現の態度が感情的で、作家の情緒や道徳感やで、世界を情味ぶかく見ているからである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽は主観芸術の典型であり、純一に感情的な表現であるけれども、智慧のすぐれた観照なしには、その最も単純な小唄すら作り得ない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにレアリズムの客観派では、こうした感情的態度が排斥される。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって後者の良心は、客観の明徹を期し、真実を確実にすることに存するので、彼等が主観主義者の感情的態度を排するのは、この「真実」を重んずる認識的良心によるのである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども「感情的な意味」と「知性的な意味」とは、たしかにその意味に於ける、感じの色合や気分がちがっている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ等の中、最も純粋に感情的で、かつ実践的であるものは、言うまでもなく「愛」である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者、即ち「詩を作らない詩人」たちは、純粋に主観的、感情的であるけれども、これを観照する客観性の智慧がない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに音楽やバレーの如きは、近代に於て益々栄えたのみならず、古代中世のものに比して、却って著るしく感情的になり、浪漫的、幻想的に傾向して来た。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　のみならず近代の短篇詩は、浪漫派を始めとして、著るしく皆感情的で、昔の叙事詩等のものに比し、却ってその点で特色している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち文芸復興期以来に於ける、理智偏重の啓蒙思潮が、近代初頭に於て反動され、人心の中に深く圧迫された感情が、一時に洋々として堤を切った為、此処に十九世紀浪漫主義の運動となり、古典韻文の生ぬるい叙事詩等が、非主観的として排斥され、非感情的として疎外されてしまったのである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本質上には、俳句も他の一般の詩と同じく、純粋に主観的のものであり、したがってまた感情的のものである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち前に他の章で述べたように、欧洲に於ける詩の歴史は、実に抒情詩と叙事詩との対立であり、詩情に於ける「情緒的なもの」と「権力感情的なもの」との、不断に交流する二部曲である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに情緒的なものは――浪漫派でも象徴派でも――必然に自由主義の精神に立脚するし、権力感情的な貴族主義のものは――古典派でも高蹈派でも――凡て必ず形式主義に傾向している故に、欧洲の詩に於ける主観派と客観派との対立は、それ自ら抒情詩と叙事詩の対立に外ならない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのあまりに独逸的な、権力感情的なニイチェが、何故に自国で読まれず、逆に南欧の外国で読まれたのだろうか。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来、言語に於ける感情的な表出は、主として語勢の強弱、はずみ、音調等のものによるのであって、アクセントと平仄とが、その主なる要素になっている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
