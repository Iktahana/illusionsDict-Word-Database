[
  {
    "uuid": "a25b5178-b7eb-538b-ab5a-fcab450eff05",
    "entry": "感情的",
    "reading": {
      "primary": "かんじょうてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
