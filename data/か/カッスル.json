    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be thirsty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長距離マラソンの後半、ランナーたちは激しく喉が渇する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "知識に渇する若者たちは、図書館の閉館間際まで本を読み耽っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "砂浜に打ち上げられた魚が、命の水を求めて渇するように口をパクパクさせている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あー、喉が渇する！ 冷たい麦茶、一気に飲み干したい気分だよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "固定観念が条件反射的にあるうちはまだよいが無条件反射とまでなるや芸術は涸渇する。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれども連日雨に渇する東海道の農民にとりては、この予報は非常の福音たるに相違なかるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾後、餓うるときは鉄丸を喰い、渇するときは銅汁を飲んで、岩窟の中に封じられたまま、贖罪の期の充ちるのを待たねばならなかった。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "好きな煙草とコツプ酒に渇することはなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に前後不覚に渇する者能くこれを買ふべし、その渇の癒るに及びては、玉漿なりとして喜び吃せしものは、素と下水の上澄に過ぎざるを悟りて、痛恨、痛悔すといへども、彼は約の如く下水の倍量をばその鮮血に搾りその活肉に割きて以て返さざるべからず。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "父母に乞うて出家す、この僧渇する時鉢を空中に擲てば自然に蜜もて満ち、衆人共に飲み足ると。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに不起の病に罹って、最早余命いくばくもないのを知りつつも少しも紊れないで、余り余裕のない懐ろから百何十円を支払って大辞典を買うというは知識に渇する心持の尋常でなかった事が想像される。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『都の花』はあたかも世間が清新の読物に渇する時に生れたので、忽ち当時の雑誌のレコードを破って、美くしい花やかな気持の好い表紙が新らしい気分を漲らして若い読書家の心を誘った。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "一雨あつたら、人よりも草木がよろこぶだらう、田植の出来ない地方、田植しても枯渇する地方のみじめさ、気の毒さ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして若い時から中年期、成熟期から晩年とその想像力の描き出す形は少し宛違つて来てはゐるが最後迄涸渇することを知らなかつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "渇する者は飲を為し易く、飢へある者は食を為し易し、近来の傾向は歴史的也故に又回顧的也常感的也。",
              "citation": {
                "source": "凡神的唯心的傾向に就て",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは炎暑の時節いかに渇する時と雖、氷を入れた淡水の外冷いものは一切口にしない。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "塵埃に塗れた、草や、木が、風雨を恋うるように、生活に疲れた人々は、清新な生命の泉に渇するのであります。",
              "citation": {
                "source": "『小さな草と太陽』序",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶えず／＼壮観と、静謐に渇する彼は、かの執念の姉妹には見棄てられ、やさしさ籠めて愚痴を呟き、巧者にも花咲く自然に血の出る額を彼は与へるのであつた。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドリスが端倪すべからず、涸渇することのない生活の喜びを持っているのが、こんな時にも発揮せられる。",
              "citation": {
                "source": "世界漫遊",
                "author": "ダウィット　Jacob Julius David",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば洋酒の客はみなこちらへ来るから、あの店の財源はたちまち涸渇する。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こりゃ本当に漠々たる広原に渇死せんとす水に渇する生きたる餓鬼　だと思ったです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "活動に先んじて池水涸渇するのが通常であるけれども、突然爆發して池水を氾濫せしめたこともある。",
              "citation": {
                "source": "火山の話",
                "author": "今村明恒",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一口の湯が、兵馬の五臓六腑までしみ渡って、渇する者に水とか湯とかいう本文通り、一口の湯が全身心に反応しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴慕の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "シューベルトは歌劇、交響曲、弥撒、室内楽、歌曲、その他あらゆる形式の作曲をし、かつてその天才の泉の涸渇する気色も見せなかった。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、筆を執らずには居られない程思想が滾々と流れ出るので、いくら書いても涸渇する事があろうなどとは思いも及ばなかったのです。",
              "citation": {
                "source": "金色の死",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "容易に涸渇する筈がないと信じて居た私の思想は、此処に至って忽ち行き詰まって了いました。",
              "citation": {
                "source": "金色の死",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気位の高い作家のフィリックス氏は宮廷もどきグループを作り、東洋の超絶語り部同然となり、取り巻きを夢中にさせ、皆の目を丸くさせて、想像力たるや決して枯渇することがない。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
