        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今年の夏は、例年よりかなり暑い日が続いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの映画、予告編で見たよりもかなり面白かったよ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この問題の解決には、かなり時間がかかりそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、かなり物静かな性格だけど、芯は強いんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うわー、このケーキ、かなり大きいね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "數年前に此地に大火があつたさうであるが、成程火災の傳播には可也都合よく出來てゐる。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか宮の裏へ拔けると、可也廣い草原に高く聳えた松林があつて、其處にさつきの女學生が隊を立てゝ集つて居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の可也に不規則な平面的分布が透視法といふ原理に統一されて、其處に美しい幾何學的の整合を示して居る。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れと云つて特に指すもののない爲に一見單調なやうに見えるが、其の中に可也複雜な、しかし柔かな變化は含まれて居る。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝｜須らく汝の自負に傲慢なれ、不遜なれ、大水の声をあげて汝みづからの為に讃美し、謳歌して可也。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽の多様は是非なし、ピアノを用ふることも風琴を用ふることも、我劇の古色を傷くる限りは出来ぬ相談なるが故に、我邦の楽にて推し通すは可也、然れども願くは、楽と動との関係を最少し緩るくして、演者の活溌なる動作を見ることを得たきものなり。",
              "citation": {
                "source": "劇詩の前途如何",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫でも全寮で可也名物男に近かつた久米や自分がやつて居るので、喝采するものも可なりあつたが、狂言その物はマルで出鱈目であつた。",
              "citation": {
                "source": "学生時代の久米正雄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "『櫻は遠く眺めても可也。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "記するも可也、記せざるも可也。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "余曰く、害を爲すものは殺しても可也。",
              "citation": {
                "source": "猫征伐",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　大雪山の第一夜　層雲峡は石狩川の有する一大偉観なるが、その鬼神の楼閣と思わるる巌峰は、大雪山の腰なれば、大雪山の有する一大偉観なりといいても可也。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "千駄木の奥の此の私の家から番町までゞは、可也遠いのであるが、出てからもう彼此一｜時間も経つから、今頃は父と母とに右と左から笑顔を見せられて、私が此頃計画しつゝある画室の事など話して居るであらう。",
              "citation": {
                "source": "背負揚",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "可也、そっちがその了簡ならこっちもそのツモリで最う一度対手になろうといいたい処だが、一度の戦争は東洋問題を解決するため止むを得ないとしても、二度の戦争は残念ながら日本の国力が許さない。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "露子は彼から感染されて居た病気がこの頃可也進んで行った。",
              "citation": {
                "source": "淡雪",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五人の間で頻繁に流通した言葉が可也あった。",
              "citation": {
                "source": "四五ニズム述懐",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "可也やったつもりだったが、どうしても出なかったのだった。",
              "citation": {
                "source": "キド効果",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "雄二には可也の幅の石段で、姉の手に縋つて下へ降りて行つたが、下駄の下に砂利の粒が滑るのが心細かつた。",
              "citation": {
                "source": "潮干狩",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のところは他の特許事務所よりも可也たかいのです。",
              "citation": {
                "source": "名士訪問記",
                "author": "――佐野昌一氏訪問記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等ノ中ニハ可也信用ノ置カレルノモアリ、又可也怪シイモノモアルガ、此點ニ就テハ一切私見ヲ加ヘルコトナシニ、其儘ヲ採録シタ。",
              "citation": {
                "source": "寺田先生と僕",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の内儀は既う四十位の、亡夫は道庁で可也な役を勤めた人といふだけに、品のある、気の確乎した、言葉に西国の訛りのある人であつた。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が余程以前から此村にゐる様な気持で、先刻逢つて酒を強ひられた許りの村の有志――その中には清子の父なる老村長もゐた――の顔も、可也古くからの親みがある様に覚えた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が餘程｜以前から此村にゐる樣な氣持で、先刻逢つて酒を強ひられた許りの村の有志――その中には清子の父なる老村長もゐた――の顏も、可也古くからの親しみがある樣に覺えた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の内儀は既う四十位の、亡夫は道廳で可也な役を勤めた人といふだけに、品のある、氣の確乎した、言葉に西國の訛りのある人であつた。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "青柳と云うその男は、その町の開業医として可也に顔が売れていたが、或私立学校を卒業したというその弟をも、お島はちょいちょい見かけて知っていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四　お島はもう大概水をくれて了ったのであったが、家へ入ってからの母親との紛紜が気煩さに、矢張大きな如露をさげて、其方こっち植木の根にそそいだり、可也の距離から来る煤煙に汚れた常磐木の枝葉を払いなどしていたが、目が時々｜入染んで来る涙に曇った。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五　或日の午後におとらが迎いに来たとき、父親も丁度家に居合せて、ここから二三町先にある持地で、三四人の若い者を指図して、可也大きな赤松を一株、或得意先へ持運ぶべく根拵えをしていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで島ちゃんの籍をぬいて了おうと、無事に収めようと、すべて己の自由になるんだよ」　威嚇の辞と誘惑の手から脱れて、絶望と憤怒に男をいら立せながら、旧の道へ駈出すまでに、お島は可也悶※き争った。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十一　奉公人などに酷だというので、植源いこうか茨脊負うか、という語と共に、界隈では古くから名前の響いたその植源は、お島の生家などとは違って、可也派手な暮しをしていたが、今は有名な喧し屋の女隠居も年取ったので、家風はいくらか弛んでいた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔ゆがみつゝ月は出で〕宮沢賢治ゆがみつゝ月は出でうすぐもは淡くにほへり汽車のおとはかなく恋ごゝろ風のふくらしペンのさやうしなはれ山の稜白くひかれり汽車の音はるけくなみだゆゑ松いとくろしかれ草はさやぎてわが手帳たゞほのかなり",
              "citation": {
                "source": "〔ゆがみつゝ月は出で〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今、その世界を聊かなりとも解明したいのであるが、当抵手に負へさうもないことであるから、仮りに、さういふ世界に恋著した宮沢賢治が、もし芸術論を書いたとしたら、述べたでもあらう所の事を、かにかくにノート風に、左に書付けてみたいと思ふ。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
