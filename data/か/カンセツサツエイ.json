        "examples": {
          "standard": [
            {
              "text": "健康診断の胸部エックス線検査では、効率を重視して間接撮影が行われることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「間接撮影の結果、再検査が必要になりましたので、次は直接撮影で詳しく調べましょう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつての集団検診では、フィルム代を節約できる間接撮影が主流だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "胃のバリウム検査において、間接撮影で得られた画像を専門医がダブルチェックする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "やぼな前掛けちょいとしめて、間接撮影のお嬢さん」とか、私たちの教室生活がそのまま歌われているのだった。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "その患者さんをどうにか満足のゆくように診療してあげ、終わると、ああ、午後になると押しよせてくる集団間接撮影の数百人の団体！",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
