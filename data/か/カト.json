  {
    "uuid": "a60bb846-aaf4-54b2-bc8c-0b474307bf63",
    "entry": "カト",
    "reading": {
      "primary": "カト",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あら、あなたの膝の上で丸くなっているカト、可愛いわね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "毎朝、カトが窓辺で鳥を眺めているのを見るのが日課なんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "うちのカトは、よくソファの裏に隠れて寝ているのよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ほら、あそこにいるカト、毛並みがふわふわで触りたくなっちゃう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ジョバンニのうしろには、いつから乗ってゐたのか、せいの高い、黒いかつぎをしたカトリック風の尼さんが、まん円な緑の瞳を、じっとまっすぐに落して、まだ何かことばか声かが、そっちから伝はって来るのを、虔んで聞いてゐるといふやうに見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザネリはカトウにつかまった。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく彼がミュンヘンの小学で受けたローマカトリックの教義と家庭におけるユダヤ教の教義との相対的な矛盾――因襲的な独断と独断の背馳が彼の幼い心にどのような反応を起させたか、これも本人に聞いてみたい問題である。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラカトア火山の爆破の時に飛ばされた塵は、世界中の各所に異常な夕陽の色を現わし、あるいは深夜の空に泛ぶ銀白色の雲を生じ、あるいはビショップ環と称する光環を太陽の周囲に生じたりした。",
              "citation": {
                "source": "塵埃と光",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）もしも人びとが、死とか、來世とか、永遠などのカトリック的認識の上に立つて「悲歌」を理解しようとするごとき誤を犯すならば、完全にそれらの結論から遠ざかつてしまふでせう、そして、根本的にそれらが理解できなくなるやうなことにもなるでありませう。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ鉄砲でもアメリカトーキーのピストルの音とは少しわけがちがう。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニのうしろには、いつから乗っていたのか、せいの高い、黒いかつぎをしたカトリック風の尼さんが、まん円な緑の瞳を、じっとまっすぐに落して、まだ何かことばか声かが、そっちから伝わって来るのを、虔んで聞いているというように見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後の兵舎のほうから、誰やら金槌で釘を打つ音が、幽かに、トカトントンと聞えました。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし、あなたに、誤解されてやしないかと思って、あなたに一こと言いたくって、それできょうね、思い切って」　その時、実際ちかくの小屋から、トカトントンという釘打つ音が聞えたのです。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "トカトントン、トントントカトン、とさかんに打ちます。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのトカトントンの幻聴は、虚無をさえ打ちこわしてしまうのです。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "へとへとになるまで続けると、何か脱皮に似た爽やかさが感ぜられ、これだと思ったとたんに、やはりあのトカトントンが聞えるのです。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのトカトントンの音は、虚無の情熱をさえ打ち倒します。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、闇屋になって一万円もうけた時のことを考えたら、すぐトカトントンが聞えて来ました、　教えて下さい。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお最後にもう一言つけ加えさせていただくなら、私はこの手紙を半分も書かぬうちに、もう、トカトントンが、さかんに聞えて来ていたのです。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、トカトントンだけは、ウソでないようです。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニのうしろには、いつから乗っていたのか、せいの高い、黒いかつぎをしたカトリックふうの尼さんが、まんまるな緑の瞳を、じっとまっすぐに落として、まだ何かことばか声かが、そっちから伝わって来るのを、虔んで聞いているというように見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザネリはカトウにつかまつた。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジヨバンニのうしろには、いつから乘つてゐたのか、せいの高い、黒いかつぎをしたカトリツク風の尼さんが、まん圓な緑の瞳を、ぢつとまつすぐに落して、まだ何かことばか聲かが、そつちから傳はつて來るのを愼しんで聞いてゐるといふやうに見えました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」紳士四「えゝ、何せまだ子供ですから、それにそちらはたぶんカトリックの信者でいらっしゃいますから。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」山猫博士、「あゝ、カトリックですか。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も祖父がきついカトリックでしたがね。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもいかんね、カトリックは。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うとカトウモセイとかカワヒガシシゲルなんて御丁寧な電報をよこす奴があったりしてね……」　とだんだん言葉つきが書生丸出しになる。",
              "citation": {
                "source": "怪青年モセイ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが、大概のアメリカトーキーだと、おそらく、このアルベール君は三町四方に響くような大声で「ささやく」ことであろう。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもアメリカトーキーだとここでなんとか一つ取っておきのせりふを言わせて、そうしてアメリカ語のわかる観客だけをどっと笑わせないと気がすまないであろう。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二等甲板の船艙のつるつる光る白い壁に黒いかつぎのカトリックの尼さんが緑の円い瞳をそらに投げて竹の編棒をつかってゐる。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "kat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
