[
  {
    "uuid": "a90f5188-bbd7-5d5d-a03d-95dfc9f36099",
    "entry": "考えれば考えるほど",
    "reading": {
      "primary": "かんがえればかんがえるほど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
