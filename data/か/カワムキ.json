        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "料理の準備で、ジャガイモの皮むきを手伝った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "りんごの皮むきは、均等に薄く剥くのが意外と難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しく購入した皮むき器は、切れ味が抜群だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その野菜は、皮むき不要でそのまま調理できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "死体に近づくと、彼女達は斬られて縮少した切り口に、あわてて、その皮むきの饅頭を押しあてた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏、共産少年少女の野営地を訪問すると、赤い旗が翻る愉快な日かげで、男の子女の子とりまぜの炊事当番が、ジャガ薯の皮むきをやっている光景によくぶつかる。",
              "citation": {
                "source": "砂遊場からの同志",
                "author": "――ソヴェト同盟の共学について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬉しい心持ちで、あっちこっち見まわしながらそこをぬけると、大きい松の木の下に家があって、裏で、赤い襟飾をつけたピオニェール少年少女が数人笑ったり喋ったりしながらジャガイモの皮むきをやっている。",
              "citation": {
                "source": "ソヴェトのピオニェールはなにして遊ぶか",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下室の炊事場では、薯の皮むきからよごれた皿洗いから、みんな機械だ。",
              "citation": {
                "source": "ソヴェト労働者の解放された生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角、ある兇漢が男の方と格闘の上、枕許にあった皮むき庖丁で刺殺し、子供を連れて逃げ様とする女を後から殺した。",
              "citation": {
                "source": "琥珀のパイプ",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "托児所の庭でアグーシャは馬鈴薯の皮むきをやっていた。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "りんごの皮むきさあさりんごの皮むきだきれずに長くつながつてするするむけばいいんだよ。",
              "citation": {
                "source": "歌時計",
                "author": "童謠集",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあさりんごの皮むきだ銀のナイフはよく切れる手を氣をつけてむくんだよ。",
              "citation": {
                "source": "歌時計",
                "author": "童謠集",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかでも、ジャガイモの皮むきがひと仕事です。",
              "citation": {
                "source": "子守つ子",
                "author": "アントン・チエーホフ　Anton Chehov",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはジャガイモの皮むきをする。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "西田さんには私のような皮むきがないから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やれお気の毒な、いざ一皮むき給え」　寄って来て、みどりの上着に手をかける。",
              "citation": {
                "source": "大菩薩峠",
                "author": "甲源一刀流の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンマ榎本来り揉む、痛いがうまい、皮膚がピリ／＼するよと言へば、「そいつはすみません、皮むきアンマは下の下です」と言ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
