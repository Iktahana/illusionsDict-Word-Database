    "definitions": [
      {
        "index": 1,
        "gloss": "tile (e.g. roof)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "台風で屋根の瓦が数枚飛ばされてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古い日本家屋の、趣のある赤茶色の瓦が夕日に照らされていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しい家では、耐久性の高い洋風の瓦を採用することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "雨が降ると、瓦屋根から滴り落ちる雫が、独特の音を立てる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "煉瓦塀に春を発見した福助人形の影法師孤児の下駄が置き忘れてありました公園の入口ペンキのはげた立札心よ！",
              "citation": {
                "source": "（風船玉の衝突）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一丁ばかり先の練瓦建の家が、泳いでゐる緋鯉のやうに、ボンヤリトキ色に見える。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪かなしいつ大仏の瓦葺　夢のように唐突であり、巨象のように大きな大仏殿。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤き煉瓦の長壘、夢の如くに遠く連なり、地平に落日の影を曳きたり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れ少年の日は、常に麥笛を鳴らして此所を過ぎ、長き煉瓦の塀を※りて、果なき憂愁にさびしみしが、崖を下りて河原に立てば、冬枯れの木立の中に、悲しき懲役の人人、看守に引かれて石を運び、利根川の淺き川瀬を速くせり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眩しいような瓦斯燈の下に所狭く並べた絵具や手帳や封筒が美しい。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹村君は前屈みになって硝子箱の中に並べたまじょりか皿をあれかこれかと物色しているが、頭の上の瓦斯の光は薄汚い鼠色の襟巻を隠す所もなく照らしている。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木枯しが森川町の方から大学の前を渦巻いて来る度に、店ごとの瓦斯燈が寒そうに溜息をする。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "王宮と河一つ隔てた広場に面した四角な煉瓦造りの建物で、これは有名なシンケルの建てた特色のある様式の建築として聞こえたものだそうである。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一に根気二に根気で集輯した素材を煉瓦のように積んで行くのである。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "植半の屋根に止れる鳶二羽相対してさながら瓦にて造れるようなるを瓦じゃ鳥じゃと云ううち左なる一羽嘲るがごとく此方を向きたるに皆々どっと笑う。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦屋根の覆いを冠った朱塗の大鳥居には、良恕法親王の筆と知られた、名高い「三国第一山」の額が架かってある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その石も巨大なるブッ欠きや、角の取れない切石や、石炭のかすのような「つぶて」で、一個一個としては、咸陽宮の瓦一枚にすら如かないものであるが、これが渾然として、富士山という創造的合成を築き上げたとき、草も、木も、人も、室も、この中へと融合同化してしまう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士駅附近へ来ると極めて稀に棟瓦の一、二枚くらいこぼれ落ちているのが見えた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋上から見渡すと、なるほど所々に棟瓦の揺り落されたのが指摘された。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "県庁の入口に立っている煉瓦と石を積んだ門柱四本のうち中央の二本の頭が折れて落ち砕けている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "容器の中の瓦斯體の分子が、その熱擾動のために器壁に反覆衝突するのが、いくらか此れに似た状況であらうと思はれた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツの町を歩いていたとき、空洞煉瓦一枚張りの壁で囲まれた大きな家が建てられているのを見て、こんな家が日本にあったらどうだろうと云って友人等と話したことがあった。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "根津を抜けて帰るつもりであったが頻繁に襲って来る余震で煉瓦壁の頽れかかったのがあらたに倒れたりするのを見て低湿地の街路は危険だと思ったから谷中三崎町から団子坂へ向かった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "団子坂を上って千駄木へ来るともう倒れかかった家などは一軒もなくて、所々ただ瓦の一部分剥がれた家があるだけであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の家の前の煉瓦塀はすっかり道路へ崩れ落ち、隣と宅の境の石垣も全部、これは宅の方へ倒れている。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは瓦が数枚落ちたのと壁に亀裂が入ったくらいのものであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土蔵もみんな焼け、所々煉瓦塀の残骸が交じっている。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊帳が幾分でも空気の疎通を妨げるとすれば二、三人も狭い蚊帳に寝ていれば炭酸瓦斯の分量も外よりは多くなるかも知れぬ。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちアーク灯の陰極になっている炭の棒を不断廻転させ、陽極には金属の棒を用い、これを水素または炭酸瓦斯で包んでなお強い磁力をアークの光部に作用させる。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気の代りに他の瓦斯を入れることもあるが、要するに稀薄な瓦斯中を電気が通る際に、その瓦斯が光を放つというだけのことである。",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにかくのごとき管に少時続けて電流を通すと、中の瓦斯がだんだんに稀薄の度を増し、遂にある度に達すると電流は通らなくなり、従って光も消えてしまう。",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何となく陰気に薄暗くじめじめして、妙に気味の悪い厭な感じがしたので、夫人が直覚的に反対したにもかかわらず、ヘルンは一見して大いに気に入り、『面白いの家』『面白いの家』と、子供のように嬉しがって、是非それを買おうと言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、何となく心を牽かれる俳句であり、和歌の恋愛歌に似た音楽と、蕪村らしい純情のしおらしさを、可憐になつかしく感じさせる作である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気を付けていたにもかかわらず一度も柱を登る姿を見た事がない。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
