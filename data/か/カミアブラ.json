        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖母のドレッサーからは、いつも微かに椿の髪油の香りが漂っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「現代のヘアオイルもいいけれど、和服の時はやっぱり髪油で艶を出したいわ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "髪のパサつきを抑えるため、少量の手のひらに取った髪油を毛先に馴染ませる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "醜い女だが、白粉と髪油の匂いがプンプンしていた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者の家の紋を散らした派手な箱や缶や手拭や、俳優の似顔の目の隈取りや、それを照らす白い強い電燈の光や、それに見入る娘たちや雛妓らの様子までもはっきり、彼女らの髪油の匂までもありありと、浮かんで来た。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴつちりと身についた洋服を着て、髪は髪油で光り、勤め人風に刈りこまれ、鼻の下には官吏らしい短かい髭と、薄い唇とがありました、彼は落着いた声で私に話しかけるのです、彼が表面の落着きに反して、興奮してゐることは、彼の手にもつた細味のステッキがぶるぶると小刻みにふるへてゐるのでわかりました。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "附け処は異なるが、その製は塗香と兄弟たるもので、その材料加薬に外国品多きより推すと、けだし外国の髪油と塗香より転成したらしい。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こりゃべっぴんのにおいがするようですが、なんていう髪油でしょうかね」「次から次へ、よくとんきょう口がきけるやつだな、これが有名な古梅園の丁子油じゃねえか」「へへえ、この油が丁子油でござんすか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "においをかいでみましたら、娘が好んで日ごろ使っておりました丁子油の髪油がかおりましたゆえ、こりゃ、どっちにしてもただごとではあるまいというので、急に騒ぎだしましてな、所々ほうぼうと人を派して、だんだんと捜すうちに、あろうことかあるまいことか、深川の先で死体となって揚がったのでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしか古帽子にふだん自分が使ひ馴れた髪油の移り香さへしみてゐなかつたなら、彼は実際太陽に草の匂を嗅ぐことができたであらうのに。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "７　ちょうどそこへ、髪油を手の序に顔へも塗ったような、頬の光った楽長が近づいて来て何かお好みの曲はございませんでしょうかと質問したので、私が一同を代表して「ハリファックスへ行くように」と勧告した。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから彼女達が何曜日かの朝、怪しげな美衣を纏って、不良な髪油と白粉との悪臭を放ちながら、白昼公然奇異な一群をなして、ぞろぞろと病院へ検診にやられる姿は、同性全体が担わなければならない耻かしめではないか。",
              "citation": {
                "source": "ある遊郭での出来事",
                "author": "公娼存廃論者への参考資料としての実例",
                "note": "青空文庫"
              }
            },
            {
              "text": "化粧水も髪油もとうの昔に空っぽだ。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、泣かずに、こっちいお出でよ――よう、師匠」　南玉は、立って来て、白粉と、髪油の匂を嗅ぎながら、富士春の肩へ手をかけた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪油のにおいがむんむんと酔わすように嗅っているのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "角な食塩の明壜に真赤な葡萄酒のやうな髪油も入つて居た。",
              "citation": {
                "source": "茗荷畠",
                "author": "眞山青果",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と湯村は行也その髪油の壜を取つて流しに投付けた。",
              "citation": {
                "source": "茗荷畠",
                "author": "眞山青果",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな風に出られて見ろ、さんざ艶めかしいところを見せつけられて、梅花の髪油の匂いを嗅ぎこまされて、このまま庫裡に引き取ったところが、思いがのこって、却って、どうにもならなかったろうぜ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "変に胸糞の悪くなるような髪油の匂いが、気のせいか、いつまでも鼻についていた。",
              "citation": {
                "source": "或る素描",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪油のついた両手を拡げてやって来る高子と、廊下で行き合った。",
              "citation": {
                "source": "二つの途",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "不自然な結髪、生彩のない厚化粧、そして何よりも堪らないあの髪油の匂ひ、といふよりも寧ろ臭気。",
              "citation": {
                "source": "三つの挿話",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "……こりゃア、千賀春のものじゃありません……それに、こうして脚をしごいて見ると、指にべっとりと髪油がつく。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "三人目",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里の下町の隣人たちが餞別にくれたコティの髪油である。",
              "citation": {
                "source": "亜剌比亜人エルアフイ",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あわただしく膝をついて、「して、望みの品というのはどんな物だ」「香木五十八種はもとより、市中にて売出しおります髪油、匂油いっさい。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすが五百人もの輩下をつかう藤波のすることだけあって、大広蓋に香道具やら香木、煉香、髪油にいたるまで、ひとつも洩れなく山ほどに積みあげて持ちこんで来た。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに、苛立ったようなようすになって、髪油のほうに移ったが、三十二三種の髪油、匂油の中にも、やはり求める匂いはない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ前髪をとったばかり、青々とした月代に、髪油のうつりがいい。",
              "citation": {
                "source": "増長天王",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ、女の髪油が、生々と、曇っている。",
              "citation": {
                "source": "無宿人国記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瞬、お勢ちゃんの髪油の匂いと、もっとそれに何か加わった感じのものが、ぼくの体にまで染まりつくほど残される。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
