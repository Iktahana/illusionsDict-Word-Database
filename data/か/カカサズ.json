    "definitions": [
      {
        "index": 1,
        "gloss": "without fail",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "健康のために、毎朝欠かさずジョギングをしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はどんなに忙しくても、欠かさず日記をつけているそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "提出期限が迫っているから、このレポートは欠かさず毎日進めないといけない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子どもたちの連絡帳へのサインは、父親である彼の役割で、欠かさず続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "物理学輪講会はルーベンスが座長であったがプランクもほとんどいつも欠かさず出席してこの集会の光彩を添えていた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその日から村上は毎朝、毎朝、朝食には山崎より貰った若狭の笹がれいを欠かさずに食べた。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早くから、晩におそくまで田畑で働き、夜は、欠かさず夜なべをした。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには、毎月欠かさず××の記事が掲載された。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して毎晩欠かさず空の見張りをしている専門家にとっては、「偶然」はむしろ主に星の出現という事のみにあって、われわれの場合のように星と人とに関する二重の「偶然」ではない。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎月御命日に欠かさず拝みにお出でなさるのは、あの経師職の息子さんばかりで……」「経師職の息子さんは毎月来るかね」「はい、お若いのに御奇特なお方で……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを考えると、わたくしは何だか師匠を見殺しにしたようで、明けても暮れても気が咎めてなりませんから、毎月その詫びながら墓参りには欠かさずに来るようにしています。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷中へ移ってからも土曜ごとにはほとんど欠かさず銀座へ泊まりに行った。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後まもなく郷里の田舎へ移り住んでからも毎日一合の牛乳は欠かさず飲んでいたが、東京で味わったようなコーヒーの香味はもう味わわれなかったらしい。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は一年間に宴会に出席すること四百回、しかも毎回欠かさずに卓上演説をしてのけたそうである。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌着も毎日のように取替えて、欠かさずに湯に入って、綺麗にお化粧をして、寝る時はきっと寝白粧をしたんですって。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　Ｓ君は毎年一度は欠かさずにここへ来るだけあって、しきりにこの箱根の谷底の湯を讃美していた。",
              "citation": {
                "source": "河鹿",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんは寝酒の一合ぐらいを毎晩欠かさずに飲んでいました。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は「クレオパトラとアントニイ」や「サロメ」など、新しい洋画を欠かさず見ていたが、弁士にもお座敷での顔馴染があり、案内女にも顔を知られて、お座敷がかかれば、そっと座席へ知らせに来てもくれた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その会合に、いつも欠かさず出席して、皆にお道化のサーヴィスをして来ました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は煤烟全部を読み直す暇がないので、判然した判断を下すに躊躇するが、当時の新聞は連続して欠かさず眼を通したものだから、未だに残つてゐる、其時の印象は、恐らく余に取つて慥かなものだらうと考へる。",
              "citation": {
                "source": "『煤煙』の序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家はこのとしから、ほとんど毎年、欠かさず二所詣をなさいまして、建保二年には正月と九月と二度もお参り致しました程で、その敬神のお心の深さは故右大将さまにもまさつて居られるやうに思はれました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あの時、雀の親子の情に、いとしさを知って以来、申出るほどの、さしたる御馳走でもないけれど、お飯粒の少々は毎日欠かさず撒いて置く。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも殆ど毎晩欠かさずに此酒場にくる。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道や枯草、藁積などには白く霜が降り、金色にさしてくる太陽の光が、よい一日を約束していたが、二十年も正月といえば欠かさず一緒に出かけた松次郎が、もうついてはいないことは一抹の寂しさを木之助の心に曳いた。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言懸けてお貞はもの案じ顔に見えたりしが、「そうそう、芳ちゃん、まだその前にね、旦那がさ、東京へ行って三月めから、毎月々々一枚ずつ、月の朔日にはきっと写真を写してね、欠かさず私に送って寄来すんだよ。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年正月のためとて浜防風と生のしらすは欠かさず送って来る。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何十年来一日も欠かさず水をそそがれた不動明王の体からは蒼い苔がふき出している。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は蓄音機という綽名を持ち、一年三百六十五日、一日も欠かさず、お前たちの生命は俺のものだという意味の、愚劣な、そしてその埋め合わせといわん許りに長ったらしい、同じ演説を、朝夕二回ずつ呶鳴り散らして、年中声が涸れ、浪花節語りのように咽を悪くし、十分毎にペッペッと痰を吐き散らしていた。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り、葡萄糖やヴィタミン剤も欠かさず打って、辛うじてヒロポン濫用の悪影響を緩和している。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "時刻は暮れ六つの鐘のきこえるのを合図に、雨の夕も風の日もかならず欠かさずに買いに来るので、店の者も自然に懇意になって、老婆を相手に何かの世間話などをするようになったが、かれはこの近所の者であるというばかりで、決して自分の住所を明かさなかった。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんにちの我れわれから観ると、単に奇怪な伝説としか思われませんが、わたしの祖父などは昔の人間ですから、井戸の家の血統が今なお連綿としているのは、自害したおっ母さんのお蔭だといって、その命日には欠かさずに墓参りをしています。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、根津とは余り遠くない本郷台に住居を定めたので、先生の旧宅へも毎月一回ぐらいは欠かさずに訪問して、奥さんの昔話の相手になることが出来るようになった。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは毎晩かかさず通いつづけていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その中でたった一人かかさずに来る奴があります」「紙屋の息子か」「あ、源次の奴ほじくり出しましたかえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
