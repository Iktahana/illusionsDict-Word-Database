          "standard": [
            {
              "text": "昔の家では、厠の神様をお祀りする習慣があったそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、夜中にトイレに行くと厠の神様に見つかるんじゃないかと怖かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この地域では、厠の神様にお参りすると、無病息災にご利益があると信じられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "引っ越したばかりの家でも、ちゃんと厠の神様への挨拶を忘れないようにしないと。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
