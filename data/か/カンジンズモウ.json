        "examples": {
          "standard": [
            {
              "text": "江戸時代の記録によると、勧進相撲は寺社への寄付を募る目的で行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "かつては、勧進相撲の勝敗が街の話題の中心になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その興行は、勧進相撲として多くの観客を集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "云うまでなく、この当時の大相撲すなわち勧進相撲は春場所と冬場所の二回で、冬場所は十月の末頃から十一月にかけて晴天十日の興行と決まっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
