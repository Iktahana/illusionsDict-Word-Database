    "definitions": [
      {
        "index": 1,
        "gloss": "to write down",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "探検家は未開のジャングルで遭遇した奇妙な動植物の特徴を、手元のフィールドノートに克明に書き記した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "祖父の遺品を整理していたら、戦時中の過酷な体験を書き記した古い日記帳が何冊も出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "後任者が困らないよう、複雑なシステムの再起動手順をマニュアルの余白に赤ペンで書き記しておいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "いつか小説のネタになるかもしれないと思い、夢で見た不可思議な光景を忘れないうちにノートへ書き記す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "仕方が無いから、Ｎさんが、それからおつしやつた、氣持のいい言葉を、歪曲すること無く、そのまま次に書き記す。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この物語を書き記す作者のもとへは、下町のある知人の紹介で和歌を学びに来たのであるが、そのとき彼女はこういう意味のことを云った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろはにほへと、一字一字原稿用紙に書き記す。",
              "citation": {
                "source": "雌に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私はその払戻し用紙に四拾円也としたため、それから通帳の番号、住所、氏名を書き記す。",
              "citation": {
                "source": "親という二字",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎ君はバスの窓から、さまざまの風景を指差して説明してくれたが、もうそろそろ要塞地帯に近づいてゐるのだから、そのＮ君の親切な説明をここにいちいち書き記すのは慎しむべきであらう。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どろぼうに就いての物語には、違いないのだけれど、名の有る大どろぼうの生涯を書き記すわけでは無い。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高く澄んだ空に虹色の熱気球で舞い上がった魂が、雲のチョークで大きく書き記す。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の感情や置かれている立場を言葉で確かめ、文章に書き記す術を獲得します。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸う妹を賺して、鉛筆と半紙を借り受け急ぎ消息はなしけるも、委しき有様を書き記すべき暇もなかりき。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "斷つて置く、以下に書き記す處は、或は此無限の生命ある世界に於て、殆んど一顧の値だに無き極々些末の一事件であるのかも知れない。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "断つて置く、以下に書き記す処は、或は此無限の生命ある世界に於て、殆んど一顧の値だに無き極々些末の一事件であるのかも知れない。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし前にも言ったようにそれはここに書き記すわけにはいかない。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから後のことは、朴と私との同棲生活の記録のほかはここに書き記す自由を持たない。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「週間朝日」昭和二年一月）怪説絹布団　この話は、しばしば友人仲間へは伝えた事のある古い話ではありますが、丁度昨今時候も初秋に入るに及び、偶然思い出しましたまま書き記す次第であります。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって日記として書き記すべき何事もない。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "義侠に富んだ九郎右衛門が、その皇子の話を聞いて如何に義憤の血を湧かせたか、如何に皇子に同情したか、それは書き記すにも及ぶまい。",
              "citation": {
                "source": "赤格子九郎右衛門",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小書といふのは能の曲目の左側に特殊演出の様式の名称を小さく書き記すからの呼びならはしで、それが諸流に夥しく堆積してゐる。",
              "citation": {
                "source": "演出",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう観察は、それを書き記すにはずいぶん長くなったが、ほんの数秒の間にしたことであった。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "今斯うしてせわしい時をいとう事もなく悲しかった時の事をその事によって得た心持を書き記す事をするのも何と云う心が私に斯うさせるのであろう。",
              "citation": {
                "source": "悲しめる心",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに、私の幼いころのことを書くとすれば、思わず知らず、私の後日の不幸な身の上ばなしをすることになってしまう出来事まで、書き記すことになってくる。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大激変に接した時の私の感動をどうして書き記すことができよう。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "――と云うことにあるということだけを、書き記すだけに止めて置こう。",
              "citation": {
                "source": "鴉片を喫む美少年",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「魚屋様は商人でのご名家、嘘偽りないお方、それゆえ現金は戴かずとも、必要の際にはいつなりとも用立て致すとお認し下されば、それでよろしゅうございます」「それはそれはいと易いこと、では手形を差し上げましょう」　サラサラと一筆書き記すと、それを乙女へ手渡した。",
              "citation": {
                "source": "郷介法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私の計画についてこの備忘録へ記すより先に、何故探検隊の一行がこの土地を見捨てて立ち去ったかを書き記す方が順序らしい。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私の書き記す備忘録には少しの偽りも記してない。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一　人としてのイエスの生涯を事実に即して書き記すこと。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭文は施錠された扉の外のホールでも容易に聞こえたので、ウォード夫人は心配に耳を傍立てて待っている間、嫌でもそれを覚えてしまい、後になって、ウィレット医師の求めに応じその祭文を書き記すことができた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
