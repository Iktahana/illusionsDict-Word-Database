[
  {
    "uuid": "3fdb0d3f-af2f-574a-bb65-398d463a4242",
    "entry": "傾く",
    "reading": {
      "primary": "かたむく",
      "alternatives": [
        "かたぶく"
      ],
      "is_heteronym": false
    },
    "grammar": {
