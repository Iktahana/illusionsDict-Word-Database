[
  {
    "uuid": "c00b8a2c-624c-559e-8df4-8de744d745ad",
    "entry": "各人",
    "reading": {
      "primary": "かくじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "副詞"
      ],
