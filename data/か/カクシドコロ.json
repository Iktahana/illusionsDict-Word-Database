        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "公衆の面前で自身の隠し所を露出する行為は、法律で厳しく罰せられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "幼児は悪気なく、彫像の隠し所を指さして「あれは何？」と母親に尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "古い医学書には、人体の隠し所に関する詳細な図解が載っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
