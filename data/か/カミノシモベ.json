        "examples": {
          "standard": [
            {
              "text": "彼は生涯を神のしもべとして捧げ、困っている人々を助け続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "聖職者たちは、自らを神のしもべと心得て、日々の務めに励む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旧約聖書には、多くの預言者が神のしもべとして登場する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "われぞ病む、愛憎度なきおん神のしもべとなのるわかうどの、祝詞か咒詛か、ほそごゑのふしをかしきを戸にききて、うしろ姿を見たるものゆゑ。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
        }
