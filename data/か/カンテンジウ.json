        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長い干ばつで農作物が枯れそうになっていた時、ようやく恵みの干天慈雨が降り、村人たちは安堵した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社の業績がどん底で希望が見えなかったが、新しい契約が決まり、まさに干天慈雨のようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試験勉強に行き詰まっていた時、友人が的確なアドバイスをくれた。あれは干天慈雨だったね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
