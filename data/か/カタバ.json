[
  {
    "uuid": "b897307b-7102-5567-bd76-4e7b5eb7a48d",
    "entry": "片刃",
    "reading": {
      "primary": "かたば",
      "alternatives": [
        "かたは"
      ],
      "is_heteronym": false
    },
    "grammar": {
