[
  {
    "uuid": "f86b9c5b-c59e-5876-ba03-e15e5b57d197",
    "entry": "冠す",
    "reading": {
      "primary": "かんす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-す",
