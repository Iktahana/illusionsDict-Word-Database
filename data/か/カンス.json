        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しいプロジェクト名には、会社の先進性を表す言葉を冠した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このソフトウェアは、ユーザーフレンドリーであることを示すために、『Easy』を冠した名前になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の署名には、尊敬の念を込めて『先生』という敬称を冠した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
