        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "来客用に用意していた有田焼の菓子皿を戸棚から出し、丁寧に拭き上げてから季節の上生菓子を乗せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "祖母の遺品を整理していたら、漆塗りの美しい菓子皿が五枚セットで木箱に入っているのを見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "お茶会で出されたアンティークのガラス製菓子皿がとても可愛らしくて、思わず裏返して銘を確認してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "普段使いのプラスチックの菓子皿では味気ないので、陶芸教室に通って自分好みの少し歪な形の皿を焼いてみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "とて虚しくなりし菓子皿の上に、白かねの錢、二つ三つ置きて、門を出でぬ。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の慾張りなばあさんが近隣の二三の人から團子の模樣のついた素燒の菓子皿を貰ひ集めた。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と菓子皿を取出して、盛りたる羊羹に楊枝を添え、「一ツおあがり、いまお茶を入替えよう。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "加奈子はショールの下に隠していた提げ菓子皿を持上げて、振って円タクのみんなに「いらない」合図をする、四台の車の窓から四つの鋭い眼が引込んで道路は再び無慈悲な爆音に蹴立てられる。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この提げ菓子皿の取手は伊太利フローレンスで買った。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中を呼んで茶を入れ換えさせ、ここの名物｜柿羊羹の菓子皿をチャブ台に載せて、博士は私と差向いになった。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ繼母が五つばかり最中の這入つた菓子皿を持つて來て、「もう、これツぽつちだけれど、壺屋のは久し振りでしよう――」「菓子どころではなかつたのです」と、渠はつツかかるやうな口調だが、繼母には多少遠慮したつもりで語つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "お君が羊羹を切って菓子皿に盛って来た。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、お芳が菓子皿を持つて入つて來た。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、お芳が菓子皿を持つて入つて来た。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゆんが茶盆に、赤や白の砂糖をかぶせたビスケツトを盛つた菓子皿を持つて出た。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくは首と首を合せて何かささやき合えるようであったが、このたびは女の方へは向わず、古伊万里の菓子皿を端まで同行して、ここで右と左へ分れる。",
              "citation": {
                "source": "一夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中が、美しい菓子皿とお茶を運んで来た。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっとりした女中が、美しい菓子皿とお茶を運んで来た。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女にとって、貞操は一つの切子硝子の菓子皿なのです。",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肴の代りに薄いウエーファーが菓子皿にあった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして、御米が菓子皿と茶盆を兩手に持つて、又出て來た。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども御米の顏は見ずに却つて菓子皿の中を覗いてゐた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "其所へ下女が三｜尺の狹い入口を開けて這入つて來たが、改ためて宗助に鄭重な御辭儀をした上、木皿の樣な菓子皿の樣なものを、一つ前に置いた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "下女が平たい大きな菓子皿に妙な菓子を盛つて出た。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "菓子皿を主客の間に置いて、やさしい肩を後へ引くついでに、「ええ」と小声に答えて、立ち兼ねた。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで八ツ橋という名が起こって、名所になったのでござります」　その時十八九にもなりましょうか、美しい娘が菓子皿を持って、奥の座敷から出て来ましたが左衛門の前へ菓子皿を置くと、しとやかに辞儀をいたしました。",
              "citation": {
                "source": "真間の手古奈",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘お登和が盆へ載せて持来れるは珈琲茶碗と小さき菓子皿「大原さん、食後のお菓子を一つ召上って御覧なさい。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "原料も精選が出来る、それを食べる時間も毎日一定して親たちが監督する事も出来る、自分で菓子を作る事を知っていると外の菓子をねだらない、お客の前へ小供が馳出して阿母さんアレなぞと菓子皿へ指をさすのはあんまり見っとも好い事でない。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルの上には珈琲碗四つ五つ、菓子皿はおおむねたいらげられて、ただカステーラの一片がいづれの少将軍に屠られんかと兢々として心細げに横たわるのみ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "点検が済んだら、すべからく寝て鋭気を養うべしだ」言いつつ菓子皿に残れるカステーラの一片を頬ばり「むむ、少し……甲板に出ておると……腹が減るには驚く。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりから従卒のうずたかく盛れる菓子皿持ち来たりて、士官次室の話はしばし腰斬となりぬ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
