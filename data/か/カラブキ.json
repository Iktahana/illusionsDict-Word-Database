        "examples": {
          "standard": [
            {
              "text": "食事の後、テーブルを濡れ布巾で拭いてから、乾拭きで仕上げるのが習慣だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "窓ガラスは、水拭きの後に乾拭きすると、曇り一つなく綺麗になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "木の家具は、日頃から乾拭きすることで艶が保たれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は愛車の手入れを怠らず、洗車の後は必ず乾拭きしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「おや、おかしいぞ」と、源吉は不審したがその不審の下からぶきみになって来た。",
              "citation": {
                "source": "山姑の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その細いしなやかな手からぶきっちょうに札が捨てられたり取られたりするのを葉子はおもしろいものに見やりながら、断続的に言葉を取りかわした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじいさんは、おっかなびっくり立ち上がって、見るからぶきような手つきをして、でたらめな踊りを踊りました。",
              "citation": {
                "source": "瘤とり",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
