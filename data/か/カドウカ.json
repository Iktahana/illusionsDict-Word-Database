[
  {
    "uuid": "cc5fb422-b46f-52b8-b915-bee9c46ff24d",
    "entry": "か如何か",
    "reading": {
      "primary": "かどうか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "whether (or not)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その提案が受け入れられるかどうか、まだ確信が持てない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "明日の天気予報を確認して、ピクニックに行けるかどうかを決めよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼が本当のことを言っているのかどうか、じっくりと見極める必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "朝日よりも美味いか如何か、私には解らぬ。",
              "citation": {
                "source": "文士の生活",
                "author": "夏目漱石氏−収入−衣食住−娯楽−趣味−愛憎−日常生活−執筆の前後",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけどこの分では、汽車に乗れるか如何かゞ怪しまれて……」　さう云つて彼は、苦しく喉を鳴した。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方焼棄てるか如何かしたのであらう。",
              "citation": {
                "source": "背負揚",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「清々と好いだらうな、あいつが毎朝掛つて来なくなつたら……」「不景気でね、さう直ぐには売れるか如何か？",
              "citation": {
                "source": "雪景色",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は万幅の力を籠めて此場合に於ける令夫人の心理状態を描いて見ようと思ふが、旨くゆくか如何か、心元ない。",
              "citation": {
                "source": "未亡人と人道問題",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さき」が真の母親であッたか如何かはどうでもよい事なのでございます。",
              "citation": {
                "source": "殺された天一坊",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ位いいぢやないかと、尚も彼が云ふと強情に身を引かんばかりにして、「いいえ、いけまへん」と、しをらしい表情をして見せたが、急に彼は自分の観察が誤つてゐるか如何かをためしたくなつて、何の悪い気もなく、「あんたは、女とちがふな」と云つたのである。",
              "citation": {
                "source": "釜ヶ崎",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜次郎が陣風斎から、八方巻雲の秘伝を授かったか如何か。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすればその数分間前、もしくはその数秒前までは正気でいた筈だから、もし云い忘れたのでなければ、一番おしまいに白骨の絵を描いたか如何かを説明していない筈はない。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "余りの不思議さに狐に抓まれたようになりつつ、自分が正気でいるか如何かを確かめるような気持ちで、まず絵巻物の新聞包みをソロソロと開いた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌は、思想の動揺に堪へる気力がない、も一度直つて隅田川を渡れるか如何かそんなことさへ口へ出したり考へたりしないで置かうといふので、意識のうすれた心情がよく現はれてゐてあはれが深い。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを鑑賞するものは、果してそれらが旨く纏つて一個の小天地を成してゐるか如何か、それを調べて見るわけである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな風にも解せられるが、果して当つてゐるか如何か少し心許ない。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし雨が降つたか如何かしてこの発甫行きは実現しなかつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "麝香の無心があった事か如何か分らないが、手塚の二字を大阪なまりにテツカと云うそのテツカを鉄川と書いたのは、高橋｜順益の思付で余ほど善く出来てる。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが正しい解釋か如何かはしばらくおき、何れにしても先生の作品の不思議な魅力は、その内容の幽幻を、白日の光よりも強く輝かしく描き出す印象描寫の冴にあるのである。",
              "citation": {
                "source": "貝殼追放",
                "author": "泉鏡花先生と里見※さん",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と親らしい前置きをして、一體その息子の書く物によつて判斷すれば、將來文士として名を成す事が出來るか如何か先生の御意見を伺ひ度いといふのである。",
              "citation": {
                "source": "貝殼追放",
                "author": "先生の忠告",
                "note": "青空文庫"
              }
            },
            {
              "text": "此家の若主人に妻君があったか如何か、と辰爺さんに尋ねて見た。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯唐の玄宗の時に、張九齡が草した『勅日本國王書』と謂ふのがあつて、勅日本國王主明樂美御徳と書き出したのがあるが、此の勅書は日本に到着したか如何かは分明でない。",
              "citation": {
                "source": "聖徳太子",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの頃の『かどのもと』の地名は今もそのまゝ殘つてゐるか如何か、又もとの樣にそこに稻田があつて螢が飛んでゐるか如何かを知らぬが、私は稻の苗を見、螢を見るとこの樂しかつた思ひ出を聯想しては、動物愛護を實地に教へてくれた慈母の俤を偲ぶのである。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞内は始は高く且つ広く、入口から四、五間の処に御内院開闢と書いた小祠がある、其右側を辿って二十間も進むと、左に一曲して間もなく急に狭くなり、身を細めても通れるか如何か疑わしい。",
              "citation": {
                "source": "春の大方山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "槭は種類に富んでいるか如何かは知らないが、木は非常に多い所から推して、峡谷の秋の色はさぞや見事なものであろうと思う。",
              "citation": {
                "source": "黒部峡谷",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は果して私のやうなまだ無名の青年のモデルになつて呉れるか如何か心配しながらＫさんから頼んで貰つたのだが、彼の女もたつた一度会つたぎりの私のことを覚えてゐて、直ぐに快く承知して呉れたと云ふ返事だつた。",
              "citation": {
                "source": "酔狂録",
                "author": "吉井勇",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題は春一がほんとうに小夜子を思い切ったか如何かという事と、小夜子が黙って引き下るか如何かという事です。",
              "citation": {
                "source": "死者の権利",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "抑も、真に青年を恋して、しかも被害者の場合におけるが如き立場に立った十九歳の若き女が、小夜子がとったような態度をとるものであるか如何か、換言すれば、小夜子が、被告人に脅迫状を送ったことによって、彼女が真に被告人を恋していたかいなかったかという判断をつけ得べきものなりや、否や。",
              "citation": {
                "source": "死者の権利",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のために小夜子があんな脅し文句の手紙を書いたか、結局この解決に来る予備手段に違いないが、ここに気付かれぬのは賢明なる検事にも似合しからぬことだと皮肉を浴びせ、更に、当夜果して脅迫的のことをいったか如何かという点に関しては、この点について検事自身「被告者と被害者のみが知っていることである。",
              "citation": {
                "source": "死者の権利",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんもお母さんも乃公を叱るけれど、実際乃公が悪いか如何か、少し道理の分る人に判断をして貰いたい。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから先に、果して隧道を開いて前方に進む事が出来るか如何か。",
              "citation": {
                "source": "列強環視の中心に在る日本",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "新体詩様式は、未だ十分の発達を示してはゐないけれども、人々はその案外に困難なる故を以てかどうか、何時の間にか退却し、昨今再び立向つてゐる状勢だが、猶極めて怠惰な立向ひ方と云へよう。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがいいことであるかどうかは、間もなく分るであらう。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
