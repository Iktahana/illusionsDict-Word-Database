    "definitions": [
      {
        "index": 1,
        "gloss": "to sweep together",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭の落ち葉を熊手で一ヶ所にかき寄せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "テーブルの上のパンくずを手のひらでかき寄せてゴミ箱へ捨てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "窓から吹き込んだ砂埃を、ほうきでかき寄せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "誰にも明日の事は分かりませんが、さし当り雨だけはというので、男たちは屋根に上って修繕し、私どもは瀬戸物の屑をかき寄せるのでした。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもそのはず、蟻塚の中を手当り次第にかき寄せるのと違いはない。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "イワンは刈り取った草を妹にかき寄せるように言いつけて、今度はライ麦を刈りに行きました。",
              "citation": {
                "source": "イワンの馬鹿",
                "author": "SKAZKA O IVANE-DURAKE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いよいよ上陸して来るかな」　棒で暗号書をつつき、かき寄せると、また新しい焔が起った。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は慾が深くていらないものまでかきよせるくせがある。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to drag towards oneself",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
