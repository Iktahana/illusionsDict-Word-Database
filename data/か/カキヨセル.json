        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "岸から離れてしまったボートを、オールで懸命にかき寄せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "眠そうにしていた猫が、私の足元にそっと体をかき寄せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "水に落ちたボールを、長い棒を使って手元にかき寄せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
