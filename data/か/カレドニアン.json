        "examples": {
          "standard": [
            {
              "text": "博物館の展示パネルには、数億年前に起きたカレドニアン造山運動が現在のスコットランドの地形を作ったと記されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "カレドニアン・スカイという名の豪華客船が、汽笛を鳴らしながらゆっくりと霧の立ち込める港を離れていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この地層に見られる複雑な折れ曲がりは、典型的なカレドニアン期の地殻変動によるものと考えて間違いありません」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あの古い藤棚の下では、今も猶、私の耳に空気を顫わすカレドニアンが響いている。",
              "citation": {
                "source": "思い出すかずかず",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあと諜報部員ムーアはカレドニアン・ホテルに向かった。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような話があったのはキングス・クロス、ユーストン、セント・パンクラス、カレドニアン通り。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            },
            {
              "text": "膨大な備蓄があるのはキングス・クロス、ユーストン、セント・パンクラス、カレドニアン通りだ。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かに、着実に、決意を秘めて、カレドニアン通りからユーストン、フィンズバリ公園からキングス・クロスの広範囲に及んだ。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
