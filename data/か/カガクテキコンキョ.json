          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このサプリメントを飲むだけで視力が回復するという主張には、何の科学的根拠もない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "気候変動に関するその報告書は、世界中の気象学者が提示した確かな科学的根拠に基づいている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "民間療法を試す前に、それがプラセボ以上の効果を持つのか科学的根拠を調べておくべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "科学的知識の進歩した結果として、科学的根拠の明らかでない云い伝えは大概他の宗教的迷信と同格に取扱われて、少なくも本当の意味での知識的階級の人からは斥けられてしまった。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし方数十里の地域に起るべき大地震の期日を数年範囲の間に限定して予知し得るだけの科学的根拠が得られるか否かについては私は根本的の疑いを懐いているものである。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、僕かて石油がなんぜ肺にきくかちゅうことの科学的根拠ぐらいは知ってまっせ。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "星によつて人間の運勢を占ふといふことは、古来、東西共通に行はれたことで、たとへそれに、科学的根拠があるにしても、そも／＼の初めは太古の人間が、星辰の運行にいろ／＼の神秘的な意味を持たせ、それを人間の生活に結びつけて来たものである。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のこの注文は放庵の脱皮を希望しての一つの利の提言なので、私のこの提言は一つの科学的根拠に立つた考へから出発したものだといふことを信じてゐるものである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、右翼日和見主義者とその眷族調停派たちは、自身の誤謬を固執し、作家同盟の一部の同志は、同志小林の指導的批判に対していささかも科学的根拠のないデマゴギー的漫罵をわめきたてさえしたのである。",
              "citation": {
                "source": "同志小林の業績の評価に寄せて",
                "author": "――誤れる評価との闘争を通じて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがね、夢判断だって空想だとばかり言えないよ、科学的根拠があるのだ。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは僕は、さらに動かすべからざる科学的根拠を附け加へやふ。",
              "citation": {
                "source": "風博士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその平均数から得られた関野君の推定は、何ら科学的根拠のあったものではなかった。",
              "citation": {
                "source": "法隆寺再建非再建論の回顧",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の眼からすれば、有神論も無神論もともに科学的根拠のない迷妄にすぎない。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの問題は、「ちょっとおもしろい話」だけなのか、ほんとうに相当な科学的根拠のある話なのか、今のところ、どっちともつかない状態である。",
              "citation": {
                "source": "白い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただそういう場合に、ある事物の決定に科学的な根拠があると言う時には、よほど注意しないと、科学的の根拠と思い込んでいることが、案外非科学的根拠である場合が有り得るのである。",
              "citation": {
                "source": "兎の耳",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "立春に卵が立つ科学的根拠はわからないが、ランドル記者は「これは魔術でもなく、また卵を強く振ってカラザを切り、黄味を沈下させて立てる方法でもない。",
              "citation": {
                "source": "立春の卵",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ムッシュウ・ジッドがあの強い精神で、病気を癒したのは俺だ、といつもおつしやるのは、或る意味で科学的根拠がありますね。",
              "citation": {
                "source": "亜剌比亜人エルアフイ",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう声明書は、もちろん科学的根拠の薄弱なもので、あまり意味のないものである。",
              "citation": {
                "source": "亡び行く国土",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "終局に於て社会衛生の問題に帰着する医学技術上の諸問題は、云うまでもなく基礎医学に科学的根拠を有っているが、その基礎医学の可なりの部分が生物学（乃至広義の生理学）にぞくしている。",
              "citation": {
                "source": "辞典",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、そのかなり練達した方位なり時間なりの観念というものも、正確な科学的根拠から来ているのではないから、未経験の地に於ては、往々にして狂いを生ずることがありがちなのはやむを得ないのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "農奴の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学的根拠もなく、ぼんやりそう思うだけだが、つまり外界からの刺戟を拒否する気持が、そんな擬態を彼にとらせているのだろう。",
              "citation": {
                "source": "庭の眺め",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは僕は、さらに動かすべからざる科学的根拠を附け加えよう。",
              "citation": {
                "source": "風博士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
