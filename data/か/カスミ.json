[
  {
    "uuid": "e37d9912-21f6-5fba-973d-1c9be989aa16",
    "entry": "霞",
    "reading": {
      "primary": "かすみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
