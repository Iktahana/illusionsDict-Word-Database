        "examples": {
          "standard": [
            {
              "text": "秋田旅行の際、お土産として精巧な桜皮細工の茶筒を購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "博物館の特別展で、熟練の技が光る桜皮細工の筆箱に見入ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "使い込むほどに艶が増す桜皮細工の小箱は、日々の生活に彩りを与えてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "繊細な模様が特徴の桜皮細工は、海外からの観光客にも大変人気がある工芸品だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "桜皮細工といってしまえば通りがいいが、しかしそれは都会人にそう思えるというに過ぎない。",
              "citation": {
                "source": "樺細工の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
