[
  {
    "uuid": "1e3a596e-0fb4-5da9-8f6f-3f4790541af7",
    "entry": "蚊遣り",
    "reading": {
      "primary": "かやり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "outdoor fire with dense smoke to repel mosquitoes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夏の夕暮れ時、縁側で蚊遣りを焚きながら読書をするのが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "蚊遣りの煙が、虫除けとして効果を発揮してくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うわ、この煙、ちょっと目にしみるね。でも、蚊がいなくなった！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔は、蚊遣りを使うのが夏の風物詩だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そのなかには肌脱ぎになった人がいたり、柱時計が鳴っていたり、味気ない生活が蚊遣りを燻したりしていた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大分もう薄暗くなっていましたそうで……土用あけからは、目に立って日が詰ります処へ、一度は一度と、散歩のお帰りが遅くなって、蚊遣りでも我慢が出来ず、私が此処へ蚊帳を釣って潜込んでから、帰って見えて、晩飯ももう、なぞと言われるさえ折々の事。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それに蚊遣りをしかけながら宅悦を見た。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の先に見える屋根の間からは、炊煙だか、蚊遣り火だかがうっすらと水のように澄みわたった空に消えて行く。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊はもう夕暮れには軒に音を立てるほど集まって来て、夜は蚊遣り火の煙が家々からなびいた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊遣りを焚いてゐるのである。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、里見君の「蚊遣り」も亦十月小説中の白眉なり。",
              "citation": {
                "source": "病牀雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "団扇使いは御寝の妨げと差控え、その代り名香をふんだんに、蚊遣り火の如く焚くのは怠らなかった。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊遣りの煙りが薄い幕の様に立ちこめたほの暗い土間で、白襦袢一枚の父と祖父とが並んで坐り、父は板をカンナで削っていた。",
              "citation": {
                "source": "十姉妹",
                "author": "山本勝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄い燭光と蚊遣りの煙りに包まれた二人の周囲に、心なしか、何か秘密の作業場と云った雰囲気が感ぜられた。",
              "citation": {
                "source": "十姉妹",
                "author": "山本勝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは梅雨もカラリと上った七月の中旬のこと、日も既に暮れてこの比野の家々には燭力の弱い電灯がつき、開かれた戸口からは、昔ながらの蚊遣りの煙が濛々とふきだしていた。",
              "citation": {
                "source": "雷",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれを刈りに行くものは、腰に火縄を提げ、それを蚊遣りの代わりとし、襲い来る無数の藪蚊と戦いながら、高い崖の上に生えているのを下から刈り取って来るという。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、釣ランプの下に、一人々々の膳を並べて、下女下男子守、或ひは臨時の雇ひ人をも加へ、子供沢山の大家族が、蚊遣りの烟にむせびながら、汗にまみれて晩餐を食べてゐた真夏の頃を思ひ出してゐるが、それは、文学的に云ふと、現世の地獄である。",
              "citation": {
                "source": "幼少の思ひ出",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊遣りをお焚きになつては。",
              "citation": {
                "source": "垂水",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　至が蚊遣りに火を入れてゐるあひだ、夫人は軒端に佇んで、珍らしく京都の話をはじめた。",
              "citation": {
                "source": "垂水",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "軒下の竹台に釘抜のように曲った両脚を投げ出した目明し藤吉、蚊遣りの煙を団扇で追いながら、先刻から、それとなく聴耳を立てている。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "お茶漬音頭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで昨今は二階の一番静かな部屋に蚊遣りを焚いて休みます」「はゝあ」　と社長は初めて聴き役に廻った。",
              "citation": {
                "source": "社長秘書",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗闇で、同室四人、椅子にもたれて眠ろうとしたが、蚊が出てきて眠られないので、蚊遣り線香をつけ、内地の生活の思い出を話しあった。",
              "citation": {
                "source": "十三夜",
                "author": "――マニラ籠城日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あれは」　蚊遣りの側から腰を泛かしかけると、槍組｜頭の湯浅五助が、「何事でもござりませぬ」　と、そこへ告げに来た。",
              "citation": {
                "source": "大谷刑部",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "濡れ縁に置いてある蚊遣りの煙が、薄と萩の茂っている庭のほうへと、絶えずゆるやかになびいていた。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪洞をその左右に、蚊遣りを焚かせ、正四郎もふさも浴衣にくつろいで坐った。",
              "citation": {
                "source": "その木戸を通って",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――成信はいつもの癖で、蚊遣り火を焚きながら、燈火をひき寄せて夜半すぎまで本を読んだ。",
              "citation": {
                "source": "泥棒と若殿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしたんだ、わけてえのはなんだ」「――なに、たいしたことでは、ないさ」「たいしたことでねえにしても、話しを聞かなくちあおちつかねえ、云って呉んねえな」　成信は蚊遣りの煙にむせて、咳をしながら脇へ向き、笑いながら、じつはわけもなにもない、あのときのでまかせだと云った。",
              "citation": {
                "source": "泥棒と若殿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は上田｜紬の万筋の単衣の下に夏｜痩せのした膝頭をそろえて、団扇で蚊遣りの煙を追いながら、思いなしか眼ぶたをしばだたいているのは、除虫菊に咽んだのかも知れない。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、蚊遣りの煙が余り籠ると咽喉を痛めそうなので、起きて、素焼の狸の容器に這入った線香の火を消した。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひどい蚊ではないか」と岡安が下役人に云った、「蚊遣りを焚いてやれ」　下役人は訝しそうな顔をした。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おすえも側に付きっきりで、蚊遣りを焚いたり、汗になった栄二を団扇であおいだり、手拭を水で絞って来たりした。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水を浴びて着替えをし、蚊遣りの焚いてある縁側で涼をいれていると、野口重四郎が廊下づたいにやって来た――道場に附属したこの住居は、十畳と八畳の客間が並び、ほかに居間、寝所、納戸という広い間取で、べつに掃除や炊事をする六兵衛という下僕夫婦の小屋が付いていた。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜は蚊遣りを焚きつぎながら、狭いところへごたごたと寝て、明くる朝は日蔭のあるうちにと早くでかけた。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前だって、悪い人だとは思っていなかったけど、また、悪い人だと思ったら姉さんをお嫁になんかやりゃしないんだけど、あんなにいい人だとは思わなかった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
