    "definitions": [
      {
        "index": 1,
        "gloss": "to bolt down (food)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昼休み時間が短かったので、急いで弁当をかっ込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、祖母の家ではよくご飯をかっ込んで叱られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試合前、彼はエネルギー補給のためにおにぎりをかっ込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "疲れて帰ってきて、冷蔵庫にあったものを勢いよくかっ込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "まず田楽を、鮒の刺身を、いい加減歩いてお腹も空いていたのだろう小助六は、御飯と一緒にかっ込むように食べた。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「凸凹」の間に中華丼をかっ込む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿へ帰り、まづい夜食をかっ込むと、すぐ仕事。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方アガったので、渋谷の塩瀬で支那めしをかっ込むと、橘の家へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼そばをとってかっ込む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ライスカレーかっ込む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯づけにでもしていたのだろう、それをかっこむ音が上り口からよくきこえた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一そのわだかまりのない気軽な名が気に入って居るし次には白とみどりのすっきりしたお茶漬をサラサラとかっこむ様な趣もすきだ。",
              "citation": {
                "source": "旅へ出て",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっとジャックがのぞいてみていますと、それはあとからあとから、いつおしまいになるかとおもうほどかっこむので、ジャックは、目ばかりまるくしていました。",
              "citation": {
                "source": "ジャックと豆の木",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをかたっぱしからひきだしてきて、昔から名高い薄茶の茶碗で、飯をかっこむやら、見事な軸へよせ書きをして笑い興じるやら……それというのも、こうでもしたら司馬家のほうから、今にも文句がでるかという肚だから、これでもか、これでもかといわんばかり、喧嘩を売ってきたのだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　居間の床の間に、擬いの応挙らしい一幅の前に、これだけは見事な碁盤と埋れ木細工の対の石入れがあったことを思い出しながら、伝二郎はなれなれしく飯をかっこむ真似をして見せた。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怪談抜地獄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
