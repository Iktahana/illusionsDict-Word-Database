[
  {
    "uuid": "c7237f1e-5808-5c00-8769-01e8a1d5e206",
    "entry": "仮小屋",
    "reading": {
      "primary": "かりごや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
