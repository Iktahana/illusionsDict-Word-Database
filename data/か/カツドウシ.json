        "examples": {
          "standard": [
            {
              "text": "彼は、最新のガジェット情報やレビューが満載の活動誌を毎月購読している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この活動誌は、特定のボードゲーム愛好家の間で、非常に人気が高い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「へぇ、こんなニッチな分野の活動誌もあるんだ！全然知らなかったよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "専門的な知識をさらに深めるため、私は関連する活動誌を読み漁った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
