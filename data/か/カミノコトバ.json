      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Word of God",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "牧師は、聖書に記された神の言葉を丁寧に解き明かした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "困難な時、彼女は神の言葉から慰めと力を得ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古代の預言者たちは、神の言葉を人々に伝えたと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼女は人間の願いを竹駒稲荷大明神に伝え、大明神の言葉を人間に受け次いでやると言うのだった。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイデッゲル教授やレーヴィット氏の話をきいて、私は弁証法的神学に興味をもつようになり、バルトの『ロマ書』とか『神の言葉と神学』などを繙くようになった。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ではどうかすると、祝詞は儀式の上で、なければならないものだから、単に読むものだと考へられさうであるが、昔は、神の言葉と信じ、寿詞では、自分等の思ふ所を述べたのである。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "文章に、霊妙不可思議な力がある、と言ふ意味からして、其が作用すると考へ、更に、神の言葉に力があるとし、今度は語の中に威力が内在してゐる、と考へた。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世の言葉は決してさながらに神の言葉ではありえぬのである。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "神の言葉は全く人の言葉を超越する。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠の世においては一切の存在は神聖者の象徴・神の言葉となる故、人倫的關係において「我」の對手として他者として立つ「汝」も被創造者としての性格を與へられる。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如くにして、主體の前に立塞がつてそれの前進を阻み又それと接觸することによつて主體を無へと押遣る自然的他者の實在性は、歪められたる形においてにせよ、神聖者の象徴、神の言葉を傳へるものとなるであらう。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化的活動も單なる自己實現に留まるを止めて神の言葉の實現となるであらう。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己に對する責任について正當に語りうるのは、その自己が他者の、結局は、神聖者の象徴・神の言葉の意味を有する場合にのみ限られる。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世においても、愛の光の輝く處では、自己實現を本質とする文化的活動もすでに神の言葉の實現を意味した。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世の藝術や知識は滅びるであらうが、神の言葉があらゆる形容を絶したる美しき淨き姿として響きとして、わが永遠の耳目を充たすであらうことを誰が否定し得ようか。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお祭の中で、神と人間との媒介をする人間というものはどういうことをしたかというと、一般民衆を代表して神に祈りを捧げ、神を祭ると同時に、一般民衆の方に向って神の言葉を伝える――そういうことをしたのです。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳優的な特色というものがどういう風にして増して来るかというと、その聖職者は、ただ単に神の言葉を伝えるだけでなくて、それが如何にも神の言葉であるかの如く、その人間は如何にも神そのものであるかの如き印象を一般の民衆に与えることが非常に大事であります。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、その神に仕える所の聖職者は、ただ単に神の姿を一般民衆に髣髴として見せ、神の言葉を恰もそれが真実の神の言葉であるような印象をもって伝えるばかりでなくて、一方に於て、その神と対立する所の悪魔の姿をも一般民衆にまざまざと伝える必要があったのです。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで、簡単な例を挙げると、最初はこの聖職者は神に代って民衆に一つの神の言葉を伝えていた。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその神の言葉を更に註釈し、敷衍し、そして、それらに対してもっと現実的な効果をあげる為に、ここに一つの物語を仕組む。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありのまゝの神の言葉を取次ぐだけの使者ではないか。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「吾の造りたるものを不潔とするなかれ」是れ大農夫たる神の言葉である。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだ、おまえの痛みはとまったろう」　女はこのクイクイの神の言葉に、はっとして胸をおさえてみた。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "諺は、私の考へでは、神の言葉の中にあつた命令だと思ふ。",
              "citation": {
                "source": "古代に於ける言語伝承の推移",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "即、神の言葉にも、次第に、会話と地との部分が出来て、其中の端的な命令の言葉が、諺であつたと思ふ。",
              "citation": {
                "source": "古代に於ける言語伝承の推移",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此宣命は既に、それ以前から固定し、生命を失うてゐた神の言葉を、其頃の言葉と妥協させた。",
              "citation": {
                "source": "古代に於ける言語伝承の推移",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天子様は、神の言葉を此国にお伝へなさる為に、お出でになつたのである。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからして、天子様の御言葉は、神の言葉と同一である。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今神主の唱へる祝詞は、此神の言葉を天子様が伝達する、といふ意味の変化したものである。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天つ神の言葉とされて居るのを、天子様が高御座で唱へられるのが、古い意味の祝詞である。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルッテルはこのことをはつきり意識してゐたので、まづさしづめ、神の言葉なる聖書を嚴格な權威として獨逸人に課した、この權威はしかしその後數世紀の正教において固定形式化した獨斷論として現はれた。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
