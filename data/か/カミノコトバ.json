[
  {
    "uuid": "577b334d-56fe-56cf-b4c1-5117df723bf7",
    "entry": "神の言葉",
    "reading": {
      "primary": "かみのことば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
