    "definitions": [
      {
        "index": 1,
        "gloss": "kaki (Japanese persimmon) seed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "柿を食べ終えた後のお皿の上には、ツヤツヤとした立派な柿の種がいくつか残っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「これ、土に埋めたら芽が出るかな？」と言って、子供が大事そうに柿の種を握りしめている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "綺麗に洗った柿の種を手のひらに載せて、その滑らかな感触を指先で確かめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「始めて貴下の随筆『柿の種』を見初めまして今32頁の鳥や魚の眼の処へ来ました、何でもない事です。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "握り飯と柿の種の交換といったような事がらでも毎日われわれの行なっていることである。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "吝嗇坊の柿の種が、小判小粒になればと云うて、御出家に土の団子を差上げまして済むものでござりますかよ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和八年六月、『柿の種』）短章　その一棄てた一粒の柿の種生えるも生えぬも甘いも渋いも畑の土のよしあし　　　　　　　＊　日常生活の世界と詩歌の世界の境界は、ただ一枚のガラス板で仕切られている。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十二年七月、渋柿）（『柿の種』への追記）　大正十二年七月一日発行の「渋柿」にこれが掲載されてから、ちょうど二か月後に関東大震災が起こって、東京じゅうの電燈が役に立たなくなった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹が日清戦争で遼東半島というデカイ握り飯を貰ったら、熊（これは帝政時代のブルジョア・地主のロシア）虎（フランス）狼（イギリス）が出しゃばって来て日露戦争で握り飯を蟹からとりあげ小さい柿の種（北満）をおしつけた。",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓姿の蟹は仕かたがないから、その柿の種にせっせと肥しをかけ（二十七年の歳月。",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも遼東という握り飯を先ずとり、それを柿の種に代えられたという蟹は、日本とだけ書いてあるが、ジックリ考えれば妙な話です。",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちどっちが柿の種を貰ったのでしょうか？",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "満州という柿の種にせっせと肥しをかけ働いている蟹はわれわれに近しい百姓姿に描いてあるが、みのった収穫は誰がとるかという肝心かなめのところは絵のどこにも描かれていない。",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途中、山道で猿は柿の種を拾いました。",
              "citation": {
                "source": "猿かに合戦",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言って、柿の種を見せました。",
              "citation": {
                "source": "猿かに合戦",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど猿はほんとうはおむすびがほしくってならないものですから、かにに向かって、「どうだ、この柿の種と取りかえっこをしないか。",
              "citation": {
                "source": "猿かに合戦",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも柿の種は、まけば芽が出て木になって、おいしい実がなるよ。",
              "citation": {
                "source": "猿かに合戦",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言いながら、とうとう大きなおむすびと、小さな柿の種とを取りかえてしまいました。",
              "citation": {
                "source": "猿かに合戦",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　かには柿の種をさっそくお庭にまきました。",
              "citation": {
                "source": "猿かに合戦",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「早く芽を出せ、柿の種。",
              "citation": {
                "source": "猿かに合戦",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "会所のまわりを、塀の隅っこのところまで行ってまた逆戻りをしたり、溝の中に柿の種子が落ちていたり手鞠がころげ込んだりしているのを見たりなんぞして、行きつ戻りつしているうちに、まだ埒があかない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿の種を蒔いても実のなるまでには七、八年はかかる。",
              "citation": {
                "source": "日本的童話の提唱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方、猿蟹合戦の柿の種のやうなことを、欲張つて夢見てゐるのであらう。",
              "citation": {
                "source": "打出の小槌",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒につんぼにしわんぼう、しわんぼうには柿の種とくらい。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、下手人の見當は付いて居る、考へ拔いた企みだ、――猿蟹合戰の筋書通り、――一度綱田屋の主人に、柿の種と握り飯を換へられた者の仕業だ」　柿の種と握り飯、それはどういふ意味になるでせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "猿蟹合戰",
                "note": "青空文庫"
              }
            },
            {
              "text": "次第に惡くなるには決つて居るだらうが、その惡くなる途中で、隅から少しは見えることもあると――眼醫者に話を聽いたことがある」「すると、あの盲目の浪人者が」「綱田屋五郎次郎が柿の種をやつて握り飯を取上げたに違ひあるまい。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "猿蟹合戰",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹の實で齒の無い者にも食べられるものは、以前は甚だ少なかつた上に、木練り即ち樹上で甘くなる柿の種類も乏しく、何か手をかける必要があつたのである。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹の実で歯のない者にも食べられるものは、以前ははなはだ少なかった上に、木練りすなわち樹上で甘くなる柿の種類も乏しく、何か手をかける必要があったのである。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ある旧友への手紙」は伸子に、桃や柿の種のしんにある真白な芽を思わせた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
