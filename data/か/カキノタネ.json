        "examples": {
          "standard": [
            {
              "text": "映画を見ながら、ついつい柿の種を一袋全部食べてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ビールのおつまみには、やっぱり柿の種が最高だね！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は辛いものが好きだから、お土産に特製柿の種を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
