        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "博物館で見つけた大きな化石には、太古の亀の甲がくっきりと残っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "本物の亀の甲を薄く削り出して、職人が丁寧にべっ甲の櫛を仕上げていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "縁側にやってきた小さなカメを持ち上げると、硬い亀の甲の感触が指に伝わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "亀の甲羅に腰かけるなどは、それは狂態と言つてよからう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　亀の甲羅に浦島が腰をおろしたとみるみる亀の背中はひろがつて畳二枚くらゐ敷けるくらゐの大きさになり、ゆらりと動いて海にはひる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひつくりかへつたまま、つまり、腹を上にしたまま泳いで、さうして浦島は亀の甲羅にくつついて、宙返りを半分しかけたやうな形で、けれどもこぼれ落ちる事もなく、さかさにすつと亀と共に上の方へ進行するやうな、まことに妙な錯覚を感じたのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と亀に言はれた時には、しかし、もうそんな、さかさの感じは無く、当り前に亀の甲羅の上に坐つて、さうして、亀は下へ下へと泳いでゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島は亀の甲羅から降りて、亀に案内をせられ、小腰をかがめてその正門をくぐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "童声或は女声合唱（童ぶり）亀の甲に揺られて、潮の瀬に揺られて、かぶりかうぶり海の子、棹やらな、附いまゐれ、波かぶりかぶるに、み船へと移らせ、名をのれ早や早や、み船へまゐ出るは臣ぞとそれまをす。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "┌輝る日麗ら万劫経たる海亀のこの諦めの大きなるかも　　　　　　　（原作）（27）┤　　　└日に照られ波にさらされ海亀の甲羅の苔も青寂びにけり　　　　　　（改作）　凡てがかういふ風であつた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "小笠原の旅から持帰った大海亀の甲羅ももはや旅への誘いを囁かない。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神仙は銀製の長さ二寸ばかりあるトッコンと云う楽器、水晶で造らえた亀の甲の形をした一寸五分ばかりのもの、鉄扇、剣の四種の品をくれた。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて故老より亀の甲は必ず十三片より成り、九と四と合せば十三故、鼈甲で作る櫛を九四といい始めたと承ったが、江戸で唐櫛屋を二十三屋と呼んだは十九四の三数を和すれば二十三となるからという（『一話一言』八）。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "三｜哩の言語４・29（夕）　英軍が今度の戦争で発明した新しい武器に亀の甲のやうな“Tank”があるのは知らぬ人もあるまい。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺色に染めた真綿を亀の甲のやうに背中に負つて、手拭を頭に巻きつけて、私達に茶をすゝめて呉れる休茶屋の婆さんが居る。",
              "citation": {
                "source": "突貫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何よりさきに眼に映ったのは、まるで亀の甲羅みたいに厚くて堅い、妙に形の変化した爪のある、アカーキイ・アカーキエウィッチには先刻おなじみのおや指であった。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の手を見てみい、亀の甲みたいやないか、そんなものを嫁にもらえるかい、といったそうだ。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の愛人から亀の甲だと呼ばれた彼女の大切なその手はどこへ落として来たものか影も形もなくなっていた。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて彼女は完全な亀の甲となって退院したが以来、はかなきその一生を棒となった片手に環をはめて、それへ糸を通し残された右手をもって糸車を廻しているという。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ霧雨の降っている往来には、細い銀杏の並木が僅に芽を伸ばして、亀の甲羅に似た蝙蝠傘が幾つもその下を動いて行く。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "石垣の崩れた処には山の切崖が煉瓦色の肌を出し、下には海に沈んだ円石が浅瀬の水を透して亀の甲のやうに並んでゐる。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで二三歩先へ出て、薬種店の方を覗くと、八ツ目鰻の干したのも釣るしてなければ、大きな亀の甲も飾ってないし、人形の腹をがらん胴にして、五色の五臓を外から見えるように、腹の中の棚に載せた古風の装飾もなかった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「肯いてくださいますか」　私はまだはっきりと口がきけないので、黙ってうなずくと、女は亀の甲でこしらえた櫛をわたしに渡して、小声で言いました。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、今太郎君は気絶した後も、亀の甲羅をしつかりつかんで放さなかつたので、とうとう水面まで一緒に浮上つて来たのでした。",
              "citation": {
                "source": "動く海底",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくなる以上は遠征の道案内に立つ方が身の為だ、と言つて、彼らも死物狂ひ、なかば脅迫の言辞を弄して迫つたけれども、朝鮮の態度は傲慢で、下賤の猿面郎が大明遠征などゝは蜂が亀の甲を刺すやうなものだ、といふ頭から軽蔑しきつた文書によつて返答してきた始末であつた。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きくて見事な茄子のある時は亀の甲焼にします。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主婦は家の内でも手拭を冠り、藍染真綿を亀の甲のやうに着て、茶を出すやら、座蒲団を勧めるやら、金米糖は古い皿に入れて款待した。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は真綿帽子を冠り、藁靴を穿き、女は紺色染の真綿を亀の甲のように背中に負って家の内でも手拭を冠る。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等より一足さきに、病院に着いたＭ中尉は、英語が出来ず、薬の話などするのに困ったが、Ｇ中尉が薬名が分らないと、例の亀の甲みたいな化学記号を書くので「あの人は薬剤師か何かではないでしょうか」といっていた。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもしろいじゃないの」　亮作は亀の甲から首をだす。",
              "citation": {
                "source": "水鳥亭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂礫の原の中に、亀の甲のような模様ができ、その線の部分に、比較的大きい礫が集まる現象である。",
              "citation": {
                "source": "白い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜって、亀の甲良はおそろしくしっかりしているじゃアないか。",
              "citation": {
                "source": "兎と亀",
                "author": "ロオド・ダンセイニ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「亀の甲より年の功と云うことがあるだろう。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
