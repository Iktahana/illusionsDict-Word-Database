          "standard": [
            {
              "text": "祖母から譲り受けた着物には、縁起の良い亀の甲の文様が金糸で刺繍されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "浴室の床に敷き詰められた亀の甲のタイルが、レトロな雰囲気を醸し出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幾何学的なデザインを考える際、亀の甲の配列をベースにすると視覚的な安定感が出る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
