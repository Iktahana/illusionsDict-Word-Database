[
  {
    "uuid": "0e7e3424-27d1-5d28-8db9-cebec291f02e",
    "entry": "書きにくい",
    "reading": {
      "primary": "かきにくい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "difficult to write or draw",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この漢字は画数が多くて、子供の頃から書きにくかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "指に怪我をしてしまったので、しばらく字を書くのがとても書きにくくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の感情は複雑すぎて、文章で書きにくかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "漫画のキャラクターデザインで、この表情を正確に書きにくいんだよな…。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "私は井伏氏の文章を尊敬してゐるゆゑに、いつそう書きにくい。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまさら、井伏さんに就いて、書きにくいのである。",
              "citation": {
                "source": "小照",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも、書きにくい。",
              "citation": {
                "source": "小照",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安朝の末でありますが、長明の『無名抄』に、こういう書きにくい音は省いて書くとありますが、この場合も多分そうであろうと思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だ、書きにくいのでありますが、それは、こんな詩なのであります。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」なんだか、とても、書きにくい思いなのですが、後者は、「矢車の花いとし。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "プルシャンブリューでは無論なしコバルトでも濃い過ぎるし、こんな空色は書きにくいと小山はつぶやきながら行った。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、大阪の話は書きにくい。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はかねがね思うのだが、大阪弁ほど文章に書きにくい言葉はない。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、これとても十分な書き方ではなく、一事が万事、大阪弁ほど文章に書きにくい言葉はないのだ。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "話は外れたが、書きにくい会話の中でも、大阪弁ほど書きにくいものはない。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、平常は無口でも、いざとなればべらべらとこなして行くのが年期を入れた俳優の生命で、文壇でも書きにくい大阪弁を書かせてかなり堂に入った数人の作家がいる。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりそれだけ大阪弁は書きにくいということになるわけだが、同時にそれは大阪弁の変化の多さや、奥行きの深さ、間口の広さを証明していることになるのだろうと私は思っている。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "川端康成氏の「十六歳の日記」は作者の十六歳の時の筆が祖父の大阪弁を写生している腕のたしかさはさすがであり、書きにくい大阪弁をあれだけ写し得たことによってこの作品が生かされたともいえるくらいであるが、あの大阪弁は茨木あたりの大阪弁である。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "感動はあっても未だ文学的なものに迄醗酵しないし、古い題材では矢張何かしっくりせず、其の他種々の事情から現在が書きにくい時期だということは判る。",
              "citation": {
                "source": "章魚木の下で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一つの観察は、少し書きにくいが、真実の為めに強いて書く。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは甚だ書きにくい事だが、これを書かないようでは、こんな物を書く甲斐がないから書く。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は書きにくい白扇よりも、その紙片の方を選んで、日頃好きな芭蕉の言葉の中から一つ二つを書いて贈ることにした。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから同じ物語の續きとして、もう一つ私は書きにくいことを書きました。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡見の訪ねにくいのは、あの手紙の返事の書きにくいのと変らなかった。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "――〔Faire la'mour, ce n'est pas tout. Ju es trop jolie pour cela. Je t'adore.〕　というような甘いことを、実際甘すぎてちょっと日本語では書きにくいのだ、子守歌でも歌って聞かせるような調子でお喋舌りしながら寝かしつけていたのだ。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "神戸へ来て、是非とも岸本の為なければ成らないことは、名古屋に滞在する義雄兄へ宛てた書きにくい手紙を書くことであった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "否でも応でも彼は香港への航海中に書きにくい手紙を書く必要に迫られた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋から取り掛っている旅行記の残部をも完成した上で、その他気に掛る仕事を片付けてしまった上で、それから書きにくい懺悔に着手しようと思い立った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても彼はその書きにくい手紙に自分の思うことの十が一をも言いあらわすことは出来なかった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても岸本は節子の位置をハッキリさせて置きたいと思い、更に義雄兄に宛てて前に送ったよりは一層書きにくい手紙を書きに掛った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のほうではこの相手に対しては短いお返事も書きにくいように思っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "椎が本",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺言書なんてものはコンナ書きにくい、自烈度いものとは知らなかった。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "微妙な心の動きは、わが心の姿さえ、動揺のしやすくて、信実は書きにくいのに、今日の問題の女史をどうして書けよう。",
              "citation": {
                "source": "柳原※子（白蓮）",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちも夜はかきにくいものだろうと思っていた。",
              "citation": {
                "source": "「青眉抄」について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
