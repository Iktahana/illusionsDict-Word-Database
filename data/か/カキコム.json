        "examples": {
          "standard": [
            {
              "text": "大きなラグビーボールを脇にかき込んで、相手のタックルをかわしながら走り抜けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は大事な書類鞄をしっかりとかき込み、雨の中を駅へと急ぐ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "たくさんの荷物を両脇にかき込むようにして、狭い階段を器用に降りていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "to rake in",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
