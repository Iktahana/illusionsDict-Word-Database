        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "センサーで取得した気温の変化を、1分ごとにメモリへ書き込んでいく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "設定変更の内容をフラッシュメモリに書き込む処理には、通常数秒の時間を要する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "サーバーがダウンする直前に、キャッシュされている重要なデータをディスクに書き込む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
