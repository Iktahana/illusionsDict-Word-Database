        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "SNSのコメント欄に、大好きなアーティストへの応援メッセージを書き込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よし、解決策がわかった！」と、攻略サイトの掲示板に新しい情報を書き込む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "匿名掲示板に心ない誹謗中傷を書き込む行為は、決して許されない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "to store",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
