[
  {
    "uuid": "fd9fb3d7-7862-5883-a14b-42f379732757",
    "entry": "書き込む",
    "reading": {
      "primary": "かきこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-他動詞"
      ],
