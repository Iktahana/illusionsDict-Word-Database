      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to fill in (field, entry, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "願書の氏名と住所を、枠からはみ出さないよう丁寧に書き込む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アンケート用紙の自由記述欄に、サービス改善への要望を具体的に書き込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "宅配便の伝票に、届け先の電話番号を忘れずに書き込む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これには「旦那さま」が「彼」になつたので驚ろいてゐるといふやうな經濟鬪爭の最初のシヨツクにあふ少女を作者が捕へて來たことに、既に題材的な制限があるのであるが、それにしてもなほ、現實を剔抉することの不足、主觀を書き込むことの不足が、この作品にそのやうな印象を與へるやうになつたことは爭へないのである。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私が綴方へ眞實を書き込むと必ずよくない結果が起つたのである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのたびに催促名簿へ年月日と氏名を記入し、その返事の有無をも書き込む。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務処理の手順が一新され、江戸以来使われてきた大福帳に代わって、洋式の帳簿にペンで書き込むスタイルが普及しはじめました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばキーボードのどこかが叩かれたらそれを察知するであるとか、画面に文字を出す、記憶装置に情報を書き込むといった類は、何をやるときにも必要になる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私の説明をその儘論文の中へ書き込むのは偽りのない所であった。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは多く材料をそのまま歴史に書き込む方法である。",
              "citation": {
                "source": "支那史學史概要",
                "author": "――史記より清初まで――",
                "note": "青空文庫"
              }
            },
            {
              "text": "参謀が地図の上に赤鉛筆で数字を書き込む。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで□の中に０を書き込む。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして二度三度四度とやりかへすために、本書にインキで書き込むことは控へて、なるべく軟い鉛筆で記入されたいものである。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして二度三度四度とやりかえすために、本書にインキで書き込むことは控えて、なるべく軟い鉛筆で記入されたいものである。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに今日檢査員立會の上で調べた事項を書き込むのである。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱の中を見て、書記はだまつて臺の上の紙に何かを書き込む。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには必要事項が書き込むやうになつてゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『イリヤツド』といへば、ホオマアの傑作で、ざつと一万五千行の長い詩だが、その男は紙の両側に七千五百行づつ克明に書き込むだものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "また同じ頃の或る伊太利人は、十八｜吋平方の紙に、自分の好きな詩を三千行ばかり書き込むで、閑さへあるといつもポケツトから取り出しては、それに読み耽つてゐたといふ事だ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "エンゲルバートのＮＬＳ、サザーランドのスケッチパッド、さらにランド研究所を訪ねた際に見せられた画板にペンで書き込むような入力装置、タブレットも心に残っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "手書きの文字の認識機能まで盛り込んだグレイルなら、ユーザーは紙に数字や文字を書き込む感覚でコンピューターを使うことができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "針金に情報を書き込むワイヤーメモリーを用い、記憶させた検査のためのプログラムをデコーダーを使って読み出すＩＣテスターの頭脳の開発にあたった後藤は、意識しないうちにコンピューターの基礎技術を身につけていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえうまくつなげたとしても、フロッピーディスクにどう情報を書き込むかを決めるコントロール用のソフトウエアもなかったことから、まずこちらから片付けることにした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ＥＰＲＯＭ（Erasable Programable ROM）と呼ばれる特殊なタイプなら、いったん書き込んだ情報を紫外線を照射するなどの処置を施して消してから、再度新しい内容を書き込むことができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "帳面を一人一人に渡しておいて、字面で書き込むだけ。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我知らず鉛筆を口の隅へあてがってそれを舐め舐め待ちかまえていて「親船八十八円ふた十銭」という声がかかるや否や、紙に細かく印刷されているその呼名の下にローマ数字を書き込むのである。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな文句を――さあ、おれに言ってみろ――こんな文句を書き込む場所が他にないのか？",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを持って次の机へ行くと、そこではこのエフの記載を原帳に控え、帳簿の番号をエフに書き込む。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "姓名や階級を聞いて書き込む第一の机には、英語の出来る日本人が坐っていた。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういったことは、翻訳ではなく研究書や別の文章として書くべきものであり、翻訳に書き込むものではありません。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そりゃわかるとも」と、病気の水兵が低音を出す、「死ねば当直日誌へ書き込むんだ。",
              "citation": {
                "source": "グーセフ",
                "author": "ГУСЕВ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによるとね、ある男児は毎日茶碗に飯を容れて、そばに箸をそえておいてやると、生後三年と九ヶ月目に、はじめて、誰も教えないのに、箸をとって茶碗の中の飯をかきこむことをおぼえたと書いてあるよ。",
              "citation": {
                "source": "少年探偵　呉田博士と与一",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで目の前の米粒は西瓜ぐらいに見えるのだそうで、これにいろは四十八文字をかきこむくらい朝めし前です」「たいしたものどすな」「そんな目ってあるもんどすかな」　そこで私と母は、もう一度感心したものである。",
              "citation": {
                "source": "棲霞軒雑記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to post a message (e.g. on a bulletin-board)",
