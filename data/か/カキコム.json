  {
    "uuid": "e798de26-8bf5-5dc8-a3ed-ee05981350ca",
    "entry": "かき込む",
    "reading": {
      "primary": "かきこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to bolt down (food)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「うまい！」と言いながら、彼はだし汁の効いた茶漬けを勢いよく口へかき込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昼休憩の残り時間がわずかなので、牛丼を急いで胃袋にかき込む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "練習後の腹ペコな状態で、山盛りの白飯をかき込む瞬間に一番の幸せを感じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "父親の茶漬けをかき込む音がさらさらと聞こえた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の描いた眼、私の描いた羽根、私が生んだキュウピーさん、冷飯に味噌汁をザクザクかけてかき込む淋しい夜食です。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の描いた瞳、私の描いた羽根、私が生んだキュウピーさん、冷飯に味噌汁をザクザクかけて、かき込む淋しい夜食。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私はまたさらさらと茶漬をかき込む。",
              "citation": {
                "source": "種紙の青む頃",
                "author": "前田夕暮",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘たちがあまり急いで飯をかき込むので、義母は、気を揉みながら、「どうして、そげに矢代さんとこばかりへ遊びに行きたがるんぢやろ」八　老人の放つた嘆声は、田丸の胸をチクリと刺した。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず日本のある学者にノーベル賞をとってもらい、その人を日食につれ出して、何も見えない眼鏡を覗いて手帖にかき込む真似を毎日して貰う。",
              "citation": {
                "source": "英国の物理学界と物理学者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『気をおつけよエミル、叔父さんはお前の兵隊さんの事を本にかき込むかも知れないよ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おじいちゃまの所へいらっしゃいましたの」　女中が答えると、彼は七歳の子供に似合わぬ冷笑の様なものを浮べて、「フン」と云ったきり、御飯をかき込むのであった。",
              "citation": {
                "source": "お勢登場",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふた葉の親子丼をかき込む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の終り来訪の正岡容と馬楽と喋り、ふた葉のそぼろ丼をかき込むと、もう五分前が鳴る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋亭でハヤシライスをかき込むと座へ引返す。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時半に辞し、電車の中でシュウマイと弁当をかき込む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食は楽屋でふた葉の親子丼をかき込む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによるとね、ある男児は毎日茶碗に飯を容れて、そばに箸をそえておいてやると、生後三年と九ヶ月目に、はじめて、誰も教えないのに、箸をとって茶碗の中の飯をかきこむことをおぼえたと書いてあるよ。",
              "citation": {
                "source": "少年探偵　呉田博士と与一",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで目の前の米粒は西瓜ぐらいに見えるのだそうで、これにいろは四十八文字をかきこむくらい朝めし前です」「たいしたものどすな」「そんな目ってあるもんどすかな」　そこで私と母は、もう一度感心したものである。",
              "citation": {
                "source": "棲霞軒雑記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はわたしが出ますからいらっしゃいな」「ええ」と平一郎が飯をかきこむのをお光は、「踊りや歌が好きだからおかしいですね」と冬子に言う。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "貫一は、軽く二杯をかきこむと、急いで席を立とうとした。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪をはじめにかきこむ鋤は、ものすごく大きくて、前へ廂のように出ていた。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "封じ手です」　六時五分、本因坊、紙をうけとり、後方へ横ざまに上体を捩じ倒して、封じ手、六十七手目をかきこむ。",
              "citation": {
                "source": "本因坊・呉清源十番碁観戦記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時も、書類棚からおろしてきた一つかみの書類が食卓の上にあつて、それに目をさらしながら茶漬をかきこむのである。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものを食べるはこの手でござる」胃　「ヤアヤアその手は」一同「くわぬくわぬ」手　「さても桑名の焼蛤、拙者がこうして手で蛤を、もってこっちの手がのびて、つまんで口へ入れるの道理、　　茶わんもつのは左の手、　　はしをもつのは右の手だ、　　茶漬けかきこむ両手の協力。",
              "citation": {
                "source": "狂言『食道楽』",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの書類にはエウドキアって本当の名を書いてくれるわ」「わたしは書類をかきこむために主人にわたしてあるんです」「いつ？",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭一はやっと一杯だけかきこむと、すぐ箸を置いて、二階に行った。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "大判の大学ノートに線をひいて、日づけ、書名、状態をかきこむようにしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "高級といっても、普通が五銭、大丼が十銭、牛のモツを、やたらに、からく煮込んだのを、かけた丼で、熱いのを、フウフウいいながら、かきこむ時は、小さい天国だった。",
              "citation": {
                "source": "浅草を食べる",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
