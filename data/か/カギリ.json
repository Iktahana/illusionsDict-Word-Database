[
  {
    "uuid": "473443f7-e5d4-5e01-b73b-368cc9c93cb4",
    "entry": "限り",
    "reading": {
      "primary": "かぎり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "limit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "人間の体力には限りがあるのだから、適度な休息は不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "予算の許す限り、最新の機材を揃えたいと考えています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "私の知る限り、この付近にコンビニエンスストアはありません。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「まあ、我慢するのにも限りがあるから、無理は禁物だよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "色々と詩論は毎月の雑誌にも現れてをりますが、此の雑誌に訳載中のアランの論文と、それからこれは直ちに詩論と呼べる限りのものではありませんが、フィードレルの芸術論、まづまづ此の二つが此の数年来に読みました詩論の中で心に残つたものであります。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が現状の裡に身を置いて考へる限り、これは正しく運命のいたづらである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の観る限りにおいて、現今社会は恐ろしく修辞的であり、謂はば人々は如才なさ、抜目のなさを獲得しようとする時にばかり、全的に活気を呈するといつた有様である。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "心理的洗練そのものが俗だとはいへまいが、心理的洗練の他に精神的渇望だの信念だのと呼ばれるものがない限り、人は俗物たらざるを得まい。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてさうである限り、新短歌も短歌と共に今後の発展を約束されるものではないとみねばなるまい。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "之の欠乏する限り、対人せる場合に現はれる感情も、飢えた獣の感情に似る他はないのではあるまいか。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、之の欠乏する限り、判断といふものもひどく相対的にしか行はれないのではあるまいか。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、尠くも批判が発展する限りに於て、彼は生甲斐を感ずる次第だ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その廊下を歩く限りの人が、その条の右か左かを通るんだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手紙をともかく「手紙といふもの」と考へる限り、手紙の価値判断はたちどころに混乱して来るのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "現今私の知る限り文士くらゐ小児病的なものはない。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまれ、フォルムに就いての理念が生ぜざる限り、アマチュアであり、またアマチュアとしてさへが、文学芸術に興じたのではなく、知ることの喜びを文学に於ても得てゐるといふに過ぎないことを分らねばならない。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "全一的な一つの持続ぶりを示したものでない限り、それの存在してゐる姿といふものはないのだし、つまり歴史に参与するものではないのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自体芸術といふものは、それが研究の対象とされる限りに於ては如何にも科学的に闡明され得るものではあれ、制作される限りでは、生れるものであつて生むものではないのである。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白い限りでは人は寧ろニガムシつぶした顔をする。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の意志や感情やを、真によく対手に呑み込んでもらうためには、対手が自分の親友｜知己であり、自分の心持ちや性格やを、充分によく知っているものでない限り百万言を費して無駄になる場合が多い。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンが学校に行ってる間、夫人は暇を盗んで熱心に読書をし、手の及ぶ限り、日本の古い伝説や怪談の本を漁りよんだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "つねに、自身にできる限りの範囲で、それを為し遂げるように努力すべきだと思います。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はいのちをことし一年限りとして Le Pirate に僕の全部の運命を賭ける。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小生は不精だから、人の事に就いて自動的には働かないが、言いつけられた限りの事は、やってもよい。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見ることを見ること」が不可能な限り、自己の叫びの当の対象を、これと指示することは出来ない。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見ることを見ること」が不可能な限り、自分の叫びの当の対象をこれだと指示することが出来ない時、さしあたつて表現を可能にするものが、かの夢想的過程にあると見られる。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして五六年目頃までは、年々、一等は一等でもその一等が目に見えて立派さを加へて行くのだが、その五六年を過ぎてしまふと、一等賞の関東地方の地図は年々おんなじ位の出来｜栄となり、もうその村が格段開けるとかなんとかしない限り、その出来栄は大体変らないといふのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "期待がこれと口に云へない場合にも期待がある限り期待が期待してゐるなんらかの型、といふものはあるのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもない限り、思念の深い人にはなるとも、詩人とはならない。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、絵といふからには絵具や画布、大工といふには槌や鉋、まづその道具ですることが面白いのでない限りそのこととはならないのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "又一方、大衆としては、詩といふ型がハツキリしてゐない限り、詩に詩以外の物をも要求してかゝる場合があるのだし、無理からぬことでもある。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩といふものが、恰度帽子と云へば中折も鳥打もあるのに、帽子と聞くが早いか「ああいふもの」とハツキリ分るやうに分らない限り、詩は世間に喜ばれるも、喜ばれないも不振も隆盛もないものである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大衆の通念の中に位置しない限り、算出される詩の非凡と平凡とを問はず、詩の用途といふものはなく、あるとすれば何か他の物の代用としての用途をしかしてゐないと云へるのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "釜石よりの帰り宮沢賢治かぎりなく鳥はすだけどこゝろこそいとそゞろなれ竹行李小きをになひ雲しろき飯場を出でぬみちのべにしやが花さけばかうもりの柄こそわびしきかすかなる霧雨ふりて丘はたゞいちめんの青谷あひの細き棚田に積まれつゝ廐肥もぬれたり",
              "citation": {
                "source": "釜石よりの帰り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "degree",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "力の限りを尽くして戦いましたが、惜しくも一歩及びませんでした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "声の限りを振り絞って、スタンドから選手たちにエールを送る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "命ある限り、私はこの研究を続けていくつもりです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よし、今日は時間の許す限り、君の話を聞くことにするよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "the end",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今年限りで、この伝統ある祭りが幕を閉じることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "今日を限りとお別れするつもりでしたが、やはり未練が残ります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼がマウンドに立つのは、恐らく今シーズンが限りだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、そうなんだ。この限定ショップって、明日が限りなんだね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 4,
        "gloss": "as long as ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この契約書にサインをしない限り、鍵を渡すわけにはいきません。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "あなたが誠意を見せてくれる限り、私も最大限の協力を惜しまない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雨が降らない限り、明日の運動会は予定通り開催されます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ははは、君がそうやって笑っている限り、僕らは大丈夫だよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 5,
        "gloss": "unless ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "何か特別な事情がない限り、欠席する場合は前日までに連絡してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "よほどのことがない限り、彼は約束の時間に遅れることはない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "本人の同意が得られない限り、個人情報を開示することはできません。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ん？特に指定がない限り、服装は自由でいいんだよね？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 6,
        "gloss": "(not) included in ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "原則として撮影は禁止ですが、この展示室に限って許可されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "以前の決定は、今回の新ルールが適用される場合はこの限りではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "規定により、週末の利用についてはこの限りではありませんのでご注意ください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ほら、会員証を忘れた場合はこの限りじゃないって書いてあるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 7,
        "gloss": "being very much (in a certain state)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長年の夢が叶い、プロの舞台に立てるなんて嬉しい限りです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "あのような素晴らしい演技を間近で見られて、羨ましい限りだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "不慣れな土地で皆様に助けていただき、心強い限りでございます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わあ、こんなに立派な表彰状をいただけるなんて、光栄な限りです！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 8,
        "gloss": "... only (e.g. \"one time only\", \"today only\")",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "本日限りの特別価格となっておりますので、ぜひお買い求めください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一家族につき一点限りの販売とさせていただきます。",
