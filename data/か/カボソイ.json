    "definitions": [
      {
        "index": 1,
        "gloss": "thin",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は生まれつき体がとてもか細い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "か細い枝が風に揺れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の書く文字は、か細い線で美しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "『十九‥‥‥』と、長い間を置いて、お前はやつと『九』が聞えるばかりのか細い聲で續けて、深い息を吸つた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は、砂の上に寝ころんで、はるかに、赤と青とのだんだら縞の水着を着た彼女のか細い腕が、抜き手を切って波と戯れているのを、不思議そうに見物していました。",
              "citation": {
                "source": "恋",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "杏平はか細い肉体と鋭い感受性とを持つてゐた。",
              "citation": {
                "source": "登つていつた少年",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「寝ていなさるが枕頭に嬢様呼んで何か細い声で話をしておいでるようで……」「そうか」「まア上って晩まで遊んでおいでなされませえの」「晩にでも来る！",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、死ぬ前の晩、八重子はか細い声で木崎を蚊帳の中に呼び入れて、「短い縁だったわね」　ポロリと涙を落して、木崎の頭髪を撫でていたが、急にはげしく燃えた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その枯れすすきのなかに何だか細い路らしいものがあるので、何ごころなく透かしてみると、そこの一面に生い茂っているすすきの奥に五、六本の橡や栗の大木に取り囲まれた小屋のようなものが低くみえた。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段へ向かう途中、ホームズの高くか細い声で、譫言のような歌が聞こえてくる。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも買う奴と違うて、何に使うてよいかわからぬ、珍らしい子供じゃというから、わざわざ連れて来させてみれば、色の蒼ざめた、か細い童どもじゃ。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、やがてその樽が、終に軽々と成り放しになつて、鉛筆のやうにか細いわたしの腕でも持ちあがつて、振つて見ても、恍惚たる液体の一滴の音も聞えなくなつて――。",
              "citation": {
                "source": "書斎を棄てゝ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車はいつか細い狭い通りを此方から向うへ抜けやう抜けやうとして努力してゐた。",
              "citation": {
                "source": "一室",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "か細い女の身で大きな箪笥を横背負に背負ひ込んで山手の方へ青田中を急いでゐる者や、米俵を引つ擔いで走つてゐる若者などが入り亂れて見えてゐた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "地震日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "年とつた製粉場主はランキン夫人からチエスタ孃の話を聞いて、健氣にも自活の道を立てゝゐるそのか細い、孤獨の娘に直ぐ心を惹かれるやうになつた。",
              "citation": {
                "source": "水車のある教會",
                "author": "オウ・ヘンリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はだから、渡や工藤や龍吉さういふ人達の一擧一動にか細い注意を拂つて自分の態度に、意識的に過ぎるとさへ思はれる程鞭を加へてきてゐた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにも、天文部からは刻々に火星のロケット艦の接近が、か細い声によって報告されてくるのだった。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはか細いひと筋の巻鬚に、自分のすばらしい体重と生命とを賭けてぶら下つてゐるものでなければわからぬことだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの白い壁に何か細い棒を一本一本刺し込んでやつたらどんなものだらう……私はそんなことを空想した。",
              "citation": {
                "source": "ジガ蜂",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは貧民救済医院といったもので、資金が朝鮮の労働者たちのか細い懐から出ているだけに、朝鮮人にはいろいろ特典があった。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は爺にか細い声で何処から来たのかと質ねた。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜻蛉の青い、西洋人のやうな眼玉は、鏡のやうに光つてゐて、何か細いものがキラキラと美しく映つてゐた。",
              "citation": {
                "source": "四郎と口笛",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "八畳の座敷の南よりの、か細い一本の柱に、たつた一つの脊をよせかけて、其前に、お寺から拝借して来た小さい低い四角な机を一つ置いて、お天気のよい日でも、雨がしと／＼降る日でも、風がざわ／＼吹く日でも、一日中、朝から黙つて一人で坐つて居ります。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "八畳の座敷の南よりの、か細い一本の柱に、たつた一つの脊をよせかけて、其前に、お寺から拝借して来た小さい低い四角な机を一つ置いて、お天気のよい日でも、雨がしと／＼降る日でも、風がざわ／＼吹く日でも、一日中、朝から黙つて一人で座つて居ります。",
              "citation": {
                "source": "海",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の耳にふと、娘たちの群れにまじつたオクサーナの声と、彼女のか細い笑ひ声が聞えた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "………三　或雪の晴れ上った午後、二十四五の女が一人、か細い男の子の手を引いたまま、引き窓越しに青空の見える堀越家の台所へ顔を出した。",
              "citation": {
                "source": "玄鶴山房",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "武夫は彼の勉強部屋の隅に、――玄関の隣の四畳半の隅にか細い文太郎を押しつけた上、さんざん打ったり蹴ったりした。",
              "citation": {
                "source": "玄鶴山房",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると、か細い黒犬が一匹、どこからか書斎へはいって来た。",
              "citation": {
                "source": "三つのなぜ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、怨もうにも怨めぬこの憎さは、天から転がり下った宿命の糸に見え、少女のか細い肩の間から徐ろに廻って来る光りの瞬きも、ますます父の最後の笑顔をほのかに浮き出す灯火のように、愁いを含んで射しこもって来るのだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗戦の憂きめをじっと、このか細い花茎だけが支えてくれているようだ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌の如きもその精神のあらはれで、従来のか細い淋しい又はじみな日本的なものを揚棄して、一躍してインド的なギリシア的な積極性の中へ踊り込んだものである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論かういふことは、これと明確に云へることではないが、今仮りに手短かに云つてみるならば、短歌・俳句は、その形の大小を云ふのではないが、はやかぼそい歌声と我等が耳に響くのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八、九のはてれ隠しに自分の守り児のかぼそい女の児を抱き上げて、　――芝居季節が近づいたんでこの子のお母さん巴里へ帰って来るってさ。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
