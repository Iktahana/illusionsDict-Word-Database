[
  {
    "uuid": "b3c9a3f0-74d9-5dc0-acf8-3b49bf0306a2",
    "entry": "家族制度",
    "reading": {
      "primary": "かぞくせいど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
