        "examples": {
          "standard": [
            {
              "text": "活字印刷の発明は、知識の普及に革命をもたらした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "グーテンベルクは、ヨーロッパにおける活字印刷の父とされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "現代ではデジタル印刷が主流だが、活字印刷の技術も息づいている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "マインツの金細工師、ヨハネス・グーテンベルクは、鋳造した活字に油性のインクを塗り、ブドウ絞り機を改良したプレスで印刷するという、活字印刷の技術を確立したとして記憶されています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "活字印刷がその頃に発明され多数の本が作られ手写本よりも安価であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
