        "examples": {
          "standard": [
            {
              "text": "ああ、この微積分、普通の電卓じゃ無理だ。関数電卓持ってくればよかったな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大学の工学部では、試験に持ち込み可能な関数電卓の種類が指定されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私はいつも机の上にプログラミング機能付きの関数電卓を置いて、ちょっとした計算に重宝していますよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "高度な機能を備えた関数電卓には使われているものの、数から見ればとても勝負にならない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなことなら、同じお金を払って関数電卓でも買っておいた方が、よほど役に立ったのに」と、思わず愚痴りたくなった人も多かったろう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
