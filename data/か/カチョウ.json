    },
    "definitions": [
      {
        "index": 1,
        "gloss": "flowers and birds",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は花鳥風月を愛でる風流な人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "屏風には、見事な花鳥の絵が描かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その庭は四季折々の花鳥が訪れ、いつも賑やかだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "尤もある画を見ると色彩については線法や構図に対するほどの苦心はしていないかと思われるのもないではないが、しかし簡単な花鳥の小品などを見ても一見何らの奇もないような配色の中に到底在来の南画家の考え及ばないと思われる創見的な点を発見する事が出来る。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれと同じような絵で、もっと好いのを前にどこか他所で見たような気がし出して来ると、私の眼は自然にその隣りの小型の美人画や花鳥画に移って行ったりする。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或はまた純東洋風の文人として、花鳥風月の趣味に遊ぶ、悟りすました人物のやうにも印象させる。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の間に山水花鳥の掛け物をかけるのもまたそのバリアチオンと考えられなくもない。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうふうな立場から見れば「花鳥諷詠」とか「実相観入」とか「写生」とか「真実」とかいうようないろいろなモットーも皆一つのことのいろいろな面を言い現わす言葉のように思われて来るのである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし俳句が短歌とちがうと思われる点は、上にも述べたように花鳥風月と合体した作者自身をもう一段高い地位に立った第二の自分が客観し認識しているようなところがある。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻物に描かれた雲や波や風景や花鳥は、その背景となり、モンタージュとなり、雰囲気となり、そうしてきたるべき次の場面への予感を醸成する。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "百貫目の利銀には今すこしは思ふまゝなるべきところを、いかな／＼然はせずして心を心にいましめ、なまなかの遊びを思はず、只花鳥に物好をあらためて、宗因の孫西山昌札の門弟となり、連歌を仕習ふ。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの人は一見乾燥なように見える抽象的系統の中に花鳥風月の美しさとは、少し種類のちがった、もう少し歯ごたえのある美しさを、把握しないまでも少なくも瞥見する事ができるだろうと思う。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わくに張った絵絹の上に山水や花鳥を描いているのを、子供の私はよくそばで見ていた。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛彫浮彫の花鳥草木……まあ私のお取次ぎは粗雑ですよ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "石榴口には花鳥風月もしくは武者絵などが画いてあって、私のゆく四丁目の湯では、男湯の石榴口に『水滸伝』の花和尚と九紋龍、女湯の石榴口には例の西郷・桐野・篠原の画像が掲げられてあった。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "榛名富士その絶頂を光らしめとがれる松を光らしめ峰に粉雪けぶる日も松に花鳥をつけしめよふるさとの山｜遠遠にくろずむごとく凍る日に天景をさへぬきんでて利根川の上に光らしめ祈るがごとく光らしめ。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花鳥花鳥の日はきたり日はめぐりゆき都に木の芽ついばめり。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああうらうらともえいでて都にわれのかしまだつ遠見にうかぶ花鳥のけしきさへ。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藝術上の遊戲とは必然性なき創作を言ふ、生活を畫くもの必ずしも眞實にあらず花鳥風月を唄ふもの必ずしも遊べるにあらず。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよ、更に光るそが絶頂にも花鳥をつけ。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら通俗の見解は、しばしば詩人を以て花鳥風月の徒と解し、吾人を一種の風流扱いにするからだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、挿絵のサンプルとして、三画伯の花鳥図同封、御撰定のうえ、大体の図柄御指示下されば、幸甚に存上候。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸行無常それ自身、人生の花鳥風月の装いに外なりません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白き花鳥図水禽さながらや、一片の蓮華、浮舟。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "またいつかみそなはす、冬の日の白き花鳥図。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、わたくしは近代の幽玄体を月光と花鳥と古俗との間に、密かに薫醸しようとした。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "『白い花鳥図』『月光の谿』『童話の月』『花楮』等の諸篇の中にさうしたものがある。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "白き花鳥図みづのうへしろがねのさざなみみればくれなゐのはちすのにほひふふむらむ。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにこの頃同じ家に花鳥と云う昼三がいた。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "花鳥は恐るべき経歴を有していた。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "花鳥は廊下で香以に逢うごとに秋波を送った。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夕小稲が名代床へ往って、香以が独無聊に苦んでいると、花鳥の使に禿が来た。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことになると、これでおいらのおしゃべりあごもなかなかちょうほうなんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
