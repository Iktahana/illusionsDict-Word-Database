        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "audible",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "エンジンの異音は、ようやく可聴域に達するほどの小ささだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この周波数の音は、人間の耳には可聴ではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スピーカーの故障により、音量が可聴レベルまで上がらなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "人間の可聴域の上限を突きやぶりそうな周波数で知子が絶叫し、あとはもう、どれがだれの声ともわからない阿鼻叫喚となった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の怪振動は一秒間三十万回の超可聴周波です。",
              "citation": {
                "source": "空中墳墓",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことになると、これでおいらのおしゃべりあごもなかなかちょうほうなんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はほんのわずかの水分しかちょうだいしちゃいませんがね、でもご覧のとおりつやつやと、みずみずしておりますよ。",
              "citation": {
                "source": "アッタレーア・プリンケプス",
