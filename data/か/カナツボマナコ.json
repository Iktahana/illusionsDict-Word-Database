    "definitions": [
      {
        "index": 1,
        "gloss": "goggle-eyes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「えっ、本当！？」と、彼は金壺眼になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "深海魚の、あの金壺眼が印象的だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "突然の発表に、皆が金壺眼で見つめ合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "驚きのあまり、彼女は金壺眼を開いたまま固まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "白粉のその頸を、ぬいと出額の下の、小慧しげに、世智辛く光る金壺眼で、じろりと見越して、「今晩は。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と金壺眼はいよいよ光った。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時来たのか」　かく言ひつつ彼は艶々と赭みたる鉢割の広き額の陰に小く点せる金壺眼を心快げに※きて、妻が例の如く外套を脱するままに立てり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "満枝は心に少く慌てたれど、さしも顕さで、雍かに小腰を屈めて、「おや、お出あそばしまし」「ほほ、これは、毎度お見舞下さつて」　同く慇懃に会釈はすれど、疑も無く反対の意を示せる金壺眼は光を逞う女の横顔を瞥見せり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "直行は又その辛し、恨し、悲しとやうの情に堪へざらんとする満枝が顔をば、窃に金壺眼の一角を溶しつつ眺入るにぞありける。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "呆れ果てたる直行は金壺眼を凝してその泣くを眺むる外はあらざりけり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼は、物を言ふ場合には陰気な金壺眼に、それはもう実に激しく小刻みな眼ばたきを、自分の言葉が止絶れるまでは間断なしに扇風機のやうなスピードで動かせ続けるのであつた。",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "つき出した厚い胸のなかにめりこんだやうな醜い猪首だつたが、眼は――その金壺眼の眼球は、なるほど口さがないわらべどもが後指さしていふとほり（原文五字缺）見えるのである――。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちらの旦那様もお坊ちゃんも金壺眼できょろきょろ御らんになる様子ったら、ほんとうにもの欲しそうですよ。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "金壺眼のお人は慾ばりの性わるですってね。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤児院にも勘坊っていう金壺眼の子がいましてね、それあ慾ばりだった。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "金壺眼の子ってほんとうに性わるですねえ。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "種に云われてみれば、どうも金壺眼の太七を貰う気もしないので、やはり思いは代書屋の倅の方へ走るのである。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ生々としている小さな金壺眼は、まるで二十日鼠が暗い穴から尖がった鼻面を突き出して、耳を欹てたり、髭をピクピク動かしながら、どこかに猫か、悪戯小僧が隠れておりはせぬかと外界を見廻したり、胡散くさそうに空気の匂いまで嗅ぎ廻す時のように、長いげじげじ眉の下からキョトキョトと始終あたりを窺っている。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしたちが座蒲団に乗ると、すぐ間もなく、テラテラした、金壺眼で、すこしお出額の、黒赤い顔の男――子供には、女も男も老人に見えたが、中年人だったのかもしれない――柔らかい袴を穿いて、黒い手｜提げ袋をさげてはいってくると、座蒲団の上に突ったったまま、あんぽんたんを見てそういったのだった。",
              "citation": {
                "source": "鬼眼鏡と鉄屑ぶとり",
                "author": "続旧聞日本橋・その三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく氏は警笛の異様なる響に夢を破られて、金壺眼をこすりこすり玄関先まで出てみたところ、そこにふらふらになって倒れている夫人を見出したのであった。",
              "citation": {
                "source": "奇賊は支払う",
                "author": "烏啼天駆シリーズ・１",
                "note": "青空文庫"
              }
            },
            {
              "text": "会議の時に金壺眼をぐりつかせて、おれを睨めた時は憎い奴だと思つたが、あとで考へると、それも赤シヤツのねち／＼した猫撫声よりはましだ。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "会議の時に金壺眼をぐりつかせて、おれを睨めた時は憎い奴だと思ったが、あとで考えると、それも赤シャツのねちねちした猫撫声よりはましだ。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "此犬はあまり大きくもないが、金壺眼の意地悪い悪相をした犬で、滅多に恐怖と云うものを知らぬ鶴子すら初めて見た時は魘えて泣いた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、酔いが廻ると、縮れ毛｜金壺眼の、鬼のような面相をしたコルシカ人どもは、大々愉快のうちに、タヌに伝授された『タラノ音頭』を合唱するのである。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "タラノ音頭　――コルシカ島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "金壺眼、行儀の悪い鼻、釘抜のようにがっしり飛び出た頬骨、無愛想にへの字を作っている口、今に始まったことではないが、どう見てもあんまり人好きのする容貌ではなかった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "影人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "出ッ張ったおでこの下に、見るからにひとの悪るそうなキョロリとした金壺眼。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "山王祭の大象",
                "note": "青空文庫"
              }
            },
            {
              "text": "金壺眼のしゃくったような下等な面構え。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "押しかえして催促すると、蔵人は光をためた金壺眼で用人の顔を仰ぎ見、重ねて言えば、抜討ちに討って捨てよう眼色であった。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十を少し越した世帯ずれのした男、蟲食い頭の金壺眼で、昼は内職の古道具の店に坐っている男――といったら、その人柄が凡そ見当がつくことでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にはドキドキする鎌を持つて、汚ない布子のジンジン端折り、捻り鉢卷がそのまゝずつこけたやうに、煮締めた手拭を、緩く首に卷いて、恐ろしい無精髯、金壺眼で、狐面で、聲だけは朗々と、威壓と虚勢に馴れた凄いバリトンです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "白梅の精",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛んだ無理を言つて濟まねえ」　富坂の周吉は入口に金壺眼を光らせて居りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青錢と鍵",
                "note": "青空文庫"
              }
            },
            {
              "text": "押入にブラ下がつてゐるのは、四十七、八の薄汚い男、月代が剥げちよろで、高い鼻筋が曲つて、クワツと開いた金壺眼、いかにも繪に描いた貧乏神のやうな感じです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鬼女",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏像を背負って兇賊は逃げた　目明しの三吉は、二本榎の正護院の裏門に突っ立って、もう二刻も金壺眼を光らせて居りました。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第五夜　悪魔の反魂香",
                "note": "青空文庫"
              }
            },
            {
              "text": "不愉快なのでそのままパンジオン（下宿）に帰ると老主婦が大きな腹をつきだし両手をつっぱって腰の所へ手をあてがった姿勢で皺だらけの顔の底にひっこんだ金壺眼をぐりぐりさせる。",
              "citation": {
                "source": "放心教授",
                "author": "森於菟",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
