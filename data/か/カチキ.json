[
  {
    "uuid": "1afaf31f-467e-599b-9ab3-96b2b0a7ffbc",
    "entry": "勝ち気",
    "reading": {
      "primary": "かちき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
