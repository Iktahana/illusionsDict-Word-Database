      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "determined spirit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あの子、本当に勝ち気だね。ゲームでも負けず嫌いで、すぐ泣いちゃうんだから。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の勝ち気な性格は、困難な状況でも諦めない強さにつながっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔から、勝負となると人が変わったように勝ち気になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このスポーツ選手は、その勝ち気なプレーで観客を魅了し続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "もとより勝ち気な女の持ち前として、おとよがかれこれ言うたから省作は深田にいないと世間から言われてはならぬと、極端に力を入れてそれを気にしていた。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸ッ子の女は勝ち気だと云いますから、自然子を生みかねるのでしょう」　こんなのはいずれもうがち過ぎ、又は突飛な議論であるが、参考のため紹介しておく。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉と違って勝ち気に生まれたお竹は、その書置を読まされて身も顫うばかりに憤った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "小女郎狐",
                "note": "青空文庫"
              }
            },
            {
              "text": "袋地所で、表は狭く却って裏で間口の広い家であったから、勝ち気な母も不気味がったのは無理のない事だ。",
              "citation": {
                "source": "犬のはじまり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "邸の修理をさせ、勝ち気な御息所が旧態を保たせていたとはいうものの、行き届かない所のあった家の中を、みがき出したように美しくして、壁代、屏風、几帳、帳台、昼の座席なども最も高雅な、洗練された趣味で製作させるように命じてあった。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧二",
                "note": "青空文庫"
              }
            },
            {
              "text": "質実な素朴な、心の細やかそうな、そして勝ち気らしい印象を受けた。",
              "citation": {
                "source": "旧師の家",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こういうことをパリで別れる際、ただ一言云った千鶴子の勝ち気のためかあるいはカソリックの仕業であろうか、とにかく今の矢代にはこれだけが分らぬことの一つだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾来十五年間、三人の兄妹は勝ち気な未亡人の手によって、ことし健吉くんが二十七歳、保一くんが二十四歳、きよ子嬢が二十二歳になるまで無事に育て上げられました。",
              "citation": {
                "source": "愚人の毒",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、いかに勝ち気の未亡人でも人間の性質というものはいかんともすることができなかったと見え、二男の保一くんは兄とはすこぶる違って、いわば不良性を帯びてきたのであります。",
              "citation": {
                "source": "愚人の毒",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、未亡人は勝ち気な人であるだけ一面はなはだ頑固であって、保一くんが請け出した女と手を切らぬ間は決してふたたび会わないと言って、健吉くんやきよ子嬢が何度頼んでもどうしても聞き入れず、ついに今回の悲劇が起こるまで勘当の状態が続いたのでした。",
              "citation": {
                "source": "愚人の毒",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい若い勝ち気な女で、人もなげに振る舞うこともあったが、それだけ万事に気が付いて、浮世の表裏をよく知っている女、そう云った女に異存はなかった。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝ち気の達吉は、同じ年ごろの少年が学校へいくのを見たりすると、うらやむかわりに、夜も、疲れた体を小さな机の前にもたせて、航空雑誌を読んだり、地理や、歴史を復習したりしていました。",
              "citation": {
                "source": "僕はこれからだ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子とけんかをしても、泣いたことのない勝ち気な子だったが、どうしたろうか。",
              "citation": {
                "source": "こま",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "性質は、正直で、いたって、さっぱりしていますが、すこし勝ち気ですから、そんなところも、お含みおきくださいまして、よろしくお世話いただきとうぞんじます。",
              "citation": {
                "source": "おさくの話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、お春のような勝ち気な女は、大嫌いでございます」　今まで堪えに堪えていたのであろう。",
              "citation": {
                "source": "乳を刺す",
                "author": "黒門町伝七捕物帳",
                "note": "青空文庫"
              }
            },
            {
              "text": "この話によって我々は彼女の勝ち気で強情な、強い性格を知ることができる。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし我々にとっては、それは女らしい勝ち気以上の何物でもない。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種の勝ち気の例は、このほかにもなお少なくない。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その青白い皮膚の色と、つめたい、鋭い眼の光とは、むしろ神経質な知識人を思わせ、また一方では、勝ち気で、ねばっこい、残忍な実務家を思わせた。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "おゆみは妹たちより際立って美しく、勝ち気でお侠なところはあったが、思いやりのふかい性分で、みんなに好かれた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "狂女の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆらい日本の女性は、ひとえに内向的で内気な弱い花といわれてきたが、この藤三娘（藤原氏の三女のいみ）の書の勝ち気で自由奔放なふうは、現代の日本女性にも負けていない。",
              "citation": {
                "source": "正倉院展を観る",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "色が黒く、小柄で、縹緻もかなりいいし、勝ち気ですばしこくて、手も口も達者だった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小麦色の細おもてに、眉が濃く、眼尻のあがった、いかにも勝ち気らしい顔だちであるが、小さい肩や、そこだけ緊って肉づいた腰つきなどに、洗練された嬌めかしさと色気が感じられた。",
              "citation": {
                "source": "葦は見ていた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木場は気ふうの荒いところであり、おりうはひとり娘だったから、しぜんと勝ち気になり、幼ないころから、自分が女であることを常に呪わしく思って育った。",
              "citation": {
                "source": "滝口",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぐい稀な勝ち気で、男の子とよくつかみあいの喧嘩をし、多くの場合おりつが勝った。",
              "citation": {
                "source": "ちいさこべ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜のような派手な勝ち気な悧発な女が、どうしてこう云う憂鬱な、殊勝な姿を見せることが出来るのであろう。",
              "citation": {
                "source": "秘密",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "但しひじょうに勝ち気が強く、少しでも機嫌に障ることがあると、それこそ眼球がとび出すようなめにあわされるので、さすが父親の図書助も彼女だけには頭があがらないというのであった。",
              "citation": {
                "source": "半之助祝言",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも勝ち気らしかった。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし勝ち気な性分で、そんな顔色をみせては、自分の負けだと思ったのだろう。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと侍の妻になったかと思うと、もうその努力の結果は、歴史の怒濤に泡となって消え去ってゆくのを見送らなければならないような、かちきな母瀧子の生活感情には、開化の声が、快く希望を唆る響としてはきこえず、世相の浮き沈みとして反映したであろう。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
