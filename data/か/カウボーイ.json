    "definitions": [
      {
        "index": 1,
        "gloss": "cowboy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はまるで西部劇から飛び出してきたようなカウボーイの格好をしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "モンタナの広大な牧場には、今も現役のカウボーイたちがいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、カウボーイになって馬を乗りこなすのが夢だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ジーンズにテンガロンハットを合わせたカウボーイスタイルは、彼の定番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それは、カウボーイの土地である。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰にピストルをつけ、カウボーイと馬に騎り、小学生のときからひとの台処で働かねばならなかったアグネスの強壮な体の中を奔放に流れている熱い血がある。",
              "citation": {
                "source": "中国に於ける二人のアメリカ婦人",
                "author": "――アグネス・スメドレーとパァル・バック――",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばアメリカのカウボーイの冠っているもの、あるいは日本の青年団とか少年団とかいう種類の男たちの冠っている帽子などは私の嫌いなものの代表であります、アメリカものの活動写真などを見ると、きっとあの帽子を着た男が現われますので閉口します。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ震災前で、カウボーイ物や、探偵の続き物が全盛だった頃だと思います。",
              "citation": {
                "source": "歪んだ夢",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカに彼が興味をもつのは、アメリカが、カウボーイの時代から、金を儲けた時代を経て、今、新しいインテリゲンチャをつくりつつある、その明るさ、活動的さ、人生にプラクティカルにぶつかって行くテクニック、そういうものに興味があるらしい。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "すごいガニ股で、妙に上半身を振って歩くと思ったら、カウボーイが職業だった。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カウボーイや坑夫よりも、その方の心得があったのも自然である。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カウボーイのやうに逞しい青年ですもの。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界的歌手の窓下で、ハーモニカを吹く大胆者は、多分少し低能な不良少年で、ラッパ形のズボンでもはいて、カウボーイ風の帽子でも冠っているだろうと思ったのですが、実物を見ると、どうしてどうしてそんな厭らしいものではありません。",
              "citation": {
                "source": "焔の中に歌う",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以降の彫刻は、アメリカ西部の野生馬がカウボーイに飼いならされたように、ショゴスが武装した古きものどもに飼いならされあるいは破壊された一時期を示していた。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーボロの広告をかねたもので、例のカウボーイが投げ縄を持ってポーズしている下に、ストア・アローズが表示してあった。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "パニオロとは、ハワイ語でカウボーイのことだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がさきほど途中で見た牧場で、彼は少年の頃からカウボーイとして働いてきた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カウボーイであると同時に、パニオロはミュージシャンでもある。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃の僕は、『ワンダーランド』そしてその続きの『宝島』で、『ロンサム・カウボーイ』というタイトルのもとに、文章を連載していた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕にとって小説のデビュー作は、『ロンサム・カウボーイ』だ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "『野生時代』の創刊号に書いた短篇は、この『ロンサム・カウボーイ』の延長線上に位置するものだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "『野生時代』という文芸雑誌の創刊号に書く小説として、『ロンサム・カウボーイ』の延長線上の、ハワイの波乗りの話しか、僕は書くことが出来なかった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ロンサム・カウボーイ』は映画フィルムのなかの映像を言葉で書き写したものだ、と僕は理解している。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ロンサム・カウボーイ』の延長線上に『波乗りの島』があるというのは、まずなによりも先に、このような意味においてだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたつ目は、ハリウッドの映画と結びついた結果の、西部フロンティアあるいはカウボーイのイメージとの重なりあいだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、日本でもそうだが、カントリー・ミュージックは、カウボーイ・ソングあるいはウエスタン、と呼ばれることが多い。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二次大戦のときまでに、カウボーイはすでにアメリカの美しい伝説のなかの、孤独なヒーローだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カウボーイとカントリー・ミュージックのコマーシャルな結びつきは、一九二四年、オットー・グレイのオクラホマ・カウボーイにすでにみられるのだが、マス・アート（大量生産商品的な芸術）としてのウエスタンのはじまりは、ジーン（オルヴォン）・オートリイだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "シアズ・ローバックのカタログにのせられて、シンギング・カウボーイとしてのオートリイのイメージは、強力にひろがった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョン・フォードの初期の映画は、伝統的なほうのカウボーイ・ソングを、音楽に用いていた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "オートリイのハリウッド第一作ができる五、六年まえから、ドラマを前にすすめていく力として、劇中にカウボーイ・ソングがうたわれるということが、普通のこととして、西部劇ではおこなわれていた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりで何日もぶっつづけに草原で馬や牛を追って暮らしているカウボーイにも、おなじようなところがある。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "６　ロックンロールとカウボーイ・ブーツ　一九六〇年は、アメリカのロックンロールにとって、最低の年だったといわれている。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
