[
  {
    "uuid": "2a246177-211e-5091-9c80-4a2b8baf433b",
    "entry": "賭け碁",
    "reading": {
      "primary": "かけご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "playing go for stakes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔の碁会所の隅では、わずかな小銭を賭けた賭け碁が常連客の間で密かに行われていたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おい、この一局に今日の昼飯を賭けないか？」と誘われ、冗談半分で賭け碁が始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "真剣勝負の賭け碁に負けた男は、代金が払えず、愛用の碁盤を質に入れなければならなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "田舎碁打じゃアあるまいし、賭け碁で江戸の天狗連を総ナメの甚八が、この筋を見落すとは！",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かあるんじゃないかな」　と、そこは生馬の目をぬく賭け碁の大家甚八、鋭い眼力で、なんとなく怪しい気配を感づいた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつァいけねえと思いついて、邸内の人間を相手にせずに、散歩のフリをして村人から事情をきいて廻ったのはさすがに賭け碁の名人。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚八も賭け碁で一生きたえあげた眼力、人生表裏に相当徹しているツモリであるが、こうワケがわからなくては、ハイ、わかりません、で引ッこむわけに行くものではない。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧侶をあいてに天皇が、賭け碁をしたりしておいでになる。",
              "citation": {
                "source": "天皇と競馬",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧侶をあひてに天皇が、賭け碁をしたりしておいでになる。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」のかけごえのみ盛大の、里見、島崎などの姓名によりて代表せられる老作家たちの剣術先生的硬直を避けた。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんださか、こんなさか、なんださか、こんなさか」　元気の好いかけごえばかりで、汽缶車はなかなか進めないのです。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こんな風にして、密輸入者レッド老人とワイトマン税関吏の追いかけごっこを書いてゆくと、何処まで行ってもキリがない。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたかたに言ひもてゆけば玉櫛笥わがみはなれぬかけごなりけり　と老人の慄えた字でお書きになったのを、ちょうど源氏も玉鬘のほうにいて、いろいろな式のことの指図をしていた時であったから拝見した。",
              "citation": {
                "source": "源氏物語",
                "author": "行幸",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾百とも知れぬ海ひょうが、うららかな春の日に腹をほして、あおむけに寝ころんだり、たがいにだきあってはころげおちたり、追いかけごっこをしてはかみあったり、なにかにおどろいたように首をあげては走って、波にとびこんだりしている。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "揚幕が上って、彼は、かけごえに迎えられて、花道をふんで行った。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでも、幻影か」　Ｘ大使は、とつぜん私の方に近づき、私が身をかわそうとするのを先まわりして、やっと、かけごえをして、私の腕を掴んだ。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな或る日、きょうは学校の前までで好いからと言って附いて来て貰った母と一緒に、私は運動場の入口に近いところで、始業の鐘のなるまで、皆がわあわあ云いながら追っかけごっこをしたり、環になって遊んでいるのを、ただもう上気したようになって見ていた。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "うたうようにかけごえをして、おどるようにはねながら。",
              "citation": {
                "source": "月夜のかくれんぼ",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トロ／＼トロ／＼と追つかけごつこがはじまりました。",
              "citation": {
                "source": "文化村を襲つた子供",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、丸木が、「どっこいしょ」　と、かけごえをしたと思うと、千二の体は袋にはいったまま宙に浮いた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「よーう」　と、黒人はかけごえして、使いなれた複雑な機械をあやつりはじめました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっとかけごえをかけ、のこぎり山の頂上の岩の間から、向こうをひょいとながめました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "針路は真東だ」　えいえいのかけごえもいさましく、四艘のボートは、暗い海上をこぎだした。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "是等のかけごとは戦前ヨーロッパではいずれもなかなか盛であり皆が人間通有の賭博的興味？",
              "citation": {
                "source": "安吾人生案内",
                "author": "その五　衆生開眼",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なによりも、殺生とかけごとが、大好きだなんて、困った性分さ。",
              "citation": {
                "source": "春はよみがえる",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "正吉は、自分の知るだけのことを、くわしく話して、「青服は、自分の口から、かけごとと殺生がなにより大好きだというのだから、やさしい顔はしていませんよ。",
              "citation": {
                "source": "春はよみがえる",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことじゃつかめませんよ」　求婚者（第二主題）はようやくあたし（第一主題）に追いついて楽しそうに追いかけごっこをする。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでだしぬけに新しい第三の主題が割りこんできて追いかけごっこの邪魔をする。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」なんて　かけごえも　いらなくて、　みんな　すきなときに　はしりだせばいいし、　すきなときに　やめていい。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "天竺ねずみは天竺ねずみは追っかけごっこがだいすきだ。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "与えないのみならず、あらゆる野卑と、悪戯と、不行作と、かけごと勝負と、だまし合いとを奨励して興がるかの如く見ゆる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と　いう　やかましい　かけごえが　きこえて、うしろから　だいみょうぎょうれつが　やってきました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらが勝つか、勝ってもまけてもたのしいかけごとです。",
              "citation": {
                "source": "柿の木のある家",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
