[
  {
    "uuid": "a37af848-a4cb-50d4-9b51-a4bebba5a2b8",
    "entry": "観客",
    "reading": {
      "primary": "かんきゃく",
      "alternatives": [
        "かんかく"
      ],
      "is_heteronym": false
    },
    "grammar": {
