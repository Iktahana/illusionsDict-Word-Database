        "examples": {
          "standard": [
            {
              "text": "彼はブラジルのカサブランカで生まれ育ったと話していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カサブランカはサンパウロ州にある小さな町だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カサブランカはコーヒー栽培が盛んな地域として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今年はカサブランカのコーヒー豆を試してみたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ワシントン、カサブランカ、ローマ、ベルリン、東京湾と順々にあげた偉大な星条旗を虎ノ門のアメリカ大使館の屋上のポールにあげるためにランチで運んでいるところだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺には骨棘は無い」　日が暮れると彼は、自信をつけようとして、カサブランカの酒場での出来事を思い起こした。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
