        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "老舗の人形店には、歴史を感じさせるからくり人形が並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そのからくり人形は、お茶を運ぶ姿がとても愛らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "舞台で演じられるからくり人形劇は、子供たちに大人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は失われたからくり人形の技術を現代に蘇らせようとしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「おほきなからくり人形だ」と云つて見たが、かの女は目を横に向けたまま、なほ口を固く結んでゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "※子も亦たった一度でもお久美さんに話す時を得たさに居たくもない所に座って、仕たくもない――平常なら此方から頭を下げても仕たく様な下らない馬鹿話しをからくり人形の様に、無神経な木偶の様にぐずぐずと喋って居なければならなかった。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビエルヂバブ閣下事には、ネクタイの中より取り出しめさるゝ空を睨んで容子振る、幾つもの黒くて小さなからくり人形、さてそれらの額の辺りを、古靴の底でポンと叩いて、踊らしめさるゝ、踊らしめさるゝ、ノエル爺の音に合せて！",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "機嫌そこねた｜からくり人形事には華車な腕をば絡ませ合つて、黒い大きなオルガンのやう、昔綺麗な乙女達が胸にあててた胸当のやう、醜い恋のいざこざにいつまで衝突合ふのです。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "只、金を通して、金の周圍に、すばらしい、同時にえたいの知れない不可思議な力を持つたからくり人形が、どし／＼と跫音高く濶歩してゐるのを感ずるだけであつた。",
              "citation": {
                "source": "天國の記録",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当座は、悲しいとか、怨めしいとかいうのをとおり越して、何の判断力もなく、まるでからくり人形のように、家の中をうろつきまわったものである。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　仙吉は、その時まで、すっかり肚胆をぬかれたような恰好で、店の上り框に突っ立ち、次郎の方をぽかんと眺めていたが、女にそう言われると、まるでからくり人形のように、ぴょこり頭をさげた。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄極楽からくり人形、大江山酒天童子電気人形、女剣舞、玉乗り、猿芝居、曲馬、因果物、熊娘、牛娘、角男、それらの大｜天幕張りの間々には、おでんや、氷屋、みかん水、薄荷水、十銭均一のおもちゃ屋に、風船屋などの小屋台が、ウジャウジャとかたまっている。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く歩けッ」　門番にどなられて、万吉は初めてハッと吾にかえり、からくり人形のように、春風の中へ、ふわりと足を運びだした。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
