[
  {
    "uuid": "db58fed5-b0c5-5d25-a57f-5d4b3ee868ce",
    "entry": "掛け合う",
    "reading": {
      "primary": "かけあう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
