        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「冷たっ！ やめろよ！」と言いながら、子供たちがプールで水を掛け合っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "真夏の祭りの熱気の中で、人々が威勢よくお互いに清めの水を掛け合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "海岸を走りながら、楽しそうに海水を掛け合うカップルの姿が微笑ましかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "優勝が決まった瞬間に、選手たちはシャンパンを掛け合って最高の喜びを爆発させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
