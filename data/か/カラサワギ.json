[
  {
    "uuid": "eb5b639d-ef17-5258-b387-f1334ca81381",
    "entry": "空騒ぎ",
    "reading": {
      "primary": "からさわぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "making a fuss (about nothing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大したことないのに、みんなで大声で怒鳴り合って、ただの空騒ぎだったね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちが何かで揉めてたけど、先生が来たら急に静かになった。まったく、空騒ぎってやつだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの政治家のスキャンダル、結局何も証拠が出なくて、ただの空騒ぎに終わったな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「大変だ！」って叫んでたけど、ただの地震速報だった。危ない危ない、空騒ぎになるところだったよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "愚かなるわれら杞人の後裔から見れば、ひそかに垣根の外に忍び寄る虎や獅子の大群を忘れて油虫やねずみを追い駆け回し、はたきやすりこ木を振り回して空騒ぎをやっているような気がするかもしれない。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎座の時には、ただもうわくわくして、空騒ぎをしたものだが、こんどは、もう冗談ではない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼんやりとではあるが、〔十五字伏字〕投資している資本家どもの利益になるばかりだと分って、新聞の空騒ぎに対して一般的な反感があった。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は堅実な英国人の間に起つた婦人運動が決して空騒ぎで終らない事を信じる。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『政治なんて空騒ぎして居る間に、肝腎の人が皆んな亡んぢまつた』と、翁が腕拱いたまゝ喪心者の如く独語されるのを、予は屡々聞いた。",
              "citation": {
                "source": "大野人",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "この諺は前触れが大変で、実際は空騒ぎに詰らなく終つた物ごとに言ふのである。",
              "citation": {
                "source": "津軽地方特有の俚諺",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我輩なぞは天下国家をどうするとかこうするとか、無闇に粗大な迂闊な問題にばかり空騒ぎをして自分の腹の中を治める事が出来なかったのです。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとうに変な具合で、なんだか皆んな莫迦々々しいやうだね……」　玄也夫妻の噂をはぢめると、総江はどうしても包みきれずに空騒ぎのやうなハシャギやうをして、大変坐りの不確かな落付かない風をし乍ら、喋つたり笑つたり又間の抜けた顔をしたり、といふ有様であつた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙にハシャぎすぎて、ふと気が附いて控えてみたりするものの、そのうちには控えることも臆劫になり、殊更てれかくしに空騒ぎの輪をかけたりした。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、近代主義の溌剌にして大胆な発見もなく、「本質主義」の堅実にして純粋な創意もなく、徒らに怠惰因循空騒ぎを以て、日に日を継ぐ有様であります。",
              "citation": {
                "source": "演劇一般講話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、これは空騒ぎに過ぎなかったと分って、やれやれと云う大安心！",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国では長い間コルシカの食人鬼と闘っていたトーリ党がひきさがり、ナポレオンの救出運動はむしろフランスよりも活溌なくらいだったが、中心にいるのはバイロンの流れをくむ学生達やロマンチックな陰謀家達で、コランが軽気球でナポレオンを救出するという計画同様、いささか空騒ぎというのに近かった。",
              "citation": {
                "source": "フランス伯Ｎ・Ｂ",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのウラミがあったのだ、なにを世間から受けさせるつもりで空騒ぎしたのだ、私はそれらの記述を新聞雑誌で読むごとに、うたた暗然として、聖人高村光太郎のために、どいつも、こいつも叩きのめしてやろうかとさえ憤激一日として安きを得なかった。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして空騒ぎが済むとかれら興行師のともがらは、騒ぎをしずめて去って行った。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "人民戦線という合言葉は最近のジャーナリストの空騒ぎにすぎぬ、という意見が、気の利いた又利いた風の、知恵として行なわれているようだが、それは多少当らぬでもない。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは彼に罪もない右のような「空騒ぎ」を憤慨していた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても近日の動静に徴して、町に於ても相当に警戒の試みられてあるべき晩なのに、存外穏か過ぎるのは、本来、商業地としての当地は、警戒ということが深ければ深いほど、空騒ぎをしない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし僕は初めからこの狸爺が、ただ不体裁な空騒ぎのために、皆さん御一同をここへ呼んだのだってことは、ちゃんと感づいていたのです。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて空騒ぎとなったが、ヤカンも時には沸騰するし、高官も指に火傷をする。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "無知で情熱的で、野蛮で空騒ぎの好きなロシアの街の人たちの唄は、本当にこんなものでもあるだろう。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が空騒ぎをしていると思うだろ。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの朝臣を捕えぬうちは、ただ空騒ぎに過ぎぬものだ。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　同居人が手を振ると、子どもたちはネズミのごとくちょろちょろと階段を降りていき、気がついたころには通りからさわぎ声が聞こえていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙二はだまってどての上からさわぎ笑って居る二人の娘の顔色の違いにおどろかされて居た。",
              "citation": {
                "source": "グースベリーの熟れる頃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『変だな』と思ったときには、猫は、とつぜん大きなしゃっくりをはじめ、それからさわぎのうちに、冷たくなって死んでしまったのです。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あぐり、（東やの女中）手つだいに来てくれて火を起すことからさわぎだ。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たき鐘のゆさぶりに、心の淵のからさわぎ。",
              "citation": {
                "source": "小曲二十篇",
                "author": "漢那浪笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎や赤坊がいるからさわぎよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その数人に対して、ステージを降りろ、と命令する人たちがいて、この対立からさわぎは大きくなり、警官が仲裁にはいると、さわぎは警官にむけられ、パトロール・カーがひっくりかえされ警官が発砲するという事件になってしまった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "世のなかでは、からさわぎをして、がやがやしてゐるやうですが、あれでは教育も、修養も、増産も、あまりうまくは出來ぬでせう。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
