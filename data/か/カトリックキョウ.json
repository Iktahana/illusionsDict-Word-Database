        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "カトリック教の教義について、詳しく説明を受ける機会があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この国では、カトリック教が主要な宗教として根付いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史の授業で、カトリック教がヨーロッパに与えた影響を学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カトリック教の伝統的な祭りは、地域の人々に大切にされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "今日の時代思潮に於ては、もはや「美」や「芸術」やの言語が、カトリック教的叛逆の「異端」を意味していない故に、我々の文壇がこうした古風の遺風の意味に於て、唯美主義や芸術至上主義を言語するのは馬鹿げている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "バークリ夫人はローマ・カトリック教会の一員なのだそうで、聖ジョージ組合の設立に深く関わっていた。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "カトリック教のひどくきびしい寄宿学校に八つのときから六年間も入れられ、あまり器用に立ちまわれないこの生徒は、終りに衰弱で半分死にかけるような苦労をした。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓バルザの精力と野心とに溢れた孫息子が、少年時代から憧れ通してしかも接近し得ないでいた貴族趣味、教養、貴族的気位、カトリック教の神秘の霧で、ベルニィ夫人は自身の逞しい素朴な愛人をくるみこんだのであった。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に小田原へ往った長男｜周碩と、この三蔵とは、後にカトリック教の宣教師になったそうである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "Il Santo（フォガッツァーロの小説）あたりであらわしていた、カトリック教に同情した心持を寺院の側からの抑圧を受けて、いっそう保守的にあらわそうとして、死ぬる前に一の小説を書いた。",
              "citation": {
                "source": "文芸の主義",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドュルタルは現世界に愛想をつかして、いっその事カトリック教に身を投じようかと思っては、幾度かその「空虚に向っての飛躍」を敢てしないで、袋町から踵を旋らして帰るのである。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして作者の厭世主義には多少の同情を寄せながら、そのカトリック教を唯一の退却路にしているのを見て、因襲というものの根ざしの強さを感じた。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "行き留まりのカトリック教まで行って、半分道だけ引き返して、霊的自然主義になるという処でしょう」「ええ。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この前後百年にも亙れる宗論の事實に就いては、然るべき參考書も多く、又極めて簡單ながら、拙稿「新に發見されたカトリック教の宗論關係の二史料」（本全集第二卷參照）にも敍述して置いたから、茲には説明せぬ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい円光を頂いた昔の西洋の聖者なるものの、――いや、彼の隣りにいるカトリック教の宣教師は目前に奇蹟を行っている。",
              "citation": {
                "source": "少年",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "カトリック教の原罪説を、自意識への呪詛とみなすこと。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その教会というのは、――信州軽井沢にある、聖パウロ・カトリック教会。",
              "citation": {
                "source": "木の十字架",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "カトリック教の秘蹟劇などは、その一種である。",
              "citation": {
                "source": "演劇の様式――総論",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "カトリック教の国に、「王様の日」といふのがある。",
              "citation": {
                "source": "巴里の新年",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "取調べは一時間半つゞいたが、結局ローマカトリック教司祭ヨワン・バッティスタ・シローテといふ氏名が分つた程度であつた。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "カトリック教徒が胸に切る十字は、あれが多分後世忍術使ひの真言九字の原形であつたに相違ない。",
              "citation": {
                "source": "わが血を追ふ人々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、私が好んで歩きまわった水車の道に沿って、いつか私の知らない間に、小さなカトリック教会さえ出来ていた。",
              "citation": {
                "source": "風立ちぬ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "カトリック教会堂は即ちユーランバに隣接してゐる。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、禅宗を信じる者が、僧侶でありながらカトリック教へ転向するということが、大いに流行したのであります。",
              "citation": {
                "source": "ヨーロッパ的性格　ニッポン的性格",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで諸村の隠れ切支丹がみんな改めて洗礼をうけて正式のカトリック教徒に復活したかというと、そうではないから、おもしろい。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "長崎チャンポン――九州の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "カトリック教の「地獄」というのは、たぶん、こんな形容を持っているのであろう。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十六聖人といっても、日本国内では知る人も少ないが、世界中のカトリック教会で毎年二月五日にそのお祭をするので、むしろ外国で有名だ。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学者パスカルが彼の科学と何の矛盾もなく信じていたこのカトリック教とはどんなものであろうか？",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋第一の大聖堂で一万余りのカトリック教徒が天主堂を中心に浦上一帯に住んでいた。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "天国行きの列車は教皇を機関手とするカトリック教会のほかにありません。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦の八月十五日は、旧教国では五大節の一つになっている〈聖母昇天祭〉の祭日にあたるので、カトリック教徒の満寿子さんは、聖母マリヤと同伴で昇天する予定だったらしいのに、ばあやがよけいなお節介をしたばかりにとうとう天国行のバスに乗り遅れてしまった、というようなことだった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
