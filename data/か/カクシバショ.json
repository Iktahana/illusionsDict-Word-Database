    "definitions": [
      {
        "index": 1,
        "gloss": "cache",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は家の合鍵の隠し場所を忘れてしまい、結局、鍵屋を呼ぶ羽目になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "子供たちは、自分たちだけが知っているお菓子の隠し場所を庭の隅に作っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "警察は、容疑者が押収された薬物の隠し場所について、まだ口を割らないと発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "また子を生むといつでもその子を取り上げられるので色々隠し場所を変えた末に、とうとう主人の書斎の書棚の奥に隠した猫もある。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘密の隠し場所へ駆け寄り、そこに物乞いでの収入が積み立ててあったので、その貨幣を手につかめるだけつかんで、外套がしっかり沈むよう、かくしに詰め込んだ。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "シンプソンは鈍器の杖でストレーカの頭部を殴りつけ、身を守ろうとしたストレーカの小型ナイフではかすり傷ひとつ受けないままで、そして馬はその盗人が秘密の隠し場所へ連れ込んだか、さもなくば男ふたりの争うさなかに逐電したまま今なお荒野をうろついているのやも。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋に着くと、いつも私の習慣にしているように扉を叩いたが、なんの返事もないので、自分の知っている鍵の隠し場所を捜し、扉の錠をあけてなかへ入った。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隠し場所の思ひつきのすぐれてゐることには、俺も彼女に敬意を表した。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく、牢名主はじめ同牢の者は、だれがやったか、どうしてやったか、匕首の隠し場所もちゃんと知っているであろうが、告げ口、耳打ちはいうまでもないこと、世間の義理人情とはまた違った義理人情を持っているこの連中が、ひととおりやふたとおりの責め方でたやすく口を割ろうとは思いもよらないことでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも、権藤四郎五郎左衛門なる長い名のその生駒家新浪人が、いちはやくご府外へ逐電したならば、五街道口のいずれかの隠し屯所へ、まだ市中に潜伏しているならば一町目付けのどこかの隠し場所へ、必ずなんらかの足跡動静を残しておいたであろうと知ったからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に安全な隠し場所ですからね、あそこは。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに先程から、劉夫人の敏捷なる行動に、ひそかに不審をいだいていた僕は、ことさら自分の武器を秘密の隠し場所からとり出すところを夫人に見られたくなかった。",
              "citation": {
                "source": "人造人間殺害事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に巧妙な隠し場所だといわなければならない。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろそのマッチの函を某所に隠してしまったので、もしその隠し場所などを喋ったとなると、杜のやり方に不審をいだかれるは必定であり、それから更に面白くない嫌疑を募らせてはたまらないと思ったので、血痕のことだけは云わないことにした。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐれた宝玉のような問題は、このように鍵の隠し場所が極めて意外なところにあり、そしてそれにぶつかって解くと、あとは全部ががらがらがらと崩れるように解けて行くようなのを指していうのだ。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉は現場を見ていないというので、詳しいことは判りませんが、年造は小刀のような物を持って、次右衛門の寝込みを襲って、思い通りに相手を仕留めて、さてその金のありかを探すと、仏壇の抽斗に百両、ボロ葛籠の底から百両、あわせて二百両だけは見付け出しましたが、残りの四百両の隠し場所がわからない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "然したとい先生の御取り出しになったのが、胎児でなかったとしても、Ｔ先生が誤診なさったことは事実でありますしなお又、先生が、その疑問の組織のやり場に困って、最も安全な隠し場所として、御自分の胃袋を御選びになったことも、やはりたしかであると思って居るので御座います。",
              "citation": {
                "source": "手術",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「隠し場所がわかった。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬はシムソンが首尾よく秘密の隠し場所へかくしてしまったか、さもなくば二人の男の闘争中勝手に逸走したまま、いまなお荒地のどこかをうろついてるのかもしれない――警察の考え方はおそらくこんなことだろう。",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ことによると盗人が隠し場所に困つて、ちよつと忍ばせたものかも知れんて。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僅かに黒姫山麓のホンの一部に過ぎぬなれど、一箱十二貫目入りの分三箇だけの隠し場所が、今日漸く分ったのじゃ」「三十六貫目の黄金！",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてあの妙な符号はたしかに宝石の隠し場所を示したものであることを、看破したのです。",
              "citation": {
                "source": "琥珀のパイプ",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もあとで考えれば、岩見の隠し場所は岩見でさえもどうにもならぬ状態にあったのです。",
              "citation": {
                "source": "琥珀のパイプ",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで狂ったように荒れまわっていた私は、とうとう書架のうしろの秘密の隠し場所から、故辻川博士の日記を発見した。",
              "citation": {
                "source": "蜘蛛",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ぐずぐずしていると、彼は書類を隠し場所から取り出して、本国へ送るだろう。",
              "citation": {
                "source": "計略二重戦",
                "author": "少年密偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから我々は出来るだけ速かに隠し場所を発見して、取り戻さなければならないのだ」「承知しました。",
              "citation": {
                "source": "計略二重戦",
                "author": "少年密偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は貴様が先刻云った隠し場所は出鱈目だった事を知ったから、本当の事を云わそうと思って謀計にかけたのだ。",
              "citation": {
                "source": "計略二重戦",
                "author": "少年密偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様がここでベラベラしゃべった隠し場所が本当だったら、直ぐ警視庁から合図の電話がかかる事になっていたんだ。",
              "citation": {
                "source": "計略二重戦",
                "author": "少年密偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなかいい隠し場所ですね。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "全財産を献じたと云っても、それは実は表向きで、彼は以前から大きな財産を、ひそかに隠して持っていて、その隠し場所を歌へ詠み込み、機嫌のよい時に一人で歌って、楽しんでいたということです。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗難というおそれもあるし、それでなくとも紀州の藩士などが、秘密をさぐり知って俺を襲い、奪いとる懸念だってあるのだから）　宥免状の隠し場所の、絶対安全の場所が出来た。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなことをいって、きみを、ほんとのかくしばしょに来させたのさ。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "６　ユウ子ちゃんは、まほうはかせにうまくだまされて、赤いカブトムシのかくしばしょを見つけられてしまいました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
