[
  {
    "uuid": "35caf06b-246c-5abd-a2e0-671e4db41166",
    "entry": "隠し場所",
    "reading": {
      "primary": "かくしばしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
