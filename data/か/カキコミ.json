        "examples": {
          "standard": [
            {
              "text": "ウェブサイトの会員登録フォームに必要事項を書き込み、送信した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アンケートの自由記述欄への書き込みが、意外と多かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "申請書に漏れなく書き込みをするには、慎重な確認が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "posting (e.g. to a blog)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
