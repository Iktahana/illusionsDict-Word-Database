    "definitions": [
      {
        "index": 1,
        "gloss": "writing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この参考書は、余白に先生の書き込みがたくさんある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試験中に問題用紙への書き込みは許可されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ノートに講義の内容を細かく書き込みながら、熱心に勉強した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "恋のお歌だけは、あまり御上手でないと、あの鴨の長明入道さまもおつしやいましたが、忍ビテイヒワタル人アリキなどとお歌の端にはお書き込みになつて居られるものの、それこそまるで絵そらごと、長明入道さまの言ひ方に従へば、ウソでございます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "べつに郵便切手名簿へも「一銭五厘切手一枚、催促ハガキ用」等と書き込み、なお支出簿へも、「一銭五厘催促用支出」と記入するなど、一つの用件にたいてい三つか四つの帳簿に記入する必要があり、またその都度いろいろな印を印台から取出さねばならず、間誤ついた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによれば、その後の身辺は静穏だが、その日の朝、また日時計の上に長い書き込みがあったからと、その写しが同封されていた。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かを知りたいというはっきりした目的があって本を読むとき、私はたいてい赤のボールペンを持って、線を引いたり書き込みを入れたりしながら頁をめくります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "内容が濃いうえに、かなり注のいりそうな『書物の出現』は、書き込みで真っ赤にしながら読んでいきたい類の本でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き込みなしでは読んだ気がしないのに加えて、書き手へのお礼の問題が頭から離れないからです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き込みは、電子本でもできる。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙の本では手書きになるけれど、電子本では書き込みにもフォントが使える。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "普及している装置の大半は再生専用で、通常書き込みには使えない。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "余白に書き込みを入れる。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一日付の最初の書き込みは木津田さんによるもので、その日のうちに古野さんからのメッセージが続きます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当のボイジャーからオープンの挨拶が寄せられる前に、書き込みの輪はどんどん広がっていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈翡翠〉さんは、サロンに寄せた初めての書き込みで、的の中心をダーツで射抜くように、エキスパンドブックの意義を言葉に定着しています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "出版社に任せていては、それは手遅れになってしまうでしょう」（一九九三年十一月二十七日付け、ボイジャーサロンへの書き込み。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "イニシャルや文様の書き込みにも、確かに念の入った仕事が施してあります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "装丁を簡素化する傾向が広まり、手書きの文様も次第に書き込みの度合いを薄めていきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてどういった経緯で山本さんは、そこここにペンで書き込みのある貴重な洋書を大学に寄贈していったのかを考えました。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざっと見当を付けては書き込みと削除だらけの原稿を一字一字数え、足りなくても多すぎても一からやり直す悪夢の作業が脳裏によみがえる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かに余白に書き込みを入れる、ページの端を折ったりクリップをはさむなどして目印とする、覚えに線を引く、書体をボールドにしたり下線を付したりするなど、従来の本でできることは（多少のおまけもついて）カバーされている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "各筆毎に番號を入れ、畝歩を記入し、本數を書き込み、最後に耕作者の姓名を記す。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "○○○さんが帯の間にはさんで持って来ていた鉛筆でそれぞれ書き込み、職業というところでゆきつまりました。",
              "citation": {
                "source": "共産党公判を傍聴して",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのおの手には帳面を持ち、その行為がよいと批評されれば、人生に於けるあらゆる斯の如き種類の行動の下に、よし、と書き込み、悪いと云われればまた、同じ総体を、一言の下に、恐るべき悪行と断定する。",
              "citation": {
                "source": "深く静に各自の路を見出せ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが彼、もしくは彼女の手落ちにならないことを僕は望むよ……あはははは」　彼はこういうと、ふと机に向つて、紙をおいてしばらく何かしきりと書き込みはじめたのであつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビット・インに詰めたスタッフには、ユーザーとの対応の逐一を日誌に書き込み、はっきり答えられなかった内容に関しては、宿題事項覧に記入し社内に持ち帰って検討する体制をとった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "値引きの原因になる汚れや書き込みも、気にならなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ書き込みの文字には、興味が湧き、前に読んだ人の肌のぬくもりが文字越しに伝わってくるような気がした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "20　タケシは『マイコン基礎講座』をノートを取り、書き込みを加えながら読み進んでいった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対して、情報の書き込みと読み取りの両方ができるものを Random Access Memory と呼び、ＲＡＭと略す。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾電池に興味を持った西は、誰に指示されるでもなく百科事典や中学、高校の教科書でその使い方や働きについて調べ、あらかじめ教科書にびっしりと書き込みを入れていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディスプレイ上の表示の意味を説明するために英語版のマニュアルにあった画面のコピーには、キルドールの手書きの書き込みがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
