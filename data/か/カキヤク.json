        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "村の寄合で書き役を任されたので、議論の内容が漏れないよう必死に記録を取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「君は字が丁寧で読みやすいから、今回の会合の書き役をお願いできないかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔の役所では、多くの書き役が墨をすり、朝から晩までひたすら台帳を作成していたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新入社員の頃は、会議の書き役を務めることで組織の力学や議論の流れを学んだものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "楊は書き役の者に命じて、かの一件の記録を訂正させ、さらに紙銭十万を焚いて、かれらの冥福を祈った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "――待つてくれ、それから書き役の又六の方も調べるんだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "凧の詭計",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處には派手なお内儀のお千世を始め、老番頭忠助、書き役又六、甥の傳七郎を始め、小僧、下女まで十幾人、固唾を呑んで控へたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "凧の詭計",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いでもらちは明くまいとみたから、おれはあれから直ぐお数寄屋橋まで飛んで行き、お南の書き役をたたき起して、お奉行所の御記録を調べてもらったよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、お南の書き役に一升買って、とんだ眠い思いをしただけに、いろんなことがわかったよ」「ヘエ、どんなことで？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「八丁堀の組屋敷から、お南の書き役まで一と廻りやつて來たが」「へエ？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "母娘巡禮",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分」「八、大急ぎで奉行所へ飛んで行つて、書き役から、近頃檢印の無い御用金か何か盜まれた事が無かつたか、訊いて來てくれ」「へエ」　八五郎は、さう囁かれると獵犬のやうに飛んで行きました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "蝉丸の香爐",
                "note": "青空文庫"
              }
            },
            {
              "text": "御數寄屋橋へ行つて、書き役の方に伺つて見るが宜い」「有難う御座います、それぢや」「待て／＼、俺も行かう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "目黒へ行く前、南の奉行所へ一寸顏を出して、書き役の遠藤｜佐仲に逢ひ、「丁度十年か十一年前に、何か飛んでもない物が盜まれて、それつ切り、その品も現れず、盜人も知れないと云ふやうな事は御座いませんか」　こんな事を訊ねます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "謎の鍵穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "御南の書き役に調べて頂けば、すぐわかる。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "掏られた遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分」「八、大急ぎで奉行所へ飛んで行って、書き役から、近頃検印のない御用金か何か盗まれた事がなかったか、訊いて来てくれ」「ヘエ」　八五郎は、そう囁かれると猟犬のように飛んで行きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "蝉丸の香炉",
                "note": "青空文庫"
              }
            },
            {
              "text": "目黒へ行く前、南の奉行所へちょっと顔を出して、書き役の遠藤｜佐仲に逢い、「ちょうど十年か十一年前に、何かとんでもない物が盗まれて、それっきり、その品も現れず、盗人も知れないというような事はございませんか」　こんな事を訊ねます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "謎の鍵穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "御数寄屋橋へ行って、書き役の方に伺ってみるがいい」「有難うございます、それじゃ」「待て待て、俺も行こう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方奉行所の書き役の方へやつた下つ引は、もつと重大なことを聽込んで來ました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "金藏の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方奉行所の書き役の方へやった下っ引は、もっと重大なことを聴込んで来ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いずれ出入の町人のような顔をして入って来ることであろうが、六十枚の手形が出ていることだから、どれが曲者やら一向に見当はつかない、――兎も角も、宵に忍び込んで、夜っぴて仕事をする様子で、書き役の手文庫から抽斗、本箱までが散々の荒しようだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "群盗",
                "note": "青空文庫"
              }
            },
            {
              "text": "後で念入に調べて見ると、書き役の書類の中から、いつぞやお前に追われて、品川沖で海の中に沈んだ強賊「疾風」の記録だけが紛失している」「――」　平次はジッと考え込みました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "群盗",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いづれ出入りの町人のやうな顏をして來ることであらうが、六十枚の手形が出てゐることだから、どれが曲者やら一向に見當はつかない、――兎も角も、寮に忍び込んで、夜つぴて仕事をする樣子で、書き役の手文庫から抽斗、本箱までが散々の荒しやうだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "群盗",
                "note": "青空文庫"
              }
            },
            {
              "text": "後で念入りに調べて見ると、書き役の書類の中から、いつぞやお前に追はれて、品川沖で海の中に沈んだ兇賊『疾風』（『八人藝の女』參照）の記録だけが紛失してゐる」「――」　平次はヂツと考へ込みました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "群盗",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇三郎はもとの藩に書き役で仕へ、ゆかりの新嫁姿の初々しさは番町の名物になりました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "敵の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄兵衛の正役は大番組だから、寄合がしらが出ていなければならないのだが、そんなようすはみえなかったし、書き役の机さえもなかった。",
              "citation": {
                "source": "十八条乙",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご苦労だが、ひとつ書き役を勤めてもらいたい」　すでに、従兵の一人は、胡正の前に、用意の筆墨と料紙を突きつけている。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……こう、胡正さん、筆記だぜ、書き役を頼むよ」　近所の衆は、もう悉く失心の姿である。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
