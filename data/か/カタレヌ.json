    "definitions": [
      {
        "index": 1,
        "gloss": "unable to win",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あのチームはどんなに頑張っても、今の状態では勝たれぬだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "強豪相手では、今日の戦力では勝たれぬと誰もが思っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "監督は、このままでは次の試合も勝たれぬと危機感を募らせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "幾ら気が張っていても、疲労には勝たれぬ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "早う盥の用意せい」「でも、対手は御愛妾の縁につながる治右衛門、泣く児と地頭には勝たれぬとの喩えもござります。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "因果は諦らめる者、泣く子と地頭には勝たれぬ者と相場がきまっていた。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「泣く児と地頭には勝たれぬ」と云ふ諺も有つて、時の強者に反抗するは損である故、大抵の人は自身の利害から考へて、容易に公には名乗らぬが、西洋諸国では今日既に之に類する念は殆ど総べての人の内心に存する様に見受ける。",
              "citation": {
                "source": "人類の将来",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ勝ち難き我が心にも勝ち得る時はありしものを、勝たれぬは、身の病なり死の根なり。",
              "citation": {
                "source": "葛のうら葉",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "権力ある者は、その子供の罪まで警官が見逃すという、日本人は昔から泣く子と地頭に勝たれぬ、権力崇拝家であり、さればこそ権力には盲目的に屈服し、したがって又、自らが権力を握れば、これをフリ廻して怪しまない。",
              "citation": {
                "source": "現代の詐術",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂壌かなたに受くるもの、　　多くは酸えず燐多く洪積台の埴土壌土と、　　　　植物群おのづとわかたれぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は我に返って、頬張っている食物を呑み下し、近くの水道｜栓でぐっと水を飲み、それからまた佝僂の背中をかがめながら、跛のよちよちした足取りで、印刷所の受持場所へ帰り、革命のメネ・テケル・ウパルシン（数えられぬ、秤られぬ、分かたれぬ）を他日書くべき、魔法の活字の箱の前に就いた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "都でも、物好きな男たちが、比丘尼買いを知らずに色事はかたれぬなどと申すをよく耳にするが、まさかこんな山里にまで、みだらな悪風が行われていようとは思わなんだ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
