        "examples": {
          "standard": [
            {
              "text": "核心を突く質問にも、彼は顧みて他を言うばかりで真意が掴めなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "なぜ遅刻したのかと聞くと、彼は顧みて他を言い始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "不利な質問に対して、政治家はよく顧みて他を言う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そんな人柄なので少し話を文学や美術の事に向けようとすると、顧みて他を言うのである。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "無心の小児が父を共にして母を異にするの理由を問い、隣家には父母二人に限りて吾が家に一父二、三母あるは如何などと、不審を起こして詰問に及ぶときは、さすが鉄面皮の乃父も答うるに辞なく、ただ黙して冷笑するか顧みて他を言うのほかなし。",
              "citation": {
                "source": "日本男子論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
