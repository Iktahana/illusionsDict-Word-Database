    "definitions": [
      {
        "index": 1,
        "gloss": "breeze off a river",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "川沿いのカフェで、火照った体に心地よい川風（かわかぜ）が吹いてきて、ほっと一息つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "窓を開けると、川風が部屋中に爽やかな緑の香りを運んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夏でも、夕方になると川風が吹いてきて涼しくなるんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "柳の葉が川風にそよそよと揺れている景色は、心が落ち着くね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "聞説らく多摩川に沿うた溝には、独歩の「忘れ得ぬ人々」の作にちなんで、独歩の碑が立っているとか、さらば近代における多摩川風景の祖道者として、花袋の碑は、そこに建てらるべきではなかろうか。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の隅田川岸と言へば自分の記憶にもぼんやり浮ぶが、低い家の立ち並んだ薄暗い泥の道、晩秋のうそ寒い川風の中をトボトボと辿り行くであらう寂しい葬送行進曲！",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大橋より川上は小蒸気船の往来なくして、たゞ川船、伝馬、荷足、小舟の類の帆を張り艫櫂を使ひて上下するのみなれば、閑静の趣を愛して夏の日の暑熱を川風に忘れんとするの人等は、大橋以西、製紙所の上、川の南西側に榛の樹立の連なれるあたりの樹蔭に船を纜ひて遊ぶが多し。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の光は背に熱いが、川風は帽の下にそよ吹く。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは疑問としてもその上にまだ山川風土でありとあらゆる多様のタイプを具備している。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と苦笑をして又俯向いた……フと氣が付くと、川風に手尖の冷いばかり、ぐつしより濡らした新しい、白い手巾に――闇夜だと橋の向うからは、近頃聞えた寂しい處、卯辰山の麓を通る、陰火、人魂の類と見て驚かう。",
              "citation": {
                "source": "月夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "径に、ちらちらと、この友染が、小提灯で、川風が水に添い、野茨、卯の花。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝るには惜しい」　川風はさっと渠の鬢を吹き乱せり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "漆のごとき髪はやや生いて、広き額に垂れたるが、吹き揚ぐる川風に絶えず戦げり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "下鴨一　出町柳の停留所で市電を降りて物憂い、何かけだるそうな足取りで葵橋の上まで来ると、「ああ、いい風……」　と、小郷宮子は頬を撫でる川風に、うっとりと眼を細めた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "川風も生暖く春めいて、ふと悩ましい。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひ立つて山口へゆく、椹野川風景もわるくない、桜冬木、白梅紅梅、枯葦、枯草、ことに川ぞひの旧道は自動車が通らないのがうれしい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓢屋の婢は川獺の悪戯をする晩を知っていて、お座敷が終って歌妓達が近くもあるし、川風に吹かれて逢引橋の袂から河岸縁を帰ろうとすると、「ちょっと待ってらっしゃい」　と云って、二階へあがって逢引橋の橋むこうの袂にあった共同便所の明りに注意するのであった。",
              "citation": {
                "source": "築地の川獺",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の影、川風、思、画堂、青潮、水の音、初夏、中津川、ほたる、杜鵑……これはと思ふ心地よき題もなきに、我まづ聊かひるみたれど、稚なきものも交れる今宵なればと、人々心したりと見ゆ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、さすがに川風はあり、ふと忍びよる秋のけはいを、枝垂れた柳の葉先へ吹き送って、街燈の暈のまわりに夜が更けた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋口だから、川風がひえるわ」　窓の外は加茂の川原で、その向うに宮川町の青楼の灯がまだ眠っていなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊帳へ戻ると、お光、千代の寝ている上を伊助の放った螢が飛び、青い火が川風を染めていた。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はやがて汚れて行く自分への悔恨と郷愁に胸を温めながら、寒い川風に吹かれて、いつまでも突っ立っていた。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ひ吹く川の瀬の風、川風の吹きの凍えに、我が向ひ辿る高崖、遥か見る北の山脈。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ひ吹く川の瀬の風、川風の吹きの凍えに我が向ひ辿る高崖、遥か見る北の山脈。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が呼んでありますから、」「本当ですか、」「本当ですとも、其所をおりませう、」　川風に動いてゐる丈高い草が一めんに見えてゐて路らしいものがそのあたりにあると思はれなかつた。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "労役を終った鵜は嬉しそうにそれぞれ羽ばたきをして、大きな喉を川風にふくらました。",
              "citation": {
                "source": "赤い土の壺",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たい川風が吹きあげていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "河岸に急造した桟敷の一隅に席を求め、まずい弁当を食い、気の抜けたサイダーを呑み、そうしてガソリン臭い川風に吹かれながら、日の暮れるのを待った。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "簾越しに川風が吹き込んで、人の込み合っている割に暑くはなかった。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち日が東の地平線を破りて出ずると共に、今まで暗黒なりし全地は急遽として光明の野となり、山川風物さながら土に印を以て押したるが如く姿を現わし、地上の万物は美わしき衣服の如くに出現するというのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "隅田川から吹いて来る川風のような感じであった。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上原さんは、その川風にさからうように、すこし右肩をあげて築地のほうに黙って歩いて行かれる。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたかたかたと、上原さんは走って階段を上って行って、私は不思議な透明な気分で、ゆっくり上って、外へ出たら、川風が頬にとても気持よかった。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "絃楽のほうは琵琶、和琴などだけで笛の上手が皆選ばれて伴奏をした曲は秋にしっくり合ったもので、感じのよいこの小合奏に川風が吹き混じっておもしろかった。",
              "citation": {
                "source": "源氏物語",
                "author": "松風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
