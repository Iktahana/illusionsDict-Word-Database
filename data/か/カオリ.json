        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "挽きたてのコーヒーの香りが部屋中に広がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この花の香りは、心を落ち着かせてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "焼きたてのパンの香りに誘われて、ついつい買ってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "森林浴で、木の香りに癒されたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」――「よき住居よき酒、香りよき煙草・紅茶。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "IIIIいといと淡き今日の日は雨｜蕭々と降り洒ぎ水より淡き空気にて林の香りすなりけり。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は香りを消さぬように薬味の青｜海苔を撒らずに椀を重ねた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女たちの手の香りはいかに、又、金髮の子たちが水菓子で重くなつた美しい皿を運んでくるとき、その女たちの立てる笑ひはいかに。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "――しかし、其處にもまた、同じやうに重苦しい空氣が、花壇の中に無理にぎつしりと詰め込まれた、あんまり多過ぎる花の香りのために、一そう重苦しくなつたやうな空氣があるばかりでした。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、この蛇をのけると、五月の山ほど若々しい、快よい、香り高いところはない。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "霊南坂で鉄道草の香りから夏を越した秋がもう間近に来ているのだと思ったような晩もあります。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "外は夕闇がこめて、煙の臭いとも土の臭いともわかちがたき香りが淀んでいる。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "清逸は香りの高い蕊の中に顔を埋めてみた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸すような、焼くような、擽るような、悲しくさせるようなその香り、……その花から、まだ誰も嗅がなかった高い香り……清逸はしばらく自分をその空想に溺れさせていたが、心臓の鼓動の高まるのを感ずるやいなや、振り捨てるように空想の花からその眼を遠ざけた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その濃緑の帷からは何処ともなく甘い香りと蜂の羽音とがあふれ出てひそやかな風に揺られながら私を抱き包んだ。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所口をぬけるとむっとするほどむれ立った薔薇の香りが一時に私を襲ってきた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、そう言っても慧鶴に異性が眩惑するような若い肉体の香りの牽引があったとも思えない。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里へ行きますと、沢山ある珈琲店で、香り高い珈琲のコップを前に控え、人々はひと息、息を入れています。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来ない望みの譬えに、松が枝に桜の花を咲かせ梅の香りを放させたいような願いだと言いますが、仏教はそれに似たことをやろうというのです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もぎ立ての高い香りにむせび乍ら、唇を赤くして飽かず喰べた。",
              "citation": {
                "source": "動かぬ女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の友人に、寝る前に香り高い珈琲を飲まなければ（飲めばの――誤植ではない）眠れないという厄介な悪癖の持主がいる。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同じでんで、大阪を書くということは、例えば永井荷風や久保田万太郎が東京を愛して東京を書いているように、大阪の情緒を香りの高い珈琲を味うごとく味いながら、ありし日の青春を刺戟する点に、たのしみも喜びもあるのだ。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の書かねばならぬのは、香りの失せた大阪だ。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、それはほかの土地よりも高かったのだと言えば、余りに身びいきになりすぎるかも知れないが、すくなくとも私は大阪は香りの高い、じっくりと味うべき珈琲だった筈だと、信じている。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気は香り高く、森は赤と鳶色の光に輝き、勢子のどよめき、鋭い銃声は新鮮な自由の歓びに充ち溢れていた。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "真暗な河岸通りに青い街灯が惨めに凍えて、烈しい海の香りをふくんだ夜風が吹きまくっていた。",
              "citation": {
                "source": "ああ華族様だよ　と私は嘘を吐くのであった",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、色もありましたし、香りもありました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはいかにもすがすがしい森で、よい香りがただよっています。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤナギとコケモモが咲きそろい、よい香りのするセンオウは甘い匂いをひろげていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "香り高い広い葉かげに、死の女神がすわっている。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ一つの短い物語の底に流れる、絵を絶した浪漫的香りも高い詩情こそその生命なのである。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から畑に入るゝ肥料なるべし異様のかおり鼻を突きて静岡にて求めし弁当開ける人の胸悪くせしも可笑しかりける。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "捉えがたいほのかなかおりを予想する。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い天井、白い壁、その上ならず壇の上には時ならぬ草花、薔薇などがきれいな花瓶にさしてありまして、そのせいですか、どうですか、軽い柔らかな、いいかおりが、おりおり暖かい空気に漂うて顔をなでるのです。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
