    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to shine out far and wide",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "明け方の太陽が、山々を越えて世界中を輝き渡る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遠くの灯台の光が、暗い海を広く輝き渡った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祭りの提灯の明かりが、村の隅々まで輝き渡っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "晴れさえすれば、もう真夏の紺青の空が目にしみて輝き渡るのである。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の関係しているある研究所の居室の室外にこの木の大木のこずえが見えるが、これが一様に黄葉して、それに晴天の強い日光が降り注ぐと、室内までが黄金色に輝き渡るくらいである。",
              "citation": {
                "source": "藤の実",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていつかお前の方まで分け入るぞよと輝き渡る藤原郷の奧山を望んで思つたものであつた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていつかお前の方まで分け入るぞよと輝き渡る藤原郷の奥山を望んで思ったものであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "空のどこかに、雲のうえの輝き渡る大きなお宮の中に、金の冠を戴いた神様がいらっしゃることをあなたは知って居た。",
              "citation": {
                "source": "少年・春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "輝き渡る日本の国です。",
              "citation": {
                "source": "朝おき雀",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "千々岩灘に散らばる漁船の白帆がその瞬間｜金色に輝き渡る。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "偉大なる人格を発揮するためにある技術を使ってこれを他の頭上に浴せかけた時、始めて文芸の功果は炳焉として末代までも輝き渡るのであります。",
              "citation": {
                "source": "文芸の哲学的基礎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "輝き渡るとは何も作家の名前が伝わるとか、世間からわいわい騒がれると云う意味で云うのではありません。",
              "citation": {
                "source": "文芸の哲学的基礎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死」によって浄化された幼児の稚い美くしさはまぼしいほどに輝き渡る。",
              "citation": {
                "source": "悲しめる心",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画館を出ると短い秋の日はもう夕方近くになり、あたりの電灯は一際明く輝き渡るにつれて、往来の人の賑ひもまた一層激しくなるやうに思はれた。",
              "citation": {
                "source": "男ごゝろ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇を見る為めには非ず、金色に彩りたる高き円天井、広き舞台、四方の桟敷に輝き渡る燈火の光に酔はんが為めなれば、余は舞姫多く出でゝ喧しく流行歌など歌ふ趣味低きミユーヂカル、コメデーを選び申候。",
              "citation": {
                "source": "夜あるき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "登山杖に身を凭せながら、高い心臓の鼓動と共に血汐の流れが脈を打って頭の心へ奔注する音を耳元に聞きつつ、山という者を始めて見たように全く新たな驚きを以て、遠く近く輝き渡る大山岳の姿を身じろぎもせず眺めていた私は、間近い竜王岳の頂上をさして驀らに急いだ。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして又彼の前には彼の怠つて來た生活が、眞の生活が、基督に於ける生活が、輝き渡る美しさを以つて現はれて來た。",
              "citation": {
                "source": "三太郎の日記　第二",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の海はつよい太陽の光をはねかえして輝き渡る。",
              "citation": {
                "source": "海の青と空の青",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "卿の額は何という光りで輝き渡る事だろう。",
              "citation": {
                "source": "風に乗って来るコロポックル",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおそれには、消え去った彼女の眼から彼の上へ静かに輝き渡る神秘な誘惑が、つけ加わっていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二つの光の中で、彼の傾向は、焼き尽す光よりもむしろ輝き渡る光の方にあった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "火山は輝き渡る、しかし暁の光はいっそうよく輝き渡るではないか。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある不可知な輝き渡る何物かの目ざめである。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "やむなく食みし　将軍のかがやきわたる　勲章とひかりまばゆき　エボレットそのまがつみは　録されぬ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈尊も、八十歳までのながいあいだ在世されたればこそ、仏日はかくも広大にかがやきわたるのであろう。",
              "citation": {
                "source": "死刑の前",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "……落葉のたまった水飲み台から一杯の水をくんで、それを飲むときの喜悦にかがやきわたるような顔。",
              "citation": {
                "source": "キャラコさん",
                "author": "馬と老人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
