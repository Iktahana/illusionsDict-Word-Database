    },
    "definitions": [
      {
        "index": 1,
        "gloss": "household with at least one member subject to taxation (ritsuryō system)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "律令制下の課戸は、税や労役を負担した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古文書に課戸の記録が残されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "課戸の数は当時の経済状況を示す指標の一つだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "つまらないことを思つてみたりするものだとは思ひ乍らも、なんだかこれはドキンと来る。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだかこれは、ロマンチシズム開花する国で云ふにふさはしいことのやうだ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりに哀しく、きのふきみのくちびる吸ひてきずつけ、かへれば琥珀の石もて魚をかこひ、かの風景をして水盤に泳がしむるの日、遠望の魚鳥ゆゑなきに消え、塔をきづくの額は研がれて、はや秋は晶玉の死を窓にかけたり。",
              "citation": {
                "source": "感傷の塔",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋宮沢賢治草穂のかなた雲ひくきポプラの群にかこまれて鐘塔白き秋の館かしこにひとの四年居てあるとき清くわらひけるそのこといとゞくるほしき",
              "citation": {
                "source": "恋",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが不思議に、どこかこの報傳の根柢には、否定し得ない確實性があるやうに思はれた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐竹は君に何かこっそり相談したことがありはしないか」「あります」私は馬場に酌をした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして近代人といふのは、多いか少いかこのむしなのではないか？",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間行事のカタログをひろげ、あれかこれかと迷ふ程愚かな姿もないものである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だかこれを聴く毎に、僕は日本文化の悲しい末路といふことを痛感する。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃ではあちこちの翻訳物を引受けたり、少年雑誌の英文欄などを手伝って、どうかこうかはやっている。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹村君は前屈みになって硝子箱の中に並べたまじょりか皿をあれかこれかと物色しているが、頭の上の瓦斯の光は薄汚い鼠色の襟巻を隠す所もなく照らしている。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかこの若先生のところで顕微鏡を見せてもらって色々のプレパラートをのぞいているうちに一つの不思議な重大なアポカリプスを見せられた。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡くなられる少し前に、たしかこれらの楊梅が始めて四つとか五つとかの実を着けたという消息を聞いたことがあったように思う。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前はまさかこのおれを、いや、まさか、そんな鬼のやうな、いや、まるでわからん。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を感じたかこの頃ではしきりに年賀状の効能と有難味を論じるようになった。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かこの影の薄くなった言葉を活かして「四十の惑い」を解いてくれる人はないだろうか。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだかこんな風な夢であったのですが、今この新短歌を読んでいると、不思議にこの夢を想い出し、そうしてこれらの詩の中に私の夢のどうしても想い出されないかけらが隠れているのではないかという気がするのです。",
              "citation": {
                "source": "御返事（石原純君へ）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界じゅうでいちばん「若い」アメリカ人が一九三〇年代の今ごろになって、いくらかこの俳諧の世界の存在に気づいて来たように見えるのははなはだ興味の深いことである。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本附近である神社の周囲を取りかこんでいるはずの樹木の南側だけが欠けている。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女等は誰かここで昼飯｜交際の旦那が見つかれば好し、もし見つからなければ仲好三人で今日一日遊んでしまおうという話がまとまった。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "池をかこんだ樹陰のほの暗さ、池はその周囲の幽暗にくまどられ、明方の月のように静寂な水の面貌を浮べていた。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それへも骨肉を分けて血の縁を結んだなら自分の性格の複雑さも増す思いで、分身を雲の彼方にも遺す思いで、自分はどのようにかこの世に足り足らいつつ眼が瞑れることだろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉娘に対してはとかく恋々たる山の祖神の翁も弟の岳神に対してはどういうものかこの点は諦めがよかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私もいささかこの東海道を研究してみましたのですが、御承知の通り、こんなに自然の変化も都会や宿村の生活も、名所や旧蹟も、うまく配合されている道筋はあまり他にはないと思うのです。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あゝあたしはゆっくりでいゝんだからお前さきにおあがり、姉さんがね、トマトで何かこしらえてそこへ置いて行ったよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニのうしろには、いつから乗ってゐたのか、せいの高い、黒いかつぎをしたカトリック風の尼さんが、まん円な緑の瞳を、じっとまっすぐに落して、まだ何かことばか声かが、そっちから伝はって来るのを、虔んで聞いてゐるといふやうに見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀河の、かたちもなく音もない水にかこまれて、ほんたうにその黒い測候所が、睡ってゐるやうに、しづかによこたはったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなにむなしく命をすてずどうかこの次にはまことのみんなの幸のために私のからだをおつかひ下さい。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろで誰かこごんで石ころを拾っているものもある。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかこんな林には気も付かずに通り過ぎるだろうと思っていたら二人の役人がどこかで番をして見ていたのです。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
