      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the past",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "過去の栄光に囚われず、未来を見据えよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その建物は過去の歴史を今に伝えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は過去の経験から多くを学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "然し、今日私が、過去の錯乱を去つたのは、実に私が、謂はば、自力的に求めたればこそで、却て今日はじめて、花の美しさをも感じられるやうになつた次第である。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "純粋持続の、人に於ける心理的状態は、強ひて言へば、未来を思ふとしては神を、現在を思ふとしては自己を、過去を思ふとしては運命を信じてゐるのだ。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去よながいながい孤獨の影よその影を岩にひきずる冬の日の薄暗い濱邊に立つて意味のふかい人生を見る。",
              "citation": {
                "source": "眺望する",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "記憶萩原朔太郎記憶をたとへてみれば記憶は雪のふるやうなものでしづかに生活の過去につもるうれしさ。",
              "citation": {
                "source": "記憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天日の下に口をあけ汝の過去を哄笑せよ。",
              "citation": {
                "source": "昔の小出新道にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の過去に発表したすべての詩篇の中で、此等の抒情詩ほど、正直ないぢらしい感情にみちてゐるものはない。",
              "citation": {
                "source": "抒情小曲集",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのリズムは、過去に現はれた日本語の抒情詩の、どれにも発見することのできない珍しい鋭どさをもつて居る。",
              "citation": {
                "source": "抒情小曲集",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等は過去の詩形を破壊すること。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私共は、既にかうした青春時代の花やかな、とはいへいくぶん狂気じみた創造の夢を過去に微笑して観ることさへもできる。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕の過去の悔恨は、友人が惡かつたことだ。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の過去における一切の思想と感情とに、ある根本的の動搖があり、新しき生活の革命に入らうとする、けなげにも悲壯な心境が感じられた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてそれらの自由にまで、いかに必死的な熱情をもつて過去を一貫したかといふこと。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤村氏の自選詩集には、過去の作品での最も秀れたもの、最も純粹で美しいものばかりが選りぬいてある。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに今日私は過去五年間の暗中模索、傷ましき躁宴の後に、聊か芸術の泉なるものが依て以て存する所以に想ひ到つた。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」彼は目覚めに夜着から頭を出す、恰度其の時のやうに彼が学校に対する過去一年間を振返つた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが何だかモヤモヤと温い摺鉢のやうなものが脳膸の天井に蓋さつてるやうで、過去一年間の其処にある何にも彼の頭に蘇りはしなかつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しこつちは寧ろウソが明白にされたので過去三ヶ年半の可なり辛い自責感を去る。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは千九百二十七年に小林に送る手紙です私には過去と未来が分らなくなつた。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の人の意識は、何時も近い過去をみてゐるものなのだ。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの恋人は、過去にも実在した如く、現在にも実在し、時間と空間の彼岸において、永遠に悩ましく、恋しく、追懐深く慕われるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで「妹」という古語を使ったのは、それが現在の恋人でなく、過去の幼な友達であったところの、追懐を心象しているためであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "因に、この句の「捨てる」は、文法上からは現在の動作を示す言葉であるが、ここでは過去完了として、既に前から捨ててある意味として解すべきでしょう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に詩を作る人々は、過去においても未来においても、新しい詩においても古い詩においても、必須的に先ず俳句や和歌を学び、すべての技術の第一規範を、それから取り入れねばならないのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお「きのふの空の有りどころ」という如き語法が、全く近代西洋の詩と共通するシンボリズムの技巧であって、過去の日本文学に例のない異色のものであることに注意せよ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那文化を同化した日本人の過去の歴史は、特によくこの事実を実証してゐる。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者の過去の生活は、北海の極地を漂ひ流れる、侘しい氷山の生活だつた。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去より來りて未來を過ぎ久遠の郷愁を追ひ行くもの。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚空を翔け行く鳥の如く情緒もまた久しき過去に消え去るべし。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去は寂寥の谷に連なり未來は絶望の岸に向へり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われの生涯を釣らんとして過去の日川邊に糸をたれしがああかの幸福は遠きにすぎさり小さき魚は瞳にもとまらず。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
