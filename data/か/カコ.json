[
  {
    "uuid": "f7415f25-81bc-5b98-9cdc-d58ea3a79002",
    "entry": "過去",
    "reading": {
      "primary": "かこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "副詞",
