        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は定年退職後も、趣味の登山や地域活動に活動的に参加している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この子はとても活動的で、一日中走り回って遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "活動的なライフスタイルを送ることで、心身ともに健康を保つことができます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近はSNSを通じて活動的な情報発信を行う企業が増えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "風雅の道はいかなる積極的活動的なる日本にも存在すべきものなのである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷淡は人を閑殺し、熱意は人を活動的ならしむ。",
              "citation": {
                "source": "熱意",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の劇の演ずるところ悲劇にもあれ、喜劇にもあれ、斯かる機会に到着する時には、演者も観客も劇の本色を忘れて、宛然たる活動的絵画の中に没入して、人もなく、事もなく、暫らく之に幻惑せられざるを得ざるが常なり。",
              "citation": {
                "source": "劇詩の前途如何",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この快適な気候と、活動的な日々との中で、足りないものは、それだけだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の話に依れば蛭氏の私宅には、電話が便所の中にまであるさうだ、彼は左手で受話器をはづし耳にもつて行き、右手を別な方面に動かしながら、ふと厠の中で思ひ出した用件に就いて、間髪をいれずに相手を臭いところに呼び出すといふ活動的なエネルギー主義者であつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本画家のうちでもつとも現在活動的な作家には、年輩を超越して、この種の老年の感傷に捉へられてゐるものは全くない、沢山の日本画家が現はれて、その大部分が没落してゆくのは、人間の感傷性を作品に加へて或る期間はそれでも済むが、永い期間には、その感傷性そのものに敗北してゆくのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "今我々は菊池契月氏といふ、既に出来上つた作家に対して、いかなる注文をなしたらいゝか、作品年表をみてもわかるやうに、この作家は、（旧姓細野契月）時代から、如何に活動的な作家であつたかといふことに思ひ到るときは、それは驚嘆に値する。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "活動的な作家なのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそのまちまちの批評は、児玉氏が決して画家型の作家でなくて対外的にも活動的な作家であるといふ理由で、その批評は少しも統一される機会が与へられないとも言へる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "旭川風物詩師団通り所見鈴蘭通りの美しさ北国の夜の街は白痴美商店街のネオンサインは光りの瞼をうごかさずもつとも人生万事動けば金がかかるからねでも街を静寂から救ふものは光りの明滅ではなく市民が活動的であることだ！",
              "citation": {
                "source": "小熊秀雄全集-11",
                "author": "詩集（10 ）風物詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "探るは、活動的也、又奮鬪的也。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方式は我々の活動的意識作用において最も明に見ることができる。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち主観的意識現象とは如何なる者であるか、いわゆる精神現象とはただ実在の統一的方面、即ち活動的方面を抽象的に考えたものである。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の精神はその身体と同じく生れながらにして活動的である。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世のいわゆる道徳家なる者は多くこの活動的方面を見逃している。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジガ蜂の颯爽たる風姿はいかにもさかんな活動的な季節の先駆けたるにふさはしく、沈んだ病室内の空気までがにはかに活気を帯びて来るやうに思はれるのだつた。",
              "citation": {
                "source": "ジガ蜂",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーロッパ一頭の切れる人物、ヨーロッパ一活動的な私立探偵と、誰もが認める男だ。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "本間教子は、友代の素朴な熱心な活動的な天稟のままに気稟の側から全幕を演じ、この幕もそのようなものとして自然に演じているのだけれど、作者としては、友代のそういう自然発生の活動性、積極的な人柄を、周囲との関係でどう考えて見ているのだろうか。",
              "citation": {
                "source": "「建設の明暗」の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は「精力が伝染するように無気力も伝染するもので、この太古のままに生きている人々の魂から、彼の活動的精神を毒するなにか鈍い毒気のようなものが、機械についた錆のように発散されるのだ」そして、「少しずつ彼を吸いとって弱めてゆく微妙なあるもの」は「かつて彼等を征服したあらゆる民族を噛みこなした。",
              "citation": {
                "source": "「揚子江」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真も、横向きになって椅子に坐るとその椅子が自然に廻転して、正面に向くまでの間の全瞬間を活動的にとる仕掛になっていた。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが文化の理論の最も活動的な内容は、当然現実の諸文化の批評である。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に自然科学それ自身が歴史をもち、又社会――例えば学会――をもつ、現代から除外されたり現代を超越せしめられたりした自然科学者は、活動的な自然科学者ではあり得ないだろう。",
              "citation": {
                "source": "再び「科学の歴史的社会的制約」に就いて",
                "author": "――岡邦雄氏に答える――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――カントの如きは啓蒙の概念を定着するに際して、之をプロシャ化さねばならなかったために、啓蒙の一応非政治的であるという実は極めて活動的な規定をば人の油断している間に、却って極めて制限的な規定にすりかえて了ったのだ。",
              "citation": {
                "source": "啓蒙の現代的意味と役割とについて",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう活動的な習慣はこのごろ若い人々の間に移って来て、旅の楽しさ、旅の間に動いている人間らしい目付の溌剌とした輝きが快く目にとまるようになった。",
              "citation": {
                "source": "映画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の気質は明く活動的であったから、自分の仕事のあるところを生活の土地として、どちらかといえば故郷を忘れて生活した。",
              "citation": {
                "source": "故郷の話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、明治の先覚的な婦人として我々に伝えられているキリスト教関係の多くの活動的な婦人は、殆ど皆この前後、いわゆる明治の開化期に、進歩的な教育を受けた人々なのであった。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
