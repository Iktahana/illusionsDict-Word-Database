[
  {
    "uuid": "15b0aa95-ee8c-5be2-8782-cd7cd2b2b824",
    "entry": "華美",
    "reading": {
      "primary": "かび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "形容動詞"
      ],
