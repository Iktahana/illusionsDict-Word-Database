    "definitions": [
      {
        "index": 1,
        "gloss": "(aircraft) hangar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
