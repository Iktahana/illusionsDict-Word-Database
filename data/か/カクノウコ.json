        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "嵐が近づいているため、全機体を格納庫へ移動させました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "修理が必要な航空機が、巨大な格納庫の中で静かに待機している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「さあ、次のフライトのために、機体を格納庫から出そう！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "博物館には、古い飛行機が大切に格納庫に展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "Ｓ大尉が格納庫の中で機体の手入れをしていると、飛行服を著たＳ中尉が顔色をかえて飛んで来て、「Ｍ兵曹がおれの機に乗ってたのだ」　と云ったかと思うと、そのままばったりと倒れてしまった。",
              "citation": {
                "source": "空中に消えた兵曹",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の下の大河を隔てた夕暮富士を越えて、鮮かな平蕪の中に点々と格納庫の輝くのは各務ヶ原の飛行場である。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "抜けめがないな○走れ　走れ地｜球行きのロケットは　格納庫の一ばん右はじですありがたう！",
              "citation": {
                "source": "小熊秀雄全集−22",
                "author": "火星探検―漫画台本",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが格納庫だどこから入りませう○格納庫の天｜窓から入らうよしつ！",
              "citation": {
                "source": "小熊秀雄全集−22",
                "author": "火星探検―漫画台本",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚ろいた　地｜球行きはどれだらうあんまり沢山あるからわからないわ○格納庫の右｜端だと教へてくれたよこれは金｜星行きのロケットだわあつたあつた！",
              "citation": {
                "source": "小熊秀雄全集−22",
                "author": "火星探検―漫画台本",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで一、二、三」　ついに艦載機はうまく格納庫に入った。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行島の甲板、砲塔、格納庫、機関部、操縦室、監視所、弾薬庫、各士官室、無電室、その他ありとあらゆる島内の要所から、この司令塔内へ向かって、幾十万、幾百万の電線が集っているのであった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "総出の整備員は、汗だくだくの大童となって、新着の飛行機をエレベーターにのせ、それぞれの格納庫へおろした。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の仏蘭西の格納庫員へ手をあげて――。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達二人は屋上に出て、格納庫の扉をひらくと飛行機を引っぱり出した。",
              "citation": {
                "source": "空中墳墓",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉庫もある、飛行場もあれば格納庫もある。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行場は東京の青山練兵場に少し広い位の場処で、大小二十幾所の格納庫が其れを取巻いて居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの格納庫にも幾つかの飛行機が納められて居て一一様式が異つて居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行場は陸軍省に属して居ても、官営｜万能ガツシヨン・アリエンヌに属する格納庫に両三日前｜発動機の装置の改善を終つた滋野君の若鳥号が納められて居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつものように、格納庫から離陸場へ引出された飛行機は、黒吉を乗せると、昨夜、この原で、無残な殺人が行われたのも知らず、一点の雲もない蒼空に、いかにも軽々と飛込んで行った。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思いつくと、葉子の死骸を、長いことかかって格納庫まで引ずるように、持って来、勝手知った出入口から忍込んで、たった一台しかない旧式練習機の、座席の足元から横に開いた特別広い空胴の中に、無理矢理押込むと、あとは知らん顔して飛行を待っていたのだった……。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかで、技師や職工たちはよく働いて、格納庫につながれてゐるノルゲ号に最後の手入れをしました。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、ノルゲ号は格納庫から引き出されました。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞穴はこの帆船の格納庫の役目をしている。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭に大きな木小屋があったが、すなわち今日の格納庫で、戸をあけるとその中に粛然と大鵬が一羽うずくまっていた。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、白堊の家だけではない、工場もあるし、動力所とおぼしい建物もあるし、飛行機の格納庫さえある。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、それなら家も、格納庫も、氷に鎖されているはずだ。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はやります」「では、君は、夜半に格納庫を襲うてもらおう。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は、格納庫に火を放つのじゃ」「爆弾がございますか」「爆弾のような化学兵器が、手に入るくらいなら、こんな命がけの冒険はせんよ。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "格納庫夜襲　遂に夜襲のときが来た。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も、たった一人で、格納庫焼打に往くのだ。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "格納庫の附近には、歩哨も、動哨もいはしない。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
