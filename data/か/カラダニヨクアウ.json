        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このスーツ、体に良く合っていて、すごくかっこいいね！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "オーダーメイドの服は、やっぱり体に良く合うから着心地がいい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "探していた理想のワンピースが見つかった！体に良く合って、デザインも完璧だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そのつもりでぬったが、からだによくあうかどうかわかりません。",
              "citation": {
                "source": "田舎のお母さん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
