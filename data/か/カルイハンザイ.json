        "examples": {
          "standard": [
            {
              "text": "「自転車の傘さし運転も、厳密に言えば法律で禁じられている軽い犯罪になるんですよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若気の至りとはいえ、万引きのような軽い犯罪であっても一生の汚点になりかねない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は軽い犯罪を繰り返した末に、ついには取り返しのつかない大事件を起こしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "指定日以外にゴミを出す行為は、社会のルールを乱す軽い犯罪に近い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "之は従前の軽い犯罪に対してのものだったと信ぜられる。",
              "citation": {
                "source": "殺人狂の話",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
