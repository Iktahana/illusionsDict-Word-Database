        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の裏切り行為は今や隠れも無い事実だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の才能と努力は隠れも無く、多くの人々から称賛されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その会社の環境汚染問題は隠れも無く、住民たちの間で大きな話題となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の絵の技術は隠れも無く、見ればすぐに彼の作品だとわかるほどだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "相対性原理論の独創的研究家としてかくれもない人だ。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿下は陸軍騎兵附の大佐で、かくれもない馬好でいらせられるのですから、御｜寵愛の「ファラリイス」という亜刺比亜産を種馬として南佐久へ御貸付になりますと、さあ、人気が立ったの立たないのじゃ有ません。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿下は陸軍騎兵附の大佐で、かくれもない馬好でいらせられるのですから、御寵愛の「ファラリイス」という亜刺比亜産を種馬として南佐久へ御貸付になりますと、さあ、人気が立ったの立たないのじゃ有ません。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "泉先生が常に里見さんの作品のいいところと出來損つたところとを、痛い程明かに指摘されながら、しかも※さんの冴えた手腕を推稱して、現代並びなきものとして居られるのは、かくれもない事實である。",
              "citation": {
                "source": "貝殼追放",
                "author": "泉鏡花先生と里見※さん",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿下は陸軍騎兵附の大佐で、かくれもない馬好ですから、御｜寵愛のファラリイスと云亜刺比亜産を種馬として南佐久へ御貸付になりますと、さあ人気が立ったの立たないのじゃ有りません。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿下は当時陸軍騎兵づき大佐で、かくれもない馬好きでいらせられるのですから、御寵愛の「ファラリース」というアラビヤ産を種馬として南佐久へお貸し付けになりますと、人気が立ったの立たないのじゃありません。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "古くアイヌが日本人或はその他の異民族と盛んに交易を行ったことは、歴史上かくれもない事実であります。",
              "citation": {
                "source": "アイヌ宗教成立の史的背景",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その手だ」と彼は笑いやんで呟いた、「おれの臆病者はかくれもない事実だからな、いまさら人の評判を気にする必要はない、よし、この手でゆこう」　双子六兵衛は立ちあがり、旅嚢を肩に、笠をかぶって松林から出ていった。",
              "citation": {
                "source": "ひとごろし",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、かくれもない問題だったと聞いているふたりの浮名は。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お次と又四郎のふたりが、祭の晩に、大川端から身投げしたと、この界隈で、いま、かくれもない評判の中に――。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……たのむ」　かくれもない事なので、御厨の浦人が、何度もいって聞かせるまでもなく、小次郎もよく知っている。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――木曾殿と鎌倉殿との不和はかくれもない事です。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄文炳の悪評はかくれもないが、その兄の黄文※は、土地の人にも、　黄仏子（ほとけの黄さん）　と別名でよばれているほど、善人の聞えが高いという。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四百余州にかくれもない梁山泊のことですからな。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "義元上洛の計画は、今ではかくれもないことで、ただ時期の問題であった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとよりかくれもない人ではあるが、今日信長からこれほどな礼遇をうける人として、あらためてその人を想念にのぼすときは、世のなかも革まって来たが、人も進み時代の先駆もみな、ようやく大人になって来たものだという感がなきを得ない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは伊勢亀山の城主で、神戸信孝に仕えていたが、夙に、誼みを秀吉に通じ、伊勢ではかくれもない“異心のある者”と見られていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "関ヶ原の合戦に、細川家は東軍に御加勢、徳川方と旗幟はすでに鮮明でおざるし――また、其許におかれては、故太閤さまの遺孤秀頼｜君が、唯一の味方とお頼みの人とは世上にかくれもないことよ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくれもない天下の敵である」「…………」　呂布は、沈黙していた。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「関羽の勇は、万夫不当と、天下にかくれもないものです。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
