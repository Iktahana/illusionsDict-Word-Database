        "examples": {
          "standard": [
            {
              "text": "京都を訪れると、日本の伝統的なカルチャーの深さに改めて感動する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現代の若者たちの間で流行しているネットカルチャーについて研究している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は異文化理解を深めるため、積極的に現地のカルチャーに触れるようにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社のイベントで、各国のカルチャーを紹介するブースが設けられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "買ってきてすぐに使い出せるパッケージソフトの完成を待つという彼らの決意を前にして、浜田はある種のカルチャーギャップにさらされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後離婚と退職をきっかけにサンフランシスコに移り住んだアルブレヒトは、大気中にカウンターカルチャーのにおいの充満したカリフォルニアで、コンピューターの布教活動を続けたいと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六〇年代後半、世界をおおった学生反乱の源流を生み、カウンターカルチャーの巨大なゆりかごとして機能した西海岸のはみ出し者たちの中には、コンピューターを管理と支配の象徴としてとらえる意識が根を張っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
