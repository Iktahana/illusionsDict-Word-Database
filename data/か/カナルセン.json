        "examples": {
          "standard": [
            {
              "text": "放電管の陰極に穴を開けると、その反対側に光の筋としてカナル線が観測される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "カナル線の正体は正の電荷を帯びたイオンの流れであると、ウィーンの実験で判明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "磁場の中でカナル線を偏向させることで、原子や分子の質量を精密に測定できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "物理の授業で、カナル線が電場によって曲げられる様子をシミュレーションで確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "老人株ではカナル線の発見者ゴールトシュタインや、ワールブルヒなどがおり、若手ではゲールケ、プリングスハイム、ポールなどもいた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（カナル線）理論によれば、これ等の原子の振動数はその運動によって、ちょうど動いている時計に対して導き出されるのと全く同様の方法で、影響されて見えることが期待せられます。",
              "citation": {
                "source": "相対性理論",
                "author": "アルベルト・アインスタイン",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
