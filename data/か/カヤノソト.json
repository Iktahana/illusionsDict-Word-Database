        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "専門的な議論が飛び交う会議の中で、知識のない私は完全に蚊帳の外に置かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ごめん、今の話、何のこと？ 僕だけ蚊帳の外みたいで、全然話が見えないんだけど」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "周囲が流行のファッションや最新のゲームで盛り上がっているのを、一人だけ蚊帳の外で眺めるのは少し寂しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "政治の世界では、密室での妥協によって、声の小さい少数派が蚊帳の外に追いやられることがしばしばある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "円かなる夢百里の外に飛んで眼覚むれば有明の絹燈｜蚊帳の外に朧に、時計を見れば早や五時なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍ署の高等係中村は、もう、蚊帳の外に腰を下して、扇子をバタバタ初めていた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "船虫が蚊帳の外の床でざわざわ騒ぐ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蒼ざめた腮の下に黒くなめらかに光る鱗のようなものが見えたので、蚊帳の外から気味悪そうに覗いていた源次は、思わず顔をあとへ引いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "富沢は蚊帳の外にここの主人が寝ながらじっと台所の方へ耳をすましているのを半分｜夢のように見た。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦子は辛うじて蚊帳の外に、障子の紙に描かれた、胸白き浴衣の色、腰の浅葱も黒髪も、夢ならぬその我が姿を、歴然と見たのである。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひたと冷い汗になつて、眼を※き、殺されるのであらうと思ひながら、すかして蚊帳の外を見たが、墓原をさまよつて、亂橋から由井ヶ濱をうろついて死にさうになつて歸つて來た自分の姿は、立つて、蚊帳に縋つては居なかつた。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "行燈は蚊帳の外の、宵から置いた処にちゃんとあって、薄ぼんやり紙が白けたのは、もう雨戸の外が明方であったんです。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひたと冷い汗になって、眼を※き、殺されるのであろうと思いながら、すかして蚊帳の外を見たが、墓原をさまよって、乱橋から由井ヶ浜をうろついて死にそうになって帰って来た自分の姿は、立って、蚊帳に縋っては居なかった。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "庵室から打仰ぐ、石の階子は梢にかかって、御堂は屋根のみ浮いたよう、緑の雲にふっくりと沈んで、山の裾の、縁に迫って萌葱なれば、あま下る蚊帳の外に、誰待つとしもなき二人、煙らぬ火鉢のふちかけて、ひらひらと蝶が来る。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は豆ランプを消すのを忘れたので蚊帳の外へ匍い出しかけたが、また止めて蚊帳の中へ入りました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっと聴きいっていた登勢はきゅうにはっと起き上ると、蚊帳の外へ出た。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿子はベソをかきながら、父のあとについて蚊帳の中へはいろうとすると、「お前は蚊帳の外で、出来るまで弾くんだ」　という父の声が来た。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜はもうこの位で勘弁してくれと、頼めばよさそうなものだのに、頑として蚊帳の外に頑張っているその依固地さは、十や十一の少女とは思えなかった。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜町の親父が来て、吊って寝ると云って持ってったが、蚊帳の外へ、養老しぼりの浴衣を着た、二十位の女が来て中を覗いたそうだ。",
              "citation": {
                "source": "沼田の蚊帳",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　言ううちに、鼠はお此の衾の上を飛びおりて、蚊帳の外へ素早く逃げ去った。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは寝まきのままで、蚊帳の外へ這い寄った。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、お元は蚊帳の外に手をついた。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "青黒い顔の男は大声をたてながら蚊帳の外へ飛び出して逃げた。",
              "citation": {
                "source": "海異志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕頭になった蚊帳の外には一人の女が坐っていた。",
              "citation": {
                "source": "女の姿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうした、何をしているのだ」「まあ坐れ、少し話がある」と云って、二人が坐るのを待って「この家は化物屋敷だぜ」「どうして、何かあったのか」「君等が出て往った後で、蚊帳へ入って、少し睡って、今度眼を覚まして枕頭を見ると、蚊帳の外に女が坐っていた」　それを聞くと二人の生徒が笑いだした。",
              "citation": {
                "source": "女の姿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は蚊帳の外で、暫く東京なる旧友の噂をする、それも一通りの消息を語るに過ぎなかった。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "撫子の浴衣を着た若い女が蚊帳の外から覗いているような夢におそわれて、少しうとうとするかと思うとすぐに眼がさめた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は蚊帳の外から声をかけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "山祝いの夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その何かを鼠に咬られでもしてはならないと思い付いて、かれは煙管を手に持ったままで蚊帳の外へくぐって出ると、物の触れ合うような小さい響きはまだ歇まなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊帳の外には足が投げ出してあった。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲團をのべて蚊帳の外へ出る。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "カヤノは寝るときまでそれを抱いていたのだが、たぶん夜なかに、ころころ寝ころぶうちにかやのそとへ投げとばしていたものだろう。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
