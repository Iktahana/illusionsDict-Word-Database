        "examples": {
          "standard": [
            {
              "text": "彼女は高校を卒業後、しばらくの間、家事手伝いをしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「お母さん、何か家事手伝いすることある？」と子供が尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近は、共働き世帯で家事手伝いを頼む家庭が増えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "いまから三十年もむかし、中流の家庭では一人二人の家事手伝いの女をもっているのが普通であった。",
              "citation": {
                "source": "私の青春時代",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間きめて、朝、夕、手つだってくれて、その余の時間はその人としての勉強なりあって、そのために家事手伝いもするというようなのならば。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
