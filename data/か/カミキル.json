[
  {
    "uuid": "0c51e256-9af5-5d3c-ac54-db4bcc963765",
    "entry": "噛み切る",
    "reading": {
      "primary": "かみきる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
