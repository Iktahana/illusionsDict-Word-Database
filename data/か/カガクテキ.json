[
  {
    "uuid": "3c7a0925-a3de-5c6e-8032-fa669be4a6b4",
    "entry": "化学的",
    "reading": {
      "primary": "かがくてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
