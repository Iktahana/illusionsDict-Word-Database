    "definitions": [
      {
        "index": 1,
        "gloss": "dry (method)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "最近のコピー機は、湿式ではなく乾式トナーを使用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この洗濯機は、乾式ドラムを採用しており、衣類へのダメージが少ない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "乾式工法は、水を使わないため工事期間を短縮できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "かれは規定の金を払つて入口の女中に湿式浴室の専用を頼んで置いて、その整理の出来る間を二階の乾式浴室の中に過した。",
              "citation": {
                "source": "浴室",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤く塗った箱形の乾式計量器であるが、之には大きなコックがついている。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
