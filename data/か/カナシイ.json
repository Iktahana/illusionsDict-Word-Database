[
  {
    "uuid": "9f2edeec-19c7-5217-affc-25f567c416ab",
    "entry": "悲しい",
    "reading": {
      "primary": "かなしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
