      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sad",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昨日飼っていた犬が亡くなってしまい、とても悲しい気持ちになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の話を聞いていると、あまりにも辛くて悲しい出来事だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試合に負けてしまったけれど、みんなが頑張ったから悲しい結果ではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遠く離れた故郷の友人が、悲しい知らせを伝えてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "だつて君そこに浮気があります浮気は悲しい音楽をヒヨツと忘れさせること度々です空　空　空やつぱり壁は土で造つたものでした。",
              "citation": {
                "source": "不可入性",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほがらかとは、恐らくは、悲しい時には悲しいだけ悲しんでられることでせう？",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "降りくる悲しみを少しもうけとめないで、安易で架空な有頂天を幸福と感じ做し自分を売る店を探して走り廻るとは、なんと悲しく悲しいことだ……３神よ私をお憐み下さい！",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の書中の諸詩篇を、年代順に配列し直して読むならば、詩毎に、彼が駆廻つた短い道程、彼の旅行、彼の恋、彼の悲しい肉体を、熾な芸術家の申し分ない歎賞を以て、繰返す思ひがするのである。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "拙い所を引ッ込めようとして、好い所まで引ッ込んぢまふやうなことも有り勝なこと、殊に文学や絵画に於てそのことは有り勝だらう……左を苦境時代のはじめに用ふ事ほんとに悲しい日を持つた人々は、その日のことが語れない。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は口に人道と博愛を称へ、自ら求め得ざる夢想の愛を求めんとして、苦しき努力の生涯を終りたる、あの悲しいトルストイの徒ではなくして、真にその肉体から高貴な人義的の愛を体得して生れた「生ける愛の詩人」である。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの悲しい宿命者も、さすがに日本に渡ってからは、多少の平和と幸福を経験した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『自分が死んでから、後生が鳥や虫に生れ変るとしても、自分は少しも悲しいと思わない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそうした八雲の悲しい心は、常に最も夫人の心を痛ましめた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした悲しい対話――これほどにも悲しい対話があるだろうか――が、いつもこの夫婦の間では、半ば詩のごとく、半ば笑談のようにして語られた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、この悲しい詩人の霊は、雑司ヶ谷の草深い墓地の中に、一片の骨となって埋まっている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも遂に何物も、何物の自由も自分には絶望であつたといふことを、悲しい沈鬱の語氣を以てかき口説いた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその自由は、悲しいかな彼自身の教養に屬しなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな荒寥とした曠野の中に、五階七階のビルヂングがそびえ立つて、悲しい田舍の花火のやうに、赤や青やのネオンサインが點つて居る。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しい市街の風景である。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何といふ悲しい景色だらう。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男は、悲しいのだ。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それは聞きました」私は悲しい気持ちであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は、子供の時から、どうしたつて悲しい思ひをしなければならぬものだ。",
              "citation": {
                "source": "純真",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "友に裏切られたことは、見も知らぬ男に裏切られたより悲しい――といふのは誰でも分る。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしおなかが空いたの――」　兄が傍を通る時に、畳の座板がひわるのが、良子の重ね合せて坐つてゐる足に感じられた、彼女は悲しい気持になつてゐた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれだけ好きな野球なんだから、負ければ悲しいつてことでもあればまだしも………それもない。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して、勿論それは好もしいことであると同時に、その裏にはまた少々悲しい事情もなかつたとは云へぬ。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は彼女が、今は昔恋の罪のために父君から塔の中に幽閉せられるやうになつた姫に関する悲しい歌をうたふのを聞いた。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だかこれを聴く毎に、僕は日本文化の悲しい末路といふことを痛感する。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、かなしいといふことは、語る権利があるといふことのやうに吾人にはともかく思はれる。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大風の吹く城の向うで化猫草の穗のゆらゆらとうごいてゐてなにものかかなしい追憶の敵が笑つてゐる。",
              "citation": {
                "source": "敵",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は、かなしいやら、こわいやら、うれしいやら、はずかしいやら、胸が一ぱいになり、わからなくなってしまいまして、妹の痩せた頬に、私の頬をぴったり押しつけ、ただもう涙が出て来て、そっと妹を抱いてあげました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪かなしいつ大仏の瓦葺　夢のように唐突であり、巨象のように大きな大仏殿。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故にこそ、いっそう、恥かしくかなしいものなのであろう。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
