        "examples": {
          "standard": [
            {
              "text": "風邪をひいたので、喀痰がひどい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "医師は患者に喀痰を採取するように指示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "喀痰を伴う咳は、気管支炎の兆候かもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うっ…！この咳、喀痰が止まらなくて辛いよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "喀痰の中に新鮮な血の交ったのがいくつも出てくるのを見ると、知らず知らず溜息が出た。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清逸は喀痰を紙に受けていくらかの明るみにすかしてみた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病者は消毒藥を盛りたる壺中に喀痰するも、路傍に喀痰するも、其の自體に關しては何等の差を生ぜずと雖も、社會の此が爲に受くる差は決して少くは無い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "八日目の朝に看病夫が來て、彼の喀痰を採つて行つた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "八日目の朝に看病夫が来て、彼の喀痰を採って行った。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "附記喀痰は一昼夜の分量、二個のコツプに六、七分目づつ位なり。",
              "citation": {
                "source": "明治卅三年十月十五日記事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの血液型なんかその喀痰からして、もう夙くの昔に判っていることでしょうよ」「ああ、それでは貴女はこれからどうしようというのです。",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
