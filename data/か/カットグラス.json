        "examples": {
          "standard": [
            {
              "text": "贈答品として、美しいカットグラスのペアグラスを選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夕食のテーブルには、きれいに磨かれたカットグラスが並べられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バーカウンターに並んだカットグラスが、照明を反射して妖艶な光を放つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "鈴蘭燈の並んだ狭いアスファルトの街に人が一杯で、ふと店さきのショー・ウインドーを見ると、独逸製のカットグラスが透明になって消えた。",
              "citation": {
                "source": "透明な輪",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はパリーから受ける私の印象は、廻るカットグラスの面を見ているように日々変化してやまぬ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、型の如く煤けた天井と、同じく煤けたシャンデリアで、それにはカットグラスが沢山ぶらさがっていて、給仕が型の如く、海辺に集う鳥の数ほど夥しい茶碗を載せた盆を、大胆に振り廻しながら擦りきれた油布の上を駈けまわるたんびに、跳ねあがったり、ちりんちりん音を立てたりする。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "カットグラスの大鉢に盛りあがった見事な葡萄の房の対うで、千鶴子は傍にいる田辺侯爵夫人と話していた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "上等の古いカットグラスから氷屋のコップ、写真のレンズ、虫めがねにいたるまで同じ程度において愛着を感じ、ことに色ガラスの色感くらい私を陶酔させるものはない。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "「南原女史、さあ」　蓬莱建介は、シャンパンをいさましくぬいて、最初にカットグラスを彼女の手に渡した。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
