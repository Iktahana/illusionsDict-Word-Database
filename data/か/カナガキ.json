    "definitions": [
      {
        "index": 1,
        "gloss": "writing in kana",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "幼児向けに書かれたこの絵本は、すべての文章が分かりやすい仮名書きになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ここ、漢字だと低学年には難しいから仮名書きにしておいてくれる？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古典文学の写本の中には、優美な仮名書きだけで綴られたものが数多く存在する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "名前を漢字で書くのが難しい場合は、無理をせず仮名書きで提出しても構いません。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "文中の一部をあえて仮名書きにすることで、文章全体の印象を柔らかくする工夫を凝らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "仮名書きの物を読むのは目に時間がかかり、念仏を怠ることになり、無益であるとしたのです。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者は、柳亭種彦の読本――之を仮名書きにした草双紙｜合巻の方が、広く行はれた。",
              "citation": {
                "source": "草双紙と講釈の世界",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐夫志といふ仮名書きのあるのによつても分かる。",
              "citation": {
                "source": "『さびし』の伝統",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮名書きの美しかりし手跡は痕もなく、その人の筆かと疑うまで字はふるい墨はにじみて、涙のあと斑々として残れるを見ずや。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国の美しさから、日本の美しさに移る時、ちょうど、いかめしい、重たい漢字の美しさから、さらさらと流れる「仮名書き」の字の美しさに移ったような、そんな軽みが日本特有の美しさとして現われるように思われる。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが全日本の女に虚栄の仮名書きを、是非もない事のように身に着けさせ、現在になおかつ続いている状態なのである。",
              "citation": {
                "source": "美術芸術としての生命の書道",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮名書きには久久都・久求都、或いは多邇久々とある。",
              "citation": {
                "source": "くぐつ名義考",
                "author": "古代社会組織の研究",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢字にたよらず、もっぱら自国の文字でそれを仮名書きにする西洋人にとっては、ニッポンとニホンとは明らかに別の名である。",
              "citation": {
                "source": "国号の由来",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "六条村年寄の留書を見ると、辻子の事をよく「るし」と仮名書きしてある。",
              "citation": {
                "source": "特殊部落の言語",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この称は近ごろになって始まったのではなく、既に文安の「※嚢抄」にも、明らかに「エッタ」と仮名書きしてあるのである。",
              "citation": {
                "source": "「エタ」名義考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "後者の峠の字は、「たうけ」と仮名書きにした本もあるから、恐らく後の人が書き替えたものであろうと思う。",
              "citation": {
                "source": "峠",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "厄介の貝六へも　人呼んで厄介の貝六、海道筋でよくない事ばかりしている中年男のところへも、仮名書きの不思議な手紙が届けられました。",
              "citation": {
                "source": "大江戸黄金狂",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地紅の結び文で、武士の手に取るには、如何にも艶かしいものですが、そんなものが来るのを予期して居たような心持で、押し開いて読むと、仮名書きの恐ろしく巧い手蹟で、「あの夜の不思議を解き度くば、崇巌院の主を訪ねられよ」　とだけ書いてあります。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第一夜　初夜を盗む",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか作曲上当面する問題として、歌詞が仮名書きにして七とか五になっていても、その中の二音を発音すると一音のようになるのがある。",
              "citation": {
                "source": "歌詞とその曲",
                "author": "信時潔",
                "note": "青空文庫"
              }
            },
            {
              "text": "小一郎のは仮名書きであったが、墨をたっぷり含ませた筆で勝手に書いたらしく、字と字がくっついて紙面がまっ黒になってい、殆んど判読することさえできなかった。",
              "citation": {
                "source": "ちくしょう谷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど秋の夜の読み物には適していると思ったので、くどい所や仮名書きのために分らない所は省略もしたし、多少は手を入れたが、大体原文の意を辿って成るたけ忠実に現代語に直してみた。",
              "citation": {
                "source": "三人法師",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本文において人名は仮名書きに統一したが索引にはフルネームの他にできるだけ生没年を調べて加えた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶安二年にでた仮名書きの和本にしても、当初はやはり参考書の意味で読まれた場合が多いのではないかと思われる。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、仮名書きの墨あとも淡い文字のあとが、こう読まれた。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三十歩の石畳の上を、カタ、カタと塗下駄の音が静かに運んでゆく――、そしてやがて、正面の石段を降りかけたが、フイと、足もとからさす明りに足をとめてみると、草履を持ってしゃがみこんだ一人の男、そばに、仮名書きで「こばいあん」とした朱文字の提灯をおいて、ゆるんだ鼻緒をすげなおしている。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、内へ帰るのを待兼ねて、大通りの露店の灯影に、歩行きながら、ちらちらと見た、絵と、かながきの処は、――ここで小母さんの話した、――後のでない、前の巳巳巳の話であった。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また飜って、お嬢さんの出のあたりは――何をいうのだ――かながきの筆で行く。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "博物館などにゆくと、貫之の美しいかながきなどがありますが、またむずかしい字を巧く、くずし方などあると、絵の横に書きとって来ることがありました。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある大名の売立に行くと、美事な貫之のかながきの巻物がありましたので、一、二行うつすつもりで書き始め、とうとう巻物全部をうつし取ってしまいました。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
