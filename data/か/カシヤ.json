[
  {
    "uuid": "ed3e22dd-b7c6-550d-a9ec-e707fb4c09e5",
    "entry": "菓子屋",
    "reading": {
      "primary": "かしや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
