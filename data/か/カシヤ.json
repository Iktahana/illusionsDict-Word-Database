      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "confectionery shop",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「わあ、この菓子屋の店先に並んでる飴玉、色とりどりで可愛い！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おばちゃん、おまけしてよ！」と近所の子供たちが菓子屋に集まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "創業百年の老舗菓子屋が、建物の老朽化を理由に、惜しまれつつその歴史に幕を閉じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "されば菓子屋、植木屋、吹屋、射的場の前には、今一客を止めず。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は隣の菓子屋の主婦と子供を二、三人連れて、花吹雪の竹の台を歩いていた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所では隣の菓子屋の主婦が忙がしそうに立働いている。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水菓子屋の目さめるような店先で立止って足許の甘藍を摘んでみたりしていたが、とうとう蜜柑を四つばかり買って外套の隠しを膨らませた。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "淋しい田舎の古い家の台所の板間で、袖無を着て寒竹の子の皮をむいているかと思うと、その次には遠い西国のある学校の前の菓子屋の二階で、同郷の学友と人生を論じている。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男は、どこかそこらの野原の菓子屋だ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "菓子屋で菓子を買ってくれた。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣へ見にやる、菓子屋へ見にやる、下水溝の橋の下まで見たが、まさかに池とは思わないので、最後に池を見たらば……。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷中の台地から田端の谷へ面した傾斜地の中腹に沿う彎曲した小路をはいって行って左側に、小さな荒物屋だか、駄菓子屋だかがあって、そこの二階が当時の氏の仮寓になっていた。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の吹く素燒の笛で、駄菓子屋で三錢ぐらゐで賣つてる品だが、室生はそれをれいれいしく、寶物のやうにして机の上に飾つて置くのだ。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして街から街へ、先に云つたやうな裏通りを歩いたり、駄菓子屋の前で立留つたり、乾物屋の乾蝦や棒鱈や湯葉を眺めたり、たうとう私は二條の方へ寺町を下り其處の果物屋で足を留めた。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒物屋｜駄菓子屋の店先に客引きの意味でかかっている写真の顔が新聞やビラの広告に頻繁に現われる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "菓子屋のドロツプやゼリビンズは點描派の畫布の樣だし、洋酒瓶の竝んだ棚はバグダツドの祭の樣だ。",
              "citation": {
                "source": "太郎と街",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでなくても老人の売っているブリキの独楽はもう田舎の駄菓子屋ででも陳腐なものにちがいなかった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして街から街へ、先に言ったような裏通りを歩いたり、駄菓子屋の前で立ち留まったり、乾物屋の乾蝦や棒鱈や湯葉を眺めたり、とうとう私は二条の方へ寺町を下り、そこの果物屋で足を留めた。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、五丁目あたりの東側の水菓子屋で食わせるアイスクリームが当時の自分には異常に珍しくまたうまいものであった。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芹川さんのお家は、私の家の、すぐ向いで、ご存じでしょうかしら、華月堂というお菓子屋がございましたでしょう、ええ、いまでも昔のまま繁昌して居ります、いざよい最中といって、栗のはいった餡の最中を、昔から自慢にいたして売って居ります。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金米糖　金米糖という菓子は今日ではちょっと普通の菓子屋｜駄菓子屋には見当たらない。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水菓子屋が鼻風邪でも引いたやうに見える。",
              "citation": {
                "source": "散歩生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜜柑、林檎の水菓子屋が負けじと立てた高張も、人の目に着く手術であろう。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いたのが、例の高張を揚げた威勢の可い、水菓子屋、向顱巻の結び目を、山から飛んで来た、と押立てたのが、仰向けに反を打って、呵々と笑出す。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに、小紅屋と云う苺が甘そうな水菓子屋がある。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」口々に――後見　何が、お霜婆さんの、ほれ、駄菓子屋の奥に、ちらちらする、白いものがあっけえ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、此寺の門前に一軒、婆さんと十四五の娘の親子二人暮しの駄菓子屋があった、その娘が境内の物置に入るのを誰かがちらりと見た、間もなく、その物置から、出火したので、早速馳付けたけれども、それだけはとうとう焼けた。",
              "citation": {
                "source": "一寸怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　其処が水菓子屋の店前で――巽は、別に他に見当らなかったので、――居合す小僧に振向いて、最う一軒薬屋はないか、と聞いて、心得て出て、更めて言った。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水菓子屋で聞いた薬屋へ行くには、彼は、引返して別荘の前をまた通らねば成らなかった。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし仕事をしている時のヘルンは、最も気むずかしやの八釜しい主人であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句もやはり、そうした主観的郷愁の一咏嘆であるが、特に心の詩情を動かしやすく、ロマンチックで夢見がちな初夏の季節を、更衣の季題で捉えたところに、句の表現的意義が存するのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルメルトは赭ら顔で眼をしょぼしょぼさせた何となく田舎爺のような感じのする、しかしどこかなかなか喰えないような気のする先生であったが、しかしやはり一とかどのえらい学者のように思われた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やり切れねえなあ、嬶は又腹を膨らかしやがったし、……」彼はウヨウヨしている子供のことや、又此寒さを目がけて産れる子供のことや、滅茶苦茶に産む嬶の事を考えると、全くがっかりしてしまった。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
