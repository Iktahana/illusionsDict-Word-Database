        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「わあ、すごいボリューム！」山盛りのふわふわなかき氷を見て、思わず歓声が上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "暑い夏の日に、縁日の屋台で食べるイチゴシロップたっぷりのかき氷は格別だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "冷たいかき氷を急いで食べたら、急に頭がキーンとして動けなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "めずらしくかき氷屋があった。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かき氷は咽喉を冷やしただけで、乾きはとめなかったようだ。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝、この現場へ来て、歌と現実がうまく重なり合ったら、歌おうと思ってた」「歌ってくれて、うれしいよ」「この店のかき氷は、うまかったね」「うちの父親は、ベンジャミンといっしょにイタリーへ戦争にいったんだ」　仲間たちが口々にそんなことを語った。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここも暑い」「樹がないからよ」「川には水がほとんどないし」「川も臭い」「でも、草の匂いはしてますね」「夏草に、きたないほこりがかぶさった匂い」「早く死にたい」「私も」　歩いていく途中、かき氷を売っている屋台が一台だけ出ていた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "かき氷、アイスクリーム、ところてん、氷白玉などの品書きの短冊が、壁に貼ってあった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
