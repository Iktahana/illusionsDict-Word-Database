        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "河川工事で川底を浚渫（しゅんせつ）していた。すごい量の土砂が出てきたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ダイバーたちが、沈没船の残骸を川底で探していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この川の川底には、珍しい石がいくつか見つかるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "……　湯の宿と、湯の宿で、川底の巖を抉つた形で、緑青に雪を覆輪した急流は、颯と白雲の空に浮いて、下屋づくりの廂に呑まれる。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る夜はまた、もの思はしげに青みがかつた白い小石が、薄月夜の川底にずつと姿をひそめてゐるのが覗かれる。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青砥、はっと顔色を変え、駒をとどめて猫背になり、川底までも射透さんと稲妻の如く眼を光らせて川の面を凝視したが、潺湲たる清流は夕陽を受けて照りかがやき、瞬時も休むことなく動き騒ぎ躍り、とても川底まで見透す事は出来なかった。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはこの時、人足たちと共に片手に松明を持ち片手で川底をさぐっているような恰好だけはしていたが、もとより本気に捜すつもりはない。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言いながら妙な腰つきで川底の砂利を踏みにじり、皆がその足元を見つめているすきを狙ってまたも自分の腹掛けから二文ばかり取り出して、「おや？",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人足たちは皆一様に、妙な腰つきをして、川底の砂利を踏みにじった。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と青砥は得意満面、「川底に朽ちたる銭は国のまる損。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "九文落して、十一文川底から出て来るとは、奇怪である。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな円い春の満月が水の上から射し込んできて、浅い川底を穏やかな白い明るさで満たしているのである。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間の抜荷買連中と共に逸早く旅支度をして豊後国、日田の天領に入込み、人の余り知らない山奥の川底という温泉に涵っていた。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "川底にもダイヤモンドだの、宝石だのが、ちらばっていました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな岩のあいだを干上がった川底に沿って歩むと、その奥に岩陰となった場所があり、そこに忠実な動物たちがつながれていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの作品が頭に浮かび、「泥にまみれて川底をさらうなんてのは、ちょっといいんじゃないか」と思ったのだそうです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう兼山の丁場の先辺りを、ゴロゴロ川底に打つかりながら流れてるかもしれない。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "川舟が上り、雨が降って、眠れる天龍が、起こって雲を呼び、雨を降らし、川底の石を転がすようになっては、死体の捜索は困難というよりも、至難になるであろう。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人の川舟船夫たちは、底の浅い川舟の中で大騒ぎしながら、竿や櫂で川底の石をつつぱつたり、水を掻いたりして、対岸の絶壁の淵の方へ川舟をやらうと努力してゐた。",
              "citation": {
                "source": "万福追想",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで信乃がいよいよ明日は滸我へ旅立つという前晩、川狩へ行って蟇六の詭計に陥められて危なく川底へ沈められようとし、左母二郎に宝刀を摩替えられようとした神宮川というは古名であるか、それとも別に依拠のある仮作名であるか、一体ドコを指すのであろう。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "女をさらって川底へひきずり込んだかもしれませんぜ」　何をいっても黙々と聞き流しながら、ゆうようと歩を運ばせていましたが、いよいよいでていよいよ右門流でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その渦卷のところで、グル／＼行つたり來たりする、と、何かゞ川底にゐて、丁度ひつぱりこむやうに、その木屑などが渦卷の中に「吸ひこまれて」しまふ。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬や春は川底に味噌漉のこわれや、バケツの捨てたのや、陶器の欠片などが汚なく殺風景に見えているのだが、このごろは水がいっぱいにみなぎり流れて、それに月の光や、橋のそばに店を出している氷屋の提灯の灯影がチラチラとうつる、流れる水の影が淡く暗く見える。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇ここと銚子とは五十里もあろに水は寝ないで流れてく川底から湧く温泉　やがて長野県についた。",
              "citation": {
                "source": "大利根八十里を溯る",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つともこの温泉が川底からわき出してゐるのは奇観である。",
              "citation": {
                "source": "大利根八十里を溯る",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "（九）の五　川底の石は滑かに、流は迅い。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　川底の石は滑かに、流れは迅い。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時橋野川にサケの上る時期であったので、某という漁夫が溜め場を監視しているとこの川のいちばん川上の溜め場の川底に何物ともつかぬふしぎなもの潜みいる。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫唱婦随が美俗とされるところでは、夫の唱える知性の流れがどのように低い川底を走っていなければならないかということに新鮮なおどろきと悲しみの眼を瞠ったとき、婦人の知性の開眼はおこなわれるのであるとさえ思うのである。",
              "citation": {
                "source": "知性の開眼",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その癖、今、都会人が散策する山径が、太古は箒川の川底に沈んでいただろう水成岩であること、その知識によって自然力の微妙さ永遠さを感じさせる手段は一つも講じてない。",
              "citation": {
                "source": "夏遠き山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らく足で川底を探ぐって歩き廻っていた。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の埋り方も、他の利根川や鬼怒川北上川と云ふ川の埋り方と違つて、故らに土砂を流す仕懸になつて居りますから、川底が他の川々よりも急に高くなる。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
