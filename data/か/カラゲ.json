        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "収穫した野菜を大きな絡げにして市場へ運んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "洗濯物をベランダから絡げにして取り込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新聞を絡げた束が玄関先に置かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "畑で刈り取った草を絡げにして片付けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "遠州縞の湯上りの尻絡げで、プロの生活には不似合いな金紋黒塗の乳母車を押して行く容子は抱えの車夫か門番が主人の赤ちゃんのお守をしているとしか見えなかった。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな柳行李が三箇細引で送るばかりに絡げてあって、その向うに、芳子が常に用いていた蒲団――萌黄唐草の敷蒲団と、綿の厚く入った同じ模様の夜着とが重ねられてあった。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今｜一個の抽匣から取り出したのは、一束ねずつ捻紙で絡げた二束の文である。",
              "citation": {
                "source": "今戸心中",
                "author": "広津柳浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "さとよりおまん様人々　写真を見ると、平田と吉里のを表と表と合わせて、裏には心という字を大きく書き、捻紙にて十文字に絡げてあッた。",
              "citation": {
                "source": "今戸心中",
                "author": "広津柳浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗助はまた行李を麻繩で絡げて、京都へ向ふ支度をしなければならなくなつた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "次には尻を絡げた親子連が来た。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "笹の葉の虫は、笹の葉を筒に巻いて糸で絡げ、なかに棲んでいる。",
              "citation": {
                "source": "桑の虫と小伜",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "油紙に包んで凧糸で絡げてある包みを解いて見ると、五寸ぐらいに切った一本の竹筒が現われました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬の首から松の枝へかけた細引を、しかと松の大木の幹へグルグルと絡げておいてから、二人の犬殺しは、ムク犬の首に二重三重に繋がれた鉄の鎖を解きにかかりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "恵林寺の慢心和尚は、法衣の袖を高く絡げて自身真先に出馬して、大小の雲水を指揮して、百姓や見舞人やを叱り飛ばして、丸い頭から湯気を立てています。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この客は差していた両刀を絡げて、無造作に二階番頭に渡して、着物の帯を解きはじめます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい若え者がひとり言をいってるなんざ、みっともねえじゃねえか」　坊主頭へ四つにたたんだ手拭を載せて、朝の陽差を避けながら、高々と尻を絡げたいでたちの相手は、同じ春信の摺師をしている八五｜郎だった。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑稽であったのは、長次郎が一足余分にあったカンジキを草鞋切れの紐を拾って無雑作に絡げつけ、よたよたしながら下りたことである。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "学年の終りに、私はまた行李を絡げて、親の墓のある田舎へ帰って来ました。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ縄でも絡げましょう。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は行李を絡げる努力で、顔やら背中やらから汗がたくさん出た。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "箸を置くと、すぐ二階から細い紐で絡げた包を抱えて下りて来た津田は、急に勝手口から庭先へ廻ったと思うと、もうその包に火を点けていた。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども今更｜鄭寧に絡げたかんじん撚の結び目を解いて、一々中を検ためる気も起らなかった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "能く紙屑籠の中へ入れてしまわなかったという事さ」　細君は赤と白で撚った細い糸を火鉢の抽斗から出して来て、其所に置かれた書類を新らしく絡げた上、それを夫に渡した。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "行李一つ絡げるにさえ、彼は細紐をどう渡すべきものやら分らなかった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗助はまた行李を麻縄で絡げて、京都へ向う支度をしなければならなくなった。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふーン、ばかにしてやがる」　米友がその後ろ姿に冷笑を浴びせている間に、竜之助は縁側まで行くと、そこへ絡げて置いた両刀を携えて、井戸端へ帰って来るのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "背には郁太郎をおぶって、手には風呂敷包を紐で絡げて提げ、足は草鞋を穿いて、歩きながら時々涙をこぼしています。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴鹿山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのもがき出す身ぶりによって見れば、両手を後ろへ廻して縛られた上に、両足をまた一つに絡げてこの中へ投げ込まれていたものと見えます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "伯耆の安綱の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さんのところへ帰してやるぞ」と孝也は云った、「おれは両親のところへ帰る、たぶん帰ることになると思う、だからおまえも帰らしてやる、わかったかちび」　檻の戸口は藤蔓で絡げてあった。",
              "citation": {
                "source": "月の松山",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――で彼は、かえってそれを気易く思ったように、帯の大小を取り外して、背の武者修行風呂敷とともに一つに絡げ、塀の内の蓑掛けの釘へ、預けるようにかけておいた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛の背には自分のほかに、何か縄で絡げた大きな荷物を、後先に縛しつけている。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "借りうけた三尺の木太刀を提げ、袴の襞もたらりと――絡げもせずに、試合の場所を選んで、先に待っていた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処かの女中が裾をからげて、下ばかりみながら近づいて来る。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん今でも未開時代そのままの模範的な迷信が到るところに行われて、それが俗にいわゆる知識階級のある一部まで蔓延している事は事実であるが、それとは少し趣を異にした事柄で、科学的に験証され得る可能性を具えた命題までが、一からげにして掃き捨てられたという恐れはないものだろうか。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
