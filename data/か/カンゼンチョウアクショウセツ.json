        "examples": {
          "standard": [
            {
              "text": "江戸時代の読本は、教育的な側面も持った勧善懲悪小説として人気を博した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「当時の勧善懲悪小説を読み返すと、当時の人々の倫理観が透けて見えて面白いよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "勧善懲悪小説の形式を借りつつ、作者は体制への風刺を巧みに潜り込ませていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "明治四十四年に文部省が「文芸委員会」をこしらえたのは、日露戦争の後、日本の思想界文学界を風靡しはじめた自然主義思想に対して、封建的な習慣や馬琴風の勧善懲悪小説の存在を擁護しようとした結果であった。",
              "citation": {
                "source": "矛盾の一形態としての諸文化組織",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会の発展の過程にあらわれる善と悪とは馬琴の勧善懲悪小説の善玉、悪玉であらわされるよりはるかに動的で互の関係のうちに質の変化を経験してゆくものである。",
              "citation": {
                "source": "地球はまわる",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
