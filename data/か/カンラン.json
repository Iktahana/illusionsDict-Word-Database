  {
    "uuid": "9b6ba87e-b800-512e-b870-77e45a003bbd",
    "entry": "橄欖",
    "reading": {
      "primary": "かんらん",
      "alternatives": [
        "カンラン"
      ],
      "is_heteronym": false
    },
    "grammar": {
