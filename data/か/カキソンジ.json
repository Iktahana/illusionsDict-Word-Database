[
  {
    "uuid": "a3b43dbc-e1b0-540b-aacd-ee1fda8837ea",
    "entry": "書き損じ",
    "reading": {
      "primary": "かきそんじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
