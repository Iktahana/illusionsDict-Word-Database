    "definitions": [
      {
        "index": 1,
        "gloss": "I wonder",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あら、雨が降ってきたかしら。洗濯物、取り込まないと。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「この道で合っているかしら。少し不安になってきたわ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「ねえ、佐藤さん、今日の会議、何時からだったかしら？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「この服、私には少し派手かしら。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "響くといふこともないけれども、何かしら本当に仕事してゐるものを却て一時的とはいへ吃驚させたりするのだ。",
              "citation": {
                "source": "文学に関係のない文学者",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから猶一台で足りるものかしらと案じてゐるのだ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　さうね、………だけど先づダンスする方が好かあないかしら。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもねえ………あなたの小説の材料になるのがあたし落ちぢやないかしら。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あら今お隣の窓から、若い男の人が此方みて嗤つてたわ、あたしたちの話を聞きやしなかつたかしら。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かしら、これは大變な事件だと思つた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども同時に何かしら腑に落ちない妙な疑問が、別に新しく心の底にきざしてきた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（なんて、こんな事を言うと、非科学的だといって叱られるかしら。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "必然的と言わなければならぬ、なんて、一言一言とがめられる、あの右翼のやっかい以前の左翼のやっかい時代が、また来るのかしら。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっきり言ったっていいんじゃないかしら。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな暑い日にはいっそドテラでも着てみたら、どうかしら。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、旅行者にとってはのんきそうに見えながらも、帝都の人たちはすべて懸命の努力で生きているのだという事を、この北京の客に説明してやろうかしらと、ふと思った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを学ばないに拘らず、思念だけでは足りない、何かしら芸術は道具を要するものであるから、作品が読まれなければならぬ。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何やかと少しく話は乱れたが、何かしら道具を以て作されるものが詩であつて、それは、その詩の伝統を習得することによつて習得されるものである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなになんでも延長したり質の問題にして考へたりしてたら御飯も食ふ時間がなくなりますよ」「さうかしら……」「女としては物分りの好い方だし、昨日の昼迄ならさうだわねと位に言つて呉れたんだらうにな……」と彼はさう思つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした種類の人間は、絶えず何かしらしゃべってないと寂しいのだ。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには何かしら、或る物なつかしい、昔々母の懐中でまどろむやうな、或はまた焚火の温暖を恋するやうな、人間情緒の本質に遺伝されてる、冬の物侘しい子守唄の情緒がある。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は荒寥とした枯木の中を、葱さげて家路に急ぐ人の姿は、さうした冬の季節の中で、ふしぎに物侘しく、孤独にふるへる生の果敢なさを感じさせ、何かしら或る暖かい、焚火の燃える家郷への、魂のノスタルヂアを追懐させる。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに黄ばんだしみのあるのも鼠のいたずらじゃないかしらんなど独語を云いながら我も手伝うておおかた三宝の清めも済む。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海と空の深い透明な色を見ていると、何かしら遠いゆかしいような想いがするのを喜んで買った。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じようにはかないうら悲しい心持ちに、今度は何かしら神秘的な気分が加わっているのであった。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎を立って時津に向かう途中でロシア人専門の遊廓だというところを通ったら二階から女どもが見下ろして何かしら分らないことを云って呼びかけた。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の露国海軍のブルータルな勢力の圧迫が若い頭に何かしら強い印銘を与えていたかもしれない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルのポルチエーが自分を小蔭へ引っぱって行って何かしら談判を始める。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さねかずらとはどんなものかしらず、蔦這いでる崖に清水したゝって線路脇の小溝に落つる音涼し。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一端に火をつけて「火渡し」と云って次の人に渡すと、次の人は「しりつぎ」と答えて次へ廻す、それからだんだんに東京でいわゆる「尻取り」をするのであるが、言葉に窮して考えている間に火が消えるとその人は何かしら罰として道化た隠し芸を提供実演しなければならないのである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか熱が出て床に就いて、誰も居ない部屋にただ一人で寝ていたとき、何かしら独り言を云っていた。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼の理論の上に輝く何かしら神秘的の光環のようなものを想像している人もあるらしい。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが少しひどくなって来ると、自分が何かしらもっと積極的な悪事を犯していて、今にもその応報を受けるべき時節が到来しそうな心持ちになる。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の連中の書くものに比べて、虚子のものには、それが表面上は単なる写生的のものでも、その裏面に何かしら夢幻的の雰囲気が漂っているような気がした。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
