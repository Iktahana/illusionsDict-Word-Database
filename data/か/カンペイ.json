    "definitions": [
      {
        "index": 1,
        "gloss": "government soldier",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "城の周囲には、厳重に官兵が配置されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "反乱軍は、圧倒的な数の官兵に囲まれ、降伏せざるを得なかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "官兵による取り締まりが強化され、街の治安は回復しつつあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い記録には、異国の地に派遣された官兵の苦労が記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "五陣生駒甚助政勝、小寺官兵衛｜孝隆、木下勘解由左衛門尉、大塩金右衛門、山内一豊。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "天文二十年に播磨國｜淡河の城に生れ、永祿八年に十五歳で、同國姫山の城主黒田官兵衞｜孝高に仕へ、永祿十一年に孝高の嫡子松壽が生れてから、若殿附にせられた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸官兵士日夜これを警衛す、裁判不服の者と裁判を得ざる者、その太鼓を鳴らせば法官｜躊躇せずその愁訴を聴き公平に判決す。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにおいて諸屯邸に至り、諸強族が官兵を役使しまた逋亡を蔵せるを検校し、ことごとく事を以て言上し、罪さるる者甚だ多し、陸杭時に江陵の都督たり、ことさらに孫皓に下請し、しかる後釈くを得たりとある。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おのづから外るゝ水には、何もたまらず流れたり……」　すると鶴巻が、敗惨の私をあやなすやうに、追ひかぶせて、「こゝに伊賀伊勢両国の官兵等、馬筏押し破られて、六百余騎こそ流れたり――」　などゝ私達の兼々の愛誦章を続けた。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にいう通り、その賊の人相風俗は大抵判っているので、丞相は官兵に命じてすぐにその捜査に取りかからせ、省城の諸門を閉じて詮議したが、遂にそのゆくえが知れずに終った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "輟耕録",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、品物をぬすみ出すと、それを近所の塔の上に隠して置いて、ふたたび自分の宿へ戻って寝ていると、夜の明けた頃に官兵が捜査に来ました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "輟耕録",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、わたくしが昨夜泥酔して帰ったことは宿の主人も知っていますし、第一わたくしは一寸法師といっても好いほどに背が低い上に、髯などはちっとも生やしていないで、人相書とは全く違っているものですから、官兵は碌々に取調べもしないで立ち去ってしまったのです。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "輟耕録",
                "note": "青空文庫"
              }
            },
            {
              "text": "「爰に伊賀伊勢両国の官兵等、馬筏押し破られて、六百余騎こそ流れたり。",
              "citation": {
                "source": "くもり日つゞき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、上野の戦争といっても、私が目撃したことは右の通り位のもので、戦争の実況などは分りはしませんが、後年知ったことで、当時｜御成街道を真正面から官兵を指揮して黒門口を攻撃したのは西郷従道さんであったといいます。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "上野戦争当時のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "――敵ながらよくも撒いたものじゃ」「軍隊の損害は、戦死は将校一名、下士官兵六名、負傷は将校二名、下士官兵二十二名、飛行機の損害は、戦闘機一機墜落大破、なお偵察機一機は行方不明であります。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は官兵を見ると狼狽した。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月二十四日に筑前守｜斉隆が卒して、十月六日に嫡子官兵衛｜斉清が襲封したのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一戸の記に、「土方歳三は一軍に将として、星恂太郎、春日左衛門等と（中略）川吸峠を踰えて函館に入り、大野に陣取りける時、彰義隊の残党等も来つて土方が隊に合し、七重村の官兵を襲」ふと云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "）香亭の云ふを聞くに、官兵の折戸を迂回した時、岡田斧吉、本山小太郎が戦死した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」両軍艦隊の大森浜に戦ひ、官兵の大川村を占領した日である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "盜賊官兵以至民居（居民？",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "本日午後五時、二百名より成るドイツ将校下士官兵の一隊は、イギリス本土よりわが占領地区カレー市へ無事｜帰還いたしました。",
              "citation": {
                "source": "独本土上陸作戦",
                "author": "――金博士シリーズ・３――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき逸早く信長の天下を見抜いたのが官兵衛（如水）で、小寺家の大勢は毛利に就くことを自然としてゐたが、官兵衛は主人を説いて屈服させる。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき官兵衛は二十を越して幾つでもない若さであつたが、一生の浮沈をこの日に賭け、いはゞ有金全部を信長にかけて賭博をはつた。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "官兵衛は自分の見透しに頼りすぎ、一身の賭博に思ひつめて、主家の思惑といふものを軽く見すぎたのだ。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "官兵衛も足もとが崩れてきたから驚いたが、独特の方法によつて難関に対処した。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "官兵衛にはまだ父親が健在であつた。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "官兵衛は単身主家の籠城に加入して臣節をつくした。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢の中から助けだされた官兵衛は秀吉の帷幕に加はり軍議に献策してゐたが、京から来た使者は先づ官兵衛の門を叩いて本能寺の変をつげ、取次をたのんだ。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "官兵衛は使者に酒食を与へ、堅く口止めしておいて、直ちに秀吉にこの由を告げる。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらか涙のおさまつた頃を見はからひ、官兵衛は膝すりよせて、さゝやいた。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
