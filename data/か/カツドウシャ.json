        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "貧困撲滅と教育機会の均等を訴える活動者たちが、チャリティイベントを企画した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、社会変革を求める若き活動者として、国内外で注目されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの活動者、SNSでの発信もすごいし、実際に行動してるのも尊敬するよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "少数派の権利を守り、差別に反対するために、多くの活動者が連帯した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一般の読者にとっても作家にとっても知りたいのは、金をとる人間の金のつかいかたより、金を大してとれないものが、猶どんな新しい社会的施設によって文化活動者としての発育の可能性、即ち才能の具体化の可能性を守られているかということである。",
              "citation": {
                "source": "近頃の話題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般生活に必要がないと認められる種類の新聞や本などというものは手に入れ難く、しかもその必要でないという結論は、決して一般の読書人・文化活動者の具体的な多数決によるものではないのである。",
              "citation": {
                "source": "ペンクラブのパリ大会",
                "author": "――議題の抜粋についての感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化活動者として私をわれわれの同志から、大衆から切りはなそうとする悪辣きわまるデマです。",
              "citation": {
                "source": "逆襲をもって私は戦います",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "質のよい熟練工、技術家、専門家としてきっちりソヴェト生産の中軸的活動者となっている。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは自分が日本プロレタリア文化連盟の関係によって引致されたものであること、そして、官憲は、他の文化団体の同志たちに対してと同様に、合法的な日本プロレタリア文化連盟を潰し、合法的な階級的文化活動者としての活動を妨害するための、陋劣な作業を、私に向っても開始したことを理解したのであった。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "客體が客體として主體に對していくらかの隔りにおいて對立してゐる間は、各の内容を構成するものとしての兩契機の共存はなほ殘されるであらうが、異なつた内容と内容との聯關を支配する緊張はますます解除され、かくて主體は活動者たるを止め客體の曇りなく淀みなき透明なる姿に見入りつつ靜かに休息するであらう。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故主體は依然活動者として留まらねばならぬ。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそれだけならば大した問題ではないのだが、丁度之をシグナルとしたように、朝鮮人の文化活動者の主なる者は殆んど例外なしにといってよい位い、その自由を束縛され始めたのではないかと想像される節がある。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにたいして、攘夷論者という破壊活動者が、朝廷がわや長州藩などにあらわれた。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "その破壊活動者は、幕府の外交を、口をきわめて非難した。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "公卿と薩長人とは、その破壊活動者の本拠であつた。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
