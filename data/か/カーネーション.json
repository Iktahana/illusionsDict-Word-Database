    "definitions": [
      {
        "index": 1,
        "gloss": "carnation (Dianthus caryophyllus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
