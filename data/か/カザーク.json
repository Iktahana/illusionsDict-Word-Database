        "examples": {
          "standard": [
            {
              "text": "その歴史小説は、カザークの勇敢な騎兵隊を描いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は祭りのために、伝統的なカザーク帽をかぶった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わー、あのカザークダンサーたち、すごく上手！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "物語は、冒険を求める若いカザークの戦士についてのものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "イヴェールスキイ門からやって来た小役人の膝から、こっそり帽子を取ってきて、その身代金としてカザーク踊りをおどらせたり、老僕ヴォニファーチイに女の室内帽をかぶせたり、――そうかと思うと、公爵令嬢が男の帽子をかぶったり……とても一々数えきれない。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "颯っと短いマントに短剣を吊って、素早く胡瓜売りの手車の出ている角を曲ったのは、舞踊で世界的名声のあるカザークの若者だ。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
