[
  {
    "uuid": "da727d54-3310-57a2-bf89-d24dcd5009c8",
    "entry": "確定的",
    "reading": {
      "primary": "かくていてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
