    "definitions": [
      {
        "index": 1,
        "gloss": "structure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しくオープンした旅館は、重厚な門構えが客を圧倒する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この屋敷の構えを見ると、かつての主がいかに権力を持っていたかがよく分かる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "商店街の奥に、ひっそりと落ち着いた構えの和菓子屋を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "けれども私は、そのころすべてにだらしなくなっていて、ほとんど私の身にくっついてしまったかのようにも思われていたその賢明な、怪我の少い身構えの法をさえ持ち堪えることができず、謂わば手放しで、節度のない恋をした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、太宰さんは、もう平気でその楯を持って構えていなさる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の代表的な思想家という説明文が附いていて、その友人は、八つ手の傍で胸を張って堂々と構えていた。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "から鮭も空也の痩も寒の内　雲水に似た旅人芭蕉も、時には一定の住所に庵を構えて、冬の囲炉裏を囲みながら、侘しく暮していたこともある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂々と玄関を構えてる医者の家へ、ルンペンか主義者のような風態をした男が出入するのを、父は世間態を気にして、厭がったのは無理もなかった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すじ向いに座を構えたまうを帽の庇よりうかゞい奉れば、花の御かんばせすこし痩せたまいて時々小声に何をか物語りたまう双頬に薄紅さして面はゆげなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく駆け来る列車の一隅に座を構えて煙草取り出せばベルの音｜忙しく合図の呼子。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで腰に鉄鍋を当てて待構えていて、腰に触る怪物の手首をつかまえてぎゅうぎゅう捻じ上げたが、いくら捻じっても捻じっても際限なく捻じられるのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿坊の造りは一定していないが、往還から少し引ッ込んだ門構えに注連を張り、あるいは幔幕をめぐらせ、奥まった玄関に式台作りで、どうかすると、門前に古い年号を刻み入れた頂上三十三度石などが立っている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の構えで、その家がどんな暮し向きであるかを知った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野方面の火事がこの辺まで焼けて来ようとは思われなかったが万一の場合の避難の心構えだけはした。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間の男たちからは距てを構えられる女も、家の中の弟妹たちからは母よりも頼みとされ、親しまれた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣の袖を襷に結び上げ、竹箆を斜に構えた僧も二三人見えます。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ゆっくり構えて、まあ、好きなら麦とろでも食べて、運の籤の性質をよく見定めなさいというのさ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の早い父親は、私が眠い目を我慢して砥石で擦って持って行く灰吹を、座敷に坐り煙管を膝に構えたまま、黙って待っている。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一平　つまり、心構えの上でさ。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」達二は脇差しを抜いて身構えしました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉たちがすわるにせまいといえば、身を片寄せてゆずる、彼の母は彼を熟視して、奈々ちゃんは顔構えからしっかりしていますねいという。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ナイルの河船でレーリーから数学を教わったエリーノア嬢は、その後シジウィック夫人となってからはケンブリッジに居を構えていた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが十三回十四回頃からロスの身体の構えに何となく緩みが見え、そうして二人が腕と腕を搦み合っているときにどうもロスの方が相手に凭れかかっていたがるような気配が感ぜられたので、これは少しどうもロスの方が弱ったのではないかと思って見ていた。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「不具戴天の父の敵覚悟しろ――」　棚倉呆れたが、門弟と共に刀の柄に手を掛けて見構える。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "進藤たちスワと身構える。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同スワと身構えれば、　駕籠の中より現れた日下部典六。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "典六追って来て身構える。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り返った典六「オオ、五郎蔵」と身構える。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と身構えると、　其の侍は大吉には眼も呉れず、這う様にして先に倒した浪人の傍へ寄り、苦しい声で、Ｔ「父の……　カッカッ」　と叫んでとどめ刺さんと大刀振り上げたが力尽きてバッタリ倒れた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉、仲蔵を抱えて身構え乍らジリ退る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "源五左、よし来いと身構える。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵、サッと身構えた。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女達の一家が主人の転勤のため、何代も住み続けた大阪から、東京へ移ってそこへ居を構えてからまだ一月も立たずであった。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
