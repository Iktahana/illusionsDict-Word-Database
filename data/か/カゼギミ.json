[
  {
    "uuid": "c25fd634-43c3-5dc5-84e5-91489f41876b",
    "entry": "風邪気味",
    "reading": {
      "primary": "かぜぎみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "slight cold",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ちょっと風邪気味みたいで喉が痛いから、今日の飲み会は大事を取ってパスさせて」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "喉の奥がチクチクしてどうも風邪気味なので、今夜は生姜湯を飲んで早めに休むことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は風邪気味だと言いながらも、今日締め切りのプロジェクトのために無理をして出社してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "季節の変わり目で寒暖差が激しいせいか、オフィスでもマスクをした風邪気味の人が増えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "少し風邪気味で、大儀な時にでも無理をして勤務をおろそかにしなかった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いまは、ちょっと風邪気味なんですけど。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が相談に行った時は風邪気味だとかいって逢ってくれなかったのです。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄亮までが、風邪気味で咽喉を痛めたというので、さして左が利かない。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その中に大納言｜殿と云われる上席の女中がいたが、それが風邪気味だと云って、出て来ない。",
              "citation": {
                "source": "女強盗",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "両親には風邪気味と申しましたので、夕方になって、近所に住んでおられる大学の助教授さんとか言う、若いお医者さんを呼んでくれましたが、別に何処と言って悪い処は御座いませんし、熱も何もなくて、脈も変っていなかったので御座いましょう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君は風邪気味で夕方まで寝た、そしておとなしく帰宅、私はねむれないのでおそくまで漫読。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬君が今日も寄つてくれたが、風邪気味なので、ちよんびり飲んで別れた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝秋谷で汗をかいたり風にふかれたりしたせいか、そしてその上に湯にはいったせいか、少し風邪気味で熱を感じたのだ。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜は十二時がうつても寝つかれなかつた、無理をしたゝめでもあらう、イモシヨウチユウのたゝりでもあらう、また、風邪気味のせいでもあらう、腰から足に熱があつて、倦くて痛くて苦しかつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も人並に風邪気味になつてゐる。",
              "citation": {
                "source": "行乞記",
                "author": "三八九日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "数日来、風邪気味なので、着れるだけ、あるだけ着て出かける、なか／＼の人出である、自動車が遠慮ぶかく乗り捨てゝある風景にも近代的地方味がある。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "行乞に出かけるつもりだつたが、風邪気味なので自重して（独身者は殊に気をつけなければならない）、閑居。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は二十六日までさんざん警察によばれて取り調べられていたのだが、高橋警部が急にひろ子に目をつけるようになつてから当分呼ばれぬようになつて、ほつと安心して気がゆるんだせいか、風邪気味で二十七日から床についてしまつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはうちでも珍しくすこし風邪気味でお休みだし――……」　一二度麻雀に誘われて遊んだりしたことのある良人の幸治のことを云い、尚子は、「でも、私、ほんとにあなたはお偉いと思うわ」　丸い柔かいウエーヴのよく似合う顔立ちにいつわりのない色を浮かべて云った。",
              "citation": {
                "source": "二人いるとき",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の身体のくせに妙な返辞だと感じたが、すこし熱もあるようなので、ようするに風邪気味なのだろうということになった。",
              "citation": {
                "source": "浴槽の花嫁",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内を乞うと彼は風邪気味で寝ていたが、快く起き出して何くれとなく注意を与えてくれた。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜――それ以前から風邪気味だつた――ばかに咳が出て、ハンカチを見ると血がついてゐたのだ。",
              "citation": {
                "source": "鬼神",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は僕はすこし風邪気味なのでね、外は寒いだろうから温くしようと思ったんだが、急に今気持ちが直って来たから、もう帽子もオーバーもいらない」　僕は苦しいいいわけをした。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し風邪気味らしいんですの。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ｍをねかし、自分も昨日雨の中を歩いて足をひやし、さむく、風邪気味故ねた。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい天気だったのにさむくなって風邪気味だ、こんや早く床に入る、たのしみ。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その四　その翌朝、頭の君は道綱のところへ使いの者に、風邪気味で役所へ出られそうもありませんから一寸お出がけにでもお立ち寄り下さい、とことづけて来させた。",
              "citation": {
                "source": "ほととぎす",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "披いて見ると、「風邪気味で、折角ゆうべ御約束したものを拝見に伺えず、なんとも残念でなりませぬ。",
              "citation": {
                "source": "ほととぎす",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ風邪気味で寐ていらっしゃるらしい頭の君から「きのうは法師共がおおぜい参っておりました上、日も暮れてからお使いの方が見えられましたので――」などと言いわけがましく書いてよこされたのは、その翌日になってからだった。",
              "citation": {
                "source": "ほととぎす",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのつもりで、けさ圭介の母から風邪気味で一週間ほども寝ていると云って寄こしたので、それへ書いた返事を駅の郵便函にでも投げて来ようと思って、外套の衣嚢に入れて来た。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は元来、甚しく鼻カタルを起し易いタチで、鼻が乾いた時にはテキメンにやられるのが習慣であるから、年中、四半分ぐらいずつ風邪気味に、自然の天恵によって鼻がぬれているような体質なのではないかと思っていた。",
              "citation": {
                "source": "小さな山羊の記録",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫　　うむ、少し風邪気味なんだけれど……まあ、今日はよさう。",
              "citation": {
                "source": "紙風船（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまうちの人、風邪気味で臥っていますからお目にかかれないそうです」　少し老けたが相変らずつんと美しいお神さんがでてきて、術もなくいった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し風邪気味のときなどは黄昏、芝居の頼兼公のような濃紫の鉢巻をして駕籠に揺られ、楽屋口ちかく下り立つと、つき添いの萬朝の背に片手かけて、しずかにしずうかに楽屋に入った。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
