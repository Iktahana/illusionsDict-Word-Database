    "definitions": [
      {
        "index": 1,
        "gloss": "reddish-brown",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "秋の山は、柿色に染まった葉っぱで美しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、柿色のマフラーを巻いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この陶器は、温かみのある柿色をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夕日が、空を優しい柿色に染め上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そのボロボロの長屋に柿色や萌黄の蛇の目の傘が出入りしている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて見かへるに暴れ者の長吉、いま廓内よりの歸りと覺しく、浴衣を重ねし唐棧の着物に柿色の三｜尺を例の通り腰の先にして、黒八の襟のかゝつた新らしい半天、印の傘をさしかざし高足駄の爪皮も今朝よりとはしるき漆の色、きわ／″＼しう見えて誇らし氣なり。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて見かへるに暴れ者の長吉、いま廓内よりの帰りと覚しく、裕衣を重ねし唐桟の着物に柿色の三尺を例の通り腰の先にして、黒八の襟のかかつた新らしい半天、印の傘をさしかざし高足駄の爪皮も今朝よりとはしるき漆の色、きわぎわしう見えて誇らし気なり。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて見かへるに暴れ者の長吉、いま廓内よりの歸りと覺しく、裕衣を重ねし唐棧の着物に柿色の三尺を例の通り腰の先にして、黒八の襟のかゝつた新らしい半天、印の傘をさしかざし高足駄の爪皮も今朝よりとはしるき漆の色、きわ／″＼しう見えて誇らし氣なり。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝戸をあけると赤、紺、水色、柿色さまざまの朝顔が咲き揃っているのはかなり美しい。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿色の顔と萌黄色の衣装の配合も特殊な感じを与える。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小倉の服に柿色の股引は外にはない。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄赤い縦横の縞は、不潔な渋柿色を呈して老婆の着物のようである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗って縫い直したものらしく、いくぶん小綺麗にはなっていたが、その布地の羊羹色と、縞の渋柿色とは、やはりまぎれもない。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "良人がどうして居るだらうと思つて、じつと考へ込んで居るときには、赤煉瓦の高い塀と、黒い鉄の門と、柿色の衣物を着て鎖でつながれた囚人の姿とがいつでも目に浮んで来る。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると柿色の囚人服を着た外山直堂であつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "正門前で自動車から降りて、見ると、学校は渋柿色の木造建築で、低く、砂丘の陰に潜んでいる兵舎のようでありました。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて和尚さんが、お御堂の横の入口に、柿色の美しいけさを着てあらはれました。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつさい和尚さんは、台の上に柿色のけさをきて坐ると、仏様の使ひかなにかのやうに、りつぱにありがたく見えたのでありました。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へ柿色の腰衣を着けた納所坊主が、茶の盆を持って縁側の曲角から来た。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大変に小柄な騎手で、柿色のシヤツを腕まくりしてピツタリと馬の首根に吸ひついてゐる様子を見ると、少年らしく思はれた。",
              "citation": {
                "source": "娘とドリアン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿色の篠掛を着けた、面長な眼の鋭い中年の修験者は、黒い長い頭髪を切って頷のあたりで揃えておりました。",
              "citation": {
                "source": "宇賀長者物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "常ならば東海道の五十三｜駅詩にもなるべき景色ならんに、柿色の筒袖に腰縄さえ付きて、巡査に護送せらるる身は、われながら興さめて、駄句だに出でず、剰え大阪より附き添い来りし巡査は皆｜草津にて交代となりければ、切めてもの顔｜馴染もなくなりて、憂きが中に三重県津市の監獄に着く。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い庭にはゆうべの雨のあとが乾かないで、白と薄むらさきと柿色とをまぜ栽えにした朝顔ふた鉢と、まだ葉の伸びない雁来紅の一と鉢とが、つい鼻さきに生き生きと美しく湿れていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　仙二郎は柿色の水兵服を着てゐた。",
              "citation": {
                "source": "鞭撻",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも柿色染であるが、手拭と褌とは縦に濃淡の染分けになって、多少の美をなしているからおかしい。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから柿色の鼻緒のついた庭下駄をはかせられて外に出ると、「そこにシャガンで待ってろ」という命令が下る。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お客さまは、金色の黒く煤けた、昔のあついたのきれや、柿色のごろ絽などを使つた図案のを抜き出してお賞めになる。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちよつといま見あたらないが、柿色の日傘をさして古風な越後上布をきた田舍娘がほこりにまみれた白足袋をはいて音をたてて橋を渡つていつた姿をおぼえてゐる。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは茶屋と茶屋とのあいだにある煎餅屋の前を通ると、ちょうど今日の運動場で売っているような辻占入りの八橋を籠に入れて、俳優の紋所を柿色や赤や青で染め出した紙につつんで、綺麗そうに沢山ならべてあるのを見つけた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中で美い酒を飮んでゐる奴等は、金とか地位とか、皆それ／″＼に武器を持つて居るが、それを、その武器だけを持たなかつた許りに戰がまけて、立派な男が柿色の衣を着る。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中で美い酒を飲んでる奴等は、金とか地位とか皆それ／″＼に武器を持つて居るが、それを、その武器だけを持たなかつた許りに戦がまけて、立派な男が柿色の衣を着る。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍では別段気づきもしなかつたが少し離れて滝が、ツル子やＮを眺めると二人ともスエータの上から柿色の引きしまつた上着を着てゐるせゐか、大辺に小柄で、芝の上を転げ回つてゐる男の子供達と見境ひがつかなかつた。",
              "citation": {
                "source": "山を越えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまさかに鶸茶の刈田、小豆いろ、温かきいろ、うち湿る珈琲の土。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "……・しろいてふてふにいつうまれたかきいろいてふてふ・蚊帳越しにまともに月が青葉のむかうから・月の水鶏がせつなく啼いて遠ざかる　郵便やさんがばさりと朝日へ投げだしてくれた　七月廿八日快晴、涼しい快い夏の朝を味ふ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
