[
  {
    "uuid": "27cc4282-8cdd-544b-9fd7-9feafe5f6311",
    "entry": "亀の子",
    "reading": {
      "primary": "かめのこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
