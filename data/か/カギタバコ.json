        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔の紳士は、嗅ぎタバコを嗜む人が多かったそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画で、登場人物が銀のケースから嗅ぎタバコを取り出すシーンがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "嗅ぎタバコは、ニコチンを鼻から摂取するタバコの一種だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこへいくと、だれもかれもが、まるで、かぎタバコをおなかにのみこんだようになって、ぼんやりしてしまう、しまつなのさ！",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで兵隊は、つくえの上にのっているかぎタバコ箱のうしろへ、ごろりとあおむけにひっくりかえりました。",
              "citation": {
                "source": "しっかり者のすずの兵隊",
                "author": "DEN STANDHAFTIGE TINSOLDAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "」いきなりかぎタバコ箱のふたがはね上がりました。",
              "citation": {
                "source": "しっかり者のすずの兵隊",
                "author": "DEN STANDHAFTIGE TINSOLDAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもなかにはいっていたのは、かぎタバコではありません。",
              "citation": {
                "source": "しっかり者のすずの兵隊",
                "author": "DEN STANDHAFTIGE TINSOLDAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてこんなことになったのか、きっとかぎタバコの黒い小鬼のしわざにちがいありません。",
              "citation": {
                "source": "しっかり者のすずの兵隊",
                "author": "DEN STANDHAFTIGE TINSOLDAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "（かぎタバコをかぐ）お気持はありがたいと思うけれど、それにお応えできないの。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーシャ　ほかに言いようがなくなると、みなさんおっしゃるのね――若い、若いって……（かぎタバコをかぐ）ドールン　（タバコ入れを取上げて、茂みの中へ投げる）けがらわしい！",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "（足早に退場）トリゴーリン　（手帳に書きこみながら）かぎタバコを用い、ウオトカを飲む。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーシャ　（かぎタバコをかぐ）ええ、あしたはね。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかにも　おさとうや　かぎタバコ　あまぐつなども　あつかっていて。",
              "citation": {
                "source": "ジンジャー＆ピクルスのはなし",
                "author": "THE TALE OF GINGER AND PICKLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "１０がつからで　かぎタバコが　５０グラムもだぜ。",
              "citation": {
                "source": "ジンジャー＆ピクルスのはなし",
                "author": "THE TALE OF GINGER AND PICKLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事実から、鉛を混ぜたかぎタバコを使うことによって、かぎタバコまたはその粗悪品で鉛中毒が起きる非常に印象的な事実が与えられている。",
              "citation": {
                "source": "食品とその混ぜ物処理",
                "author": "FOOD AND ITS ADULTERATIONS; ANALYTICAL SANITARY COMMISSION OF \"THE LANCET\"",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
