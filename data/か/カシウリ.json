        "examples": {
          "standard": [
            {
              "text": "この自転車は、月々数千円の分割払いで貸し売りもしているそうです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔は、近所の八百屋さんが野菜を貸し売りしてくれていたのを覚えています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「給料日前で現金がないんだ。このお店、貸し売りはやってないかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "高額な家電製品は、保証人がいれば貸し売りで購入できる場合がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "貸し売りせずにこの商売をやりぬくつもりなんですもの。",
              "citation": {
                "source": "都会の中の孤島",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、磯五ともあろうものが、どうしてそんな額にのぼるまで、貸し売りを許しておいたのだろう？",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
