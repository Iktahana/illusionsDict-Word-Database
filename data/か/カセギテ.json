        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「我が家の稼ぎ手は私一人だから、病気で倒れるわけにはいかないんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長男が就職して立派な稼ぎ手になったことで、両親もようやく一息つける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は若くしてプロスポーツ選手として契約し、一家の稼ぎ手となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "自分の少年の頃、一家に取って唯一の稼ぎ手であった父親を喪って以来、母と祖母が杖とも柱とも頼むのは独り息子の自分だけであった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、お父さんの方に誰も稼ぎ手がいなくなるごと考えたりして……」「馬鹿なっ！",
              "citation": {
                "source": "栗の花の咲くころ",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其家は代々の稼ぎ手で家も屋敷も自分のもので田畑も自分で作るだけはあった。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人相を見るに、これは夫婦ぐらしで豆屋を始めて居て夫婦とも非常な稼ぎ手ではあるが、上さんの方がかえって愛嬌が少いので、上さんはいつも豆の熬り役で、亭主の方が紙袋に盛り役を勤めて居る。",
              "citation": {
                "source": "熊手と提灯",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥料さえ買えぬ農村の四苦八苦の生活の中から稼ぎ手の若者を奪いとられて、われわれはどうする？",
              "citation": {
                "source": "国際無産婦人デーに際して",
                "author": "――作家同盟各支部に婦人委員会をつくれ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はつまり他の農民より稼ぎ手だったと云うに過ぎない。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとにあなたは稼ぎ手よ！",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "血気の旺な稼ぎ手の息子らに左右から押しつけられ、温泉にでもつかったようにじっと仰向いておとなしくしていたが、暫くすると、庄平は萎びた指で、「アレ」と弱々しく云って自分の頭の上の方を指した。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勉の年とった親たちは、亡くなった息子の代りに、嫁の乙女を一家の稼ぎ手として離すまいとしていた。",
              "citation": {
                "source": "朝の風",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "出京以来まだ半年だが、その間に、何十通となく見た母の手紙には、唯一人の稼ぎ手のぼくを失って、以後の苦しさは、つつみようもないものが窺われる。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "云うまでもないだろうが、家計は稼ぎ手のお兼がにぎっていて、しっつぁんは与えられる小遣いでやっているのだが、そんなものが長くある筈はなく、彼はもっぱら奢ってくれそうな相手を求めてぶらつき、またしばしばお兼の男のところへいってねだった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両方で三十一世帯、稼ぎ手の男には二匁、女には米三合というきめ（費用は役所から借りた）である。",
              "citation": {
                "source": "しじみ河岸",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "稼ぎ手のお絹は七十余日まえからいない、たぶん相長屋の者たちが、協同で二人をやしなっているのだろう、たぶんそうだろう。",
              "citation": {
                "source": "しじみ河岸",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親は寝たっきりの病人、弟は自分のことさえ満足にできない」と彼はいった、「それで稼ぎ手のおまえがいなくなって、あとがどうなるかわからないのか」　お絹はこくっと唾をのんだ。",
              "citation": {
                "source": "しじみ河岸",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もともと客の少ない街道で、こう稼ぎ手が多くてはやりきれない、これでは共食いである。",
              "citation": {
                "source": "雪の上の霜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
