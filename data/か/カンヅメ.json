[
  {
    "uuid": "e803f6a4-43b6-5830-b44c-4cd66acafc19",
    "entry": "缶詰",
    "reading": {
      "primary": "かんづめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
