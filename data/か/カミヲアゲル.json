        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「たまには雰囲気を変えてみようかな」と、彼女は浴衣に合わせて艶やかに髪を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "台所の熱気に耐えかねて、彼女は手近なゴムで無造作に髪を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "成人式のために、美容院で数時間かけて華やかに髪を上げてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "気合を入れて仕事に集中する時は、いつも前髪までまとめて高く髪を上げることにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "時々気にしたらしくまっくろな髪を上げる小指の先が紅をさした様に色づいて居るのや、まぼしいほど白い歯がひかる事なんかを千世子は見つけて思わずうす笑いした。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙な事を吹聴するようでおかしいが、実をいうと僕は女の髪を上げるところを見ているのが好きであった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を作り、髪を上げると、今度はトランクに用意して置いた婚礼衣裳の着附けである。",
              "citation": {
                "source": "恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
