        "examples": {
          "standard": [
            {
              "text": "社員証の更新のため、背景を白にした顔写真を提出してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はSNSのプロフィールに、笑顔が素敵な顔写真を設定している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "運転免許証の更新では、規定サイズの顔写真が必要となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イベント会場への入場には、本人確認のため顔写真付きの身分証明書提示を求められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「それが大池忠平の顔写真だ……湖水の分れ道で君を拾ったのがその男だったはずだ。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは、あの女が言ってましたね……ロッジで逢ったのは、顔写真の男とはちがうようだって……あれは正直な発言だったんですな……皮肉な女だ。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "記事は簡単な三、四行のもので、旅行者の顔写真もなかった。",
              "citation": {
                "source": "箱の中のあなた",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや上目づかいにカメラを見て微笑しているアランの、色刷りの顔写真の下に「アランという名のこのサーファーについて、情報の提供を皆さんにお願いします」という文句が見える。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
