[
  {
    "uuid": "088225a2-3fbd-5abb-9664-cdfd978f1e7a",
    "entry": "畏まる",
    "reading": {
      "primary": "かしこまる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
