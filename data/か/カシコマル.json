    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to obey respectfully",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "普段は冗談ばかり言っている部長も、社長面談の席ではすっかり畏まって、一言一句選びながら答えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "初めて恋人のご両親に挨拶へ行った際、あまりに畏まりすぎて、出されたお茶の味すら覚えていない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「そんなに畏まらなくていいよ、今日は無礼講の飲み会なんだから、もっと楽にしてくれ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "式典の来賓席に案内されると、周囲の重鎮たちの雰囲気に圧倒され、自然と姿勢が畏まってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "さきに秋冷相催し、次第に朝夕の寒さと成り、やがて暮が近づくと、横寺町の二階に日が當つて、座敷の明い、大火鉢の暖い、鐵瓶の湯の沸つた時を見計らつて、お弟子たちが順々、かく言ふそれがしも、もとよりで、襟垢、膝ぬけと言ふ布子連が畏まる。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が手をついて畏まると、先生にはお客分で仔細ないのに、宙外さんも煙に卷かれて、肩を四角に坐り直つて、酒のいきを、はあはあと、專らピンと撥ねた髯を揉んだ。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と女どもが、畏まると、「翌日は又おみおつけか。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、両手で袖口を引っぱってから畏まるように膝を揃え、顎を引いて、やっぱり顔を伏せ気味にしている。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主税はヒヤリとして、ついに無い、ものをも言わず、恐れた顔をして、ちょっと睨んで、そっと上って、開けた障子へ身体は入れたが、敷居際へ畏まる。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "板張りの上に莚を一枚敷いてその上に畏まるのだから、ずいぶん足が痛くなる。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、先刻から酒席の間を、彼方此方と廻って、酒宴の興を取持っていたが、漸く酩酊したらしい顔に満面の微笑を湛えながら、藤十郎の前に改めて畏まると、恐る恐る酒盃を前に出した。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の前では、非常に畏まるが、駄々で懶惰で底意地がわるい。",
              "citation": {
                "source": "剣の四君子",
                "author": "柳生石舟斎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵の酒宴の可笑しさよ娘が運ぶ瓶子よりもるる灯影にかしこまる左右の破顏を反り見て七兵衞獨り忻忻たり。",
              "citation": {
                "source": "煤掃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月の変った態度に、少し恥かしそうにうつ向いてかしこまる。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とレストレードは畏れかしこまる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、出ると大きく成つて、ふやけたやうに伸びて、ぷるツと肩を振つて、継ぎはぎの千草の股引を割膝で、こくめいに、枯蘆の裡にかしこまる。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けっきょく創作というものは、広義に於ける人間社会を（人間社会に必要な、天然界をも含んだものであるが）まず対象とするものであるから、人間社会で使っている言葉を、そっくり持って来て使えばよいので、それを為ないということは、屹度文章を作る場合にかしこまるからに相違無い。",
              "citation": {
                "source": "大衆物寸観",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また判官の前に恐れかしこまる奴隷もなかりし。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "足が痛い、左の足が腫れてゐる、かしこまることができなくなつた、よろしい、歩くことがむつかしくなつたつてよろしい、それは日頃から私の望んでゐたところだ！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は鳥の御馳走にしました――外国からお帰りになると、反ってこういうものの方が好かろうと思いましてね」「久し振で皆さんと御一緒に頂きますかナ」と言って洋服のままかしこまる中根の膝も痛そうであった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は倦んで了って、特別席にかしこまる官吏の影も見えません。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは洋服だから、かしこまるのが窮屈だつたから、すぐ胡坐をかいた。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは洋服だから、かしこまるのが窮屈だったから、すぐ胡坐をかいた。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも、学問の無い人は、かしこまるといふ言葉を、あらたまつて云ふ時には、かしこまゐるだと思うて、さう云うて、平気でゐる事があるが、祝詞にも、かうした間違ひがある。",
              "citation": {
                "source": "呪詞及び祝詞",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいきなりそこに痩せた身体をしやちこ張らせてかしこまると、「へえ、いえ」　と、何か文句にならないことを口の中で云つて、もう一度低いお辞儀をかへした。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣りは宿直の室であったか、「はっ」とかしこまる声がすると間の襖が静かに開いた。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "直接ではないが間接には、この組紐のお仙という女、敵方の一人と申してよろしい」「かしこまる！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は、当分、家から出ないそうだって」「こいつは弱ったね」「おれが家にいたって、吉あんちゃんが困ることはないだろう」「それがどうも弱るんで……ここで先生に臍を曲げられると、大事になる」　吉青年は割膝になってかしこまると、ついでに床に両手をついて頭をさげた。",
              "citation": {
                "source": "春の山",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大作、これよ、大作」「はッ」　と驚いて大声に答えた伊吹大作、ふすまを引いてかしこまると、大岡越前守忠相はもうきちんと正座して書台の漢籍に眼をさらしている。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体かしこまるべきものがおとなしく控えるのは別段気にするにも及ばんが、毬栗頭のつんつるてんの乱暴者が恐縮しているところは何となく不調和なものだ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞこちらへ」　うつくしい腰元ふうの少女が、縁がわにかしこまるのでした。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "葡萄榾ちよろ／＼燃えて夏炉かな煙管に火つけて夏炉にかしこまる五月二十八日　亀田、綾華居。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、事だ」　もんどり打ったピグミーは、一間ばかりかなたへ飛んで、そこへペタンとかしこまると、さも大仰な表情をして、両手をついたものです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴慕の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おーい、人足共はあるかやい」　お取持が恐縮千万のうちに、後ろを振返って大きな声で呼ぶと、「おーい」と勢揃いの声がして、一方から現われるのは、揃いの着物に向う鉢巻の気負いが五人、手に手に鳶口を携えて、しずしずと世話役の前へかしこまる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
