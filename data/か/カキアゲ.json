    "definitions": [
      {
        "index": 1,
        "gloss": "mixed vegetable and seafood tempura",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今日のランチは、サクサクのかき揚げうどんにしよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "お寿司屋さんで、新鮮な海老と野菜のかき揚げを頼んだら、これが絶品だったんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "家でもかき揚げ作れるかな？ちょっと難しそうだけど、挑戦してみたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "かき揚げの天ぷらが、甚だ結構だ。",
              "citation": {
                "source": "魔味洗心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あーっといい湯だ、おい紋太夫」若さまの声である、「このばか者ッとくるか、ばかの柱をかき揚げにして一杯やるからって、紋太夫にそう云え、はっは狼狽えてやがる」「もうこれきりにあそばせ」宙野が低い声で囁やいた。",
              "citation": {
                "source": "若殿女難記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、揚げ立ての、上等の天ぷらを食って、しまいに、かき揚げか何かを貰って、飯を食う。",
              "citation": {
                "source": "下司味礼讃",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "海老のかき揚げは、梅月のシステムで、大きく軽し。",
              "citation": {
                "source": "このたび大阪",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きなかき揚げを平げ、すしの方へ行き、喫茶で冷コーヒーとみつ豆と菓子。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時近く打ち止めて、又朝日地下の天ぷらへ行き、大きなかき揚げと飯を一杯。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "天ぷらは、古き梅月の大きなかき揚げもよけれど、広重の小さなカキが忘れられない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "襷をはずして、髪をかきあげて、おせきがとつかわと店を出たのは、昼の八つ（午後二時）を少し過ぎた頃であった。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボックスでは、一人のまるで女の様な綺麗な肌をした色の白い、ぼくと同年輩位の美少年が、セルの着物の袖から白い手をぬッと伸ばして房々とした髪の毛をかきあげながら、その店の、雀斑のあるかなり可愛いい顔をしたワンピースのドレスの少女とひそやかに語らいながら二人切りの時間を楽しんでいる様だった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな、長い金色の髪の毛を、金のくしでかきあげていました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "生意気なこと考えたので、ひとりで顔があかくなって来て、私は、濡れた手で髪をかきあげる。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘は鳴る……銀色の教会の鐘……硝子※のなかには薄色の青き眼がねをかけたる女、かりそめのなやみにほつれたる髪かきあげて、薬罎載せたる円卓のはしに肱つきながら金字見ゆるダンヌンチオの稗史を閉し、静かなる杏仁水のにほひにしみじみときき惚れてあり。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは路傍なり、猫目石の奢りかがやく夕暮の崖の下なり、熱くちらばる花の中に、流石女の稚けなけれどなまめかしく、而も無心に、童は薔薇色薄きシヤツをかきあげつる、尻も真白く、病める、悲しき、取りみだしたるその溜息。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は蒼ざめた顔にふりかかる散らし髪をかきあげながら、亭主の前へ手をついた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "少年少女の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "泳ぎながらも客らしい人を見つけると、あかちゃけた短い髪を元気よくかきあげてから、やすんで行きせえ、と叫んだ。",
              "citation": {
                "source": "魚服記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（五平と寅蔵も手伝いて、おいよの死骸をかきあげる。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（五平と寅蔵は毛布につつみたる死骸をかきあげ、源五郎も付添いて出てゆく。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こう言って彼は爪の伸びた指先きでおどろの髪をかきあげながら、畏れ敬うように再び小坂部の顔を打ち仰いだ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、妙な音が部屋の中でする樣なので細めた灯をかきあげてみると果して隅の一本の柱がべつとりと濡れて、そのあたりにぽとぽとと雨が漏つてゐるのである。",
              "citation": {
                "source": "山寺",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでにぜひ美禰子の肖像をかきあげてしまうつもりである。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭の日、むつかしき言のかずかず挨拶ひ、父は笑ましき、禿頭するするとかきあげながら――われもまた爲ではかなはじ、かのごとも大人とならば。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねむごろに土かきあげ、塵にかへれとはうむりぬ。",
              "citation": {
                "source": "北村透谷詩集",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "（六郎兵衞は先に立ち、助八と雲哲は彦三郎をのせたる駕籠をかきあげると、雲哲は又よろける。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "襷をはづして、髪をかきあげて、おせきが兎つかはと店を出たのは、昼の八つ（午後二時）を少し過ぎた頃であつた。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "――「近代異妖編」",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして頭髪に爽快なローションをふりかけ、ブラッシュでぎゅうぎゅうとかきあげた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつむいてゐる、白髮をかきあげたうなじが細かつたが、そのあたりからひさは眼を一時もそらさなかつた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもない人だったんだけれ共後れ毛をかきあげた小指の変な細さが目について忘られない人の仲間入りしたんですよ、　十七位の娘でしたけど。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなり長い間しゃくり上げて居たさきは、ようやっと前髪をかきあげながら、「もうやめましてございます。",
              "citation": {
                "source": "蛋白石",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、生えぎわの美しい千代の下げた頸筋を苦しそうに見下しながら、いたたまれないように何遍も何遍も、落ちていもしない髪をかきあげた。",
              "citation": {
                "source": "或る日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ半白だった髪の毛を後ろへかきあげて、長い髯をしごいては、その手を高くさしあげて「神は……」と一段声をはりあげるそのいい声に魅せられてしまった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
