    "definitions": [
      {
        "index": 1,
        "gloss": "while fumbling one's words",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
