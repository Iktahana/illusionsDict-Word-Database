    "definitions": [
      {
        "index": 1,
        "gloss": "sweet-smelling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "雨上がりの庭から、咲き誇る沈丁花の香しい匂いが窓を抜けて部屋まで届いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "淹れたてのほうじ茶から香しい湯気が立ち上り、張り詰めていた心がゆっくりと解けていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわあ、台所から香しいバターの匂いがする！今日のおやつは手作りクッキーかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古書店の棚に並ぶ古い和紙からは、年月を経てなお香しい、墨と紙の独特な香りがした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "其｜焼たての香しい香が戸外までぷんぷんする。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして奇麗に傷口を洗ってやって、その上、傷口へ二三度｜香しい息を吹きかけてやって云いました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂浜から、ひょっこりひょっこりと出る芋づるの奴より、この……山の松露が、それこそ真に香しい露の凝ったので、いわば松の樹の精根でがしてな。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち、香しいやうな、遠くで……海藻をあぶるやうな香が傳はる。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃く香しい、その幾重の花葩の裡に、幼児の姿は、二つながら吸われて消えた。",
              "citation": {
                "source": "若菜のうち",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　師匠も銀子の口車に乗り、やがて大弓場を処分して、藤本へ入って来たのだったが、入れてみると、ちぐはぐの親父と、銀子の所思どおりに行かず、師匠の立場も香しいものではなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬は、甘い、香しい、暖かな、とろりとした、春の野に横わる心地で、枕を逆に、掻巻の上へ寝巻の腹ん這になって、蒲団の裙に乗出しながら、頬杖を支いて、恍惚した状にその菫を見ている内、上にたたずむ蝶々と斉しく、花の匂が懐しくなったと見える。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯野は一、二の官立学校の試験を、いつも失敗して、今通っている学校は、学課の程度が低く、卒業生の成績や気受けも香しい方ではなかった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがその報告の内容は、キンギン国にとって、あまり香しいものではなかった。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い女達の花｜簪、若い男達の道化仮面、笑う声、さざめく声、煮売屋の釜からは湯気が立ち、花見田楽の置店からは、名古屋味噌の香しい匂いがした。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はあまり香しい話ではありませんが、若干おもしろいところもありますので、新年そうそう皆さんのお耳を汚させていただきます。",
              "citation": {
                "source": "餅のタタリ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里にも倫敦にもあんな大きな、そしてあのように香しい蓮の花の咲く池は見られまい。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの蘭を御覧に入れるという、我国民の真情は、誠に蘭花のように香しい極みである。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家も揺ぐかと思われる中に、山田は、彼女のやさしい香しい息に脹らむ胸のあたりを喰い入るように見つめた。",
              "citation": {
                "source": "掠奪せられたる男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里にも倫敦にもあんな大きな、そしてあのやうに香しい蓮の花の咲く池は見られまい。",
              "citation": {
                "source": "水　附渡船",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "正義の宮殿にも往々にして鳥や鼠の糞が落ちていると同じく、悪徳の谷底には美しい人情の花と香しい涙の果実が却て沢山に摘み集められる。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "上州｜花隈の城主として、天狗飛切りの秘術を編み出し、当時｜芳名香しいところの、戸沢山城守より伝授されたる小太刀潜入飛燕の術もて、岩に手を掛け枯木に縋りまたは空中を両手で煽ぎ、数十｜丈の壁面を、目にも止まらず躍り上がる。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フラフラと縁先へ歩いて行き、香しい初夏の前栽へつとその眼を走らせたが、「訳と云うのは他でもない、ここに咲いているこの百合の花、いつも嫋々と首を垂れ、風吹けば揺れ、雨降れば傾ぐ、相手次第でどうともなる……これが妾の今の身の上……お前これでも解らぬかえ？",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、要屋で聽くと、決して香しい方ではなく、他家から入つて家督に直つた主人の山之助などは、口を極めてといふ程でなくとも、こと毎に久吉の陰險さをほのめかします。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "井戸の茶碗",
                "note": "青空文庫"
              }
            },
            {
              "text": "冠婚葬祭博士、余り香しい地位じゃありません」「…………」「皆、僕のことを先生と呼びます。",
              "citation": {
                "source": "冠婚葬祭博士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、要屋で聴くと、決して香しい方ではなく、他家から入って家督に直った主人の山之助などは、口を極めてというほどでなくとも、ことごとに久吉の陰険さをほのめかします。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "井戸の茶碗",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分、大したこともありませんよ」　あまり香しい収穫もなかった様子です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "女の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショルは良いバリトンだが、アメリカ的でないので、レコードではあまり香しいことはない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、声も若さも失ったファーラーは再度オペラに復帰の望みを絶たれ、コンサートとレコードへの復活を心がけたが、少くともレコードの方は香しいことがなかったようだ。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "がこの総指揮官も香しいことはなかった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、生乾きの、香しい草が厚さ一尺、その上に着茣蓙を敷いた一坪ばかりの座敷、屋根は純白の天幕である。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "栴檀は二葉より香しい。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミルテやペパーミントのかぐわしい香りもただよってきます。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "この灌木は、ここではしばしば十五フィートから二十フィートの高さにもなって、ほとんど通り抜けられないくらいの叢林となって、あたりの大気をそのかぐわしい芳香でみたしている。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面ゆれて――そのかぐわしい葉先からとこしえの雫が露と落ちる。",
              "citation": {
                "source": "ポオ異界詩集",
                "author": "エドガー・Ａ・ポオ　Edger A. Poe",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
