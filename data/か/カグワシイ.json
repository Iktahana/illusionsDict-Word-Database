[
  {
    "uuid": "193f0ad3-d8bd-5ed4-aa67-92201e09e341",
    "entry": "香しい",
    "reading": {
      "primary": "かぐわしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
