        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "競馬で大金を当てたと思ったら、甘い話に乗せられて鴨ネギ状態だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "酔っぱらった観光客は、ぼったくりバーにとって鴨ネギ同然だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この辺りは、土地勘のない人を鴨ネギにする悪質な業者がいるから気を付けて。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "double stroke of good luck",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
