        "examples": {
          "standard": [
            {
              "text": "参加人数には、運営スタッフも数え込んでおいてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "交通費や宿泊費まで予算に数え込むと、到底今の持ち合わせでは足りない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "今の段階で彼を即戦力として数え込むのは、少し時期尚早かもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その時代助はこの論理中に、或｜因数は数え込むのを忘れたのではなかろうかと疑った。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
