        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「会議続きで頭がぼんやりするから、強めのカフェインを入れてシャキッとさせなきゃ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「へぇ、このチョコレート、通常の三倍もカフェインが入ってるんだって。試験勉強にいいかも」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「最近胃の調子が悪いから、しばらくカフェインの摂取を控えるように医者に言われちゃってさ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「えっ、この時間からエスプレッソ飲むの？ カフェインで夜寝られなくなるよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ジギタリス剤、アトロピン、ムスカリン等の猛毒からアドレナリン、カンフル、カフェイン等の薬剤に至るまで心臓に作用する毒物薬物の殆どすべてにわたって、僕は一々の曲線を作り上げたのだ。",
              "citation": {
                "source": "恋愛曲線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも色と苦さだけはコーヒーに似ておらぬでもなかったから、それに耳かき一ぱいのカフェインをまぜて時々用いていたのである。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "カフェインをいれすぎると胸のやける代用品だった。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをまくらもとにおいて見ながら、いったいこの草稿の原動力はカフェインなのだろうか、老船長の友愛なのだろうか、と考える。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "検察のあらゆる神経系統は、カフェインの注射をされたようなすさまじいばかりの昂奮状態を示し始めた。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
