[
  {
    "uuid": "857ea71d-10ae-5876-9df8-2e26273cac39",
    "entry": "官吏",
    "reading": {
      "primary": "かんり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "government official",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "官吏はどうかと云った人もあったが、役人と云うものは始めから嫌だった。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "騎兵聯隊や上肢の運動や、下級官吏の赤靴のことや、山沿ひの道を乗手もなく行く自転車のことを語らうと思ふ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "○○銀行○○課の一團は物靜かでモーニングを着た官吏風の人が多い。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "災害直後時を移さず政府各方面の官吏、各新聞記者、各方面の学者が駆付けて詳細な調査をする。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "故人北原多作氏のごとき少数な篤学の官吏の終生の努力と熱心によってようやく水産に聯関した海洋調査がやや系統的に行われるようになりはしたが、自分の知る限りでは時々の政府の科学的理解のない官僚の気まぐれなその日その日の御都合による朝令暮改の嵐にこの調査の系統が吹き乱される憂いが多分にあった。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通学校で第一に仕立てるべきものは未来の官吏、学者、教員、著述家でなくて「人」である。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には会計官吏や書記や小使の用をつとめなければならない。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎のどこの小さな町でも、商人は店先で算盤を弾きながら、終日白っぽい往来を見て暮しているし、官吏は役所の中で煙草を吸い、昼飯の菜のことなど考えながら、来る日も来る日も同じように、味気ない単調な日を暮しながら、次第に年老いて行く人生を眺めている。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "小幡は維新後に官吏となつて今は相當の地位にのぼつてゐる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣は多く小官吏であったのである。",
              "citation": {
                "source": "雪ちゃん",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "議会などでわずかばかりの予算の差額が問題になったり、またわずかな金のためにおおぜいの官吏の首を切ったり俸給を減らしたりするのも結構であるが、この火災による損失をいくぶんでも軽減することもたまには講究したらどんなものであろうかと思われる。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも彼がかりにわが日本政府の官吏であったと仮定したら、はたしてどうであったかを考えてみることを、賢明なる本誌読者の銷閑パズルの題材としてここに提出したいと思う次第である。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "官吏は直ぐ石を取寄せて一見すると、これ亦た忽ち慾心を起し、これは官に没收するぞと嚴かに言ひ渡した。",
              "citation": {
                "source": "石清虚",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「国家の干城たる軍人」が悪いのか、母と妹とが悪いのか、今更いうべき問題でもないが、ただ一の動かすべからざる事実あり曰く、娘を持ちし親々は、それが華族でも、富豪でも、官吏でも、商人でも、皆な悉く軍人を聟に持ちたいという熱望を持ていたのである。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階建、格子戸、見たところは小官吏の住宅らしく。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "目的は空知川の沿岸を調査しつゝある道庁の官吏に会つて土地の撰定を相談することである。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "且つ道庁の官吏は果して沿岸｜何れの辺に屯して居るか、札幌の知人｜何人も知らないのである、心細くも余は空知太を指して汽車に搭じた。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "年輩四十｜幾干、骨格の逞しい、頭髪の長生た、四角な顔、鋭い眼、大なる鼻、一見一癖あるべき人物で、其風俗は官吏に非ず職人にあらず、百姓にあらず、商人にあらず、実に北海道にして始めて見るべき種類の者らしい、則ち何れの未開地にも必ず先づ最も跋扈する山師らしい。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それは出られましやうとも、然し空知川の沿岸の何処等ですか其が判然しないと……」「和歌山県の移民団体が居る処で、道庁の官吏が二人出張して居る、其処へ行くのですがね、兎も角も空知太まで行つて聞いて見る積りで居るのです。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "されども余は空知川の岸に沿ふて進まば、余が会はんとする道庁の官吏井田某の居所を知るに最も便ならんと信じて、空知太まで来たのである。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "商人が自分の商品に興味と熱を失う時代は、やがて官吏が職務を忘却し、学者が学問に倦怠し、職人が仕事をごまかす時代でありはしないかという気がすることもある。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "開拓使時分に下級官吏の住居として建てられた四戸の棟割長屋ではあるが、亜米利加風の規模と豊富だった木材とがその長屋を巌丈な丈け高い南京｜下見の二階家に仕立てあげた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当の地位の官吏の娘と生れ、英語塾で教育を受けた彼の妻の梅子は、当時に於てはモダンにも超モダンの令嬢である筈だ。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが歌舞伎芝居が好きで、わけて田之助びいきの処から、其の楽屋に出入りしているうち同じ贔負の国太郎と知り合い、官吏の家庭とはまるで世界の違う下町生活の話を聴いて異常な好奇心と憧憬から自分から進んで黒繻子の襟のおかみさんになったのであった。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国太郎も、官吏のお嬢さんを貰って側にばかりへばり付いて居るという非難を河岸の者から聴き度くない為め、精々交際は欠かさないようにする。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かんり部長さんと一昨日、長時間お話し致しましたときも、思ったことです。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
