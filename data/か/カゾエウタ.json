        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖母が縁側で昔懐かしい数え歌を口ずさんでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "この地方に伝わる数え歌には、当時の農作業の様子が描かれています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "子供たちは毬をつきながら、息を合わせて数え歌を歌い始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
