    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Karafuto (Japanese name for Sakhalin)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖父はかつて樺太で暮らしていたとよく話していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "明治時代、樺太は日本とロシアの間で領土問題の中心となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史の授業で、樺太の地理や開拓の歴史について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "樺太の地図を広げて、かつての国境線をたどる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "厳しい冬の続く樺太の自然は、独自の生態系を育んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "荷役に忙しい樺太や釧路通ひの汽船や、白いペンキの醜く剥げ落ちた帆船の中には、舷の低い捕鯨船の疲れたやうな姿が横はつてゐる。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はあ、北海道へは始終往復をするですが、今度は樺太まで行くですて。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手摺の靄が一｜面に、浸の形が樺太の図に浮ぶ。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此でまた、汽車半分、否、室一つ我ばかりを残して、樺太まで引攫はれるやうな気がしたのである。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "樺太の氷に閉されてゐた海の水が、寒い重々しい一脈の流れとなつて、根室釧路の沖をかすめて西南に突進する。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがもし対丈で、赤皮の靴を穿けば、樺太の海賊であるが、腰の下の見すぼらしさで、北海道の定九郎。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "樺太二部の一は、我が幾万の同胞を殺し、幾億の軍費を費せしに対して、余りに少き賠償なれど、若し国民が此戦勝により、何等か偉大なる精神上の賜物を得しならば、余輩は数十億の償金を得るよりも、幾万方里の領土を加ふるよりも、寧ろ我国将来の為に之れを慶賀せん。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "之れに反し、日露戦争に於ける戦勝の結果は如何、僅に樺太二分の一の領土を得たるも、同時に臥薪甞胆の意気をすら失へるに非ずや。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はじめの願書は、樺太、新京などからも来て、ざっと六百通ちかく集ったのですよ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "材木堀が家を南横から東後へと取巻いて、東北地方や樺太あたりから運ばれて来た木材をぎっしり浮べている。",
              "citation": {
                "source": "晩春",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "樺太の山中にて尾白鷲眼を放つ梢には横雲の縹雲ほのあかりぬ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "樺太風景神こそはおそらくは童形ならむ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十二年より昭和二年に至る作品の中、覊旅を主としたる印旛沼、北信、鹽原、樺太、北海等の短歌・長歌・口語歌。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも樺太のツンドラ地帯に生ずる小灌木の名である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂樺太葡萄酒である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまさしく樺太観光団の一員として、この壮麗な高麗丸の甲板上にある。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸したウイスキイの酔は、すぐにも発散したし、湯上りのやや肌寒を感ずるところへ、明日はいよいよ樺太だと思うと、何か気も昂れば、引き緊っても来る。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いがけない樺太風景である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっ、樺太だ、確かに。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "駛る駛る駛る、樺太犬が、一匹二匹三匹、五匹六匹、二列だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう夜が明ければ樺太だが。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　本来からいえば、小樽を出て翌朝、私たちは樺太西海岸の本斗に上陸して、真岡より野田へ汽車で行き、一晩泊って、それからまた海路を国境の安別まで続航するはずであった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "右舷にはいつでも鮮かな緑と寒い黒椴の丘陵とが眺められて、何となく樺太らしい物珍らしさが感じられたものの、いよいよ北緯四十五度の線を越したかと思うと、曇天の日の円までが、ただ白くぼやけて寒ざむと、頼りなく仰がれても来た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど、樺太は寒いな。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい、犢ほどの樺色の樺太犬がのそりと、その前には出ていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それは樺太事前草とでもいうのだろう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまた佇ち停って、これらの初めてみる樺太の景趣に目を円くした。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほう、それが樺太蕗ですか。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "樺太虎杖の花は内地で見るようなほのぼのとした淡紅いろを含めていないが、その緑がかった薄黄は却て虔ましくてあわれであった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事は休んでいると見えて、その板敷きの広間はガランとして、例の大きな樺太犬なるものが獅子のように傲然とその真ん中に蹲っているだけであった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
