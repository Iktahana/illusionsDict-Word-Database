[
  {
    "uuid": "18c1304e-a09a-5e28-a331-7d8027c3e6a7",
    "entry": "樺太",
    "reading": {
      "primary": "からふと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
