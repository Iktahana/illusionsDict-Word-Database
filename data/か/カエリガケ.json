    },
    "definitions": [
      {
        "index": 1,
        "gloss": "on the way back",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "仕事帰りがけに、駅前のパン屋に寄るのが日課だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちは学校の帰りがけ、公園で友達と遊ぶのが楽しみらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議の帰りがけ、取引先の人とばったり会って少し話をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "旅行の帰りがけに、お土産を買いに立ち寄った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "帰りがけに、雨も小止みになったので、自動車で韮崎の町を突き切り、釜無川の東岸に沿うて、露出しているところの七里岩を、向う岸の美しい赤松の林から眺めた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時、二人は帰りがけに、山の上へ引っかえして、ヤケクソに持っているだけの弾丸をあてどもなく空に向けて発射してしまったりした。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りがけに藤二を促すと、なお、彼は箱の中の新しい独楽をいじくっていた。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」彼は、帰りがけに、陳に囁いた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――勿論、田端から帰りがけに、直ぐに園の家に立寄つたのであるが。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の儲けは帰りがけに皆飲んでしもうたが、明日は又これで飲めようぞ……ところで良助さん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日社長の処で一杯飲んで帰りがけに、芋倉長江が嬉しいと言ってここに喰い付きやがったんだ。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなこんなで前借のこと親方に言い出すのは全く厭だったけど、言わないじゃおられんから帰りがけに五円貸してくれろと言うと、へん仕事は怠けて前借か、俺も手前の図々しいのには敵わんよ、そらこれで可かろうって二円出して与こしたのだ。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "孵化場から今帰りがけのところとみえて、彼が近づくと生臭い香いがあたりに香った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りがけに仏壇に行つて、灯心を代へて、位牌に一寸御辞儀をした。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国々を修行に歩行いている内、養老の滝を見た帰りがけに煩って、宅で養生をしたんです。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と自から肩の嬌態、引合せた袖をふらふらと、台所｜穿をはずませながら、傍見らしく顔を横にして、小走りに駆出したが、帰りがけの四辻を、河岸の方へ突切ろうとする角に、自働電話と、一棟火の番小屋とが並んでいる。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「じゃ、やっぱりお帰りがけね、お待ちなさいよ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　果せる哉、この一行は、それから参詣を済まして帰りがけに、あの……仲通りで、一人軒伝いに、包ましく来かかる清葉に、ゆくりなく出逢ったのである。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りがけの霞の空の、真中を蔽う雲を抜けて、かんてらの前へ、飛出したお千世の姿は、爺さんの目には、背後の蔵から昨夜の雛が抜出したように見えて、あっと腰を抜いて、ぺたんと胡坐を掻いて、ものを言うより莞爾々々としていたのである。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒は飲めず、畏って煙草ばかり吐かしていたので、愛想に一本、ちょっと吸って、帰りがけにくれたのが、」「承知々々。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はね、お爺さん、宵からお目に掛っていた客が、帰りがけにこの橋から放生会をなすった品があるんです。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どこをどう廻りましたか、宵に来た奴が十時過ぎ、船を漕いだものが故郷へ立帰ります時分に、ぽかんと帳場へ戻りまして、畏って、で、帰りがけに、（今夜は闇でございます、提灯を一つ。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、そのお帰りがけなのでござりますて。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りがけには、武蔵坊も、緋縅も、雁がねも、一所に床屋の店に見た。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は帰りがけの片膝を浮かしたのである。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝商売の帰りがけ、荷も天秤棒も、腰とともに大胯に振って来た三人づれが、蘆の横川にかかったその橋で、私の提げた笊に集って、口々に喚いて囃した。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "行抜けに北の縁側へも出られますで、お前様帰りがけに取違えてはなんねえだよ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして帰りがけ、信吉は冴子の肩に手をのせた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドリアンはヘンリイ卿の晩餐に招かれてその帰りがけに、霧深い町角でゆくりなくもベエシル・ハルワアドと出逢った。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "-------------------------------------------------------　夕方の神楽坂通りは散歩の学生や帰りがけの勤め人なぞでいつもいっぱいである。",
              "citation": {
                "source": "牛込館",
                "author": "映画館めぐり（十）",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りがけにチエ子の大好きな、絵本を買って来るようなこともなくなった。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "決めて帰りがけに葉子達は神楽堂の方の借主をどんな人達かと聞いて見た。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りがけに密と通ると、何事もない。",
              "citation": {
                "source": "雛がたり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この挿話に用があるのは、翌朝かえりがけのお妻の態度である。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
