[
  {
    "uuid": "a484d0bd-1109-5d9f-ab09-cb315c7cee62",
    "entry": "帰りがけ",
    "reading": {
      "primary": "かえりがけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
