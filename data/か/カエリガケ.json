        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あ、そうだ、母さんに頼まれたもの、帰りがけに買って帰ろう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ごめん、もう帰りがけなんだけど、ちょっとだけいい？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この書類、今日中に提出しなきゃ。帰りがけにポストに入れてくるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
