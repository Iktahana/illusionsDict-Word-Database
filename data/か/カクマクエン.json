        "examples": {
          "standard": [
            {
              "text": "昨日から目がゴロゴロして充血していると思ったら、眼科で角膜炎と診断された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "コンタクトレンズを長時間つけっぱなしにしていたせいで、角膜炎になってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "乾燥した職場で一日中パソコンを見ていると、目が乾いて角膜炎になりやすいらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "抗生物質の目薬で角膜炎の症状はだいぶ落ち着いてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "が彼女は角膜炎だと云った。",
              "citation": {
                "source": "溺るるもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
