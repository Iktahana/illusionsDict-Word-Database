          "standard": [
            {
              "text": "小説家は、主人公の激動の人生をありのままに語り尽くすことを目指した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祖父は、戦争中の体験談を、もう二度と話すまいと心に決めていたが、孫に請われて、ついに語り尽くした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もうこれ以上、何も隠すことはない。私の人生の全てを、今ここで語り尽くそう。」と彼は静かに言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "秀吉は、彼らから聞くだけを聞き、語るだけを語り尽くすと、「寝むぞ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
