    "definitions": [
      {
        "index": 1,
        "gloss": "cocktail",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ホテルのバーで、街の夜景を見ながらカクテルを一杯注文した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女はシェイカーを振って、鮮やかな青い色のオリジナルカクテルを作ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「普段あまりお酒は飲まないんですが、このフルーツカクテルは飲みやすいですね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ノンアルコールのカクテルも種類が豊富で、お酒が飲めなくても楽しめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "序にバスケツトを探つて、緑蝶夫人はなむけする処のカクテルの口を抜いた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……旅の単衣のそゞろ寒に、膚にほの暖かさを覚えたのは一｜杯のカクテルばかりでない。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "句集自序の一節として私の句はまだ／＼水つぽいけれど、へたなカクテルのいやなあくどさはないと信じてゐる。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って彼、杉山茂丸は、その上海や香港に於て、東洋人の霊と肉を搾取しつつ鬱積し、醗酵し、糜爛し、毒化しつつ在る強烈な西洋文化のカクテルの中に、所謂｜白禍の害毒の最も惨烈なものを看取したに違いない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスにしばらくいた男で、カクテルには、自慢の腕を持っています。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――カクテル、辛いのをね。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　銀盆に落花生とカクテルとを載せて、運んで行くと、「貴女は？",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、行き当りばったりのスタンドバーでカクテルを飲んだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、カクテルをもらおう。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　他の女給がカクテルを運んで来た。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ綺麗な指に嵌めてやろうと思って買って来た指環なのだから……」　彼は軽い興奮の表情でカクテルのグラスを唇に持って行った。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "エロスのカクテル、抱擁、馬鹿噺、接吻、目茶苦茶踊り――で、パッパッと目の先を刺激して瞬時瞬時を過して行けば、理窟はいらない、それならそれで誠にそれは面白い、何たる朗らかさぞや！",
              "citation": {
                "source": "新興芸術派に就いての雑談",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何か強くないカクテルを貰おうかね。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、京子に断って、カクテルを注文したが、それがいつかウイスキーに変り、三杯となり、四杯となり、食事が終って、自動車に一緒に乗った時は、彼の白い顔が、微醺を帯びて輝いていた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗じみた、甘鹹い手の甲の皮膚をシッカリと…………て気を散らそうと試みた……が……しかしその手の甲の肉から湧き起る痛みすらも、一種のタマラない……………のカクテルとなって彼の全身に渦巻き伝わり、狂いめぐるのであった。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸せかえるようなペンキ画の道具立て、白粉の女、安葉巻の煙と、カクテルの複雑な味――そういう雰囲気もたしかに一つの魅力をもっているではあろう。",
              "citation": {
                "source": "探偵小説壇の諸傾向",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く出鱈目な調合法で切りにカクテルをつくつて飲み続けて居るＢが居た。",
              "citation": {
                "source": "くもり日つゞき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると、クリーバーは飲みかけたカクテルを下に置いて、フィルゼルにもたれかかりながら、「僕はあなたの仰言るように、充分独逸へは同情を感じますさ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは銀座裏の小ぢんまりした店で、間接に来る照明が淡蒼い光を漂わし、クションに腰かけて、アルコオル分の少ないカクテルを一杯作ってもらって、ちびちび嘗めていると、自然に神経の萎え鎮まるような気分のバアであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "小夜子のところへ雪崩れこんで来るのも、時にはそういった連中の一部であったが、庸三も仲間の人たちと会か何かの崩れに、たまにはそういう新らしい享楽の世界へ入ることはあっても、カクテル一杯を呑むのに骨が折れるくらいなのに、性格的な孤独性と時代の距離があるので、いつも戸惑いしたような感じしかなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カクテルでも召し食りません？",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋と西洋の奇妙なカクテルがぷんぷん香っている。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夜更けてあおるカクテル・ガラスのふちに、ほんのり附いたモデル女の口紅。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「霧の中を往く馬車」というのと「虹の夢」という二つのカクテルを混ぜるのが彼の独特の技能でした。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、まずその電気広告費を稼ぐために、彼は毎日違法倶楽部の酒台の向側でカクテル壜を振らなければならなかったのです。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ピイタア、この紳士にあの「あたしの記憶のために」のカクテルを一つ混ぜて上げて頂戴。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまのレッテルの洋酒壜が、夥しく並んだ壜棚と背の高い花道のような卓子との間に挟まって、カクテル・グラスを、危そうに取り上げている肥り肉のちょっと人好きのする年増女が目にうつった。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿に戻つて、すぐ入浴、そして一杯、それはシヨウチユウ一杯とドブ一杯とのカクテルだ、飲まずにはゐられないアルコール（酒とはいはない）、何とみじめな、そして何とうまいことだろう！",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・風のトマト畑のあいびきで　やうやう妻になりトマトもいでゐる　　　　□　虫がこんなに来ては死ぬる　八月三十日風が落ちておだやかな日和となつた、新居三日目の朝である、おさんどんと坊主と、そして俳人としてのカクテル。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "八幡は労働都市だけあつて、たべもの店が多くて安い、そこで私もサケとビールとシヨウチユウとのカクテルを飲んだ。",
              "citation": {
                "source": "行乞記",
                "author": "北九州行乞",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
