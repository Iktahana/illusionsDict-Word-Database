      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gap (in a fence or hedge)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "生け垣の垣間から、隣の庭で遊ぶ子供たちの声が聞こえてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "塀の垣間から、ちらりと猫が覗いているのが見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "台風で壊れた垣間から、強い風が吹き込んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "自分がここにいるということを人に知られずに、垣間から舞台をのぞき見するのはこころよいものである。",
              "citation": {
                "source": "田舎から東京を見る",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなときでもなければ垣間見ることを許されなかった、聖なる時刻の有様であった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに晝も暗き樹立の中に、ソと人の氣勢するを垣間見れば、石の鳥居に階子かけて、輪飾掛くる少き一人、落葉掻く翁二人あり。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏蘭西扉の傍には、何のつもりか舶来の酒の壜や前菜料理の材料なぞと一緒に大きくふくらましたゴム風船の沢山浮んでいる見世飾があって、それらの透き間から垣間見ている者もいた。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "檜垣の主人が持ち帰ったのは主にフランス近代の巨匠のものだったが、本能を許し、官能を許し、享受を許し、肉情さえ許したもののあることは東洋の躾と道徳の間から僅にそれ等を垣間見させられていたものに取っては驚きの外無かった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――やあ、緑青色の夥間に恥じよ、染殿の御后を垣間見た、天狗が通力を失って、羽の折れた鵄となって都大路にふたふたと羽搏ったごとく……慌しい遁げ方して、通用門から、どたりと廻る。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "野の花は少けれど、よし蘆垣の垣間見を咎むるもののなきが嬉し。",
              "citation": {
                "source": "松翠深く蒼浪遙けき逗子より",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "無限を垣間見、夢みて、それと比較するために、自分をも事物をも本氣にしない……。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "御身の此寺に近付き給へるを垣間見、如何はせむと思ひ惑ひ候ひしが、所詮、人間道を外れし此身。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして最早、スッカリ原始生活に慣れ切っている久美子と、四人の子供達が、澄み切った真夏の太陽の下で、丸裸体のまま遊び戯れている姿を、そこいらのトド松の蔭から、心ゆくまで垣間見た訳ですが、その時のＡの驚きはドンなでしたろう。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その周りで幾人かの野次馬が首を伸ばして目を凝らし、中の様子を垣間見ようとしていたのだが、無理そうだった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "（アクテオンは、希臘の男神の名なり、女神ヂアナを垣間見て、罰のために鹿に變ぜられ、畜ふ所の群犬に噬まる。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛吉は心なく垣間見た人に顔を見らるるよう、思いなしか、附添の婦人の胸にも物ありげに取られるので、うつむいては天窓を掻いた。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "名をなつかしみ、尋ねし人、妾宅と覚しきに、世にも婀娜なる娘の、糸竹の浮きたるふしなく、情も恋も江戸紫や、色香いろはの手習して、小机に打凭れ、紅筆を含める状を、垣間見てこそ頷きけれ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "當國の領主日置の若殿｜忍男の君が、何かの折に幾度か手古奈を垣間見て、常々愼ましき性に似ず身柄忘れての戀衣、千重に八千重に思ひつみ今は忍びかねての、思ひを近く仕ふる媼に打明けた。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "或日お妙の父親が私の家に写真師などを引き伴れて訪れ、あの一組の甲冑を人間が着てゐる通りの恰好に組み立て、恭々しく撮影してゐるところを私は垣間見た。",
              "citation": {
                "source": "鎧の挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この様子を垣間見て、金公の徒党が仕返しに来るだらうと思つた。",
              "citation": {
                "source": "肉桂樹",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月にわたる久きをかの美き姿の絶えず出入するなれば、噂は自から院内に播りて、博士の某さへ終に唆されて、垣間見の歩をここに枉げられしとぞ伝へ侍る。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬これを垣間見、瓢金なその妻と謀り自分は飲みに出たと称し妻をして疾に托して王を招かしめた。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に親子の関係がどんな釘に引っかかっているかを垣間見たようにも思った。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小波の恋が破れて後、その令嬢が縁付いた婚家の近くに住っていた私は時折｜美貌を垣間見、淑徳を聞くにつけて小波のために頗る同情に堪えなかった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉腕朝明、一群鱗しろく淺瀬に走せ散る鮎と見えて、まとへる綾羅色をわかみ、透きても見ゆるや玉の腕、葉がくれ木の實を摘みなましと、人目をおもはず手をさしのべ、袖口こぼれしはなやかさに、垣間見とれしを誰と知るや。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、抜けッ、抜かぬかッ」　可哀そうに若衆は、垣間見ただけでも身の内が、ぼッと熱くなる程な容色を持っているというのに、こういう野暮天な人斬り亡者共にかかっては、折角稀れな美貌も一向役に立たぬとみえて、口汚なく罵しられるのをじっと忍びながら、ひたすらに詫びるのでした。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、抜けッ、抜かぬかッ」　可哀そうに若衆は、垣間見ただけでも身の内が、ぼッと熱くなる程な容色を持っているというのに、こういう野暮天な人斬り亡者共にかかっては、折角稀れな美貌も一向役に立たぬとみえて、口汚なく罵しられるのをじっと忍びながら、ひたすらに詑びるのでした。",
              "citation": {
                "source": "旗本退屈男",
                "author": "第一話　旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまで経つても二人は物も言はず同じ姿を保つてゐるばかりでしたが、その様子を凝つと垣間見てゐるうちに、どうやら私が、それこそ架空のまゝにお伽噺の中で結末をつけたと同様な仕儀に立至つてゐるらしく思はれました。",
              "citation": {
                "source": "船の中の鼠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この姿を一目でも奴が垣間見たならば、忽ち魂を蕩かせて、鋭い毒爪を磨くことであらう、部屋へ入らう。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "）の説に依ると、Ｃ家の主人が襷がけになつて深夜こつそりと黒い馬の尻尾を胡粉で染めてゐるところを垣間見て来た者がある。",
              "citation": {
                "source": "鱗雲",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『御門が何うしてもお許しにならぬので……』『御門が……』　登子の姿を垣間見てから、何うしてもそれを大内裏に召すと言つて言ふことをきかなかつた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "講談社がキングという雑誌を復活させたという新聞広告を見て、私は列国の教養人に対し、冷汗をかきました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "波が砂をかきまぜているのに、どうして一様に交じらないでしょうか。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
