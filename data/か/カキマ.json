[
  {
    "uuid": "4b087288-6440-5169-84fe-eb4164d602e1",
    "entry": "垣間",
    "reading": {
      "primary": "かきま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
