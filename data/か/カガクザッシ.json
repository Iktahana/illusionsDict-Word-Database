    "definitions": [
      {
        "index": 1,
        "gloss": "science magazine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ねえ、この科学雑誌の特集、ブラックホールの最新画像が載っててすごくワクワクするよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は子供の頃から科学雑誌を隅々まで読み耽り、いつか宇宙の謎を解き明かすことを夢見ていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "本屋の理工学コーナーには、最新のAI技術や量子コンピュータの動向を伝える科学雑誌が何種類も並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "科学雑誌の美しいカラーグラビアは、文字だけでは捉えにくい物理現象を視覚的に理解する助けになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "先達てドイツのある科学雑誌に猫の宙返りの真似をする雛形が載せてあった。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の科学雑誌が色々ある、中には科学の抜殻だけを満載して中実は空虚なのもあるようである。",
              "citation": {
                "source": "雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "記者がこの器械の事を近着の科学雑誌で読んだ後、場末の町を散歩していたら、とある米屋の店先で小僧がズックの袋に豆かなにか入れたのを一生懸命汗を垂らして振っていた。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十一月二十七日『東京朝日新聞』）　　　　　　　　　四十六　　　　　　大洋中の拾い物　本月十四日の本紙に横浜の人が北太平洋で鮫漁中に英文の手紙の入った空瓶を拾うた記事が出ていたが、近着の科学雑誌を見ると次のような事が載せてある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃英国の某新聞で陸海軍人の待遇を論じたのについて某科学雑誌記者は次のような事を云っている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつであったか、街燈の照明の影響でこの木の黄葉落葉に遅速があるということが、どこかの通俗科学雑誌の紙上で問題になったことがあるように記憶するが、しかし現在の新芽の場合では、街燈との関係はどうもあまりはっきりしないようである。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学に対する興味を養成するには、六かしくて嘘だらけの通俗科学書や浅薄で中味のないいわゆる科学雑誌などを読んでもたいして効能はない。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また通俗科学雑誌のページと口絵をにぎわすものの大部分は科学的商品の引き札であったり、科学界の三面記事のごときものである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人営業のライターの看板を掲げた時期は、一般向け科学雑誌のブームにも重なり合いました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学雑誌の編集部から求められていたのは、基本的な知識や新しい発見、我々が捕らわれている常識とは食い違う科学的な視点などを、わかりやすく、かみ砕いて表現することでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターの台頭や科学雑誌の創刊ブームに付け込んだライターへの転身作戦は、それなりの成果を上げた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学雑誌に掲載されたからいゝやうなものの、高沖氏よ、この神話の問題を科学者にどんな扱ひをされるか、一度科学雑誌にでも掲載して見給へ。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "――秘密、犯罪等を扱った科学雑誌等を読みたがっている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞穴から外へ出てみると、かつて科学雑誌に出ていた一千万年後の世界という絵そっくりの街があらわれた。",
              "citation": {
                "source": "千年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻頭に置いた『崩れる鬼影』は昭和八年、博文館から創刊された少年科学雑誌「科学の日本」に書き下ろしたものである。",
              "citation": {
                "source": "『地球盗難』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供のための科学雑誌には『子供の科学』などがある。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は会社に籍を置いたまま、おりからの科学雑誌の創刊ブームに乗って、仕事の重点を原稿書きに移そうと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はどこかの科学雑誌にでも投稿してやろうかと思って、腹案していたものなんだが、小手調べに君の批評を聞いてみてもいい。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしまいには船長と俺が腰をかけている寝台までも抱え上げて覗いたが、寝台の下には独逸や仏蘭西の科学雑誌が一パイに詰まっているキリであった。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年たちは、科学雑誌やものがたりで、こういう機械人間のことを読んで知っていて、いつかその本物を見たいとねがっていた。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "1850年の初めに「地方医学外科学雑誌」にハント氏のコレラについての質問にたいするワイト島（＊イングランド最大の島）ジョン・Ｃ・ブロクサム氏の返事の手紙が掲載された。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国の科学雑誌ネーチュア誌に、世界の目ぼしい研究を毎回少数ずつ拾って紹介している中に、先生の研究がわが国からは一番多く紹介されていたようである。",
              "citation": {
                "source": "文化史上の寺田寅彦先生",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの通俗科学雑誌によって、科学というものは米の飯のようなものだということを教え込むことは、先ず困難であろうと思われるのである。",
              "citation": {
                "source": "科学と文化",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこういう解釈も成り立つ、即ちこれらの科学雑誌は無縁の一般の人に科学に対する興味を呼び起させ、その興味から多くの人々を正しい科学の道にはいり込ます動機を作るということが考えられるのである。",
              "citation": {
                "source": "科学と文化",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外面的な要点については、読者も――私自身が大いに行ったように――古い新聞記事や科学雑誌の綴じ込みで拾い集めることができるからだ。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "〕はやりかけの仕事、即ち『月刊通俗科学雑誌』に出ている「古代人の世界観」の翻訳を持ち込んだ。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一般的な記事を『月刊通俗科学雑誌＊』へ書き、次にもっと注意深い報告書＊＊をつくり上げることにしよう。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
