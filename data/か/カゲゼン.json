    "definitions": [
      {
        "index": 1,
        "gloss": "tray for absent one",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "海外に単身赴任中の夫の無事を祈り、毎朝陰膳を据えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "遠く離れて暮らす息子のために、母は誕生日になると陰膳を用意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "昔の人は、旅に出た家族の帰りを待つ間、陰膳を欠かさなかったという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "読者知るや、さんが、オムレツを啣んで、あゝ、うまい、と嘆じ、冴返る身に沁々とほつき貝と、芥川さんが詠じて以来、――東京府の心ある女連は、東北へ旅行する亭主の為に鰹のでんぶと、焼海苔と、梅干と、氷砂糖を調へることを、陰膳とゝもに忘れない事に成つた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日は御前様御誕生日に当り申候へば、わざと陰膳を供へ候て、私事も共に御祝ひ可申上、嬉きやうにも悲きやうにも存候。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――母親がお茶を立てながら俺に陰膳を供えていてくれるころだ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏壇には、いつも、灯が新らしく、そして、陰膳が美しく――ただ、その中に一つ、気味の悪いのは、薄絹の上の紙の中にある、髪の切ったものであった。",
              "citation": {
                "source": "寛永武道鑑",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "源三郎に陰膳すえて、道場方とにらみ合い――ふしぎな生活がつづいている。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "家では佐太郎の陰膳を据えることを、初世は毎日朝晩欠かしたことがなかつた。",
              "citation": {
                "source": "押しかけ女房",
                "author": "伊藤永之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の陰膳の据えられた仏壇を拝んでから爐ばたの足高膳の前に坐つた佐太郎は、五年ぶりのドブロクの盃を三つ四つ、重ねるうちに、もういい加減酔つてしまつた。",
              "citation": {
                "source": "押しかけ女房",
                "author": "伊藤永之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所の蠅入らずの上に、陰膳をそなえていたときのまま直次の写真が飾られている。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡き良人の位牌、また、一族の誰彼と、数限りなく本堂の壇にならんでいる護国の英霊の前に、朝暮、陰膳を参らせる時のほかは、めったに裲襠の裳を曳いてはいなかった。",
              "citation": {
                "source": "日本名婦伝",
                "author": "大楠公夫人",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いや、陰膳まで」　と、客は、床へ眼をやって、沁々何か感じ入っている。",
              "citation": {
                "source": "日本名婦伝",
                "author": "小野寺十内の妻",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には、木曾川の国境へ遠征し、稀※、帰って来ても城内の寝泊りが多いし、まだ二十歳にもならない新妻は、常に、陰膳ばかり供えて、独りで喰べ、独りで縫い、独りで家事を見ていた。",
              "citation": {
                "source": "日本名婦伝",
                "author": "太閤夫人",
                "note": "青空文庫"
              }
            },
            {
              "text": "姑と嫁とのほかに、藤吉郎の分も朝夕、必ず陰膳として、床の前にすえて喰べる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし死んだとは思われず、どこかに生きているものと、毎日かげぜんを供えて、ただ、あの子が、どうかして無事に帰ってくれるのを待っていた。",
              "citation": {
                "source": "雲と子守歌",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
