        "examples": {
          "standard": [
            {
              "text": "「うわっ、あの先輩のロングシュート、めちゃくちゃ格好がいいな！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は自分の非を素直に認めて謝罪した。その潔い態度は本当に格好がいい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「その帽子、君によく似合ってて格好がいいね」と友人に褒められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "素人目にはわが大学の安田講堂よりもかえって格好がいいように思われる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かっこうがいいとか悪いとか、そういったレベルのことではない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "シンデレラも服えらびによばれ、どんなかっこうがいいかしら、とふたりにきかれました。",
              "citation": {
                "source": "シンデレラ",
                "author": "CINDERELLA, OR THE LITTLE GLASS SLIPPER",
                "note": "青空文庫"
              }
            }
          ]
        }
