        "examples": {
          "standard": [
            {
              "text": "冷たい水に手を浸しながら、伝統的な紙すきの技法をベテランの職人から教わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この村では冬の農閑期を利用して、古くから和紙の紙すきが盛んに行われてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夏休みの自由研究として、牛乳パックを再利用した紙すきに挑戦してみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "さねかづら這ひまとはれる　垣をしるべに※黄昏に咲く花の色も、紙を干す板のしろさにまけて、見えつゝ※鳴きたつる蝉にまじりて、草たゝく音きかするや、紙すきの小屋※示人天皇は　神にしますぞ。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵の具屋の手代、紅製造業、紙すきなどから、朝鮮貿易と出かけ、帰って来て大阪で紀州｜炭を売り、東京へ引っ越して来てまずガラス屋に雇われ、その次がくつ屋となってこうもり屋を兼ねたと言います。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "義公であつたか烈公であつたか、御殿女中が紙をそまつに取扱ふのを見て、紙すき女たちが、寒中川で紙すきをする辛さを見せた話は、たしか修身教科書にもあつたと思ふ。",
              "citation": {
                "source": "田舍の新春",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "津村はこれによって、母の生家が紙すきを業としていたのを知り得た。",
              "citation": {
                "source": "吉野葛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりでなく、生計の援助もしてやって、伯母のために離れを建て増したり、紙すきの工場を拡げたりした。",
              "citation": {
                "source": "吉野葛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが十七の歳に、実家の方が手が足りないので暇を貰って家に帰り、そののちずっと農事の助けをしているのだが、冬になると仕事がなくなるところから、昆布の家へ紙すきの手伝いにやらされる。",
              "citation": {
                "source": "吉野葛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
