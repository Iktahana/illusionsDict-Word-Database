    "definitions": [
      {
        "index": 1,
        "gloss": "one hand",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「彼は片手でハンドルを握り、もう片方の手でハンバーガーを頬張っていた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「スマホを片手に、寝落ちするまでSNSを眺めるのがやめられない。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そんなの、片手間でできるくらい簡単な仕事だよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「片手にカバン、片手に傘を持って、雨の中を走って駅まで行った。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "曰く「われは横綱らしく強いところを見せようとして左の腕を大きくぶるんと振って相手を片手で投げ飛ばそうとしたが、相手は小さすぎて、われの腕はむなしく相手の頭の上を通過し、われはわが力によろめき自ら腰がくだけて敗れたのである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野も山も新緑で、はだかになってしまいたいほど温く、私には、新緑がまぶしく、眼にちかちか痛くって、ひとり、いろいろ考えごとをしながら帯の間に片手をそっと差しいれ、うなだれて野道を歩き、考えること、考えること、みんな苦しいことばかりで息ができなくなるくらい、私は、身悶えしながら歩きました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男が赤毛氈の縁台のまんなかにあぐらをかいて坐ったまま大きい碾茶の茶碗でたいぎそうに甘酒をすすりながら、ああ、片手あげて私へおいでおいでをしたでないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　祖母は片手で膝を突いて立つた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "外套の隠しへねじ込むと蜜柑がつかえるから、また片手でしっかりさげて歩き出した。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹村君は片手の皿の包を胸に引きしめるようにして歩いていたが、突然口の中で「三百円もあるといいなあ」と呟いた。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手を挙げて合図をして「居た居た、あそこに」と云われても、どこにどんな鳥がいるのか明き盲の自分にはちっとも見えない。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、長男の道樂は、次男三男の酒亂の如くムキなものではなく、ほんの片手間の遊びである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨染の衣を着た坊さんが、網代笠を片手に杖ついて、富士に向って休息しているとすれば、問わずして富士見｜西行なることを知る。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "山麓帯の裾野で、日に焼けて、疲労をひどくしたくないので、定めの行程は短いにもかかわらず、翌十日は朝｜出立した、馬を五頭、一頭は荷物を積んで、案内者の、チャアルス・グーチという男が、裸馬に乗り、アルペン杖を横たえながら、片手で荷馬車を曳いて先登に立って行く。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓜わらべは小竹の中へ逃げ込みそうなので片手で押えた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手を柱に凭せ体を少し捻って嬌態を見せ、片手を拡げた袖の下に入れて、写真を撮るときのようなポーズを作った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "用心口を鎖してお寢間へ戻り給ひしが再度立つてお菓子戸棚のびすけつとの瓶とり出し、お鼻紙の上へ明けて押ひねり、雪灯を片手に縁へ出れば天井の鼠がた／＼と荒れて、鼬にても入りしかきゝといふ聲もの凄し。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小指は高くゝりの覚」で貸借の争議を示談させるために借り方の男の両手の小指をくくり合せて封印し、貸し方の男には常住坐臥不断に片手に十露盤を持つべしと命じて迷惑させるのも心理的である。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭の主人公なるが如く心得、家庭の事は、男子の片手間の事業かの如く考えて居るのが、今日家庭を説くものの理想らしいが、これが大間違の考と云わねばならぬ。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手を高く打ち振りながら早口に短い言葉を連発していた。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若旦那が、僕は御役に立たないがせめても、といったようなことを云って、そうして「万歳」と云って片手を上げた。",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後にデンプシーの審判で勝負が決まった時｜介添に助けられて場の中央に出て片手を高く差上げ見物の喝采に答えた時、何だか介添人の力でやっと体と腕を支えているような気がした。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋服の上に汚れた白の上っぱりを着たままで、肩から絵具箱をかけ、片手にも画架か何かを持っていた。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十月三日『東京朝日新聞』）　　　　　　　　　十三　　　　　　霧中の汽車信号　鉄道線路の傍に巨人のごとく直立しあるいは片手あるいは両手を拡げて線路の安否を知らせる普通の信号標は、通常の天気ならば昼夜の別なく有効であるが、ただ霧が掛かって数歩の外は見え分かぬような日には何の役にも立たぬ。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もこれとてもそういう時にひいた風邪だけが特に記憶に残るので、それでそういう片手落ちの結論に導かれたのかもしれないが、しかし、そうばかりでもないと思われる理由はたしかにある。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "保下田の久六、児分にまもられて二階から下りて来る（片手を首から釣って居る）。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉花道から、大刀片手に大跨にヅカヅカと舞台へ来り、平土間に向って、Ｔ「文句が有ったら　上って来い」　観衆睨み乍ら舞台の端を行ったり来たり「文句ある奴何奴だァ」と怒鳴って歩く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は片手に伊太利亜種の赤き翁草の花の大束を持ち、片手に柑子を盛りたる籠を持ちいる。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ペエテルは杖に力を入れて起ち上がつて、片手を十になる小娘の明るい色をした髪の上にそつと置く。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "湊は、茶を飲んだり、鮨を味わったりする間、片手を頬に宛てがうか、そのまま首を下げてステッキの頭に置く両手の上へ顎を載せるかして、じっと眺める。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　奧さんはたくましい青木さんの肩に片手をかけたまゝこびるやうにその顏を見上げた。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "健吉は、稲束を投げ棄てゝ急いで行って見ると、番をしていた藤二は、独楽の緒を片手に握ったまま、暗い牛屋の中に倒れている。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けいこわ、かたてまの、あそびにあらず。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋本夫人　　歯なんかたてて頂かなくつてもよう御座んすよ。",
              "citation": {
                "source": "賢婦人の一例（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
