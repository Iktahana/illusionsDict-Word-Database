        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この部屋、壁一重みたいで隣の話し声が筒抜けだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "防音対策で壁を二重にしたかったんだけど、予算の関係で壁一重になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "雪国では、断熱のために壁一重では寒すぎる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "壁一重隔てた校長室で、校長は矢鱈にその方に気を取られてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それぢやあ、家賃の中からさつ引いて払はうぢやないか」　と、壁一重隣同志の相談が纏つて、井戸屋さんがやつて来た。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時尋常四年生の教室――それは壁一重に廊下を隔てた所にあるのだが――がきゅうに賑やかになって、砂きしみのする引戸を開くとがやがやと廊下に飛びだす子供らの跫音がうるさく聞こえだした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁一重でも、おんなじ枕。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間無く、天井無く、障子｜襖無く、壁一重にて隣を分ち、大戸一枚道路を隔てる、戸に接してわづかに三畳｜乃至五六畳の一室あるのみ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……壁一重向うの室にモウ一人の私が寝ているのだ。",
              "citation": {
                "source": "ビルディング",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はもはや二十日以上も、麻川氏と壁一重を隔てたばかりの生活を過した。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁一重の隣家を憚って、蹴上の旅館へ寺田を連れて行ったりした。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁一重向うは赤の他人である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁一重を境にして、上のかたには駕籠かき權三、下の方は駕籠かき助十が住んでゐる。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでのやうなお声だと、壁一重隣に住んでるものは、どうにもやりきれませんわ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつぞや抗議を持込んで来た婦人たちが腹癒せの仕返しらしく、それからといふもの毎日のやうにムーアが仕事を始めると、それをきつかけに、隣の室からオルガンが単調な、懶い音を壁一重こちらにまでもひきずり込むので、これにはさすがに強情なムーアも少なからず閉口させられたといふことだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁一重の軒下を流れる小堰の水に、蝦を掬ふ小供等の叫び、さては寺道を山や田に往返りの男女の暢気な濁声が手にとる様に聞える――智恵子は其聞苦しい訛にも耳慣れた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁一重の軒下を流れる小堰の水に、蝦を掬ふ子供等の叫び、さては寺道を山や田に往き返りの男女の暢氣の濁聲が手にとる樣に聞える――智惠子は其聞苦しい訛にも耳慣れた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎で暮してゐた時とは、境遇も違ふし場所柄も違ふ、今ではこのセヽこましい東京の街中で、然も間借りをしてゐる境涯である、壁一重先きには他人が住んでゐるのだ、毎晩／＼夜中も関はず大声を発して、加けにどたばたとあばれられたりしては、朝になつて隣りの人に挨拶をすることも出来やしない、まるで狂ひの沙汰だ……。",
              "citation": {
                "source": "蝉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "名所圖會にはあの村里の圖も出てゐるが、それを見ると兩國の境は壁一重といつてもいゝ。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、壁一重隔てた隣りの部屋はわたしが三年の月日を送つたところで、澤木君が顏を洗ふ音でも、窓をあける音でも、部屋を歩き※る音でも、そこにゐてわたしは手に取るやうに聞くことが出來たからであつた。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁一重の隣りには人力車夫が住んでいる。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "純一は帽とインバネスとを壁の鉤に掛けて、ビュッフェエと壁一重を隔てている所に腰を掛けた。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁一重の隣家の中學生が頓狂な發音で英語の復習をはじめた。",
              "citation": {
                "source": "業苦",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "二六時中ゲジゲジ野郎の相手がでけるけえ、ヘン　酔ぱらわなきゃ　俺アにはこの世の中が暮していけねえよ……」「……ま、一辺云ってみな、野郎……」　ガチャン　バタン　ガラ　ガラ　ガラ……　祭壇の壁一重隣りでは乱闘が始まった。",
              "citation": {
                "source": "反逆",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに荒壁一重のすぐ左隣は馬小屋で、右側は大家との共同便所だったので、不潔この上なしだった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "植物に於ては、眼も鼻も口も持たない草木の根が、壁一重向うの肥料の方へズンズンと伸びて行く。",
              "citation": {
                "source": "霊感！",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、その石壁一重の彼方は、館の何処であろうか。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その時壁一重の向うに、誰やら、コトリコトリと歩き廻るような音が聴えてきた。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁一重の印刷場からは、活字を手にしたまゝ、男女の職工が狭い戸口に顔を重ねて見物する。",
              "citation": {
                "source": "大野人",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまたあの次の夜、壁一重隔てた道具置場で喚き立てた男のこえがまだ耳についていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
