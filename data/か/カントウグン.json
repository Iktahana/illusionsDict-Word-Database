[
  {
    "uuid": "39ce55a1-85df-500e-8192-57bfc0861739",
    "entry": "関東軍",
    "reading": {
      "primary": "かんとうぐん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Kwantung Army (Japanese armed forces in Manchukuo)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "関東軍の独断で行われた柳条湖事件の爆破工作は、その後の満州事変へと発展する決定的なきっかけとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「祖父は昔、関東軍の通信兵として満州に駐屯していた時期があったらしいんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史の教科書を開くたび、関東軍の暴走が日本の外交政策に与えた深刻な影響について考えさせられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "若し、そんな支障がなかったら、関東軍は、幸村等に、どれ程深く切り込まれていたか分らない。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和三年十月、関東軍参謀に転補。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の関東軍参謀は今日考えられるように人々の喜ぶ地位ではなかった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅順で関東庁と関東軍幹部の集会をやる場合、関東庁側は若い課長連が出るのに軍では高級参謀、高級副官が止まりで、私ども作戦主任参謀などは列席の光栄に浴し得なかった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東軍に転任の際も、今後とも欧州古戦史の研究を必ず続ける意気込みで赴任した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和四年五月一日、関東軍司令部で各地の特務機関長らを集め、いわゆる情報会議が行なわれた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果、昭和四年七月、板垣大佐を総裁官とし、関東軍独立守備隊、駐箚師団の参謀らを以て、哈爾賓、斉々｜哈爾、海拉爾、満州里方面に参謀演習旅行を行なった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那事変勃発当時、作戦部長の重職にあった私は、到底その重責に堪えず十月、関東軍に転任することとなった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は私は板垣中将が関東軍参謀長時代から東亜連盟は断念しているだろうと独断していたのであったから、これには相当驚かされたのであった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて昭和十二年秋関東軍参謀副長として着任、皇帝に拝謁の際、皇帝から「日系軍官」の名を無くして貰いたいとの御言葉を賜って深く感激したことがある。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人から借りたわけでしたが、当時はぼんやりしていたが、満州事件が起ってから新聞で見ると、かつて大家であった本庄という軍人は、外ならぬ関東軍指令官の本庄大将であるのが分って、ほほう、というような訳でした。",
              "citation": {
                "source": "「伸子」について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国の民衆を愚昧無気力にしておくために関東軍は阿片を売った。",
              "citation": {
                "source": "商売は道によってかしこし",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの八月九日の夜、新京から真先に遁走を開始した関東軍とその家族とは、三人の子をつれて徒歩でステーションに向う著者にトラックの砂塵をあびせ、列車に優先してのりこみ、ときには飛行機をとばして行方のわからない高官の家族の所在をさがさせまでした。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、八月十五日から数日たってやっと降伏した知らせが届いた満蒙奥地の開拓移民団の正直な老若男女が、ことの意外におどろいて数百名の生死を賭す団の進退をうちあわせようと駆けつけたときには、もうどこにも関東軍の影はなかった。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "満蒙奥地の住民のそのような怨み、憎悪が開拓団に向けられた理由こそは、関東軍が絶対命令で実行させつづけた住民からの収奪であったのに。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とるものもとりあえず新京を脱出した八月九日という日は、十五日より六日も前で、関東軍、役人たちの遁走前奏夜曲であったということを著者は、なにかの思いでこんにち、かえりみるときもあるだろう。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東軍の威勢は日本の運命を左右し一人一人の首ねっこを押えていただけに、この歴史的事実にたいして、一般の人々の抱いている人間的道義的侮蔑は深く鋭いものである。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気鋭の中国研究者として知られた同教授は、三重県に本部のある『山岸会』へ行き『共同生活実践の中で中国研究を続ける』という」　一九二八（昭和三）年、中華民国の政治家、張作霖が日本の関東軍によって爆殺された年、新島淳良は生まれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "少将は先きに旅順でお目に掛つたのであるが、先月下旬俄かに関東軍司令部が奉天に移つたので、憲兵司令官として旅順から来奉されてゐるのである。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はいずれも関東軍の兵隊だったので、降伏してからソ連に送られ、それぞれ収容所で重労働に従っていたものである。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、いずれは関東軍が、これを攻めるに相違ない、ではわしも出かけて行って、いろいろ策動してやろうと、鬼火の姥が眷族をひきいて既にその地に向かったそうな。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその城にこもっておられた、主上をはじめたてまつり尊澄法親王、藤原藤房、同じく具行、千種忠顕、尊貴｜縉顕の方々は、関東軍の手に渡った。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この月十五日に関東軍は、総勢こぞって京都を立ち大和路と佐々良路と天王寺路と、そうして伊賀路の四道から、赤坂の城へ向け出発した。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここが関東軍の本営であり、そこへ捕えられた自分達であり、自分達の訪ねて行く姉というのは、宮方に味方する桂子なので、それを明かしたなら自分達の身は、安穏ではあるまいと思われたので、知らぬよと素ッ気なく云ったのであった。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして今は敵ともいうべき、関東軍に捕えられ、生死のほどもおぼつかない。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えてみれば、チャムスの大学の満人教師が、関東軍司令部へ出かけて行って、日本軍の飛行機を使わせてくれと頼んだようなものだから、叱られるくらいですめば、まだ大いに有難かったわけである。",
              "citation": {
                "source": "大雪山二題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（金吾）……塀の内からラジオの声「……ガガガ、ガアガア、本月十八日、満洲柳条溝にて鉄道線路が爆破されて以来、十九日には関東軍れい下の皇軍の奉天入城に引きつづき事態は益々拡大のちょうこうを示し……ガガガ――」金吾の下駄の音はそれを引離して歩いて行く。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "社長はいよいよ満洲で戦争がはじまったんだから、セメント山もセメント山だけど、鉄の方に手を出すつもりで、関東軍の大どこと引っかかりをつけてくれるような軍人をつかまえようというんで目下血まなことになっているんだから、柳橋の方に入りびたりになる暇なんぞ全然ないですよ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてそこで関東軍がこの宋哲元軍を徹底的に糺弾すべく対策を協議している最中、恰も頃を見計らって、宋哲元軍は、関東軍と国民中央政府とからの警告にも拘らず、満州官吏に対して突如発砲を敢えてしたものである。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
