        "examples": {
          "standard": [
            {
              "text": "欧州連合のユーロは、成功した貨幣同盟の代表的な例だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史上、複数の国が貨幣同盟を結び、経済的な結びつきを強化した例は少なくない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "貨幣同盟に参加するかどうかは、各国の経済状況に大きく左右される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "単一通貨の導入は、貨幣同盟の大きなメリットの一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "しかし、貨幣同盟は加盟国に財政規律を求めるという側面もある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
