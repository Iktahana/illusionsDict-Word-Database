    "definitions": [
      {
        "index": 1,
        "gloss": "charisma (i.e. attractiveness, charm)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は会議で、そのカリスマで瞬く間に聴衆を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼のカリスマは、周囲の人々を惹きつけ、自然とリーダーシップを発揮させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの俳優は、画面からあふれるような独特のカリスマを持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新任の部長は、穏やかながらも強いカリスマを放っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "古川にとって西は、圧倒されるような波動と、しびれるような魅力を備えたカリスマだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "売上高に対する経常利益率が、成長を重ねながらなお二〇パーセント台を維持し続けるという高収益体質と、社員の滅私奉公的な献身、その核となる稲盛和夫のカリスマ性において、京都セラミツクは際だっていた★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターの意義を謳い上げ、カリスマとしてスタッフの力を引き出していくことには異才を発揮しながらも技術的な力は持たなかったジョブズにとって、自ら開発の方向付けを行ったリサは、初めての自分のマシンとなるはずだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "カリスマと一匹狼的な独立心を兼ね備えたフィリップ・Ｄ・エストリッジというリーダーのもと、ごく少数の独立したプロジェクトチームによって進められたＰＣの開発物語は、一〇年前、自分自身が主人公となって演じたドラマの筋立てをそっくりなぞっているように見えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "charisma (i.e. divinely conferred power or talent)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の言葉には、まるで神から授かったかのようなカリスマがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "困難な時代において、国民はカリスマを持つ指導者の出現を待望していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "宗教的指導者のカリスマは、多くの信者を惹きつけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "charismatic person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「彼はまさにカリスマだね。誰もが彼の意見に耳を傾けるんだから。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はチームのカリスマとして、皆をまとめ上げる力がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あのバンドのボーカルは、圧倒的なカリスマでライブ会場を熱狂させる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社を立ち上げた社長は、若くしてカリスマと呼ばれる存在になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 4,
        "gloss": "someone famous (usu. for their talent)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ファッション業界では、あのデザイナーはまさにカリスマとされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "YouTubeで有名なあの料理研究家は、もはやカリスマ的存在だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はスポーツ界のカリスマとして、子供たちの憧れの的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あのアーティスト、本当にカリスマだよね。出てくるだけで空気が変わるもん。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
