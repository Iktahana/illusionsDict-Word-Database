        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ボウルに卵と砂糖を入れて、泡だて器でよくかき混ぜてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この塗料は使う前に缶をよくかき混ぜないと、色が均一にならないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "セメントを水と混ぜ合わせる際、ダマにならないようしっかりかき混ぜることが肝心だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "完全に空気で飽和していない水をこの弾性がある流体とともにかき混ぜると空気の一部は吸収されるが大気の２つの主なガス成分である酸素と窒素は同じ割合で影響されることはない。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで上記のものに、雨水またはテムズ川の水または沸騰させた水９ガロンに溶かした25ポンドの砂糖を入れ、133ガロンの樽の中で棒で注意深くかき混ぜる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして顔の上の矛盾をかき混ぜるつもりなのかも知れない。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "卵をかき混ぜるか、そのままにするかは専門の料理師に研究してもらう。",
              "citation": {
                "source": "オフ・ア・ラ・コック・ファンタスティーク",
                "author": "――空想半熟卵――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドミン　ペーストをかき混ぜるすりこぎみたいなものですよ。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリガーセンが火をかき混ぜると、クロッカスのような青・黄色の火花が踊った。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はパレットナイフの柄を使ってミルクとパンの小切れをかき混ぜると、猫がその中に鼻を入れられるように身を引いた。",
              "citation": {
                "source": "四風の街",
                "author": "The Street of Four Winds",
                "note": "青空文庫"
              }
            },
            {
              "text": "何が一番面白かりしぞと問へば、湯をかきまぜるが、一番面白しといふ。",
              "citation": {
                "source": "親馬鹿の旅",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械的方法というのは、大気をかきまぜる方法である。",
              "citation": {
                "source": "霧を消す話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　アリスはそわそわとコックに目をやってね、そのひとがまさか言うとおりにはと様子をうかがったんだけど、コックはせわしなくスープをかきまぜるばかりで、話を聞いていたそぶりもないから、また口を開いて、「２４時間、かな？",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は、公園の入口のそばへ馬をつなぐと、馬車から飼料槽をとりおろし、秣のなかへひとつかみほどの糠を投げいれて、「ほら、もう、すぐぞ」　と、いいながら、両手でせっせとかきまぜる。",
              "citation": {
                "source": "キャラコさん",
                "author": "馬と老人",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あたし、公園へ散歩に来ましたのよ」　老人は、秣をかきまぜる手をやすめて、ゆっくりとキャラコさんのほうへふりかえると、片手で頬かぶりをしていた手拭いをとって、「やあはれ、それはお元気なこって……。",
              "citation": {
                "source": "キャラコさん",
                "author": "馬と老人",
                "note": "青空文庫"
              }
            },
            {
              "text": "タテハナのタテはもとかきまぜることで、斯うして作る粉の全體の名かと思はれるのに、現在は二種を分離した第二等のものゝ名だといふ。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "タテハナのタテはもとかきまぜることで、こうして作る粉の全体の名かと思われるのに、現在は二種を分離した第二等のものの名だという。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "かきまぜる動作には、一種異様な口笛を吹くような音が伴うが、これが長くかき廻すことと、短くかき廻すこととによって中断される動作と、完全に一致する。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
