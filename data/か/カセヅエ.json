        "examples": {
          "standard": [
            {
              "text": "険しい山道を登るため、彼は途中で見つけた頑丈な鹿杖を手に取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔話に出てくる旅の僧は、いつも一本の鹿杖を伴っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バランスを崩しかけたとき、持っていた鹿杖が彼の体を支えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "鉢叩きは鹿杖すなわち鹿の角のついた杖を突き、瓢箪を叩いて念仏を申す。",
              "citation": {
                "source": "間人考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鹿杖を突く事は、彼らがもと多くは殺生の徒であったが為に、その犠牲となった畜類に廻向し、罪障消滅を図るの為であったと解せられるが、しかも瓢箪を叩きながらこれを鉢叩きと呼ぶはいかなる故であろう。",
              "citation": {
                "source": "間人考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
