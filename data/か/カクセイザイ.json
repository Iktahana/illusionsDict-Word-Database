[
  {
    "uuid": "7afca14b-3051-5115-bec5-fc80e21f04dd",
    "entry": "覚醒剤",
    "reading": {
      "primary": "かくせいざい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
