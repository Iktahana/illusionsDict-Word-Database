[
  {
    "uuid": "13ae08d7-c35d-5cd8-98ef-3e4153e51cf3",
    "entry": "髪飾り",
    "reading": {
      "primary": "かみかざり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
