      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hair ornament",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「その髪飾り、着物の地色とぴったり合っていて、顔まわりがパッと華やいで見えるね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夏祭りに向けて、彼女はつまみ細工の技法を使って自分だけのオリジナルの髪飾りを作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "七五三の時に娘がつけた真っ赤なリボンの髪飾りは、今でも桐の箱に大切にしまってある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "また昔の日本の女になくてかなわなかった髪飾りや帯などは外国の女には無用の長物である。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川、天保の改革に幕府から厳しい奢侈禁止令が出て女の髪飾りにもいわゆる金銀玳瑁はご法度であった。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれが真珠、いずれが豚、つくづく主客てんとうして、今は、やけくそ、お嫁入り当時の髪飾り、かの白痴にちかき情人の写真しのばせ在りしロケットさえも、バンドの金具のはて迄。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからやはり岩屋の前へ、あきだるを伏せて、天宇受女命という女神に、天香具山のかつらのつるをたすきにかけさせ、かつらの葉を髪飾りにさせて、そのおけの上へあがって踊りを踊らせました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしただ言葉だけでご返事を申しあげたのでは失礼だとお考えになって、天皇へお礼のお印に、押木の玉かずらというりっぱな髪飾りを、若日下王から献上品としておことづけになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "オパールの髪飾りか。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "知ってざますよ」「なに、知っている※　どこのものじゃ」「江戸町の角菱楼にいなました薄雪さんざますよ」「その者は、特に達磨がすきじゃったか」「大好きも大好きも、どうしてあんなひょうげたものが好きやら、髪飾り帯下じゅばんの模様まで、身につけるほどの品物はみんな達磨の模様でありんした」「さようか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座の或る菓子屋には、欧州風の部屋着の揃いに、揃いの頭、揃いの髪飾りの美少女が五人、輪を作って椅子に腰をかけていた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の死後母は熱心な王党員である司令副官と結婚し、この一家とマリイ・アントワネットのきずなは、アントワネットが断頭台にのぼる前、ロオルの母に自分の髪飾りと耳輪とを形見に与えた程深いものであった。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒紋付に絹の股引を穿いた仲人らしい男と、母親かと思はれる年恰好の老女と、外に二三人の荷担ぎの男がついて花嫁自身も手に何か提げて、頭髪飾りをして歩いて行く。",
              "citation": {
                "source": "伊良湖の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには、母がまだお嬢様だった時分、書いたものや、繍ったもの、また故皇太后陛下からの頂戴ものその他一寸した私共には何でもなく見える、髪飾りなどばかり入って居たのだ。",
              "citation": {
                "source": "盗難",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふんわりとした髪飾りは、両耳の上にだけくっついていて、『ええ、どこかへ飛んでいってしまいたい！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、王宮からは、苡の実を髪飾りとなした鈿女らが山韮を振りながら、酒楽の唄を謡い上げて踊り始めた。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから気絶なすった貴方を介抱しておりますと、弛んだ貴方の懐中から、固く封じた巻物らしい包みと、姉さんが大切にしていた宝石や髪飾りが転がり出して来ました。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで僕は、伸子がレヴェズにあの室を指定して、自分はアレキサンドライトを髪飾りにつけ、それに電燈の光を透過させて、レヴェズを失意せしめた――と解釈するに至った。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」法水はポケットから泥塗れに潰れた白薔薇を取り出して、「たぶん姉さんのでしょうが、この髪飾りが、振綱の下から五寸程のところに引っかかっていたのです。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何より貴重な暗示だったのが、あの髪飾りの薔薇でした。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏見戦争の後で直ぐ、朝命を蒙つて征討将軍の宮に随従し北陸道の鎮撫に出掛けたと云ふ手紙や、一時｜還俗して岩手県の参事を拝命したと云ふ報知は、其の時々に来たが、少しの仕送りも無いので、奥方は嫁入の時に持つて来た衣服や髪飾りを売食して日を送つた。",
              "citation": {
                "source": "蓬生",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（そう云えば奥様の髪飾りなども、金目の物から一つ一つ、いつの間にか行衛が知れなくなった）　部屋の中をジロジロ見廻していた京助の優しい心配らしい眼が、自分の膝の上へ落ちた時に、また京助は溜息を洩らした。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪飾りといえば黄金珊瑚、家内こぞって三ッ指で、お嬢様お嬢様とたてまつる、ポーッと上気するばかりであった。",
              "citation": {
                "source": "柳営秘録かつえ蔵",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ以前から髪飾りと代えて、お玉のお吉は三味線を手に入れ、それを弾いて門に立ち、一文二文と貰う鳥目で、二人は今日までくらして来た。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪飾りの宝石が、耳の後ろでこまかく震えました。",
              "citation": {
                "source": "白塔の歌",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時彼女は、何の髪飾りもなく服も質素でありまして、遙かな白塔に見入ってるその姿は、都塵を離れた清楚さを帯びて、歌曲にふさわしいものでありました。",
              "citation": {
                "source": "白塔の歌",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は方福山の招宴の時と同じように髪を結び、髪飾りをつけ、ただ着物は同じ淡青色ながら、絹が繻子に変ってるだけでした。",
              "citation": {
                "source": "白塔の歌",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の前に、金の事となると眼の色を変えてかかる義母の浅ましい様子を見るにつけ、田舎の、身銭を切っても孫達のためにする母方の祖母や、もう身につける事のない衣裳だの髪飾りなどをお君の着物にかえた母親が一層有難く慕わしかった。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は今、露出した腕を組み、花の髪飾りを付けたままの頭を素肌の胸のあたりに垂れて坐っていた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "スペードの女王",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、母の俤は母親がその時時の流行を逐うて著ていた着物や、次から次へ変えた髪飾りに応じて変った顔をして泛んで来た。",
              "citation": {
                "source": "ある自殺者の手記",
                "author": "モオパッサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そうそういつぞやこんなお多福に、結構な髪飾りを一揃い……」「ああそうそう忘れていた」いくらか紙へ包んだが、「これで前垂れでももとめるがいい」「相済みませんでございます」チョロリと帯へ※んだが、「どうぞごゆっくり」と行ってしまった。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘子供など髪飾り衣類などに花美異風の拵えこれ無きよう相心得、若きものにはその親支配人どもより急度申渡せ。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　蔵前旅籠町を西福寺門前へ抜けようとする角に、万髪飾り商売で亀安という老舗があった。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "うし紅珊瑚",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
