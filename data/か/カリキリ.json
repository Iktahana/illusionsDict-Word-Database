    "definitions": [
      {
        "index": 1,
        "gloss": "reserving (for exclusive use)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "会社の忘年会で、あのレストランのフロアを借り切りにしたそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末の公園は家族連れで賑わっていたが、テニスコートは借り切りで練習している人がいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新幹線の一車両を借り切りにして、社員旅行を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この部屋、今日一日借り切りだよ！」と幹事が嬉しそうに言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "自分は蚕種検査の先生方の借り切り船へ御厄介になった。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "※県の食店へ二人の僧が来て、一昼夜万銭で部屋を借り切りにした。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰つて来ると、私は、その時まだ十八だつた異母妹の弓子を連れて、毎日裏の山へ登つたり、川口にある貸ボートを借り切りにして海に降つたり、川をずつと上流の方まで漕いだりして遊びまはつてゐた。",
              "citation": {
                "source": "鬼神",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大坂で梶子は帆船を借り切り、それへ乗って二人は船出した。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論そこもわしの借り切りになっているのだ。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "店はなぜか今日は客がすくなく、ぼくたちの借り切りのような雰囲気だった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭日の、なにもレースのないスピードウエイのコースを時間で借り切り、人気の高いあのロードレーサーの試乗をさせてもらっている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴は、シティに事務所を構え、豪華ホテルの特別室を借り切り、田舎に邸宅と競走馬の厩舎を購入してやがる。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "二カ月もいるうちに、二篇の短篇、五十枚ばかりきり書けなかった。",
              "citation": {
                "source": "骨を削りつつ歩む",
                "author": "――文壇苦行記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "待合室にいた人物が、何かよくわからない理由で、誰か別のものでかかりきりのあいだに、患者兼同居人の部屋へ上がったのだと。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "業務を引き継いでから三ヶ月の間は仕事にかかりきりで、我が友シャーロック・ホームズとも顔を合わせなかった。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身は動画の編集にかかりきりとなってしまい、β版をなだめながらの制作作業は、ボイジャージャパンの野口英司さんが全部背負い込んでくれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は翻訳にかかりきりとなっていましたから、さっそくこのホームページを開きっぱなしにして使いはじめました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは老夫人の請願書を持って帰って、一晩じゅうそれにかかりきりだった。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼女は組合の方にかかりきりになつたわけではなく、畑仕事から解放されたわけでもなかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "土蔵の戸の鍵は沢が預って居て、友江さんの食事も土蔵の掃除も沢がかかりきりでしたが、信之は、友江さんを監禁してから、一度も見舞に行きませんでした。",
              "citation": {
                "source": "暴風雨の夜",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隣家はこんもりした植込みのある――泉水などもある庭をもった二階家で、丁度そこの塀を二塀ばかりきりとって神田上水の井戸があるのを、塩せんべ屋のお婆さんが井戸番をしているようなかたちだった。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "町の構成",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に坐ってては、それだけの分量、なかなかはいらないので、従妹の夫は殆んど買い出しにかかりきりという有様さ。",
              "citation": {
                "source": "或る日の対話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その数日といふものは全く手紙にかかりきりで、封筒も貼れなかつたに相違ない。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大事業だナ、地べた発見のためには一日一人かかりきりの仕事だ。",
              "citation": {
                "source": "日記",
                "author": "一九三一年（昭和六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "目的をきめ目的のために寧日なくかかりきり、意識の分裂、妄想を最小限に封じることが第一、ねむくなるまででも辞書をオモチャに戦争継続、十時間辞書をひいても健康人の一時間ぐらいしか能率はあがらぬけれども、二六時中、目の覚めている限り徹頭徹尾辞書をひくに限る。",
              "citation": {
                "source": "二十一",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢中になって拵え、かかりきりで一気｜呵成に仕上げた作だ。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天文台では、一日二十四時間、近づくモロー彗星の観測と記録とに、かかりきりであった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはもちろん、この怪塔が海中につかりきりだと、あとしばらくして爆発し、彼も死んでしまわねばならぬのをおそれての上のことです。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、彫刻のみにかかりきりということはできません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベスは、手が器用でしたし、ほとんど朝から晩までかかりきりでしたから、まもなくできあがりました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "この隠れ家で、朝のうちは仕事にかかりきり、夕方には天気さえよければ、石ころの多い海辺を歩いて、足もとに哮えて砕ける浪の音に耳をかたむけた。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから考えつきまして、扇面いっぱいに、三万三千三百三十三の松の絵を、梨地蒔絵で、幸阿弥風に――面倒な注文でございますが、御影堂では、夜も昼も、職人から主人からかかりきりで、それもやがて、仕上げに近いと聞きましてございます。",
              "citation": {
                "source": "元禄十三年",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし懸かりきりで眼が覚めないと困るな」「なに大丈夫です。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐紙越しに突かれた槍の穗にかすられたらしく、左脇腹の乳の下のあたり、一寸ばかりきり割かれて、丹前から座布團へ、疊へ、ひどい血が流れて居るではありませんか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "妾の貞操",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
