[
  {
    "uuid": "8527cf9a-39fc-5584-a0e3-3909ec1bf618",
    "entry": "狩野派",
    "reading": {
      "primary": "かのうは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
