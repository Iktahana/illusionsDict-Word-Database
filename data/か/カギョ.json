    "definitions": [
      {
        "index": 1,
        "gloss": "river fish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その料亭では、清流で獲れた新鮮な河魚を使った料理が名物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "子供の頃は、よく父と川へ行って河魚を釣ったものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ダムの建設によって、その川固有の河魚が絶滅の危機に瀕している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "魚の中に於て、海魚は潮汐によつて其の氣が張弛するが、河魚は朝間詰夕間詰に於て著しく活溌になることは、老漁の看取して十二分に信じて居ることである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の気配もせぬので、のぞいて見ると隅っこの青く透いたサイダー瓶の棚の前に、鱗光の河魚の精のような爺が一人、しょぼんと坐っていた。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "河魚といへば、いづれも新鮮な生命にぴちぴちしてゐて、その姿をしなやかな、美しいものとのみ思つて、友達のやうな親しみをもつて遊び馴れて来た私に、この古池の鯉は、彼等の持つ冷たい不気味さと憂鬱との半面を見せてくれるに十分であつた。",
              "citation": {
                "source": "魚の憂鬱",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "網から引あげられて籠に入ったお前は、タニスで発見せられた名高いニイル河神の石像に彫りつけられた河魚のように、いつも横向きになっていて、つぶらな唯一つの眼しか見せていない。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "河魚といえば、いずれも新鮮な生命にぴちぴちしていて、その姿をしなやかな、美しいものとのみ思って、友達のような親みをもって遊び馴れて来た私に、この古池の鯉は、彼等の持つ冷たい不気味さと憂鬱との半面を見せてくれるに十分であった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "無數の小さな河魚は醉つぱらつて浮き上り、酒の流れに口をつけて飮んだ人は泥醉して僅に燒け殘つた母家に轉がり込み、金箔の古ぼけた大きな佛壇の扉を剥がしたり歌つたり踊つたりした。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の気配もせぬので、のぞいて見ると隅つこの青く透いたサイダー罎の棚の前に、鱗光の河魚の精のやうな爺が一人、しよんぼりと坐つてゐた。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "河畔の旗亭に車を止めそこで私たちは河魚料理で晝食をした。",
              "citation": {
                "source": "伊那紀行",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生憎只今は何物も御座ません時でして――野菜も御座ませんし、河魚も捕れませんし。",
              "citation": {
                "source": "伊豆の旅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってその反対なもの即ちすべての陰気、骨だらけの女や万河魚類、すし、吸物、さしみ、あらい、摺れ枯した心、日本服など頗る閉口するのである。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして不味い河魚の串に刺したのを、かみさんに燒かして酒を呑んだ。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯の用意にと、蓮太郎が宿へ命じて置いたは千曲川の鮠、それは上田から来る途中で買取つたとやらで、魚田楽にこしらへさせて、一緒に初冬の河魚の味を試みたいとのこと。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "水に住むと言えば、この人に親しみのあるのは、池に飼う鯉か、王滝川まで上って来る河魚ぐらいに限られている。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節がら食膳に上るものと言えば、石斑魚か、たなびらか、それに木ささげ、竹の子、菊豆腐の類であるが、山家にいてはめずらしくもない河魚や新鮮な野菜よりもやはり遠くから来る海のものを差し上げたら、あるいは都の料理方にもよろこばれようかと彼女は考えたのである。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "お種は嘉助の前にも膳を据えて、「今日は旦那も骨休めだと仰るし、三吉も来ているし、何物も無いが河魚で一杯出すで、お前もそこで御相伴しよや」　こう言われて、嘉助は癖のように禿頭を押えた。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどは、燐閃、河魚のごとく躍って各務房之丞の鬢をかすめ、ガッシ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして不味い河魚の串に刺したのを、かみさんに焼かして酒を呑んだ。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "捨鉢な調子であったから、政江は何かぎょっとした。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　青扇はなぜかぎょっとしたらしく顔つきを変えて立ちあがった。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は息子のことを云われて、何故かぎょっとしたようであった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "股引、腹掛、脚絆に草鞋ばき、ねじ鉢巻きの者もいて、焼けだされたような薄汚い不気味な恰好で上陸した姿を見て、白人や比律賓人は何かぎょっとし、比人労働組合は同志を糾合して排斥運動をはじめ、英字新聞も日清戦争の勇士が比律賓占領に上陸したと書き立てた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にそれが女であるというので、二人は何だかぎょっとした。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "股引、腹掛、脚絆に草鞋ばき、ねじ鉢巻の者もいて、焼けだされたような薄汚い不気味な恰好で上陸した姿を見て、白人や比律賓人は何かぎょっとし、比人労働組合は同志を糾合して排斥運動をはじめ、英字新聞も書きたてた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　わたくしを呼ぶ声がふだんと変っているので、なんだかぎょっとして振返ると、母は息をはずませながら小声で言い聞かせました。",
              "citation": {
                "source": "蜘蛛の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、それが只の毒蛇ではなく、ひと噛みそれに襲われたならば、忽ち生命を奪われると称されている大島産の恐るべき毒蛇金色ハブでしたから、いかな退屈男も、これにはしたたかぎょっとなりました。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ぞ初めてあかした直参旗本のその身分｜素姓に、二人はしたたかぎょッとなったらしく、二重の狼狽を見せると、それだけにまたこの恐るべき退屈男に堂々と乗り込まれては一大事と見えて、威勢を張りながら必死にはねつけました。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ぞ初めてあかした直参旗本のその身分素姓に、二人はしたたかぎょッとなったらしく、二重の狼狽を見せると、それだけにまたこの恐るべき退屈男に堂々と乗り込まれては一大事と見えて、威勢を張りながら必死にはねつけました。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」それから大地主さんの手紙を見ると、彼は何だかぎょっとしたように私には思われた。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "山チイはでたらめなひとだったが、シゴイさんに逃げられると、ひとが変ったようになり、眼なんかぎょろぎょろさせてすごいようだった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "拙者も、いささかぎょっとして、髷を持つ手を離してしもうた。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
