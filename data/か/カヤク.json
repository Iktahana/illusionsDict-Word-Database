[
  {
    "uuid": "90c9899a-7df9-5ed0-b6f1-48da4c1e6d9b",
    "entry": "加役",
    "reading": {
      "primary": "かやく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
