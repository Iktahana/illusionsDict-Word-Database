    "definitions": [
      {
        "index": 1,
        "gloss": "each person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "プロジェクトリーダーは、各者に割り当てられたタスクの進捗状況を確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "会議の最後に、議長は各者に意見を述べる機会を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "避難訓練では、担当者の指示に従い、各者が冷静に行動した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "大陸のかくしゃくたる太陽は、市街をも、人間をも、工場をも、すべてを高くから一目でじり／＼睨みつけていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だかくしゃくしゃしてたまらないのよ」と云った。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし僕等四人だけはとにかくしゃべりつづけにしゃべっていました。",
              "citation": {
                "source": "手紙",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、何んと今年私が四十三、父が八十三になって、父は、未だかくしゃくとしているのに、私がこの体なのだから、私としては、この父の死ぬ前に、私を死なしたくないと考えている。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただせっかくしゃべったものだから、これだけのことはつけ加えておきたい。",
              "citation": {
                "source": "仏蘭西文学と僕",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械人間は、ふふふとふくみ笑いをすると、サルの耳に口をよせて、何かくしゃくしゃ、ささやいた。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士が、年齢の割にかくしゃくたる原因は、一つは博士の旺盛なる食慾にあるといっていい。",
              "citation": {
                "source": "大使館の始末機関",
                "author": "――金博士シリーズ・７――",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ている間に一杯一杯一杯と重なって、ついには両人の皿には山盛の砂糖が堆くなって、壺の中には一匙の砂糖も余っておらんようになったとき、主人が寝ぼけ眼を擦りながら寝室を出て来てせっかくしゃくい出した砂糖を元のごとく壺の中へ入れてしまった。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくしゃべらせておくと又何を言い出すかわからないし、言葉の上では分が悪い。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "立原は例の長いからだをそこまで運ぶと、女の人に何かくしゃくしゃと言い、女の人はすぐにうなずいて素直に立原の後について来た。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "老来かくしゃくたるものがある。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくしゃくとしているのだ。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
