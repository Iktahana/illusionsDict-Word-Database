[
  {
    "uuid": "70307180-f857-5bf1-bbe5-6fac05bfbf22",
    "entry": "各社",
    "reading": {
      "primary": "かくしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "all companies",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新技術の発表を受け、各社が一斉に類似製品の開発に乗り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "年末商戦に向けて、百貨店各社は独自のセール企画を打ち出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "自動車メーカー各社は、円安を背景に過去最高の営業利益を記録した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "大規模なシステム障害が発生し、各社にその影響が及んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "まず試みに各社名宝のスターの「横顔の音」でも聞かせたらどうであろう。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "各社とも騒いで居るんだが、何か一つ特種を市内版までに抜かなくちゃならないんだ」「村井は居ないのかい」「チェッ。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら初刷だって、そんな無駄話で十頁も二十頁も埋られた日には、元日の新聞は単に重量に於て各社ともに競争する訳になるんだから、其の出来不出来に対する具眼の審判者は、読者のうちでただ屑屋丈だろうと云われたって仕方がない。",
              "citation": {
                "source": "元日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一意、旧藩主の恩顧と、永年奉仕して来た福岡市内各社の祭事能に関する責務を忘れず、一身を奉じつくして世を終った。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとく、歴史記述に関する各社の意欲には、温度差がありました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦書き、ページめくりで読めるビュワーを各社の幅広い機種向けに開発し、これに合わせて加工したファイルを並べたページが用意されている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこいつをうまく使いこなせるようにと、各社はそれぞれ工夫を凝らす。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワークスのプロモーションにあたって連携プレーを狙う各社からの挨拶が続いているにもかかわらず、アルコールがすでに回りはじめたのか、会場の一部からは通夜の宴の喧騒を思わせる大声が上がり始めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本サンは、東芝、富士通を初めとする各社に製品をＯＥＭ供給し、ＣＴＣ（伊藤忠テクノサイエンス）をはじめとする代理店経由の流れを加えた間接の販売ルートに、売り上げの約九十パーセントを負っている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではここでもう一段の軽量化をはかって、本当に持ち歩けるマシンをとなって、各社は大いに頭をひねる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダイナブックが起爆剤となって、各社はいっせいに小型マシンの開発に血道を上げた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アスキーは各社のマシンの開発方針策定に深く関わり、ＯＳを始めとするソフトウエアのビジネスを通じて、パーソナルコンピューターの在り方を決めてきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとてつもない大風呂敷を広げて、ＴＲＯＮチップの開発という大仕事に各社を引きずりだした風雲児坂村健の手並みには、３８６からはセカンド・ソース（これがどんな味のソースであるかは、次項で書く）を認めないというインテルの方針も有利に作用しただろうが、オレは実際肝をつぶした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "各社はここからＯＳの供給を受けて、教育用マシンとしてのＢＴＲＯＮをまず送り出すはずだった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "教育用マシンとしての各社のＢＴＲＯＮ発売計画は頓挫した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンパックやＩＢＭをはじめとする各社のマシンから３８６を引っこ抜き、代わりにＡＭＤのチップを突っ込んでアプリケーションを走らせ「ほら、互換でしょ」とやった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノートブック型マッキントッシュ、パワーブックのラインナップを始めとするアップルの新製品、各社からぞろぞろ出てきた手書きのペン・ベースのシステム、いわゆるマルチメディア関連、Ｗｉｎｄｏｗｓアプリケーションに『Count on it !』といった話ばっかりで、ＡＭＤのＡの字も聞こえてこないじゃないか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話機商売で味を占めた日本のメーカーは、押された番号によって各社の電話回線のなかから一番安いものを自動的に選ぶα―ＬＣＲ機能というやつをくっつけて電話を買い替えさせようと企んでいるが、こんなものはソフトウエアの追加ですませられるではないか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "各社で警戒して居る以上、ヒョッとするとタチアナ姫は来るのかも知れないと思いました。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は少し馬鹿々々しくなりましたが、然し各社の連中が駆け出す以上、駆け出さない訳には行きませんでした。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ若い美しい未亡人が、祈祷の最中に泣き崩れているところを何の会釈もあらばこそ、マグネシウムをボンボンと焚きながら、各社の連中が折り重なって撮るのです。",
              "citation": {
                "source": "Ｍ侯爵と写真師",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると、鶏林（朝鮮の異称）の風雲おだやかならずと云うので、東京大阪の新聞社からも記者を派遣することになりましたが、まだ其の時は従軍記者というわけではなく、各社から思い思いに通信員を送り出したというに過ぎないので、直接には軍隊とは何の関係もありませんでした。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等生物団　第一報発表以後のわずか十八時間に、各社の第一線記者は悉くへたばってしまった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしと前後して、各社の諸君も大抵来会したのであるが、主人側の家橘が顔をみせない。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず新興キネマは、杉山、毛利、久松の三名を挙げ、右は会社に迷惑をかけた不埓ものであるから、絶対に雇用するなかれという意味の通告を各社に向って送付している。",
              "citation": {
                "source": "映画界手近の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ今回に限ってかかる実例を作り得たかといえば、それは一には各社とも長年にわたる監督・俳優争奪戦に疲労し倦み果てた結果である。",
              "citation": {
                "source": "映画界手近の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実行案の成立が、いつまでも実現しない理由は、各社の代表が、互に自社の利益を擁護する立場を脱しきれないためと、いま一つには当局の態度がいささか傍観的にすぎるためらしい。",
              "citation": {
                "source": "思い",
                "author": "――情報局の映画新体制案について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "各社代表が、利益から離れられないのは、むしろ当然すぎることであつて、少しもこれを怪しむ理由はない。",
              "citation": {
                "source": "思い",
                "author": "――情報局の映画新体制案について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで現状の実際からみれば音響監督のことなど夢のような話で、ほとんど各社とも一つの作品に付随する音楽の全部を一晩か二晩で入れているありさまである。",
              "citation": {
                "source": "雑文的雑文",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大陸のかくしゃくたる太陽は、市街をも、人間をも、工場をも、すべてを高くから一目でじり／＼睨みつけていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
