        "examples": {
          "standard": [
            {
              "text": "コンサート会場で、バンドが歌詞カードを配っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "カラオケでは、歌詞カードを見ながら歌うのが普通だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "CDの初回限定盤には、ボーナストラックと共に歌詞カードも封入されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "歌の練習をするために、歌詞カードを印刷しておいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "歌詞カードをおくの。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌詞とコードネイムだけで、音符は書いてない」　これは、練習中に〈カモン・レッツ・ゴー〉の歌詞カードをやぶいてから、国語と数学の時間をフルに利用して、営々と書き写してきた、だいじな労作だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれに、歌詞カードをわたすなよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌詞カードなんかなくたって、この曲はだれでも歌えるの」　と笑いながら、柾生がオープンＧを押さえ、五弦から順にシレソと弾く。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "手もとにある場合は国内盤の歌詞カードを参照しているが、最終的にはじぶんの耳がたよりなので、あなたがご存じの歌詞とはズレがあるかもしれない（とりわけ〈ホエン〉と〈レドウッド・トゥリー〉）。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
