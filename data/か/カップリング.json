        "examples": {
          "standard": [
            {
              "text": "このモーターとポンプを繋ぐには、適切なカップリングが必要です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い配管のカップリングが劣化して、水漏れが起きていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "エンジンの出力を効率的に伝えるため、特殊なカップリングが採用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "カップリングを静かに変えて見ました。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "精密なコンデンサーカップリングか何か使って、箱の面の各点の振動の様子を見て、ノーダルラインでも決めてみたら、きっと何か面白いことが見つかると思う。",
              "citation": {
                "source": "続先生を囲る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
