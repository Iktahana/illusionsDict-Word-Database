        "examples": {
          "standard": [
            {
              "text": "その賭け事師は、運だけでなく鋭い洞察力で勝負に臨む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼はかつては有名な賭け事師だったが、今は静かに暮らしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "プロの賭け事師として生計を立てるのは、並大抵のことではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もし勝ったら、君も賭け事師になるか？」と彼は冗談を言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "幻の冒険に大金を継ぎこむことになるが、ハロルドにはもともと賭け事師の素質があった。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            }
          ]
        }
