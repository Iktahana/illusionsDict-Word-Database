        "examples": {
          "standard": [
            {
              "text": "カタールで開催されたスポーツイベントには、世界中から多くの観客が集まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "カタール航空は、サービス品質の高さで知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「カタールって、夏はすごく暑いらしいね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "湾岸諸国の一つであるカタールは、経済発展が著しい国だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "三月初旬に、Ｙは大腸カタールをした。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月二日（火曜）　Ｙ、大腸カタールを起し、工合よろしからず。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "大腸カタールの話が出、彼百日もわるかった由。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月十一日（木曜）　Ｙの腸、さすが大腸カタールなり。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし承知している最中に、突然急性胃カタールでどっとやられてしまった。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は八月二十日から劇烈な胃カタールで寢こんでしまつたし、それが一徃收まると、九月一日にはもう『滿韓ところ／″＼』の旅に出かけたからである。",
              "citation": {
                "source": "知られざる漱石",
                "author": "小宮豐隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために彼女は咽喉カタールを起していたのです。",
              "citation": {
                "source": "途上",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八一六年の十月以降、彼ははげしい※衝性カタール 〔Entzu:ndungskatarrh〕 を病んだ。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
