        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔の旅籠には、共同の厠が設けられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "山小屋の厠は、いつもきれいに掃除されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "厠の奥から、かすかに水の音が聞こえてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い農家では、今でも厠を使っているところがあるそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "でなければ厠に上られてはこされているからだろう」女神の化粧は自分で納得ゆくまで何遍でも仕代えさせられるので永い。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女神の上厠は、はこそのものよりも、うつらうつら物うち考えられるのでこれも永い。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "厠神の植山姫、水匿女も永く場を塞がれて手を焼くそうであるという。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "心細く感じながらも、ひとりでそっと床から脱け出しまして、てらてら黒光りのする欅普請の長い廊下をこわごわお厠のほうへ、足の裏だけは、いやに冷や冷やして居りましたけれど、なにさま眠くって、まるで深い霧のなかをゆらりゆらり泳いでいるような気持ち、そのときです。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉藏は、ひとりで厠へ立つて歩けるほど元氣を恢復してゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "深夜、厠へ行く途中、廊下で同宿のわかい女とすれちがつた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小菅が、深夜、厠へ行つたそのときでさへ、おのれの新調の青い外套をきちんと着て廊下へ出たといふ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕上鞍上厠上合わせて三上の意だという。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「厠上」のほうは人によると現在でも適用するかもしれない。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞍上と厠上の場合にはこれが明白であるが枕上ではこれが明白でないように見える。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜のひきあけに、いつものとおり咳がたてこんで出たので、眠られぬままに厠に立った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "稚厠の上に　抱へられてた、すると尻から　蛔虫が下がつた。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蛔虫が、稚厠の浅瀬で動くので動くので、私は吃驚しちまつた。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方にも厠はあるが、運ぶのに、ちと遠い。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦子の姿は、無事に厠を背後にして、さし置いたその洋燈の前、廊下のはずれに、媚かしく露われた。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "不祥な言を放つものは、曰く厠から月に浮かれて、浪に誘われたのであろうも知れず、と即ち船を漕ぎ出したのも有るほどで。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく待合の手水鉢に柄杓の無いのは、厠に戸の無いより始末が悪い。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、厠の板戸を、内から細目に、小春の姿が消えそうに、「私、つい、つい、うっかりして、あのお恥かしくって泣くんですわ……ここには水がありません。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、寝ぬくもりの冷めないうち、早く厠へと思う急心に、向う見ずに扉を押した。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "厠へ行くのに、裏階子を下りると、これが、頑丈な事は、巨巌を斫開いたようです。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "車麩の鼠に怯えた様子では、同行を否定されそうな形勢だった処から、「お町さん、念仏を唱えるばかり吃驚した、厠の戸の白い手も、先へ入っていた女が、人影に急いで扉を閉めただけの事で、何でもないのだ。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、おくれ馳せながら、正体見たり枯尾花流に――続いて説明に及ぶと、澄んで沈んだ真顔になって、鹿落の旅館の、その三つ並んだ真中の厠は、取壊して今はない筈だ、と言って、先手に、もう知っている。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう身も世も断念めて、すぐに死場所の、……鉄道線路へ……」「厠からすぐだろうか。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下から、厠までは、宵から通った人もある。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、時々崖裏の石垣から、獺が這込んで、板廊下や厠に点いた燈を消して、悪戯をするげに言います。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸障子を立て籠めて、その部屋はすべての光を防ぐやうに出来てゐるばかりでなく、かれは厠へ通ふ時のほかは他の座敷へも廊下へも出なかつた。",
              "citation": {
                "source": "梟娘の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "厠へゆく時でも、かれは両袖で顔を掩ひかくすやうにしてゐたが、どうかして其袖のあひだからちらりと洩れた顔をみせられた場合には、誰でもその美しいのに驚かない者はなかつた。",
              "citation": {
                "source": "梟娘の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れも長屋で、褓襁の干してあるのも見えれば、厠も見えて、此方では向ふの家の暴露された裏を見せつけられてゐるのであツた。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　銀子は笑っていたが、その経験がないとは言えず、厠へ入って、独りでそっと憤激の熱い涙を搾り搾りしたものだったが、それには何か自身の心に合点の行く理由がなくてはならぬと考え、すべてを親のためというところへ持って行くよりほかなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来の人達も何かわやわや云いながら駈け出して行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
