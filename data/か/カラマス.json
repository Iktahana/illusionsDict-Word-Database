[
  {
    "uuid": "6ed70c04-2aef-5c23-bc69-42c464c46851",
    "entry": "絡ます",
    "reading": {
      "primary": "からます",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
