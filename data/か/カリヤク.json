        "examples": {
          "standard": [
            {
              "text": "部長が急病で倒れ、彼が回復するまで課長が仮役でその職務を代行することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新人研修の一環として、先輩社員の指導のもと、私は会議の議事録作成の仮役を任された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "社内イベントで、普段は裏方だが、今回は受付の仮役を務めることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "選挙期間中、ボランティアとして事務所の手伝いや電話対応の仮役を引き受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "翌年三月、みずから七名の家臣をひきつれ、支配地授受のため折柄開庁した函館の仮役所に出向いた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳生対馬守、別所信濃守の造営奉行｜仮役所は、前もってこの山王のそばにしつらえてある。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "余計な世話ばつかりやくのよ。",
              "citation": {
                "source": "女人渇仰",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "できるだけわかりやくするためか、排水管の出口で、手で水を受け止めるような真似をした。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
