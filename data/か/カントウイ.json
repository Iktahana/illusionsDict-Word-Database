        "examples": {
          "standard": [
            {
              "text": "弥生時代の遺跡から出土した土偶の服装を見ると、当時の人々が貫頭衣を着用していたことが推測できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史体験教室で麻布を使った貫頭衣を自作したが、頭を通す穴を開けるだけの単純な構造に驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ほら、これがあの有名な貫頭衣だよ。卑弥呼もこんな感じの服を着ていたのかもね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "其風俗不淫、男子皆露、作衣如單被、穿其中央、貫頭衣之。",
              "citation": {
                "source": "魏志倭人傳",
                "author": "陳壽",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
