[
  {
    "uuid": "dbf65cdb-72ae-5e0a-bc81-6e657de12e13",
    "entry": "仮名文字",
    "reading": {
      "primary": "かなもじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the Japanese syllabary symbols",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "平安時代の女性たちは、繊細な仮名文字を駆使して自らの恋心を和歌に託した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "漢字ばかりの堅苦しい文章に、柔らかな仮名文字が混ざることで格段に読みやすくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "墨をたっぷりと含ませた筆で、流れるような曲線を描く仮名文字を書き連ねる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「まずは自分の名前を、一文字ずつ丁寧に仮名文字で練習しましょうね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "初めの中は変な仮名文字だから読み苦くって弱りましたが、段々読むに慣れてスラスラと読めるようになった。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに、近年勾当の令孫君、余が学校を訪われ君が祖父故葛原勾当自記の四十余年間に亘れる仮名文字活字日誌を示され、且、其生存中に於ける事業の大要及び勾当の趣味等につき、詳に語らる。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手くそな仮名文字だが、やッとその意だけは通じている。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦斯燈に「かしはざき」と書いた仮名文字が読める。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "儚き日君のたよりの来た日からかなしい噂がたちました水に流して呉れろとは夢と思への謎か知ら走り書きだが仮名文字で「涙」と記してありました水に流して呉れろとは熱い涙の事か知ら。",
              "citation": {
                "source": "別後",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "大尉は一番上の受信紙の、片仮名文字の電文を口の中で読みくだした。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "更によく見ると、その虫蝕いの跡は仮名文字の走り書きのように読まれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はお由をそっと呼んで、八つ手の古い葉を見せると、お由もその虫蝕いのような仮名文字を「おそでしぬ」と読んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄さん、仮名をトンにし、漢字をツーにして、早く、この十二組の文字を書き直して、どういう仮名文字に相当するか検べてください」　私はやっとかかって左のとおり検べあげました。",
              "citation": {
                "source": "紅色ダイヤ",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士の説によると、日本に科学の智識が行き渡らないのは、仮名文字や漢字がのさばつてゐるからで、便利な羅馬字さへ普及してゐれば、男にも女にも、猫にも、鰯にも科学思想が行き渡つて、みんな身持がよくなるといふのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "書かれている仮名文字と発音とが別々で、書かれている字の通りに読んだのでは意味が分らない場合が少くなかった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こりずまに書くや此仮名文字まじり人は笑へど書くや此仮名」とか云ふ歌をさへ作つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶山の仮名文字を用ゐること常よりも稍多かつたのは、老人の読み易きやうにとの心しらひではなからうか。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　わたくしは榛軒の妻志保が始て柏に仮名文字を授けたのは此頃であつたかと謂ふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の紙のじみな色をしたのへ、漢字を草書で書かれたのがすぐれて美しいと宮は見ておいでになったが、またそのあとで、朝鮮紙の地のきめの細かい柔らかな感じのする、色などは派手でない艶なのへ、仮名文字が、しかも正しく熱の見える字で書かれてある絶妙な物をお見つけになった。",
              "citation": {
                "source": "源氏物語",
                "author": "梅が枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "細川下邸の清正公門前の大きな椎の木の並んだ下には、少壮時代の前かけがけ姿の清方さんが長く住まわれて、門柱に「かぶらき」と書いた仮名文字の表札がかけてあった。",
              "citation": {
                "source": "牢屋の原",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "生家へも、母親の死んだあとはあまり便りがなく、一昨年京阪を吹きまくった大暴風雨に、鴨川の出水をきいて、打絶えて久しい見舞いの手紙が来たが、たどたどしい仮名文字で、もはや字も忘れて思いだすのが面倒だとあった。",
              "citation": {
                "source": "モルガンお雪",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮名文字わが歌の仮名文字よ、あはれ、ほつほつ、止所なく乱れ散る涙のしづく。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "八「ちょいと、マア御覧よ、こんどはこんなことが書いてあってよ」と一人が小さい紙切を持ってベンチの隅に俯伏すとやっと、十四五歳のを頭に四五人の子守女が低い足駄をガタつかせて、その上に重なりおうててんでに口のなかで紙切の仮名文字をおぼつかなく読んで見てはキャッキャッと笑う。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "――と思ったのは間違いで、書物の真中と思われる辺りに、次のような仮名文字が記されてあった。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の中へはいッて見ると、小草の二三寸延びた蔭または蚊帳草の間などから、たおやめの書いた仮名文字ののしという恰好で、蕨が半身を現わしていた，われわれはこれを見ると，そらそこにも！",
              "citation": {
                "source": "初恋",
                "author": "矢崎嵯峨の舎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行船隊を発見す　地下街の司令部では、印刷電信機が、リズミカルな響をあげて、各所の要地から集ってくる牒報を、仮名文字に打ち直していた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がきっとここだというところまで解いて、それで駄目だったのは、あの『あらまそーお』云々を仮名文字のまま引繰りかえしたから失敗したのだ。",
              "citation": {
                "source": "獏鸚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは昨夜と同じように、表の戸はすっかり締めきってあるのに、掛行燈だけが、かんかんと明るく、昨夕「若葉屋」と書いてあったところに、今宵は「こなや」と仮名文字で記されてありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その飲みっぷりが相当にものになっているから、白雲も面白いことに思い、「時に、お前のその絆纏に染めてある仮名文字は、そりゃ何じゃ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから、読み砕こうと思って再三苦心したが、どうもわからねえ、何のおまじないだい」「へ、へ、へ、これでございますか」　白雲が、さいぜんから気にしていたことの一つは、この若い者の背中に、仮名文字が一列に染め出されている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは仮名文字だから、横文字と違って、読むに困難はないが、文句そのものが意味を成さないから、白雲ほどのものが思案に余っているらしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
