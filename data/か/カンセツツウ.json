        "examples": {
          "standard": [
            {
              "text": "寒くなると、昔の古傷のせいか膝の関節痛がひどくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はリウマチが原因で、常に全身の関節痛に悩まされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "登山をした翌日、普段使わない筋肉と関節痛でまともに歩けなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近、指の関節痛がひどくて、瓶の蓋を開けるのも一苦労だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その翌日も信三は帰らなかった、兄の省吾は熱が高くなり、はげしい関節痛をともないだしたので医者を呼んだ、医者は、「まだはっきりしないがことによるとチフスかもしれないから」　そう云って手当の指図をし、すぐ検便の結果を知らせるからと帰っていった。",
              "citation": {
                "source": "四年間",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
