        "examples": {
          "standard": [
            {
              "text": "天井の補強工事で、カッペを何本か追加する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "設計図を見ると、この部分には強度を保つためにカッペが使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い倉庫の屋根を支えるカッペが錆びていて、交換が必要だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
