    "definitions": [
      {
        "index": 1,
        "gloss": "country bumpkin",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "都会に出てきたばかりの頃は、何を見ても『かっぺ』扱いされた気がしたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼、最初はちょっと『かっぺ』っぽい雰囲気だったけど、今ではすっかり都会に馴染んでるね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そんな反応してるの、まるっきり『かっぺ』じゃん、と友達にからかわれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "待つ人があるだっぺとか逢いたい人が待ちどおかっぺとか、当こすりを云ってお民さんを泣かせたりしてネ、お母さんにも何でもいろいろなこと言ったらしい、とうとう一昨日お昼前に帰してしまったのでさ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかがいなかっぺいのけんつくぐれえに尾っぽを巻いて、江戸八百八町の名折れじゃござんせんか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "「詰んねえことさ、その……何さ、きい奴まだ若けえのに――その亭主兵隊さとられちまってはあ――その……さびしかっぺえと思ったんで、おらあ……何、ちょっくら親切してやったのうばばあめ……騒いでけつかる」　去年の六月、私は祖母とその村にいた。",
              "citation": {
                "source": "田舎風なヒューモレスク",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでもはあ、民衆一体の仕合わせを目あてにしてやっているちゅうのは嘘でなかっぺえな――支那の奴等も目醒めて来たんだない」　目醒めて来たとは、ブラボー！",
              "citation": {
                "source": "北へ行く",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると主人は、「いなかっぺはぐずでしょうがねえなあ。",
              "citation": {
                "source": "水菓子屋の要吉",
                "author": "木内高音",
                "note": "青空文庫"
              }
            },
            {
              "text": "元のパルチザン、集団農場さ入れねえことは、なかっぺ。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……俺らとこだって……ちっこい者が出来ねえもんでもなかっぺ。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の子の前がはだけて膝っ子僧が出て居るのを祖母がしてやる様に、しずかに可愛がって居るらしくなおしてやりながら、「お前さま、今まで、こんなむさい家は見なすった事がなかっぺい。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「古利根がよかっぺ」　とか、どこぞこは、もう、ダメだっぺ、というようなことを答える。",
              "citation": {
                "source": "釣り師の心境",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "物を拾って届けるのは当り前じゃねえか、オレが一割もお礼やること、なかっぺ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「寒かっぺから、これ飲んだらどうだや」と彼女は二合瓶を傍の土瓶へあけて火の上にかけ、「戦地からお艶らお父の写真来てたっけよ。",
              "citation": {
                "source": "おびとき",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊さんもあれ見たらうれしかっぺで……女の子って可愛もんだな、ほんとに俺も一人ほしかっけ……野郎らばかりで、ぞろぞろ飯ばかりかっ食らいやがって……」「出来ねえ限りもあんめえで……まアだ。",
              "citation": {
                "source": "おびとき",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やア、これはしたり、百姓のまねなんど止した方がよかっぺで」と彼はいきなり近くの木株へ腰を下ろして、煙管を出し、「いや、こないだは痛けえだったっちう話だっけな。",
              "citation": {
                "source": "瘤",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "――明日でよかっぺ。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "碌な米だねえけんど、外米よりはまさか旨かっぺから。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホイソラ、ホイソラ』いなかっぺえいなかっぺいのおたずねだ。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだ巧かっぺえ」　皆は破れるように喝采した。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いそがしかっぺえがちょっくら坐って、話してえがんけえ？",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺れえ一人悪者になってりゃおめえは嬉しかっぺえなあ、おい！",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬉しかっぺえよ」と神経的に涙をこぼし始めた。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とかしてくれたら、はあなじょうに小気味がよかっぺえ！",
              "citation": {
                "source": "禰宜様宮田",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……なじょにしたらよかっぺえ……」　幾度考えたとて、徒に同じ埒の中を堂々廻りするほかない。",
              "citation": {
                "source": "禰宜様宮田",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けんども、はあ何んでもお前等が仕合せになってんだら、行ぐも悪かあなかっぺえ。",
              "citation": {
                "source": "禰宜様宮田",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして女房にも、身の振方をきめてやるという条件つきで、そのことを話すと、女房も、「それも、よかっぺえて……」と云う。",
              "citation": {
                "source": "三郎爺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら留蔵がかえって毒気をぬかれて、もうよかっぺと云って、仲なおりした逸話があります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京にいたとき、田舎から転校して来た生徒があると、「いなかっぺえ」といって、やっぱりみんなでからかったり、意地悪をしたりしたものだ。",
              "citation": {
                "source": "おごそかな渇き",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
