    "definitions": [
      {
        "index": 1,
        "gloss": "change",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "10年ぶりに地元に帰ったら、駅前のあまりの変わりように言葉を失った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「へえー！彼、あんなに大人しかったのに、今の仕事っぷりの変わりようはすごいね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "病気を克服した後の彼女の前向きな変わりようには、周囲も驚かされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "わずか数時間の間に、穏やかだった海が荒れ狂う嵐へと変わりようを見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "変わったといえば家の焼けあとの変わりようもひどいものだった。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンネン技師からはひっきりなしに、向こうの仕事の進み具合も知らせてよこし、ガスの圧力や山の形の変わりようも尋ねて来ました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずかのあいだにサイラス・ブラウンの変わりようといったらなかった。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろこび勇んで四人はとある漁船のかげに一休みしたのであるが、思わぬ空の変わりようにてにわかに雨となった。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（愛憐の情に堪えざるごとく）あなた様のこのお変わりようは！",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "宰相中将はこうした立場を与えられるに至った夢のような運命の変わりようにも自己の優越を感じた。",
              "citation": {
                "source": "源氏物語",
                "author": "藤のうら葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大臣は笑顔をして、「字が非常に上手になったね」　などと言っていることも昔とはたいした変わりようである。",
              "citation": {
                "source": "源氏物語",
                "author": "藤のうら葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は痛切に良人のこの変わりようを悲しんでいた。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧二",
                "note": "青空文庫"
              }
            },
            {
              "text": "短いお手紙に返事をすることすら恥ずかしかった方であるのに、今の心はそうでない、久しくおいでにならぬことがあれば心細いであろうと思われるのも、われながら怪しく恥ずかしい変わりようであると中の君は心で思った。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            },
            {
              "text": "村から学校へ通う女学生の風俗すら、その時分と比較してみれば変わりようも甚だしければ、また弁当箱を下げて、近接した町の小会社や、工場へ通勤する青年の数も多くなったのに驚かされます。",
              "citation": {
                "source": "事実と感想",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても昨日までのお父上は、殿のご乱行につかれましてもこの私などよりはもっともっと、お心に掛けられておられまして、時々ご諫言も申し上げた筈、それだのにたった一夜の違いで、その諫言という言葉をさえ真面目に取らぬほどのお変わりよう。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という変わりようだろう！",
              "citation": {
                "source": "大ヴォローヂャと小ヴォローヂャ",
                "author": "ВОЛОДЯ　БОЛЬШОЙ　И　ВОЛОДЯ　МАЛЕНЬКИЙ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私の方はとてもの変わりようよ。",
              "citation": {
                "source": "大ヴォローヂャと小ヴォローヂャ",
                "author": "ВОЛОДЯ　БОЛЬШОЙ　И　ВОЛОДЯ　МАЛЕНЬКИЙ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてトロイカが町の門へ向かって疾駆して行くあいだ皆は黙りこんで、ただ彼女が温かく居心地のいいように気をつかいながら、銘々の心の中で、以前の彼女と現在の彼女の変わりようを、じっと思い較べるのであった。",
              "citation": {
                "source": "大ヴォローヂャと小ヴォローヂャ",
                "author": "ВОЛОДЯ　БОЛЬШОЙ　И　ВОЛОДЯ　МАЛЕНЬКИЙ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんという変わりようでございましょう。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　うらと表の合わせかがみ――この変わりよう果たしてお艶の本心であろうか？",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何がそんなに、おかしいのかな」「あなた様の変わりようでございますよ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "このいきなりの変わりように、たいへんおそれをなしたものの、ちぢむのはそこまで、キノコのかさもとりおとしてないから、まだまだあきらめたりしません。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "このいきなりの変わりように、たいへんおそれをなしたものの、はげしくちぢんでいくのでぐずぐずしてはいられないと思って、とっさにもうひとつのかけらを食べにかかる。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこれでおしまいなんだ、どうにも変わりようがないってことは、おれにもわかっている。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "『たといどんな変わりようだってかまうもんか』と彼は自暴自棄的な、凝り固まった自信と決心をもって、そうくり返した。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然の変わりように、さしもの強靭な神経も参ってしまった。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然の変わりように、ジュリアン先生は内心笑っていた。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "謹んでお詫び申し上げます」　夫人の変わりようと言ったら、トリガーセンと同じくらい大きい。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "大変な変わりようではありませんか。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然の変わりように皆興奮した。",
              "citation": {
                "source": "四日闇夜",
                "author": "THE FOUR DAYS' NIGHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがどうだ、彼女のかわりようは。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "其のかわりようく物を見る、ようく聴いて居る。",
              "citation": {
                "source": "漁師の娘",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その決心――かわりようがない？",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが巣鴨を出ると、よってゆけるような友達の家は遠すぎたりして、行雄のところへ行き、自分の内面とかかわりようもない声と動きにみちた暮しの様を見ると、ひろ子は、せめてまだあの家がるうちに、という風に気をせいて目白へ帰るのであった。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
