        "examples": {
          "standard": [
            {
              "text": "子供の頃、縁日でカルメ焼きを買ってもらうのが楽しみだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カルメ焼きを作る実験を理科の授業でやったことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "焦がさないように気をつけながら、慎重にカルメ焼きを型から外した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "鶴石は留吉を見ると、とてもよろこんで、留吉を連れてどこかへ出掛けて行つたが、暫くしてまだ熱いカルメ焼きの大きいのを二つ留吉が持つて戻つて来た。",
              "citation": {
                "source": "下町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜月五日　姉さんが、カルメ焼きを造るといって、火を落として、新しい畳の上に、大きな焼け穴をあけた。",
              "citation": {
                "source": "ある少年の正月の日記",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
