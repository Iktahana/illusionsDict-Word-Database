        "examples": {
          "standard": [
            {
              "text": "スマホで簡単に調べられる時代でも、私は紙の辞書を引く手触りが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "テストの時、電子辞書が禁止だったので、使い慣れた紙の辞書を持っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い紙の辞書には、書き込みがたくさんあって、持ち主がどれだけ勉強したかがわかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい言葉に出会ったら、まずは紙の辞書で意味を確認するようにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "紙の辞書をばたばたさせるよりもはるかに軽快です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
