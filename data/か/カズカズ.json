[
  {
    "uuid": "7adee838-7477-54ba-a8a7-c8d48761e10b",
    "entry": "数々",
    "reading": {
      "primary": "かずかず",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
