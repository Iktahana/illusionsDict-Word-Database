  {
    "uuid": "4bc0b447-ca74-51e8-be41-02d61ed13eab",
    "entry": "干犯",
    "reading": {
      "primary": "かんぱん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
