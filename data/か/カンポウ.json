    "definitions": [
      {
        "index": 1,
        "gloss": "official daily gazette",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "俺はその時官報を披いて見て居つた。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鼻先へ出て「行政官は早いですなあ」と俺の顔と官報とを一目で覗き分けをしつつ云つたあいつの顔は「この冷笑と侮蔑と憐憫とを君に捧げよう」と云はんばかりであつた。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "官報にある事は、官報に據る。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半官報にある事は、半官報に據る。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は東京に在りて、すでに天方伯の秘書官たりしが、余が免官の官報に出でしを見て、某新聞紙の編輯長に説きて、余を社の通信員となし、伯林に留まりて政治学芸のことなどを報道せしむることとなしつ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は東京に在りて、既に天方伯の祕書官たりしが、余が免官の官報に出でしを見て、某新聞紙の編輯長に説きて、余を社の通信員となし、伯林に留まりて政治學藝の事などを報道せしむることとなしつ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが官報に掲載され、出張旅費稼ぎでもできれば申分なからう。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　『浮雲』第三篇及び官報局出仕『浮雲』第三篇の発表されたのはこれより少し後であった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、結局古川の斡旋で、古川部下の飜訳官として官報局に出仕したのが明治二十二年の夏であって、これから以後の数年は生活の保障に漸く安心して暫らく官途に韜晦し、文壇からは全く縁を絶って読書に没頭する事が出来た。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　官報局及び雌伏時代露語の両川・高橋時代の官報局・精神心理の研究・罪悪心理と下層研究・最初の家庭生活の失敗・『片恋』・官報局を去る　二葉亭の仕官を説く前に先ずその恩師古川常一郎を語らねばならない。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、富貴顕栄を見る土芥に等しく、旧外国語学校廃止後は官報局の一属僚を甘んじて世の栄達を冷笑していた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の官報局は頗る異彩があった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "揃いも揃って気骨稜々たる不遇の高材逸足の集合であって、大隈侯等の維新の当時の築地の梁山泊知らず、吏臭紛々たる明治の官界史にあっては恐らく当時の官報局ぐらい自由の空気の横流していたはけだし類を絶しているだろう。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "高橋健三は官報局の局長室に坐している時でも従五位勲何等の局長閣下でなくて一個の処士｜自恃庵主人であった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "官報局に出仕する間もなく二葉亭は家庭を作って両親と別居した。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は重く感じた責任をも感じなくなって、「自分は文人でない」と文学とは絶縁した意でいたから、ツルゲーネフを訳したのも唯の一時の融通のための拠ろないドラッジェリーで、官報局で外字新聞を翻訳した時と同じ心持であった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "折からあたかも官報局長は更任して、卓落｜不覊なる処士高橋自恃庵は去って、晨亭門下の叔孫通たる奥田義人が代ってその椅子に坐した。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "二葉亭は本来｜狷介不覊なる性質として迎合屈従を一要件とする俗吏を甘んじていられないのが当然であって、八年の長い間を官報局吏として辛抱していたのは、上に自由なる高橋健三を戴いて、恩師古川の下に吏務に服していたからであった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "二葉亭の一生中、その位置に満足して※々として職務を楽んでいたは官報局の雌伏時代のみであった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　放浪時代から語学校教授原稿生活・実業熱・海軍編修・語学校教授　官報局を罷めてから暫らく放浪していた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "二葉亭が官報局を罷めた直接の原因は局長の更任に続いて恩師古川の理由なき罷免に対する不満であったが、それ以外に何時かは俗吏の圏内を脱して自由の天地に※翔しようとする予ての志望が幇助っていた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "官報局に在職中、哲学や精神生理に頻りに興味を持って研究していたが、東亜の国際関係や産業等の調査はこれがために少しも怠たらないで継続していたので、一度は東亜の舞台に躍り出して一と芝居打とうとする念は片時も絶えなかった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "官報局を罷めたのは偶然であるが、退職すると同時にこの野心が俄に活火山の如く燃上って来た。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その必要からして、官報局を罷めた後の二葉亭は俄に辺幅を飾るようになった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "官報局を罷めてから間もなく、関節炎に罹って腰が立たなかった時も元気は頗る盛んで、談笑自如として少しも平生と変らなかった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
