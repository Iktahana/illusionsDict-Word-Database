        "examples": {
          "standard": [
            {
              "text": "新入社員に部署の皆を顔つなぎした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "商談がスムーズに進むよう、取引先の担当者と上司を顔つなぎした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "パーティーでは、共通の知人を介して色々な人に顔つなぎをしてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
