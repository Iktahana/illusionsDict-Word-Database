[
  {
    "uuid": "6e4b7766-32d2-5e97-b4cd-53559882795d",
    "entry": "奏でる",
    "reading": {
      "primary": "かなでる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
