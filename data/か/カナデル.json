        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "舞台上でバレリーナが軽やかに舞い、見る者を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祭りの広場では、民族衣装を着た人々が陽気に踊っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の動きは音楽と一体となり、まるで空間を奏でているかのようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
