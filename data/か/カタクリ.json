    "definitions": [
      {
        "index": 1,
        "gloss": "dogtooth violet (Erythronium japonicum)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "春の妖精と呼ばれる片栗の花が、林の中で可憐に咲いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ハイキングコースの脇に、片栗の群生地が広がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "昔は片栗の根から採れるでんぷんを、片栗粉として利用していたそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "帰ってから用心に鰹節、梅干、缶詰、片栗粉などを近所へ買いにやる。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "片栗をいれてねばりをつけた。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "沈澱した砂は片栗粉のやうにぎつしりと堆積して雜草も生えて居なかつた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くして、「これはハミガキに楊子に、これは片栗ですか？",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車が停るたび、片栗粉のやうにギシギシした雪を踏んで、ぶらぶら歩くのですか、皆｜毛皮裏の外套を着込んで、足にはラシャ地で製つた長靴をはいてゐます。",
              "citation": {
                "source": "シベリヤの三等列車",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪は本降りになつて片栗のやうなきしきしした雪が積つてゆく。",
              "citation": {
                "source": "雪の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうの葛、片栗だと、美しくもあるし、水にすぐもどったりしないから、でき上がったものが美味である。",
              "citation": {
                "source": "琥珀揚げ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "九州の窮介、吉野の葛、山中の片栗というような本場ものでやると、料理も完全なものになる。",
              "citation": {
                "source": "琥珀揚げ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "京成電車踏切近くなる門構の家に汁粉一圓四十五錢との貼札出せるを見、入りて食するに片栗粉を團子のやうになし汁は薄甘き葛湯なり。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "午近く米飯の代りに片栗粉の汁粉啜りて飢を凌がむと、それを賣る家まで至り見しに、二月中當分休の札を出したり。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウルネ　ウルネカヅラといふ野生植物の根だといふことで、昔の飢饉年には是から片栗粉を取つて食べたといふ話が、紀州の上山路などにはある。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カヅラといふ以上は本物の片栗で無いことは明かである。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウルネ　ウルネカズラという野生植物の根だということで、昔の飢饉年にはこれから片栗粉を取って食べたという話が、紀州の上山路などにはある。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カズラという以上は本物の片栗でないことは明らかである。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜂蜜、躑躅花、青豆、片栗粉などを調味したものであったが、不思議に活きた味と高い香りがあった。",
              "citation": {
                "source": "全羅紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたくりの花は、その足もとで、たびたびゆらゆら燃えましたし、空はぐらぐらゆれました。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたくりの花はゆらゆらと燃え、その葉の上には、いろいろな黒いもようが、次から次と、出てきては消え、でてきては消えしています。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかで小鳥もチッチッと啼き、かれ草のところどころにやさしく咲いたむらさきいろのかたくりの花もゆれました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その窪地はふくふくした苔に覆われ、所々やさしいかたくりの花が咲いていました。",
              "citation": {
                "source": "若い木霊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この前ね、僕、こゝからかたくりの花を投げてあげたんだよ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この前ね、僕、ここからかたくりの花を投げてあげたんだよ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかで小鳥もチツチツと啼き、かれ草のところどころにやさしく咲いたむらさきいろのかたくりの花もゆれました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっ赤なアネモネの花の従兄、きみかげそうやかたくりの花のともだち、このうずのしゅげの花をきらいなものはありません。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、末男も、おなじやうに、『俺だつて、誰れにも逢はふとは思はない、只あの石狩原野だの、高原の落日、白樺の林なにを考へてもいゝなあ――それに五｜月頃になるとあの白樺の根に、紫色の小さいかたくりの花が咲くなんていふことを考へると、全くたまらない。",
              "citation": {
                "source": "追憶",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "階下でかたくりのねったのをよばれる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰯雲がかたくりのように筋を引いてゆくと、牛の群も何時か去ってゆき、起重機も腕を降ろしてしまった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰯雲が、かたくりのように筋を引くと、牛の群も去り起重機も腕を降ろして夕べの月仄かな海の上に、もう二ツ三ツおしょうろ船が流れていた。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年の四月にはいつて、「かたくりが芽を出しました。",
              "citation": {
                "source": "かたくり",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "景子来なばかたくり掘りにゆくべしと空しく待ちてすごせし日ありき",
              "citation": {
                "source": "かたくり",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "カッコウの鳴きかわす声が聞える森には、いつの間にかかたくりの花がちらほらする。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
