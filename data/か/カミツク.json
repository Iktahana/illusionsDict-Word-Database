    "definitions": [
      {
        "index": 1,
        "gloss": "to bite (at)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "宅配便の配達員が、門の陰から飛び出してきた飼い犬に足を噛み付かれたらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わっ、このトカゲ、指を出すとすぐ噛み付こうとするから気をつけろよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "蛇が獲物を捕らえる瞬間、目にも留まらぬ速さで喉元に噛み付いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幼稚園から帰った息子が、「友達に噛み付いちゃった」と泣きながら報告してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いきなり頭の方へ噛み付くと皮が破れて緑色の汁が玉のように吹き出した。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お道はぞつとして思はず衾の袖に獅噛み付くと、おそろしい夢は醒めた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（その声を聞くや、太吉は又ふるえ上って、父の背中に獅噛み付く。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おつやが「このお客様」と云った時、太吉はまた悸えておつやに獅噛み付く。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬が尾を踏まれて噛み付く時のやうな調子だつた。",
              "citation": {
                "source": "我が最近の興味",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり噛み付くでごぜえましょう」と言って、お秀と一緒に乳首を覗きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉と二人の女中とが当然その責任者であるので、かれらは徳兵衛から噛み付くように叱られた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "少年少女の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "噛み付く……町の辻で出会った犬猫の心理と全然同一である。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は噛み付くようにどなった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お関は真青な顔をして下を向いて黙って居たが、いきなり頭を上げると噛み付く様に鋭い声で、「お前、人を強請る気だね。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「俺には名なんかないのだ」　今にも対手を噛み付くような恐ろしい顔をしていながら柳沢はしきりに軽口を利いて女どもの対手になっていた。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の停留する四辻では噛み付くやうな声で新聞の売子が、「紳士富豪の秘密を暴きました………。",
              "citation": {
                "source": "海洋の旅",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "訳の解らねえ奴が大将になり、さて一旦大将になると、遮二｜無二そいつに獅噛み付く。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏み返したとたんに赤犬が噛み付きさうに吠える仕掛は念入り過ぎやしませんか、親分」　ガラツ八の八五郎は危ふく格子戸につかまつて、件の噛み付くやうな赤犬を追ひ乍ら、四方構はぬ聲をあげるのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "娘と二千兩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「狐が噛み付くとでも思ふのかい」「狐は心配ないが、また崩れたら何うするんです」「一度崩れたんだもの、もう大丈夫さ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "十萬兩の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八、少し起して見てくれ――お前は足の方を持つんだ――あツ噛み付くぜこの佛樣は」　平次は死骸の頭を抱へて、床の上に眞つ直ぐに起し乍ら、そんな事を言ふのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "二人濱路",
                "note": "青空文庫"
              }
            },
            {
              "text": "――尤もこの野郎は醉が廻ると噛み付くかも知れないよ」　平次は後から登つて來るガラツ八の鼻のあたりを指すのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この足ですよ、親分」　ガラッ八の噛み付くような声と、春松の呟くような声が、悩ましい対照で、同じことを際限もなく繰り返しております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鐘五郎の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "あきらめ兼ねた八五郎は、それでも追っ手をゆるめず、品川へ入って、歩行新宿から南本宿まで飛びましたが、見覚えの駕籠は影も形もなく、犇々と身に迫るのは、噛み付くような空腹感です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "駕籠の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "コラ」　噛み付くように押し戻す警官へ、「その方は、この事務所の御主人です。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第四夜　恋の不在証明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八、少し起してみてくれ、――お前は足の方を持つんだ、――あッ噛み付くぜこの仏様は」　平次は死骸の頭を抱えて、床の上に真っ直ぐに起しながら、そんな事を言うのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二人浜路",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それはこの玄々斎の観相がよく当るからだ、何の不思議もない」　八五郎の噛み付くような声に応じて、落着き払った玄々斎の声、少し高慢な、そのくせ媚びるような調子で聞えます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死相の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もっともこの野郎は酔が廻ると噛み付くかも知れないよ」　平次は後から登って来るガラッ八の鼻のあたりを指さすのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "「狐が噛み付くとでも思うのかい」「狐は心配ないが、また崩れたらどうするんです」「いちど崩れたんだもの、もう大丈夫さ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "十万両の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "老女が断末魔の苦しみに悶えている間、何かが踵に噛み付くのを感じ、それは老女を助けに来たブラウン・ジェンキンだったのだ。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "「少し噛み付くのですが、暴れまはりはしませんので。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "徒一　（噛み付くように）言うかっ女！",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛りの付いた狂犬見たいなもので、何處へ噛み付くか――」「餘計なことを言ふな」　平次は八五郎を叱り飛ばしながらも、手早く支度に取りかゝりました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "一番札",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、朝野はわが意を得たりといった顔で、「浅草の空気は僕らにはいかんです」　僕らというのに特に力を入れて、断乎として、何か噛み付くみたいに言った。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、かみつく、引っかく、振り飛ばすというのである。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to snap at (someone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
