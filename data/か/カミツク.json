        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の挨拶が少し冷たかったからといって、そんなにムキになって噛み付かなくてもいいじゃないか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "会議中、新しいプロジェクトの案が出るたびに反対派の彼が噛み付いてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「最近の君は、ちょっとした冗談にもすぐ噛み付くから、正直話しにくいよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は正義感が強すぎるあまり、不正を見つけると相手が誰であれ真っ向から噛み付く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
