[
  {
    "uuid": "0e16fa3f-5720-585b-bcc1-1005bbf45555",
    "entry": "書き直す",
    "reading": {
      "primary": "かきなおす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
