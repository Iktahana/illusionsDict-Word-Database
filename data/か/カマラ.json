        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "カマラの赤い実は、古くから染料や薬として利用されてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "植物図鑑でカマラの項を調べると、その生態や利用法が詳しく書かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "熱帯地域に自生するカマラは、その独特の見た目から観賞用としても人気がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "カマラの駅には汽車と乗客を見物する土民が異様な服装で群れさわいでいた。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "カマラの村へ着くまで人家は一軒もない。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "カマラでは、私たちの船へ乗り込む青年を見送って、祖母らしい人が桟橋に凭れて泣いていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "カマラからサヴォリナ。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、筋肉労働者と握手して、君等こそ、われらのカマラアドと誓ひを立てながら、組合で劇場を立てるために、一度砂をかけたブル劇作家協会に寄附を申込んだ。",
              "citation": {
                "source": "劇場と作者",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで紅海へ入って北方カマラン諸島まで行き、八月にインドへ帰った。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもなかに「ヨロクはナミントカンでしまって（儲けはみんな使ってしまって）ヒンはヤリもカマラン（銭は一文もない）」などとぼやいているのもいた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
