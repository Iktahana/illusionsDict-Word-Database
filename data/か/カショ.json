[
  {
    "uuid": "e7592ce1-5444-54e5-b30b-db57ce0f2aec",
    "entry": "家書",
    "reading": {
      "primary": "かしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
