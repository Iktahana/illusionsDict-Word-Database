        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "letter from home",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "故郷を離れて数年、久しぶりに家書を受け取って涙が溢れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "戦地から故郷の家族へ、無事を伝える家書をしたためた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学生時代、下宿生活で一番の楽しみは週末に届く家書だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "近藤の家書は、以下続いてゐる。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "召集は、モスクワの国際革命作家書記局から、世界のプロレタリア作家、革命的作家に向って発せられた。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国際革命作家書記局からベラ・イレシュが喋った。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "匆々野枝蒲原房枝様［『明治大正女流名家書簡選集』、『婦人倶楽部』第七巻第一〇号〔一九二六年一〇月号〕附録］",
              "citation": {
                "source": "書簡　蒲原房枝宛",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし二家書庫の蔵する所は、互に出だし借すことを吝まなかったらしい。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "多紀※庭は「爾後転輾附益非一、而旧経之文、竟併合于諸家書中、無復専本之能伝于後矣」と云つてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "九十七｜頁の半紙本で、首に「森氏」、「伊沢家書」の二印がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "家書及飯田書状来る。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私家書目の勃興――遂初堂書目・郡齋讀書志・直齋書録解題　今一つの新現象は、個人の藏書目録の盛になつたことである。",
              "citation": {
                "source": "支那目録學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "明季清初の藏書家書目　明末から清初の間には隨分藏書家が多數あり、その目録も大分殘つてゐる。",
              "citation": {
                "source": "支那目録學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "「独逸日記」というのに、「家書｜到る」ということが、月に二、三回はきっと見えます。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月七日の「独逸日記」には、「朝家書至る。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉の上に題したる詩に、只知君報国満腔気、泣対神州一片秋の句ありき」としてあり、十八年九月十三日の条にも、「朝家書又至る。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）老来擲却百家書、意気揚揚鵬不如、樺海台山猶覚狭、垂天翼向遠洋舒。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨過秋宵露気寒、家書不到思漫漫、知吾独有故山月、飽見北天光一団。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "日夜船窓望布哇、水天連処浪無涯、家書未到年将暮、好託東風伝客懐。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等は再び今十六日深夜二時貴家書斎に現わるべし、しかして西側の壁に朱色の証拠を残すべし、もしこの事を警察に告ぐる時は一家残らず惨殺すべきもの也。",
              "citation": {
                "source": "黒襟飾組の魔手",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等は今十八日深夜二時、貴家書斎にて黄色金剛石頸飾を受取らんとす。",
              "citation": {
                "source": "黒襟飾組の魔手",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "起訴内容は国家書類所持による外国スパイという自供です。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘府の御書さえ借覧をねがい出るほどであるから、公卿の諸家はいうまでもなく、どんな貴顕の家書でも、大名の蔵書でも、（どこには何がある）　と知れば、労と日子をいとわずに求めた。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家書には、兵学の書も多かった。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえさんに謙遜するいわれはない」「ですが、大江匡房の家書家統を継いで、六韜の奥義を究められたとか。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が若い時の、罪障が報ったっぺ、可いわ、娘の支度と婿殿へ引出ものをかねて、一番、宝船を漕いでまかしょ、お正月だ、祝えッて、大酒をのんだんです。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨に濡れて、何かしょんぼりした後ろ姿。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "水はなんだかしょっぱいへんな味がしました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、このおかあさまは、ひばりのことを「下等な野そだちの鳥」とよんで、そんなものをうちのなかへ入れることをなかなかしょうちしてくれません。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "――組合に帰ってから、伴さんや阿部さんは何処かしょげこんでしまった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞光は、その時あざ笑いながら、「おい、ただ行ったって、何かしょうこがなければわからないぞ。",
              "citation": {
                "source": "羅生門",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある座敷では洋服の男が六、七名、芸妓とともに円陣を作ってやっちょろまかせのよやまかしょというものを踊っていた。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "――僕はどういう素性の女かよく知らないが、夏なんぞその女が奇妙ななりをして、買物袋をぶらさげながらなんだかしょぼしょぼして歩いているのを見かけては、何者だろうとおもっていたんだがね。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
