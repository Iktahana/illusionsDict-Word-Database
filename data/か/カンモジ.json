        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この報告書は、閑文字が多くて要点が掴みにくい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "作家は、無駄な閑文字を削ぎ落とし、文章を磨き上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議の議事録には、時折、発言の繋ぎとなる閑文字が見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「室町も末になって、乱世の間に連歌なんという閑文字が弄ばれたということも面白いことですが、これが東国の武士の間に流行ったのは妙ですよ。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説や風聞録のようないわゆる閑文字について言われる事は、実は大多数の読者にとって、他の大部分のいわゆる重要記事についても言われるのである。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの読者が社会記事や政治欄を読む心持ちが小説その他の閑文字を読む心持ちと根本的にどれだけ違うかという事はよくよく考えてみるとかえって容易にわからなくなって来る。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方では俳諧を無用の閑文字と考える風がますます盛んである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでにいいかげん閑文字を羅列したことを恥じる。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此點からいふと單に美的な文字は昔の學者が冷評した如く閑文字に歸着する。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句趣味は此閑文字の中に逍遙して喜んで居る。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから芸術に於ては閑文字だからと言つて捨て去ることは出来ない。",
              "citation": {
                "source": "不思議な鳥",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその契約書の内容というものが、決して一片の形式的な閑文字ではなくて、どんなに密接な関係において彼らの生活に直接結びついているものであるかということを、彼らはその後機会あるごとに思い知らなければならなかったのである。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "急ぐ用事でもないが、色々話しがあるから、此手紙が着いたら来てくれろと書いて、あとには京都の花がまだ早かつたの、急行列車が一杯で窮屈だつた抔といふ閑文字が数行列ねてある。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "急ぐ用事でもないが、色々話しがあるから、この手紙が着いたら来てくれろと書いて、あとには京都の花がまだ早かったの、急行列車が一杯で窮屈だったなどという閑文字が数行｜列ねてある。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの神経衰弱と狂気とは否応なく余を駆つて創作の方面に向はしむるが故に、向後この『文学論』の如き学理的｜閑文字を弄するの余裕を与へざるに至るやも計りがたし。",
              "citation": {
                "source": "『文学論』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、詩を以て遊戲と爲し閑文字と爲し彫虫篆刻の末技と爲すは古來の漸なり、是弊敗れずんば眞詩決して起らじ。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の青年｜輩は動ともすると実用なる科学智識の研究を閑却してヤレ詩を作るの歌を詠むのあるいは俳句を案ずるのと無用な閑文字に脳漿を絞っているが、そんな事は専門家に委すべき事だ。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の人間の全部のもの、精神も肉体も魂も本能も血も毒も涙もみんなあげて花となり、ふるさとに呼びかけられた声であり、俳句などゝいふ閑人の閑文字ではない。",
              "citation": {
                "source": "蟹の泡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬杖をつき、読みさしの新聞に対ひしが、対手酒のほろ酔と、日当りの暖か過ぐると、新聞の記事の閑文字ばかりなるにて、終うと／＼睡気を催しぬ。",
              "citation": {
                "source": "元日の釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこの事がなかったなら、わたくしは今日のように、老に至るまで閑文字を弄ぶが如き遊惰の身とはならず、一家の主人ともなり親ともなって、人間並の一生涯を送ることができたのかも知れない。",
              "citation": {
                "source": "十六、七のころ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにこれら巷間の諸芸人が脱俗軽妙の芸境においては、我ら工業日本の再建を頓に忌嫌するごとき市井閑人の閑文字を俟つことなくんば、永遠にわが芸能史上からは抹殺されつくしてしまふからである。",
              "citation": {
                "source": "浅草燈籠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一年目の今日、ここ下総市川の里に卜居して残花の午下りを、嘱されて旧東京夏宵の追懐など閑文字を弄する境涯になつてゐられようとは、どうしてあのときおもひ知る由があつたらう。",
              "citation": {
                "source": "旧東京と蝙蝠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "今このような閑文字を止めておくことも、全く無意味のことでもないだろう。",
              "citation": {
                "source": "御殿の生活",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡堂の方は、大正初め、新聞の政治記者をしている頃、政閑期には政治面の「かこいもの」という閑文字を書いていたが、筆名がないので、長某と署名すると、編集局の悪童共が、「お前も雅号を拵えろ」と言うのである。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "ペンネーム由来記",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにきめておけ」と本人の私の意見などを無視して、翌る日の新聞の閑文字から、胡堂という署名が入ったわけである。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "ペンネーム由来記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
