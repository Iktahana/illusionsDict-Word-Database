        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "会社の業績が発表されると、多くの株主が株価の動きに注目する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は長年の付き合いのある企業の株主として、毎年株主総会に参加している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい経営方針について、株主からの意見が活発に交わされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "同じような立場から云うと、基礎の怪しい会社などを始めから火葬にしないでおいたためにおしまいに多数の株主に破産をさせるような事になる。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "没落は、百貨店レーン・クロフォードの株主総会で六七四株を代表するクロフォードは議長席について悲壮な報告をした。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちレーン・クロフォード半期欠損額九万五千七百六十元四六｜仙、これが填補は前年度繰越金から二万六千九三元五一仙、株主準備金から二万元、一般準備金から五万元をもってする。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにたいして株主の一人であるケャムペルは閉店を提議したが、これは大ブリテンの名誉のために採用にならなかった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき株主によって提唱された他の重大な欠損理由は不況のため高級品の販売絶無となる。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "岐阜県××町、――里見稲子、二十七、と宿帳に控えたが、あえて誌すまでもない、岐阜の病院の里見といえば、家族雇人一同神のごとくに崇拝する、かつて当家の主人が、難病を治した名医、且つ近頃三由屋が、株式で伊勢の津に設立した、銀行の株主であるから。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこに来ていたのはみんな株主でした。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが株主の反感は非常だったのです。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし達はそこの会社の株主でもあり支店でもありますんでね。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちあ、たかだか恩を売って、人情を買う奴だ、贅六店の爺番頭か、三河万歳の株主だと思うから、むてえ癪に障っても、熱湯は可哀相だと我慢をした。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "船主や株主らにとっては、黄金時代であった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "勞働的株主制ノ立法。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "私人生産業中株式組織ノ事業ハ其レニ雇傭サルル肉體的精神的勞働者ヲシテ、自ラ其ノ株主タリ得ル權利ヲ設定スベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "從テ、勞働的株主ヲ併存セシムルコトハ内容的根本的ニ常ニ該事業ヲ健確ニ支持スベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "勞働的株券ノ發言權ハ勞働爭議ヲ株主會議内ニ於テ決定シ、一切ノ社會的不安ナカラシムベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "また彼の耳にはいる父の評判は、営業者の側から言われているものなのか、株主の側から言われているものなのか、それもよくはわからなかった。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし株主の側から出た噂ならだが、営業者間の評判だとすると、父は自分の役目に対して無能力者だと裏書きされているのと同様になる。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の人々は皆なかれを信じて、その資本の株主となつた。",
              "citation": {
                "source": "田舎からの手紙",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジミィは、銀行の石段の上でぶらついていた少年を、俺は株主だぞといわんばかりの態度で捕まえ、この町のことをいくつか訊ねた。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに株主へ二割二分五厘なんて滅法界もない配当をする会社なんて、日本にだってそうないんだ。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――岸野は雑穀、海産、肥料問屋、ホテル、××工場、精米株式会社を経営し、取引所会員、拓殖銀行其他の株主、商業会議所議員、市会議員をやっている。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために、飛行島株式会社というのが出来て、南シナ海をとりまく諸国――つまり英国が主となり、仏国、米国、オランダ、暹羅、中国の諸国を表面上の株主として、莫大な建造費を出しているのだった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "連中は、わしと同じ地主だが、同時にまたわしが借りとる信託會社や地方銀行の株主でもあるんだ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "早い話がポスターにいくら株主の名前を並べたって客は一人も来はしないのだから。",
              "citation": {
                "source": "映画界手近の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの背には、多くの重役、株主、会社員がおり、しかも、彼らの代表する会社はもともと利益を唯一の目的として成立したものであつてみれば、彼らが利益を度外視して、真に虚心坦懐に事をはかるというようなことは、実際問題として期待し得べきことかどうか、はなはだ疑なきを得ない。",
              "citation": {
                "source": "思い",
                "author": "――情報局の映画新体制案について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「正木さんでも、私でも――矢張、この鉱泉の株主ということに成ってます」　と先生は流し場の水槽のところへ出て、斑白な髪を濡らしながら話した。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、あなたの旦那さんは、会社へ勤めておられるそうですが、その会社で良人の方は大株主ででもあるのでしょうか。",
              "citation": {
                "source": "「我らの誌上相談」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが満州にいる誰かに雇われて働らかされに行ったのであって、われわれの内誰一人、南満州鉄道の大株主だというものはない。",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "重り重った借金を会社は株で払うしか方法がなかったので、昨今の景気は或る組を相当な株主にしてしまった。",
              "citation": {
                "source": "くちなし",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
