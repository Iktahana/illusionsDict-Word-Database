        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この界隈は古い町並みが保存されており、立派な瓦葺きの家が整然と軒を連ねている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「やっぱり日本家屋は瓦葺きに限るね」と、祖父は新築の屋根を満足そうに眺めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "瓦葺きの屋根は重厚感があるが、最近は耐震性を考慮して軽量な素材に葺き替える家も増えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "隣町のお寺の本堂が、数年がかりの修繕を終えて見事な瓦葺きに蘇った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "外神田の河岸近くの一帯は、あの大火に不思議に焼け残ったのであるが、その黒い土蔵や、昔風の瓦葺きの屋根、寂びた白壁などが並んだ落ち付いた町並みと、柳原あたりの（この辺は昔もあまり立派な町並みではなかったが）バラックを見比べると、坐ろに今昔の感に打たれざるを得ない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "家根といえば瓦葺きか板葺きである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "家には相当の財産もあって、女中や作男は置きませんでしたが、村の人に田を作らせて取る年貢米は、母子二人の生活を支えるに十分でありましたから、瓦葺きのこじんまりした家に、二人は比較的平和な日を送っていたのでありました。",
              "citation": {
                "source": "白痴の知恵",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方でよく見かける藁葺き屋根の人家が何百軒も連なっているが、それに加えて大きな通りには小綺麗な瓦葺きの二階建ての建物があって、店と宿屋が軒を並べていた。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "西の方の小山の裾に、お寺の大きな屋根を眞ん中にして、富んでゐるらしい瓦葺きの家や藁葺きの家や白壁の光る土藏なぞが、ごちや／＼と一塊りになつてゐるのは、××の部落で、其處の男女が三人五人、剥いだ獸皮の眞白に見えるのを、この川原に持ち出して、清らかな水に晒してゐた。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りすがりに蒼い瓦葺きの文化住宅の貸家があったので這入ってみる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼い瓦葺きの文化住宅の貸家があった。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝夕のたつきも知らざりし山中も、年々の避暑の客に思わぬ煙を増して、瓦葺きの家も木の葉越しにところどころ見ゆ。",
              "citation": {
                "source": "書記官",
                "author": "川上眉山",
                "note": "青空文庫"
              }
            },
            {
              "text": "此式は国頭地方に多いが、外の地方は、大抵屋根は瓦葺き、柱は厚さの薄い物に、緯を沢山貫いて、柱間一つだけを入り口として開けてゐる。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめはトタン葺きのバラックでしたが、後には瓦葺きの建物となりました。",
              "citation": {
                "source": "崖下の池",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後、真作が他に住居を得て移転してから、小屋は取り壊され、ささやかながらも瓦葺きの住宅が建てられて、恒吉が姪の辰子と共に住みました。",
              "citation": {
                "source": "崖下の池",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その農家の中で一軒だけ瓦葺きの、構へも他の家より稍大きな家があつて、これが此の物語の主人公である房一の生家、高間家であつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦葺きの大きな門はしまつてゐたが、丁度その時くぐりがカタリとあいて、一人の老神父が出て来た。",
              "citation": {
                "source": "ハビアン説法",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "左に曲ると大きな森があつて、その内に小さい格子付の瓦葺きの家がある。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方によっては普通の農民に、瓦葺きや破風作り等の家を許さず、たまたま領主に対して功労のあったものにのみ、特典としてこれを認めた。",
              "citation": {
                "source": "家の話",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦葺きの、三十坪ちかくありそうな平屋の建物で、屋根を掛けた井戸が脇にあり、四五人の女たちが菜を洗っていた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "狂女の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦葺きの屋根の変種に就ては、この日記ですでに述べるところがあった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会の家はたいてい瓦葺きだが、板はトランプの札みたいに薄く、藁葺屋根は火薬のように火を引きやすい。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺院のみならず、宮殿でも、庶民の住宅でも、外から見て最も眼立つものは、或る場合には瓦葺き、或る場合には茅葺きの大きな屋根と、その庇の下にたゞよう濃い闇である。",
              "citation": {
                "source": "陰翳礼讃",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "桑が丈高く伸びているので、遠くから望むと、旧家らしい茅葺きの台棟と瓦葺きの庇だけが、桑の葉の上に、海中の島のごとく浮いて見えるのがいかにも床しい。",
              "citation": {
                "source": "吉野葛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家屋の構造に、それまで制約されていた条件（たとえば、大名武家以外は、瓦葺きの屋根はできなかったなどの――）を撤廃し、自由に、防火本位の家を、たれでも建てられるように、市政を改めた。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦葺きが普及すれば瓦の間に、萱葺が厚くなればこれに穴をあけて住み、人がいなかった昔はどうしていたろうかを、もう考えて見ることも出来ぬようになっている。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つは板葺き一派の三角のゆるい扁たいもので、ささ板やこけら板で葺いたのから、檜はだ、杉皮の屋根まであり、現在さかんに建っている瓦葺きもその中にふくめてよい。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺を瓦葺きといった言葉が伊勢神宮にもあって、宮殿や神のお社でさえも、さいしょは瓦をつかってはいなかった。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう中でも、土蔵造りという瓦葺きなどは新らしいもので、大きな商人の多量の財貨をかかえた者でないと、必要もなく、また持ちこたえることができない。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸は年々歳々の御触出しあるがゆえに、通り筋と間筋は大方瓦葺きとなったが、はしばしにはたたき屋根が多い。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、中くらいの場所は表側だけ瓦葺きで、いわゆる半瓦の家はめずらしくなく、まして場末には瓦一枚もつかわぬ家ばかりであったが、わずか四、五年をへだてて二度目に下って見ると、もう瓦葺きがよほど多くなっていたから、のちには京大阪の市中と同様になるであろうともいっている。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれから瓦葺きが急激に増加してきたけれども、なお明治のなかば過ぎまでは、二千三千というような大きな延焼が、毎年のようにつづいていた。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
