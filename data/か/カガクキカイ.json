        "examples": {
          "standard": [
            {
              "text": "この工場では、最新の化学機械を導入し、生産効率を大幅に向上させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "化学機械のメンテナンスは専門知識が必要なので、定期的にメーカーの担当者が点検に来る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しい合成プロセスを試すため、特殊な化学機械を設計・製造する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "顕微鏡や気圧計などいろいろの理化学機械のはいった戸棚が、しずかに横にすべりつつ、壁の中にはいっていくのでした。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "錠をおろしてあるのではないが、どうしてもあかないので、結局その隙間へ鑿の刃を挿し込んで、ようようにこじあけると、抽斗のなかには、はなはだ簡単な化学機械が順序正しくならんでいた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "貸家",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
