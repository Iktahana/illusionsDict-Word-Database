        "examples": {
          "standard": [
            {
              "text": "鹿児島大学の農学部附属農場では、広大な敷地を活かして南国特有の農作物の研究が盛んに行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わあ、鹿児島大学のキャンパスの中まで桜島の灰が積もってる！これぞ鹿児島の日常だね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鹿児島大学医学部は、離島医療の最前線を支える医師を育成する重要な拠点としての役割を担っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "郡元キャンパスを歩いていると、鹿児島大学のロゴが入ったパーカーを着た学生たちとすれ違った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一九五五（昭和三十）年、稲盛和夫は鹿児島大学工学部応用化学科を卒業し、高圧電線用の碍子メーカーである京都の松風工業に入社した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等小学校時代に結核を患った稲盛は、この経験もあって大阪大学の医学部薬学科を志望したが果たせず、家族の強い勧めで二期校の鹿児島大学に進んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
