        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "かつて、早稲田大学の学生といえば、角帽に高下駄、そして腰に手ぬぐいというスタイルが定番だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「へぇー、昔の日本の大学生はこんな四角い帽子を日常的に被って街を歩いていたんだね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父の古いアルバムを開くと、角帽を斜めに被って仲間と肩を組む若かりし日の姿があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
