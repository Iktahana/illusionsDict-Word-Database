      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "exotic non-Japanese wood (rosewood, ebony, blackwood, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この仏壇は最高級の唐木である紫檀で作られており、非常に重厚感がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "唐木の細工物は使い込むほどに艶が出て、独特の風合いが増していく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "父は趣味で唐木の箸を集めており、黒檀の渋い色合いを気に入っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ちょっとした庭もあり、十二畳の本座敷なぞは唐木が使ってある床の間があって瀟洒としている。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "左の肱が直ぐ窓に掛けられる樣に、そして左からと正面からと光線の射し込む位置に重々しい唐木の机は置かれたのである。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐木机の脚、かぶと虫の兜、蟋蟀の太腿――強健なものは、多くの場合に焦茶色にくすぶっている。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしやと思つて土蔵を覗いてみると、女房が一番大事の唐木箪笥をすつかり引つ剥してしまつてゐたさうだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐木造りの綺麗な茶箪笥が直ぐ手の屆く邊にあつて、煌やかな九谷とも思はるゝ茶道具が並んでゐた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "あな冷た唐木の机岩に似ぬ人の涙の雫かかれば「似ぬ」はこの作者が好んで用ひる語尾の変化で、私なら決して用ひないものだ。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの伊賀越の芝居でも、唐木政右衛門が岡崎の宿に着く際、この抜道を通ったということに作ってある。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその廊下から湯殿へ行く処の二枚の襖は、唐木の透かしになって、大きな金の桐の紋が付いていた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "また林露竹氏等の千代田吟社からは唐木の書棚を贈られるし、その他の人々からも祝賀の記念物を数々貰ったのは私の名誉とする所である。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の他道了さまのお丸薬に帝釈さまのお水が有りまする、此方の唐木の違棚には、一切煎茶の器械が乗って居りまして、人が来ると茶盆が出る、古染附の茶碗｜古薩摩の急須に銀瓶が出る、二ツ組の菓子器には蒸菓子と干菓子が這入ってありますという、万事手当が届いて居りまする。",
              "citation": {
                "source": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "author": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐木の机に唐刻の法帖を乗せて、厚い坐布団の上に、信濃の国に立つ煙、立つ煙と、大きな腹の中から鉢の木を謡っている。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬太郎はこうして店から店を順々に見ながら、つい天下堂の前を通り越して唐木細工の店先まで来た。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて其の夏も過ぎ秋も末になりまして、龜甲屋から柳島の別荘の新座敷の地袋に合わして、唐木の書棚を拵えてくれとの注文がありました。",
              "citation": {
                "source": "名人長二",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐木政右衛門が二刀を揮って目ざましく働く。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女と子供、しかも、母子二人でなければならぬとナ、ハアテ……」　この護摩堂の天井は唐木の合天井になっておりまして、そこに親獅子仔獅子の絵がかいてあった――今はないけれども――その母獅子のほうは、狩野秀信の作。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "何気なく座布団の上へ坐ると、唐木の机の上に例の写生帖が、鉛筆を挟んだまま、大事そうにあけてある。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが、唐木の机に憑りてぽかんとした心裡の状態は正にこれである。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "兼てからわが座敷の如何にも殺風景なのを苦に病んでいた彼は、すぐ団子坂にある唐木の指物師の所へ行って、紫檀の懸額を一枚作らせた。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに我々は唐木政右衛門を主人公とする岡崎の段を取ってみる。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして政右衛門は、昔の幸兵衛の弟子庄太郎として、河合股五郎の敵のうちの最も恐るべき唐木政右衛門に、すなわち自分自身に、対抗すべく懇願されるのである。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鳥が陳東海に殺されたことはもう早文で届いている筈だが、又もや出尻伝兵衛に引張り出されてこの事件に立合った関係上、義兄の唐木屋利七にお鳥の無残な最期の様子を物語らなければならないことが情けない。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "長崎ものがたり",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは頭を三つばかりも叩かれました」「いやはや、どうも」　道行の皺を引伸ばしながら土間へ入り、長崎の唐木屋利七が泊っている筈というと、女中は怪訝な顔して内所へ入って行ったが、間もなく主人の喜藤次が出て来た。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "長崎ものがたり",
                "note": "青空文庫"
              }
            },
            {
              "text": "……へえ、唐木屋さんは如何にもわたくしどもへ泊っておいででござりますが、先月の十五日に庭窪の蘇州庵たらいうところへ行くといやはりましてお出掛けになッた切り、かれこれもう四十日近くにもなるのだすが、今以てお帰りなさりまへんので、わたくしどもでもご案じ申上げておるのでござります。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "長崎ものがたり",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとすると……」　わけの判らぬことを独でグズグズ言っていたが、主人の方に膝を向け変え、「唐木屋が出て行くとき何か変ったことでもありませんでしたかな」　主人は、嚥みこめぬ顔で、「へえ、格別、変ったこともござりませなんだが。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "長崎ものがたり",
                "note": "青空文庫"
              }
            },
            {
              "text": "……朝の四ツごろ使屋が封じ文を持って来まして、唐木屋はんはそれを読むと、急にこう厳つウい顔付にならはりまして、間もなくそそくさとお出かけになられましたが……」　源内先生は、セカセカと立ち上って、「ご亭主、わしはな、急な用事でちょっと出かけて来るから、わしの荷物とこの供を預って貰います。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "長崎ものがたり",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それはそれとしても、唐木屋利七は、一体、何のためにこんなところに用があッたンだろう。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "長崎ものがたり",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それからまた二年おいた一昨年の秋、ひょッくりやって参りまして、そン節の詫言をさまざまにいたし、お種さんの婿殿が唐木の商売をしておるというのであッたら、寧波の自分の山に仰山唐木があるによって、欲しいだけ元価で積出させまッしょう、と申します。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "長崎ものがたり",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅紗やギヤマンや更紗や唐木細工が一パイだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "父の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "和蘭風と言ふか、平次には見當もつきませんが、疊の上に異樣な模樣を織り出した絨毯を敷いて、唐木の机、ギヤマンの鏡、金銀の珠玉に細工をした手廻りの小道具まで一介の町方御用聞の平次に取つては、生れて初めて見る品ばかりです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "佛像の膝",
                "note": "青空文庫"
              }
            },
            {
              "text": "うら枯やからきめ見つる漆の樹　木枯しの朝、枝葉を残らず吹き落された漆の木が、蕭条として自然の中で、ただ独り、骨のように立っているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
