        "examples": {
          "standard": [
            {
              "text": "フライドチキンは完璧に調理され、カリッとジューシーだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、外側がカリッと焼かれたトーストをかじるのが大好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ポテトチップスはとても新鮮で、一口食べるたびに満足のいくカリッという音がした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "船のあらゆる部分が急にカリッ、カリッと鳴り出すと、水に濡れていた甲板や手すりに、氷が張ってしまった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」こう云いながら、カリッと音を立てゝ林檎を噛った。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅干のタネを、おく歯でカリッと噛み割ると、私たちの子供のころ“天神サマ”とよく言った白いタネの中の種肉が出る。",
              "citation": {
                "source": "押入れ随筆",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空をあおげば団々のちぎれ雲が、南へ南へとおそろしいはやさで飛び、たちまち、灰色の湖水がピカリッ、ピカリッと走ってまわる稲妻のかげ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピカリッと手槍の紫電、小屋の前をはすかいに流れたかと思うと――「怪しい奴ッ！",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
