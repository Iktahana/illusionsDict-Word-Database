        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの二人の間には、深くて長い掛け構いがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔からの掛け構いを大切にするのが彼の流儀だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地域の人々との掛け構いが、この店の信用を築いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
