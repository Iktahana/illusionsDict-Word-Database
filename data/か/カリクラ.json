        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "村の祭りの目玉は、腕自慢の男たちが参加する狩競だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "優勝者には、今年の狩競で捕獲された最大の猪が贈られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "伝説の狩人は、かつての狩競で数々の獲物を仕留めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
