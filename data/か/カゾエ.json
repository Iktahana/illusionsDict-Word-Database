[
  {
    "uuid": "a40fa578-a8ec-54f2-a790-043172c2cba8",
    "entry": "数え",
    "reading": {
      "primary": "かぞえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
