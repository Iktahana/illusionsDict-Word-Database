        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このゲーム、昔の作品なのにカラーグラフィックスがとても綺麗で驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいPCは、カラーグラフィックスの処理速度が格段に上がったようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医療分野では、カラーグラフィックスで病巣を可視化する技術が進んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プレゼンテーションでは、視覚に訴えるカラーグラフィックスが効果的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "画面上に描かれたものは単なる色つきの円でしかなかったが、初めてカラーグラフィックスを体験したクラブのメンバーにとっては、たとえようもないほど美しい魔法に他ならなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "６５０２を抱えてカラーグラフィックスに酔ったウォズニアックの感動は、すぐに彼の内に確信を生み出していった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "スフィア社のミニコンピューターが、ホームブルー・コンピューター・クラブの会合で演じて見せたカラーグラフィックスの魔法は、何人かのメンバーの心をとらえたまま放さなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタンフォード大学の電気工学部で教えていたハリー・ガーランドとロジャー・メレンの二人もまた、この会合でカラーグラフィックスに魅せられていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ウォズニアックも、自分の６５０２マシンにカラーグラフィックスの機能を持たせることを、次の目標に据えていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "高解像度のカラーグラフィックス機能を備えたアップル※用には、ベーシックを使ってゲームをはじめとするたくさんの視覚的なソフトウエアが書かれていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＭＣ―70に関しても、直線的なイメージを生かしてすっきりとコンパクトにまとめた筺体のデザインが固められたあとで、松本は限られたスペースに高解像度のカラーグラフィックスを表示する基板を押し込むことを求められた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当初からＭＳ―ＤＯＳマシンとして設計されたＰＣ―１００は、ＧＷベーシックをもとにしてマウスや高解像度のカラーグラフィックスへの対応、漢字入力などの機能拡張を行ったＮ１００―ＢＡＳＩＣも、ＭＳ―ＤＯＳ上でフロッピーディスクから読み込んでくる形をとっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
