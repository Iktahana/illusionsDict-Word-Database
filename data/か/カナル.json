        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ベネチアでは、ゴンドラに乗ってカナルを巡るのが定番の観光だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "パナマ運河（カナル）は、大西洋と太平洋を結ぶ重要な水路だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この地域では、灌漑用水を運ぶために小さなカナルが張り巡らされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「見て、あのカナル沿いのカフェ、すごく雰囲気が良さそうだね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "老人株ではカナル線の発見者ゴールトシュタインや、ワールブルヒなどがおり、若手ではゲールケ、プリングスハイム、ポールなどもいた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "動くとも見えない水をたたえたカナルをへだてて、向う側の人家が見える。",
              "citation": {
                "source": "普請中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「新吉ヨ、晴レヤカナルカ、僕ハ今度クルブラ島ヲ去ツテ、バージニヤ州ナル、ノーホーク海軍鎮守府詰メニ出世シタ。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガダルカナルの時でも　飛行機は足りない、兵糧は足りない、兵隊は足りない。",
              "citation": {
                "source": "東大での話の原稿",
                "author": "一九五〇・十二月八日",
                "note": "青空文庫"
              }
            },
            {
              "text": "狗奴國に就きては、『外交繹史』に菅氏云、大隅ヨリ南ニハ、種子屋久ナドイフサヽヤカナル島々ハアレド、共ニ攻撃スル程ノ國無ケレバ、此狗奴國ハ、モト下ノ「女王國東、渡海千餘里、復有國、皆倭種」トアル地ノ内ナルヲ、陳壽ガ、東ヲ南ト誤リタルナラン。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "那珂氏は之に説明を與へて此ノ風俗ハ、イカナル原因ヨリ生ジタルカハ知ルベカラザレドモ、卑彌呼壹與等ガ、國人ニ畏服セラレタルハ、其ノ英略アルガ爲ノミニハアラデ、此ノ風俗アリシニモ由レルナルベシ。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "有力者中好古ノ名有テ其ノ実無キ輩ハ、徒ラニ古クモ有ラヌ玉瓶瑶盃ニ千金ヲ費ヤシ、反故紙ニモ劣ル偽其昌贋徴明ナドニ流涎シテ、其嚢ヲ倒ニスルハ愚カナルコトニコソ。",
              "citation": {
                "source": "好古小言",
                "author": "※上漁史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガダルカナル及びアッツ島の敗戦、サイパン島における全員戦死、住民婦女子まで自決をとげた。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後戦争はガダルカナルをはじめとして、アッツ島の玉砕、サイパン島、沖縄のカンラクと我が軍はどしどしまけて来た。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此御歌イカナル御懽有テヨマセ給フトハシラネド、垂水ノ上トシモヨマセ給ヘルハ、若帝ヨリ此処ヲ封戸ニ加へ賜ハリテ悦バセ給ヘル歟。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちやうど、ガダルカナルの退却のころだつた。",
              "citation": {
                "source": "恋をしに行く（「女体」につゞく）",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぢや、兄さんは、ガダルカナルの転進を、どういふ風に思ひますか？",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "又｜澳斯太利人モ其中ニ知識ヲ得ルコト極メテ速カナル者アレドモ、結合力ト團聚力トハ無シト。",
              "citation": {
                "source": "學問ハ淵源ヲ深クスルニ在ルノ論",
                "author": "西周",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬ヘバ暖カナル結果ハ太陽ノ上ル源因ニ由リ、寒キ結果ハ雪ノ降ルニ由ルト言フガ如ク、人事ニテ言ヘバ、家屋ノ美麗ナルハ其家富ムト云フ源因ニ由リ、其國治ルトハ其政善シト云フ源因ニ由ルト云フガ如ク、萬事ニ其結果ヲ推シテ其源因ニ遡ル性アリ。",
              "citation": {
                "source": "人智論",
                "author": "西周",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私が〈危険、警戒ヲ要ス〉という信号をすると、〈イカナル危険ナリヤ、場所ハイズコナリヤ〉という返事が来ます。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "信号手",
                "note": "青空文庫"
              }
            },
            {
              "text": "」〔家縁｜易ヘ了ル一茅廬／五畝吾ニ於テ尚余リ有リ／老脚只貪ル平地ノ穏ヤカナルヲ／山ヲ下リ水ニ近ヅカント又移居ス〕の絶句がある。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「パリには種々の水源があるが、５分の４の水はカナル・ド・ルルク（Ourcq 川が起源）からであり、これはナポレオンの決定により船の運行も目的であった。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その中央にはグレイト・カナル（大運河）が通っていて、その中に下水は死肉、排出物および泥の上に放出される。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "（カナル線）理論によれば、これ等の原子の振動数はその運動によって、ちょうど動いている時計に対して導き出されるのと全く同様の方法で、影響されて見えることが期待せられます。",
              "citation": {
                "source": "相対性理論",
                "author": "アルベルト・アインスタイン",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行の先発隊はストラットン教授の外に印度のコダイカナルの太陽研究所長ロイヅ博士とストラットン教授の無電の助手バグノルド少佐との三名であった。",
              "citation": {
                "source": "英国日食班の印象",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま横浜と横須賀の警備をして居ります」〈海兵隊〉というのは、ガダルカナル以来、いろいろな意味であたしたちの関心をひいた異常な名詞だった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩兵ですか」「ノオ、水陸両用戦車隊」「ずっと戦争をして来たわけなのね」「ガダルカナルからオキナーハまで」「たいへんだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしの味覚が感じるのは、ガダルカナルで海兵隊が感じたのとおなじ味なのだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういえばガダルカナル島のアメリカの陸戦隊は、毎日夕方の五時にピタリと戦争をやめ、ラジオをかけてビールを飲んでいたということだった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "大本営が全員玉砕したと発表したアッツ島から、転進に成功したというガダルカナル島から、大勢の日本兵の俘虜がカナダ国境に近い五大湖地方のマッコイ・キャンプに収容されていることも知っている。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "久慈隊のほうは、仏印から来たというおっとりした兵隊ばかりで、将校も下士官も柄がよかったが、浜田隊はガダルカナル、ニュウブリテン、モレスビー作戦と、ひどいところばかりやってきた生残りの寄せ集めだといい、兵隊だかごろつきだかわからない、人間の情性を喪失したような異常者の集団だった。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十八年の春と言えば、大戦第三年目に入り、既にミッドウェーの敗戦、ガダルカナルの撤退によって、戦況既に我に不利に傾き、要路の人たちの焦慮がそろそろ見えて来た頃である。",
              "citation": {
                "source": "千里眼その他",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年　（微笑）……ガダルカナルですか？",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓　そうそう、そったらカナルだ。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……二番目の息子が、今言った甲州にいる慎造さんで、三番目は、よそへ養子に出て、四番目は出征中で、末の道雄さんは、こねえだ、ガダルカナルちゅう、とこで戦死しました。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
