      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to feel",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "暖かい日差しを感じて、思わずウトウトしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "満員電車での息苦しさを感じ、早く降りたいと思った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の言葉に、深い悲しみを感じ取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この香りは、故郷を思い出させる懐かしい気持ちにさせてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "だが、読み出して、「一寸御相談したい事等」の所へゆくと、私は額に重い力を感じるのであつた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にみえる杉の植木は、いといとしめつぽくは感じる。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて、ユマニテと詩と、仮りに全然無関係なものだとしても、ユマニテに感じる人にでなければ詩は生れないし又、観賞も出来ぬわけだといふことは云へる。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やもりを見て昔を思い出すと運命のたよりなさという事を今更のように感じる。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の日本人ことに都会人が西洋へ行って西洋の都市に暮していても、真に西洋を感じるということはおそらく比較的稀であろう。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただかえってこんな思わぬ不用意の瞬間に閃光のごとくそれを感じるだけであろうかと思われる。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてなんとなく空虚と倦怠を感じると同時に妙な精神の不安が頭をもたげて来る。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、何という表題の書物であったか、若い僧侶が古い壁画か何かの裸体画を見て春の目覚めを感じるという場面を非常にリアルな表現をもって話して聞かせた事があった。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は『仰臥漫録』を繙いて、あの日々の食膳の献立を読む事に飽きざる興味を感じるものである。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南アルプス紀行が一枚も書かれないで、逝かれたため、桂月氏の簡潔なる名文を、永久に見ることが出来ないのは、甲斐の不幸ばかりでなく、山岳文学のためにも寂寥を感じる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "本田家の当主は、家族の者と主治医とに守られて、陶製のもののように、何も考えることも感じることも出来なくなった頭を、氷枕と氷嚢との間に挟んでいた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺なんざあ、三十年も銅や岩ばっかり噛って来たが、それでも歯が一本も欠けねえ」「岩は、俺たちの米のおまんまだ」　と云う程、慣れ切った仕事であったのに、それでもその一瞬間は、たとい夏であっても体のどこかに、寒さに似たものを感じるのであった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の考へる通りを考へ、人の感じる通りを感じる。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの蒲鉾なりに並んだ茶の樹の丸く膨らんだ頭を手で撫でて通りたいような誘惑を感じる。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは子供の時分に何か長く欲しがつて居た新しい玩具を手に入れて始めて其れを試みようとする時、或は何かの研究に手を付けて、始めて新しい結果の曙光が朧に見え始めた時に感じるのと同じやうなものであつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "受信器のアンテナに電波が来れば急速な交番電流が起る、これを白熱灯デテクターおよび電流計あるいは電話の受話器に接続すれば、ごく微弱な電波でも感じるから遠距離の通信には都合のよいものである。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの光は写真の種板によく感じるからこれを使えば夜間でもほとんど昼間同様の写真が撮れる。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一平　僕はあの小説を読むと描き方はやわらかく感じるが、あの女は格別新しいとは思わないね。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間が色々な球を弄ぶことに興味を感じるのには、もっと深い本能的な起源があるのではないかという気がする。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "北へ行くほど人間の少なくなるのを感じる。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　あらゆる花の中でも花の固有の色が単純で遠くから見てもその一色しか見えない花と、色の複雑な隈取りがあって、少し離れて見ると何色ともはっきり分らないで色彩の揺曳とでも云ったようなものを感じる花とがある。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "異常を「感じる」ところをいくら療治してもその異常は直らない。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがうまく行っている場合には、観客は実際自分の目がそっちへ向くように感じる。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この黒い所が浜べに近づいて来ると、もうそよそよと涼しい風を感じるようになります。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後の海軟風（土佐ではマゼという）が衰えてやがて無風状態になると、気温は実際下がり始めていても人の感じる暑さは次第に増して来る。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち芸術に対する感受性は必ずしも各人に普遍的なものではないから、ヴィエイが感得しないある物をケラーが感じるという可能性は残っている。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまには複製でない本当の原本と思われる絵を見出して愉快を感じる事もあったが、ややもすればその独創的な点がもうそろそろ一種の安心したような、これでいいといったようなおさまり方に変化するのを認めて失望した。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に彼の『イディオット』の主人公の無技巧な人格の美に対して感じるような快感を津田君の画から味わい得られる。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "民衆批評家は作品の客観的価値よりはむしろ自分の眼の批評をするのであり自分の要求を自白する、だから、自分さえ構わなければ何を云っても構わないと同時に、被批評者は何を云われても別に自分の信条に衝動を感じる必要はないかもしれない。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもそれをするには、おまえさんの指がかんじるような痛みをかんじるわけではない。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to be moved (by)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その感動的な演奏に、会場全体が静まり返った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の懸命な姿を見て、胸が熱くなるのを感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "突然の優しさに、思わず涙がこぼれそうになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "to become infected with (an illness)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "季節の変わり目は体調を崩しやすいので、風邪を感じないように注意している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は最近、新型ウイルスの感染を感じたらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "混雑した場所では、病気を感じないようにマスクをする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
    ],
