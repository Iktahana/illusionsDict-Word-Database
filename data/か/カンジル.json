[
  {
    "uuid": "6ebecdbc-1c5e-5748-bd3b-b87b06ab5621",
    "entry": "感じる",
    "reading": {
      "primary": "かんじる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
