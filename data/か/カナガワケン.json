    "definitions": [
      {
        "index": 1,
        "gloss": "Kanagawa Prefecture (Kanto area)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
