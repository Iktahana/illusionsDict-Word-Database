  {
    "uuid": "0e013eeb-9c70-515a-9639-a7f1f3f83488",
    "entry": "科白劇",
    "reading": {
      "primary": "かはくげき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
