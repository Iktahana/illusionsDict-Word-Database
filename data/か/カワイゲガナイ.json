        "examples": {
          "standard": [
            {
              "text": "いくら仕事ができても、あの人の態度は可愛げがない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "無表情で愛想もない彼は、どうにも可愛げがない人物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供らしい純粋さや無邪気さが全くなく、可愛げがないと感じる人もいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "全身の毛が黒く、顔だけが白くて、きつねかさるに似て、形は、かわいげがないというよりは、なんだか気味悪い気がしたのであります。",
              "citation": {
                "source": "母犬",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
