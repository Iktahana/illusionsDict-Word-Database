[
  {
    "uuid": "b7bb12d3-f58c-5b6e-83ef-320d684ecd3c",
    "entry": "樫粉",
    "reading": {
      "primary": "かしご",
      "alternatives": [
        "かしこ",
        "カシゴ",
        "カシコ"
      ],
      "is_heteronym": false
