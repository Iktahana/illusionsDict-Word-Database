    },
    "definitions": [
      {
        "index": 1,
        "gloss": "oak flour (esp. as animal food)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔の農村では、凶作の年に山で集めたドングリをすり潰してアクを抜き、樫粉にして飢えをしのいだという記録が残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "飼育している豚の肉質を良くするため、飼料の配合を見直し、少し高価だが樫粉を混ぜてみることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "民俗資料館の隅に、かつて村人たちが樫粉を挽くのに使っていた巨大な石臼がひっそりと展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "自分はフランス語はいちばん不得手だがしかしごくゆっくり話してくれればだいたいの事だけはわかるつもりだと言ったら、それで結構だと言ってぽつぽつ話しだしたが、その話の内容は実に予想のほかのものであった。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしごくおとなしうございます。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしごく気の小さい好人物で柔和な目にはどこやら人を引く力はあった。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と申しあげただけではさぞかしご不審でござりましょうが、実のところを申しますると、それもこれもみんな女のあさましいねたみからでござりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "この期に臨んでもはやまやかしごとを言ってくれな。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……でもしかしご上人様があんなところにおられる筈はない）　この疑惑に苦しんで、わたしはしばらく途方にくれていました。",
              "citation": {
                "source": "犬神娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、しかしご内儀のお菊殿から云えば、自分一人だけの勝手の用事も、自らあろうというもので。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『けれど、せっかくの思召さるる観月のお莚に、何も奉らないのは、さぞかしご本意なく思召さるるでありましょう』　と、公卿はさびしく、つぶやいた。",
              "citation": {
                "source": "にらみ鯛",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしご主人に残された小原の牛はしきりに家を恋しがりまして、二日ばかりはほかの牛なかまと遊ぼうともしません。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "極悪人だの」「しかしご前と比べましては！",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しかしご様子を見たところ、貧しいご身分とも思われぬ。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしご存知のように食品についての違反はあとを絶たず、食品製造業が国際的な大企業になるにつれて「混ぜ物処理」は巧みになり、添加物の種類および数はむしろ増えて対処はさらに困難になった。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は研究の結果を次のような要点に纏めている、自然の世界は「できごと」の世界であり、歴史の世界は「でかしごと」の世界である。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「でかしごと」の世界というのは行の・主体の・個性の・心の・世界である。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして Geschehen の代りに「できごと」、Tat とか Tatsache の代りに「でかしごと」という「やまとことば」を使う点が、新日本主義の「日本主義」たる所以だろう。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしごく悪いやつになると二、三円しかしない物もあるです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときは歌詞も楽器の伴奏も中止されて、あとには、リズムとしてどうやらととのえられた、しかしごく自然のままに取り扱われた笑い声以外に、なんにも残らない。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは単に好きだというにすぎなかったが、しかしごく強い多少不安な好き方だった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしごく少数者のみがそれをなし得るのであって、大多数の女はただ男をひきつけんがためにのみ書いていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の方では、ねんごろにしかしごくていねいに口をきいて、真面目なことや、美しいことや、二人で聴いてる音楽のことや、それが自分にとっては何を意味するかということを、話してきかした。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや最後の手段きり残っていないことが明らかな今となっては、彼は疲れてるようであったがしかしごく冷静だった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫よりはるかに複雑でない性質の彼女は、自分の道徳上の誠意のうちに、また、自分の義務としてる多少｜頑な理知的なしかしごく高尚な意見のうちに、うずくまり込んでいた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしごく懇意だったあとに、政治上のことで離れ離れになった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしご仁慈の篤いお心より、求めるに求めがたく、お悩みのご様子にちがいないと、それがしどもの凡慮を以ても、お察しいたしておりましたので……かくは計ろうて参りました。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしごく緩慢な周期をもって意識の明瞭なときと不明瞭なときが交互にくるのを自分でも気がついてる様子だった。",
              "citation": {
                "source": "妹の死",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした發作はもうよほど以前から彼にはあったのだが、しかしごく稀にしかおこらず、一年に一度か二年に一度程度であった。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしごんえむ殿がお高の葬式をしてやった事は、真実のために記録しなければならぬだろう。",
              "citation": {
                "source": "艶妖記",
                "author": "忍術千一夜　第一話",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」「風上にもおけん」「しかしごきげんがおわるいとはたのものが困ります」「なあに、忠諫の精神が足らんのさ。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあ」「照彦様だけはとにかく、照正様も照常様もご成績がおよろしくありませんでした」「しかしご平常でもご予習ご復習をお好みにならないのですから、休暇中は……」　と有本さんが口ごもった。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はいつでもたべきれません」「大したものね」「しかしご馳走ばかりたべているといけません」「なぜ？",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
