        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この木製の立体パズルはなかなかの考え物で、解くのに丸三日もかかってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ちょっとした考え物を出そう。さて、この暗号が示す場所はどこかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古道具屋で見つけたこの知恵の輪は、大人でも思わず熱中してしまう考え物だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新聞の隅に載っている考え物コーナーを、朝食を食べながら解くのが父の日課だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
