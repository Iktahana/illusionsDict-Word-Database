    },
    "definitions": [
      {
        "index": 1,
        "gloss": "something that requires thought",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日インスタントラーメンばかり食べるのは、健康面でさすがに考え物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この土砂降りの中で試合を強行するのは、選手の安全を思えば考え物じゃないかな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "まだ幼い子供にそんな高価なブランド品を買い与えるのは、教育上考え物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼のあまりにルーズな金銭感覚は、社会人として考え物だと言わざるを得ない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「善行日」ばかりを奨励するのも考え物ではあるまいか。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の生命をあずかるという天職から、こういうことをするならば、医師はじつに尊い職業であるが、自己の生活的職業のためにこんな事をするのは考え物だと思った。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「体は大層好くなりましたが、なんだかこう控え目に、考え考え物を言うようではございませんか。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "たびたびおれがここに来るのも考え物だて」　紙幣を渡しながらこういって倉地は応接室を出た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから結婚は考え物だよ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "郊外へ退いて行かねばならないとなると、これは差し当って考え物である。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫工会の成り立ちについて",
                "note": "青空文庫"
              }
            },
            {
              "text": "留守を守る女房のお政は、お摩りからずるずるの後配、歴とした士族の娘と自分ではいうが……チト考え物。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば一つの身体をよくしよう、最も身体をよくするには、うまい物を食え、これはなるほどお芋や南瓜ばかりでは身体は丈夫にはなるまい、いいことをお話しになッた、皆様も御同感であろうと思う、ただどうして、うまい物を食ッて行こうか、という問題が事実問題でここが考え物だ。",
              "citation": {
                "source": "人格の養成",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも黍団子の半分くらいでは、鬼が島征伐の伴をするのも考え物だといい出したのである。",
              "citation": {
                "source": "桃太郎",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケンメリヒ君……皆がこの軍曹の云う通りの気持なら、ここで犬死にさせるのも考え物ですから……」　そう云った軍医大佐の片頬には、何かしら……冷笑らしいものが浮かんでいるように思ったが……しかしそれは極度に神経を緊張させていた私の錯覚か、又は仄青い光線の工合であったかも知れない。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「観音様へ願をかけるのも考え物だとな。",
              "citation": {
                "source": "運",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとサ、そんな事は考え物だよ」　にえきらない返事をしたっきり母親は前に長々とうねって居る手紙の字をあっちこっちひろって居た。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オイ、ワーニャ、お前すぐ編集次長のカメネフを電話でよびだせ」「でも首領」とワーニャは急に不安な顔をして「そいつは大きに考え物ですぜ。",
              "citation": {
                "source": "見えざる敵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやいや待て待て、考え物だ。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巾着切の上前をはねなければ三度のご膳が戴けないと、事が極まればこうして、生きてるのも考え物だ。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘定を払う前にあんまり味をほめすぎるのは考え物だ。",
              "citation": {
                "source": "決戦川中島　上杉謙信の巻",
                "author": "――越後守安吾将軍の奮戦記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼みようによっては一肌も二肌も脱ぐ女だが……どうも現在では考え物だ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつは考え物だぞ、三吉も一緒に来い、俺が行って正太によく話してやる。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ししじゅうからは、この威張っているかしの木が、いいかげんなことをいっていると知りましたので、自分もここへ巣をかけるのは考え物だと思って、他の木へと移っていきました。",
              "citation": {
                "source": "谷間のしじゅうから",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "癩病一家へ御降臨あそばしたからッて、牛肉屋の娘がにわかに気が強くなるのは考え物だな」「あなたの何が天才なのさ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その五　万引家族",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレだけが名タンテイぶって、あんまり深入りするのも考え物かも知れないなア、と一応悟るところもあった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十二　愚妖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヴィタミンＣを蒸溜水中で何分煮たら破壊した」という実験を、「ヴィタミンＣは熱によって破壊される」と言ったり、「鳩に胚芽米を喰わすと脚気にならなかった」という研究を、「胚芽米を喰えば栄養が摂れる」という風に説くのはどうも考え物である。",
              "citation": {
                "source": "兎の耳",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともそういうつまらぬことは誰も研究をしないから分らないので、ちょっと研究すれば直ぐ分るはずだという議論も出るかも知れないが、子供に「どうして雪があんなに不思議な形をしているのか」と聞かれて、何とも返答の出来ぬのもちょっと考え物である。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究なんかどうでもいいと思うほどにはならなかったが、余り忙しく働くのも考え物だと思う位にはなった。",
              "citation": {
                "source": "由布院行",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「電気にしとけば、こんな危険はないのだがね」と、栄一が言うと、父は、「電気は不経済なばかりじゃない、柱や鴨居へ穴を明けて家を台なしにするから考え物じゃ。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんならば詩人になるのも考え物だ。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが近来どこの商店でも飾り窓などに馬鹿な金をかけることが流行で、狭い間口の店まで貴重な売場面積をショウ・ウインドに占領されているようだが、あれなどは考え物だと思う。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中川君は考え物だよ」「何故？",
              "citation": {
                "source": "髪の毛",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の人間共の云うのでは信用出来ないが、合理的に理性的に物を考え物を云う博士の言葉だから世間は広く之を信用するだろう。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
