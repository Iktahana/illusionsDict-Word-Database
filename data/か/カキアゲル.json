          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "暑くなってきたから、髪を指でさっとかき上げてみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "風が吹いて前髪が邪魔だったから、軽くかき上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もう、髪が顔にかかる！」そう言って、彼女は無意識に髪をかき上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一つ一つ「帽子」を脱ぎ取って縁側へ並べたり子芋の突起を鼻に見立てて真書き筆でキューピーの顔をかき上げるものもあった。",
              "citation": {
                "source": "球根",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども葉子はもう左手の小指を器用に折り曲げて、左の鬢のほつれ毛を美しくかき上げるあの嬌態をして見せる気はなくなっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び金髪をかき上げる暇もなく、彼はブーキン夫人の有名な饒舌に捕まった。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たっぷりと水を含ませた鬢出しで前髪をかき上げると、ふっさりと前髪は額に垂れて、違った人のように私も美しくなっている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本髪はいゝな、キリヽと元結いを締めてもらうと眉毛が引きしまって、たっぷりと水を含ませた鬢出しで前髪をかき上げると、ふっさりと額に垂れて、違った人のように美しくなる。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……………………と………インキ壺の中に何か落ち込んでいるのに気がついて、ペン先で二三度突つき、その中の一個をかき上げると、ハッとしてペン軸を取り落す。",
              "citation": {
                "source": "涙のアリバイ",
                "author": "――手先表情映画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は短い髪の毛をかき上げると、小泉の方へ苦笑に似たしなをして、活発に立上った。",
              "citation": {
                "source": "立枯れ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しきりに、漆黒の髪が額に垂れ下るのを、細い手でかき上げるのが、なんとはなしに美しかった。",
              "citation": {
                "source": "赤耀館事件の真相",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　先生は気持よくさう云つて、長い頭の髪毛をグシヤ／＼とかき上げると、今度はみんなの方へ向いて、かう云ひました。",
              "citation": {
                "source": "仔猫の裁判",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして長い小説をかき上げるうちにピアノがいくらかひけるようになり声が出たらどんなにうれしかろう。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い髪が額に二三筋垂れ下るのを無雑作にかき上げる癖と、切れの長い眼を瞬く癖とを、私は見落さなかった。",
              "citation": {
                "source": "運命のままに",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "木下は長い髪の毛をかき上げるようにして、片手で頭を押えじっと画面を見入った。",
              "citation": {
                "source": "二つの途",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪をかき上げる動作に合わせて、直子は大きくのけぞった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "生意気なこと考えたので、ひとりで顔があかくなって来て、私は、濡れた手で髪をかきあげる。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（五平と寅蔵も手伝いて、おいよの死骸をかきあげる。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（六郎兵衞は先に立ち、助八と雲哲は彦三郎をのせたる駕籠をかきあげると、雲哲は又よろける。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "額に垂れた髪をかきあげるたび、その手で髪の毛をむしる癖。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "服の着方、釦のはめ方、ネクタイの結び方、片手で乱れ髪をかきあげる癖まで……そして和服の時には、襟を合せる様子から、帯を結ぶ手付まで……其他無数の細かい事柄。",
              "citation": {
                "source": "女人禁制",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕に買物籠をひっかけたエレーナは、信吉を見ると、後れ毛をかきあげるような風をして持ち前のカサカサ声で挨拶した。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなうつ向いて、サイは何ということなし散っていない後れ毛をかきあげるような動作をした。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、すこし離れている、ぼくにさえ聞えるほどの激しい動悸、粒々の汗が、小麦色に陽焼けした、豊かな頬を滴り、黒いリボンで結んだ、髪の乱れが、頸すじに、汗に濡れ、纏りついているのを、無造作にかきあげる。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、どういうものか、縮らした髪を片手でかきあげる真似をして、あの白い額の、細おもての顔を、きりっと引きしめ、眼をそらしながら、言うことがいいじゃありませんか。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子をかぶってる柿沼の顔には、何の表情も見て取られず、長谷川は眼鏡の奥で瞳をこらしたがふと、片手をあげて、無帽の長髪をかきあげる身振りをした。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　李がなにか饒舌ってる時、君枝はちょっと小首をかしげがちに、片手をかるく頬に、そして片手で鬢の毛をかきあげる素振りをして、それで李の方へ表情を隠しながら、庭に少し距ってる吉村の方へ、眼を二つ三つ大きくまたたいてみせた。",
              "citation": {
                "source": "鳶と柿と鶏",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "字をかきあげるまで一時間もかかったろう。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十二　愚妖",
                "note": "青空文庫"
              }
            },
            {
              "text": "書いてはすて、書いてはすて、博士はなんども書きなおして、やっと一｜通の手紙をかきあげると、封をして、宛名をしたためた。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "重吉のまだ短く刈られていない髪は、すこし長く額の上に乱れかかって、それをかきあげるとき、指に軽かった。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなふうに触っては擽ったいじゃございませんの、もっと遠慮なしにやって下さいまし、ぐいぐいと」「もちろん、――やりますよ」　万三郎は眼を脇へ向け、火にでも触るような手つきですばやく乳房をかきあげるなり、右手の指で、（貼ってある膏薬を）さっとひき剥がした。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
