    "definitions": [
      {
        "index": 1,
        "gloss": "to peel",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食事の準備を手伝うため、リンゴの皮をむくことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "手が汚れるけれど、温州みかんの皮をむく瞬間が一番好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "茹でたてのジャガイモは、熱いうちに皮をむくのがコツだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "内臓を切り放し、外へ引出すときに、烏賊の皮をむくときのように、パリパリと音がするのであった。",
              "citation": {
                "source": "人体解剖を看るの記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダットのいきおいで部屋へ行き、唐もろこしの皮をむく。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根の皮をむく機械など使う手練の鮮やかさは、ついその役にも立たぬものを買ってみたくさせるだけの才能がある。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身、いくら皮をむくつもりでも、すっかりはむけないし、大した仕事も生れ出ないことを、自ら歎じてはいたが、それでも芯についての自信はあった。",
              "citation": {
                "source": "或る夜の武田麟太郎",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、冷めたいだろう、そんなに濡れて、傘はないのか」「傘なんかない、食物だってないんだもの」といまだ水々しい栗の渋皮をむくのに余念もない。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "えんりょなく、はぎ取るんだ」「顔の皮をむくのですか」　蜂矢は、おどろいて、命令する人の方をふりかえった。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "亮太郎　　どんなことつて……例へば、芋の皮をむくんだつてさうだ。",
              "citation": {
                "source": "村で一番の栗の木（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄製のサヤのもあったし、木製のサヤのもあったが、この山刀の斬れ味は格別で、薪を叩き斬ることもできれば、リンゴやジャガイモの皮をむくこともできて、万能の用途があった。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、辛いといったら、台所の台の前にじっと立ちづめで、ジャガイモの皮をむくほど辛いことはない。",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて手前どもの果物は決して皮をむく必要がないのでございます。",
              "citation": {
                "source": "果物屋の広告文",
                "author": "仲村渠",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者は私の陰茎をつまみ、包皮をむく。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "その速やかなること、一分間に二十個の大芋の皮をむくこと容易である。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅は花城が好きになったので、木の実の皮をむく時わざと案の下へ落して、俯向いて拾うようなふうをして、そっとその履をつまんだ。",
              "citation": {
                "source": "翩翩",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯崎の子供の寂しい葬式のあんまり鮮やかな印象と、須美子の悲しみの真新しさは、伸子自身の悲しみの上をおおいかけていたうす皮をむくのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皮をむくと、なかが紫になっていて、そりゃいい匂いがしてよ。",
              "citation": {
                "source": "或る少女の死まで",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろでは餌の芋はふかした皮つきを持って行き、釣り場で皮をむく。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「梅ちやんお上りな」と梅代の方へは新聞紙のまゝ一寸突きやつて、自分は兩肱を兩膝の上に突いて體を前にかゞめながら細君は皮をむく。",
              "citation": {
                "source": "俳諧師",
                "author": "高濱虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた如何です」と三藏の方に會釋して梅代は恐ろしいものをこは／″＼摘まむやうな指つきをして、其癖中で上等らしいのを目早くえりわけて、それから細君と同樣に兩膝の上に兩肱を突いて前かゞみになつて皮をむく。",
              "citation": {
                "source": "俳諧師",
                "author": "高濱虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一緒にジャガイモの皮をむくのも結構ですし、ハニのところに通っているような金持の息子がアゴで女中を使わないようにしつけるのはいいけれども、大人の現実生活としてジャガイモの皮を一緒にむくよりも、もすこし本質的なことで一緒にやれることもあるのだし。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごらんなさい、米友さん、あなたに買って来ていただいた庖丁が、こんなによく切れて――」　なるほど――お雪ちゃんの言う通り、お雪ちゃんは今、芋の皮をむくにしても、新しい卸し立ての庖丁を使っているところであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてみると、新婚当夜ほどの新しい気分を与えてくれる今晩の調度も、相当の犠牲なしには得られなかった恩恵であることが一層深く感ぜられ、お雪ちゃんは幾度か米友の労をねぎらって、やがてお芋の皮をむくことが終ると、お茶をいれ、お茶菓子を出して、二人で飲みはじめました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉様は大きな梨のなかから甘さうなのをよりだして皮をむく。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬でもドブ鼠でもモグラモチでも、肉気のものなら、みんなキザンでコマ切れにすりゃ百円札に化けちゃうでしょう、カミサンなんざ鼠の皮をむくだけでテンテコ舞をしているうちに焼かれて死んじゃってネ。",
              "citation": {
                "source": "出家物語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "生剥逆剥は、馬の皮をむく罪。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日、桃を出した時、かわをむくのに、スーッスーッと音をたてて一度もとぎれずにきれいにむき終えた。",
              "citation": {
                "source": "四年のあいだのこと",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村警部は、ころがっている怪人の上に、かがみこんで、ビニールのお面を、かわをむくように、とりさりました。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
