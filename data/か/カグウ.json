    "definitions": [
      {
        "index": 1,
        "gloss": "temporary residence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "災害で家を失った人々は、仮寓施設で生活している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は一時的な仕事のために、その街に仮寓することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この古民家は、今は研究者の仮寓として使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "旅の途中、私たちは小さな村に数日仮寓した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "避難民は、仮寓先で支援物資を受け取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "秋琴楼に仮寓の昔も思い出さしむ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "田中舘先生の肖像を頼む事に関して何かの用向きで、中村｜清二先生の御伴をして、谷中の奥にその仮寓を尋ねて行った。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷中の台地から田端の谷へ面した傾斜地の中腹に沿う彎曲した小路をはいって行って左側に、小さな荒物屋だか、駄菓子屋だかがあって、そこの二階が当時の氏の仮寓になっていた。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰朝当座の先生は矢来町の奥さんの実家｜中根氏邸に仮寓していた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月二十五日の夜が例の大火、予の仮寓は危いところで類焼の厄を免がれたものの、結果は同じ事で、其為に函館では喰へぬ事になつて、九月十三日に焼跡を見捨てて翌日札幌に着いた。",
              "citation": {
                "source": "悲しき思出",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "景子のロンドンに於ける仮寓は此の丘の中に在った。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一上目黒渋谷境、鈴懸の仮寓、小さいが瀟洒とした茶室造り、下手に鬱蒼たる茂み、上手に冬の駒場野を望む。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹林に恵れた小田原の山荘に於ける震災前後の生活から、珠数工に隣り住んだ谷中天王寺十八番地の仮寓時代、大森は馬込の月光の谿を瞰望した丘の上の一年が此の間に推移した。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "再校分の校正刷を擁へたまま、築地の仮寓から愈々動坂に移つたのは恰度盛夏の頃であつたが、それはその儘握りつぶしになつて了つて、また新らしく原稿紙を散らかし出した。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時博多の北船という処に仮寓して後、福岡市の西職人町に借家｜住居をした。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日、いったん湯の川に帰り、引かえしてまた函館に至り仮寓を定めぬ。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿岳は物故する前二、三年、一時｜千束に仮寓していた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、少年の筆らしくない該博の識見に驚嘆した読売の編輯局は必ずや世に聞ゆる知名の学者の覆面か、あるいは隠れたる篤学であろうと想像し、敬意を表しかたがた今後の寄書をも仰ぐべく特に社員を鴎外の仮寓に伺候せしめた。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の仮寓してゐるＤ寺の和尚さんは『前世からの約束事でせう。",
              "citation": {
                "source": "神童の死",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は大正十二年の震災に麹町の家を焼かれて、その十月から翌年の三月まで麻布の十番に仮寓していた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "松江へ行って、道士の太古庵に仮寓していた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "輟耕録",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の一月ほどは時雄の家に仮寓していた。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は大正十二年の震災に麹町の家を焼かれて、その十月から来年の三月まで麻布の十番に仮寓していた。",
              "citation": {
                "source": "十番雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この琵琶法師が、ある時京都から、その頃、大阪南本町の仮寓にゐた私を訪ねて来てくれたことがあつた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその指図が実際眼で見る以上に、ちやんと図星にあたつてゐるのに、すつかり感心させられた車夫は、南本町の私の仮寓に客を送りこむと、手拭で顔の汗をふきふき言つた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時の汽車で博多へ、百道のＴさんを訪ねたが不在、そしてやうやく老司の少年院を尋ねあてたが、三洞さんは博多の事務所にゐられるといふ、引き返して事務所へ、さらに仮寓へまで連れて行つて貰つて、三年ぶりに懐かしい温容に接することが出来た、坊ちやん二人を連れての下宿生活である。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "三洞仮寓うらは椿の落ちたままむつかしい因数分解の、赤い何の芽　三月廿七日　曇、微雨、博多。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の麓にその人たちの仮寓はあった。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、長兄の仮寓があつた。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の麓にその人たちの仮寓はあつた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にわたくしは蘭軒が家を湖上に移したことを言つたが、それは一時の仮寓であつたと見えて、此時は又本郷にゐたらしい。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "）その後私たちは、毎月一回、青楓氏の仮寓に集って翰墨の遊びをするようになった。",
              "citation": {
                "source": "御萩と七種粥",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は日本公使館に、良人は日本領事館に仮寓して居たので、屡共に顔を見られた筈ながら交際は無かつたのである。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが君の病の小康を得た或日、庄の仮寓で、さゝやかな句会を開いたそのときの作品に、大舷の窓被ふある暖炉かな一片のパセリ掃かるゝ暖炉かなストーブや黒奴給仕の銭ボタン　といふ句があつた。",
              "citation": {
                "source": "不器男句集",
                "author": "芝不器男",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の夏や瓢作りに余念なく青々と地を這ふ蔓や花瓢晩涼やうぶ毛はえたる長瓢　数年前俳句をつくりはじめた頃、板櫃河畔の仮寓でも大瓢箪をつくつたが、その美事な青瓢は軒に吊るす中作りかたを知らず腐らしてしまつた。",
              "citation": {
                "source": "瓢作り",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
