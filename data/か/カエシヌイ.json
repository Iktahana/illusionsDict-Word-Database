        "examples": {
          "standard": [
            {
              "text": "ほつれかけたカーテンの端を、返し縫いでぐし縫いしておいたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このパッチワークキルトは、返し縫いを重ねて作られているから丈夫なんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の制服のボタンが取れそうだったので、返し縫いでしっかりと補強しておいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "――ここの住人たちの着物は、殆んど洗い返し縫い返した品である、新調するときにも古着屋から買うのがせいぜいで、そのため半端物や古着を背負って、定期的にまわって来る商人が二人いるが、持って来た品を売るよりも、反対にぼろを買わされるほうが多い、とぼやくくらいであった。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
