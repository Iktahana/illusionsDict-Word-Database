        "examples": {
          "standard": [
            {
              "text": "彼は、新しい趣味を見つけると、その場所へ毎日通いつめるタイプだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "娘は、お気に入りのカフェに週に何度も通いつめている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "体調が優れない友人を心配し、数日間通いつめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの研究室は、成功するまで通いつめる覚悟で挑むつもりだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しいレシピをマスターするために、図書館に通いつめて参考書を読み漁った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "十一　それからの黒吉は、研究所の所員たちに嗤われ、肝腎の葉子にすら蔑まれながら、それでも、僅かな暇を偸んでは、不自由な足を引ずって、あの千鳥食堂に、通いつめるのだった。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と次週へのお楽しみという連続映画に引かされ毎週毎週通いつめるのは、まるで恋人とのあいびきのような甘い雰囲気であったのです。",
              "citation": {
                "source": "私の洋画経歴",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんど社員みたいに通いつめることもありますけど、社員ではないのです」「どんなお仕事なの？",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
