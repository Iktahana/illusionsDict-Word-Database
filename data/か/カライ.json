[
  {
    "uuid": "882e6740-c744-5192-bd20-fe5d18675ad0",
    "entry": "辛い",
    "reading": {
      "primary": "からい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
