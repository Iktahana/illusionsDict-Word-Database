    "definitions": [
      {
        "index": 1,
        "gloss": "marbled bamboo (Chimonobambusa marmorea)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "黄昏に袖無を羽織って母上と裏の垣で寒竹筍を抜きながらも絵の事を思っていた。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗いランプの光で寒竹の皮をむきながら美しい絵を思い浮べて、淋しい母の横顔を見ていたら急に心細いような気が胸に吹き入って睫毛に涙がにじんだ。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃のわが家を想い出してみると、暗いランプに照らされた煤けた台所で寒竹の皮を剥いている寒そうな母の姿や、茶の間で糸車を廻わしている白髪の祖母の袖無羽織の姿が浮び、そうして井戸端から高らかに響いて来る身に沁むような蟋蟀の声を聞く想いがするのである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つは寒竹の筍である。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高知近傍には寒竹の垣根が多い。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "年取った祖母と幼い自分とで宅の垣根をせせり歩いてそうけ（笊）に一杯の寒竹を採るのは容易であった。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の五歳の頃から五年ほどの間熊本｜鎮台に赴任したきり一度も帰らなかった父の留守の淋しさ、おそらくその当時は自覚しなかった淋しさが、不思議にもこの燈下の寒竹の記憶と共に、はっきりした意識となって甦って来るのである。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ではたいていの田園の産物もデパートの陳列棚で見られるのであるが、それでもまだ楊梅や寒竹の筍は見られない。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "淋しい田舎の古い家の台所の板間で、袖無を着て寒竹の子の皮をむいているかと思うと、その次には遠い西国のある学校の前の菓子屋の二階で、同郷の学友と人生を論じている。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一匹の犬が豊吉の立っているすぐそばの、寒竹の生垣の間から突然現われて豊吉を見て胡散そうに耳を立てたが、たちまち垣の内で口笛が一声二声高く響くや犬はまた駆け込んでしまった。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭は先日までの花壇を取り除けて仕舞つて、俄苔を貼つた平地のところ／″＼に石と寒竹だけが配置されてあつた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆寒竹でございます、はい、お品が宜しうございます、五圓六十錢に願ひたう存じます。",
              "citation": {
                "source": "彌次行",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その緩い坂を登りつめてしまえば、大震災の当時の市区改正のため築山のうしろは断ち切られた俄崖になり、見下ろす崖の肌にも寒竹の根や灌木の根が瓦石と混って赭土の断面にむくじり出ています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "築山の羅漢柏、枝ぶりの蜒つた松、ばらばらの寒竹、苔蒸した岩、瓢箪形の池の飛石、汀の小亭、取りあつめて、そのまま一つの象になつてる。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡廊下の前には寒竹のような小さな竹で編んだ眼隠がしてあった。",
              "citation": {
                "source": "料理番と婢の姿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒竹の生けがきをめぐらした冠木門をはいると、玄関のわきの坪には蓆を敷き並べた上によく繭を干してあった。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の秋Ｋ市の姉から寒竹の子を送ってくれた事、Ａ村の姉からいつか茶の実をよこした事などが思い出された。",
              "citation": {
                "source": "球根",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体何という藪だ、破竹か、孟宗か、寒竹か、あたまから火をつけて蒸焼にして噛ると、ちと乱だ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの寒竹の中から、ふんわり白い影が、煙のようにふわふわと歩き出したとかしないとか、噂とりどり。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒竹の繁みがガサガサと幽かにゆれたかと思うと、うす白い男の影がふんわり浮きあがりました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手の寒竹の繁みが、ザアッと鳴った。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえらふたり、十五郎に化けて、かようかように梅甫夫婦を脅して来いと言われましたゆえ、迷って出たのじゃ、今すぐ別れろと、うまうまひと狂言書いたのでござります」「夜な夜な玄関先の寒竹の繁みの中とやらへも、白い影が出るとか申したが、それもおまえらの仕業か」「相済みませぬ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに今日は荷物も一処につけて来たといふほどの――」　満里子は寒竹の鞭で靴の先を叩きながら、「十九世紀は何うしてもお派に合はない。",
              "citation": {
                "source": "サロメと体操",
                "author": "ヘツペル先生との挿話",
                "note": "青空文庫"
              }
            },
            {
              "text": "畫伯がのこされた歌集「寒竹」をひらいて讀んでゆくと、明治四十年の條に「故園春雪」と題して五首の歌が選まれてあるが、そのなかの一首に春河の雪解の出水平押しに溢れ漲ぎる國移るべくの歌に出會ふのである。",
              "citation": {
                "source": "雪解水",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "美事な孟棕の植込みを遠景にして、庭中に漫々とたたえた水のなかの岩組みに水晶｜簾の滝がかかっていて、ちょうどそれが薄暮であったので、青々した寒竹の茂みから燈籠の灯に透けて見えるのも涼しげであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "山がかりの巌から、滝が轟き流れおち、孟宗竹の植込みのあいだから、夏は燈籠の灯が水の飛沫をあびて、涼しい風にゆらぐ寒竹や萩のなかに沈んでいた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
