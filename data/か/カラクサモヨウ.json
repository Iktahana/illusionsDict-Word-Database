[
  {
    "uuid": "6c2094b4-695a-51d0-944a-5a2a5b53f3db",
    "entry": "唐草模様",
    "reading": {
      "primary": "からくさもよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
