        "examples": {
          "standard": [
            {
              "text": "工場見学で、製造工程の最終段階で使われる大型の乾燥炉を見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "塗料を均一に乾燥させるため、最新の乾燥炉が導入された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "湿気を含んだ木材は、専用の乾燥炉に入れて完全に水分を取り除く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "資本家は、機械に截断された労働者、ベルトに巻き込まれて、砕けてしまった労働者、乾燥炉の中へおちて、焼き鳥のようになった労働者には驚かない。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
