        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅人は腰に小さな革袋をぶら下げ、道中の食料を入れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の人は、貴重品を革袋に入れて肌身離さず持ち歩いたそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の工房には、色とりどりの革袋が天井から吊り下げられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お土産に買ったハーブティーを、手触りの良い革袋に詰めてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これを集めて革袋に貯えておくと、一種の発酵を起していわゆるパルクが出来上がる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、或る日のこと、彼女は一人の若者を見初めたので、その魔法を用いたのだが、下婢に欺かれて、若者の髪の毛のつもりで、実は居酒屋の店先にあった羊皮の革袋から※り取った毛を燃してしまった。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、夜半に及んで、酒の溢れている革袋が街を横切って、魔女の家の扉口迄飛んで来たと云うことである。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は非常に太っていたが、しかしいつかはそれよりもっと太っていたらしく、ちょうど猟犬のブラッド・ハウンドの頬のように、ゆるんだ革袋のような皮が、顔の周囲に垂れ下っていた。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は偶然の思付からフートボールの革袋をむいてゴムへ一杯に空氣を吹き込んだ。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞬間である、偶然自由を得たイワノウィッチの右の手は、自分の腰に吊した拳銃の革袋を探っていたのである。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "座が定ると、不昧は自分の手で笈の蓋を開き、幾重にもなった革袋や箱包をほどいた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りに我れわれの持っている金を半分わけてあげると言って、重そうな革袋を出して渡した。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "座が定まると、不昧は自分の手で笈の蓋を開き、幾重にもなつた革袋や箱包を解いた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "水でも呑ませば生き返るかと、四辺を見ると誰のか知らんが、酒を入れる旅行持の革袋が飛び散って居る、是屈強と取り上げて口を開けるとブランデー酒の匂いがあるから、之を彼の口に注ぎ込んだが、死んだ蛙の生き返る様に生き返った。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だろうと音のする方を見ると彼は何時持ちだしたのか、望遠鏡でも入っていそうな長い革袋を肩から斜めに懸けていて、それをポンポンと叩いてみせたのだった。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その革袋の中には、いかなる品物が潜んでいるのだろう。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして肩から長い革袋を下すと、その口を開いた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "札は孔を穿ち緒を貫き、覆ふに革袋を以てしてある。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "革袋は黒の漆塗で、その水戸家から受けたものには、眞志の二字が朱書してある。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は大きな帳簿と黒い革袋を抱えて土幕の間を縫い歩いていた。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "その銀環をぐいと引くと、革袋の口が現れた。",
              "citation": {
                "source": "高島異誌",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の力を合わせても、革袋は動こうともしないのである。",
              "citation": {
                "source": "高島異誌",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから何卒今度ばかりは諦めて下さい」　……って……そう云っているうちに、ポケットからお金をドッサリ詰めた革袋を出して、妾の手に握らせたの。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾、その革袋を床の上にたたき付けて泣いちゃったわ。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は幾度も繰返して云った、古き衣に新らしき補布をあてる者があろうかと、また、新らしき酒を古き革袋に入れる者があろうかと、これらの言葉はただ譬えなのである。",
              "citation": {
                "source": "文学以前",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上は、天命を待つより外にない）　小太郎は、革袋から小銭を出して、茶店を出た。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "原訳二通の条約草稿を茶色の革袋へ密封して、特別仕かけの錠をおろす。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中なにごともなくアフガニスタンへ着いて、密書入りの革袋は、ただちにドイツ領事館内の金庫へ保管される。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いまそこの金庫へ入れた革袋の中にあるとばかり思っていた「厳秘」の二書を、エリク・ヘンダスンが持って来て、眼の前へ突きつけたのだ。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "天幕の梁には牛酪を充たした大きな革袋が釣るしてある。",
              "citation": {
                "source": "喇嘛の行衛",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも逞しい若者で、粗末ながら乗馬用の服装をし、腰には拳銃らしい革袋をさげ、鞍には大きな荷をつけていました。",
              "citation": {
                "source": "三つの悲憤",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はすっかり隙間のないほど身固めし、腰にはピストルの革袋を、肩から斜めに、大きな鶴嘴を、そしてズックの雑袋の中には三本の酒壜を忍ばせて、上陸第一歩は自分だといわんばかりの顔つきをしていた。",
              "citation": {
                "source": "月世界探険記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
