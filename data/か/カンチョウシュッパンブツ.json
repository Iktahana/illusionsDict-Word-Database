        "examples": {
          "standard": [
            {
              "text": "この統計データは、最新の官庁出版物から引用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "図書館で、明治時代の官庁出版物を見つけて興味深く読んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "特定の法律の施行状況を知るには、関連する官庁出版物を確認するのが一番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして農林省は、自分のところには室も本もなくして、ただリストの整備によって、そのころのわが館の官庁出版物を五〇パーセントは利用したのであった。",
              "citation": {
                "source": "支部図書館三周年に寄せて",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて秋、国内の官庁出版物を米国に送る事によって、アメリカの国会図書館から、交換として送って来る、外国官庁出版物は時には月一万部を越える事すらあったのである。",
              "citation": {
                "source": "機構への挑戦",
                "author": "――「場所」から「働き」へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "農林省にまだ図書室のなかった時、近藤康男氏を中心とする調査局、渉外局、八つの研究所を打って一丸とする調査網は、それは図書課として、我館のアメリカ官庁出版物の五〇パーセントを読んだのであった。",
              "citation": {
                "source": "集団文化と読書",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が警保局の統計によると恰も一九三一年を中心にして、社会関係の普通出版物（雑誌と官庁出版物を除いた出版物）の数は最高潮に達しているのである。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
