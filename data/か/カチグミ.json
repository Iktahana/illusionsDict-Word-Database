[
  {
    "uuid": "3dc926d8-1c98-5cff-8df6-b471dbee96d8",
    "entry": "勝ち組",
    "reading": {
      "primary": "かちぐみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "winners (those who have succeeded socially, economically, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新興企業で成功を収め、彼は若くして世間から勝ち組と見なされるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "高校時代の同窓会で、皆がそれぞれの人生で勝ち組になろうと奮闘しているのが感じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "どんなに努力しても、全てが思い通りに行くわけではなく、勝ち組と負け組という言葉には複雑な気持ちになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "勝ち組の議長は村人にうさん臭い目で見られるだろうし、後をつけられて行動を逐一監視されるだろう。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずる賢い人、頭でっかちの人、うぬぼれた人には、勝ち組の人生はない。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
