[
  {
    "uuid": "83d2acc1-cb37-547f-8b56-542560722443",
    "entry": "神信心",
    "reading": {
      "primary": "かみしんじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
