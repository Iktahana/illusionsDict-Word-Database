    },
    "definitions": [
      {
        "index": 1,
        "gloss": "belief in god",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は特に特定の宗教を信仰しているわけではないが、人一倍、神信心が厚い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「困った時だけの神信心じゃあ、願いも届かないよ」と祖母にたしなめられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "毎朝欠かさず氏神様へお参りに行くのが、彼の長年の神信心の形だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "科学的な根拠を重んじる彼にしては珍しく、神信心を大切にする一面がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "三次が、「旦那Ｔ「神信心って奴もやって見るとまんざら悪かァ御座んせんね」　と言って「急ぎやすから御免なせえ」と其の儘スタスタと去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄五郎が、Ｔ「成る程ね、神信心もまんざら悪かァ無え筈よ」　と言われて三次真赤になった。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十五万石の大目付、丸潰れと来たなあ」「それでももしや、お熊の縁談から起った意趣、遺恨じゃないかと思うて、襟半の方へ探りを入れてみると、花婿の半三郎も、今は隠居しとる父親の半左衛門夫婦も、神信心の律義者という評判に間違いないらしい」「それは毛頭間違いない。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘ではない、神信心もしていたようじゃが、しかし大きくおなりで、お達者なように見える。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分探しましたぜ」　わたくしはなおも母の事を聞きますと、母はわたくしの無断の家出から気狂いのようになって毎日神信心やら占やらで、きょうも、わたくしの旧学園友達の赤坂の吉良の家へ何事か手蔓を探り出すべく訪ねた帰りに豊川稲荷へお百度を踏みに行ったのだと言いました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの女って、水神様のことだろう、今まで私の傍にな、こんな梅干爺でも平生の心がけがいいからな、神信心をして、嘘を吐かず、それでみだらな心を起さずさ、だから神様が何時でもお姿を拝ましてくださるのだ、あのお池の中に祭ってござる水神様だ」　広巳は老人の横面をくらわしてやりたいように思った。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、神信心を怠っちゃあなりやせん」と、お静は親切に言った。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしの正月、浅草の観音さまで金運きたるっていうおみくじが出たんで、福が来るかなと思っていると、それがだんな、神信心はしておくものですが、ほんとうにあっしへ金運が参りましてな、みごとに三百両という金星をぶち当てたんでがすよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰯の頭も神信心、尼になっても女子は女子じゃ。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「染吉とお照は一方に冬坡をいじめながら、一方には神信心をはじめました。",
              "citation": {
                "source": "鴛鴦鏡",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにお城の一件が知れたので、要作夫婦は蒼くなって、どうぞ自分たちに難儀のかからないようにと、神信心や仏参りをして、可哀そうなくらいに心配しています。",
              "citation": {
                "source": "半七捕物帳",
                "author": "川越次郎兵衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "神信心の深い方で、「汝の敵を愛せよ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体｜直に手紙の返事を寄す人には神信心の厚い、正直者が多いものだが、この応募者も察する所、正直者だつたに相違ない。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「平素神信心をしない罰だよ。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあさ、そんなに言はないで手を貸しておくれよ、私だつて神信心しない事があるもんかよ。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むかしむかし、ある小学校に神信心の深いお婆さんの先生がありました。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間にざらにある背信者のなかには、以前神様のお弟子だといはれると、昔馴染の女の名でも言はれたやうに急に顔を赧くする人もあるが、岩野氏に限つて、そんな恥かしがりではない筈だから、くれぐれも言つておくが、今話すのは岩野氏がまだ神信心をしてゐた頃の出来事である。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは人間が親切な上に、神信心しないさうぢやから、お前が片づくのに誂へ向きといふものぢやて。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体直ぐに手紙の返事を寄こす人には神信心の厚い、正直者が多いものだが、この応募者も察する所、正直者だつたに相違ない。",
              "citation": {
                "source": "名文句",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど父は嚴格な、神信心な人でした。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはこの頃この國のお伊勢參りが、古市の姫買ひを目的として、神信心は附けたりであつたから、子供の參宮をば、八十の老婆の嫁入りよりも、まだ不思議なこと、可笑しいこととしたのである。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "――が、その内に困まった事には、少将もいつか康頼と一しょに、神信心を始めたではないか？",
              "citation": {
                "source": "俊寛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一統が一通りならん心配で、お夜詰をいたし、明番になりますと丁度只今の午前十時頃お帰りになるのですが、御容態が悪いと忠義の人は残っている事がありますので、富彌様はお留守勝だから、御新造はお留守を守って、どうかお上の御病気御全快になるようにと、頻りに神信心などを致して居ります。",
              "citation": {
                "source": "菊模様皿山奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて日本も嘉永の五年あたりは、まだ世の中が開けませぬから、神信心に凝るとか、易占に見て貰うとかいうような人が多かったものでござります。",
              "citation": {
                "source": "闇夜の梅",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ここで婆さんを入れる、あの隠居も神信心だなんて言いながら、婆さんの溜めたのを欲しいからと人が言う。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "君江はこの不審と、去年からの疑惑とを思合せて、これから先どんな事が起るかも知れないと、急に空おそろしくなって、今まで神信心は勿論、お御籤一本引いたことのない身ながら、突然｜占いを見てもらう気になったのである。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの先週は、神信心だのあれやこれやの呪い事だので、おれあぺてんにかけられて、可哀そうな実直な商売人めがこれまで出くわしたことのある中でも一番不仕合せな目に遭ったじゃねえか！",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神信心でござんすかえ」嘲笑うような声である。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれどもそのゝち一ねんとたゝぬあいだにまったくめしいになりまして、かみしんじんもいたしましたがなんのきゝめもござりませなんだ。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
