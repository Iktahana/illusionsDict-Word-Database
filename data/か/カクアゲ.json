        "examples": {
          "standard": [
            {
              "text": "来期からこの部署が本部に格上げされることが決まり、課内は色めき立っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「やった！ ついにうちの店、ミシュランの星付きに格上げされたよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "外債の格付けが一段階格上げされたことで、海外投資家からの資金流入が加速した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "準レギュラーからレギュラーへの格上げを告げられ、彼は人知れずガッツポーズをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「こりゃあもう事業部に格上げして、逃げられないようにした方がいいんじゃないか」　小林はだめを押した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがＰＣ―８００１の周りで何が起こりつつあるかを認識した小林は、「もう専門の事業部に格上げして、ここから逃げられないようにしたほうがいいんじゃないか」と大内の決断を促した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用所用人の役目で、物書などの出る幕ではないのだが、その年は事務繁多で手繰りがつかず、金十郎が用人並に格上げされて邸廻りをした。",
              "citation": {
                "source": "奥の海",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へはいると、安二郎は風呂銭を節約しての行水で、お君は袂をたかくあげて背中を流していた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからもあることだから、参考のためにいっておくがな、さきほどはせっかくあげた非人をこちらへいただいてしまって、ごちそうさまだったよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日本文学入門」は明治以来昭和十五年までの日本文学が観察されていて、文献がこまかくあげられているとともに、国文学というものがいかなる方法で研究されるべきかという点について新しい考察もふくめられている。",
              "citation": {
                "source": "世代の価値",
                "author": "――世界と日本の文化史の知識――",
                "note": "青空文庫"
              }
            },
            {
              "text": "甥に代筆を頼もうと思ったが、せっかくあげるのに自分でかかなくっちゃ、坊っちゃんに済まないと思って、わざわざ下たがきを一返して、それから清書をした。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他こまかくあげれば際限がない。",
              "citation": {
                "source": "道具と餌と天候",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "銅張りの船は青いロシヤ國旗を掲げていま水面に辷り出したところ、まはりには兩手をたかくあげた水兵風のロシヤ人大工たちと、丁髷に鉢卷、股引に草履の日本人大工たちが腕拱みして見おくつてゐる。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜会巻きというのか、束ねた毛をたかくあげて、背を向けると呼吸をのむような見事な襟脚が二つならんでいた。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　メフィストの二十面相が、両手をたかくあげて、頭の上で、グルグルとまわしました。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくわたしは（世間には死者の記憶をとやかくあげつらう人たちがたくさんいるが）、そういう人たちに、「彼はこういうふうに判断し生活した。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロボットは、右手に、厚ぼったい紙のたばを持っていましたが、その右手を、たかくあげたかとおもうと、紙たばを、パッと、下の道路にむかって、投げおろしました。",
              "citation": {
                "source": "電人Ｍ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
