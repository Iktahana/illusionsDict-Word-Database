        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あの時、私が『絶対に無理だ』と言ったのは、やや過言でした。方法はあるはずです。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「私の説明に誤りがありました。先ほどの発言は過言であり、訂正させていただきます。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「君の才能を『天才だ』と評したのは、さすがに過言だったかもしれません。でも、それに近いものがあるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「会議での発言、あれは過言だったと反省しています。もっと慎重に言葉を選ぶべきでした。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
