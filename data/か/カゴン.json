[
  {
    "uuid": "8658e007-28a9-598c-a54b-531aa4aaab9e",
    "entry": "過言",
    "reading": {
      "primary": "かごん",
      "alternatives": [
        "かげん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
