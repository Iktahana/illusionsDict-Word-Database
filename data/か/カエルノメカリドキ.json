        "examples": {
          "standard": [
            {
              "text": "ぽかぽかとした陽気に誘われて、午後の歴史の授業中に蛙の目借時を感じてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "蛙の目借時とはよく言ったもので、春の縁側で本を読んでいるとどうにも眠くて仕方がない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "重要な会議の最中にこっくりこっくりと船を漕いでしまい、先輩から「すっかり蛙の目借時ですね」と笑われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "春は蛙の目借時、かかる日も、食客殿は幸福であった。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
