    "definitions": [
      {
        "index": 1,
        "gloss": "just because",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "忙しいからって、連絡をしないのは良くないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "安いからって、品質の悪いものばかり選ぶのは後で後悔するだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "みんながそうしているからって、それが正しいとは限らない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ちょっと疲れたからって、すぐに仕事を中断する癖を直すべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "実になる、ならない、もへんなもので、むかし発電機の発明をして得々としていたところ、一貴婦人から、けれども博士、その電気というものが起ったからって、それがどうなるのですの？",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら暑いからって、そんな処へもぐり込む奴があるもんかい。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらにゃ、ダイナマイトを抑えつけるてな、芸当は打てねえんだからってな。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日｜麹漬をつけるからって、お母さんがそう云うから、私飛んできました」　民子は非常に嬉しそうに元気一パイで、僕が、「それでは僕が先にきているのを民さんは知らないで来たの」　と云うと民子は、「知らなくてサ」　にこにこしながら茄子を採り始める。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝階下　お半が鶴吉に、　「あの人、余ッ程……妾に会いたかったのね」　「それァお前……一目会って行き度えと言ってきかなかったが、そんな事をして居ちゃ危ねえからって、俺達が無理矢理に発たせたんだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、こう云ったからって妾は打算と赤鼻が好きさ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人は、警戒兵が寝静まったころを見はからって、その自然を利用した。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「否エ妾になれって明白とは言わないけれど、妾々ッて世間で大変悪く言うが芸者なんかと比較ると幾何いいか知れない、一人の男を旦那にするのだからって……まあ何という言葉でしょう……私は口惜くって堪りませんでしたの。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これは、一度兵士達が見つけて以来、勤務について、寄宿舎にいなくなった留守を見はからって敢行された。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "使えないからってそれでも面白いいい鉛筆なのです。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも可、時と場合で捕われないにも限らんが、撲られて痛いからって、平気で味方の内情を白状しようとは、呆れ果た腰抜だ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金があるからって、威張っていやがる。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "器械的に対称の法則にばかり叶ってゐるからってそれで美しいといふわけにはいかないんです。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "器械的に対称の法則にばかり叶っているからってそれで美しいというわけにはいかないんです。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「否、私は炭籠の炭ほか使ないよ」「そうら解った、私は去日からどうも炭の無くなりかたが変だ、如何炭屋が巧計をして底ばかし厚くするからってこうも急に無くなる筈がないと思っていたので御座いますよ。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に盗んだところを見たのではなし又高が少しばかしの炭を盗られたからってそれを荒立てて彼人者だちに怨恨れたら猶お損になりますぞ。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "……酔っぱらっているからって渡瀬作造は渡瀬作造だ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部　　俺たちの仕事が認められないからって、裏切りをするような奴は……出て行け。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬古　　沢本、おまえはさもしい男だなあ、なんぼ生蕃と諢名されているからって、美術家ともあろうものが「食えそうなもの」とはなんだね。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お土産を楽しみにして、お腹をすかして帰るからって、言づけをしたそうです。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は滅多に御座敷はありませんし、あの……」　とお千世は言淀んだが、「鑑札のお代だって余計なものだのに、電話なんか無駄だからって、それで、譲ってしまったんでしょう。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　三十八「お前さんの母様が亡なんなすった時も、お前にゃあ何でもしたいことが出来るからってとお言いだったと聞いちゃあいたがね、まあ、随分思切ったこったね。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して自分が出来ないからって人をねたんだり、出来たからって出来ない人を見くびったりさない。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども僕たちの方のきめでは気象台や測候所の近くへ来たからって俄に急いだりすることは大へん卑怯なことにされてあるんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今度は菜食だからって一向安心にならない。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に魚がどんなに死ぬからってそれが私たちの必ずそれを喰べる理由にはならない。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又私たちが魚をたべたからって魚が喜ぶかどうかそんなこともわからない。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ何かに殺されるだろうからってこっちが殺してやろうと云う訳には参りません。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "振売の時、チリンチリンと鳴らすが、似ているからって、風鐸蕎麦と云うんだそうです。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
