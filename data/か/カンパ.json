    "definitions": [
      {
        "index": 1,
        "gloss": "fundraising campaign",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」カンパネルラが不思議さうにあたりを見まはしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンパネルラだってあんな女の子とおもしろさうに談してゐるし僕はほんたうにつらいなあ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カンパチが脂がのっています、それに今日は蛤も――」　ともよの父親の福ずしの亭主は、いつかこの客の潔癖な性分であることを覚え、湊が来ると無意識に俎板や塗盤の上へしきりに布巾をかけながら云う。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽の曲名をつけるとすると、（グラナダ）（ダルダナス）（ラ・カンパネラ）（カプリース）あんまり華美で仰山な名はいやである。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この生徒のこの答えは、ロシュフコー（６）や、ラ・ブリュイエール（７）や、マキアヴェリ（８）や、カンパネラ（９）のものとされている、あの、あらゆる贋の深遠さよりも深いものだよ」「で、その推理者の知力を相手の知力と合致させることはだね」と私は言った。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンパニーレの広辻はひっそりとして人影もなく、昔の大公の宮殿の燈火は一つ一つ速やかに消えゆくところであった。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、次に出ている「カンパニーレ」はその広場にある鐘塔。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこでは世界の不景気騒ぎをよそにして九千百九十六万ヘクターの収穫カンパの真最中だから。",
              "citation": {
                "source": "小熊秀雄全集",
                "author": "―３―",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は「基金カンパ」を起しているのだと云って、会う同志毎に五銭、十銭とせしめた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にこの戦争の時期に「メーデー」とか、八月一日の「国際反戦デー」というような大きなカンパを前にして、彼奴等はどうでもこうでも党の力を根こそぎにしなければならなかった。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して、プロレタリア暦の上の形式的一カンパの日ではない。",
              "citation": {
                "source": "国際無産婦人デーに際して",
                "author": "――作家同盟各支部に婦人委員会をつくれ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人同盟員の自己教育、同伴者的婦人作家の獲得、特に婦人に関係ある種々なカンパへの組織的動員等はすべて婦人委員会の活動に属する。",
              "citation": {
                "source": "国際無産婦人デーに際して",
                "author": "――作家同盟各支部に婦人委員会をつくれ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンパネラやＦ・ベーコンやサン・シモン等が、大なり小なりそうだった。",
              "citation": {
                "source": "技術的精神とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本主義列国の反ソヴェト同盟カンパニアに対して作家はどう戦うべきか。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしほんとにソヴェトの人民を解放しようとするなら、先ず何よりいま自分たちがやっている反ソ・カンパニアをやめさえすればいいんだ。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『労働者新聞』にもピオニェールのための『ピオニェールスカヤ・プラウダ』にも、この反ソヴェト・カンパニアに対する批判がのった。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学新聞が、多勢のソヴェト作家にあてて、反ソヴェト・カンパニアに対する感想を求めた時、みんなは殆んど異口同音に答えた。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェトのプロレタリア作家達は反ソヴェト・カンパニアというモメントから、ボルシェヴィキらしく、階級的発展に役立つものをとりあげた。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場内の集会、労働者クラブの講演会『プラウダ』『労働者新聞』などが、帝国主義国の反ソヴェト・カンパニアに対する闘争についてソヴェト同盟の革命的大衆の自覚によびかけているばかりではない。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "各国の帝国主義者たちが、それぞれの方角と方法でソヴェト同盟破壊のためのカンパニアを精力的に起さずにはいられないほど、それぞれの国内での情勢が切迫して来ている。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロテスタントの大部分を統一している日本キリスト教団は「日本再建伝道」カンパニヤを起している。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "荏原が籐椅子カンパのとき二十何円もよこした。",
              "citation": {
                "source": "「乳房」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "規模から見ても利益率から見ても、日本のエクセレントカンパニーと呼ぶにふさわしい存在であろう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピープルズ・コンピューター・カンパニー、人民のコンピューター会社ということになるのだろう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンフランシスコ郊外のメンローパークにある、ピープルズ・コンピューター・カンパニーという団体では、『ドクター・ドブズ・ジャーナル（ＤＤＪ）』というホビイスト向けの雑誌を出しはじめていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★一九七六年五月十九日の日本のネクタイ族の訪問は、ピープルズ・コンピューター・カンパニーのメンバーにとっても大きな驚きだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "西海岸では以前から、大企業や国家による管理のための装置としてではなく、一人ひとりの可能性を開く道具としてのコンピューターを目指して、ピープルズ・コンピューター・カンパニーが活動を続けていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＩＴＳのエド・ロバーツは、かねてからコンピューター技術の大衆的な普及を目指して活動を続けてきたピープルズ・コンピューター・カンパニーに、唯一存在していた完成品のアルテアを貸し出していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピープルズ・コンピューター・カンパニーの会報にアルテアのコンサートの顛末を書き、八進数と音階との対照表に二曲のデジタル楽譜を添えて発表したドンピアは、その後繰り返しアルテアとともに旅立ったのが自分たちだけでないことに直面させられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
