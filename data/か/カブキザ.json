        "examples": {
          "standard": [
            {
              "text": "銀座にある象徴的な「歌舞伎座」での公演のチケットを予約しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「歌舞伎座」の建築は、そこで行われる公演と同じくらい印象的です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "多くの観光客が、日本の伝統演劇を体験するために「歌舞伎座」を訪れます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
