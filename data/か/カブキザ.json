    "definitions": [
      {
        "index": 1,
        "gloss": "kabuki troupe",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この有名な「歌舞伎座」は、全国を巡業してきた長い歴史を持っています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "俳優たちは皆、著名な「歌舞伎座」の一員です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "若手俳優は、「歌舞伎座」の伝統の中で厳しく訓練されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "また時々は夫人に芝居見物をすすめて、『歌舞伎座に団十郎、たいそう面白いと新聞申します。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチリと一つスウィッチを入れさえすれば、日比谷公会堂の演奏、歌舞伎座の演技が聞かれるからである。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し当人は東京の盛り場を大抵其の縄張り地内として、その勢力の大したものなるは、其の葬の日に歌舞伎座を使用したに照してもわかる。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "余談ではあるが、二十年ほど前にアメリカの役者が来て、たしか歌舞伎座であったかと思うが、「リップ・ヴァン・ウィンクル」の芝居をした事がある。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十年四月、中央公論）　　　　　十六　歌舞伎座見物　二月の歌舞伎座を家族連れで見物した。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この芝居を見てから数日後に友だちといっしょに飯を食いながらこの歌舞伎座見物の話をして、どうもどの芝居もみんな、もうひと息というところまで行っていながら肝心の最後のひと息が足りないような気がするという不平をもらしたら、Ｔ君は、畢竟いい脚本がないからだろうと言った。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞伎座の一夕の観覧記がつい不平のノートのようになってしまったようであるが、それならちっともおもしろくなかったのかと聞かれればやはりおもしろかったと答えるのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本日は弟と歌舞伎座に行く事になっていた。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば歌舞伎座の正面二階から舞台を見るような場合、視像の深さはほとんどなくなっているはずであるが、われわれは俳優の運動によって心理的に舞台の空間を認識する。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年の十一月、歌舞伎座で『河内山』を上演した。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は市村座に出勤し、次に歌舞伎座や明治座にも出勤したが、とかく一つ所に落付かないで、浅草公園の宮戸座等にもしばしば出勤していたので、自ずと自分の箔を落してなんだか大歌舞伎の俳優ではないように認められるようになった。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかな事はいえませんが、私の知っている限りでは、米斎君がはじめて舞台装置をなすったのは、明治三十七年の四月に歌舞伎座で、森鴎外博士の『日蓮上人辻説法』というものを上演しました。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから翌年の二月に歌舞伎座で、今の六代目菊五郎が長谷川時雨さんの『桜吹雪』を上演しました。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一言もないので、二度目にやる時には御指図に従いますから、といって、大正五年に歌舞伎座で再演した時には、万事米斎君に御願いしました。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○歌舞伎座新築落成して、十一月二十一日より開場。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○三月、歌舞伎座にて「相馬平氏二代譚」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○五月、中村鴈治郎大阪より初めて上京し、歌舞伎座と新富座に出勤。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月、歌舞伎座の中幕に「戻り橋」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四年（辛卯）　一八九一○六月、歌舞伎座にて福地桜痴居士作「春日局」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月、歌舞伎座にて新作「太閤軍記朝鮮巻」を上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五年（壬辰）　一八九二○一月、歌舞伎座にて三遊亭円朝の「塩原多助一代記」を脚色して上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○七月、歌舞伎座にて円朝の「牡丹灯籠」を脚色して上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞伎座にては七月二十八、二十九、三十の三日間、出征軍人慰問劇を興行し、来遊中のフランス女優テーラー嬢も団十郎の一座と共に出勤。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月、歌舞伎座にて日清戦争劇「海陸連勝日章旗」を上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○五月、川上音二郎一派は歌舞伎座に出勤して「威海衛陥落」を上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月、歌舞伎座にて団十郎は歌舞伎十八番の「暫」を勤め、連日売切れの大入りを占む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○四月、歌舞伎座にて団十郎は十八番の「助六」を演じ、前年の「暫」に劣らざる好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○九月九日より三日間、歌舞伎座において東京養育院慈善演劇を催し、貴婦人令嬢らが売店を開く。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
