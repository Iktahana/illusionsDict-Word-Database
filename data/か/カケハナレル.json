        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の理想とする世界は、現実とはかけ離れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その提案は、私たちの当初の目的とかけ離れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "都会の喧騒からかけ離れた、静かな田舎に住みたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「こんなはずじゃなかったのに！」と、現実は夢とかけ離れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、それがあまりにかけ離れるともう私はただ彼を尊敬することだけが専門になり始めた。",
              "citation": {
                "source": "鳥",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to be very different (from)",
        "register": "standard",
        "nuance": null,
