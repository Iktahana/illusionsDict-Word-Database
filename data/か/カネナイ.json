[
  {
    "uuid": "a77098bb-64d5-5a3e-9ac0-490a987bab13",
    "entry": "兼ねない",
    "reading": {
      "primary": "かねない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "接尾辞"
      ],
