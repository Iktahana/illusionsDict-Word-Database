[
  {
    "uuid": "bdb13617-620f-5b91-95d6-0e78bb68871a",
    "entry": "感奮",
    "reading": {
      "primary": "かんぷん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
