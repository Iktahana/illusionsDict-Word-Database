[
  {
    "uuid": "d21cbb22-0e0a-5b64-aebf-c18fa5f64241",
    "entry": "間出",
    "reading": {
      "primary": "かんしゅつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
