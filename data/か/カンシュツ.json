    },
    "definitions": [
      {
        "index": 1,
        "gloss": "travelling incognito",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "王子様は身分を隠して間出し、庶民の暮らしぶりを視察した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "有名な小説家が取材のために間出し、地方の小さな村で数週間過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "SPの目を掻い潜り、彼女はこっそり間出して市内の祭りを楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の偉い人は、世の中の様子を知るために、よく間出したという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "日本人では自分の外に九州大学の桑木さんもある期間出席されたように思う。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八二年十月に発熱性のリューマチスに罹って数週間出勤が出来なかった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……晝間出掛けられますか。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中小姓の山崎さんはと訊くと、これも昼間出たぎりでまだ帰らないと門番が教えてくれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "冠婚葬祭を軽んずる様で人間出世は出来ぬという信念をもっている。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間出れば出られぬことはない筈だが、使っている小女が子供と云っても好い位だから、何一つ任せて置かれない。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄關と向ふの醫者の裏板塀との細い露地を通り、自分の家の臺どころの角から曲つて、また細い露地を三四間出ると、我善坊の通りだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せめて三四時間出るところでなくちや、旅行したやうな気がしないや。",
              "citation": {
                "source": "青い風",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "役の小角が葛城山へ石橋を架けようとして、海内山神の合力を求めた時、たつた一人、葛城の女神が容貌のみにくいのを他にみられるのを恥ぢて、晝間出合はなかつたので、結縛したといふ傳説に因いて、作意を構へたものです。",
              "citation": {
                "source": "詩集の後に",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾ら何でもこんな場所へ、まっ昼間出てくるもんですか。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれだけの時間出ていては書く時間がないので困ると、いつも申していましたから、大学を止められたと云う事でなく、止められる時の仕打ちがひどいと云うのでございました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し目録學は支那に在りて、特別の發達を爲し、二千年前に於て劉向、劉※父子を生じ、其後之を祖述したる者は間出すれども、要するに二劉の上に出づる者なし。",
              "citation": {
                "source": "敬首和尚の典籍概見",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "（わたしは病気で欠席し、最後の日の数時間出席したばかりであったが）しかし、「勤労者文学」のことは、前大会での提案者徳永直の報告に一任されている。",
              "citation": {
                "source": "その柵は必要か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は懊悩のたえ切れない苦しさを少しでも軽くしようと冀って、昼間出掛けようと思った先輩の須永助教授のところを訪い、一切を告白して適当な処置を教えて貰おうと決心しました。",
              "citation": {
                "source": "三角形の恐怖",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし諸仏菩薩、世間出世間の善道を説きて、衆生を教化するひとましまさずば、あに仁義礼智信あることを知らんや。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "同月八日此間出生仕候娘病気之処、養生不相叶申上刻死去仕候、七歳未満に付、御定式之通、三日之遠慮引仕候段御達申上候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の家からは葬式が長い間出なかつた。",
              "citation": {
                "source": "無常の風",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "家畜のような先生の眼と自分の眼とが、鏡の中で刹那の間出会ったのは正にこの時である。",
              "citation": {
                "source": "毛利先生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから約束通り噴水の横でチイ嬢に会って、演芸館の裏で夜間出勤のサンドウィチマンを二人買収して、チイ嬢と二人で薄い布張りの四角い箱の中に這入って、入口の看守にテケツだけ見せて会場を抜け出しました。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもし僕が十分間出て来なかったら、なんとか旨い口実をつけて様子を見に来て呉れ給え」　渡辺刑事は石子が先輩振って指図がましく振舞うのが不愉快だった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明末に權勢を專らにした魏忠賢、清末に勢力を振うた李蓮英ら、皆河間出身の宦官であつた。",
              "citation": {
                "source": "支那の宦官",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、その仕掛を作ったのが算哲で、それを利用して永い間出入りしていた人物と云うのが、犯人に想像されるんだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どうだい、この間出した本の売れ口は？",
              "citation": {
                "source": "寒さ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏は最近の著述を揃へて僕に贈る事を約し、僕達が仏蘭西に滞在する間出来る丈の便宜を計らうと云はれた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にとつて制作はその瞬間出來る限りたのしまれたる生の活動の氣高い一片である。",
              "citation": {
                "source": "展望",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――女子この室より出でんとし、瞬間出口にて振り返り、仆れし愛弟を凝視す。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、どうかするとそのまま自分の部屋へ引込んで、そこから長い間出て来なかったりする事があった。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一星社の若主人は五年間出征していた青年にて、私の愛読者の由。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……自分じゃ、つい此の間出たばかりだ、と言っていたが、そんなことはないでしょう。",
              "citation": {
                "source": "別れたる妻に送る手紙",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "occasionally making an appearance",
