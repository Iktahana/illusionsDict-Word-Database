    "definitions": [
      {
        "index": 1,
        "gloss": "alias",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は素性を隠すために仮の名を使い、酒場の片隅でひっそりと暮らしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おい、俺をその仮の名で呼ぶのはよしてくれ。慣れなくてどうも寒気がする。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "潜入捜査官は、偽造された身分証に記された仮の名を何度も頭の中で復唱した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "作家は本名を伏せ、風変わりな仮の名を用いて作品を世に送り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」と衝と寄りて、門番の両手を扼るは、昔関口流皆伝の柔術家、今零落して屠犬児、弥陀平というは世を忍ぶ仮の名にて、本名あるべき親仁なり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "上原とあった門札こそ、世を忍ぶ仮の名でも何でもない、すなわちこれめ組の住居、実は女髪結お増の家と云ってしかるべきであろう。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真実をいえば器も非器も仮の名である、身も心も便宜上の呼称である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "二者即一、一者即二、身心と分け、器分非器分と分けるのもつまりは仮の名である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "余談に渉ったが心・身・器分・非器分の別は実に仮の名である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮の名ではあるが、東といい西という名目のあるのは便利である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十三年前、予米国ミシガン州アンナボアに佐藤寅次郎氏と野原の一つ家に住み、自炊とは世を忍ぶ仮の名、毎度佐藤氏が拵え置いた物を食って出歩く。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "両国橋が御普請だというので、どんな様子か拝見に出て来たんですよ」「と云うのは、世を忍ぶ仮の名で、占い者にお手の筋を見て貰って……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「解放治療」なぞいう鹿爪らしい名前は、世を忍ぶ仮の名に過ぎないのだ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴矢田平は明の宋蘇卿の遺子｜順喜歓が仮の名にて、これしきの一天下を覆がへすになんの手間隙と云ふ意気込にて、真柴久次に仕へしが、老女石田の局に見あらはされ、自尽す。",
              "citation": {
                "source": "両座の「山門」評",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "今こそお蓮さんなんぞと云っているが、お蓮さんとは世を忍ぶ仮の名さ。",
              "citation": {
                "source": "奇怪な再会",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝も出がけに自分からわしの妹にしておこうなんていったくせに、忘れっぽいったらありゃあしないよ、ほんとに」「では、あんたは、お福の茶屋嬉し野のおきんさんではないのか」「うれし野のおきんとは、世を忍ぶ仮の名、ほほほほ、はばかりながら茶くみ女に見えますかねえ。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで日下開山の横綱のような名だが、いずれ、世を忍ぶ仮の名。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "かごやの客",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「藤枝蔵人様というのは仔細あって世を忍ぶ仮の名、まことはあれが、成滝近江様本人でしたよ」　平次はとうとう最後の切札まで投げ出しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "敵討果てて",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お静とは仮の名、真は稲富喜三郎の妹、曾ては自分の許婚であった、繁代の世を忍ぶ姿であったでしょう。",
              "citation": {
                "source": "江戸の火術",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに解決済みといえるものはほとんどなく、レイクはこのものに仮の名を与えるにあたり神話学に立ち戻って――巫山戯た渾名をつけたのだ、「旧支配者」と。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "どん底の人　そのとき、仮の名速水荘吉は、ネズミ色のセビロ、ネズミ色のオーバー、ネズミ色の鳥打ち帽といういでたちで、東京周辺のある繁華街にまだ残っているブラック・マーケットの迷路の中を歩いていた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉塚の妻女のむらは、娘にふさという仮の名を付けた。",
              "citation": {
                "source": "その木戸を通って",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新町とは彼の仮の名であろう、羽折も袴も、乗馬用のものである。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊＊＊＊＊　アントワーヌ・エスカランが本名であるが、かえってカピタン・プーラン、バロン・ド・ラ・ガルドという仮の名の方で知られている。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "市※の若旦那が世を忍ぶ仮の名で、市岡菊太郎としては可なりの腕前を持っている。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「今は、それも前身の仮の名にすぎぬが、実は、拙者は海野信濃守行親の子です」「えっ」思わず範宴は眼をみはった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おん身の峰阿弥という名は、琵琶を持ってからの仮の名でしょう。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで道祖神は地蔵の仮の名のように、思っている人も時々はあるのだが、その考えはあべこべで、実際は子供の好きな道祖神を、後に地蔵さんといって拝ませたのである。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "無可とは、武蔵が、仮の名であった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……柳斎とは、仮の名。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて病気の発作が起った時、ヘルンは自己の運命をすっかり自覚し、死後における妻子の保護と財産の管理とを、親友の法学士に一任して、後に心がかりのないようにした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとはもう聞えないくらいの低い物言いで隣りの主人からは安心に似たようなしずかな波動がだんだんはっきりなった月あかりのなかを流れて来た。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そのとき向うのつめくさの花と月のあかりのなかに、うつくしい娘が立っていました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしたちは二人、モリーオの市の方のぼんやり明るいのを目あてにつめくさのあかりのなかを急ぎました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
