    "definitions": [
      {
        "index": 1,
        "gloss": "tourist",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夏休みに入り、ビーチには多くの観光客が訪れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地元の人は、親切に観光客を道案内していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「わあ、こんなに観光客が多いなんて知らなかった！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "早朝の市場は、地元の住民と観光客で賑わっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "室戸岬が日本何景かの一つになってから観光客が急に多くなり、今では、汽車こそまだ開通しないが、自動車や汽船で楽に日帰りが出来るそうである。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめては狩衣か、相成るべくは、緋縅の鎧……と気がつくと、暑中伺ひに到来の染浴衣に、羽織も着ず、貝の口も横つちよに駕籠すれして、もの欲しさうに白足袋を穿いた奴が、道中つかひ古しの蟹目のゆるんだ扇子では峠下の木戸へ踞んで、秋田口の観光客を――入らはい、と口上を言ひさうで、照覧あれは事をかしい。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくもアメリカの百万長者がアルプスの空気と光線に健康とエネルギーを求めて歩く間に、多くの日本人の観光客はそのほかにおまけとして山水の美の中から日本人らしい詩を拾って歩くであろう。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "外人観光客へ勧める宣伝文に「日本は世界一の空の都」と観光局はつけ加えていい。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから此の地方へ毎年観光客がやって来て、落す金が八億フランにのぼるそうです。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは、東京からか、または伊那盆地から、いきなり飛び込んで来た、観光客には、奇岩怪石の間を、天龍川が幅狭く食い込んで、流れて居るので、たしかに珍らしいに違いない。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ別に、彼に安易さを覚へさせたのは、彼が心配したように「生活」を求めて彼女が訪れて来たのではなくつて、全く単純な観光客として、小さな観光団に加つて、序でに、眼色の変つた兄貴にも会つて行かう――位ゐの、全く安楽な状態で、遊びに来たのであるといふことだつた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の美といえば京都、奈良、お濠の景色というのは、ものを知らない観光客だけではない。",
              "citation": {
                "source": "中国に於ける二人のアメリカ婦人",
                "author": "――アグネス・スメドレーとパァル・バック――",
                "note": "青空文庫"
              }
            },
            {
              "text": "観光客ちらほら、むつまじいアベツクもゐた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　と一つ、亜米利加人の観光客みたいに曖昧に感心しておいて、彼女を促し、ショファを引具してちょっとそのウェリントン大公の参謀本部を訪問する。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女と私と、狩りに行くいぎりすの老貴族とベルゲンの女富豪と、あめりかの観光客と埃及人の医学生と。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日そこを走るのは、労働者・農民の陽気な観光客を満載した遊覧乗合自動車だ。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三恵寺へまた拝登する、いかにも山寺らしい、坐禅石といふ好きな岩があつた、怡雲和尚（温泉開基、三恵寺中興）の墓前に額づく、国見岩といふ巨岩も見た、和尚さん、もつと観光客にあつてほしい。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "観光客は進行方向左に折れて琵琶湖疏水を渡り、宝塔寺や石峰寺、瑞光寺を訪ね、全国に広がるおいなりさんの総本宮、伏見稲荷大社に足を伸ばす。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "深草で電車を降り、観光客とは逆に進行方向右に折れると、竜谷大学と向かい合って京都府警察学校がある。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら、傍で見ていたアメリカの観光客の一人が、自分もその通りに仰向きに寝て撮ってみてるの。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の観光客なら聖地を冒涜でもするやうに怒り出す所かも知れない、そこを反つて興じたわけなのであらう。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来の支那は観光客のために歴代何一つしなかった　葬式されずにころがっている人々の死骸さえかたづけなかった。",
              "citation": {
                "source": "観光について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て、市長が荘太玄を訪ねて来まして、市長に推挙されかかったこともある彼に、北京繁栄策をいろいろ話し、ついでに、名所旧跡や記念建造物への観光客を世界各地から誘致するための、有効な方法をも相談しました。",
              "citation": {
                "source": "白塔の歌",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、紅葉の季節なので、観光客が雑沓していて、興ざめの感じがした。",
              "citation": {
                "source": "山上湖",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この平和世界の始まりの記念塔としても、あの不ざまな沈没艦は観光客によろこばれているのです」「なるほどねえ」　僕はしみじみと昔を思い出した。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、市場、ホテル、料理店、街角、音楽会、今の伊太利は、もとの乞食のかわりに、憲兵と、売子、観光客、給仕人、花売りなんかに化けた密偵とで、隙間もなく覆い尽されているのです。",
              "citation": {
                "source": "踊る地平線",
                "author": "長靴の春",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある有名な湖のほとりにある温泉町に宿をとった時のこと、バスがその町にさしかゝると、すぐ眼についたのは、観光客歓迎の宣伝塔である。",
              "citation": {
                "source": "北海道の性格",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでカッポも一口しか味わうことができなかったが、観光客は国見の丘という風景のよいところでカッポ酒をのんで刈干切り唄という土地の唄を実演入りで聞くことになっているらしい。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "カッポ酒がいかに観光客にうけているかということは、この国見の丘という神話の地に大そう近代的な公衆便所ができていることで察せられたのである。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "観光客へのサービスのために国見の丘という聖地にコンクリの便所を設けることにも一向に不都合を感じておらぬのである。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自殺者と、それをめぐる観光客の殺到によって、島民はうるおい、米も食えるし、内地なみに暮せるようになったという。",
              "citation": {
                "source": "安吾巷談",
                "author": "湯の町エレジー",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿寒の雄大な景色で観光客を云々などと気楽なことをいっていてもはじまらないということがよく分った。",
              "citation": {
                "source": "アラスカ通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いそがしいのでつい忘れるが、フレッドさんはチャイナ・クリッパアで日本へフジヤマを見に来たのんきな観光客じゃない。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがいったん無形文化財に指定されるや、全国の心なき観光客がワンサと押しかけてきて、いよいよおばの記憶をこんらんしたようである。",
              "citation": {
                "source": "おば金成マツのこと",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
