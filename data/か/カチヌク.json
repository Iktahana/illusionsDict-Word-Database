[
  {
    "uuid": "bb2d5346-2c53-5bb4-bb80-bd6069cc144f",
    "entry": "勝ち抜く",
    "reading": {
      "primary": "かちぬく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
        "動詞-自動詞"
