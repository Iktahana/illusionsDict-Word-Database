    "definitions": [
      {
        "index": 1,
        "gloss": "(home) tutor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "期末試験が近いので、苦手な数学を家庭教師に見てもらうことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は大学時代、家庭教師のアルバイトで学費を稼いでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "英語のリスニング強化のため、ネイティブの家庭教師を探している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私は大学へはいってゐて、家庭教師にやとはれてゐたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時フランス女の家庭教師がイレエネの息子の、七歳になつて、色の蒼いのを連れて、そこへ近寄つて来た。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は大学へはいっていて、家庭教師にやとわれていたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、綴方の事は、きれいに忘れて、学校から帰ると、花壇の手入れ、お使い、台所のお手伝い、弟の家庭教師、お針、学課の勉強、お母さんに按摩をしてあげたり、なかなかいそがしく、みんなの役にたって、張り合いのある日々を送りました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "後でわかった事ですが、沢田先生は、小学校で生徒の受験勉強の事から、問題を起し、やめさせられ、それから、くらしが思うように行かず、昔の教え子の家を歴訪しては無理矢理、家庭教師みたいな形になりすまし、生活の方便にしていらっしゃったというような具合いなのでした。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は、もともと、家庭教師を呼ぶ事には反対だったのですが、沢田先生のおくらしの一助という名目に負けて、おいでを願う事にしていたのであって、まさか、そんな無責任な綴方教育を授けているとは思いも寄らず、毎週いちど、少しは和子の学課の勉強の手伝いをして下さっているものとばかり思っていた様子でした。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は大學へはいつてゐて、家庭教師にやとはれてゐたのです。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ訊きたいわ」「何でもないさ、東京近くのこの温泉なら先生の弟子だといってちょっと楽器を掴んでみせれば、座敷や家庭教師の口はいくらでもある。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどおれのうちでは、子供が四人できて、それに家庭教師がなくて困っているところなんだ。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴雄が山吹教授に電話を掛けることを思いついたのは、山吹教授の訳した「アメリカとは何ぞや」の本を見つけたためだったが、実に鶴雄は、学校が休暇になる前、山吹教授に、「どこか、住込みで家庭教師の出来る家はないでしょうか」　と頼んで置いた――そのことを想い出したからであった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "住込みの家庭教師になろうと思ったのは、もう先斗町の家にいたたまらなかったからである。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――この間お願いしました……」「ああ、家庭教師のこと……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――梶鶴雄君は小生の教え子にて、学力優秀、品行方正にて家庭教師として最適の人物と愚考仕り候わば、宜しく御引見の上御採用下され度く願い上げ候……。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、あんた、幹男の家庭教師になりにいらしたのね」「ええ」「幹男、来年三高を受けるんだけれど、あの子ちっとも出来ないのよ、たぶん落第だと思うわ」　宮子はそう言って笑ったが、ふと狼狽したように、あわててつけ加えた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――あの家には出戻り娘がいるからね」　だから、美少年の鶴雄を家庭教師に推薦するのは、躊躇されるね――と山吹教授が言うと、スタンダールの「赤と黒」の訳者の桑山竹夫が、「つまり、ジュリアン・ソレルかね。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあに、家庭教師に雇われて来たんだよ」「ふーん。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところが、おれは芸者や舞妓を道具に使って儲けた金で悠々と飯を食ってるじゃないか」　だから家庭教師になろうとしたのだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時五歳の私に彼女は源氏物語の桐壺の巻を「何れの御時にか、女御更衣数多侍ひ給ひける中に……」と読ませて、私は何の意味も判らないながら、養育母兼家庭教師である彼女の字に真似て実語経の一節や、万葉集の歌を万葉仮名で書き始めた。",
              "citation": {
                "source": "私の書に就ての追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄弟は父が現代教育の方針に不満といふ理由で、一人は中学を、一人は高等学校を、途中から退学させられて、通つて来る二三人の家庭教師に就かされてゐるが、実は父が家庭に於ける享楽生活に手不足を来すのを、父は極力嫌つたためでもあつた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その部屋では、上品な洋服の、青白い顔をした十歳くらいの男の子が、だらし無く坐ってもぐもぐ菓子を食いながら、家庭教師に算術を教えてもらっていた。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭教師のほうは、二十七八の、白く太った、落ちついている女性で、ロイド眼鏡を掛けていた。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、きのう迄、良家の家庭教師だったんだぜ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから此の人達を家庭教師にしてフランス語の練習です。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間、他所でお会いしたときに、私働きたいって、お話ししたら、ちょうどあの方のお兄さんが、家庭教師を探しているんですって、日曜だったら兄もきっと家にいるから、一度会いにいらっしゃいって、おっしゃって下さったのよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に来ていた家庭教師の方は、義姉があまりに、家庭教育ということに、理解がないと云って憤慨して出てしまったのよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、家庭教師などいう仕事も、決して生やさしいものではないとつくづく思った。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭教師の候補者などには、そうやすやすとは会わないという肚だろうか）そんな邪推が、新子の心に、ようやく萌し始めた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、家庭教師として、家へ来て頂くとすれば、路子さんのお友達だからといって、ご遠慮ばかりしていられないところも、出来ますから。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が、働かないと、だんだん家中干ぼしになる怖れあり、貴君は家庭教師など、不賛成かもしれませんが、どうかあしからず。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
