    "definitions": [
      {
        "index": 1,
        "gloss": "rash",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭の手入れをするときは、ウルシの気触れが怖いから長袖長ズボンに手袋が必須だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この腕の赤み、もしかして湿布の気触れじゃない？」「あ、貼ったところがちょうど四角く腫れてる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "化粧品を新しいものに変えたら顔に気触れが出てしまって、しばらくは外に出るのも億劫だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私もちよいちよいかうして陸に上つて來たお蔭で、陸上生活に少しかぶれて、それこそ聞いたふうの批評なんかを口にするやうになつて、どうもこれはとんでもない惡影響を受けたものだと思ひながらも、この批評癖にも、やめられぬ味がありまして、批評の無い龍宮城の暮しにもちよつと退屈を感ずるやうになつたのです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」狸はいまは破れかぶれになり、「後生だから手を放せ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、こうなったら、やぶれかぶれ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかわざとらしい所や、衒氣的の象徴かぶれがあるので私は好みません。",
              "citation": {
                "source": "ふつくりとした人柄",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）「おい親友、鉄カブトかぶれよ、危ねえぞ」「何言ってやんでえ　可笑しくッて鉄カブトが冠れますかッてンだ」「鉄砲の弾丸は頭ばかり当たるッて訳のもんでもあるめえ、手に当る事もありゃ足にも当らア鉄のテッ甲脚絆でもはめてきアがれ」○帽子の中へ写真を入れて置く兵隊。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国の文化にかぶれたものが、もう一遍立帰って来たときに始めて日本固有の文化の善い所が新しい眼で見直されるということもあるかもしれないのである。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火渡り宮沢賢治竜王の名をしるしたる紺の旗黄と朱の旗さうさうと焔はたちて葉桜の梢まばゆし布をもてひげをしばりし行者なほ呪をなしやめずにくさげに立ちて見まもる軍帽をかぶれる教師",
              "citation": {
                "source": "火渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手がやり出せば、やぶれかぶれだ、畜生！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆んど破れかぶれに其の布を、（もはや着物ではありません。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は高等学校一年生の時に、早くもお洒落の無常を察して、以後は、やぶれかぶれで、あり合せのものを選択せずに身にまとい、普通の服装のつもりで歩いていたのであるが、何かと友人たちの批評の対象になり、それ故、臆して次第にまた、ひそかに服装にこだわるように、なってしまったようである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おゝ娘たち、（町の人形どものやうに、手数を食った馬鹿げた着物を着ないでも、）お前たちはひときれの白い切をかぶれば、あとは葡萄いろの宵やみや銀河から来る鈍い水銀、さまざまの木の黒い影やらがひとりでにおまへたちを飾るのだ。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーシュはやぶれかぶれだと思ってみんなの間をさっさとあるいて行って向うの長椅子へどっかりとからだをおろして足を組んですわりました。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに欄干を附けたものか附けないものかと色々工夫したが矢張り附けないほうが自然だというんで附けないことに定めました……まア構造はこんなものですが、僕の想像はこれで満足しなかったのだ……先ず冬になると……」「ちょッとお話の途中ですが、貴様はその『冬』という音にかぶれやアしませんでしたか？",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「殖産」という流行語にかぶれてついに破産してしまった。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "中　十二月に入ると急に寒気が増して霜柱は立つ、氷は張る、東京の郊外は突然に冬の特色を発揮して、流行の郊外生活にかぶれて初て郊外に住んだ連中を喫驚さした。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "……貴様このカアライルにでもかぶれているととんだ間違いになるぜ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "救いに絶望してやぶれかぶれに享楽にしがみついて居る自分の姿が浅間しいものに顧みられた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと見ると破れかぶれの歌にも見えますけれどもそうではありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は以上の友のどの思想にも趣味にもかぶれて居ません。",
              "citation": {
                "source": "智慧に埋れて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには用意がなければならず、覚悟もしないじゃ出来まいが、自分へ面当なら破れかぶれ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、破れかぶれ、何を隠そう。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「破れかぶれは初手からだ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か、かぶれでもしやしないかしら、螢だと思ったものの、それとも出合頭に、別の他の毒虫ででもありはしないかと、一度洗面台へ行って洗いましたよ。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何うした事か、今年は夏帽子が格安だつたから、麥稈だけは新しいのをとゝのへたが、さつと降つたら、さそくにふところへねぢ込まうし、風に取られては事だと……ちよつと意氣にはかぶれない。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "破れかぶれよ、按摩さん、従兄弟再従兄弟か、伯父甥か、親類なら、さあ、敵を取れ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三十七）　お葉を追い捉えた重太郎は、定めて破れかぶれの乱暴を始めるかと思いの外、彼は矢はり温順い態度であった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻の真紀子が姦通していることを、たった今はじめて知ったという苦悩が、小郷をやぶれかぶれの情欲のるつぼへ陥し入れてしまったのだろう。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
