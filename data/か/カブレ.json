        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は海外ドラマに気触れて以来、急にアメリカ人みたいな大げさなジェスチャーで話すようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あいつ、また小難しいカタカナ語ばかり使って……」「完全にコンサル気触れだな、あれは。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都会の華やかな生活に気触れてしまったのか、あんなに好きだった故郷の風景を退屈だと言う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
