    "definitions": [
      {
        "index": 1,
        "gloss": "merciless",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ああっ、教授の仮借なき赤ペンで、提出したレポートが真っ赤っかだよ……」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ひえっ、あの審判、ファウルに対して仮借なき厳格さだね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は裏切り者に対して仮借なき報復を行い、組織内での地位を確固たるものにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "六月にはいると、盆地特有の猛烈の暑熱が、じりじりやって来て、北国育ちの私は、その仮借なき、地の底から湧きかえるような熱気には、仰天した。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「戦争と革命との新たなる周期」において、文化運動の内部に発生したこのような敵に対して、仮借なき闘争こそが必要である。",
              "citation": {
                "source": "同志小林の業績の評価に寄せて",
                "author": "――誤れる評価との闘争を通じて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "このたびの決議のレーニン的基礎づけ、思想的基礎づけの半ばは、同志小林が全力を傾けて実践した日和見主義との仮借なき闘争の成果によって行われたと云っても過言ではないであろう。",
              "citation": {
                "source": "前進のために",
                "author": "――決議によせて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそれだけに吾々は、議会に於ける政党の自由本然の仮借なき言論を要求することが出来るわけだ。",
              "citation": {
                "source": "思想議会たるを知れ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペテルブルグの気候の仮借なき援助によって、病勢が予想外に早く昂進したため、医者は来たけれど、脈をとってみただけで、如何とも手の施しようがなく、ただ医術の恩恵にも浴せしめずして患者を見殺しにしたといわれないだけの申し訳に、彼は湿布の処分を書いただけであった。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれらの武器は、もはや、戦争を終熄させるためにではなく、仮借なき人間殺戮のために、全面的破壊のために使用されるだろう。",
              "citation": {
                "source": "ヒロシマの声",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮借なきということの意味、仮借なき自己批判という場合にも明らかなように、政治的に妥協せぬ意味、プロボカートルが組織を腐敗させ、方針を歪め、損傷を与えるのみならず検挙後も偽りの陳述、中傷等によって罪悪を重ねるのが特長である。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、その個人の裡に常に宿っていた秘密の仮借なき凝固であり永久化であるのだ。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏が晩年に及んで、あの冗長な私の旧作「法成寺物語」に仮借なき削除を施され、独特の解釈を以て築地小劇場の舞台に上場され、原作者の想到し得なかつた優秀な演出をされたことを思へば、氏も亦後には私に対して昔のやうな温情を抱かれ、再び師匠の態度を以て私の作品に臨まれたのであらう。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷酷無残な人情と、仮借なき法の運用に対する反抗は、昔から小説のよき題材ではあるが、わけてもヴィクトル・ユーゴーの『レ・ミゼラブル』は代表的で、法の冷たい執拗さの影に、人間の果敢なさ弱さを強調したものである。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "捕物小説というもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も多く知力をそなえた者から知力を奪い去り、最も善良な者から善良さを奪い去るかの観がある、その仮借なき徳操、その狭小な心は、彼を苛立たせ、彼を傷つけ、反発心によって彼をより放恣な生活に投げ入れたのである。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、最後まで突進して、たとい苦しみを受けようとも、事物の真相を見きわめんと欲する、誠実な魂の仮借なき本能には、どうして抵抗することができよう？",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽は魂の仮借なき鏡である。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは怜悧な面白いりっぱな人々ではあったが、孤立してるために往々逆説に傾きやすく、また仲間だけで言論する習慣のために、仮借なき批判と饒舌とに傾きがちだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は多くの外国人と同じく、自分が出会った二、三の類型によって得た仮借なき意見を、フランス婦人全般に押し広げてしまった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のうちにまた彼の上に司教からともされた仮借なき光明が、盲目ならんと欲する彼を強いて眩惑さしたことも、幾度であったろう。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからわたしは、ウェヌスを、わたしよりも純潔な多くの人々が証言するほどに、仮借なき女神であるとは少しも思わなかった。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の過去、彼の現在、彼の未来、彼の仮借なき原理、彼の快楽信仰、その思想が彼に反世間的態度を与えたところの闇の王国、彼の行動、あらゆる場面で示された組織力。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついには戴宗も答えにつまり、階から庭へ蹴落されたあげく、仮借なき拷問に責めさいなまれた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたんに仮借なき父の稽古槍は、亀一の肩を烈しく突いた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "布教にくるばてれんも、それをたずねて日本へ渡った者も、幕府の宗門役人からみれば、みな同色な異国人、見つけ次第に十｜字架を背負わせて、仮借なきサビヤリを加えた数は、かの切支丹鮮血遺書やその他の殉教史が示すとおりであります。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、対手は龍耳老人、かなわぬまでもと、見返りお綱の捨て身に斬ってかかる刃は、二度まで、三度までむなしく空を打たされて、なぶるがごとく後ろへよろけると、「――汝もかッ」　と、仮借なき杖はふたたび持ちなおされて、お綱の新藤五を一撃に叩きおとした。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "剣山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮借なき武士たちは、ひとたび命をうくるや、馬謖を拉して轅門の外へ引っ立てたちまちこれを斬罪に処そうとした。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、光厳のみかどすらも、ひだりの肘に一矢をうけて、鞍つぼを鮮血に染められていたし、まわりの女房輿にも、仮借なき矢がブスブス立って、みかど同様、駒の背にお姿をさらしている法皇、上皇など、もちろん、お人心地もないすがたであった。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
