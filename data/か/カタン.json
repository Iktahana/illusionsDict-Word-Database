[
  {
    "uuid": "ee5d8669-b66b-58dd-996d-be5e9a41c15c",
    "entry": "下端",
    "reading": {
      "primary": "かたん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
