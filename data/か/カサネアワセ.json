        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "物理学では、波の「重ね合わせ」が基本原理の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この画像は、二つの異なる写真を「重ね合わせ」て作られたものらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "複数の要素の「重ね合わせ」によって、複雑な模様が生まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてそれを一枚一枚写真にとって、そのおのおのを重ね合わせて重ね撮り写真をこしらえる。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　翁は張盤の前に正座した時、必ず足の拇指を重ね合わせていた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "多重露光してイメージを重ね合わせると、フィルムの上に見たこともない新しい映像の世界が育ちはじめます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの挑戦を受けた側は、自らの覇権に対する脅威を、文明と自由と個人の尊厳の危機に重ね合わせてとらえた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＣＰＵのクロック・スピードが支配する音の重ね合わせには、乗る気もないし聴かされるのもまっぴらだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の人々は、この政治的價値と藝術的價値とは二つの直線のように、全く重ね合わせることができると考えるのである。",
              "citation": {
                "source": "政治的價値と藝術的價値　マルクス主義文學理論の再吟味",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしほとんどの日本人は、ＮＥＣの三文字に日電の子会社、新日本電気の家電製品のイメージを重ね合わせていたはずである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面を単純に複数のウインドウに分割するだけのタイリング方式も試みられたが、ウインドウの大きさを自由に設定できて、重ね合わせることのできるオーバーラッピングウインドウを考案し、スモールトークに組み込んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "無線通信に用いる電波の周波数を上げ、いくつもの信号を重ね合わせて大量の情報を送ろうとするマイクロウェーブ多重通信は、当時の日本電気にとって華だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルトのディスプレイ上にウインドウが重ね合わせて開かれ、アイコンが操作され、ワードプロセッサーの文章中の書体が自由に変更される様を凝視していたビル・アトキンソンは、文字も含めたすべての要素をグラフィックスとして扱うというリサの方向付けが正しかったことを、あらためて確信させられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本は各点の色を決めるにあたって、画面と同じ解像度を持ったプレーン（面）を複数用意し、それぞれの色の重ね合わせによって表現する方式をとれば、書き換えの動作を高速化できるのではないかと考えた★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが同じ四ビットで一六色を表現するにしても、それぞれは一ビットのプレーンを四枚用意して重ね合わせる方式をとれば、各プレーンへの読み書きを同時並行して行うことで処理速度を稼げるだろうとの発想から、この方式が考案された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マックではウインドウを重ね合わせ、前後を自由に入れ替えてその時点で必要なものを大きく表示できたのに対し、Ｗｉｎｄｏｗｓ１・０は画面を縦横の線で仕切っただけの、重ね合わせのできない窓しか提供できなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロソフトはその後、一九八七（昭和六十二）年十二月にはウインドウの重ね合わせを可能にしたＷｉｎｄｏｗｓ２・０の発表を行った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌にはツイ私が今さっきまで着ていたのとおんなじ白木綿の患者服を着て、胸にかけた白毛布の上に、新しい繃帯で包んだ左右の手を、行儀よく重ね合わせているところを見ると、今朝早くから壁をたたいたり呼びかけたりして、私を悩まし苦しめたのは、たしかにこの少女であったろう。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事件の内容というのは偶然に離れ離れに起った、原因不明の出来事の色々を、一つに重ね合わせで覗いたものに過ぎないのだ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それを二人の博士が感違いをして、無理に一枚に重ね合わせて、一つの焦点を作ろうとしているのだ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる疑問を重ね合わせた最後の疑問の焦点となるべき、唯一点を発見して私と同じようにビックリしたに違いない。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その暗渠の上を通り越すと彼は、いつの間にか線路の上に歩み出している彼自身を怪しみもせずに、今まで考え続けて来た彼自身の過去の記憶を今一度、シンシンと泌み渡る頭の痛みと重ね合わせて、チラチラと思い出しつづけたのであった。",
              "citation": {
                "source": "木魂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さーン」　と呼びかける頬ペタの赤い太郎の顔や、その太郎が汲込んで燃やし付けた孫風呂の煙が、山の斜面を切れ切れに這い上って行く形なぞを、過去と現在と重ね合わせて頭の中に描き出すのであった。",
              "citation": {
                "source": "木魂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と疑い迷っているうちに、又もグッタリと寝台の上に突っ伏して、重ね合わせた手の甲に額の重みを押し付けたのであった。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "重ね合わせてあッたのは吉里の写真である。",
              "citation": {
                "source": "今戸心中",
                "author": "広津柳浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗さという暗さを幾層にも重ね合わせたように、しぶとい暁前の闇が行手を遮っているのだった。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――手紙類を、大使館気づけで受けとるようにして来たから……」　秋山宇一は、黙ったままそれをききながら小柄な体で、重ね合わせている脚をゆすった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶色の斑点の無数に浮かんだ、しわだらけの両手を、かさねあわせている。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして資本主義と民主主義とをかさねあわせたため、いまのアメリカの保守的な独占資本主義ができあがった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブレーキングをかさねあわせ、カーブ進入のための減速を完了させる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにかさねあわせて、椅子にすわったままのナミが、うたった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのポストは、たくさんのうすい金の輪を、かさねあわせてつくったもので、ちょうど手品師の持っているステッキのように、自由にのびたり、ちぢんだりするのです。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
