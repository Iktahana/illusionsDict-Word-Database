        "examples": {
          "standard": [
            {
              "text": "昔の浮世絵には、時々中国から来たという立派な唐猫が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの丸っこい顔立ち、どことなく唐猫っぽいね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "伝説によると、その寺には不思議な力を持つ唐猫が住んでいたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最近、インターネットで唐猫をモデルにしたグッズを見かけたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "あとで東宮は淑景舎の方の手から所望をおさせになったために、女三の宮から唐猫が献上された。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "口を開き、頬に皺を溜めて歯をむき出しながら、何かわけのわからねことをぶつぶつ喋った。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は立ちあがって、三度、十字を切り、腰かけの下からねこを引きだして、カバンの中へ入れた。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの子が……もう早くからねこんでいるかい」「いいえ、つい十五分ほどまえねたばかりです。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
