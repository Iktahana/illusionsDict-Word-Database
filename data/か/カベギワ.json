[
  {
    "uuid": "63bd62e0-b2f8-5cbc-905e-4a4ff68fcc3c",
    "entry": "壁際",
    "reading": {
      "primary": "かべぎわ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
