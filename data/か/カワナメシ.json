        "examples": {
          "standard": [
            {
              "text": "この革製品は、伝統的な皮なめし製法で作られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "皮なめしの工程は、時間と手間がかかるが、革の質を大きく左右する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "工房では、昔ながらの皮なめし技術を学べるワークショップが開催されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「――ドイツのね、ヨゼフ・ディーツゲンという人は、やっぱり皮なめし工という、手工業労働者だったんだ」　しばらくだまっていた倅が、とつぜんそんなこといいだすと、母親は手をやめて、きょとんとした。",
              "citation": {
                "source": "白い道",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、ビールの不正な醸造者がポーターやエールに中枢神経の興奮性を与えるために使うコクルス・インディクス（Cocculus indicus：有毒物質ピクロトキシンを含む）は市場で黒抽出物（black extract）として知られていて、表向きには皮なめし業者や染色業者のためということになっている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
