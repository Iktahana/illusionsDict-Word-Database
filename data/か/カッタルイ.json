        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あー、今日の会議、話が長くてかったるいな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このかったるい雰囲気をなんとか変えたいんだけど、いいアイデアがない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "同じことの繰り返しで、最近仕事がかったるく感じられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
