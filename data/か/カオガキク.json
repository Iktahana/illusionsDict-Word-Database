        "examples": {
          "standard": [
            {
              "text": "彼は役所に顔が利くので、手続きがスムーズに進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あのベテラン営業マンは、業界の重鎮たちに顔が利くらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "困ったときは、顔が利く先輩に相談してみるのが一番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "松島も次第に商売の骨もわかり、周旋屋の手に載せられるようなどじも踏まず、子供を使いまわすことにも、特得の才能が発見され、同業にも顔が利くようになった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の言つているのは、君が毛利さんのすゝめを無にして水谷先生の方をうつちやる事になれば、毛利さんだつてあんまり良い気持はしないだらうし、もともと毛利さんは好文堂では仲々顔が利くらしいから、君のそつちの方の仕事もまづくなるんぢやないかなあ？",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "立派なもんだな」「官員さんだもの」　トムは顔が利く。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
