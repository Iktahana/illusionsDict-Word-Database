        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このソフトウェアの次期バージョンでは、待望の機能拡張が行われる予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "事業を海外に拡張するため、現地法人を設立した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "子供部屋が手狭になったので、家の裏に部屋を一つ拡張することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この道路は交通量が増えたため、片側二車線に拡張される工事が進んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      }
