        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "職人は真っ赤に熱した鉄を金敷きの上で力強く叩いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "博物館には、古い鍛冶屋で使われていた金敷きが展示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "金敷きから響く金属音は、村に活気を与えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の家業は代々続く鍛冶屋で、庭には大きな金敷きが置かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "かなしきものまにや、のぞみうしなひ、いつさいより靈智うしなひ。",
              "citation": {
                "source": "偏狂",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "波宜亭少年の日は物に感ぜしやわれは波宜亭の二階によりてかなしき情感の思ひにしづめり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのが心も魂も、忘れはて棄て去りて悪酔の、狂ひ心地に美を索むわが世のさまのかなしさや、おのが心におのがじし湧きくるおもひもたずして、人に勝らん心のみいそがはしき熱を病む風景ばかりかなしきはなし。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよかなしきわが心いはれもなくて拳する誰をか責むることかある？",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫を飼はゞ、その猫がまた争ひの種となるらん、かなしきわが家。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより、これは諷刺に非ず、格言に非ず、一篇のかなしき物語にすぎず、されど、わが若き二十代の讀者よ、諸君はこの物語讀了ののち、この國いまだ頑迷にして、よき通事ひとり、好學の白石ひとりなきことを覺悟せざるべからず。",
              "citation": {
                "source": "「地球圖」序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　友はみな、僕からはなれ、かなしき眼もて僕を眺める。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、けれども友は、ただかなしき眼もて僕を眺める。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長女は、かれのぶっとふくれた不機嫌の顔を見かねて、ひとりでは大人になった気でいても、誰も大人と見ぬぞかなしき、という和歌を一首つくって末弟に与えかれの在野遺賢の無聊をなぐさめてやった。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "波宜亭少年の日は物に感ぜしやわれは波宜亭の二階によりてかなしき情歡の思ひにしづめり。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなれば故郷のひとのわれに辛くかなしきすももの核を噛まむとするぞ。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の日空に輝やきて、無限にかなしき橋なり。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉　　かなしき旅の法螺吹きよ。",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥右ヱ門は真黒になつて、親方と向かひあつて立ち、てんとんと、かなしきの上をたたきました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなしきの上では強い見事な刀やなぎなたができていきました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "長女は、かれのぶっとふくれた不気嫌の顔を見かねて、ひとりでは大人になった気でいても、誰も大人と見ぬぞかなしき、という和歌を一首つくって末弟に与え、かれの在野遺賢の無聊をなぐさめてやった。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、いま、自らすすんで、君がかなしき藁半紙に、わが心臓つかみ出したる詩を、しるさむ。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "世に武家の義理ほどかなしきは無し。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右衛門も感傷にたえで、「ありあけの月は袂にながれつゝかなしき頃の虫の声かな」と返している。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "君も若し萬一不幸にして予と共に病院を休息所とするの、かなしき願望を起さねばならぬことが今後にあるとするならば、その時はよろしく予と共にあまり重くない慢性腹膜炎を病むことにすべしである。",
              "citation": {
                "source": "郁雨に與ふ",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "向日葵の日に蒸すにほひ、かはたれのかなしき怨言ゆるやかにくゆりぬ、いまも絶間なき火のささやきに。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "色ふかき、ミラノのそらは日本のそれと似たれど、ここにして摘むによしなき素馨、海のあなたに接吻のかなしきもあり。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "また思ふ、柑子の店の愛想よき肥満たる主婦、あるはまた顔もかなしき亭主の流す新内、暮れゆけば紅き夜の灯に蒸し薫ゆる物の香のなか、夕餉時、街に入り来る旅人がわかき歩みを。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい客を待つ間、やすらかな五｜分時が過ぎゆく……四十三年六月　　畜生やはらかにかなしきは畜生のこころなれ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれ、かかる日に病みて伏すやはらかにかなしき畜生の捉へがたき微温の、やるせなきそのこころ……四十三年六月　　隣人隣人は露西亜の地主のごとく、素朴な黒の上衣に赤木綿のバンドを占め、長靴を穿き、禿げた頭のきさくから他の畑を見回る。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は世にもまめやかに、心やさしくて、かなしき女の身の上になにくれとなき温情を寄するに似たり。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十五年四月　　白い月　　　　わがかなしきソフイーに。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづこにかいづこにか揺曳ける絃の苦悩の………『……ああはれ、よしなや、われらがゆめぢ、　　　　　　　かなしきその日の接吻にも………』緩るやかにねぶたき砥石。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "『……かなしきその日の接吻にも、　　　　　　　さまたげ難かる「我」のほこり、　　ひたぶる抱きて涙すれど恐怖と苦悩の………』さあれなほものうき砥石。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
