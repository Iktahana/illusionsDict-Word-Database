        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "実験の客観性を保つため、観察者は被験者の行動に一切介入してはならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「私はただの観察者ですから、皆さんの議論を自由に続けてください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "量子力学の世界では、観察者が測定を行うことで粒子の状態が確定すると言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしまた、西鶴のような頭のいい観察者が、真の武士道の中の美点をも認めることが出来なかったとは想像されない。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の好色物に現われた性生活の諸相の精細な描写記録は、この人間界の最も深刻な事実を事実として客観的に集輯したものであるには相違ないが、彼がそういうものを著述する際における彼の態度が、果して動物の観察者が動物の生活を記載する場合と同じものであったかどうかは疑問である。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画を見ることによって吾々は凡庸な観察眼の代りに異常に鋭い観察者の眼を獲得することになる。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "津々浦々に海の幸をすなどる漁民や港から港を追う水夫船頭らもまた季節ことに日々の天候に対して敏感な観察者であり予報者でもある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ冷静な観察者となって自然の選択淘汰の手さばきを熟視するほかはないようにも思われるのである。",
              "citation": {
                "source": "俳句の型式とその進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "観察者の頭が現象の中へはいり込んで現象と歩調を保ちつついっしょに卍巴と駆けめぐらなければ動いているものはつかまえられない。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は彼の独特なのに敬服しながら、そのあまりに精細過ぎて、話の筋を往々にして殺して仕舞う失敗を歎じた位、彼は精緻な自然の観察者である。",
              "citation": {
                "source": "『土』に就て",
                "author": "――長塚節著『土』序――",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人哲学者は無論ヒユーマニチーの観察者ならずんばあらず、然れども吾人は恐る、民友子の「観察論」の読者には、或は詩人哲学者を以て単に人性人情の観察者なりと、誤解する者あらんことを。",
              "citation": {
                "source": "内部生命論",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来の諸作は分明に紅葉をして細微なる人情の観察者たらしめ、露伴をして逸調の奇想を吐く者たらしめたるに、不思議にも「伽羅枕」及「新葉末集」に至りて、両家の意匠の、其外部の形式の如何に拘らず、陰然相似たる所あるが如し。",
              "citation": {
                "source": "「伽羅枕」及び「新葉末集」",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし俳句ではたとえ形式の上からは自分の感情を直写しているようでも、そこではやはり、その自分の感情が花鳥風月と同様な一つの対象となっていて、それを別の観察者としての別の自分が観察し記録し描写しているように感ぜられるものが多い。",
              "citation": {
                "source": "俳諧瑣談",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリイのやうな大都会にはこの両面があつて、吾々のやうな局外の観察者には無限の興味を感ぜさせるのである。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにおいてもまたヨブ記作者の優秀精到なる天然観察者なることを知るのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし聡明な観察者となれないまでも、注意深い観察者となって世間の実際を見渡したならば、我々は忽ち一ツの大きな急所を見出すことが出来るだろう。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "注意深い観察者となって世の中を見渡すことは最良の教えを得る道である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "福田氏は鯉の研究者としても大したものだといふ、鯉といふ魚類の生物学的研究者であるか、或は観察者としての研究者であるかその点は語らない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "この『漣』は全く科学的な根拠と一致してゐるといふことは、福田氏が科学人であるか、或は観察者としての徹底的態度が、偶然にもこの作品を産み出したのであるか、その何れであるか、その解明も興味ふかいものがある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しそれらを掴むのが不可能のことならば、公平な観察者鑑賞者となって、両極の持味を髣髴して死のう。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両極の観察者になろうとした時、私の力はどんどん私から遁れ去ってしまったのだ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから少し綿密な観察者は、智と情との間に、情と意志との間に、又意志と智との間に、判然とはその何れにも従わせることの出来ない幾多の心的活動を発見するだろう。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シエーキスピアの作品には、どれを見ても、シエーキスピアの個人性が深くきざまれてゐて、注意深い観察者には、それがはつきりと感知できるであらう。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちマダムは、もっとも優れたる心理表現の観察者たるべく、その基礎的練習をはじめられました。",
              "citation": {
                "source": "奥様探偵術",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "後の意識より前の意識を見た時、自己を対象として見ることができるように思うが、その実はこの自己とは真の自己ではなく、真の自己は現在の観察者即ち統一者である。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間性のひき上げてとしての人間性観察者・批判者としてのインテリゲンツィアの意義と任務とを、漱石は作品の裡に強烈に描き出した。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学教育のことが云われるからには、有益な科学の原理的な知識とともに、無私なよい観察者としての能力と、独創性を発揮するに足りるだけの周密、動的な推理の力とを二本の脚とする科学の精神が、あらゆる男女の心に培かわれてゆくことを願っていいのであろうと思う。",
              "citation": {
                "source": "科学の精神を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
