[
  {
    "uuid": "4fc5e1bc-751a-50f8-960c-29d7eb4dac53",
    "entry": "勧告",
    "reading": {
      "primary": "かんこく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
