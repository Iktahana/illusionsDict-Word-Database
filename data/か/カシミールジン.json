          "standard": [
            {
              "text": "「市場で出会ったカシミール人の老人が、伝統的な刺繍の歴史について熱心に教えてくれたんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "カシミール人としての誇りを胸に、彼女は故郷の文化や平和を世界に伝える活動を続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "カシミール人の家庭に招かれ、スパイスの香りが漂う温かいもてなしと地元の家庭料理を堪能した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その一つの寺はカシミール人のマホメット教徒の集まる所で、一つはシナ人のマホメット教徒の集まる寺であります。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            }
          ]
        }
