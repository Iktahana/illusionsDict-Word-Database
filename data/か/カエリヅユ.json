    "definitions": [
      {
        "index": 1,
        "gloss": "return of the rainy season",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "梅雨明け宣言が出たと思ったのに、今週は返り梅雨で雨続きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "珍しく8月に入ってから返り梅雨があり、蒸し暑い日が続いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "返り梅雨のせいで洗濯物がなかなか乾かず、困っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "４　しかし、翌朝はきのうと反対に、降りみ降らずみのぬか雨で、また返り梅雨の空もようでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "返り梅雨で庭先はぬかるみでしたから、地上にはかれが歩くのとともに、はっきりとうしろ前をさかしまにはいているわらじの跡がついたのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして秋ぐちにかかる頃になって天気が崩れだし、まるで返り梅雨のように、陰鬱な曇天と雨の日ばかりが相次いで来た。",
              "citation": {
                "source": "彩虹",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
