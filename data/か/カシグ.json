[
  {
    "uuid": "e295ddcc-5252-52c6-b71d-89ebd04ee506",
    "entry": "傾ぐ",
    "reading": {
      "primary": "かしぐ",
      "alternatives": [
        "かたぐ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ガ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to incline toward",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "裏山の斜面が昨夜の大雨で少し崩れた影響で、庭先にある物置の小屋が今にも倒れそうなほど右に傾いでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地盤沈下が進んでいるのか、この路地にある電柱はどれも不自然な角度で道路側へ傾いで見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大雪の重みに耐えかねて、公園の古いフェンスがぐにゃりと内側に傾いでしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "春の日は永や、のどかや、　　前うしろ傾ぐになひや。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "修道院の※あけはなち晩餐なり甜瓜がまろし月の光に修道院こよなく明し燈のつきてこの焼豚の塊の美しさわれ立ちて今は踊らむ月あかり深めば鐘もゆり傾ぐなり月がいい。",
              "citation": {
                "source": "海阪",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "信じられない程滑らかな海、頭上に近く、千古の伝説のように明るく輝く星――そして甲板一杯に部屋部屋の電燈を見せて大きく傾ぐ城のようなタイタニック。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "……雪ぼこりは馬の蹄の下から渦まきかかって来るし、橇も右へ左へ、今にも引っくり返りそうに傾ぐのです。",
              "citation": {
                "source": "かもじの美術家",
                "author": "TUPEJNYJ HUDOZHNIK",
                "note": "青空文庫"
              }
            },
            {
              "text": "フラフラと縁先へ歩いて行き、香しい初夏の前栽へつとその眼を走らせたが、「訳と云うのは他でもない、ここに咲いているこの百合の花、いつも嫋々と首を垂れ、風吹けば揺れ、雨降れば傾ぐ、相手次第でどうともなる……これが妾の今の身の上……お前これでも解らぬかえ？",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの鉄環をグイと引く、すると天井が一方へ傾ぐ、その隙間から這い上がる、上の間道へ行けるのだ。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして岩床が次第次第に、一方へ傾ぐのを見遁がしてはならない。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花子がドサリと横に倒れその重みで船が傾ぐほど揺れて激しい水音が舷側にすると、彼は見る見る狂暴になつた。",
              "citation": {
                "source": "水に沈むロメオとユリヤ",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子の出世で何方かへ傾ぐのである。",
              "citation": {
                "source": "村一番早慶戦",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角入ったんだから、もう諦める方が宜いかも知れない」　と二人はグラついていて、何方へでも傾ぐ。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしぐずぐずしていると、他の教師たちがその部屋にはいってくるのは知れている。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしぐずぐずしていると今につかまってしまうのが目に見えていましたので、皇子は宿禰に向かって、さあ、おまえ、振熊に殺されるよりも、鳰鳥のように、この湖水にもぐってしまおうよ。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀久子は大声に泣いてぶっつけたいような胸を、しかしぐっと引き締めるようにしながら、ふたたび馬腹へ拍車を加えた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギーイときしみながら船が大きくかしぐのにうまく中心を取りながら歩こうとすると、また不快な気持ちが胸先にこみ上げて来るのを葉子は強く押し静めて事もなげに振る舞おうとした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯かしぐゆふべの煙庭に這ひてあきらけき夏の雨は降るなりはちはちと降りはじけつつ荒庭の穗草がうへに雨は降るなり俄雨降りしくところ庭草の高きみじかき伏しみだれたり澁柿のくろみしげれるひともとに瀧なして降る夕立の雨　一日のうちでは朝がいゝ。",
              "citation": {
                "source": "樹木とその葉",
                "author": "なまけ者と雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯かしぐゆふべの煙庭に這ひてあきらけき夏の雨は降るなりはちはちと降りはじけつつ荒庭の穂草がうへに雨は降るなり俄雨降りしくところ庭草の高きみじかき伏しみだれたり渋柿のくろみしげれるひともとに滝なして降る夕立の雨　一日のうちでは朝がいゝ。",
              "citation": {
                "source": "なまけ者と雨",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "知識階級が、それをのむことが出来、それでかしぐことのできるただの水であった、というのが真実なら、むしろこんにちの日本のまじめな人たちは、それを欣快と思うだろう。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此朝の米をかしぐ間の私の幻想は急行列車の中に空想の玩具を積みあげて火花の鎖のやうに燃へて走つて行きます。",
              "citation": {
                "source": "蒼馬を見たり",
                "author": "蒼馬を見たり",
                "note": "青空文庫"
              }
            },
            {
              "text": "両かしぎというのは、左右へかしぐようにつける糸目で、凧の喧嘩には是非これに限る。",
              "citation": {
                "source": "凧の話",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "」七　かかし　かかしぐらいしんぼうのいいものもありません。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしぐっと胆力をすえて、本堂の中へ入ってみた。",
              "citation": {
                "source": "鬼退治",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、ほら、もつとまんなかにいないと、舟がかしぐですよ」　井出康子は、あわてゝ舟べりからひじをはなした。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩というものを作るということは、或る意味で盗まなければならないことだ、小説を書く場合にもまた多くを盗まなければならない、巧みに溶かしてぬすむということは、その詩人なり小説家の、頭の溶かしぐあいと、ぬすむことによって盗んだ十倍も本物を自分から惹き出すことにある。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしぐずぐずしているわけにはいかない。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "視界全体が、大きく左へかしぐ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "トラックのパワーが空気のなかをまっすぐにぼくを直撃し、ぼくの上体が思わず前にかしぐ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶくぶく息を吐き、口から血を流し、上着に垂れ、首がかしぐと、死んでしまった。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆を張れ」　夜は夜で、追い風をうけながら、夜どおし舟もかしぐばかりな帆しぶきを浴びつづけて行く。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
