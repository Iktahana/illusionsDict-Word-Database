        "examples": {
          "standard": [
            {
              "text": "事務所の貸賃は、毎月月末に指定された銀行口座へ振り込むことになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "このコンテナ倉庫の月々の貸賃は、広さの割に手頃で助かる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "契約更新の際に、貸主から来期以降の貸賃の値上げを要求された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "ボオイが、毛布の貸賃を取りにやって来た。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう働いて貸賃を取った三艘の田舟はお秀の母親の手で綺麗に洗われ、涼しそうに横わっています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな不潔で不便でも、貸賃が安く、交通に都合がよいので、大抵の部屋はふさがつてゐるやうだ。",
              "citation": {
                "source": "日本三文オペラ",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い襦袢に白い腰巻をして、冬大根のように滑らかな白い脛を半分ほど出してまめまめしく、しかしちんまりと静かに働いていた。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
