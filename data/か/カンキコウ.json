        "examples": {
          "standard": [
            {
              "text": "部屋の空気を入れ替えるため、換気口を開けておいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "浴室の換気口がホコリで詰まっているようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あのマンションの換気口から、時々タバコの臭いがする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この部屋には換気口が二つあるので、空気がよく循環する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "換気口の新品｜綿網すら、通風を妨害しているような気がする。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "当階の寝室が背中合わせに造られて、間に大きな換気口があるからだ。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "直後、押し殺した声が換気口から聞こえ、ドスンという落下音がした。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがガードンはベッドから起きて隣室を換気口から見ようと決めた。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋭い耳に、いびきのような音がはっきり聞こえたので、換気口に体を半分入れて、何とか隣室の寝台を見た。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちきしょうめ、換気口を通って見てやれ」　難なくガードンのような陸上選手は換気口を通って、隣の寝室まで行けた。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "素早く自室へ戻り、換気口側に立ち、待っていると、隣室から靴音が聞こえた。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃よく半時間おいてから、再び換気口から侵入し、エレベータの隣室へ着地した。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
