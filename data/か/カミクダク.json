        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "複雑な科学的概念を、子供にもわかるように噛み砕いて説明する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この専門書は難解だが、要点を絞って噛み砕けば理解できるはずだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「つまり、こういうことだよ」と、先生は難しい話を私たちに噛み砕いて教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
