        "examples": {
          "standard": [
            {
              "text": "厳しい冬の寒さがようやく影を潜め、庭の梅が蕾を膨らませ始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつての繁華街も今ではシャッターが目立ち、活気はすっかり影を潜めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "警察の取り締まりが厳しくなってから、その界隈の暴走族は影を潜めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「最近、あのうるさかったセミの声も影を潜めて、秋らしくなったねえ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼女の前ではどんな女性も影を潜める、とでも考えているのであろう。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　それから半月経ったある日江戸の街々の甍の上に泳いだ鯉幟が影を潜めると、長い旅に出ていた平次はどこからともなく、神田の家へ帰って来ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "江戸阿呆宮",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
