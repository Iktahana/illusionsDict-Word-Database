[
  {
    "uuid": "2e4d5324-88c3-5eb4-acc1-9ce663efad54",
    "entry": "借り着",
    "reading": {
      "primary": "かりぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
