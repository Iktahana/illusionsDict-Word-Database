    },
    "definitions": [
      {
        "index": 1,
        "gloss": "borrowed clothes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "急なパーティーだったので、友人に借り着を頼むしかなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "舞台衣装は借り着だが、サイズもぴったりでとても気に入っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は借り着とは思えないほど、そのドレスを着こなしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「それでこの人は、おまえとは、おまえの外套を無断で借り着して行くような間柄だったのか？",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ姉の晴れ着を借り着していい心地になっているような叔母の姿も目に映っていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業写真に、私は黒木綿の紋付を着てうれしそうに写っているが、これは下級生の紋付を借り着して行ったもので母もその当時は、卒業出来るのなら工面してでも紋付を造ってやったにと云い云いした。",
              "citation": {
                "source": "私の先生",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高島田に園子の嫁入衣裳を借り着したおしもは嬉しさからすっかり上気てしまって、廊下のあたりや勝手元をうろうろ歩きまわったりした。",
              "citation": {
                "source": "女心拾遺",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず新たに移った乙の波に揉まれながら毫も借り着をして世間体を繕っているという感が起らない。",
              "citation": {
                "source": "現代日本の開化",
                "author": "――明治四十四年八月和歌山において述――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……馬子にも衣裳髪形、借り着でも何んでも晴着をひっかけ、押し出して行ったらあの男、立派な若殿に見えるからなあ」　突然お吉は立ち上がった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　借り着に及んで店へでたが、富子のやうに金銭にやつれてしまふと、借り着まで如何にも借り着といふやうに板につかなくなつてしまつて、心に卑下があるから、その翳がそつくり外形へ現れて、どことなく全てに貧相で落附きがない。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで借り着をした様な着物の着振りから、上の空の様に座って居る座布団付の悪さから、どうしても昨日まで鍬を握って居た男とほか思えない筋肉の異常な発達を見ると始めて、軽い安心仕た様な気持に成った。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は人のモーニングを借り着していたのである。",
              "citation": {
                "source": "小林さんと私のツキアイ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "半蔵はまだ借り着のままだ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　風呂から上がると、お駒は日本一太郎の浴衣を借り着した妙な恰好で、部屋の隅に長くなって眠ってしまった。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、明治年代のことであつたか、大正の初め頃であつたか、その辺の記憶が明瞭を欠くのだが、今も不思議に覚えてゐるのは、その時私は細かい十の字｜絣の対の大島の袷（これは友人の借り着であつた）に、お召の夏袴を穿いてゐた。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は借り着の紋附き袴で、それでなくても自然｜鯱硬張つてゐたところへ、その日瀧田君が私を連れ出したと云ふのが、当時問題の人物であつた私と云ふものを文壇に紹介する一方、附き合ひの狭い私を世間へ出してやらうと云ふ好意があつたことゝ思はれるので、それが私の意識に反映して、一層固くならざるを得なかつた。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そろそろ、はじまった……」　大池のピジャマとガウンを借り着した、しどけないふうな女を、管理人がどんな眼で見て行ったか、久美子にも察しがつく。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやだ、帯をもうそんなにぐたぐたにしてさ……手伝つたげるから締め直しなさい」　初めての借り着で自分ながら思ふやうに着こなせないのを、梨枝子は知らないではないが、今迄着てみたいとも思はなかつた和服をかうして身につけると、なにかしら新鮮な気持がして、つい楽しいのである。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が信じないのはあたりまえだが、君はもうおれにとっちゃアそんな借り着のもんじゃない。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が信じないのは当り前だが、君はもう俺にそんな借り着のもんぢやない。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひろ子は、思わずまだ立ったままでいた自分の位置で借り着の重吉の大きい肩に手をおいた。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯を浴びて借り着の袷になり、酒肴の膳を前に、加平とさし向いに坐った彼は、初めて久方ぶりの挨拶をし、無断で出奔した詫びを云った。",
              "citation": {
                "source": "おれの女房",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は水をあびてさっぱりとし、借り着の帷子でくつろいでいた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたずらに他人の性能を借り着するばかりで、自分の性能はさぼるにまかせている。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "何分、雨に逢って、着物もずぶ濡れだから、一時｜娼家の物を借り着するが、実は今日瀬田の唐橋で約束の者が待っているはず。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん近くになって見ると、ついて居るのはみんな黒ん坊で、眼ばかりぎらぎら光らして、ふんどしだけして裸足だろう。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪やひげは長い間手入れを怠つてゐたので、もぢやもぢやとはえ、そのなかに眼ばかりぎよろぎよろして、悪い人相になつてゐました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐古は豹一がやっとソファの奥深く収ってしまうのを見届けてから、「では御ゆっくり……」と言って、眼ばかりぎょろぎょろ光らせている豹一をそこに残して、立去ってしまった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお主従の礼をくずさない態度も額髪のかかりぎわのあざやかさもすぐれて優美な中将だった。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪の質、頭の形、髪のかかりぎわなどの美しさは西の対の姫君とそっくりであった。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時に、さすがの右門も、おもわず少しばかりぎょっとなりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "巣の中には、目ばかりぎよろつかせた、まだ羽の生えてゐない、へんに不恰好な雛たちが、四五羽塊りあつて、うごめいてゐた。",
              "citation": {
                "source": "巣立ち",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "参謀長のマハン少将は、ところどころ赤く血のにじんだ軍服も破れ、色が青ざめて眼ばかりぎろぎろ光っている。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
