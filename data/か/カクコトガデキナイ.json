        "examples": {
          "standard": [
            {
              "text": "現代社会において、インターネットは欠くことができないインフラとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "チームワークにおいて、信頼関係は欠くことができない要素だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このプロジェクトの成功には、彼の経験が欠くことができなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」五　尤も我々の信ずるところによれば、現実的な歴史の概念は或る自然の要素を欠くことができない。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "かようにして夢と素直と愛とはよき生活が可能なるがために欠くことができない三つのものである。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら真理の意味を実質的に規定しようとするとき、存在の概念は欠くことができないであろう。",
              "citation": {
                "source": "哲学入門",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "責任の倫理は自己の行為の結果に対して責任を負うことである故に、それは知識を欠くことができないのである。",
              "citation": {
                "source": "哲学入門",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにはなお諸異本の精細な対照が必要であり、特に個々の部分についての比較研究を欠くことができない。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおこの修行にとっては、「求道者の団体」すなわち「僧」もまた欠くことができない。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその究極の意義に対する止み難い根本的要求――現世のいかなるものをもってしても結局満たし切られることのない心は、ここに欠くことができない。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜眠ったあとではニュースは朝めしと同様に欠くことができないのだ。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、太刀魚のえさには欠くことができない。",
              "citation": {
                "source": "瀬戸内の小魚たち",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもっと明白に言うと自然科学は知識発展の過程において医学の進歩のために欠くことができないものであり自然科学が方法としての位置を保ち医学が自主性を保つならば常に実りが多かった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
