        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "税関の鑑定官が、持ち込まれた美術品の真贋を慎重に調べている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このワインは、専門の鑑定官によって高い評価を受けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は長年の経験を持つ美術品の鑑定官として、業界で信頼されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "葉煙草の賠償價格は鑑定官の鑑定によつてきまつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に鑑定官が立つ鑑定臺の前の窓は、彼の腰から二間位の高さまで、總ガラス張りになつてゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の鑑定官と一人の書記とが、鑑定臺をはさんで待つ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に傍に立つた二人の鑑定官は、葉の束を一把づつ手に取つて見た。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鑑定官が二人ゐるな正確と公平を期すためちうことになつとるんやからね。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鑑定官がそれほどに熟練してゐるとも云へるが、一つにはまた、鑑定官の一人が主任で、他は從屬的な存在だといふことにもよつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓達は送られて行く荷を見、また鑑定官を見た。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼鏡をかけ髭のある鑑定官はだが彼等の方を見ることはなかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事に敏速であることは鑑定官の生命であり、誇りだつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人のうち若い方の鑑定官に見られる一種の誇張は、彼が人々のさまざまな眼を感じて居り、自分の一擧一動を強く意識してゐることを示してゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、荷が鑑定官の手を離れ量目係の手に移ると、彼等の眼も亦そこへ移つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は鑑定官に對して、自分達の評價を對立せしめずにはゐられない。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ためらひながら向うを見ると、そこに立つ鑑定官の姿といふものは大きく見える。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしておいて彼は鑑定官の方を見た。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鑑定官の前には彼の荷の一つが擴げられてあつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鑑定官の一擧一動は強く彼の注意を惹かずにはゐないが、その時彼の注意をうばつたものはまた特別だつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもはあんなに敏速に一つの荷を捌いて行く鑑定官の手が、容易に今の包を行かしめようとはしないのだつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、主任の鑑定官がわきを向いて、書記に何か云つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　書記はだまつて鑑定官の方を指し示し、自分はもとの席に着いた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七番の男はおづおづと鑑定官の前へ進んで行つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、鑑定官は男を見るなり云つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小供ながら、渠は詩人ゲーテの樣に多方面の學者風であつたが、ゲーテがたしか鑛山技師にもなつたことがある樣に、渠は二十八歳の時、鑛山局の鑑定官になつた。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月下旬に、大蔵省から被害区域と土質分析のために鑑定官数名が調査に出張したが、被害民の実情には、その分析試験の結果を待っている余裕はなかった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
