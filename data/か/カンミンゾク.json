[
  {
    "uuid": "51a33614-d950-51dd-a3b8-42242c505652",
    "entry": "漢民族",
    "reading": {
      "primary": "かんみんぞく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
