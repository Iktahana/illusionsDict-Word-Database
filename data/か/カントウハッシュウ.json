      {
        "index": 1,
        "gloss": "the eight Edo-period provinces of Kanto (Sagami, Musashi, Awa, Kazusa, Shimousa, Hitachi, Kouzuke and Shimotsuke)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
