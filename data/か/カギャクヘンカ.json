        "examples": {
          "standard": [
            {
              "text": "この化学反応は可逆変化なので、生成物から元の物質に戻すことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "理論上は可逆変化だが、実際にはエネルギー損失なしに元に戻すことは極めて難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "氷が水になり、水がまた氷になるのは、身近な可逆変化の一例だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "もしもシステム内のグルタミン酸がこの可逆変化を受けると分子の混合物のすべてのα−水素原子は水と同じ同位体濃度を持たなければならない。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            }
          ]
        }
