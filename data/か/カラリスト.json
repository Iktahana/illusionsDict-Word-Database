        "examples": {
          "standard": [
            {
              "text": "この映画の映像美は、腕利きのカラリストの手腕によるものだと評判だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、長年の経験を持つプロのカラリストとして、多くのクリエイターから信頼を得ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新人カラリストの彼も、個性的な色使いで注目を集め始めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」麻川氏「詩人Ｘ氏は相変らず若くてカラリストだ。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃學校の生徒で、素晴しいカラリストで、すてきな美しい芝居の畫をかく天才だつた。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "漱石は生れつきカラリストだつたやうである。",
              "citation": {
                "source": "知られざる漱石",
                "author": "小宮豐隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
