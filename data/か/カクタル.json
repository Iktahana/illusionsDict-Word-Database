[
  {
    "uuid": "391d9a4a-6fd8-5030-bba0-963c2c28d94c",
    "entry": "確たる",
    "reading": {
      "primary": "かくたる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "連体詞"
      ],
      "ctype": null,
