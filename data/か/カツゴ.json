        "examples": {
          "standard": [
            {
              "text": "日本語の動詞や形容詞は、活用形を持つ活語の代表例だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この文法書では、活用しない不変化詞と区別して、活語の活用パターンを詳しく解説している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「走る」は活語であり、未来形や過去形に変化させることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
