        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「大きな筒状のパスタ、カネロニの中にリコッタチーズとほうれん草をたっぷり詰めてオーブンで焼いたんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「イタリアンレストランで初めてカネロニを食べたとき、そのボリュームと濃厚なソースに驚いちゃった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今日はちょっと凝った料理を作りたいから、手作りのミートソースでカネロニを焼いてみようかな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「カネロニは茹でる手間がかかるけど、焼き上がりの香ばしさを知っちゃうと病みつきになるよね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ラザニアとかカネロニとか、そのようなものを食べたと記憶している。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテ・グリで、如月敏と食事、ミネストロン、カネロニ、ポークチャップで、うまかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間、ブーフ・アラ・モードの味を覚え、カネロニーやその他フランス料理の一と通りを覚えてしまったのだ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷映画へ涼みに入る、ニュースと一本見て、丁度逢った徳山とホテルのグリルへ行き、夕食、コールコンソメ、コールドラブスター、カネロニー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時、ホテルのニューグリルへ屋井と行って、オルドブル、アスパラガスクリームスープ、白魚フライとカネロニー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋井が迎へに来り、ホテ・グリで夕食、ポタアジュに、カネロニーとベヂタブル・ディナー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶然小田末造に会ひ、例の気焔に当てられ、コンソメ・カネロニー、鶏のコゝット等を食べる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤山一郎とホテ・グリへ行き、オニグラ、カネロニー、ゲームパイ、コーヒー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテ・グリへ、中島清助と食事、ポタアジュに、ロブスター・タミドオ、カネロニー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、電話でレンラクした藤田潤一が津田と来り、一荘やらうといふことになりて、カネロニー一皿食ったゞけで、銀座荘へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
