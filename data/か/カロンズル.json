[
  {
    "uuid": "b979d646-2fa6-56e4-bcae-6dff88ffb789",
    "entry": "軽んずる",
    "reading": {
      "primary": "かろんずる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-ずる変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to despise",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "傲慢な王は、民の声に耳を貸さず、彼らを軽んじた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「奴らの意見など、鼻から軽んじているさ」と、彼は嘲笑した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年の功績を軽んずるような評価には、彼は納得できなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "相手の若さを軽んずるべきではない、経験に勝る情熱を持っているかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしその半面の随伴現象としていわゆる骨董趣味を邪道視し極端に排斥し、ついには巧利を度外視した純知識慾に基づく科学的研究を軽んずるような事があってはならぬと思う。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時三郎を軽んずるごとく、「一体貴下は何御用でお出でなすったのです。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "冠婚葬祭を軽んずる様で人間出世は出来ぬという信念をもっている。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "師を軽んずるは古来、文科学生の通弊とす。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "命に従わず朝を軽んずるというので、節刀を賜わって関白が愈々東下して北条氏を攻めるというのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに近頃吾人を評難する者あり、吾人「文学界」の一団を以て、ライフに関する、すべての事を軽んずる者の様に言ひ做して、頻に攻撃を試むると覚えたり。",
              "citation": {
                "source": "人生の意義",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに世間には「人生」といふ字の誤り易きところから、往々にして吾人を以て、ライフといふものを軽んずる者の如く認めて、気早なる攻撃を試むる者あり。",
              "citation": {
                "source": "人生の意義",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに今の世の所謂基督教会なるものを見るに、朝に入りたるもの夕に出で、出没常なく、去就定まりなし、その入るや入るべからざるに入り、其出づるや出づべからざるに出づ、何ぞ自らの心宮を軽んずるの甚しき。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いささか軽んずる色があって、ニヤニヤと頤を撫でる。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命を軽んずること鴻毛のごとく、約を重んずること鼎に似たり。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯る言葉の発言者は何んな平和な孤島に生活しても、生活のみの不平と陰鬱を呪詛して徒らにアポロの使徒を軽んずるでありませう。",
              "citation": {
                "source": "附「歌へる日まで」",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七節にいう「神の懲し給う人は幸福なり、されば汝全能者の※責を軽んずるなかれ」と。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを軽んずる時は造化の神をよく知ることは出来ない。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンウェイがビナレスの猴堂に詣で多くの猴を供養したところに猴どもややもすれば自重して人間を軽んずる気質あるよう記した。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の眼には身命の危険を軽んずることは、貴族の天分なのであつた。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もその当時は内々得意であったが、後に遼陽城外の劉家に来て、かの奉天歩隊の勘当息子をみるに及んで、彼らが余りに文を重んじ、武を軽んずるの甚しきを憐れむような心持にもなって来た。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "他語以て之を言へば生命を軽んずることなり。",
              "citation": {
                "source": "読書弁",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "加藤氏が「軽国政府」と言える題にて述べたる短文にも「人民をしてあえて国事を聴く能わざらしめもって恣に人民を制圧せんと欲するところの政府は余これを目して国家を軽んずるの政府と言う云々」と明言したり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別その為に芸術を軽んずる気などは起らないね。",
              "citation": {
                "source": "続野人生計事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "死を怖れるというと語弊があるが、また死を軽んずるといえばよく聞えるけれども、軽んじ方によっては甚だ愚の極であって、日本人は死することを何とも思わぬというは、褒めれば褒めるようなものの、生の責任を知らぬものと批難さるるのも無理ならぬことと思う。",
              "citation": {
                "source": "「死」の問題に対して",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "死を軽んずるということは義務を軽んずるという事になると僕は思うている。",
              "citation": {
                "source": "「死」の問題に対して",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう風に死を軽んずるという事は決して褒むるに足らぬと思う。",
              "citation": {
                "source": "「死」の問題に対して",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければあらゆる不良少年のように彼自身を軽んずるのに了るだけだった。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子は我家に養育せらるゝ間こそ父母に孝行を尽す可きなれども、他家に縁付きては我実の父母よりも夫の父母たる舅姑の方を親愛し尊敬して専ら孝行す可し、仮初にも実父母を重んじて舅姑を軽んずる勿れ、一切万事舅姑の言うがまゝに従う可しと言う。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだしその然るゆえんは、武人の政府、文を軽んずるの幣などとて、嘆息する者もありしかども、我が輩の所見はまったくこれに反し、政府の文武にかかわらず、子弟の教育を司る学者をして政事に参与せしむるは国の大害にして、徳川の制度・慣行こそ当を得たるものと信ずるなり。",
              "citation": {
                "source": "学問の独立",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞典式体操、菜食主義、複方ジアスタアゼ等を軽んずるのは文を作らんとするものの志ではない。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸福を軽んずる者も、それ自身の仕方で幸福を求めているといえるであろう。",
              "citation": {
                "source": "哲学入門",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞典式体操、菜食主義、複方ヂアスタアゼ等を軽んずるのは文を作らんとするものの志ではない。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければあらゆる不良少年のやうに彼自身を軽んずるのに了るだけだつた。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "―或精神的風景画―",
                "note": "青空文庫"
              }
            },
            {
              "text": "長じて、種のために生をかろんずるにいたるのも、自然である。",
              "citation": {
                "source": "死刑の前",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
