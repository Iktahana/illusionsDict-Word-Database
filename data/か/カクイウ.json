[
  {
    "uuid": "97d9dc0c-8c7e-51f1-9e12-331d8dcb4e6a",
    "entry": "かく言う",
    "reading": {
      "primary": "かくいう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "in this way",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「かく言う私も、若い頃は君と同じような失敗をして上司に叱られたものだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は健康管理の重要性を説くが、かく言う本人は相当なヘビースモーカーだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「かく言う私自身、この結末を予想していたわけではありませんでした」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都会の喧騒を嫌う彼女だが、かく言う彼女も生まれ育ったのは大都会の真ん中だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "かく言う自分もさよう、同類と信じているのである。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "的等の一人、かく言う私だ……」　　　　　　　十三「なお聞けば、古市のはずれに、その惣市、小料理屋の店をして、妾の三人もある、大した勢だ、と言うだろう。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕車よりおそかったら代は戴きません」　かく言ううちも渠の手なる鈴は絶えず噪ぎぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の事をとやかく言うよりは、自分のていたらくに就いて考えてみるがよい。",
              "citation": {
                "source": "かすかな声",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、よしんば知っていたって、とやかく言う資格は僕には無い。",
              "citation": {
                "source": "女類",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "信尹、再び幸村に対面してかく言うと、「信濃一国は申すに及ばず、天下に天下を添えて賜るとも、秀頼公に背きて不義は仕らじ。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大胆な冒険を試みて成功したのであるから、今また一つの冒険を企てて失敗しているからといって、それをとやかく言うにはあたらない。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく言うは、あえて氏が取材を難ずるにあらず。",
              "citation": {
                "source": "遠野の奇聞",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人なるが故にその智壮者に勝つといい、監督なるが故にその信仰平信徒に優るというが如きは、しかしてかく言うて己を立て他を倒さんとするが如きは過れるの甚しきものである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、世の学者たちは、この頃、妙に私の作品に就いて、とやかく言うようになった。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなる床の軸にも見える通り、御先々代八郎次さまは至っての偉物でな、病気平癒の祈願を籠めてさしあげたは、かく言う沼田正守がまだ壮年の砌のことじゃ、それ以来当豊明権現を大変の御信仰で、あの一札にもある通り、貢納米から労役人夫、みな行き届いた御仕方じゃ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十二月二十二日）　　　　　　　十三の一　私はすでに前回の末尾において、富者はその財をもって公に奉ずるの覚悟がなくてはならぬと言ったが、かく言うことにおいて、私の話はすでに消費者責任論より生産者責任論に移ったわけである。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもとやかく言うなら二人で逃げてもいいじゃないか。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく言う僕も他人より賛辞を受けたことはないが、上に挙げた例の一部にあたっているかも知れないと思えば、この辺が筆を止めるところであろうか。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しもう、とやかく言うのは止そう。",
              "citation": {
                "source": "囚われ人",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫と同じように、あなたが、硝子戸の中で日向ぼっこをしたり、電気炬燵でうつらうつらしたり、やたらに欠伸をしたりするのを、私はとやかく言うのではありません。",
              "citation": {
                "source": "未亡人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄と君との間の感情を、僕はとやかく言うのではない。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "建築費の点も、僅かな坪数だから、大したこともあるまいし、そのようなことをとやかく言うカヨではない。",
              "citation": {
                "source": "蔵の二階",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく言う私も、時に、無に帰そうと思う時が、あるですよ。",
              "citation": {
                "source": "不良少年とキリスト",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "……「僕はなにも、自分のことをとやかく言うんじゃないぜ。",
              "citation": {
                "source": "真珠の首飾り",
                "author": "ZHEMCHUZHNOE OZHERELJE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、フランクが受けあって言うには、彼の父が政治をとやかく言うのを聞いたのはほとんどこの時だけで、この意見は、あるとき数週間ほど泊っていった国会議員から借りてきたものにちがいないということだった。",
              "citation": {
                "source": "クリスマス・イーヴ",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "軒先に掛けた日蔽の下に居ても跳上る飛沫の烈しさに、わたくしはとやかく言う暇もなく内へ這入った。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と女中は矢田の帽子と夏｜外套とを持って立ちかけるので、矢田はとやかく言うひまもなく、案内されるがまま、先刻舞踊家のいた座敷とも知らず、黙って裏二階の四畳半に入った。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ成吉思汗様が辛子をお舐めになった時でも、かく言うそれがしさえお傍にいれば、ああ辛いとおっしゃるかわりに、わっはっはと笑わせてお眼にかける。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……かく言う拙者を作阿弥と看破さるるとは、貴殿は、容易ならざる眼力の持主――」「なんの、なんの！",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つ、どうやら公儀の手も、動いておるようにも思われる――五番目には、かく言うおれと……はッはッは、いや、おれの片眼には、江戸じゅうの、イヤ、日本中の人間が、あの茶壺をねらっているように思われるワ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　何を訊かれてもかく言うだけだった。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "霙橋辻斬夜話",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたが、とやかく言うことはないのよ。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリサイ人の学者らは、イエスが中風の者に「子よ、汝の罪｜赦されたり」と言われたのを聞き咎めて、「この人何ぞかく言うか、これは神を涜すなり、神ひとりのほかは誰か罪を赦すことを得べき」と論じたのであります（二の五―七）。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとはまた真黒闇になるのだが、そんな事をとかくいうことはかえって余計な失礼の事のように思えたので、そのままに坐を立って、襖を明けて奥へ入った。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
