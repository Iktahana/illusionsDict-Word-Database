[
  {
    "uuid": "4a3caa61-f43b-5fd5-87e3-82a00bea4244",
    "entry": "搦め手",
    "reading": {
      "primary": "からめて",
      "alternatives": [
        "からめで"
      ],
      "is_heteronym": false
    },
    "grammar": {
