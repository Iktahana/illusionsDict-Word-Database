    "definitions": [
      {
        "index": 1,
        "gloss": "setting off the night before one normally would have departed, travelling in a different direction, spending the night there, and leaving for one's destination in the morning (done to avoid travelling in an unlucky direction; a common practice during the Heian period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "目的地が暦の上で「ふさがり」の方角だったため、わざわざ遠回りをして方違えをしてから向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "方違えのために立ち寄った知人の屋敷で、思いがけず豪華な食事の歓待を受けることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「明朝は方違えをしてから出立するゆえ、準備を怠らぬように」と主人が供の者に命じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "当時の日記を読むと、方違えという口実を使って密かに恋人のもとへ通う者もいたようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「女の家へ方違えにおいでになった場合とは違いますよ。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでたびたび方違えにこの家を選んだのはあなたに接近したいためだったと告げた。",
              "citation": {
                "source": "源氏物語",
                "author": "空蝉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むろん方違えをして来たさ」と殿も殿で、あんまり見え透いたような事を仰ゃるものだから、こんどは私も少しばかり気色を顔に出して、「それほどのお気持がおありなさいますかどうか、今後に試めさせていただきます」と応じた。",
              "citation": {
                "source": "ほととぎす",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
