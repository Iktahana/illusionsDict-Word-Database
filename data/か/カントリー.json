        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "国際電話をかけるたびに「あそこの国番号は何番だ」とわめき散らす必要ももはやなく、静かにカントリー・コードの一覧表のウインドウを一つ開けば良いではないか、と考えたのである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして馬鹿馬鹿しいカントリー・ガールだ。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは独立戦争以前に『プロヴィデンス・ガゼットとカントリー・ジャーナル』が印刷されていた場所だった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "パラケルススが死去したときに15歳年長のフラカストロはヴェロナに近い立派なカントリーハウスで立派な友達に囲まれて生きていた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の南のはずれ近く、ニシモト・カントリー・ストアの前には、すでに人が集まっていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "車を出てニシモト・カントリー・ストアに向かって歩いた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きなトラックから黄色いブルドーザーが一台、カントリー・ストアの前に降ろされているところだった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車で来ては、ニシモト・カントリー・ストアの前まで歩いて来るのだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニシモト・カントリー・ストアの西側の壁に、シャベルから先に衝突した。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニシモト・カントリー・ストアは、やがてあっけなく崩れ、倒れ、平たくなった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ニシモト・カントリー・ストアは、もうない。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまご覧になったとおり、ハレイワのニシモト・カントリー・ストアは、これで終わりです。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はハワイ島のコナに場所を変え、カントリー・ストアを開きます。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アナザー・ニシモト・カントリー・ストア、と命名しました。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌の題名は『ニシモト・カントリー・ストア』と言います」　マイケルは歌い始めた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "消えていくニシモト・カントリー・ストアに対する追憶の悲歌だった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニシモト・カントリー・ストアの残骸を、自らの重量を利用して細かく砕き始めた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ニシモト・カントリー・ストアが取り壊しになると聞いてから、少しずつ作ってきた歌なんだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちは、ニシモト・カントリー・ストアに別れを告げた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カントリー・ストアの周辺から車が散り始めた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだい、調子は」「ニシモト・カントリー・ストアが取り壊しになった」「奴ら、次はなにを壊すつもりなんだ」「マイケルが、おなじことを言ってた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、『ニシモト・カントリー・ストア』という歌を作ったんだ」「聴きたい」　州知事オフィスの黄金色燦然たるキャデラックに、ラリーは単純に喜んだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイケルのギターの弾き語りで、『ニシモト・カントリー・ストア』だ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しくて、なんだかこわくて」　マイケル・ヘレアウカラニが、自作の歌『ニシモト・カントリー・ストア』をシングル盤のレコードにする。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニシモト・カントリー・ストアが取り壊しになる朝の、現場の模様を撮影したテープだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウエインは、ニシモト・カントリー・ストアの経営者ベンジャミン・ニシモトの甥にあたる。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニシモト・カントリー・ストアに託して、マイケルの心は完璧に過去に向かってたみたい」「いまだから、そんなふうに思うんだ」「違うわ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "７　ニシモト・カントリー・ストアの跡地に、人々は正午から集合し始めた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイケルが残してくれた、『ニシモト・カントリー・ストア』の歌だ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの人たちとおなじく彼もハワイ屈指のミュージシャンであり、硬い張りのあるバリトンで歌うカントリー・ソングは、この二十年、地元のジュークボックスで人気を保ち続けている。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
