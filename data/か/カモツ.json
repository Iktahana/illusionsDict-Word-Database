        "examples": {
          "standard": [
            {
              "text": "その探検隊は、引き上げられた難破船から貴重な貨物（財宝）を発見した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "担保として差し出された貨物（動産）の評価額は、非常に高かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "戦後、敵国から接収された貨物（資産）は、政府によって管理された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
