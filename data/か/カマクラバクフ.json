    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Kamakura shogunate (1185-1333)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "源頼朝が鎌倉幕府を開いたのは1192年だと教わったけど、今は1185年説が有力なんだって。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鎌倉幕府の執権政治は、北条時頼の頃に全盛期を迎えたと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「鎌倉幕府が崩壊した後、足利尊氏が新しい時代を切り拓いたんだよね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "御家人たちの不満が溜まったことが、鎌倉幕府の基盤を揺るがす原因になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "津軽に於いて、口三郡は鎌倉役であり、奥三郡は御内裏様御領で、天下の御帳に載らざる無役の地だつたと伝へられてゐるのは、鎌倉幕府の威力もその奥地に及ばず、安東氏の自由に委して、謂はゆる守護不入の地となつてゐたことを語つたものであらう。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉幕府と元寇　平家の衰亡は、武家にして、藤原氏を学んで、大宮人としての弊害を承け継ぐと共に、土地を根拠とする武士自身の生活を忘れたためである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼朝死後、頼家、実朝が相次いで非命に斃れ、鎌倉幕府の命運｜将に傾むかんとするが如き情勢を示した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも泰時、時頼等の傑出した人物が相継いで執権となり、鎌倉幕府の全盛時代を現出した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "承久の変に於ける不臣を敢てした鎌倉幕府が、かくも強大になつたことは、悲しむべきだが、武士の統制機関が出来るだけ、強大となつて、将に来らんとする皇国｜未曾有の危機たる蒙古襲来に当らうとしてゐたことは、北條氏が、無意識の裡に行つてゐたせめてもの罪滅ぼしであらう。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "建武中興　元寇は、日本の輝しき大勝に終つたが、その戦禍を甚だしく受けたものは、戦勝の殊勲者たる鎌倉幕府それ自身であつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "文永弘安の両役に於ける莫大なる戦費は勿論、その前後に於ける辺海警備の費用、諸社寺に於ける祈祷に対する恩賞などで、鎌倉幕府の財政は、漸く窮乏を告ぐるに至つた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも、播磨の赤松則村は、京都の手薄を知り六波羅探題を襲はんとしたので、鎌倉幕府は驚いて足利尊氏、名越高家の両将に、兵を率ゐて救援に上洛せしめた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二）　政治の実権が久しく朝廷を去つてゐたから、公卿は政治の実際に疎く、しかも鎌倉幕府の滅亡と共に、幕府が処理してゐた政務をも朝廷で併せ行はねばならぬことゝなり、政務が渋滞してしまつたこと。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "家康は、頼朝の鎌倉幕府の組織に傾倒したが、単なる模倣はしなかつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "家康は、鎌倉幕府や室町幕府の政策の跡に鑑みて、皇室に対し奉つて十七箇条の公家諸法度を制定し、陽には尊崇して陰には圧迫した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼朝（源頼朝、鎌倉幕府創立者）の疑いはとうてい避け難いところではあったろうが、義経に惜福の工夫の欠けていたのも確かに不幸の一因となったのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "四條金吾は鎌倉幕府の江馬入道につかへた武士で、當時四面楚歌の日蓮に師事し、法華經信者の隨一ともいへる若人だ。",
              "citation": {
                "source": "尼たちへの消息",
                "author": "――よく生きよとの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が朝家に処し、平氏に処し、諸国の豪族に処し、南都北嶺に処し、守護地頭の設置に処し、鎌倉幕府の建設に処するを見る、飽く迄も打算的に飽く迄も組織的に、天下の事を断ずる、誠に快刀を以て乱麻をたつの概ありしものの如し。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉幕府の要路者は日蓮への畏怖と、敬愛の情とをようやくに感じはじめたので、彼を威迫することをやめて、優遇によって懐柔しようと考えるようになった。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その号令は天皇の意志ではなしに、藤原氏の、鎌倉幕府の、軍閥政府の意志であつた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくとも頼朝が鎌倉幕府を定めるころまでは、コマ家は一族重臣のみと血族結婚していたのである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "西行は鎌倉幕府の将軍に謁見を許され銀製の猫を賜わるの光栄に浴したが、用なきものとしてこれを道に遊ぶ児童に与えて去った。",
              "citation": {
                "source": "冬日の窓",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、鎌倉時代において京師の※紳が目して東夷もしくは夷となすものは、往々にして鎌倉幕府を指し、あるいは一般に武士を示すの語となれり。",
              "citation": {
                "source": "武士を夷ということの考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして、同じ東夷もしくは夷の称をもって呼ばれたる鎌倉幕府または一般武士は、実に京師の※紳よりして、また蝦夷として認められたりしものならざるべからず。",
              "citation": {
                "source": "武士を夷ということの考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお俘囚の長たる平泉の藤原氏や、東夷と呼ばれた鎌倉幕府が、都の文化を輸入し、都人を使役した様に、その富にまかせて里の文化の輸入をもしようし、気の利いた里人をも使役して大尽になりすます。",
              "citation": {
                "source": "炭焼長者譚",
                "author": "系図の仮托と民族の改良",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは鎌倉幕府の威力を以てしても、容易に鎮定することが出来なかった程の、盛んなものであったらしいのですが、その詳細なことはわかりません。",
              "citation": {
                "source": "本州における蝦夷の末路",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に少しく詳しく歴史を研究する様になりまして、鎌倉時代の末に津軽で蝦夷の乱が起り、鎌倉幕府の兵も容易にこれを鎮定することが出来なかったという事実の存在を知りました時には、殆ど意外の感に打たれたのでありました。",
              "citation": {
                "source": "本州における蝦夷の末路",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを今の武家華族の家についてみても、徳川時代の諸大名は大抵戦国時代に新たに起ったもので、鎌倉幕府以来の大名の子孫が、そのまま継続しているものは僅かに指を屈するばかりしかない。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "西行は鎌倉幕府の将軍に謁見を許され銀製の猫を賜はるの光栄に浴したが、用なきものとして之を道に遊ぶ児童に与へて去つた。",
              "citation": {
                "source": "冬日の窓",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「方今天下の武士という武士、わずかの数をのぞきましては、他はおおよそ鎌倉幕府に、今に帰属しおりまする。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃宮方では朝権恢復、鎌倉幕府討滅の、再度の計を企てられ、その最初の手段として、この年早々に法勝寺の円観、小野の文観、南都の知教、浄土寺の忠円、教円などという、名だたる高僧知識をして、北条家調伏の修法をせしめた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新田義貞は上野に、赤松｜則村は播磨の国に、結城宗広は陸奥の国に、土居、得能は四国の地に、名和長年は伯耆の国に、菊池武時は九州の地に、そうして足利高氏さえ、鎌倉幕府を見限って宮方にひそかに心を寄せた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤旗白旗は源平戰爭の標幟には必要なりしも、鎌倉幕府の政治家には、何の必要なかりき。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤旗白旗は源平戦争の標幟には必要なりしも、鎌倉幕府の政治家には、何の必要なかりき。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
