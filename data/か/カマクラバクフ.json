[
  {
    "uuid": "a1e460a1-ad28-5704-a784-a162ba0c8c5d",
    "entry": "鎌倉幕府",
    "reading": {
      "primary": "かまくらばくふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
