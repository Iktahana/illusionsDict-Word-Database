        "examples": {
          "standard": [
            {
              "text": "「プリンターの調子が悪いけど、紙詰まり程度の軽い故障みたいで安心した」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "エンジンから変な音がするが、整備士によれば部品交換で済む軽い故障らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ネットが繋がらない原因を調べたら、ルーターの接触不良という軽い故障だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大規模なシステム障害ではなく、一部の端末に軽い故障が発生しただけだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "もう五十六七になる陽気な人で、腰の筋を違えたというだけの、病気とはいえない軽い故障だった。",
              "citation": {
                "source": "寒橋",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
