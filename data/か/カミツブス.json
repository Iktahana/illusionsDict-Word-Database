        "examples": {
          "standard": [
            {
              "text": "風邪薬の錠剤が大きすぎて飲み込めず、仕方なく奥歯で噛み潰したが、その苦さに悶絶した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「グッ……」と、彼は溢れ出しそうな怒号を喉の奥で噛み潰した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "おつまみのナッツを無心で噛み潰しているうちに、ようやく気持ちが落ち着いてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アーモンドを噛み潰した瞬間の香ばしい香りが、焼きたてパンの風味を引き立てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "自分も、他人も、一緒くたに丸め、突転して力の限り踏みにじり、噛み潰す、火のような亢奮で、脂汗を掻きながら、歯軋りをするのである。",
              "citation": {
                "source": "渋谷家の始祖",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
