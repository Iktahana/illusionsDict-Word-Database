[
  {
    "uuid": "758dd7c2-f084-5029-9ea3-2a1eff7a6fbc",
    "entry": "過雁",
    "reading": {
      "primary": "かがん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "flying goose",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夕暮れの空、一列になって飛んでいく過雁の群れに、思わず見入ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "詩人は、遠い故郷を想いながら、鳴き声高く渡る過雁の姿を歌に詠んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "水墨画に描かれた過雁の姿は、秋の寂寥感を巧みに表現している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "北越の猛将上杉謙信が「数行過雁月三更」と能登の国を切従えた時吟じたのも、霜は陣営に満ちて秋気清き丁度｜斯様いう夜であった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "謙信も亦、信玄に劣らぬ文武兼備の大将で、文芸の趣昧ふかく、詩にはおなじみの、｜霜満軍営秋気清数行過雁月三更越山併得能州景遮莫家郷｜憶遠征　の詩があり、歌には、ものゝふのよろひの袖を片しきし枕にちかき初雁の声　などある。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "能登遠征のときの霜満軍営秋気清数行過雁月三更　は、ずっと後年の作であるが、青年ごろの作かと思われるものに、次のような一首がある。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして杖にすがったまま辛うじてかがんだ猫背を延ばして前面に何物をか求むるように顔を上げた。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、茶いろの少しぼろぼろの外套を着て、白い巾でつつんだ荷物を、二つに分けて肩に掛けた、赤髯のせなかのかがんだ人でした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かがんで炉に靴下を乾かしていたせいの低い犬の毛皮を着た農夫が、腰をのばして立ちあがりました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七は少しかがんでよく視ると、黒い蛇は余り大きくなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "キッコはかがんで机のまわりをさがしましたがありませんでした。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斉田はつくづくかがんでその暗くなった裂け目を見て云った。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに小さな五、六人の人かげが、何か掘り出すか埋めるかしているらしく、立ったりかがんだり、時々なにかの道具が、ピカッと光ったりしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、茶いろの少しぼろぼろの外套を着て、白い布でつつんだ荷物を、二つに分けて肩にかけた赤髯のせなかのかがんだ人でした。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "半焼けになった物置きが平べったくたおれている、その後ろに三、四人の人足がかがんでいた。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤッ」さむらいはふところから白いたすきを取り出して、たちまち十字にたすきをかけ、ごわりと袴のもも立ちを取り、とんとんとんと土手の方へ走りましたが、ちょっとかがんで土手のかげから、千両ばこを一つ持って参りました。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子はかがんでしずかにそれをはずしました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブドリがその小さなきたない手帳を出したとき、クーボー大博士は大きなあくびをやりながら、かがんで目をぐっと手帳につけるようにしましたので、手帳はあぶなく大博士に吸い込まれそうになりました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中でも、一番その唄をいいなあと思つたのは、少し離れたところに、かがんでゐる栄蔵であつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて巳之助はかがんで、足もとから石ころを一つ拾った。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだうまいか」といって、主人はそこにかがんだ。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸び上つてはチヨキン、かがんではチヨキン、腰を叩いてはチヨキン。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は棹をあげ、また、さしつぎ、親たちはかがんでゐる、耕作のよい疲れで。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベェリヴェヤワのお母さん七面鳥は私の乗込んだ団平船の高い艫の方に大きく膨れてかがんでいたが、いかにも楽天家の本相をあらわしていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦稈帽で半シャツ、かがんで、細い棹の糸をおなじくしんかんと水に垂らしている。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その煙りがこちらの部屋まで流れ込んで来るので、堀部君は慌てて入口の戸を閉めたが、何分にも寒くて仕様がないので、再びその戸をあけて出て、自分も竃の前にかがんでしまった。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリヤンの外にも、七八人の島民女が鎌を手にして草の間にかがんでゐる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリヤンの外にも、七、八人の島民女が鎌を手にして草の間にかがんでいる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの眼にはそれが単に吹雪としか見えなかったが、同行者の多くの者の眼には、それが婦人の形をして立ち上がり、屍の上にかがんでこれに接吻し、それから氷山を横ぎって急いで飛び去ったように見えたと言うのであった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は男の上にかがんで調べる。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の考えで行くと、犯人はドレッバーの死体の間近でかがんだ際に落としたのだが、その時には気づかなかった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして石の前に、長身で長いひげをたくわえ、いかつい顔をした、ひどくやせぎすの男がかがんでいた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、ついて来るままにさせ、歩いて行く途中でおりおりかがんで軽く手で叩いてやった。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
