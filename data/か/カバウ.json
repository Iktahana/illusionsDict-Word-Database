[
  {
    "uuid": "bff51919-641c-57b7-9b49-a4b3bcdb83d3",
    "entry": "庇う",
    "reading": {
      "primary": "かばう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to protect (someone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はとっさに私の前に出て、飛んできたボールから庇ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "転びそうになった子供を、母親が両腕でしっかりと庇った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "上司は部下の些細なミスを庇い、自分が責任を負う姿勢を見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "どんな時も私の味方になって庇ってくれる友人がいることは、本当に心強い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その親鳥は、雛を守るために大きな翼で全身を庇うように広げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "佐吉さんがどんな我儘なふしだらをしても、お母さんは兄さんと喧嘩してまでも、末弟の佐吉さんを庇うわけだ。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲の奥の一端に、目※連、阿難を庇うて立ち居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　歩を移すのに引添うて、身体で庇うがごとくにしつつ、「ほんとに驚いたんですか。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "声に応じて少年はかッぱと刎ね起きて押被さり、身をもってお雪を庇う。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の車夫を屹と見ながら、お鶴を庇うて立ったのは、洋装した一個中脊の旅客であった。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小盾も見えず、姿見を傍に、追って出る坊主から庇うのに、我を忘れて、帷子の片袖を引切りざまに、玉香を包み、信女を蔽うた。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）学円　（庇う状に手を挙げて、また涙ぐみ）御道理じゃ、が、大丈夫、夢にも、そんな事が、貴女、（と云って晃に向きかえ）私に逢うて、里心が出て、君がこれなり帰るまいか、という御心配じゃ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまんが飽くまでも全真を庇うようならば、これも一緒に殺すよりほかは無いということに相談を決めたんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして葛飾を庇うためにピストルを死人の手に握らせる。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとに接するとき、少し尊大ぶる悪癖があるけれども、これは彼自身の弱さを庇う鬼の面であって、まことは弱く、とても優しい。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右の電車線路を眺め渡して、越すときだけ彼女を庇うように片手を背後に添えていた逸作は、かの女がまるで夢遊病者のようになって「似てるのよ、あの子一郎に似てるのよ」などと呟きながら、どこまでも青年のあとに随き、なおも銀座東側の夜店の並ぶ雑沓の人混へ紛れ入って行くのを見て、「少し諄い」と思った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と酒井の前を庇う気で、肩に力味を入れて云ったが、続いて言おうとする、（貴女がお世話なさいませんでも……）の以下は、怪しからず、と心着いて、ハッとまた小さくなった。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（姫を庇うて大手を開く。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "後はどう来たか、恐い姿、凄い者の路を遮って顕るる度に、娘は私を背後に庇うて、その鎌を差翳し、矗と立つと、鎧うた姫神のように頼母しいにつけ、雲の消えるように路が開けてずんずんと。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "へッ被成もんだ、あの爺を庇う位なら、俺の頬辺ぐらい指で突いてくれるが可い、と其奴が癪に障ったからよ。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "掴寄せられた帯も弛んで、結び目のずるりと下った、扱帯の浅葱は冷たそうに、提灯の明を引いて、寂しく婦の姿を庇う。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　緋鹿子の片隅に手を添えて、小親われを庇うて立ちぬ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（傘を人形にかざして庇う。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお杉は少年に引添うて、渠を庇うようにして言う。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小坂部も懐剣をかまえて男を庇うように立った。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかと云って、強盗であるかも知れぬ闖入者を、庇うような口は利けなかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "早乙女主水之介と知って匿まえと申しおったゆえ、直参旗本の意気地を立つるために、あの夜はあのように庇うてつかわしたが、それゆえに天下の重罪人を存ぜぬ事とは言い条、野放しにさせたとあっては、これまた旗本の面目のためほってはおけぬ。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "うぬが要らぬ旗本風を吹かしゃがって、庇うべき筋合のねえ奴を庇やがったために、折角網にかけた大事な星を取り逃がしたお咎めを蒙って、親代々の御番所の職を首にされたゆえ、その腹いせをしにやって来たんだッ」「なに、お役御免になったとな？",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にしていたモチ竿を投げすてながら、襲いかかろうとしていた農民達を軽く左右にはねのけて、ぴたり、鳥刺しをうしろに庇うと、静かに、だが、鋭い威嚇の声を先ず放ちました。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫は、跛を引いて逃げ帰ると、納屋の隅にうずくまって、殴られた足をかばうようにねぶった。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人のくせに日本人をかばう巡警は叩き殺して呉れる！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄貴の烏も弟をかばう暇がなく、恋人同志もたびたびひどくぶっつかり合います。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、小郷が殺されているのを見ると、てっきり三好だと思って、三好をかばうつもりで、自分だと言ったんですね。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小郷に身を任せたのも、鈴子の身代りという気持のほかに、小郷から金を取って落ちぶれた三好に貢ごうという、しおらしい気持もあったんだが、これがかえって悪かったんですね」「じゃ、梶君が自白したのは……」「君勇をかばうつもりだったんですよ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「梶鶴雄をかばうつもりだったんですよ」十一「なるほど、みんながみんなを、かばおうとして自分が犯人だと言ったわけですね」　と、小田は微笑した。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
