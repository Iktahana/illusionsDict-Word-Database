        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の不用意な発言に、私は思わずカチンときて言い返してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "また同じミスをしてしまい、上司にカチンとくるような口調で注意された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冗談のつもりだろうが、言われた瞬間カチンときて、しばらく口をきかなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の横柄な態度に、心の中でカチンと反発を覚えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
