    "definitions": [
      {
        "index": 1,
        "gloss": "curry (esp. Japanese curry)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今日のランチはCoCo壱番屋のチキンカツカレーにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "家で母が作るカレーは、いつも隠し味にチョコレートが入っているんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末に友達とキャンプに行って、外で食べるカレーは格別に美味しいよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "レトルトのカレーも最近はすごく種類が増えて、選ぶのが楽しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "出来ることなら老女が自分を乗せかけている果しも知らぬエスカレーターから免れて、つんもりした手製の羽根蒲団のような生活の中に潜り込みたいものだと思った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの場合を総括するに、いずれもかつてポアンカレーの述べしごとく「原因の微分的変化が結果の有限変化を生ずる場合」に当るを見る。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポアンカレーは「方則は不変なりや」という奇問を発している。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ複雑な変化の微小な事、またポアンカレーの謂うごとく複雑さが十分複雑であるために「偶然の方則」が行われ、多くの場合には簡単な平均的の云い表わしを抽象的に考える事が出来るのであろう。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポアンカレーの言葉を借りて云わば、前者は源因の微分的変化に対して結果の変化がまた微分的である場合に当り、後者は源因の微分的差違が結果に有限の差を生ずる場合である。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うなぎの蒲焼（鑵詰）ライスカレー（同上）あずきようかん（同）栗のきんとん（同）ほーじ茶、ココア、角砂糖（斯うたくさんは食えんわい）小包は厳重にして置いて呉れ。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロダンさんはロオズ夫人と妾を連れてカレー港から、ドーバーの港に着のみ着のままで避難しました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の知る限りではただアンリー・ポアンカレーがその晩年のエッセー（７）において論じたものである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう（三月二十三日）はミカレームの祭日だそうです。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一階から二階へ人を運ぶためにエスカレーターを運転している時がある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人は間違えてこれをライスカレーといった。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどエスカレーターの最下段に押して入れてやれば、あとはひとりで、少なくも二階までは持って行ってくれるのと同じようなものである。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓越しに見えるエスカレーターには、下から下からといろいろの人形がせり上がっては天井のほうに消えて行った。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな事を考えながら、自分もエスカレーターに乗ってＭ百貨店の出口に突き出されたのであった。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エレベータとエスカレータの研究の為急に東京に参り候、御不便ながら研究すむうちあの請負の建物はそのまゝお使ひ願ひ候」　お父さんの村長さんは返事も出させませんでした。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来ることなら老女が自分を乗せかけている果しも知らぬエスカレーターから免れて、つんもりした手製の羽根蒲団のような生活の中に潜り込み度いものだと思った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "船中朝の食事は「スープ」の他冷肉、「ライスカレー」、「カフヒー」それに香料の入つた美麗しき菓子、其他「パインアツプル」等極めて淡泊な食事で、それが濟むと、日出雄少年は何より前に甲板を目指して走つて行くので、夫人も私も其後に續いた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "が依然として、街頭のパンやライスカレーは姿を消さず、また、梅田新道の道の両側は殆んど軒並みに闇煙草屋である。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はまず、カレーライスを食い、天丼を食べた。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、それを平げると、暫らく水を飲んでいたが、ふと給仕をよんで、再びカレーライスを注文した。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、あてもなく闇市場を歩いていると、パンを売っているばかりか、食堂の飾窓にはカレーライスの見本もも出ているではないか。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カレーライス出来る……？",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その食堂に、どうして白米があるのか、毎日何百杯かのカレーライスを売るだけの米があるのか――ということも、考えなかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、いらん」　食堂だと思ったが、夜はカフェに変るのだろうか、いや、朝っぱらからもうカフェじみているわいと思いながら、小沢はぶっ切ら棒に断ったが、ふと思い出して、「――それより、にぎりを持って来てくれ」　十五円のライスカレー一皿では、腹が一杯にならなかったのだ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「名物のライスカレーはいかがでしたか。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても辛くて内地の方には食べられないでしょう」　私は昼の食堂で、カレー汁の外に、白飯に交ぜる添菜が十二三種もオードゥブル式に区分け皿に盛られているのを、盛装した馬来人のボーイに差出されて、まず食慾が怯えてしまったことを語った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、支那料理めいたもの、日本料理めいたもののほかに、容器は粗末だが、泥亀をタアトルス・スープに作ったものや、野鶏をカレー入りのスチューにしたものは特に味がよかった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つめたいものを飲みたくなって、昭和通りの小さい食堂へはいって、ソーダ水を飲んで、それからついでに、ライスカレーを食べた。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシヤでは、ライスカレーでも、手で食べるそうだ。",
              "citation": {
                "source": "食通",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドーヴァー海峡は少し荒れましたが霧が濃く無かったので定刻通り、フランスのカレーへ到着出来ました。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
