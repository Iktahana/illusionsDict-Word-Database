        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "修正箇所を分かりやすくするため、変更前の文章を括弧付きで残しておく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "フォームの入力項目に、括弧付きで（必須）と明記されているか確認してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "数式の計算順序を間違えないよう、内側の計算を括弧付きの式にまとめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
