        "examples": {
          "standard": [
            {
              "text": "練習コースを一周しただけで脱輪してしまい、仮免試験に落ちて意気消沈した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「やったー！ 仮免合格だ！ 明日からいよいよ路上教習だよ」と友人にLINEを送る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "免許センターでの本試験に備えて、仮免の有効期限が切れないうちに手続きを急ぐ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "仮免を掲げた教習車が、おどおどとした様子で交差点を右折していった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "敵陣十郎はどうかというに、甲源一刀流では剣鬼のような使い手、自分のように新影流で、ようやく仮免許を受けたような者とは、段違いの名人である。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやにおちついているが、おへそのつくだ煮でも食べすぎたのかい」　すると、伝六が黙ってなにか気味のわるいものでも見るように、向こうのへやのすみをあごでしゃくったものでしたから、なにげなく右門も視線を移すと、少しばかりめんくらいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "――昼湯にでもいってひと汗流してきたばかりらしく、青ざおとした月代に、ふた筋三筋散りかかるほつれ毛を風になぶらせながら、夏なおりりしくすがすがしい姿をにこやかにぬっと現わしたので、すっかりめんくらったのは伝六親方でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私は、すっかりめんくらい、困惑して、あいての要求の全体を理解するだけに考えをまとめることができなかった。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「深川の顔役さんで、木場の甚とおっしゃる人が、すっかりめんどうをみてくださいましたよ」「ほかに、相良どのの在世中、出はいりして、家事向きの相談にあずかった者があろうが」「いいえ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっしは、すっかりめんくらってしまいましたよ」「いまさら、ぐずぐず言うな。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリョーシャはすっかりめんくらってしまって、長老が立ち上がろうとしたときも、助け起こすことを忘れていたほどである。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "井上君は、すっかりめんくらっていました。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "れいのチンピラ別働隊の少年たちは、さっきからのおそろしいできごとに、すっかりめんくらってしまって、ひとかたまりになって、何か話しあっていましたが、明智が小林少年のことをたずねますと、その中からひとりのチンピラ君が前に出て、妙なことをいいました。",
              "citation": {
                "source": "青銅の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
