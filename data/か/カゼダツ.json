    "definitions": [
      {
        "index": 1,
        "gloss": "to blow (wind)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「おっ、急に風立ってきたな。嵐になる前に、外に出している植木鉢を玄関に入れよう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "遮るもののない山頂に立つと、どこからともなく冷ややかな風立つ音が聞こえ、秋の訪れを知る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おいおい、そんなに強く風立つ中でキャンプファイヤーなんて無理だ。火事になるぞ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夕凪が終わり、海の方から爽やかに風立つ瞬間が、一日のうちで最も心地よい時間だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "（座敷は二階かい、）と突然頬被を取って上ろうとすると、風立つので燈を置かない。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "風立つ中を群って、颯と大幅に境内から、広小路へ散りかかる。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そよとばかり風立つままに、むら薄の穂｜打靡きて、肩のあたりに秋ぞ染むなる。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさは俄かに秋風立つ。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに月も風立つた空に時々光を洩らしてゐた。",
              "citation": {
                "source": "ピアノ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑い日がやや沈みかけて、涼風立つ頃、今まで只一色大海の様に白い泡をたぎらせて居た空はにわかに一変する。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう四時近く、日はエギュイユの蔭に沈んで、やや風立つと、寒くて寒くてたまったものではない。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
