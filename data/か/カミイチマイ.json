    "definitions": [
      {
        "index": 1,
        "gloss": "one sheet of paper",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
