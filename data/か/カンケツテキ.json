        "examples": {
          "standard": [
            {
              "text": "医師は患者に、この症状には観血的な手術が必要になる可能性があると説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "観血的な処置はリスクも伴いますが、根本的な解決のためには避けて通れません。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "内視鏡を用いた低侵襲の観血的治療法が近年進歩している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "薬剤による治療で改善が見られない場合、次の段階として観血的なアプローチを検討します。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
