    "definitions": [
      {
        "index": 1,
        "gloss": "bare shoulder",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祭りの喧騒の中、片肌をあらわにした男たちが神輿を担いでいく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ちょっと、片肌見えてるわよ。着物が崩れてる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彫り物を見せるために、彼はわざと片肌を脱いで座り込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "片肌ぬいで汗を拭いている男もある。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見たまえ」　と妻木君は左の片肌を脱いで痩せた横腹を電燈の方へ向けた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人心地もなく苦しんだ目が、幽に開いた時、初めて見た姿は、艶かな黒髪を、男のような髷に結んで、緋縮緬の襦袢を片肌脱いでいました。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と片肌脱、身も軽いが、口も軽い。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤き顱巻向うざまにしめて、裾を括げ、片肌脱ぎて、手にせる菓子の箱高く捧げたるがその銀六よ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すかし見る框の上に、片肌脱ぎて立ちたるは、よりより今はわが伯母上とも行交いたる、金魚養う女房なり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は片肌脱ぎたるまま、縄もて後手に縛められつ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、灯ともし頃に家に帰ると、家では定連の外に、見知らぬ人も二三人来て、座敷一ぱい、いろ／＼の道具や品物を置き並べ、まん中に置いた台の前に立って、定連の一人の新川堀の酒問屋の息子が、向う鉢巻に片肌ぬぎで、台の上を叩きながら怒鳴っておりました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の青さに片肌ぬぎのたぼもつやめく髪の型、つんとすねたり、かもじ屋に紺は匂ひて新らしく。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面に雲竜の刺青の片肌を脱いで、大胡坐を掻いた和尚の前に積み上げてある寺銭が山のよう。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内に、肩越に抱くようにして投掛けていた貴婦人の手で脱がしたか、自分の手先で払ったか、少い女の片肌が、ふっくりと円く抜けると、麻の目が颯と遮ったが、直に底澄んだように白くなる……また片一方を脱いだんです。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "省作は手水鉢へ水を持ってきて、軒口の敷居に腰を掛けつつ片肌脱ぎで、ごしごしごしごし鎌をとぐのである。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "省作が片肌脱いで勢いよく鎌をとぎ始めれば、兄夫婦の顔にもはやむずかしいところは少しもなくなって、快活な話が出てくる。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつたは幾年か以前の仕立と見える滅多にない大形の鳴海絞りの浴衣を片肌脱にして左の袖口がだらりと膝の下まで垂れて居る。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "片肌脱ぎで片手に酒徳利を掴んでゴク／＼とラツパ飲みをしながら、閻魔の形相であつた。",
              "citation": {
                "source": "鎧の挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この苦境を見るに見兼ねて、もし仕官する希望でもあるならと片肌抜いでくれたのが語学校の旧師の古川常一郎であった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "いぶかりつつも主水之介は、さッと片肌はねてのけると、おもむろに手にしたは飾り重籐、颯爽としたその英姿！",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "助十の弟助八は廿歳前後のわか者、刺青のある男にて片肌をぬぎ、鉢卷、尻からげの跣足にて澁團扇を持つて立つてゐる。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）權三　（片肌ぬいで。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さう云ひながら三人が交々片肌抜ぎになつて、覚悟を決めて、奴等の幻を追ふように力んだので――先づ私は、雪二郎の力瘤をつかんでみると、それは恰も皮下に一個の林檎を蔵してゐるが如くグリグリと蠢く態は、魔力の潜みと思はれた。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（庭口より下總屋義平、鉢卷き片肌ぬぎにて木太刀を持ちて出づ。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼田は片肌を脱ぎ、森川は立襟の洋服の鈕を脱して風を入れ乍ら、乾き掛つた白粉で皮膚が痙攣る様なのを気にして、顔を妙にモグ／＼さしたので、一同は復笑つた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼田は片肌を脱ぎ、森川は立襟の洋服の釦を脱して風を入れ乍ら、乾き掛つた白粉で皮膚が痙攣る樣なのを氣にして、顏を妙にモグ／＼さしたので、一同は又笑つた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "さアという場合に片肌ぬぐなんてことはありませんから。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭りの巷に男姿の芸者数多、揃い衣の片肌脱ぎになって、この唄につれ獅子頭曳くも趣は同じく、折柄の気勢いにはまたなしともまたなし。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "陶器を販賣してゐると云ふ風評を聞いてゐるだけで、此頃の樣子は判然とは知らなかつたけれども、尋ねて行けば、何とか片肌ぬいでくれるやうな氣がしないでもない。",
              "citation": {
                "source": "雨",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒に酔うた事ないてや」「そんならこの腕に喰付いてみんかい」　木乃伊の爺さん一杯機嫌らしく、片肌を脱いで二の腕を曲げて見せると、真四角い木賃宿の木枕みたいな力瘤が出来た。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬚だらけの脱獄囚みたいな友吉おやじと、鶴髪童顔、長髯の神仙じみた老ドクトルが、グラグラ煮立った味噌汁と虎鰒の鉢を真中に、片肌脱ぎか何かの差向いで、熱燗のコップを交換しているじゃないか。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "むつは鍋をさげて横の川へ行き、石塊をひろってつるをカンカン叩きましたが、つるのゆがみかたはだんだんひどくなるばかりです。",
              "citation": {
                "source": "クララ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
