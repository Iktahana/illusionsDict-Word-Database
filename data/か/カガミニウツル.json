[
  {
    "uuid": "989728db-e98d-56db-91ea-cab134933f96",
    "entry": "鏡に映る",
    "reading": {
      "primary": "かがみにうつる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
