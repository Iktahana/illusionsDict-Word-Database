        "examples": {
          "standard": [
            {
              "text": "GWには、久しぶりに親戚一同の顔が揃う予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日の会議は重要な議題なので、役員全員の顔が揃った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ついにみんなの顔が揃ったね！乾杯しよう！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "土地の芸者も顔が揃うた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "六人の顔が揃うと、打ち連れ立って骨ヶ原に向った。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同の顔が揃うと、新十郎はうしろに隠した両手の品々をそッととりだして一同に示した。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同顔が揃うと宴席に勅令が降った。",
              "citation": {
                "source": "酒渇記",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、よその土地の主も五六人相前後してアタフタととびこんできて、蒼ざめた常連の顔が揃う。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十一　稲妻は見たり",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして顔が揃うと、それを飲みながらとりとめもない話をする。",
              "citation": {
                "source": "由布院行",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同の顔が揃うと、べつな公堂へ出向いて、事件の重大性を説明し、また一場の訓示を垂れて励ました。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず一同で、外から仔細をお告げ申しあげ、よく御得心を仰いだ上で、迎えの駒へ、おすすめいたすがよいかと思う」「駒は、どうした」「駒は彼方だが」「たれか、それも曳いて来い」　やがて、顔が揃うと、年かさの一人が、やおら御堂格子の前へすすみ出た。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
