        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "秋になると、庭の蛙手が鮮やかな赤色に染まり、季節の移ろいを感じさせてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "古い和歌に詠まれている蛙手とは、今の私たちがよく知るカエデやモミジのことだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "冷え込んだ山道を歩いていると、足元に落ちている蛙手の葉が霜で白く縁取られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "……蛙手に、底を泳ぎ寄って、口をぱくりと、」「その口でか、その口じゃの。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙手の木々の木ぬれは。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、あれはかえるでございますわ。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで口取とのせかえるで――　こんな事を平気で云った。",
              "citation": {
                "source": "旅へ出て",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼は、べつに顔色をかえるでもなし、にこにこして、リント少将のことばを、きいていた。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえるは、ゆかの上にころげたとたん、もうかえるではなくなって、世にもうつくしいやさしい目をした王子にかわっていました。",
              "citation": {
                "source": "かえるの王さま",
                "author": "DER FROSCHKONIG ODER DER EISERNE HEINRICH",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、そんな立派なカンナなら、なにも、かつおぶしをおけずりにならなくとも、立派に、大工道具につかえるではありませんか」「大工道具に、立派に使えるほどの上等だから、かつおぶしがけずれるんだよ」　しばらくわたしの手許を見ていた詩人はつくづくといった。",
              "citation": {
                "source": "カンナとオンナ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「今日は一寸出かけたの、でもじきかえるでしょう」「休みでしょう、まだ」「ええ。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは十五日ごろにかえるでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔさんは今度こそ商売をかえるでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "八日は、ごたついて、くたびれ、この間から何しろかえるかえるでひさがいても一向落付かなかったので、いよいよ行ってしまってかえってほっとしたところもあるというような工合です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲ちゃんは二十八日ごろかえるでしょう、おし迫って大変ね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体島田もそうです、何時にどこに行く、何日にかえるでは行ったっておちおちしなくて腹立たしい。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたら、本当にどんなに有効につかえるでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜多分かえるでしょう、出さき不明の由です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっとうまくゆかないでしょう、笑い草ですが、折角考えついたおじいさんおばあさんにしろ、その息子さんのこと思えば、何だかすこしつっかえるでしょう？",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑郎は最後に出る船でかえるでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "月曜の夜かえるでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "咲はもう当分来ないでしょう、国は来月初旬かえるでしょう、何かあったらどうするの？",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし将監は、それをふりかえるでもありません。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれをふりかえるでもありません。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
