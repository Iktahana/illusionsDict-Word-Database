        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "監察官は冷徹な眼差しで、不祥事を起こした巡査部長への取り調べを続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「監察官室からの呼び出しだ」と言われ、彼は顔を青くして席を立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "行政監察官として、各省庁の予算執行が適切に行われているかを厳格に審査する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その案内者が親しい同僚だけであればなんでもないが、しかしその中に学界の監察官のようなかたが一人でもいて来客の肩の後ろで厳粛な顔をしていられると自分の口は自然に膠着してしまって物が言えなくなる。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした監察官も日本の名誉のために必要かもしれない。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……眉が保寿官、眼が監察官、鼻梁が審弁官、口が出納官、そうして耳が採聴官。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまく行けば副知事を、さもなければ、どこか重要な省の監察官あたりを狙っていたのである。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを出ると、かねがね副知事の椅子を、それが駄目なら監察官の口をとしきりに奔走していた省の役所へ赴いた。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "行かないと拘引するぞ」「でも、あなた……」「あなたとはなんだ、農林監察官を知らないか。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "出て行け、こじきこぞうめ」　ははあ、これが農林監察官か。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは親方の見せたお手本で、警官や監察官に反抗すると、どんな目に会うかわかっていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおかみよりもおそろしい農林監察官からさけることもさらに必要であった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "モンテスキウは正しくも曰く、『風紀の頽廃は、この風紀の頽廃をなくするために設けられた監察官の職を、破壊してしまった。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "メテルス・ヌミディクスが監察官として行った演説を、憤りと嫌悪とを感ずることなくして読むことは不可能である。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど多くは、十八世紀の監察官やナポレオン時代の軍需商人など、国家の財産を買い取った者の子孫である）――その貴族にボニヴェー家というのがあった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この下水溝の管理は共和国時代は監察官たちにより行われたが帝国時代にはクロアカ管理人（curatores cloacarum）と呼ばれる特別な官吏が任命され、修理および清掃の労働者は罪人が行った。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠退すれば多年の功労によって年寄役に任ぜられる、それは国家老格で藩政の監察官に当る。",
              "citation": {
                "source": "葦",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国目付というのは幕府から外様諸侯の国許へ派遣される監察官で、定員は二名または三名、任期は半年から一年の交代である。",
              "citation": {
                "source": "あだこ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "監督官として工場監察官が任命されたが多くの違反が行われた。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮廷の監察官は妃殿下に、どこにも出てるオルレアン公の肖像のことを告げていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "で宰相コルベールは、地方の監察官と諸侯の議政府とに命じて、でき得る限り多くの囚人をこしらえさした。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの用意が整ってしまうと、監察官殿と呼ばれてる銀のぬいとりをつけた男が、監獄の主事に命令をくだした。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "給主は藩から付けられた監察官のようなものである。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者の柳公綽が、襄陽の民政監察官として、その地にあった時の見聞を自記したものである。",
              "citation": {
                "source": "人間山水図巻",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
