    "definitions": [
      {
        "index": 1,
        "gloss": "to begin to write",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "先生の合図で、生徒たちは一斉に作文を書き出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "パソコンに向かって、新しい企画書を書き出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昨日の夜、急にアイデアが浮かんで、メモ帳に書き出したんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてその凡そで以て何やかや書き出すやうになる。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて十一月｜某日、自分は朝から書斎にこもって書見をしていた、とあらためて書き出す。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "題を決めるのに一日、構想を考えるのに一日、たのまれてから書き出すまでに二日しか費さなかったぐらいだから、安易な態度ではじめたのだが、八九回書き出してから、文化部長から、通俗小説に持って行こうとする調子が見えるのはいかん、調子を下すなと言われたので、決然として、この作品に全精力を打ちこむ覚悟をきめた。",
              "citation": {
                "source": "文学的饒舌",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は原稿を書き出すと、そばにゐてルビを打つて呉れるお鳥のことも殆んど忘れたやうになつてしまう。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　新子は、およそ二月ぶりで、美沢に手紙を書くとなると、無理矢理に押し込んだり、駆逐したりしていた感情が、一々新しい生命を吹き込まれたように、心の隅々に甦って来て、とても平静な気持で、美沢に呼びかけ、美和子のことを書き出すことが、出来にくかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かの高説を借り、論理のはしごに上って高みから説き起こすかわりに、自分自身や、置かれている状況のありのままを見つめるところから始め、そこから書き出す方法にも、単なる方法論以上の意味があると思います。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ小生の所有にかかはる土地の件に関しては度々申しあげたるが如く一切を放擲したきが年来の小生の念願なれば――」　云々といふ手紙を書き出すのであつたが、交川に書いた時のやうな情熱が伴ふことなく、たちまち眠くなつて来るのであつた。",
              "citation": {
                "source": "疑惑の城",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この米高また紙高の時節に羊に関する雑談などを筆するは真に張り交ぜ屏風を造って羊に食わすほど紙｜潰しな業と思えど、既に六、七年続き来った『太陽』の十二獣談を今更中絶も如何と、流行感冒の病み上りでふらつく頭脳で思い付き次第に書き出す。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれを書き出す前に注意して極量を少しく超過するだけの分量を服んだのである。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ボンボン時計にも鳩時計にも赤い札が貼られてゐたが、時計は何時ものやうに動いてゐた――と書き出すかな。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩主人とお宿へでも伺はせて頂きたいと思ひますの、およろしいでせうか」　こんな風に書き出すと、ネルの話も盡きさうにない。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "この外交官はその頃名うての筆まめな男で、勢みに乗るとどんな皮肉を書き出すか判らなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は書き出す時は、あまりの嬉しさに勢い込んで出来るだけ精密に叙述して来たが、慣れぬ事とて余計な叙述をしたり、不用な感想を挿入したり、読み返して見ると自分でもおかしいと思うくらい精しい。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "李剛は中央の大机に帰って、通知書を参考しながら原稿を書き出す。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボウイが正面壁間の黒板へ何か書き出す。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、心臓が口からとび出しはしまいかと思うほど胸轟かして文房堂から買って来た原稿紙をひろげて、何かを書き出す。",
              "citation": {
                "source": "青春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時頃になって少し涼しくなってから、わきに濡手拭を引きつけて、汗をふきふきこれを書き出す。",
              "citation": {
                "source": "一日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていよ／＼書き出して見ると、その心配の爲めに、書き出すまでの熱心は半分以上も減じてしまひ、當てにならない女だといふ恨みが先きに立つて、優しい言葉がどうしても出ない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう／＼煙草錢を氷峰に出させてもゐられないから、「僕もまた原稿書きをやらうか」と、さし當り新らしい物を書き出す勇氣はないので、義雄は自分が東京出發前後に書きかけた小説――面白くないので、中絶してあるの――を取り出し、讀み返して見る。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、それではまだ足りないと思つてか、義雄が爐を右にしてがらす窓のそばの小机にもたれてゐるのを押しのけ、その席を奪つて、自分が机に向ひ、渠をじらすつもりで手紙を書き出す。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "」義雄は辛抱し切れないで云つた、「おれは今これを書き出すところだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "第九章「論者とカライルと僕との相違」といふ項目を書き出す時、午前五時が鳴つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝から夕まで家の中に射し込んでゐる夏の日光を、みのるは彼方此方と逃げ廻りながら隅の壁のところに行つてその頭をさん／″＼打つ突けてから又書き出す事もあつた。",
              "citation": {
                "source": "木乃伊の口紅",
                "author": "田村俊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "純一はこれまで物を書き出す時、興奮を感じたことは度々あったが、今のような、夕立の前の雲が電気に飽きているような、気分の充実を感じたことはない。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝、女中がストーブの灰をかきだすと、兵隊さんは、小さなハート形の、すずのかたまりになっていました。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は頭で物を考え出すよりもフケをかきだす方がいゝと考えているような様子であった。",
              "citation": {
                "source": "遺恨",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして間もなく大きな鼾をかきだすと見る間に、隣に着飾った若奥様らしい人の肩に凭れて、いい気持ちそうに眠ってしまった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
