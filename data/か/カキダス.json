      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to scrape out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "鍋の焦げ付きをヘラでかき出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "泥をバケツからかき出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "溜まったごみを排水溝からかき出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冷蔵庫の霜をかき出す作業は大変だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "甘い物のげっぷと一しょに、いつもの「ふらんす女・涙の半生」を機械的に繰り返しながら、はなし半ばに怒濤のような鼾をかき出す可哀そうなテレサ！",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで傍に人の居るのを忘れた様に自分の爪の先からかき出す音の行末を追う様に耳をかたむけて居る。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もぐら戦車は、はじめ、あの先のとがったかたい鼻で、土を掘りくずし、それから前脚をつかって、その土を、うしろへかき出す。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然足を踏まれた先刻の職人が鼾声をかき出す。",
              "citation": {
                "source": "深川の唄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは八月に入ってからかき出す積りです。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "能登の方へ行くとカイノゴといふ者が多く、カイは匙即ち臼の中のものをかき出す器の名らしいから、本來は團子の粉のことゝいふ方が正しく、つまりはカイノゴ用の米といふことを省略した名かと思はれる。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "能登の方へ行くとカイノゴという者が多く、カイは匙すなわち臼の中のものをかき出す器の名らしいから、本来は団子の粉のことという方が正しく、つまりはカイノゴ用の米ということを省略した名かと思われる。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手紙をかき出すについて、まず伸子は、癇癪をしずめなければならないと考えているところだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に腰が据れば、それが（小説をかき出すのが）おのずから本当だと思われます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう手紙かき出すときにはもっとほかのいろいろのことを話そうとしていたのでしたがおのずから「うっせき」が洩れました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝、女中がストーブの灰をかきだすと、兵隊さんは、小さなハート形の、すずのかたまりになっていました。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は頭で物を考え出すよりもフケをかきだす方がいゝと考えているような様子であった。",
              "citation": {
                "source": "遺恨",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして間もなく大きな鼾をかきだすと見る間に、隣に着飾った若奥様らしい人の肩に凭れて、いい気持ちそうに眠ってしまった。",
