[
  {
    "uuid": "d9167258-4f60-5086-9e94-0d0b6fb6966f",
    "entry": "仮面",
    "reading": {
      "primary": "かめん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
