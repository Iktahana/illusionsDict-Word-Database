        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は正体を隠すために、巧妙な仮面を被っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "女優は、プライベートでは顔を隠すための仮面を愛用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この芝居の主人公は、常に仮面をつけて登場する謎めいた人物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
