    "definitions": [
      {
        "index": 1,
        "gloss": "yours sincerely",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「寒暖定まらぬ折、どうぞ皆様ご自愛くださいませ。かしこ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "亡き祖母が遺した古い手紙は、どれも美しい筆致の「かしこ」で結ばれており、当時の奥ゆかしさを感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "義母への礼状を書き終え、最後に一筆「かしこ」と添えてから丁寧に封筒を閉じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "若くは、「俺をやつぱり畏れてゐるな」。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は人の富や名声に対しては嘗つて畏敬の念を抱いた事は無いが、どういうわけか武術の達人に対してだけは、非常に緊張するのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が這入つた時、教師達は誰も話をしてはゐなかつたが、それと知ると其処にゐた全部の者は一斉に、不馴れな人間に対する心意気のない、畏敬の表情を作つて差向けてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「佛蘭西文學の旺盛時代たる路易第十四世の朝に於て、突如として一世の耳目を聳動し來れる一書あり、其の簡淨痛快にして靈犀奇警なる人世批評は、天下驚畏の中心となれり、本書是れ也。",
              "citation": {
                "source": "ラロシフコー",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌くる日は穂高岳に上るつもりで、朝｜夙く起きた、宿の女が「飯が出来やしたから、囲炉裏の傍でやって下せえ、いけましねえか」と、畏る畏る閾越しに伺いに来る、いいとも、と返辞して大囲炉裏の前に、蝋燭を立て、猟士や宿の人たちと、車座になって飯を済ます、準備も整って出かけると、雨になった。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "地を相するというのは畢竟自然の威力を畏れ、その命令に逆らわないようにするための用意である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "震動の筋肉感や、耳に聞こゆる破壊的の音響や、眼に見える物体の動揺転落する光景などが最も直接なもので、これには不可抗的な自然の威力に対する本能的な畏怖が結合されている。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで交換局では畏って早速接続すると女皇陛下は御満足で、ものの小半時間もゆるゆる後対話があった。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして僕等の仲間は、彼等の歌人について批評を聞き、文壇的にも先輩として畏敬してゐたのである。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで僕等自身もまた、その缺點を自覺してゐることから、常に常識的なものに畏敬し、常識學の修養につとめて居る。",
              "citation": {
                "source": "常識家の非常識",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度僕のこの敬意は、我々詩人が時に小説家に對して抱く所の、或る種の畏敬と同じ性質の者であつた。",
              "citation": {
                "source": "常識家の非常識",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外村茂は「青空」のなかでもその苦しいまで正義感に溢れた作風で人々の注目、畏敬を集めてゐた。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸助十二歳の時、子供らと海に遊び、誤りて溺れしを、見てありし子供ら、畏れ逃げてこの事を人に告げざりき。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分もこの老いさらぼえた山人に何とはなしに畏怖の念をいだいていたが、しかしその「山オコゼ」というのがどんなものだか知りたいという強い好奇心を長い間もちつづけていた。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "両親が昔安政の地震に遭難した実話を、子供の時から聞かされていたこともこの畏怖の念を助長する効果はあったかもしれないのであるが、しかしそれにはかかわらず、おそらく地震に対するこの恐怖は本能的なものであった。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "重圧する畏怖の下に、黙々と憐れな人間の意図を衛っている。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間は金毛の兎が遊んでいるように見える谿向こうの枯萱山が、夜になると黒ぐろとした畏怖に変わった。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮は、報徳神社といふ、彼の二宮尊徳翁を祭れるもの、石段の南北に畏くも、宮樣御手植の對の榊、四邊に塵も留めず、高きあたり靜に鳥の聲鳴きかはす。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝る時、上人は帯を解かぬ、もちろん衣服も脱がぬ、着たまま円くなって俯向形に腰からすっぽりと入って、肩に夜具の袖を掛けると手を突いて畏った、その様子は我々と反対で、顔に枕をするのである。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　私はそのさっきから何んとなくこの婦人に畏敬の念が生じて善か悪か、どの道命令されるように心得たから、いわるるままに草履を穿いた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その馬がさ、私も別に馬は珍しゅうもないが、白痴殿の背後に畏って手持不沙汰じゃから今引いて行こうとする時縁側へひらりと出て、（その馬はどこへ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は畏って聞き果てると、膝に手をついたッきりどうしても顔を上げてそこな男女を見ることが出来ぬ、何か胸がキヤキヤして、はらはらと落涙した。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの中、キリシタンの法は、少しは奇異を見せたものかも知らぬが、今からいえば理解の及ばぬことに対する怖畏よりの誇張であったろう。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして畏るべき鉄のような厳冷な態度で修法をはじめた。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」なるほどこういう状態では、当人は宜いが、周囲の者は畏れたろう。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "織田信長が今川を亡ぼし、佐※木、浅井、朝倉をやりつけて、三好、松永の輩を料理し、上洛して、将軍を扶け、禁闕に参った際は、天下皆鬼神の如くにこれを畏敬した。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その昔、独断と畏怖とが対峙していた間は今日の「科学」は存在しなかった。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芋虫などは人間に対して直接にはなんらの危害を与えるものでもなし、考えようではなかなかかわいいまた美しい小動物であるのに、どうしてこれが、この虫に対しては比較にならぬほど大きくて強い人間にこうした畏怖に似た感情を吹き込むかがどうしてもわからない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かしら人間の進化の道程をさかのぼった遠い祖先の時代の「記憶」のようなものがこの理由不明の畏怖｜嫌忌と結びついているのではないかという疑いが起こし得られる。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋宮沢賢治草穂のかなた雲ひくきポプラの群にかこまれて鐘塔白き秋の館かしこにひとの四年居てあるとき清くわらひけるそのこといとゞくるほしき",
              "citation": {
                "source": "恋",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
