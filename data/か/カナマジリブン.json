        "examples": {
          "standard": [
            {
              "text": "日本の新聞記事は、基本的に漢字と仮名交じり文で構成されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "平安時代の文学作品では、女性が書いたものが仮名交じり文で書かれていることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この報告書は、専門用語が多いにもかかわらず、分かりやすい仮名交じり文で書かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現代の文学作品の多くは、読みやすさを考慮した仮名交じり文が主流となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "将来にわたっても、漢字仮名交じり文から、完璧な点訳データを一気に生成するといったことは困難だろう。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "総合研究所で基礎研究の進められていた仮名を漢字に変換する技術を生かし、大型よりは一回り小振りのミニコンピューター（と言ったってパーソナルコンピューターに比べりゃクジラよ）をベースに、漢字仮名交じり文の作成機を商品化するプロジェクトが第一。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
