[
  {
    "uuid": "79ecec81-f439-5cd3-8b6c-600d9fa78a47",
    "entry": "唐物屋",
    "reading": {
      "primary": "からものや",
      "alternatives": [
        "とうぶつや"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Edo-period seller of foreign goods",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "江戸時代、浅草には多くの唐物屋が集まり、異国の珍品を扱っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この絵巻物には、当時の唐物屋の賑わいが描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祖父の古い日記には、昔ながらの唐物屋で買ったという品物の話が出てくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "三　ライオンを出てからは唐物屋で石鹸を買った。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（清正公樣の前だよ……煎豆屋の角、唐物屋の所……水天宮樣の横通………）　と所々で、――釣臺に附いてくれました主人が聲を掛けて教へますのを、あゝ、冥途へ行く路も、矢張り、近所だけは知つた町を通るのかと思ひました。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清正公樣の前、煎豆屋の角、唐物屋の所、水天宮樣の裏通り、とそツち此方で、一寸々々見えなく成つたらしいんですが、……」十一「すぐに、卍が出て、ふつと前へ通つて行きます。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者にしたって同じ事で、下廻りの役者なんぞは、随分給料が安いといって不平を並べますが、大根はといえば好なんだから唐物屋なら唐物屋で、もっと給料を出すからといったところで、役者をやめて其方へ行きやしません。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子は唐物屋や呉服屋、足袋屋などが目につき、純綿物があるかと覗いてみたが、一昨年草津や熱海へ団体旅行をした時のようには、品が見つかりそうにもなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも、この懐中の一両は、それがし昨日、かねて所持せし徳乗の小柄を、坂下の唐物屋十左衛門方へ一両二分にて売って得た金子には相違なけれども、いまさらかかる愚痴めいた申開きも武士の恥辱。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不運の友を、いささか不憫と思召さば、わが自害の後に、坂下の唐物屋へ行き、その事たしかめ、かばねの恥を、たのむ！",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎はその夕方野々宮さんの所へ出かけたが、時間がまだすこし早すぎるので、散歩かたがた四丁目まで来て、シャツを買いに大きな唐物屋へはいった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある唐物屋の中からは、私の嫌ひなものゝ一つである蓄音機の浪花節が、いやに不自然な聲を出して人足をとめようとしてゐましたが、誰もちよいと振りかへつたまゝでそゝくさ行き過ぎるのが、「もうぢきに冬が來るぞ、ぐづ／＼してはゐられやしない。",
              "citation": {
                "source": "冬を迎へようとして",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもながら、場末の唐物屋にメリヤスの肌着が積まれ、大賣出しの立札がたてられ、三等郵便局の貯金口に人垣が作られ、南京豆の空袋が、風にふかれて露地を走る風景の中では、街角に傾いたまゝ突立つた瓦斯燈よりも、人間は慌しいと思ふことだ。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "新式に硝子戸の店を造った唐物屋の前には、自転車が一個、なかばは軒の雨滴れにぬれながら置かれてある。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理屋に三味線の音が夜更けまで聞こえ、市日には呉服屋唐物屋の店に赤い蹴出しの娘をつれた百姓なども見えた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの店でも弓張り提灯をつけて、肴屋には鮭、ごまめ、数の子、唐物屋には毛糸、シャツ、ズボン下などが山のように並べられてある。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ、その頃は硝子戸を入れる時代になっておりませんから、何処でも塵埃のためには困らされました（その頃、タシカ、神田のお玉ヶ池の佐羽という唐物屋がたった一軒硝子戸を入れていたもので、なかなか評判でありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "高村東雲の生い立ち",
                "note": "青空文庫"
              }
            },
            {
              "text": "埃深い唐物屋や古着屋の店なども、年々衰えてゆく町の哀れさを思わせている。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女が若い盛りに、杉の森の裏小路で、長唄のお師匠さんをしていた時分、若い衆であったお店の人甚兵衛さんが思いついて夫婦になり、当時の開港場横浜取引の唐物屋になったのだ。",
              "citation": {
                "source": "鬼眼鏡と鉄屑ぶとり",
                "author": "続旧聞日本橋・その三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いってみれば唐物屋はインテリくさく、鉄商は鉄火だった。",
              "citation": {
                "source": "鬼眼鏡と鉄屑ぶとり",
                "author": "続旧聞日本橋・その三",
                "note": "青空文庫"
              }
            },
            {
              "text": "京橋八官町の唐物屋吉田吉兵衛なのである。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの角にある店蔵が、半分は小さな郵便局に、半分は唐物屋になっている。",
              "citation": {
                "source": "お律と子等と",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その唐物屋の飾り窓には、麦藁帽や籐の杖が奇抜な組合せを見せた間に、もう派手な海水着が人間のように突立っていた。",
              "citation": {
                "source": "お律と子等と",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋一は唐物屋の前まで来ると、飾り窓を後に佇みながら、大通りを通る人や車に、苛立たしい視線を配り始めた。",
              "citation": {
                "source": "お律と子等と",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、空房の漢語も讀めたれば、場所に似合はぬ唐物屋も、よめたり。",
              "citation": {
                "source": "飛鳥山遠足",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐物屋の頭禿げし亭主の顏今も忘れず、繪草紙賣る店に屡々通ひしも事實なれど、その他の人はお鶴はもとより煙草屋の姉弟も皆我がほしいままに描き出せる架空の人物に過ぎざるなり。",
              "citation": {
                "source": "貝殼追放",
                "author": "「その春の頃」の序",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤々と禿げた、肥った翁が丸い鉄火鉢を膝子のように抱いて、睡たそうに店番をしていた唐物屋は、長崎屋と言った。",
              "citation": {
                "source": "山の手の子",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の装飾に斬新をほこる唐物屋や洋酒店の中には、半ば大戸を下した所も見えた。",
              "citation": {
                "source": "茗荷畠",
                "author": "眞山青果",
                "note": "青空文庫"
              }
            },
            {
              "text": "代助は二三の唐物屋を冷かして、入用の品を調えた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "九の六　三四郎は其｜夕方野々宮さんの所へ出掛けたが、時間がまだ少し早過ぎるので、散歩かた／″＼四丁目迄｜来て、襯衣を買ひに大きな唐物屋へ入つた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからものやわらかな調子で、こう言いました。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
