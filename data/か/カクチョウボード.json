        "examples": {
          "standard": [
            {
              "text": "デスクトップPCの機能を増やすには、マザーボードのスロットに拡張ボードを取り付けるのが一般的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "高音質で音楽を聴くために、サウンド機能に特化した拡張ボードを増設した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "USBポートが足りなくなったので、USBハブ機能を持つ拡張ボードの購入を検討している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "エド・ロバーツにとっての悩みの種は、アルテア用のさまざまな機能拡張ボードが、赤の他人によって作られはじめたことだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本体内には拡張ボードを差し込むための増設スロットが五つ用意されており、オプションにまわされた容量一六〇Ｋバイトの五インチドライブを二台組み込むスペースが空いていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
