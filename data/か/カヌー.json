        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "湖畔のレンタルショップでカヌーを借りて、水上散歩を楽しみました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "アマゾン川での冒険旅行では、カヌーを使ってジャングルを探検しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちは、初めてのカヌー体験に大興奮していました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "静かな川面をカヌーで進むのは、とてもリフレッシュできますね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一れつ一れつならんでる、カヌーがなぎさにならんでる。",
              "citation": {
                "source": "一れつ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "）な邸宅の噂は、やがてカヌーに乗って、遠くフィジー、トンガ諸島あたり迄｜喧伝された。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カヌーとボートとに分乗。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母達のカヌー組は既に着いていた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗ろうとすると、スコール襲来、再び家に戻り、半時間休んでから、五時出発、またボートとカヌーとに分乗。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度側を通りかかつた島民の男を呼びとめ、カヌーを漕がせて、船に歸つた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十分後、殊勳の二水夫に押へられたナポレオンが再び島のカヌーで船に連れ戻された時、眞先に彼は手酷い平手打を三つ四つ續けざまに喰はせられた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "堡礁内の淺い緑色の水、眞白い砂と丈高い椰子樹の遠望、汽船目懸けて素速く漕寄せて來る數隻のカヌー、其のカヌーから船に上つて來ては船員の差出す煙草や鰯の罐詰などと自分等の持ち來たつた※や卵などとを交換しようとする島民共、さては、濱に立つて珍しげに船を眺める島人等。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "カヌーに移り、やがてカヌーから岸に下り立ち、二三の島の者と共に警官について椰子林の間に消えて行くのを、私は甲板から見送つた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど側を通りかかった島民の男を呼びとめ、カヌーを漕がせて、船に帰った。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十分後、殊勲の二水夫に押えられたナポレオンが再び島のカヌーで船に連れ戻された時、真先に彼は手酷い平手打を三つ四つ続けざまに喰わせられた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "堡礁内の浅い緑色の水、真白い砂と丈高い椰子樹の遠望、汽船目懸けて素速く漕寄せて来る数隻のカヌー、そのカヌーから船に上って来ては船員の差出す煙草や鰯の缶詰などと自分らの持ち来たった鶏や卵などとを交換しようとする島民ども、さては、浜に立って珍しげに船を眺める島人ら。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "カヌーに移り、やがてカヌーから岸に下り立ち、二、三の島の者と共に警官について椰子林の間に消えて行くのを、私は甲板から見送った。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "カヌーという丸木舟。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "港まで、あと海上三マイルというところで、ぼくは五、六艘のカヌーが帆を張って走っているのを認めた。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "六隻よりなる船団なれども……」「なれども――どうした」「帆を張った現地人のカヌーじゃ」「なんだ、カヌーか。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "カヌーじゃ、おどかしばえもしないが、店開きだから、やってみよう」　そして、かねての手筈どおりやった。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐさま恐龍号は潜航にうつり、カヌー舟団を追い越した。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐龍はかま首をもたげ、ゆらゆらとふりながら、現地人の、カヌーをにらみつけた。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "木製のカヌーだの、絵だのの中に一つ小さい可愛い、インディアンシューズがある。",
              "citation": {
                "source": "無題（一）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｃ先生、先生は此方の人々が愛用するカヌーを御承知でいらっしゃいますでしょう。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "石垣のはずれのところに、カヌーという丸木舟が、さかさになってすてられていた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉太郎は、そばへ行って、このカヌーをつくづくと見た。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを越えたところに、カヌーがひっくりかえったままになっている。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの細くなっているところね、これから先は、カヌーも行けなくなるんで、みんなで荷物をせおって歩いて行ったんだよ。",
              "citation": {
                "source": "イグアノドンの唄",
                "author": "――大人のための童話――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
