        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昨夜の宴会の後、テーブルに残された燗冷ましは、もう飲む気になれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ああ、この燗冷まし、ちょっともったいないけど、もう美味しくないから捨てようか。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の店では、一度燗冷ましになった酒を、お客様に出すことは絶対にない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "居たたまらぬ風で、冷汗を流しつゝ居室へ入つた道臣は、燗冷ましの酒を手酌でグイ／＼飮んだ。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルコール分は含まれていなくていいのだし、飲んで酔おうというのとは異なるから、かんざましでよいわけである。",
              "citation": {
                "source": "鍋料理の話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
