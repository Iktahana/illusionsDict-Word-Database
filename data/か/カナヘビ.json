        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭の手入れをしていたら、葉っぱの上で日向ぼっこをしている金蛇を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、よく田んぼのあぜ道で金蛇を追いかけて遊んだものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その昆虫を狙っているのか、石の上でじっと動かない金蛇がいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鮮やかな緑色の金蛇は、光に当たるとキラキラと輝いて見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "入江の奧より望めば舷燈高くかゝりて星かとばかり、燈影低く映りて金蛇の如く。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "入り江の奥より望めば舷燈高くかかりて星かとばかり、燈影低く映りて金蛇のごとく。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "月は中天にありて一条の金蛇波上に馳する処、ただ見る十数｜艘の漁船あり。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由豪放な青春の気はその疲れた肉体や、衰えた精神に金蛇銀蛇の赫耀たる光をあたえる。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜はほのぼのと明けて、太陽の光が東の天に金蛇を走らしたころに、一同は身軽に旅装をととのえた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山だ、だが山はあんなに白く見えるはずがない」　ぼくらはなおもかわるがわる望遠鏡をとってながめたが、もう太陽は西にかたむいて海波に金蛇がおどれば、蒼茫たるかなたの雲のあいだに例の白点が消えてしまった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼に入るものは、二三の漁火の星の如く、遠くちらつくと、稀に、銚子行汽船の過ぐるに当り、船燈長く波面に揺き、金蛇の隠現する如きを見るのみにして、樹林無く、屋舎無く、人語馬声無く、一刻一刻、人間界より遠ざかる。",
              "citation": {
                "source": "大利根の大物釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋の外には金蛇の酒を提げた女がうろ／＼してゐる。",
              "citation": {
                "source": "来訪者",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉づきのいい雪膚の腕もあらわにむき出した羅衣軽裳の若い女将で、柘榴色の唇をキュッとゆがめ、金蛇の腕環のみえる手を頬の辺りにやって、さっきから虫を抑えていた風だった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして女の金蛇の腕環を取って、そこからつかみ出すやいな、土間の一隅に埋けてあった三箇の大きな酒甕のうちの一つへ、女将の体を逆しまに放り込んでしまった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全速力でそのおうちからかけ出ると、見つかるのは外で立ちつくす小動物のむれ――モルモット、ラッテといったネズミたちにリスどもと、ミドリカナヘビっていうトカゲの〈ビル〉くん、モルモットの１ぴきにかかえられててね、ほかにもびんから何か飲ませてやってるのもいたり。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
