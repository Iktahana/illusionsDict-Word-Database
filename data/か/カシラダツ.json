    "definitions": [
      {
        "index": 1,
        "gloss": "to become the head (of a group, organization, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ベテランの職人が引退し、一番弟子の彼が現場で頭立つことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "町内会の役員選びで誰もが躊躇する中、彼が自ら頭立って引き受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "新しいプロジェクトチームでは、経験豊富な彼女が自然と頭立つ立場になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "若い衆の中で頭立つには、腕っぷしだけでなく仲間を思いやる人望も必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "……覗くと、静まり返った正面の階の傍に、紅の手綱、朱の鞍置いた、つくりものの白の神馬が寂寞として一頭立つ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……覗くと、静まり返つた正面の階の傍に、紅の手綱、朱の鞍置いた、つくりものの自の神馬が寂寞として一頭立つ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "館野が一つに成つて僕を止める積りであつたから到頭立つことは出來なかつた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、租税課出張所において二、三の頭立つ者を呼んで説諭しようとしたが、誰れも出て来ない。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「校合」今日の「校正係」といふのが頭立つたもので、これも僧侶が當つてゐた。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭立つ老人は小野塚鉄斎の化身とでもいうのであろうか？",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　越前屋の同勢の中で頭立つたのは、これも主人の甥で金次といふ若者。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "遺言状",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に頭立つた子分は、血潮の中の鐘五郎を抱き起しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鐘五郎の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭立つた中年の武士に劬められて、すご／＼と引揚げて行きます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一人も生かしちやならねえ、口がうるさい」　頭立つたのが號令すると、七八本の刄が、折から昇つた月の光を受けて、三方からサツと殺到するのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お局お六",
                "note": "青空文庫"
              }
            },
            {
              "text": "張角は、その弟子たちを、三十六の方を立たせ、階級を作り、大小に分かち、頭立つ者には軍帥の称を許し、また方帥の称呼を授けた。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "身柄はさのみよくもなくて、世馴れた顔にさかしらだつて後宮に立ち交る古女房みやうぶのおもとの名は、此滑稽味を持つた眷属殿には、事実、うつてつけのあざ名である。",
              "citation": {
                "source": "狐の田舎わたらひ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
