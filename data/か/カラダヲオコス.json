        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝、アラームが鳴ってもなかなか体を起こせなかったよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ソファでうたた寝してたのを、家族に呼ばれてハッと体を起こした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "怪我でしばらく寝たきりだったけど、リハビリのおかげで少しずつ体を起こせるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「大丈夫？」って声をかけられて、痛む体をゆっくり起こした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "体を起こすと躄って進んだ。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、素晴らしい」　花井夫人がそう言って、上体を起こす。",
              "citation": {
                "source": "落日の光景",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま思いますと、そのときはもう村上さんは、起きたいとしても、身体を起こすことが出来なかったのでした。",
              "citation": {
                "source": "手紙",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "芳衛さんが、揺椅子の中で、急に身体を起こす。",
              "citation": {
                "source": "キャラコさん",
                "author": "雪の山小屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "お邪魔してはいけませんから……」　佐伯氏は、あわてたように身体を起こすと、「邪魔だなんて、……よかったら、……すこし、話して行ってください」　そういって、狭い蘆の間で、すこし身体をすさらした。",
              "citation": {
                "source": "キャラコさん",
                "author": "蘆と木笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャラコさんは、長椅子から身体を起こすと、足音を忍ばせながら、そっとレエヌさんの部屋をのぞきに行った。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャラコさんは、寝台のうえにそっと身体を起こす。",
              "citation": {
                "source": "キャラコさん",
                "author": "雁来紅の家",
                "note": "青空文庫"
              }
            },
            {
              "text": "舗道の上に体を起こすのは容易だったが、縞模様のある磨かれた敷石がどんなものか見分けることができず、切り出されたタイルの形状は奇怪な角度を持っており、非対称的というよりも、地上のものではなく彼の理解の及ばぬ何らかの対称性に従っているのだという考えが頭に浮かんだ。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体を起こすためには、手足を使うはずだった。",
              "citation": {
                "source": "変身",
                "author": "DIE VERWANDLUNG",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂の上に体を起こすと、砂丘のスロープの途中に立っている亜紀子が、彼の視線のなかに入った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
