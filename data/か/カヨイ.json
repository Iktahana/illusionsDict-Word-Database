    },
    "definitions": [
      {
        "index": 1,
        "gloss": "coming and going",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この交差点は車の通いが激しく、事故が多発している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "駅周辺の人の通いが一日中絶えない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "鳥の通いが以前より減ったように感じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人々の賑やかな通いが、この商店街の活気を生み出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この道は、裏道としては車の通いが意外と多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "文化のガイドたちは、またまた図書館通いを始めなければなるまい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはずっと後のことであるが、ここへ通いながら纏めた小さな仕事を気象のコロキウムで話すように教授から命ぜられたとき、言葉が下手だからと云って断ったが、自分がすけてやるからぜひやれと云われ、仕方なしに黒板の前に立たされた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三学期一年半のベルリン大学通いは長いようでもありまた短いようでもあった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五にごく近頃、ハンブルヒのシュリックという有名な造船家が大きな独楽を船中に取付け、これを迅速に回転すると横揺れがほとんど止まるという巧みな考えを出し、小形の船で実験したら非常に好結果を得たので更に目下エルベ、ヘリゴランド間通いの千トンくらいの客船に取付けるのを製造中だそうである。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが普通いう山の麓であることか、おおらおおら。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隙を覗い折を見ては苫船へ通います。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして流行着のマネキンを乗せたロンドン通いの飛行機が悠長に飛んで行く。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸な夫ルパートが「第三者」アリスンの部屋から二階の妻ジュリーの部屋への隠れた通い路を発見して、暗い階段をびっこ引きながら上がって行く。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が夜会服に替えてサルーンに設けられた席に着くと、金モールの事務長の植民地通いの海員らしい頑丈な腕がさしのべられて関西｜訛のある社交的なバスが、ようこそ、Ｙさん。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父は、江戸通いの船乗りであった。",
              "citation": {
                "source": "自伝",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪から例の瀬戸内通いの汽船に乗って春海波平らかな内海を航するのであるが、ほとんど一昔も前の事であるから、僕もその時の乗合の客がどんな人であったやら、船長がどんな男であったやら、茶菓を運ぶボーイの顔がどんなであったやら、そんなことは少しも憶えていない。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の初め、彼は城下に住むことを厭いて、半里｜隔てし、桂と呼ぶ港の岸に移りつ、ここより校舎に通いたり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大通いずれもさび、軒端暗く、往来絶え、石多き横町の道は氷れり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "末の二人はどんな好いところへ行くかと思われるように喜んで、そして自分等の好みで学校通いの洋服を着せてもらって、一時間も前から靴をはいて勇んで飛び廻っていた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四、五日たってから、ある朝奮発して早起きして、電車が通い始めると絵具箱を提げて出かけた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉原通いらしい鼻唄の声を聴きながら、二人はここに半刻ほども待ち暮らしていると、暗いなかから人の来るような足音が低くきこえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは毎晩かかさず通いつづけていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "久次郎はその後も相変らず通いつづけていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "とお前様お聞かせ申す話は、これからじゃが、最初に申す通り路がいかにも悪い、まるで人が通いそうでない上に、恐しいのは、蛇で。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは前にも申した通り学生生活の時代が極短くて、漢学の私塾にすらそう長くは通いませんでした。",
              "citation": {
                "source": "学生時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "去勢されたような男にでもなれば僕は始めて一切の感覚的快楽をさけて、闘争への財政的扶助に専心できるのだ、と考えて、三日ばかり続けてＰ市の病院に通い、その伝染病舎の傍の泥溝の水を掬って飲んだものだそうだ。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人は苦労人で、ちゃんとできた人であるから、醜くとり乱すこともなく、三七、二十一日病院に通い、注射を受けて、いまは元気に立ち働いているが、もしこれが私だったら、その犬、生かしておかないだろう。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでも若い時分は弁護士になろうてんで、神田の東洋法律学校へ通いまして六法全書なんかをヒネクリまわしていたもんですが、生れ付きのナマクラでね。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の貫きて真直に通う路あり、車もようよう通い得るほどなれば左右の梢は梢と交わり、夏は木の葉をもるる日影鮮やかに落ちて人の肩にゆらぎ、冬は落ち葉深く積みて風吹く終夜物のささやく音す。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後は私も二晩置きか三晩置きには必ずお幸のもとに通いましたが、ごく内証にしていましたから、誰も気がつきませんでした。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この主婦の亡夫は南洋通いの帆船の船員であったそうで、アイボリー・ナッツと称する珍しい南洋産の木の実が天照皇大神の掛物のかかった床の間の置物に飾ってあった。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれの場合にも、普通いかなる意味においても決して笑うべき理由は見つからないが、それにもかかわらず笑いの現象が現われ来るのをいかんともする事ができなかった。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が初めて平円盤蓄音機に出会ったのは、瀬戸内海通いの汽船の客室であったように記憶する。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから「娘を堅う人にあわせぬ」と強く響くあとに「奈良通い同じつらなる細元手」と弱く受ける。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃｜痳疹が流行りよるけに何かよい禁厭はないかちゅう話から、わしが気休めに書いて遣った、意味も何もない出放題じゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
