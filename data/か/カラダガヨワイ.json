[
  {
    "uuid": "ec6745da-e500-5624-90f8-36c72087bc6c",
    "entry": "体が弱い",
    "reading": {
      "primary": "からだがよわい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
