    "definitions": [
      {
        "index": 1,
        "gloss": "pumpkin (Cucurbita sp.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食卓には、甘く煮付けたかぼちゃが並んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ハロウィンの時期には、かぼちゃをくり抜いてランタンを作るのが恒例だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "家庭菜園で育てたかぼちゃが、今年は豊作だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "十一日　垣にぶら下がっていた南瓜がいつの間にか垂れ落ちて水引の花へ尻をすえている。",
              "citation": {
                "source": "窮理日記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　朝霧が山村を罩めて、鶏の声が、霧の底から聞える、黄色い南瓜の花に、まだ夢が残つてゐるかして、寝惚けた姿をしだらなく大地に投げ出してゐる、ぼツと白壁が明るくなる、森がうつすらと、烟つぽい緑を、向うの山の懐に、だんだら、染めに浮かせる、起き上つて支度をする頃は、方々の家から、軽い炊煙が立ちはじめた。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母の云うのはみんな北海道｜開拓当時のことらしくて熊だのアイヌだの南瓜の飯や玉蜀黍の団子やいまとはよほどちがうだろうと思われた。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑とも庭ともつかない地面には、梅の老木があったり南瓜が植えてあったり紫蘇があったりした。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裾短かで袖は肱より少い、糊気のある、ちゃんちゃんを着て、胸のあたりで紐で結えたが、一ツ身のものを着たように出ッ腹の太り肉、太鼓を張ったくらいに、すべすべとふくれてしかも出臍という奴、南瓜の蔕ほどな異形な者を片手でいじくりながら幽霊の手つきで、片手を宙にぶらり。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以外には南瓜の畑も、豌豆の畑も、玉葱の畑も、カイベツ（甘藍）の畑も、一樣にくすんだ夜の色になつてゐる。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その為に作った南瓜や蕪菁もたべる。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はははは飛ぶわ飛ぶわ、南瓜畠へ潜って候。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "われら此の森の伏屋、小川の芦、海は申すまでも候はず、岩端、松蔭、朝顔、夕顔、蛍、六代御前の塚は凄く涼しく、玄武寺の竜胆は幽に涼しく、南瓜の露はをかしげに涼しく、魚屋の盤台の鱸は……実は余りお安値からず涼しく、ものにつけ涼しからぬはこれなく候。",
              "citation": {
                "source": "逗子より",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼とんびが手毬をつくやうなしをらしいことはすまいと、あの時思つただけど、何しろ俺達や南瓜みてェな馬鹿ばかりだで。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どつしりと尻を据えたる南瓜かなと云う句も其頃作ったようだ。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく瓜と云う字のつく所を以て見ると南瓜も糸瓜も親類の間柄だろう。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "親類付合のある南瓜の句を糸瓜仏に奉納するのに別段の不思議もない筈だ。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、御飯を頂いて、柄相応に、月夜の南瓜畑でもまた見に出ましょうかね。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "麓では、二人の漁夫が、横に寝た大魚をそのまま棄てて、一人は麦藁帽を取忘れ、一人の向顱巻が南瓜かぶりとなって、棒ばかり、影もぼんやりして、畝に暗く沈んだのである。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "放題の荒地で、雑草は、やがて人だけに生茂った、上へ伸び、下を這って、芥穴を自然に躍った、怪しき精のごとき南瓜の種が、いつしか一面に生え拡がり、縦横無尽に蔓り乱れて、十三夜が近いというのに、今が黄色な花ざかり。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その薄さえ、垣根の隅に忍ぶばかり、南瓜の勢は逞しく、葉の一枚も、烏を組んで伏せそうである。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、これでは地味が荒れ果てる、無代で広い背戸を皆借そうから、胡瓜なり、茄子なり、そのかわり、実のない南瓜を刈取って雑草を抜けという。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十六、七の若いものに、畠いじりは第一無理だし、南瓜の蔓は焚附にもならぬ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　ここから、南瓜の葉がくれに熟と覗くと、霧が濃くなり露のしたたる、水々とした濡色の島田｜髷に、平打がキラリとした。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸七は、蟇と踞み、南瓜の葉がくれ、尾花を透かして、蜻蛉の目で。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に南瓜の葉が一面に波を打って、真黄色な鴎がぱっと立ち、尾花が白く、冷い泡で、糸七の面を叩いた。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "南瓜の葉蔭に……　　　　　　　三十五尾花を透かして、蜻蛉の目で。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――とにかく、来客――跣足のまま、素袷のくたびれた裾を悄々として、縁側へ――下まで蔓る南瓜の蔓で、引拭うても済もうけれど、淑女の客に、そうはなるまい。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸七の気早く足へ掛けたバケツの水は、南瓜にしぶいて、ばちゃばちゃ鳴るのに、障子一重、そこのお京は、気息もしない。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんな、そんな事、何、こんな内、上るにも、踏むにも、ごらんの通り、西瓜の番小屋でもありゃしません、南瓜畑の物置です。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山果庭ニ落チテ、朝三ノ食｜秋風ニ※クとは申せども、この椎の実とやがて栗は、その椎の木も、栗の木も、背戸の奥深く真暗な大藪の多数の蛇と、南瓜畑の夥多しい蝦蟇と、相戦う衝に当る、地境の悪所にあって、お滝の夜叉さえ辟易する。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、この縁側に腰を掛けて、眼をショボショボさせている写真、これも甲府に住んでいた頃の写真ですが、颯爽としたところも無ければ、癇癖らしい様子もなく、かぼちゃのように無神経ですね。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かぼちゃを食わぬ主義や、いがくり頭で通す主義や、無帽主義などというのは愛嬌もあるが、しかし他人の迷惑を考慮に入れない主義もあった。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "御家族の方たちは、みんな母屋のほうにいらっしゃって、私たちのために時たま、番茶や、かぼちゃの煮たのなどを持ち運んで来られる他は、めったに顔をお出しなさらぬ。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
