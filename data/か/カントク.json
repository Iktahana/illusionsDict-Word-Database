[
  {
    "uuid": "a878b514-882a-5db4-a50d-827a9101a797",
    "entry": "監督",
    "reading": {
      "primary": "かんとく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
