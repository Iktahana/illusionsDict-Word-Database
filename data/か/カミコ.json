        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔、特別な儀式のために、紙子で作られた衣装が用いられたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "美術館で、薄い紙子で作られた繊細な人形を見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「こんな紙子で服が作れるなんて、面白いね！」と、子供が感心していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "二番目は我当が出し物の「紙子仕立両面鑑」で、十月中旬から開場した。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にその出し物とする「紙子」の助六は、義太夫の語りものとしてこそ知られているが、舞台の上で見せられるのは初めてであるので、東京の観客には喜ばれなかった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "只、身すがらにと出立ち侍るを、紙子一衣は夜の防ぎ、浴かた、雨具、墨、筆のたぐひ、あるはさりがたきはなむけなどしたるは、さすがに打捨てがたく、路次の煩ひとなるこそわりなけれ」「奥の細道」　牛込の下宿で捨吉はこの芭蕉の文章を開けた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "（五月一日）『宝船』第一巻第二号の召波句集｜小解を読みて心づきし事一つ二つ紙子きて嫁が手利をほゝゑみぬ「老情がよく現はれてゐる」との評なれど余はこの句は月並調に近き者と思ふ。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝暦十二年の春、ふとした事から豊後訛のある浪人が仙台で紙子揉みをしていたが、女房と何か争った末、女房を足蹴にしたのが基で死なしてしまった――今どうしているか、多分そのまま居やしないか、と云う話を聞いた。",
              "citation": {
                "source": "相馬の仇討",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さうして見ると、「桜鍔恨鮫鞘」の鰻谷も、「紙子仕立両面鑑」の大文字屋も、語り物としては名高いものだつたが、舞台には、彼の発意で移されたものだつた。",
              "citation": {
                "source": "戞々たり　車上の優人",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかな大風だとて、吹き飛ばされもせず、紙子細工ではござらぬから、濡れたところで大事ない。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "へん、紙子細工や張子の虎じゃあるめえし、べら棒め、濡れて落ちるよな箔じゃあねえや。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "無明の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「強製紙」と新しく名附けていますが、「紙子紙」とでも呼ぶ方が至当ではないでしょうか。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち紙子の一種で秘伝として蒟蒻粉を入れて漉きます。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今後私はそれを「紙子紙」と呼ばう。",
              "citation": {
                "source": "和紙十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も柳生だけで出来るのではないが、紙子の系統を引く紙を今も盛に漉くのは此処だけである。",
              "citation": {
                "source": "和紙十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙子として保温甚だよく防寒の具に適する。",
              "citation": {
                "source": "和紙十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近時刊行した私の「工芸文化」や「美と模様」や「芭蕉布物語」は凡てこの紙子紙を素地に用ゐた。",
              "citation": {
                "source": "和紙十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この本の表紙はその紙子紙であるが、こゝに入れた第七と八も同じ紙を素地に用ゐた。",
              "citation": {
                "source": "和紙十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、机の端の紙きれを取って、紙子縒に縒っている。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "返事によっては、吾々三名、徒らに赤穂へ帰って来たものでないことを断っておきますぞ』　内蔵助の指に、紙子縒がぴんと縒れていた。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "読むとすぐ、内蔵助は、紙子縒にして、弄んでいたが、いつのまにか、何うかしてしまった。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "マジエスチック・ホテルのティダンスは閑散として、ロシア人の踊子の赤い踵が見えず、他の金髪美人連がアクビをかみころしていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もしもこれらの問題をかみこなすに適当な「歯」すなわち「方法」が見いだされた暁には、形勢は一変してこれらの「骨董的」な諸現象が新生命を吹き込まれて学界の中心問題として檜舞台に押し出されないとも限らない。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから右手をそっちへ突き出して左手でその右手の手首をつかみこっちへ引き寄せるやうにしました。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから右手をそっちへ突き出して左手でその右手の手首をつかみこっちへ引き寄せるようにしました。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり絶ち切れない因縁のふかみこそはなげきなのだ。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その悪党が一味徒党を組んでお家横領を企てて、おん年二十一歳の若殿さまをのろい殺しに祈ってまわる、そいつをかぎつけた忠犬が、かみころして歩いているという寸法さ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルザックに還れと叫ぶ人々が、バルザックへ戻る前に既にそれをかみこなす自分らの歯を我から不要のものとして抜きすて去っているとしたら、そもそも何の規準によってこの一箇の巨大な古典を摂取し得るであろう。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十二月十二日）　　　　　　　十二の一「さんらんの翡翠の玉の上におくつゆりょうらんの秋はきにけり「秋ふかみこごしく雨の注げばかこころさぶしえとどまりしらず　きょう友人がくれた手紙の端にはかような歌がしるしてあった。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「幽霊もしばしはさしうつむきてゐたりしが、（中略）怨めしと思ふかたきをかみころし、一念散ずるときは泉下へもゆくべきに、いまだ此土にとどまることのふしんさよと心をつけて見るに、さして常にかはることもなし。",
              "citation": {
                "source": "案頭の書",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはおかしさをかみこらえて、彼に毒蜘蛛の恐るべきことと、最近一匹が逃げだしていまに行方のしれないことを話してきかせてやった。",
              "citation": {
                "source": "蜘蛛",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああこないだ順二郎のところへハガキをよこしたようだよ、仙台辺はもう大分朝晩さむいらしいよ」　欠伸にならない欠伸を歯の奥でかみころしながらのような声の調子で、瑛子は、「あのひとは、何ていうんだか、熱がないっていうものか、何しろ電気一点張りなんだから」と、長男のことを云った。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "微かな温かみ、その温かみこそ僅かに秋の夜中の寂寥と冷気とから二人を元気づけていた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
