    "definitions": [
      {
        "index": 1,
        "gloss": "pretext",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は病気を仮託して、気まずい関係の親戚が集まる会合への出席を断った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "作者はこのSF小説に、現代の管理社会への痛烈な風刺を仮託している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女は亡き母への追慕の念を、一輪の白百合の絵に仮託して描いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "が、紀記ともに其処は仮託が多いと思われる。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともちょっとひく感冒と、眩暈は持病で、都合に因れば仮託でね――以前、私の朋達が一人、これは馴染が有って、別なある待合へ行った頃――ちょいちょい誘われて出掛けた時分には、のべつに感冒と眩暈で、いくら待っても通って見ても、一度も逢えた事は無かったんだ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に曰く、太祖の遺詔に、諸王の入臨を止むる者は、太祖の為すところにあらず、疑うらくは斉泰｜黄子澄の輩の仮託するところならんと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "到来物があるたびに、以前は燥ゃぎ立って隣家の加福の家へ自分で裾分けを持って行ったものだったが、この頃は、母親に言われても、何かに仮託けて、つかいに行きたがらない。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "漱石先生の「夢十夜」のやうに、夢に仮託した話ではない。",
              "citation": {
                "source": "点心",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの精緻な追求や仮託は、吾々にとって一時の道連れに過ぎなかった。",
              "citation": {
                "source": "文学に於ける構想力",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯｜一人子にあるが苦しさ――市原王悲独子歌（巻六、一〇〇七）ことゝはぬ木にはありとも、うるはしき君が手馴れの　琴にしあるべし――琴の精の処女に仮託して。",
              "citation": {
                "source": "日本文学における一つの象徴",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其を山三お国に仮託したものと思ふ。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "強ひて言はゞ、好事の創作歌人が、軽太子・春日皇女等の故事に似た此情史を伝へた為、仮託したものかとも思はれる。",
              "citation": {
                "source": "相聞の発達",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其は先に言うた伝奇情史として、文学に目醒めた人が、代作気分の残つてゐる時代の一つの影響として、二人の唱和を、頼まれない代作としての芸術に仮託したものと見る事である。",
              "citation": {
                "source": "相聞の発達",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "やまとたける或は、大国主・大鷦鷯天皇・大長谷稚武天皇に仮託した文学は、所謂美的生活に徹した寂しさ、英雄のみが痛感する幽けさを表してゐた。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "詔旨と寿詞との間に、天神に仮託した他の神――とこよ神の変形。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "北御門へ来る神楽は、恐らく北方からくる神であつて、或はおなじ八幡に仮託せられる様になつたとしても、気比の神らしい処が見えるのである。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此らの怒りを鎮めた事の伝へから、男性の怒りに関することは、長谷天皇に仮託して言ふやうになつた。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、やゝ似た事態が岡本の場合に起つたとき、岡本に仮託してかねての憤懣を吐きだしてゐるのではないかと。",
              "citation": {
                "source": "女体",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの方向への発展は、それが教権への挑戦の武器としてかかげられたる時は正当なる権利を保持したにもかかわらず、その実践的弁証法的発展の中に一つの桎梏として変容し、天才と独創と美の概念が、ややもすれば放恣と個人性と非真実性とに仮託的重要さを貸し与えるの危険性にまで立ちいたるのである。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちそれはかの天才と独創と美の概念がついにややもすれば放恣と個人性と非真実性とに仮託的重要さを貸し与えるにいたった危険性である。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし注意すべきは、この新しき芸術観、すなわち天才と創造と美の概念は、個人主義勃興期に確立された時は、封建主義への叛逆の武器として、実に正当な権利を保持したるにもかかわらず、天才と独創と美の概念はついにややもすれば、放恣と個人性と非真実性とに仮託的重要さを貸し与えるの危険性をはらんできた。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "純粋の名の下に、放恣と個人化と非真実（畸形性）が仮託的重要性をもつにいたったのである。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして天才と創造の概念は、ついに放恣と個人性とに仮託的重要さをあたえるにいたった。",
              "citation": {
                "source": "絵画の不安",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "察するに『由来記』は徳川時代に大和の金峰山に倣って、蔵王権現と改称した時に作ったもので、座王も蔵王と書くべきを故意に座王とし、空海に仮託して古いもののように思わせようとしたのではないかと考える。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は鳥海氏が蕨岡の社に勢力を張るに及びて、霊鳥に仮託して縁起を説き、山を鳥海と唱えしむるに至ったのかも測られないが、今は暫く疑問の儘にして他日の調査に待つことにする。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『夢がたり』は、『アッタレーア』などと並んで、動植物の世界に仮託された童話の形式を持っている。",
              "citation": {
                "source": "「あかい花　他四篇」あとがき",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいまこの一つの言葉に、色々の意味を仮託して置く。",
              "citation": {
                "source": "母たち",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はレーノォなる人物を知らず、その人を加害者に仮託しようなどと、夢にも思っていなかった。",
              "citation": {
                "source": "悪の花束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこの書は恐らくは、泰壱に仮託して煉金服餌のことを説いた書であろうということが分る。",
              "citation": {
                "source": "古代東洋への郷愁",
                "author": "――『仙書参同契』の解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草を呑むんだと云うが、煙草は仮託で、実は、腹立紛れに敲きつけるんじゃないかと思う。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "景憲が弾正に仮託してこの書を書いたことには何かそういう根拠があるであろう。",
              "citation": {
                "source": "埋もれた日本",
                "author": "――キリシタン渡来文化前後における日本の思想的情況――",
                "note": "青空文庫"
              }
            },
            {
              "text": "曩に児島高徳楠木正成僧日蓮の事蹟を云々し頃日また武蔵坊弁慶を称して後人の仮託に出づとなし公会において之を演じたり。",
              "citation": {
                "source": "史論の流行",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊＊　シェーラーはその知識社会学なるものから、コントに仮託して、歴史性の原理と価値的原理とを追放する。",
              "citation": {
                "source": "イデオロギーの論理学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
