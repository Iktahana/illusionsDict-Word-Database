[
  {
    "uuid": "599022b3-3f07-54d4-a427-6235b9f1b0b1",
    "entry": "仮託",
    "reading": {
      "primary": "かたく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
