        "examples": {
          "standard": [
            {
              "text": "長時間のデスクワークで、最近かすみ目になることが増えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "運転中に急にかすみ目になり、危うく事故を起こすところだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医者にかすみ目の症状を伝えたところ、適切な目薬を処方された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "老婆はかすみ目をしばたたいて我々を見ると、震う荒れた手で懐をまさぐりながら立っていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、ばあさんはかすみ目しているものですから、見わけがつかず、それをヘンゼルの指だとおもって、どうしてヘンゼルにあぶらがのってこないか、ふしぎでなりませんでした。",
              "citation": {
                "source": "ヘンゼルとグレーテル",
                "author": "HANSEL UND GRETEL",
                "note": "青空文庫"
              }
            }
          ]
        }
