[
  {
    "uuid": "fea3e218-fedf-5740-a637-60c64867cd93",
    "entry": "叶う",
    "reading": {
      "primary": "かなう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to come true (of a dream, wish, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長年の夢だった海外旅行が、ついに来月叶うことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "星に願いをかけたら、本当に叶うと信じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "努力の甲斐あって、彼女の悲願だったオリンピック出場が叶った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "宝くじが当たって世界一周旅行が叶うなんて、夢のような話だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "Ｔ「夜更けてこッそりお詣りすると」Ｔ「必ッと願いが叶うんですッて」　「そんな馬鹿な事」　伊吉は信じない。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "対称の法則に叶うって云ったって実は対称の精神を有っているというぐらいのことが望ましいのです。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし僕の願さえ叶うなら紅塵三千丈の都会に車夫となっていてもよろしい。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "心弱くて叶うまじ、と廉平はやや屹としたものいいで、「飛んだ事を！",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大へんさっぱりして諸君の御希望に叶うだろう。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時｜経たば素性履歴を聞き糺し、身に叶うべきほどならば、力となりて得させむず、と性質たる好事心。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしも忰もこれという病気に罹ったこともなく、災難に出逢ったこともなく、無事に年月を送って来た上に、今度は測らずも元の主人の屋敷へ帰参が叶うようになった。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い同士のあいだに何かの縁が結ばれていて、屋敷へ帰参が叶うことになれば、二人は逢うことが出来ない。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、逸子が酒屋へのビール注文の仕方は、鼈四郎のふだんのいい含めの旨に叶うものであった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋は叶う方が可さそうなもんですが、そうすると愛別離苦です。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄　かねてのお望みに叶うた方を、何でお帰しなさいました。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "折入ってお願いは、相叶うことならば、お台所の隅、お玄関の端になりとも、一七日、二七日、お差置きを願いたい。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも願が叶うと云います……咒詛も、恋も、情も、慾も、意地張も同じ事。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "案の定、その場から、思いが叶うた、お二人さん。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度、願が叶うた上では、人の袂にあるのさえ、美津さん、婦は、蛇は、可厭らしな！",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「糸ちゃん、望みが叶うと、よ、もやいの石鹸なんか使わせやしない。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾はどのみち助からないと、初手ッから断念めてるが、お貞、お前の望が叶うて、後で天下｜晴に楽まれるのは、吾はどうしても断念められない。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "野中の遊郭を中心に小さな町を形造っているＴ――町附近もこの条件に叶うのでわたくしは暫らくこの界隈に滞ります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの父はわたしに「何でも日本一になれ」という自分の理想を満足させられそうな希望を幾分見出し、近いうちに自分の踊り方の名跡を継がし、自分の目がねに叶う妻を宛がって、自分の名を担って日本一の幇間になって貰おうと思っていた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の目がねに叶うという妻は少くとも芸人の妻として四方八面へ自在に応酬して、所帯持ちもよく、その上親孝行の嫁に外ならなかった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その贔屓の仕方が結局はいま言うわたしの性格の弱さをハンドルに握って、わたしを自由自在に自分の好みに叶う装飾品に仕立てるに外ならなかった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "容易にはまたとお目もじも叶うまじと存ぜられ候。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつら　おまへは先程、夢のやうな望みと笑うたが、夢のやうな望みが今叶うた。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "生半な喜多流を残すよりはタタキ潰した方が天意に叶うと思っていたらしい精進ぶりであった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪を犯したやつらに、自分を襲ったのは誰か、そして天罰の下った理由を悟らせる時間があって初めて、復讐が叶うのです。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご婦人との面会は叶うかな、ワトソン？",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "成長と進歩、それが人間の本来の姿、本当のところ（道）なので、それが叶うと嬉しく感じるのでしょう。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹脂の香に　朝は悩まし　　うしなひし　さまざまのゆめ、森竝は　風に鳴るかなひろごりて　たひらかの空、　　土手づたひ　きえてゆくかなうつくしき　さまざまの夢。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、そうすることによって結局は奉公の第一義にかなうことが出来るという自分勝手な考えもありはしたが、とにかく興味の向くことなら何でも構わず貪るように意地汚くかじり散らした。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『忘れ得ぬ人は必ずしも忘れてかなうまじき人にあらず、見たまえ僕のこの原稿の劈頭第一に書いてあるのはこの句である。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
