    "definitions": [
      {
        "index": 1,
        "gloss": "to be suspicious of (someone's motives)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "部外者が私たちの会議の内容を勘ぐるのは不自然だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、彼の曖昧な態度を勘ぐり、真相を探ろうとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「君はいつも人のことを勘ぐりすぎだよ。」と友人は笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "探偵は、犯人の動機を勘ぐりながら、現場の証拠を丹念に調べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "何も知らないくせに、勝手なことを勘ぐらないでほしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "まあ精々かんぐるがいい。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かんぐるのは、失敬だぞ。",
              "citation": {
                "source": "夜の道づれ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
