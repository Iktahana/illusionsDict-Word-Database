    "definitions": [
      {
        "index": 1,
        "gloss": "token (gesture, gift, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ほんの形ばかりの品ですが、皆様で召し上がってください」と手土産を差し出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "規則だからと、形ばかりの研修を数時間受けさせられたが、実のある内容は皆無だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "二人はすでに冷めきっており、周囲の目を気にして形ばかりの結婚生活を続けているに過ぎない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "道路の隅に形ばかりの植え込みがあるが、手入れもされず雑草が伸び放題になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "病院から引取って形ばかりでも葬式をすませ、妹と姪とを自宅に引取るまでの苦労を今更のように思い浮べてみる。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴診器を三、四か所胸にあてがってみた後、瞳を見、眼瞼を見、それから形ばかりに人工呼吸を試み注射をした。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの二人のむしろ見すぼらしい形ばかりの洋服を見比べているうちに一種の佗しさを感じた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラス障子の外には、狭い形ばかりの庭ではあるが、ちょっとした植込みに石燈籠や手水鉢などが置いてあった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえさんが丁度来たから、もうそろそろ出かけるとしようか」　形ばかりに戸をひき立てて、内は留守だからと隣りの人にことわって、半七はかの男と共に露路を出ると、表通りはもう夜になっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "――吾々は「扇を倒にした形」だとか「摺鉢を伏せたような形」だとかあまり富士の形ばかりを見過ぎている。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "崩れたる土塀、歪みたる衡門、あるいは掌のくぼほどの瘠畠、形ばかりなる小社などの、常は眼にいぶせく心にあかぬものも、それ近くにこの花の一ト木二タ木咲き出づるあれば、をかしきものとぞ眺めらるゝ。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひなは七月に行った時はまだ黄色い綿で作ったおもちゃのような格好で、羽根などもほんの琴の爪ぐらいの大きさの、言わば形ばかりのものであった。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大軟派といっても、それは形ばかりで、女性には臆病でした。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺骸は有り合わせのうちでいちばんきれいなチョコレートのあき箱を選んでそれに収め、庭の奥の楓の陰に埋めて形ばかりの墓石をのせた。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴吉は箸をつける前に立上つて、仏壇の前に行つて、小つぽけな白木の位牌に形ばかりの御辞儀をすると、しんみりとした淋しい気持になつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がものを言う前にファニーは形ばかり口の隅に笑みを見せながら「Farewell !」と言った。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "形ばかりの竹を縄搦げにした欄干もついた、それも膝までは高くないのが、往き還り何時もぐらぐらと動く。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨風に朽ちて形ばかりに立つてゐる校門が見えた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この庫裡と、わずかに二棟、隔ての戸もない本堂は、置棚の真中に、名号を掛けたばかりで、その外の横縁に、それでも形ばかり階段が残った。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯形ばかり、何時何処でも、貴方が思ふ時、其処に居る、念ずる時直ぐに逢へます、お呼び遊ばせば参られます。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと、形ばかりの修繕を済ましたと、　また後ろでは勢を盛り返した。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "某致仕候てより以来、当国｜船岡山の西麓に形ばかりなる草庵を営み罷在候えども、先主人｜松向寺殿御｜逝去遊ばされて後、肥後国八代の城下を引払いたる興津の一家は、同国｜隈本の城下に在住候えば、この遺書御目に触れ候わば、はなはだ慮外の至に候えども、幸便を以て同家へ御送届｜下されたく、近隣の方々へ頼入り候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は無努力、無神経の、ただ形ばかりのデカダンだ、僕らの考えとは違って、実力がない、中味がない、本体がない。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから最後に、無意味な、無気分な、只美しい、品のいい、音と形ばかりの、笛の舞の世界をあらわして最高の芸術愛好者を酔わせて了うのである。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その破壞して形ばかりになりたる裡に、大なる無花果樹あり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちこちする中、昼も過ぎたので、年寄はまめまめしく形ばかりの膳立をした、お菜がその時目刺に油揚。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗込んでから、またどうか云う工合で、女たちが二人並ぶか、それを此方から見る、と云った風になると、髪の形ばかりでも、菩提樹か、石榴の花に、女の顔した鳥が、腰掛けた如くに見えて、再び夢心に引入れられもしたのでありましょうけれど、なかなか、そんな事を云っていられる混雑方ではなかったのです。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人事僅かに至らぬところあるが為に、幾百千の人が、一通りならぬ苦しみをすることを思うと、かくのごとき実務的の仕事に、ただ形ばかりの仕事をして、平気な人の不親切を嘆息せぬ訳にゆかないのである。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸から東へ二間ほどの外は竹藪で、形ばかりの四つ目垣がめぐらしてある。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の行きとまりに低い珊瑚樹の生垣、中ほどに形ばかりの枝折戸、枝折戸の外は三尺ばかりの流れに一枚板の小橋を渡して広い田圃を見晴らすのである。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井は形ばかりに張ってはあるが、継目の判らぬくらい煤が黒い。",
              "citation": {
                "source": "新万葉物語",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "入り口は黒板べいの一部を切りあけ、形ばかりという門がまえだ。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "きどって黙っていた、むかしのおもかげがただその形ばかりに残ってるのだ。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七は形ばかりの木戸をあけて声をかけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
