      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "a (single) moment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "孫が遊びに来てくれたほんの片時の時間は、おばあちゃんにとって何よりの活力源だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「すみません、片時だけお時間をいただけますか？ 折り入って相談があるんです」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都会の喧騒を離れ、森の中で過ごした片時の休息が、私の疲れた心を癒してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "然し音楽は片時も念頭を離れなかつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って来たとて宅に片時居るでもなし。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――君が君自身であったことは片時もなかったのだということを！",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と幾度も一人で合点み、「ええ、織さん、いや、どうも、あの江戸絵ですがな、近所合壁、親類中の評判で、平吉が許へ行ったら、大黒柱より江戸絵を見い、という騒ぎで、来るほどに、集るほどに、丁と片時も落着いていた験はがあせん。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「必ずしも信仰そのものは僕の願ではない、信仰無くしては片時たりとも安ずる能わざるほどにこの宇宙人生の秘義に悩まされんことが僕の願であります」「なるほどこいつは益々解りにくいぞ」と松木は呟やいて岡本の顔を穴のあくほど凝視ている。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の事は忘れ明日の事を思わず、一日一日をみだらなる楽しみ、片時の慰みに暮らす人のさまにも似たりとは青年がこの町を評する言葉にぞある。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学の哲学科第一年生――なんて、「これは深刻なんだぞオ」といふ言葉を片時も離さないで、カントだのヘーゲルなぞといふのを読んでゐる。",
              "citation": {
                "source": "散歩生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "年をとると気忙しゅうて、片時もこうしてはおられぬわいの、はやくその美しいお姿を拝もうと思うての。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが可厭ならお止しだけれど、極った人が出来た上は、片時も、寝衣で胡坐かいた獣なんぞ、備前焼の置物だって身のまわり六尺四方は愚なこと、一つ内へは置けないから、即座帰れ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝と思へば朝、晝、夜、夜中、明方、もうね、一｜度其が見えましてから、私の覺えて居ますだけは、片時も、然うやつて、私の顏を凝視めたなり、上下に、膝だけ摺らさうともしないんです。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鸚鵡は、尤も、お孃さんが片時も傍を離さないから、席へ出ては居なかつたの。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十　その悪戯といったらない、長屋内は言うに及ばず、横町裏町まで刎ね廻って、片時の間も手足を静としてはいないから、余りその乱暴を憎らしがる女房達は、金魚だ金魚だとそういった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼ながらお可哀そうで、片時もこんな恐い処に貴方をお置き申したくはございませんから。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "言語道断の淫戯者片時も家に置難しと追出されんとしたりし時、下枝が記念に見たまえとて、我に与えし写真あり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "片時もこの居まわり三町の間に居りたくない、生命ばかりはお助けじゃ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗り合いは前後に俯仰し、左右に頽れて、片時も安き心はなく、今にもこの車｜顛覆るか、ただしはその身投げ落とさるるか。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの王子と、ラプンツェルも、お互い子供の時にちらと顔を見合せただけで、離れ難い愛着を感じ、たちまちわかれて共に片時も忘れられず、苦労の末に、再び成人の姿で相逢う事が出来たのですが、この物語は決してこれだけでは終りませぬ。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろの本を読んで聞かせて、片時も、私を手放さなかった。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太孫｜猶齢若く、子澄未だ世に老いず、片時の談、七国の論、何ぞ図らん他日山崩れ海｜湧くの大事を生ぜんとは。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と先生、卓子の上へ両手をずかと支いて、（三年｜前から、御尊名は、片時といえども相忘れません、出過ぎましたが、ほぼ、御訪問に預りました御用向も存じております。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういうものか、嫌で、嫌で、片時も居たたまらなくッてよ。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、人の妻の身で、何たる恐しい了簡だろうと、心の鬼に責められちゃあ、片時も気がやすまらないで、始終胸がどきどきする。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――旅の疲労も有らつしやらうか、何なら、今夜は私が小家へ休んで、明日の晩にも、と言ふたが、其には及ばぬ……若しや、其が真実なら、片時も早く苦艱を救ふて進ぜたい。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ煩っておりますので、片時でもほッという呼吸をつかせてやりたく存じますが、こうでございます、旦那様お見かけ申して拝みまする。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "永劫を一瞬に縮めて光るこの生命、この人間の魂は愛なしには片時も生きられぬ。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど我を煩悩の闇路よりすくひいで玉ひし君、心の中には片時も忘れ侍らず。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそ正直に打ち明けてくれればよかったと思うのですが、当人としては恥かしいような、怖ろしいような、もう片時もわたくしとは一緒にいられないような苦しい心持になって、前後の考えもなしに宿屋をぬけ出してしまったものと察せられます。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ、かたときも忘れたことのない、かわいい坊やの声です。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはかたときも他からはなれることなく、水蓮のそばをすぎたり、ふきあげのしぶきの下をくぐったりした。",
              "citation": {
                "source": "おしどり",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間とてかたときも女のことをわすれたことはありませんでした。",
              "citation": {
                "source": "おしどり",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
