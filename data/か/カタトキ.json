[
  {
    "uuid": "c4de5a76-78ec-50cb-b90d-46880c3e2bf6",
    "entry": "片時",
    "reading": {
      "primary": "かたとき",
      "alternatives": [
        "へんじ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
