    "definitions": [
      {
        "index": 1,
        "gloss": "to break up and start anew",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
