        "examples": {
          "standard": [
            {
              "text": "休日の午後、お気に入りのカフェでゆっくりカフェラテを飲むのが最高の息抜きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ホットのカフェラテ、ショット追加でお願いします」と店員に伝えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このカフェのカフェラテはフォームミルクがきめ細かくて、口当たりが本当にまろやかだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "カフェラテのカップが小さな泡を吐く昼なお暗いコードの実験室で、彼は細い息を吐きながらキーボードをいじくっている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
