        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お電話では詳細を分かりかねますが、機材側のシステム故障かも知れません。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "もしかすると私の勘違いかも知れませんが、以前どこかの学会でお会いしませんでしたか？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "天候の影響で、予定より到着が15分ほど遅れるかも知れません。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "こちらの手違いの可能性もございますので、もう一度社内のデータを確認いたします。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これは、一つには私が今迄に、詩人である人と余りおつきあひして来なかつたといふことに過ぎないのかも知れません。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし相手がやはり詩人である場合は、随分容易に話が通じ、又互ひに利するのかも知れませんが、今の所私は、詩論といふものは殆んど無益だと諦め切つてゐる有様です。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれでもし勝ったら、私は今ほど日本を愛する事が出来なかったかも知れません。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パラソルをさして歩くと、少したすかるかも知れませんが、男がパラソルをさして歩いている姿は、あまり見かけませんね。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、光線の加減で、そんなに濃く写ったのかも知れませんよ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しナフタリン臭くなっているかも知れませんけど、ね、」と私のほうに向き直って言って、「うちのひとには、もう、なんにも要らないのです。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三尺ちかくあつたのかも知れません。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三尺ちかくあったのかも知れません。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやＭの性質では案外そんなことを言はないかも知れませんよ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑つてやらう、などといふのが、そもそもよくない料簡だつたのかも知れません。",
              "citation": {
                "source": "魚服記に就て",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の宛名もまるで變るかも知れません。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひよつとしたら、この新聞を讀んでゐる御家庭もあるかも知れませんから。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここを越えて行くのは、人間では、あなたが最初で、また最後かも知れません。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "龜は、さらにまた言葉をつづけて、「でも、その貝は、あけて見ないはうがいいかも知れません。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりやもう私は、育ちもよくないし學問も無いし、あなたのお話相手が出來ないかも知れませんが、でも、あんまりですわ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一時は四郎も死んだことにして思い諦めましたが、なにしろ自分より六つ七つ若いのですからまだ生きているかも知れません。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてみますと、第三紀の終り頃、それは或は今から五、六十万年｜或は百万年を数えるかも知れません、その頃今の北上の平原にあたる処は、細長い入海か鹹湖で、その水は割合浅く、何万年の永い間には処々水面から顔を出したりまた引っ込んだり、火山灰や粘土が上に積ったりまたそれが削られたりしていたのです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこれらの語については、まだ他に多少問題になる点もあり、また、古典語として「ぬ」「つぬ」「しぬぶ」など読むこともかなり久しい慣例となっていますから、現代の読み方としては必ずしも改めなければならないこともないかも知れませんが、理論上は右のようになると思われるのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから『万葉集』は編纂した者は一人かも知れませんが、それの土台になったものは非常に沢山あって、色々の昔の歌集や歌を書いておいたものなどを集めて来たもので、決して或る人が始めて書きおろしたものではありませぬ。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは、甲と乙との音は実際どんなに違っていたかというに、前に述べた通り一方を或る子音にｉ、ｅ、ｏというような単純な母音がついたものとすれば、他方は今普通には用いられないような母音がついたものかも知れません。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "または一方が母音が一つ附いたものであるに対して、一方は母音が二つ重なって附いたものかも知れません。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしある意味においては人を死なすかも知れません。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "）その外の事も姉さんの思っている通りかも知れません。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それともここで寂しいと思うのは、あんまり家が広過ぎるせいかも知れません。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はわたしがおっ母さんの世話をするのも、因襲の外の関係なので、わたしは生涯をその関係に委ねたというものかも知れませんよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜというのに、折角旧思想を取片付けてしまっても、その跡の、石瓦に覆われた地面の上には、新思想は芽ざして来ないかも知れませんから。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "事によったらまたここで偶然お目にかかれるかも知れませんね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "）わたくしの申す詞は明瞭でないかも知れませんが、それは御勘弁あそばさなくてはいけません。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵の人なら迷ってしまうかも知れませんわ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお金でいまに太郎の美くしいお嫁に着物を買つてやるのです…………太郎はどこからかきつと美くしいお嫁さんを連れて来ませう…………そのお嫁さんは、ひよつとするときつい意地悪るかもしれません。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
