    "definitions": [
      {
        "index": 1,
        "gloss": "to earn (income)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「よし、今年の夏休みはバイトでしっかり稼いで、海外旅行に行くぞ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都心のレストランで深夜まで働いて、大学の生活費を稼いでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は株式投資で元手を十倍にし、悠々自適に暮らせるだけの金を稼いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そんなに必死に稼いで、一体いつ使うつもりなんだい？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼のレジオン・ド・ヌウルはフランス政府が彼の東洋流の栄養法が人口の味覚を満足さした功労によって、エリゼェの大統領官邸で贈与された（彼は巴里で生物学を研究するかたわら党費を稼ぐために豆腐を製造販売していたので。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、年が若くって、男が悪くなくって、正直でよく稼ぐ男を、亭主にもって不足はねえ筈だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの子もおとなしく稼ぐようだから阿母もまあ、安心だ」「いえ、実はそのお蝶のことに就きまして、今晩お邪魔にあがりましたのでございますが、どうもわたくし共にも思案に余りましてね」　四十女のひたいの皺をみて、半七は大抵想像がついた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い者のこった、ちっとは面白いこともなけりゃあ稼ぐ張り合いがねえというもんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそんなに稼ぐのも、やっぱり主人が偉いのだ。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方象は小屋に居て、十｜把の藁をたべながら、西の三日の月を見て、「ああ、稼ぐのは愉快だねえ、さっぱりするねえ」と云っていた。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なか／＼に稼ぐ所ではないから、いきつぎに表へ出て、近所の方に、たゞ今の禮を立話しでして居ると、人どよみを哄とつくつて、ばら／＼往來がなだれを打つ。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿賃を稼ぐためもあるが、第一の目的は、姉を苦界から救う金を作るためであった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お金なんか沢山出さなくたって、女優はめいめいで稼ぐからいいと、会社じゃそう思っているんだもの、お話にならない」「馬鹿だなあ」「役者が、馬鹿なのよ」「じゃあ、なんだって、そんな馬鹿なものになったんだい？",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく当分自前で稼ぐことにして路次に一軒を借り、お袋や妹に手伝ってもらって、披露目をした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子も貧乏ゆえに、あっちで喰われこっちで喰われ、身を削いで親や妹たちのために糧を稼ぐ女の一人なので、青年八百屋が彼女のために、何となしにジャン・バルジャンを読ませようとしたのも、意識したとしないにかかわらず、どこか理窟に合わないこともなさそうであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ、主義のためであるとしても、十九や二十の息子を、親の手から振り放って、他人の雇傭の鞭の下で稼ぐ姿を、よくも、黙って見ていられるものである。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、お初にお目に懸りまする、いかがでごわりまするか、ますます御翻訳で、とさぞ食うに困って切々稼ぐだろう、と謂わないばかりな言を、けろりとして世辞に云って、衣兜から御殿持の煙草入、薄色の鉄の派手な塩瀬に、鉄扇かずらの浮織のある、近頃行わるる洋服持。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴は、旧来た黍がらの痩せた地蔵の姿して、ずらりと立並ぶ径を見返り、「もっと町の方へ引越して、軒へ瓦斯燈でも点けるだよ、兄哥もそれだから稼ぐんだ。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "家にも二人まで下男がゐたし、隣近所の助勢も多いのだから、父は普通なら囲炉裏の横座に坐つてゐて可いのだけれど、「俺は稼ぐのが何よりの楽だ。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち先のごとくにして軒ごとを見舞いあるき、怜悧に米塩の料を稼ぐなりけり。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく何羽も一度にと慾張ったら滅多にあたらないで、一羽ずつと地道に稼ぐつもりだと思わぬ獲ものがある。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たんば、早くから稼ぐな」　するとその男はちょっと首をかしげて見ましたが、まるで紙鳶の片尾がとれて木へ傾きかゝるように二人の方へ肩を先に寄せて来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は花田の言ったことはちゃんと聞き取ったと見え、愛想よく、「あゝ、稼ぐよ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ぼんぼん育ちの柳吉には働きがなく、結局蝶子が稼ぐ順序で、閑にあかせて金づかいの荒い柳吉を養いながら、借金をかえしていこうと思えば、二度の勤めかそれともヤトナかの二つ、勿論あとの方を選んだ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが白人の女をかかえて歩くのですから、とても舞台で稼ぐだけでは足りるはずがありません。",
              "citation": {
                "source": "マレー俳優の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳吉に働きがないから、自然蝶子が稼ぐ順序で、さて二度の勤めに出る気もないとすれば、結局稼ぐ道はヤトナ芸者と相場が決っていた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はそれらのルンペン相手に稼ぐけちくさい売笑婦に過ぎない。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだ、そうして次の日から、象は朝からかせぐのだ。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭がねえならかせぐのよ、情人が不実なら別な情人を目つけるのよ。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを食べて暗くならないうちにもう少しかせぐんだ。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前も野原へ出て何かかせぐほうがいいぜ。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞社の方では教師としてかせぐ事を禁じられた。",
              "citation": {
                "source": "入社の辞",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お嫁に行って、妾になって、まだその上に女優を欲張ろうとは、お前も随分ふてい奴、さ」「そうとも、さ、こんなにふとったからだだもの、かせげるだけかせぐん、さ、ね」「じゃア、もう、僕は手を引こう」と、僕は坐り直した。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車馬のように暗雲にかせぐのはいいことなのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
