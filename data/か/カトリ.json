        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夏のキャンプでは、蚊取りスプレーが必須アイテムだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔ながらの蚊取り線香の香りが、夏の風物詩となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "部屋で作業するときは、蚊取りグッズを準備しておくと集中できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ベランダに蚊取りネットを張って、虫の侵入を防いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこには蚊取り線香を手にした下のお内儀がたっていた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、萩原さんを皆と一緒におくって行って、夫が帰って来ると蚊帳がないので私達は部屋を締め切って蚊取り線香をつけて寝につくと、「オーイ起きろ起きろ！",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、萩原さんを皆と一緒におくって行った夫が帰えって来ると、蚊帳がないので、部屋を締め切って、蚊取り線香をつけて寝につくと、「オーイ起ろ起ろ！",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか、×××印蚊取り線香小売販売人御招待といふ団体のなかにまぎれこんだことがあつた。",
              "citation": {
                "source": "車中も亦愉し",
                "author": "小津安二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても蚊取り線香販売人といふ見立てにはわれながら恐縮して、どうかと思つたことだつた。",
              "citation": {
                "source": "車中も亦愉し",
                "author": "小津安二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからもう先生のタクトなんかとりませんから。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "路次の入口に人力車が三台来て並ぶと、その顔は瞬間面のようにとりつくろい、子供の分別ながら豹一はそれを二十六才の花嫁の顔と察し、何かとりつく島の無い気がした。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かとりわけ罪の重い犯人がいたとは思わない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の頭は、何かとりとめのない夢でも追つてゐるかのやうに、無暗と軽いばかりだつた。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、彼女は下車しないのみか、肩の辺を少し動かして、懐から何かとり出した様子であった。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だかとりとめのないことを書いてしまったが、これも、まさに発表さるべき作品にはや魅せられた証拠だと思って頂きたい。",
              "citation": {
                "source": "国枝史郎氏の人物と作品",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "このユタという言葉は『オモロ双紙』や『女官御双紙』のような古い本の中にも一向見当らない言葉で、『混効験集』には「時とりや、占方をするもの、巫女の類也、ゑかとりや、返しの詞、いづれもありきゑとの神歌御双紙に見ゆ」とあります。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "巫覡を時とりや（時を取る人）または、えかとりや（日を取る人）というところから見るときは日や時の吉凶を占うところから来たようでもあるが、日本語に夢解きという言葉のあるのを見るとまた解くという動詞の名詞形「解き」から出たようでもある。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "お増は疲れた頭脳に、始終何かとりとめのない夢ばかり見ていた。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし婦人の生活に重くのしかかっている封建性はなかなかとりのぞかれないといわれています。",
              "citation": {
                "source": "今度の選挙と婦人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬のためにああいう状態になっているときの譫語は、全く我を知らずに口走るのではなくて、先ず、何かとりとめなく喋りたいという明瞭な欲望が感じられた。",
              "citation": {
                "source": "寒の梅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日それが自然発生的にさえ多く書かれる何かとりつきやすさがあるらしいのは、どういうわけだろう。",
              "citation": {
                "source": "今日の文学の諸相",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だかとりとめもないやうなことを随分書きましたがまだ／＼書きたいことはあとから／＼湧き出て来るやうです。",
              "citation": {
                "source": "私信",
                "author": "――野上彌生様へ",
                "note": "青空文庫"
              }
            },
            {
              "text": "甥はだぶだぶの軍服を着て、シヤベルで何かとりかたづけてゐた。",
              "citation": {
                "source": "星のわななき",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、僕の上には何かとり残されたものの空虚が滑り墜ちてゐた。",
              "citation": {
                "source": "魔のひととき",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "するととり残されるかとり残されぬかを決するものは未だ生まれざる大詩人が短歌の形式を用ふるかどうかである。",
              "citation": {
                "source": "又一説？",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だかとりとめもない事ばかり書きましたが、どうか悪しからず御赦し下さい。",
              "citation": {
                "source": "大正十二年九月一日の大震に際して",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私のしっこを飲んでいる――」　大人たちは、はじめは何をいっているのかとりあわなかったが、彼女があんまり伊勢子は正直だ、伊勢子は正直だ、私のしっこを飲んでいる――と小躍りするので、やっと彼女の悪戯が、味噌をだいなしにしてしまったのだと感じた。",
              "citation": {
                "source": "西川小りん",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも飽きると袋から何かとり出してはむしやむしや食べる。",
              "citation": {
                "source": "ボルネオ　ダイヤ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エヘン」　私はわざと横を向いて咳払いをすると、「諸口さん、いい天気ですね……あの雲なんかまるでクリーニングされた脱脂綿みたいに白いですね」「まあ、いやだ脱脂綿みたいだなんて、そんなこと、いうもんじゃないわよ」　彼女は、あの歪めた顔を、いつの間にかとりすまして、ツン、と蔑むようにいった。",
              "citation": {
                "source": "※の囁き",
                "author": "――肺病の唄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてポケットから何かとりだして、それを右手で、宙になげあげてうけとめてゐます。",
              "citation": {
                "source": "シロ・クロ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌ってしまうと、ポケットから何かとりだして、ぱっと放りました。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほ」の用語例が忘れられてから、いつの間にかとり換へられたに違ひない。",
              "citation": {
                "source": "「ほ」・「うら」から「ほがひ」へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "○『婦人画報』どうしたのかとりに来ないが　とにかく「モスク※日記から――」十四枚ばかり書いた。",
              "citation": {
                "source": "日記",
                "author": "一九三一年（昭和六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたとしちゃ、木津さんをとるかとりかえされるかという、たいへんなところなんでしょうけど、泣き声をだすのはおよしなさいよ。",
              "citation": {
                "source": "猪鹿蝶",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
