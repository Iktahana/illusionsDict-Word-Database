        "examples": {
          "standard": [
            {
              "text": "遠くの地平線に、巨大なきのこ雲が立ち上り、核爆発が起きたことを示していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "シミュレーションによると、一度核爆発が起これば、その周辺地域は長期間放射能に汚染される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "冷戦時代、大国は砂漠や海洋で何度も核爆発実験を繰り返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "ソフトウエアの空白を誰が埋めるのか　カリフォルニア大学のバークレー校でコンピューターを学び、国防省の研究所で核爆発の影響に関するシミュレーションプログラムの開発に携わったトム・ピットマンは、誕生したばかりのマイクロコンピューターにもっとも素早く反応した一人だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら反物質は通常の物質と接触したときに核爆発を起こすからだ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画館から出てくるのは、核爆発のあとで防空壕から出てくるような感じだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
