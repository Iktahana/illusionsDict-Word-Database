        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "釣りの初心者でも、岩場の多い場所では笠子が釣れやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日の漁港には、新鮮な笠子がたくさん水揚げされていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "笠子の煮付けは、身が締まっていて、おかずにも酒の肴にもぴったりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "やがて半月あまりを経たりしに突然福地家の執事｜榎本破笠子より予て先生への御用談一応小生より承り置べしとの事につき御来車ありたしとの書面に接し即刻番地を目当に同じく木挽町の河岸通なる破笠子が寓居に赴きぬ。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて破笠子はおのれが歌舞伎座作者部屋に入り芝居道実地の修業したき心底｜篤と聞取りし後｜倶に出でて福地家に至り勝手口より上りてやや暫くわれをば一間に控へさせけるがやがてこなたへとて先生の書斎と覚しき座敷へ導きぬ。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "破笠子は恭しく手をつき敷居際よりやや進みたる処に座を占めければ伴はれしわれはまた一段下りて僅に膝を敷居の上に置き得しのみ。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて三十分ばかりにて我は再び破笠子に伴はれ福地家を辞して帰りしがそれより三、四日にして歌舞伎座盆興行の稽古となるやわれはここに榎本氏｜請人にて歌舞伎座へ証文を入れいよいよ梨園の人とぞなりける。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "稽古にかかる前破笠子より葉書にて作者部屋のものを呼集め手分なして書抜をかく。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　深切を叱言のごとくぶつぶつ言って、納戸の隅の方をかさかさごそりごそりと遣る。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かさご、あかぎ、ごんずい、くしろ、おこぜ、海鰻、その他なほ數種、幾ら聞いても直ぐ忘れてしまふ樣な奇怪な名を持つた魚たちが四邊の海で釣れました。",
              "citation": {
                "source": "樹木とその葉",
                "author": "海邊八月",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ二三十尋もある深みの底から一尺大のかさごなどがその大きな口をあいて、一條の絲につれて重々とあがつて來る時の指から腕、腕から頭にかけての感覺の面白さはまつたく別でした。",
              "citation": {
                "source": "樹木とその葉",
                "author": "海邊八月",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚祝いの帰途でもあるらしく、少しばかり酔っている青年たちは歩道一杯の横列に制服の腕をくみ合わせ、罪のない高声を、　　たかさごや　　たかさごやア　　この浦ふうねに帆をあげて　　高砂や　　たかさごやアと祝婚行進曲の節をもじった合唱で、のしているのであった。",
              "citation": {
                "source": "杉垣",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その良い例はかさごであろう。",
              "citation": {
                "source": "雑魚図譜",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その島の周りが吾々の漁場であって、章魚とかさごと栄螺とが主な獲物であった。",
              "citation": {
                "source": "真夏の日本海",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々町の子供たちも一週間もすると、もうすっかり海に馴れてしまって、半日位夢中になって章魚やかさごを追っていた。",
              "citation": {
                "source": "真夏の日本海",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴を覗いて行くうちにかさごに出会うことがよくあった。",
              "citation": {
                "source": "真夏の日本海",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々が狙うのは章魚とか、かさご類のいわゆる底魚であるが、黒鯛の子だのべらだののように、途中を泳いでいる連中も上手な人には突けるのだそうである。",
              "citation": {
                "source": "真夏の日本海",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その島の周りが吾々の漁場であつて、章魚とかさごと栄螺とが主な穫物であつた。",
              "citation": {
                "source": "真夏の日本海",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々町の子供たちも一週間もすると、もうすつかり海に馴れて了つて、半日位夢中になつて章魚やかさごを追つてゐた。",
              "citation": {
                "source": "真夏の日本海",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴を覗いて行くうちにかさごに出会ふことがよくあつた。",
              "citation": {
                "source": "真夏の日本海",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々が狙ふのは章魚とか、かさご類の所謂底魚であるが、黒鯛の子だのべらだののやうに、途中を泳いでゐる連中も上手な人には突けるのださうである。",
              "citation": {
                "source": "真夏の日本海",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚はかさごといしだいとを描いて見たが、この方は崋山先生の絵があるので、どうも見劣りがしていけない。",
              "citation": {
                "source": "南画を描く話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たかさごやあ……この」（変な謡曲）。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この……この……たかさごやあ……」（変な謡曲）。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれが御祝儀をやろう」と万吉が酔いの出た赤い顔で云った、「いけねえかな松田さん、たかさごやだよ」　松田権蔵が眼を剥いた、「なんだと、おめえそんな芸当ができるのか」「芸当たあ痛えな」「やっておくれ」と与平が云った、「それで今夜のおめでたが締るよ」　万吉はうたい始めた。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
