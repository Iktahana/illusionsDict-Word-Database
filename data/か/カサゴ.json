        "examples": {
          "standard": [
            {
              "text": "水族館の岩礁水槽には、保護色で岩に溶け込む笠子が泳いでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "瀬戸内海では、笠子が夏の食卓を彩る人気の魚だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "漁師は、網にかかった笠子の鋭いトゲに気をつけながら、慎重に外した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
