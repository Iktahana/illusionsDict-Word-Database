[
  {
    "uuid": "96e30150-a275-5983-8170-51a6cb36a027",
    "entry": "観世音菩薩",
    "reading": {
      "primary": "かんぜおんぼさつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Avalokiteshvara (Bodhisattva)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "浅草寺のご本尊は、多くの人々の信仰を集める観世音菩薩である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "観世音菩薩は、人々の苦しみの声を聞きつけ、救いの手を差し伸べると言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "三十三間堂には、千体もの観世音菩薩像が並んでおり、その光景は圧巻だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女は、観世音菩薩のように慈悲深く、誰にでも優しい人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "「南無大慈大悲観世音菩薩。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが完全に出来れば私たち自身が観世音菩薩であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿弥陀如来といい、観世音菩薩というものも、実はこの働き（宇宙の大生命が「道」を私たちに覚らしめようとする働き）を指して名づけたものに過ぎません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又観世音菩薩、毘沙門天王にも夢に会ったとある。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにいますはすなわち、わが師父、南海の観世音菩薩摩訶薩じゃ。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一見尋常一様の観世音菩薩の立像の如くなるも、長崎にて物慣れし吾眼には紛れもあらず。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、走りながら観世音菩薩を繰りかえし繰りかえし唱えた。",
              "citation": {
                "source": "断橋奇聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世相を代表し、客観を代表した観世音菩薩をわざわざ他から持つて来た形などにも深い意味がある。",
              "citation": {
                "source": "谷合の碧い空",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "世尊の持つた客観性の普賢菩薩と他から来た観世音菩薩との対比の上にも、考へて見なければならないことが非常に多い。",
              "citation": {
                "source": "谷合の碧い空",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "山国川の清流に沐浴して、観世音菩薩を祈りながら、渾身の力を籠めて第一の槌を下した。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこの観世音菩薩が、「深般若波羅蜜多を行ずる時」というのは、どんな意味であるかというに、すでに申し上げておいたごとく、それは、観音さまが甚深微妙なる般若の宗教を実践せられたということで、観世音は、単に心の眼を見開いて、般若の哲学を認識せられたのみでなく、進んで般若の宗教をば親しく実践されたのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "康頼　法華経の中にも入於大海仮使黒風吹其船舫飄堕羅刹鬼国其中一人称観世音菩薩名者是諸人等皆得解脱羅刹之難とかいてあります。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "藷焼酎をひつかけたので、だいぶあぶなかつたが、やつと行き留めた、夜はぐつすり寝た、おかげで数日来の睡眠不足を取りかへした、南無観世音菩薩。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月廿二日　晴、あたゝかい、行程一里、佐志、浜屋（二五・上）誰もが予想した雨が青空となつた、とにかくお天気ならば世間師は助かる、同宿のお誓願寺さんと別れて南無観世音菩薩。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうでもといはれて、病人のために読経した、慈眼視衆生、福聚海無量、南無観世音菩薩、彼に幸あれ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "独り老男老女に取っては伝法院と一寸八分の観世音菩薩と淡島様とに彼の趣味を伴う。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそれ三社様に至っては、浜成、武成の兄弟と仲知とが遠く推古帝の御宇、一日宮戸川に網して一寸八分の黄金仏（観世音菩薩）を得たという詩のような伝説、吾儕は敢えて彼これその詮索をなすを欲せず、かばかりにロマンティックな語りぐさをいつまでも保全して、徒なる解釈をこれに試みたくないと思う。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "石山寺の観世音菩薩も、女房の弁も並べて拝みたいほどに大将は感激していたが、玉鬘からは最初の夜の彼を導き入れた女として憎まれていて、弁は新夫人の居間へ出て行くことを得しないで、部屋に引き込んでいた。",
              "citation": {
                "source": "源氏物語",
                "author": "真木柱",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして太子の前の地びたにぺったりひざをついたままうやうやしく、「敬礼救世観世音菩薩。",
              "citation": {
                "source": "夢殿",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日羅の言った言葉は、人間の世の苦しみを救って下さる観世音菩薩に、そしてこの度東の果ての日本の国の王さまに生まれて、仏の教えをひろめて下さるお方に、つつしんでごあいさつを申し上げますという意味でございます。",
              "citation": {
                "source": "夢殿",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "井師の恩に思ひ到る時に私は、きつと、妙法蓮華経観世音菩薩普門品第二十五を朗読して居るでありませう。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上はただ清水寺の観世音菩薩の御冥護にお縋り申すばかりでございます。",
              "citation": {
                "source": "おしの",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文句は何でも観世音菩薩の「庭に年経し槐の梢」に現れるとか何とか云ふのだつた。",
              "citation": {
                "source": "槐",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると婆さんの真名娘が私かにこの稚児に想ひを寄せ、稚児の身代りになつて死んでしまふ、それから稚児は観世音菩薩と現れ、婆さんに因果応報を教へる、この婆さんの身を投げて死んだ池は未だに浅草寺の境内に「姥の池」となつて残つてゐる、――大体かう云ふ浄瑠璃である。",
              "citation": {
                "source": "槐",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからその又国芳の浮世絵は観世音菩薩の衣紋などに西洋画風の描法を応用してゐたのも覚えてゐる。",
              "citation": {
                "source": "槐",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はその後槐の若木を見、そのどこか図案的な枝葉を如何にも観世音菩薩の出現などにふさはしいと思つたものである。",
              "citation": {
                "source": "槐",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "（寂しき微笑）わたしのように腑甲斐ないものは、大慈大悲の観世音菩薩も、お見放しなすったものかも知れません。",
              "citation": {
                "source": "藪の中",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水の御寺の内陣にはひれば、観世音菩薩の御姿さへ、その儘侍従に変つてしまふ。",
              "citation": {
                "source": "好色",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、大慈大悲の観世音菩薩、どうか其処を御示し下さい、侍従は河原の女乞食と、実は少しも変らない証拠を。",
              "citation": {
                "source": "好色",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
