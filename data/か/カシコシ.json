        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "銀行の当座勘定でうっかり貸越が発生してしまい、慌てて別の口座から資金を振り替えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "契約しているカードローンには極度額50万円の貸越枠が設定されているため、急な出費の際も当面は安心だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "決算期末の時点で当座貸越となっていたため、貸借対照表では短期借入金として計上しておくよう経理に指示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「与助にはなんぼ程貸越しになっとるか？",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へえ、……としますと……貸越しになっとる分はどう致しましょうか？",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その代り貸越しになっとる二十円は棒引きにして貰うように骨折ってやったぜ。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "売先からの勘定は取れず、貸越し貸越しになり、それに引きかえ荷方からは頻りに勘定の前借りを申込まれる。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貸越しをもう少し催促して取立て、前借りをもう少し引緊めて拒絶する。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その度毎に給金の前渡しや貸越が必ず附帯する。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここは縁起がわるいから、私たちはまたどこかで新規｜蒔直しです」　ここへ引移って来てから、貸越の大分たまって来ている羅紗の仲買などに、お島は投出したような棄鉢な調子で言っていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここは縁起がわるいから、私たちはまたどこかで新規蒔直しです」　ここへ引移って来てから、貸越の大分たまって来ている羅紗の仲買などに、お島は投出したような棄鉢な調子で言っていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはもう充分にお察し申しておりますが、先ほどから申しますとおり、何分にも殿様のほうには、だいぶお貸越しに願っておりますんで、へい一度清算いたしまして、なんとかそこへ形をつけていただきませんことには……手前どもといたしましても、まことにはや――」　源十郎のこめかみに、見る見る太いみみずが這ってくる。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しどけなき、なれが頸は虹にしてちからなき、嬰児ごとき腕して絃うたあはせはやきふし、なれの踊れば、海原はなみだぐましき金にして夕陽をたたへ沖つ瀬は、いよとほく、かしこしづかにうるほへる空になん、汝の息絶ゆるとわれはながめぬ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "はしけやししのぶもじずりかかるとき　　　　　　　　るすのかみがみいともかしこし　ほう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕は得たりかしこしとすきを窺って例の金の板を部屋の中に投げこんでしまいました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの教科書、神代の事は申すもかしこし、神武天皇以来現代まで、阿倍比羅夫ただ一個所に於いて「津軽」の名前を見つける事が出来るだけだといふのは、まことに心細い。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に人界不定のならひ、是非も無き御事とは申せ、想ひ奉るもいとかしこし。",
              "citation": {
                "source": "二日物語",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌この殿はうべもかしこし白妙の不二の高嶺をまともにぞ見る春鵙冬ごもり冬ごもりうらさびぬらし。",
              "citation": {
                "source": "篁",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘇峰先生の「観察論」は、近来の大文と申すもかしこし、元よりわれら如きが讃美し奉るも恐れ多き事なり。",
              "citation": {
                "source": "人生の意義",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "御神は伊奘諾伊奘冊二柱の神にましませば申すもかしこし、御狗とは狼をさしていう。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "小倉遊亀氏が『浴女』を描いて発表したことに就いて、何か世間では得たりかしこしとそれを名作として賞讃したやうな傾きもある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがとりも直さず「商売は道によってかしこし」である。",
              "citation": {
                "source": "商売は道によってかしこし",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかの大火に寺院はおろかあたりの家居まで扨も焼けたりや焼けたり、千歳の松も限りあればや昔の縁｜乍ち消えうせて木も枝もやけこがれさも物うげに立てるあはひに本堂のみ屹然として聊かも傷はざるは浪花堀江の御難をも逃れ給ひし御仏の力、末世の今に至るまで変らぬためしぞかしこしや。",
              "citation": {
                "source": "かけはしの記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "讃岐路のあやの松山白峰に君ましませばあやにかしこし　この歌の下に流れてゐる感じは、前にあげた圓位と順徳院の真野の山陵の場合と全く同一で五百年を隔てて古への薄幸な帝王を忍ぶ悲壮ではあるが冷静な心持である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやは阿野又は繞で郡の名、そのあやにあやにかしこしのあやを引かけ、ここに寛先生の短歌革新運動以来追放されて久しいかけ言葉が復活した次第である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし彼が室外に出て鍵をかけていったとしても、さっき煙のようにこの部屋に闖入した蠅男の一味は、えたりかしこしと帆村の留守中に再びこの部屋に押し入り、糸子に危害を加えるかもしれないのだ。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いに、そこに見はりをしていた海底超人の姿は見えなかったので、えたりかしこしと、すぐさま無電室にとびこんだ。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の「勅なれば最ともかしこし鶯の宿はと問はばいかに答へむ」という故事のあったために鶯宿梅の名も生じ、この優しい鶯宿梅の名の出来たために「私しや鶯、主は梅、やがて身まゝ気まゝになるならば、さあさ鶯宿梅ぢやないかいな、さつさ何んでもよいわいな」という意気な端歌の文句も生れたのであります。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある声　　教へかしこし。",
              "citation": {
                "source": "富士はおまけ（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏目金之助　　　　　高浜清様　　　　　　○明治三十九年八月十一日（葉書）　拝啓　昨日の駄句「花嫁の馬で越ゆるや山桜」を、「花の頃を越えてかしこし馬に嫁」と致し候が御賛成下さい。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "心のうちに花嫁の姿を浮べて、当時の様を想像して見てしたり顔に、花の頃を越えてかしこし馬に嫁と書きつける。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしかぐや姫は帝の使いに対しても、「帝の召しての給はむことかしこしとも思はず」と放言し、面会を謝絶する。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に恥ぢ神には恥ぢず初詣神は唯｜臠すのみ初詣推し量る神慮かしこし初詣十二月七日　偶成。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
