    "definitions": [
      {
        "index": 1,
        "gloss": "riverside",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "休日の朝は、川辺を散歩して新鮮な空気を吸い込むのが日課だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バーベキューをするなら、開放感のある川辺の広場が気持ちいい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは川辺で石投げをしたり、水たまりで遊んだりして楽しんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夕焼け空の下、川辺には散歩する人々のシルエットが長く伸びていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "頃は、駿河国という名称はなくて、富士川辺まで佐賀牟国と呼ばれていた時代のことである。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び先の川辺へ出た。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘が淵附近の地一帯をいふにや、近き人の著しゝ『隅田川叢誌』には隅田川辺なる村里の総称なりといへり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀井戸の金糸堀のあたりから木下川辺へかけて、水田と立木と茅屋とが趣をなしているぐあいは武蔵野の一領分である。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は窟に暫く棲んでいたので、岩穴から此の川辺へ抜け出る間通を心得ていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の深川辺には貧乏長屋が多かったので、そこらの長屋のおかみさん達は、値のやすいのに惚れて重兵衛の魚を買った。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「若いときには品川辺に住んでいたそうですが、十五六年も前からここへ引っ込んで来て、小さい荒物屋をやっています。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち「昔々しきりに思う慈母の愛」「春あり成長して浪葉にあり」の情愁で、時間の遠い彼岸にある、或る記憶に対するのすたるじや、思慕の川辺への追憶である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女はをとめの身で大胆にもかの女の家の夕暮時の深窓を逃れ来て、此処の川辺の夕暮にまぎれ、河原の玲澄な野薔薇の床に横たはる。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何峠から以西、何川辺までの、何町、何村、字何の何という処々の家の、種々の雑談に一つ新しい興味ある問題が加わった。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわて床屋春は早うから川辺の葦に、蟹が店出し、床屋でござる。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、最も近い徒渉場たる十二ヶ瀬を渡ろうと急ぐや、越の殿軍甘粕近江守は川辺の葦間から一斉に鉄砲の雨をあびせたので、甲州兵悩まされながら、川の上下、思い思いに雨の宮の渡猫ヶ瀬等から川を渡り北進した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとなりの生垣のある家へはいったのを確かに見とどけたから、それとなく近所で訊いてみると、その女はおとわといって深川辺の旦那を持っているんだそうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は道行を極めて、なんでも神奈川辺に隠れているとかいう噂もありましたが、その後どうしましたかしら。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでどうしたかというと、川辺の誰も知らないところへ行きまして、菜種を蒔いた。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中川辺でございますがこのごろ新築いたしまして、水などを庭へ引き込んでございまして、そこならばお涼しかろうと思います」「それは非常によい。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "中川辺を通って行くと、小さいながら庭木の繁りようなどのおもしろく見える家で、よい音のする琴を和琴に合わせて派手に弾く音がした。",
              "citation": {
                "source": "源氏物語",
                "author": "花散里",
                "note": "青空文庫"
              }
            },
            {
              "text": "『川辺』や『野路』など肉の薄いものではあるが、一種の凄惨なリアリティをもつてゐる『野路』の子供達の表情に痴鈍な美がある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "予の現住地田辺町と同郡中ながら、予など二日歩いてわずかに達し得る和深村大字里川辺の里伝に、河童しばしば馬を岩崖等の上に追い往き、ちょうど右の談のような難儀に逢わせるという。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十年経て故郷に還る途上その近処の川辺に息む。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "野芹、梅の花、春の雨、鶯、杜若、蛍の飛び交ふのを見ても、蛙の喧しく啼くのを見ても、人が海辺川辺に避暑に出かけて行く噂を耳にしても、時の間に過去になつたその恋がいろ／＼に思ひ出されて容易にそこから離れて来ることは出来なかつた。",
              "citation": {
                "source": "百合子",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "貫いた線を余り真直にしすぎたやうな処があるが、出て来る人物もそれぞれ活躍して、あの酒を飲む川辺さんなどが殊によく出てゐた。",
              "citation": {
                "source": "自他の融合",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "この川辺家へ来てから、幾度かくれんぼに引き出されたかわからない。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "村川は、この四月に京都大学の法科を出て上京して以来、下宿を見つけるまでのしばらくをこの川辺家に寄寓しているのだが、彼は、この家の主人から、ずっと前から世話になっている。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の、川辺宗太郎が、二十年近く前桂内閣の閣僚の椅子を占めていた全盛時代に、小石川原町の高台を五千坪近く買って、建築した邸宅だけに、日本館と洋館とを合せて間数三十いくつを数えて、かくれんぼをするのには、絶好の広さである。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が、一高時代に川辺家へ出入りしていたときには、倭文子はまだいなかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵寝の習慣を持っている川辺家の人々は、皆寝しずまって、月のみが、樹木の多い庭園を昼のように照していた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "川辺という家なんだ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "川辺家の主人は、朝早く起きて西洋草花の手入れをするのが、この三四年以来｜日々の仕事である。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるまる　いちにち　あそぶのは　すんだ　かわべの　ワスレナグサ。",
              "citation": {
                "source": "ねっこうまれのこびとたち",
                "author": "ETWAS VON DEN WURZELKINDERN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
