        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "カードキーをドアのセンサーに翳すと、ロックが解除された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "母親は熱を出した子供の額にそっと手を翳して熱を確かめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼はQRコードを決済端末に翳して、支払いを済ませた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "水晶玉に手を翳すと、未来のビジョンが見えるという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      },
