        "examples": {
          "standard": [
            {
              "text": "この畑では、有機栽培のため化学肥料は一切使われていない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "即効性のある化学肥料は、植物の成長を促進するのに役立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "化学肥料の過剰な使用は、土壌や地下水に悪影響を及ぼす可能性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "うなわれた畑には化学肥料が施された。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ適時に適当な肥料を必要量だけ与えてやることにより、しかも化学肥料ですぐ吸収し得る状態にしてやれば、その効果は明らかに出て来ることと思われる。",
              "citation": {
                "source": "稲の一日",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが実際は農村でも化学肥料は必要だし、満州でも石炭の産出が重大与件である。",
              "citation": {
                "source": "技術の哲学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ硫安を入れるかというに、近くの田畑に化学肥料として硫安を使う。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
