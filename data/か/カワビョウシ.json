        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "父の書斎には、何十年も読み継がれた革表紙の分厚い本が並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "特別な日の写真アルバムは、高級感のある革表紙を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "図書館の奥で、歴史を感じさせる革表紙の辞書を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この聖書は、手に馴染む革表紙で、開くたびに心が落ち着く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」と牧師は女のやうな繊細な手をして革表紙の聖書をとんと叩いた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、何時になつたら済むといふのだ、念のため教へて欲しいと友達がいふと、フイシユは革表紙の擦り切れた新約全書を机の上から引張り出して、「有難いのは、この本だよ、ちやんと今度の戦争の終末期まで出てゐるから、大したもんさ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとの外套室に帰つてめい／＼外套を着込まうとする際、リイドの友達はポケツトに手を突込むでゐたが、一寸不思議さうな顔をして、革表紙の大形の手帳をその中から引張り出した。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "主が特別の恩恵を垂れ給うたのですよ」　長い髯の男は手にしていた古い革表紙の手擦れた聖書を振って言った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところどころに書入のしてある古く手擦れた革表紙の本だ。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホノルル・ブロオドウェイの十仙店で、ぼくは、紅のセエム革表紙のノオトを買いました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は左の腋に革表紙の金字の書物。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は思い出して、机のひきだしの奥から、例の青い革表紙の手帖をとりだして、にやりにやりと笑いながら、いくども読みかえした。",
              "citation": {
                "source": "脳の中の麗人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "）一行が歐洲行をしたとき、オランダから贈られた疊半分もあるやうな「鳥類圖譜」の大きい革表紙石版刷りの本があつたりした。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "奧附もないが、丸がかりの洋裝で、がつしりした革表紙の背には箔捺しで「英和對譯辭林」とある。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私が耶蘇になったといって、私を憎んで殺そうとしましたから、私、海を泳いで日本の船へ逃げ込んで、ようやく助かりました、その時、海の水で本がこの通りいたんでしまいました」　手ずれきった革表紙を繙いて、頁のしみだらけになったところを駒井に見せて金椎が説明する。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく革表紙、仏蘭西仮｜綴じの立派なノートである。",
              "citation": {
                "source": "仁王門",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国製の万年筆とシャープペンシル、腕時計、革表紙の手帳、革製の横に長いがまぐち、上等な麻のハンカチーフ、洋銀にしゃれた模様を彫ったコンパクト、櫛などの脇に、自分の貯金通帳と認印があるのをみつけたのだ。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い革表紙のバイブル・サイズだ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来は革表紙の手帳のためのリフィルなのですけど、それを表紙なしで使ってました。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "革表紙の裏ポケットに差し込んで使うリフィル。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "きれいなグリーンの革表紙の手帳だった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くの町で革表紙の立派な「判取帳」を見ました。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "記録というのは、真赤な革表紙で綴じ合せた、二冊の部厚な手紙の束であった。",
              "citation": {
                "source": "悪霊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
