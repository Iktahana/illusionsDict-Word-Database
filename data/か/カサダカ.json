        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は昇進してから、部下に対してかさ高な態度をとるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女のかさ高な物言いが、チームの和を乱している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "権力を背景にした、かさ高な要求には応じられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
