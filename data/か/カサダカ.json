        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このダウンジャケットは軽いが、たたむとかさ高になるのが難点だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "羊毛の布団は、羽毛布団に比べてかさ高で重い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "配送用の段ボールが思ったよりかさ高で、車に積むのに苦労した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "」といってかさ高の郵便を青蛙堂主人のところへ持って来た。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴共別てかさ高にて候間供先にても口論等致又者惡言等申者之有候はば急度お仕置申付にて可有之候。",
              "citation": {
                "source": "凡愚姐御考",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、今日、彼女の現実の能力はそのかさ高な荒っぽさに充足しきれないのだから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かがり」（越中特有の、繩を荒目の網にかがって作った一種のかます）に詰めこんだ雑品を、かさ高に背負った山人たち、その一と足、一と足、重々しく踏みしめて行く頼もしい足跡を、奔逸しようとする気力を抑え抑えして、ついて行く。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな鞄やら、行李やら、かがりやら、いろいろな荷物をかさ高に背負って、初めての手合いも多いと見え、――まだヤマは遠いかネ、などと、恐る恐る助七たちに聞いているのもあった。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「邪魔になどしないつもりなのに、ずい分かさ高に感じるのね。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがかさ高くふくらんでいるのです。",
              "citation": {
                "source": "湖畔亭事件",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡単なものから先にして、二通の封書と、一葉のはがきとを見て了うと、あとにはかさ高い原稿らしい一通が残った。",
              "citation": {
                "source": "人間椅子",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "松かさだか鳥だかわからない黒いものがたくさんその梢にとまってゐるやうでした。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "松かさだか鳥だかわからない黒いものがたくさんその梢にとまっているようでした。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "記憶といつても、何の記憶かさだかでないながら、そのなつかしさだけがついと胸をうつやうな感じである。",
              "citation": {
                "source": "池のほとりに柿の木あり",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手垢のついた指ずれの少しよごれた原稿は、かさだかにいえば、滝田氏には乱鶴乱雲の間をさまよう体に見え、一代の文学者というものの原稿の貴とさをみきわめた人であったろう、彼はこれを経師に裏打ちをさせ、一冊の書巻として保存していた。",
              "citation": {
                "source": "芥川の原稿",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう気分で宿々に泊る母の旅心は窮屈であったろうし、同行する父にとってもかさだかであったろう。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
