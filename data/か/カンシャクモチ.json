[
  {
    "uuid": "307f9867-78ba-58e3-9759-52cca2debe59",
    "entry": "癇癪持ち",
    "reading": {
      "primary": "かんしゃくもち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
