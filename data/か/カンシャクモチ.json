    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hot-tempered person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "父は昔から癇癪持ちで、すぐに怒鳴り散らしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は癇癪持ちだが、根はとても優しい人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チームに癇癪持ちがいると、雰囲気が悪くなることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの店長は有名な癇癪持ちだから、クレームはつけない方がいい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "中尉は下顎骨の張った、獰猛な、癇癪持ちらしい顔をしていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部さんは吃りで、癇癪持ちで、気むずかしやね。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯父は変わり者で、短気な癇癪持ち、怒ったら口汚いのですが、平生は引っ込み思案でして。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐しい酒呑みで頑固屋で、癇癪持ちで、そして極めての好人物であつた。",
              "citation": {
                "source": "古い村",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父さんは、ひよつとすると、あんな風な癇癪持ちだから河の中へでも棄てゝしまつて知らん顔をしてゐるのかも知れなくつてよ。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "癇癪持ちの教師は平手で横っ面をぴしゃりと食らわすのもあった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "癇癪持ちだったが、その怒る動機にいつも面白いところがあった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はその頃ひどく我儘で癇癪持ちの子供だつたが、姉の前でだけはいつも素直な気持になれるのであつた。",
              "citation": {
                "source": "魔のひととき",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞奴は癇癪持ちだという。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝気で癇癪持ちに皮肉もののあるはずがない。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸妓だろうが何だろうが……」「……馬鹿ッ……反抗するカッ……」　と云ううちに前に居た癇癪持ちらしい警官が、来島の横ッ面を一つ、平手でピシャリとハタキ付けた。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "病弱の身体で、あの気紛れな――今は大へんよくなったが――癇癪持ちの夫に仕えて、些の不満も現わさず、唯々諾々として忠実を守っている姿は涙ぐましいものがある。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "その庭園にはシェイクスピアが植えた桑の木があったが、十八世紀の中頃、当時その屋敷はガストレルという牧師のものになっていて、シェイクスピアの名声が世間に漸く高まった頃で、遠近から見物人が押しかけて来てうるさいというので、癇癪持ちの牧師はその木を伐り倒してしまった。",
              "citation": {
                "source": "シェイクスピアの郷里",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば剛情者、わがまま者、癇癪持ちの通武はいつも怏々として不平を酒杯に漏らしつ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "卿も知っとる通り、あの武男さんの母さん――御隠居は、評判の癇癪持ちの、わがまま者の、頑固の――おっと卿が母さんを悪口しちゃ済まんがの――とにかくここにすわっておいでのこの母さんのように――やさしくない人だて。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の者で、私より三つも年上で、癇癪持ちでしてね、始終私をいじめてばかりいました。",
              "citation": {
                "source": "林檎",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "つむじ曲りの、癇癪持ちの、ひねくれ者のように見ている人もあります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、宅が癇癪持ちですからね。",
              "citation": {
                "source": "写真（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャレンジャー教授は、癇癪持ちで、人間嫌いで、時々狂暴性を発揮する人物である。",
              "citation": {
                "source": "イグアノドンの唄",
                "author": "――大人のための童話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより、癇癪持ちがそろっているんだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の私はまだ癇癪持ちでしたから、そう不真面目に若い女から取り扱われると腹が立ちました。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までは車屋のかみさんでも捕えて、鼻づらを松の木へこすりつけてやろうくらいにまで怒っていた主人が、突然この反古紙を読んで見たくなるのは不思議のようであるが、こう云う陽性の癇癪持ちには珍らしくない事だ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "才人は才に斃れ、智者は智に敗れ、苦沙弥君のような癇癪持ちは癇癪を利用さえすればすぐに飛び出して敵のぺてんに罹る……」「ひやひや」と迷亭君が手をたたくと、苦沙弥君はにやにや笑いながら「これでなかなかそう甘くは行かないのだよ」と答えたら、みんな一度に笑い出した。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が心配性なら、あなたはよっぽど癇癪持ちですわ」「そうかも知れない。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この純一君と話しているうちに、漱石の話がたびたび出たが、純一君は漱石を癇癪持ちの気ちがいじみた男としてしか記憶していなかった。",
              "citation": {
                "source": "漱石の人物",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の間にやさしい愛情がないわけでもないのに、細君は夫を「気違いじみた癇癪持ち」に仕上げ、夫は細君を従順でない「しぶとい女」に仕上げて行く。",
              "citation": {
                "source": "漱石の人物",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『道草』に書かれた時代よりも後に生まれた純一君は、父親を「気違いじみた癇癪持ち」として心に烙きつけていた。",
              "citation": {
                "source": "漱石の人物",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "漱石を気違いじみた癇癪持ちと感じることは、夫人や子供たちの側からは、それ相応に理由のあることであろう。",
              "citation": {
                "source": "漱石の人物",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しいゝ時は非常に御きげんがよくて、何うしてかんしゃくもちなんだらうってくやしがるし、いろ／＼な、修養に関する意見も立派なものですが、さあ悪い時は、たゞ死にたくなってかんしゃくが起きておこりたくて堪らないんださうです。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、舌うちする音がしたので、かんしゃくもちの先生は、エミイを許すことなんか、考えようともせず、「手を出して、さあ！",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
