[
  {
    "uuid": "29fe5c7a-88aa-557d-bc47-e62b59984822",
    "entry": "勘当",
    "reading": {
      "primary": "かんどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "disinheritance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それに、君、僕はちかく勘当されるかも知れないのだよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自棄まぎれに飛出したんで、両親には勘当はされても、位牌に面目のあるような男じゃない。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女も情を立てて帰らないから、両方とも、親から勘当になったんですね、親類義絶――つまるところ。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は勘当されたッて。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「息子さんは不埒が分って勘当かい。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまぢやもう、おれのはうから、あれは無いものと思つて、勘当して、おや？",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "げびた言い方をすれば、私は二十代のふしだらのために勘当されていたのである。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『われひとりを悪者として勘当除籍、家郷追放の現在、いよいよわれのみをあしざまにののしり、それがために四方八方うまく治まり居る様子』などのお言葉、おうらめしく存じあげ候。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四国の或る殿様の別家の、大谷男爵の次男で、いまは不身持のため勘当せられているが、いまに父の男爵が死ねば、長男と二人で、財産をわける事になっている。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまはもう、華族もへったくれも無くなったようですが、終戦前までは、女を口説くには、とにかくこの華族の勘当息子という手に限るようでした。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵対又は勘当の者なりとも召抱｜扶持等随意たるべきことという許しは与えられた。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "巌石の城を攻落した時に、上坂左文、横山喜内、本多三弥の三人が軍奉行でありながら令を犯して進んで戦ったので厳しく之を咎めたところ、上坂横山の二人は自分の高名の為ではなく、火を城に放とうと思うたのであると苦しい答弁をしたので免されたが、本多は云分立たずであったので勘当されて終った。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て九州陣巌石の城攻の時に軍令に背いて勘当された臣下の者共が、氏郷と交情の好かった細川越中守忠興を頼んで詫言をして貰って、復新に召抱えられることになった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其男が勘当を赦されて新に召還されたばかりの次の日出仕すると、左馬允、汝は大力相撲上手よナ、さあ一番来い、おれに勝てるか、といって氏郷が相撲を挑んだ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "情死、駈落、勘当等、これ皆愛の分弁たり。",
              "citation": {
                "source": "愛と婚姻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿を云え、縁談の前へ立って、讒口なんぞ利こうものなら、己の方が勘当だ、そんな先生でないのだから、と一言にして刎ねられた、柳橋の策｜不被用焉。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時女房に勘当されたが、やっとよりが戻って以来、金目な物は重箱まで残らず出入先へ預けたから、家には似ない調度の疎末さ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘当された息子じゃねえが、二階で寝ると魘されらあ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "監督の叔父さんから内々注意があるもんだから、もう疾くに兄さんへは家でお金子を送らない事にして、独立で遣れッて名義だけれども、その実、勘当同様なの。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘当と言って投げ出す銀煙管。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『われひとりを悪者として勘当除籍、家郷追放の現在、いよいよわれのみをあしざまにののしり、それがために四方八方うまく治まり居る様子、』などのお言葉、おうらめしく存じあげ候。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘当ではない自分で追出て、やがて、おかち町辺に、もぐって、かつて女たちの、玉章を、きみは今……などと認めた覚えから、一時、代書人をしていた。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "知れて、柳吉は中風で寝ているが頑固者の父親をしくじり、勘当になり、蝶子にかかる身体となったが、蝶子も柳吉と暮したさに自ら借金つくって引き、黒門市場のなかの裏長屋に二階借りして、ふたり住んだ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "里子の時分、転々と移っていたことに似ているわけだったが、しかしさすがの父も昔のことはもう忘れていたのか、そんな私を簡単に不良扱いにして勘当してしまいました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし勘当されたとなると、もうどこも雇ってくれるところはなし、といって働かねば食えず、二十五歳の秋には、あんなに憧れていた夜店で季節外れの扇子を売っている自分を見出さねばならなかったとは、何という皮肉でしょう。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はもうたいした野心もなく、大金持になろうなどと思ってはいなかったというものの、勘当されている身の上を考えれば、やはり少しはましな人間になって、大手を振って親きょうだいに会えるようになりたい、そのためにはまず貯金だと思っていたのですが、酒のためにそれもできない始末でした。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて春風荘の一室に落ちつくと、父は、俺はあの時お前の若気の至りを咎めて勘当したが、思えば俺の方こそ若気の至りだとあとで後悔した。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺田にしては随分思い切った大胆さで、それだけ一代にのぼせていたわけだったが、しかし勘当になった上にそのことが勤め先のＡ中に知れて免職になると、やはり寺田は蒼くなった。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれつき肌が白いし、自分から言うのはおかしいが、まア美少年の方だったので、中学生の頃から誘惑が多くて、十七の歳女専の生徒から口説かれて、とうとうその生徒を妊娠させたので、学校は放校処分になり、家からも勘当された。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が岩村田へ戻るようなら、もうへえ、かんどうする……わしも困っちまって――百姓　……そうかや。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
