        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "京都の寺院で、室町時代に描かれたとされる唐絵の屏風が特別公開されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖父が遺した古い蔵から、鮮やかな色彩の唐絵の掛け軸が見つかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "唐絵特有の力強い筆致は、見る者を圧倒する迫力がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "美術史の講義で、南宋時代の唐絵の様式について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "床の軸は大きな傅彩の唐絵であって、脇棚にはもとより能くは分らぬが、いずれ唐物と思われる小さな貴げなものなどが飾られて居り、其の最も低い棚には大きな美しい軸盆様のものが横たえられて、其上に、これは倭物か何かは知らず、由緒ありげな笛が紫絹を敷いて安置されていた。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし長崎の人の記載に、「小原慶山、又渓山に作る、字は霞光、丹波の人、元禄中長崎絵師兼唐絵目利に任官、其子小原勘八、名は克紹、巴山と号す、聖堂書記役なり」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "都府楼観音寺唐絵と云はんに四ツ目の鐘の裸なる、報恩寺の甍の白地なるぞ屏風立てしやうなり。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐絵の羅浮仙のように腰がほそくて、着ている被布の紫がつよすぎる。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吐き気がついてからえづきをした。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　さきの話ずきの女は、この春月の詩碑へたずねて遠くからちょいちょい人が来ることや、五年前の除幕式には東京からえらい人が見えたことやをこまごまと話つづけた。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へええ、貴様あとからえらそうなことを云ってやがら。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもアラムハラドはそんなに偉い学者でしたからえこひいきなどはしませんでした。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどかしわばやしの前まで来たとき、清作はふいに、うしろからえり首をつかまれました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お天気のいい時教室さはいってるづど先生にうんとしからえるぞ。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しからえでもおら知らないよ。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもこの事務所では、何せ事務長が黒猫なもんですから、このかま猫も、あたり前ならいくら勉強ができても、とても書記なんかになれない筈のを、四十人の中からえらびだされたのです。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちやうどかしはばやしの前まで来たとき、清作はふいに、うしろからえり首をつかまれました。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっぷあっぷ溺れるまねをしたりなんかもするねえ、そんなことをしてふざけながらちゃんと魚をつかまえるんだからえらいや、魚をつかまえてこんどは大威張りで又氷にあがるんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生に見つかつたら、俺があやまつてやるからええに。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いついたら、深くも考えず、ぱっぱっとやってしまったんだ」「馬鹿しちゃったね」と東一君は孫だからえんりょなしにいった。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ありゃ、もう二、三｜日で死ぬからええて。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　慘劇の現場　夜の十時、グスタフソン警視がストックホルム警察廳の自室で煙草をふかしてゐると、あわただしくはいつて來たのは主任警部のソオルで、いきなり呶鳴りつけるやうに、「ただ今モルトナス島の派出所からえらい事件を報告して來ました。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「木之さん、あんたは大人しいから、たとい五十銭でも貰えば貰っただけ家へ持って来るからええけど、うちの人は呑ん兵衛で、貰ったのはみんな飲んでしまい、まだ足らんで、持っていった銭まで遣ってくるから困るよ。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、途中からえらい降りで。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "茉莉は事務所の者が見ている」　と、言われると、もはや陽子はマネージャーの言葉にはさからえなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日も二三日前からだらけてゐた体が、前晩あたりからえらい熱病にでも罹つたやうに、熱ざしてほてるのでかかり付けの医師に行つて来たところであつた。",
              "citation": {
                "source": "あかんぼの首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、おさかなは、すぐと、ひいさまたちの所まで泳いで行って、その手からえさをとってたべて、なでいたわってもらいました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "のっそり子の省作も、おとよさんの親切には動かされて真底からえい人だと思った。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあお菊さん菓子とらねいか鉄っさんのおごりだからえんりょはいらねいよ。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し自分は入夫といふ關係もあるしそれに生來の寡言なので姻戚の間の協議にも彼は「どうでもわしはようがすからえゝ鹽梅に極めておくんなせえ」とのみいふのであつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうで俺ら餘計者だ、居やしねえからえゝや、幾ら持てたつて構やしねえ」彼は更に獨語いた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんでも俺れこたはあ、來なくつても癒つからえゝつて藥よこしたんだぞ」與吉は少し間を隔てゝ怖づ／＼いつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うむ、枕おつゝかるやうに成つたからえゝこたえゝに」卯平のいふのを聞て勘次は幾らか矜を以て又白い木綿を見た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おらげもすけたらよかつぺなア兼ツあん、摘んですけなけりや話してやつからえゝよ」　とお安は又からかふ。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
