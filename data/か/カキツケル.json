        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大事なことだから、手帳に書き付けておこう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は彼女の住所を慌てて紙切れに書き付けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "思いついたアイデアを忘れないうちに書き付ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "黒板に今日の予定を書き付ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "この時「自然詩人」は感興の対象なる事象物象をセンチメンタルに、あまりにも生理作用で書き付ける。",
              "citation": {
                "source": "河上に呈する詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」友人は手帳を一枚破って数語書き付ける。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はかく色彩のある衣を熱愛するがゆえに従ってそれを染める（書き付ける、すなわち摺り付ける）料になる実を女に贈り与えるのはそこに大いに意義がある。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は筆と紙を取り出でて、死なんとする人の言の葉を一々に書き付ける。",
              "citation": {
                "source": "薤露行",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "贄といふ船着で、隣の室に若い男と女が戯れて終夜騒いで居ても、袂の手帳に歌をかきつける余裕を失はないやうなのが其時の私であつた。",
              "citation": {
                "source": "春雨にぬれた旅",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子はそういう買物をめずらしがって、フロマージュ（チーズ）六ヶ四フラン四〇サンティーム、クッキー一二五グラム三フラン五五サンティーム、玉子二ヶ（上）一フラン七〇サンティーム、桜んぼキロ四フラン、など、手帖にかきつけるのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまりキューとひきつめていていやなので、殆ど元のとおりですが、左の方をすこしわけるようにしてかきつけることにしたのです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりあなたがおかきになるようにかきつけるわけです、はじめ横に、それからずっと上の方へ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
