    "definitions": [
      {
        "index": 1,
        "gloss": "hardware store",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ちょっとネジが緩んでるから、金物屋でドライバーを買ってこよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この町には、昔ながらの金物屋がいくつか残っていて、味があるんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "おばあちゃんの家に行く途中、金物屋に寄ってお米を研ぐためのボウルを買った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あら、こんなものまで置いてるの？」って、近所の金物屋で驚いたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それは駅前の金物屋から四、五年前に二円で買って来たものだ。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "間口三間くらゐの小ぢんまりした金物屋である。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五十くらゐのひとで、金物屋の越野ですが。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、失礼ですが、越野たけ、あの、金物屋の越野さんは、こちらぢやございませんか。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで何かに憑かれたみたいに、たけはゐませんか、金物屋のたけはゐませんか、と尋ね歩いて、運動場を二度もまはつたが、わからなかつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ帰ることにきめて、バスの発着所のベンチに腰をおろし、十分くらゐ休んでまた立ち上り、ぶらぶらその辺を歩いて、それぢやあ、もういちど、たけの留守宅の前まで行つて、ひと知れず今生のいとま乞ひでもして来ようと苦笑しながら、金物屋の前まで行き、ふと見ると、入口の南京錠がはづれてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……話の中に、田舎から十四で上京した時は、鍛冶町辺の金物屋へ小僧で子守に使われた。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今度は金物屋に行って鉛の半円鋳を六百斤ほど買集め、そっくりそのまま町外れのシロカネ屋（金属細工屋）に持って行って、これは蓬莢島から来た船の註文ゆえ、特別念入りの大急ぎで遣ってもらいたい。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "金物屋さんがありますからね、そこから右へはいって、半丁かな？",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳やという小料理屋がありますからね、先生、このごろは柳やのおステさんと大あつあつで、いりびたりだ、かなわねえ」　駅へ行き、切符を買い、東京行きの省線に乗り、阿佐ヶ谷で降りて、北口、約一丁半、金物屋さんのところから右へ曲って半丁、柳やは、ひっそりしていた。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　すると、夜店の金物屋さんは、眼を真丸くして、『それは大変だ、悪魔は爪から出入りするもんですよ。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、トロちやんは、夜店の金物屋さんが『悪魔は爪から出入りをしますよ。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "血のあとをふきとっても、まだ安心ができませんので、それから、わたしは、近所の金物屋から小刀を一挺買って来て、それを死体の背中へ突きさして他殺と見せかけようと思ったのです。",
              "citation": {
                "source": "予審調書",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、金物屋を呼んで来て下さい。",
              "citation": {
                "source": "予審調書",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「もう金物屋を呼ぶ必要はありません。",
              "citation": {
                "source": "予審調書",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "その金物屋は、たしかにあなたにあの晩あの小刀を売ったと言っておるのです。",
              "citation": {
                "source": "予審調書",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時刑事が金物屋の報告を伝えて来たのです。",
              "citation": {
                "source": "予審調書",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒が悪いというなら、泥棒に凶器を売る銃器店や、金物屋もわるいことになる。",
              "citation": {
                "source": "或る探訪記者の話",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居見物の男女など大正一四・一二作『演劇・映画』大正一五・二、新橋演舞場初演　第一幕　京橋｜具足町の和泉屋という金物屋の奥座敷。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀吉　露月町の金物屋で大和屋十右衛門という人だそうです。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）――幕――　第三幕　　（一）　京橋具足町の金物屋、和泉屋の店さき。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七　なるほど金物屋の番頭だけに、薬鑵あたまに出来ていやあがる。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから駒形に接近した境界にこれも有名だった伊阪という金物屋がある（これは刃物が専門で、何時でも職人が多く買い物に来ていた）。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "名高かった店などの印象",
                "note": "青空文庫"
              }
            },
            {
              "text": "老管理者は途で金物屋に寄つて、金槌を一｜挺買つて帰つた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすっぺらな手紙を女中に出させてから明日金物屋へ「きゃしゃ」な「ふせかご」を命じる事を忘れてはならない事の様に思いつづけて居た。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもないんだよ、　お前あした金物屋へ行ってね一寸目位の高さが四尺位で長さが一間半位の『ふせかご』を作るようにたのんどいで。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうです、訳あないじゃありませんか」　大工が仕事を初めたところで、釘をすら買うべき小銭に事かいていたお島は、また近所の金物屋から、それを取寄せる智慧を欠かなかった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、ばかなものや、自分の役目にふさわしくないものには、それが見えないという話を思い出しますと、ちょっとへんな気持になりました。",
              "citation": {
                "source": "はだかの王さま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろんな部分から火や血や人間の屍が噴き出ていて、僕をびっくりさせたが、僕は剥ぎとられたほかの部分から何か爽やかなものや新しい芽が吹き出しそうな気がした。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろんな部分から火や血や人間の屍が噴き出てゐて、僕をびつくりさせたが、僕は剥ぎとられたほかの部分から何か爽やかなものや新しい芽が吹き出しさうな気がした。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
