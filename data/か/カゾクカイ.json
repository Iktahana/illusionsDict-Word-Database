        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "病院では、患者の家族をサポートするために定期的に家族会を開催している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "災害で被災した方々の家族会が結成され、情報交換や支援活動を行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "認知症の家族を介護する人たちが集まる家族会で、体験談を共有した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この社会小説への門としての長篇小説流行が、当時に於てもその長篇小説らしい構成を欠いていること、武田麟太郎の「下界の眺め」にしろ横光利一の「家族会議」にしろ或は「人生劇場」「冬の宿」その他が一様に通俗性に妥協している点で批判を蒙っていたことは、なかなか意味のあることであったと思う。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "各車庫を中心としてもち、（ストライキのとき）組合の家族会の活動を支持するために托児所をもった。",
              "citation": {
                "source": "「乳房」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○我々が働けるように家族会をやって進めて下さい。",
              "citation": {
                "source": "「乳房」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、今朝、既に広尾では家族会を応援して移動託児所をひらいていることを説明した。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族会議　機智的な会話に十分才能を認め得るも、後半は著しく弛緩し、修正を加ふにあらざれば退屈至極ならん。",
              "citation": {
                "source": "ラヂオ・ドラマ選者の言葉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "須貝　（一寸うろうろして）やあ、家族会議？",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスマスの晩、ホテルの家族会へ、毎年招かれてゆくならわしになっていたのだが、私はその一週間前あたりから床につくことがさだめられているように、風邪や肺炎をおこした。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私を除いての家族会議が毎夜行われているようだった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月二日（日）　東洋経済に家族会があったが、平川唯一君が電気器具の修繕にきてくれる約束があったので行かなかった。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "石田家におけるその夜の家族会議は、湿りに湿って、露もしとどのありさまだった。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族会議といっても、長男の五十雄君はつづきの六畳で寝て居り、生臭い人生と一切やりとりをしない気でいる長女の千々子さまは、自分の居場所にきめている玄関の三畳へひっこんで音もたてない。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "入院するほうがいいと云われたが、ひとまず家へ帰って寝、入院について家族会議を開いた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の部終ると朝日ビルのＡＢＣ家族会てのへ顔を出し、流行歌漫談を一席やる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族会議かなんかにお邪魔したようだ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
