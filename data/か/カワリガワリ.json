        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ほら、重いから代わり代わり持とう」「助かるよ、じゃあ次の角までお願い」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "渋滞が続く高速道路で、夫と代わり代わりハンドルを握ってようやく実家に辿り着いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "病室の祖父の枕元で、親戚たちが代わり代わり昔話を語りかけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "二人の打者が代わり代わりバッティングケージに入り、鋭い打球を飛ばしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その家々に支那人が代わり代わり腰をかけて、油っこいものを、さもおいしそうに青天井の下でたべている。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローマ宗の寺院はこれに反し、堂内別にヤソ処刑の礼壇を設け、その前に十字架上のヤソ像を仰臥せしめ、参詣のものをして代わり代わりひざまずき進みて、その像の手足胸腹を口吻せしむ。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "照彦様と正三君はもとよりのこと、この主従と特に親しい三名は代わり代わりに難くせをつけられる。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "村人達はかわりがわり庄造の病気を見舞ったが、其の都度庄造の枕許に坐っている狸の殊勝な姿を見た。",
              "citation": {
                "source": "狸と俳人",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ころがり落ちると仰向けになって今度は下からすきまに足をかわりがわりにさし込んだりする。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "使いのふたりがかわりがわりに話すところをまとめると、こうである。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "兼吉と五郎は、かわりがわり技師と花前との身ぶりをやって人を笑わせた。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母は寒いからもう少し寝ていよという、姉も次なも仲なも乳房にとッついているのも、起きるだという、起ようという起してという、大騒ぎになッてきた、婆や、早く着物をあぶってという、まだ火が起りませんから、と少しまってという、早く早くと四人の児供らはかわりがわり呼立てる。",
              "citation": {
                "source": "浅草詣",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから昼間は村人がかわりがわりに斧で伐り、夜は夜で夜もすがら根下を焼いて、ようやく三七二十一日めで伐り倒しました。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年共産同盟の若々しい合唱団もトラックにのって来ていて、新協とかわりがわり歌をうたい、よろこびの日の賑わいを添えた。",
              "citation": {
                "source": "メーデーに歌う",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、イヌとネコは、かわりがわり言いました。",
              "citation": {
                "source": "金のくびかざり",
                "author": "小野浩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こりゃふるね」「同じふるなら、早くたのみますね」　かわりがわり本気で窓から空模様をうかがっている。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は、ケイ紙などと重ねて机の上に出してある「働く婦人」をとりあげ、片手でワイシャツの腕を、かわりがわり引きあげた。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの左右から校友がかわりがわりに握手するやら肩を打つやらした。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいていは、順番に畑を一年遊ばせて、地力の恢復をはかっているので、五種の作物を、かわりがわりにつくっている。",
              "citation": {
                "source": "日本の将来",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして畳一畳位に一杯に並べられたその悠長に大きい歌留多を、かわりがわりに一枚ずつ開けて行くのである。",
              "citation": {
                "source": "御殿の生活",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいていかわりがわりにでるので、先月はカレーだったら、今月はオムレツだという工合に皆がはり切って待つわけである。",
              "citation": {
                "source": "若き日の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーリキイは大きくてさっぱりと暖い掌の中へ、かわりがわり伸子と素子の手をとって挨拶した。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまわりを囲んで立つ男女労働者たちは、何というまじりけない感歎と、期待とほこりをもって「われらの成果」たるドニェプルの模型にスウィッチを入れ、赤・青の豆電気が、かわりがわり、大きい模型の重要地点にきらめく様に見入っていることだろう。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「少し大きくなったようね」　と君子姉さんと貴子姉さんがかわりがわりに頭をなでてくれた。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、警官たちが、かわりがわり、たいあたりで、ドアにぶっつかり、見るまに、それをやぶって、中にふみこんで行きました。",
              "citation": {
                "source": "虎の牙",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
