        "examples": {
          "standard": [
            {
              "text": "料理中は、必ず換気扇を回すようにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "浴室の換気扇がうるさくて、交換を考えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "タバコの煙が充満しないように、換気扇を強めに設定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この部屋は窓がないので、強力な換気扇が必須だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」「とりあえず山を越えて、あとはそれから考えよう」　高志は、非常口わきの、小浴場の換気扇をかえりみた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "換気扇からは湯気がもれ、彼らが入らなくても、やはり風呂の用意ができていることを示していた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
