          "standard": [
            {
              "text": "先日買った漢字辞典に載っている部首索引は、調べたい字をすぐに見つけられて便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この漢字辞典は、古語の用例も豊富で、古典を読むときに重宝している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供が小学校に入学したので、学習用の漢字辞典をプレゼントした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "外国人の友人が日本語を勉強しているので、わかりやすい漢字辞典を勧めてあげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼の説は時代遅れとなり妻の変死も原因して彼は公的のものと一切関係を断ち、売れそうな漢字辞典や、受験本を書いて独力で出版販売した。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
