        "examples": {
          "standard": [
            {
              "text": "カルヴィニズムの思想は、その後のヨーロッパの社会や政治にも大きな影響を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この本では、カルヴィニズムの源流から現代に至るまでの展開を追っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "厳格な規律を重んじるカルヴィニズムの倫理観は、一部で成功の象徴とも見なされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "カルヴィニズムの教えは、一部の改革派教会によって今日まで受け継がれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "カルヴィニズムのすべてへの吝嗇さへの反感。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは云わば一つの――尤もカルヴィニズム運動などに較べるべくもなく小規模ではあるが――資本主義の精神だったのである。",
              "citation": {
                "source": "イデオロギー概論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
