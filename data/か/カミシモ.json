        "examples": {
          "standard": [
            {
              "text": "上下の色を揃えた裃の装束は、儀礼の場にふさわしい威厳を感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "裃を脱ぎ捨てて身軽になった彼は、ようやく畳の上に大の字になって寝転んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "武家の正装として、裃をビシッと整えるのは武士の嗜みの一つであった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
