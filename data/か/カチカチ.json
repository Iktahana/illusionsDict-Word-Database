        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の考え方は非常にカチカチで、新しいアイデアを受け入れようとしない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の伝統的な考え方は、カチカチで変化に抵抗があった。",
              "citation": {
