        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古い柱時計は、毎秒「カチカチ」と時を刻む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "寝室の時計の絶え間ない「カチカチ」という音で眠れない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "メトロノームはピアニストのために一定の「カチカチ」というリズムを刻んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "グリムもアンデルセンも、日本の桃太郎やカチカチ山の作者も、すべて皆兒童心理學の大家であり、同時にフアンタスチツクの夢をもつてる詩人であつた。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し眠りたいと思うて寝返りをすると、額の氷袋の氷がカチカチと鳴って袋は額をはなれる。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃太郎、カチカチ山、舌切雀、瘤取り、浦島さんなど、父は子供に讀んで聞かせる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カチカチ山　カチカチ山の物語に於ける兎は少女、さうしてあの慘めな敗北を喫する狸は、その兎の少女を戀してゐる醜男。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "現今發行せられてゐるカチカチ山の繪本は、それゆゑ、狸が婆さんに怪我をさせて逃げたなんて工合ひに、賢明にごまかしてゐるやうである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が防空壕の中で、このカチカチ山の繪本を讀んでやつたら、「狸さん、可哀想ね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或ひは、この子は、父に連れられて近所の井の頭動物園に行つた時、檻の中を絶えずチヨコチヨコ歩きまはつてゐる狸の一群を眺め、愛すべき動物であると思ひ込み、それゆゑ、このカチカチ山の物語に於いても、理由の如何を問はず、狸に贔屓してゐたのかも知れない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをこのカチカチ山ばかりは、どうも、その仇討の仕方が芳しくない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは、カチカチ山だもの。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、この山はカチカチ山つていふ名前なのよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は、ついさつき、ここはカチカチ山だつて言つた癖に。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カチカチ山だの、ボウボウ山だの、名前からして妙に出來てる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ、カチカチ山といふのがあつて、それからいよいよパチパチのボウボウ山といふ事になるんだが、あいつあいけない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、いい加減に、カチカチ山あたりでごめんかうむつて來るんですな。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瘤取り、浦島さん、カチカチ山、その次に、桃太郎と、舌切雀を書いて、一應この「お伽草紙」を完結させようと私は思つてゐたのであるが、桃太郎のお話は、あれはもう、ぎりぎりに單純化せられて、日本男兒の象徴のやうになつてゐて、物語といふよりは詩や歌の趣きさへ呈してゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私は、カチカチ山の次に、いよいよこの、「私の桃太郎」に取りかからうとして、突然、ひどく物憂い氣持に襲はれたのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この舌切雀にせよ、また前の瘤取り、浦島さん、カチカチ山、いづれも「日本一」の登場は無いので、私の責任も輕く、自由に書く事を得たのであるが、どうも、日本一と言ふ事になると、かりそめにもこの貴い國で第一と言ふ事になると、いくらお伽噺だからと言つても、出鱈目な書き方は許されまい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瘤取りの二老人も浦島さんも、またカチカチ山の狸さんも、決して日本一ではないんだぞ、桃太郎だけが日本一なんだぞ、さうしておれはその桃太郎を書かなかつたんだぞ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢夫さんと一緒になった時などは、刀がほんとうにカチカチぶっつかったぐらいだ。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自働電話の送信器の数字盤が廻るときのカチカチ鳴る音と自働連続機のピカピカと光る豆電燈の瞬きもやはり同じような考えを応用して出来た機構の産物であると見れば見られなくはないであろう。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてポケットが大へん重くカチカチ鳴るのに気がつきました。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "光の骨までカチカチ云うぜ。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い葉を、カチカチと二ツばかり噛んで手に取って、掌に載せて見た。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お月様の中の小兎をよろこばず、カチカチ山の小兎を愛している。",
              "citation": {
                "source": "古典竜頭蛇尾",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カチカチ山は仇討ち物語である。",
              "citation": {
                "source": "古典竜頭蛇尾",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてポケットがたいへん重くカチカチ鳴るのに気がつきました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」歯がカチカチ云ふたびに青い火花はそこらへちらばりました。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢夫さんと一緒になった時などは、刀がほんたうにカチカチぶっつかった位だ。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太刀はいなづま　すゝきのさやぎ、燃えて……」　組は二つに分れ、剣がカチカチ云ひます。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
