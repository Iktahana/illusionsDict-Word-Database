    "definitions": [
      {
        "index": 1,
        "gloss": "life in natural setting, free from worldly cares",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は都会の喧騒を離れ、田舎で閑雲野鶴の生活を送っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "定年後は、釣りや畑仕事に明け暮れる閑雲野鶴の暮らしが夢だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "余計な欲を持たず、閑雲野鶴を気取る彼の生き方に共感する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若くして出世を捨て、閑雲野鶴の境地に至った高僧の話を聞いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして十幾ヶ月の間閑雲野鶴を友として暮したが、五年以前の秋、思立つて都門の客となり、さる高名な歴史家の書生となつた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑雲野鶴空濶く風に嘯ぶく身はひとり月を湖上に碎きてはゆくへ波間の舟ひと葉ゆふべ暮鐘に誘はれて訪ふは山寺の松の風。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し彼は其生涯の後年に於てこそ所謂閑雲野鶴、頗る不覊自由の人とはなりたるなれ当時に在りては猶純乎たる封建武士の子たりし也。",
              "citation": {
                "source": "頼襄を論ず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
