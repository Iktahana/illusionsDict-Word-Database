        "examples": {
          "standard": [
            {
              "text": "給料日前はいつも空っけつで、食べるものにも困るほどだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ギャンブルで大負けしてしまい、財布の中は空っけつになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "月末になると、僕の貯金はいつも空っけつになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "お前のお母さんもだらしがないけど、お前もだらしがないぞッ」　勘三は、ひどく空きっ腹で、二三軒回った新聞社が駄目だったし、雨は土砂降りの吹き流しと来てるし、懐は一文なしの空っけつと、朝から御承知のすけで出て来ているのだ。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "からっけつの尻端折、笠一蓋の着たッ切雀と云うも恥かしい阿房鳥の黒扮装で、二見ヶ浦に塒を捜して、「お泊りだ、お一人さん――旅籠は鐚でお定り、そりゃ。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうお客にすりゃ御損が行く、情人にして不足のねえからっけつ曾我の十郎てえお兄いさんだ、頼むぜ、と取巻いた人立を割って怒鳴り込んだんでさ。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
