        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "銀行から事業資金の貸付を受けることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "急な出費に備えて、友人にお金を貸し付けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この制度では、低金利での貸付が可能です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あら、そんなにたくさんお金を貸し付けるなんて、大丈夫？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "多額の貸付は、審査に時間がかかることがあります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それに彼は、いくらか小金を溜めて、一割五分の利子で村の誰れ彼れに貸付けたりしていた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日田金を日田の材木屋が下請けのようにして、日田の月隈の奉行所に御座る大公儀の御金奉行の監督を受けながら、九州の諸大名の城下城下におる御用金預り……博多で言えば蔵元屋のような主立った商人にソレゾレ貸付ける。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "早縄をかけたまま横の山道へ担ぎ込んで、懐中物を取上げてみると案の定、蔵元屋の身上調べと、黒田藩のお納戸の乱脈を細かに調べ書きにしたものが、貸付証文と一緒に在ったわい」「あっ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘八百万両も貸付けたら小人島の政治界なんぞには今でも頭の出せそうに思われる理屈がある。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "敢て富有といふではないが、少許は貸付もあつた様だし、田地と信用とは、増すとも減る事がない。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ヶ月ばかり前に、貸付の契約は出来てしまっていた。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "他ノ生産的各省ヘノ貸付。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "先に大口の言込有りし貸付の緩々急に取引迫りて、彼は些の猶予も無く、自ら野州塩原なる畑下と云へる温泉場に出向き、其処に清琴楼と呼べる湯宿に就きて、密に云々の探知すべき必要を生じたるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "拓殖銀行は特別低利で「年賦償還貸付」をした。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――田に修繕を加えて、少しでも上り高を多くしようとすれば、どうしてもそれを拓殖銀行へ抵当に入れて「年賦償還」の貸付けを受けなければならない。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "）――すると、その金は拓殖銀行から、又農業資金として、年賦貸付になって出て行く。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は欲するままに、余に貸付けられたるわが国を動かす権利があるんだ」10　白堊館の大統領寝室に於て。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「捨吉、あの向うが小父さんの領分だ」　と小父さんは舞台の正面に向った高い桟敷を指して見せて、土間にも幾｜桝か買って置いたところがある、そこは出方に貸付けてあるなぞと話し聞かせてくれた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿下は陸軍騎兵附の大佐で、かくれもない馬好でいらせられるのですから、御｜寵愛の「ファラリイス」という亜刺比亜産を種馬として南佐久へ御貸付になりますと、さあ、人気が立ったの立たないのじゃ有ません。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿下は陸軍騎兵附の大佐で、かくれもない馬好でいらせられるのですから、御寵愛の「ファラリイス」という亜刺比亜産を種馬として南佐久へ御貸付になりますと、さあ、人気が立ったの立たないのじゃ有ません。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "日歩六銭は欠かさず手取りということにして、それ以上は中尾の腕次第、九銭で貸付けた時は一銭五厘、拾銭のときは二銭という風に中尾に歩分けした。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貸し金は小口を主として、返済は三ヵ月限度とし、貸付範囲はサラリーマンを主としていた。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一人の男はきりこのレンズの眼鏡を見物人へ貸付けてあるくのである。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人で、六十万両を貸付けていた浜村孫兵衛が、催促しがてら、話対手になっただけであった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「戯談は、さて置き――帳尻を合せましたなら、ちと、密談を――」　斉興が、頷いて、用人に「その五十両、小藤次へ貸付としておけ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝てる間も起きてる間も、算盤玉こばかりはじいていますて」　仙太の父親は、油商売のほかに、高利で金を貸付けていた。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉をひそめた彼らは、速やかに肥沃な土地を選定して、至急貸付けを願い出ろと諭した。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏査した新しい支配地の貸付を、開拓使の仮庁舎に出頭して懇請しなければならない。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「土地貸付けの儀にてまいった者、判官どのご多忙と云われるなら、責任ある係り役人にても結構、自分は――」　彼は名乗るのであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "天と地の折目をのばして、一折りずつひろげると、先ず主人邦夷の名が例の通り低く書かれて、「其方へ、石狩国石狩郡ノウチ、トウベツノ地一帯ノ貸付｜被仰付候事」と二行に書き、「明治四年六月、開拓使」と署名されていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜んでくれるであろうと思った貸付け地の許可は、反対にありありと不安を募らせた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二には、今後の『開墾資金』として相当額の金子の貸付けを開拓使に承諾させること。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旧仙台藩伊達邦夷貸付地」　月日は記さなかった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍らには、「旧仙台藩伊達邦夷貸付地」と書いた標木が、草の海に浮んでいた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうとも、連れて来ておくンなさい、どんなに喜ぶことだろうか」　貸付けを得た原野は茫々として涯が見えなかった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
