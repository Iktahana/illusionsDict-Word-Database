        "examples": {
          "standard": [
            {
              "text": "必殺技は、どんな硬い壁でも貫くことができるんだ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の歌声は、まるで壁を貫くように、会場の隅々まで響き渡った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "どんな障害があっても、目標に向かって壁を貫く意志が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "だから鉄の扉やコンクリートの厚い壁を貫くことなんか何でもない。",
              "citation": {
                "source": "蠅",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "全くの素人がちょっと考えれば鉄砲弾は木壁を貫くだけで、横側の硝子板には影響がないようであるが、流体はある一部へ加えられた圧力を四方八方へそのまま伝えるという流体力学の原理があって、硝子の破れるのは当然なのである。",
              "citation": {
                "source": "「光線の圧力」の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
