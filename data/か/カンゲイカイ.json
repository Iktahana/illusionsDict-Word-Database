    "definitions": [
      {
        "index": 1,
        "gloss": "welcome party",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しい部署の歓迎会、いつやるか決まった？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "同期入社の皆で、新しく来た先輩の歓迎会を企画しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わー！すごい！私のための歓迎会だ！ありがとう！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "私はこの話を昼も杜鵑の鳴く青葉の山へ行っても、晩の歓迎会の席でも、また宿屋へ帰っても古いことを知ってそうな年寄りを見つけると、訊ねて聞き取ったのである。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歓迎会で会った老婦人の一人は言った。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、税務署長歓迎会　税務署長が壇を下りましたらすぐ名誉村長が笑ひながら少しかゞんで署長の前にやって来ました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "檜垣の二階に、歓迎会の集りがあった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はさきの夜、檜垣の歓迎会の晩餐にて、食事のコース中、夫人が何を選み、何を好み食べたか、すっかり見て取っていた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう蹴球部の新入部員歓迎会が学校のホールで催された。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "往復の船中の恋愛、帰ってきたぼくは歓迎会ずくめの有頂天さのあまり、多少神経衰弱だったのです。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、今晩の歓迎会はどうだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち二、三人は博物館の参観、公会堂での観光団歓迎会へ臨む前のほんの小閑をぬすんで、その旧市街見物と出かけたのであった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二人が、今朝、公会堂の観光団歓迎会のすぐ後から、幌馬車に乗って、豊原の西郊の追分という部落へ散策したと思いたまえ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　少くとも私たちは何一つ与えられないで、公会堂の歓迎会席場へなだれ込むより外なかったのだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "謡の師匠なら、さき様の歓迎会や披露どころか。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本からも、日本パンクラブ代表として、老詩人×氏が出席してゐた、彼は果してどんな音響を立てゝ、日本の風船を叩きつぶしたであらうか、日本代表はまもなく日本へ帰つてきた、そこで×氏の報告を兼ねた歓迎会が開らかれた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この集会は、山口孤剣（やまぐちこけん・義三）君の出獄歓迎会であった。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝国ホテルで菅井博士の帰朝歓迎会があったでしょう。",
              "citation": {
                "source": "華やかな罪過",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は博士の奥さんと少し知り合いだったせいか招待状を頂いたので、その歓迎会へ出席してみたのです。",
              "citation": {
                "source": "華やかな罪過",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「帰朝歓迎会なんていうものくらい下らんものはありませんね。",
              "citation": {
                "source": "華やかな罪過",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "送別会と歓迎会、その記事はいつも新聞紙上をにぎわした。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで我等｜扈従記者の一行が県氏の案内で釧路へ着くと、釧路第一の料理亭、○万楼で土地の官民の有志が我我のために歓迎会を開いてくれた。",
              "citation": {
                "source": "石川啄木と小奴",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "かと思うと氏は素人の芝居などの、舞台監督をやられたり、キャフェーへ出かけて談笑したり、諸方面の歓迎会や送別会などへ、常に出席をして倦まなかった。",
              "citation": {
                "source": "名古屋の小酒井不木氏",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "樽野は今も相変らず、天気さへ好ければＮ村行を続け、鴎丸に会へばスターの歓迎会が面白かつたことを日増に言葉少く語り合ふこと、何故か村長が姿を見せなくなつて軽い不安を感じてゐることで、事実の上では何うしても小説の区切りになるやうな出来事も想ひも起らなかつた。",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "知合の誰彼が発起で、ある晩歓迎会が催された。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家の活躍４・４（夕）　二日の夜大阪ホテルで催された洋画家｜鹿子木孟郎氏の歓迎会の席上、鹿子木氏が近頃流行の“Camouflage”といふ語を口に出すと、居合せた大阪の洋画家連は、いづれも初耳らしく、兎のやうに耳を引つ立ててゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時ブランデスという人がイブセンが来たから歓迎会を開こうというと、イブセンはそんな歓迎会などは御免蒙ると言っている。",
              "citation": {
                "source": "模倣と独立",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "みなさまはこの数日来、卒業し、送別会、上級学校の新入生としての歓迎会と、若々しい人生の一つの門から他の門へとおくぐりになりました。",
              "citation": {
                "source": "新しい卒業生の皆さんへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園の入口にはウインネッケ彗星大歓迎会　音楽と映画の夕べと云う立て札が出て居る。",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が長崎から東京に行つた折には、日本の社会主義者は彼の名誉のため厳粛な歓迎会を催し、また彼が横浜を立つ前には特に送別会を開いた。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
