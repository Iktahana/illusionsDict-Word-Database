        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長年の努力が実を結び、ついに目標を達成できた。言葉にならない、感慨無量だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "恩師との再会に、彼は感慨無量で、ただ頭を下げることしかできなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "家族全員で無事に困難を乗り越え、今、こうして皆で食卓を囲めていることに、感慨無量である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「まさか、こんな日が来るとは…」と、彼は感慨無量な面持ちで空を見上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "井戸の底で可笑しい位の事だから、二軒の長屋の主婦も、感慨無量な顔を見合はせて、「まあ」　と云つたまゝ、涙をこぼしながら笑ひ出した。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「安宅先生はこういう家に生れたのかなあ――」と、わたくしを感慨無量にさすものがありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その生存している僅かな人々と相会して翁の旧事を語ると誠に感慨無量なものがある。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてはまた、郷里を想い、自分達の活動を想い、淋しい生活を振り返って、感慨無量の涙にくれるに相違ないのです。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し日がたって気の落ち着いたころに御訪問した入道の宮ででも、感慨無量な御会談があったはずである。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも感慨無量で折角飲んだ酒も醒めて来るが、暫くするとまた飲みたくなりゃこそ酒屋が渡世が出来る理窟故ますます感心する。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬか生きるかわからない』かう言つて、主人公はその持つてゐる『浴泉記』の原稿を友人に託する条は、殊に感慨無量で、何うしても、ロシアの文芸の産物であるといふ感を深くさせる。",
              "citation": {
                "source": "ペチヨリンとゲザ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ夜光命が二年半の歳月を過ごしたる處とて、感慨無量なるべし。",
              "citation": {
                "source": "三里塚の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親や母親の感慨無量なのに引きかへて――また常子の心持の次第に少女らしい感傷的な心持に落ちて行くのに引かへて、種子の眼にはあたりのものが、すべて何の意味もなしに、何の背景もなしに、唯、Blank Page として映つた。",
              "citation": {
                "source": "草みち",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は感慨無量でしばらく無言のまま顔を見合わしていたが、やがて女の方が口をきった。",
              "citation": {
                "source": "山吹町の殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "大地を歩くなんて、一千年以来のことだと思うと、じつに感慨無量であった。",
              "citation": {
                "source": "千年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "『何でもない、何でもない……』　窕子は感慨無量だつた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じその晩石川と銀座のそばやで一杯やりながら再び小奴のことを話しだすと石川も感慨無量の面もちでうなだれてしまつたので、もうそれ以上私は石川に小奴の話をする勇気がなくなつてしまつた。",
              "citation": {
                "source": "石川啄木と小奴",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが軍の怪力線の煙と消えたので彼もすこしは本望じゃろう」　そういって牧山大佐の声が受話器を通じて感慨無量といった顔をしている帆村の耳に響いた。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『……………………』『感慨無量だツたね。",
              "citation": {
                "source": "漂泊",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『感慨無量だツたね。",
              "citation": {
                "source": "漂泊",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さけとさしみとすしとで四十四銭、腹いつぱいになつた、感慨無量で胸いつぱいだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "独酌一本、感慨無量。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月廿三日　宮市の安宿で感慨無量。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は南京入場式、そして今夜は満月、誰も感慨無量であらう、殊に出征の将兵は。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれからもう十五年になる、あの頃の私を考へると、まことに感慨無量である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯田を通過する時は感慨無量であつた、私は胸の中で、飯田よ飯田よ、蛙堂老よ蛙堂老よ、と感謝の合掌を捧げるばかりだつた。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "感慨無量、自責の念たへがたきものがあつた。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "老境――悪夢の残滓、罪悪と悔恨、――私の老境はこんなものだ、感慨無量、――立ちあがれ、老を味へ、ほがらかな老境に入れ、体験を活かすべし。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "観月感慨無量、戦線をおもひ銃後をかへりみる、遠近親疎、有縁無縁、南無阿弥陀仏。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、二度も三度も、新聞の記事を繰返して読みながら、台所に立ったまま、全く感慨無量という状態に置かれたのです。",
              "citation": {
                "source": "偶感一語",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふうん、やっぱりそうか……あの人が大隊長で、僕はその部下にいたことがあるんだが……あの精神家の息子かね……」　部長はちょっとの間感慨無量といったような風で、ひとり言のように言っていたが、やがて自分に帰ったようになって、「その東という人は第二師団で有名な精神家だったんだ。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その記念日にあたって、わたしたちが力をつくして闘い、抵抗しなければならないのが国の内外にあらわになって来ているファシズムであり、戦争挑発であるということは、実に感慨無量のことです。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老夫婦が一組、私たちがいるのも眼にはいらないふうで、感慨無量といった顔で佇んでいた。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "感慨無量だ」　巴里から同行した美術家仲間はこの手紙を見てリオンへ向けて発って行った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
