        "examples": {
          "standard": [
            {
              "text": "「対数の整数部分を除いた『仮数部』に注目すれば、真数の数字の並び方がわかるんだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「テストでは仮数部の計算を間違えて、桁数は合ってるのに数値が全然違う答えになっちゃった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「常用対数表から仮数部を正確に読み取る作業は、慣れるまで少し時間がかかるね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
