  {
    "uuid": "08d9f339-7d54-5727-b2a4-4f1e1db31c79",
    "entry": "華表",
    "reading": {
      "primary": "かひょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "monument at cemetery entrance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "村の外れにある古い神社の参道には、立派な石造りの華表が静かに佇んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史小説の中で、主人公が異国の都にある巨大な華表を仰ぎ見て感嘆するシーンが印象的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この華表は、かつて大陸から渡ってきた石工が手がけたものだと言い伝えられています」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "墓所の入り口で、二本の華表が門柱のように歴史の深さを物語っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それから不折邸の横に「上根岸四十番」と記し、その右に大きな華表を画いて「三島神社」としてある。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中流より望みてその華表の上半のみ見ゆるに、初めてこれを見る人も猜してその三囲祠たるを知るべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "華表　柱頭　千歳の後、旅魂　旧に依りて　家山に到らん。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処は森の中で、入口には古ぼけた木の華表があった。",
              "citation": {
                "source": "火傷した神様",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、眠い、眠い、眠くてしかたがないぞ」　夢心地になって華表の下まで来たところで、もう一歩も歩かれなくなったので、そのまま其処へころりと寝てしまった。",
              "citation": {
                "source": "火傷した神様",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどその時、二人の旅人が華表の近くへ来て休んでいたが、あまり寒いので、一方の旅人が、「どうだ、火を焼こうか」　と云うと、一方の旅人も、「いいだろう」　と云って、さっそく二人で枯枝を集め、腰の燧石で火を出して、それを枯枝に移して暖まりながら話しこんでいるうちに、強い風が吹いて来た。",
              "citation": {
                "source": "火傷した神様",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雉は森へ火の移ったのを見ると、これも旅人以上に驚いて、御殿の前へ往ってはらはらしていたが、神様のことも心配なので、華表の処まで来たところで、来宮様は暢気そうに華表の下で鼾をかいて眠っていた。",
              "citation": {
                "source": "火傷した神様",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火はもう傍へ来て、今にも華表に燃え移りそうになって来た。",
              "citation": {
                "source": "火傷した神様",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより、咽喉がかわいた、水を一ぱい持って来い」「だめです、そんな暢気なことを云ってちゃ、焼け死にます、早く起きてください」「酒を飲んで焼け死ぬる奴があるか、水を持って来い」　火はもうその時｜華表に燃え移っていた。",
              "citation": {
                "source": "火傷した神様",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早く、早く、早く起きないと、焼け死にます、早く、早く」「なにを、そんなにあわてるのだ」　来宮様がやっと正気になって、顔をむっつりあげた時には、もう華表は一面の火になっていた。",
              "citation": {
                "source": "火傷した神様",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "路の左側に石の華表のある社は、河津八幡宮で、元の祭神は天児屋根命であったが、後に河津｜三郎祐泰及びその子の祐成、時致の三人を合祀したものであった。",
              "citation": {
                "source": "火傷した神様",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "来宮様は、お酒が好きで、酒を飲んで、寝ておりますと、火事になって、火が華表の傍まで燃えて来ても眼が覚めんものですから、鳥が来て起してくれましたが、起きられないで、火傷をしましたから、それで、暮れの十七日の夜の十二時から、むこう一週間、酒を飲まんことになっております」　と笑い笑い云った。",
              "citation": {
                "source": "火傷した神様",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の先祖もこの明神に華表を寄進したということが家の記録に残っているから、江戸時代までも相当に尊崇されていたらしい。",
              "citation": {
                "source": "こま犬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二疋とも千余年を経た妖獣であったが、晋の司空張華の博学多才であることを知って、それをへこますつもりで、少年書生に化けて、馬に乗って出て往こうとすると、華表神が呼び止めて、「君達はどこへ往くのか」　と聞いた。",
              "citation": {
                "source": "狐と狸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "華表神とは墓の前にある鳥居の神である。",
              "citation": {
                "source": "狐と狸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸は華表神の問いに答えて、「司空の張華と、議論しに往くところだ」　と言った。",
              "citation": {
                "source": "狐と狸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると華表木の精が、「張司空は才人であるから、二人が命を失うばかしでなく、その禍が俺たちにもかかってくる、どうかやめてくれ」　と言ったが、狸と狐は聞かずに出かけて往った。",
              "citation": {
                "source": "狐と狸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷孔章が、「そんな神木がどこにあるか」　と言うと、張華は、「燕の恵王の塚の前の華表木が千年を経ているということだ」　と言って、使をやってその木を取らした。",
              "citation": {
                "source": "狐と狸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "使は、「張司空の処から華表木を取りにきた」　と言った。",
              "citation": {
                "source": "狐と狸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで使の者は華表木を伐ってみると、木の中から血が流れた。",
              "citation": {
                "source": "狐と狸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄手の軍が、こんな朱敗を重ねてぐずぐずしている間に、幸村は軍を勝曼院の前から石之華表の西迄三隊に備え、旗馬印を竜粧に押立てていた。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "華表のしたに風船玉売の老婆がいた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "広巳は見むきもしないで華表を潜った。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へい」　広巳はそうしてお辞儀をするなり、体をかえして正面の華表の方へ歩いた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "広巳は安心して華表を潜って往った。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "華表を潜りながら拝殿の方へ眼をやった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一の華表を潜ったところで、驕慢な長者は大きな声をだしました。",
              "citation": {
                "source": "宇賀長者物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　類は友だっていいますがね、此奴の方が華表かずが多いだけに、火の玉の奴ア脊負なげを食って、消壺へジュウー……へへへ、いい様じゃありませんか、お互です。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "神官等が石の華表を出て行つた後は暫くして人も散つて、華表の傍には大きな文字を表はした白木綿の幟旗が高く突つ立つてばさ／＼と鳴つて居た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかひょうひょうとしながら一匹狼の踏ん切りを腹にためた後藤富雄を兄貴分として、ソフトウエアの土岐泰之、ハードウエアの加藤明を核に配した日本電気の開発チームに、古川はＷＣＣＦで出会った人々に覚えたのと同様の近しさを感じるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
