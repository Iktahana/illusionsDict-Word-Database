          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "環境相は、国連気候変動会議で日本の立場を表明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "首相は、新しい環境相に経験豊富な人物を起用した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今朝のニュースで、環境相の定例記者会見が報じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "環境相の発言は、国内外で大きな注目を集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、来月のG7環境大臣会合で議長を務める環境相だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
