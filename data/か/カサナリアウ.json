[
  {
    "uuid": "e547b5ac-1753-5818-a2e3-94e8fb7f97e0",
    "entry": "重なり合う",
    "reading": {
      "primary": "かさなりあう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-自動詞"
      ],
