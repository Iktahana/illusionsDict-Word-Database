          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この場所には嘗て、壮大な城が建っていたらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "嘗ては人気を博したその歌手も、今ではあまりメディアに登場しない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "嘗て彼らは親友だったが、今は連絡も取っていない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "』」――「嘗て私は、橋の上を通りかゝつたとき、橋の上では人間が、みんなニヒリスチックになるものだと考へた、思つた。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼稚園のピクニックで来た時に、嘗てすべつてころんだ所も、そのまゝであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これは嘗て旅行の途立寄つた兵庫県は御影師範の記憶である。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "風はリボンを空に送り、私は嘗て陥落した海のことを　その浪のことを語らうと思ふ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば四つ目垣でも屋根でも芙蓉でも鷄頭でも、未だ嘗て此れで稍滿足だと思ふやうに描けた事は一度もないのだから、いくら描いてもそれはいつでも新しく、いつでもちがつた垣根や草木である。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、そこに鎮まる岳神も、嘗て姉の福慈の女神と共に、東国へ思い捨てたわが末の息子が成長したものであろうという予感は沁々とある。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て常陸の山に在って旅人から聞いた話の、八つの湖に女神の姿を待ち侘ぶ河神たちの姿も眼の前に見た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう間柄でありつつも、飽くまで臆病に飽くまで気の小さな両人は、嘗て一度も有意味に手などを採ったことはなかった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生犀星氏は嘗て私達の中谷孝雄の作品を評して、氏獨特の表現で、「第一流の打ち込み方」と云つた。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらのものは、嘗て我々の祖先たちのよき話相手であつたやうに、我々の不幸や喜びによく通じてゐます。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、その意味を説明する前に、私はこの一文の読者に、氏が嘗て批評に就いて有島生馬氏に与へた反駁文と、同じく嘗て書かれた氏の感想「芸術その他」とを想ひ起し、また氏が何故に自己の直接体験を取材化しないかを一寸考へてみて戴きたく思ふ。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗てボズさんと辨當を食べた事のある、平い岩まで來ると、流石に僕も疲れて了つた。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに迷うことは、嘗てなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きてゐるか、死んでゐるか、わからない――また、一體そんな娘を嘗て持つたことがあつたのかどうかも、時々には疑はしくなる、彼の娘なるものが、その不思議なとんとん、とんとん、といふ響のなかに不幸な生存を傳へて來るのであつた。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んでゐるどころか、嘗てそんな夫を持つてゐたといふそのことさへ、誰かに左う思ひ込まされてゐるばかりのことではないのか。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗てはわれわれに親しかつた古い歌ひ振りの詩を今日に於いて省みるならば、われわれはそれがもう全く讀めないものになつてゐるのに驚く。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北川冬彦は嘗て最も潔癖に日本産の文學をうけつけなかつた詩人である。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは空想と云はんよりは實感であり、實感であるよりは實感をあらはすための手段であり、――そしてそれは最後の段階に達して、手段そのものから嘗て一度も人間の頭腦に存在しなかつたやうな「實感」を呼び起す作品を形成する。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北川冬彦にも嘗て器物愛好があつた。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て衣絵さんが、婿君とこゝを通つて、鰻を試みたと言ふのを聞いて居たので、園は、自分好きではないが、御飯だけもと思つたのに、最う其は売切れた……「そら行け。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、魔の棲むべき岩窟を、嘗て女賊の隠れ家であつたと言ふのは惜い。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が嘗て住みし谷中の家の庭に一｜本の此樹ありき。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪が悪霊の単独の誘惑の結果であるという考えは、嘗て彼等に起った事が無かったのである。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまだ嘗て電信柱に啖い付くほど嬉しい眼に合った事がなかったから……。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りに拾い上げる時は何もかも一時だよ」と嘗て筆者に言った事がある。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実さんは嘗て、いろいろな人の芸風を評した後にコンナ事を言った事がある。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して相島は嘗て日記にフォックスの事を書いて「われは彼れを尊敬す。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「是れは僕が嘗て愛讀したんだが、此の外には一寸日本の本はないからまあ持つて行つて見給へ……こんなものでも病人にさはるといけないから、初めに君が讀んで見てくれ給へ。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て聞いた事のない不可解な、物凄い、奇異な言葉で山が語る。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の正面の壁に子供の小学校の霜降の服と、糊でビリビリの日覆をかけた小学帽とが掛かつてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
