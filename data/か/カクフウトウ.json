        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "A4サイズの書類を折らずに郵送するために、角形2号の角封筒を買いに行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "就職活動で履歴書を送る際は、清潔感のある白い角封筒を選ぶのがマナーとされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "結婚式の招待状が、美しい切手の貼られた上質な角封筒で届いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "但馬さんは、来る度毎に私を、こっそり廊下へ呼び出して、どうぞ、よろしく、ときまったように真面目に言ってお辞儀をし、白い角封筒を、私の帯の間につっ込んで下さるのでした。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、いつでも知らん顔をして居りますし、私だって、すぐその角封筒の中味を調べるような卑しい事は致しませんでした。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（帯の間から、白い角封筒を出し、歩いて野中教師の傍に寄り）先生、黙って、ね、何もおっしゃらずに、黙って、受け取って頂戴！",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "野中教師、菊代を二、三歩追いかけ、それから立ちどまり、引返して机の上の角封筒を取り上げ、上衣のポケットに入れて、少し考え、また取り出して封筒の中をしらべる。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（上衣の内ポケットから、白い角封筒を出し、節子の手もとにほうってやって）まだ、七、八百円は残っている筈だ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（節子）（角封筒のほうには目もくれず、黙ってうなだれている。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "節子、冷然と坐ったままでいたのであるが、ふと、膝元の白い角封筒に眼をとめ、取りあげて立ち、縁側に出てはきものを捜し、野中のサンダルをつっかけ、無言で皆のあとを追う。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "節子、無言で野中に寄り添い、あたりを見廻し、それから白い角封筒をそっと野中に差し出す。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "角封筒は月光を受けて、鋭く光る。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭をもたげると枕もとに、真白い角封筒が一通きちんと置かれてあった。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云って準之助氏は、自分用らしい白い角封筒を新子の前にさし出した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い角封筒で、航空便として軍事郵便である。",
              "citation": {
                "source": "くちなし",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水色角封筒の裏に、つぼみ、志野よりとしてある。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "加野はポケットから部厚い角封筒を出して、素早くゆき子の膝に置いた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　部屋へかえると食後の散薬を飲もうと、薬台の抽斗をあけた、その時、中に挟んであったのであろうか、パタンと音がして部厚い白の角封筒が落ちたのに気がついた。",
              "citation": {
                "source": "※の囁き",
                "author": "――肺病の唄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴郎も早く御自分の荷物を出して下さい」といって、分厚な角封筒を渡した。",
              "citation": {
                "source": "日蔭の街",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは、どこへしまったかなあ」　黒川は、ポケットをさがしまわっていたが、やがてまっ白い角封筒を、ズボンのポケットからつまみだした。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それから四五日の後、閑枝は机の上に、再び差出人の署名のない、白い角封筒を見出した。",
              "citation": {
                "source": "仙人掌の花",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあくる日の夕方、閑枝がいつもの通り湖畔の散歩から帰って見ると白い角封筒が机の上に置かれてあった。",
              "citation": {
                "source": "仙人掌の花",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清さんはちらとわたくしの顔を仰ぎ見て、懐から真白な角封筒を取り出しました。",
              "citation": {
                "source": "死因の疑問",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那」郵吉は、大きい鞄の中から、出しにくそうに、白い角封筒を取り出した。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には一通の角封筒と、その中から引出したらしい用箋とが入っていた。",
              "citation": {
                "source": "地中魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくどこかへ行つてゐたと思ふと、やがて帰つて来て、手にもつた一通の封書、その封は切つてあつて、すこし皺のよつた角封筒であるが、それを妻の方に差し出した。",
              "citation": {
                "source": "ある夫婦の歴史",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "手提袋から大形の角封筒を出す。",
              "citation": {
                "source": "軌道（黙劇）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は例の角封筒を出した。",
              "citation": {
                "source": "女",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の女が階下へ降りて来た時、格子戸にその白い角封筒がはさまれてあった。",
              "citation": {
                "source": "女",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は朗かに笑うと、角封筒を机の上にまっすぐに置いて出て行った。",
              "citation": {
                "source": "女",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は角封筒を出し、子供の母親へ渡してくれとたのんだ。",
              "citation": {
                "source": "女",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えゝ、毎週一回は必ず」「今度は何日」「明後日」「お渡し願います」　女はハンドバッグのとめがねをならして角封筒をとりだし、白い布で体全体を掩っているモルモットのような感じのその女の子にそれを手渡した。",
              "citation": {
                "source": "女",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
