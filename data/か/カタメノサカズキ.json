    "definitions": [
      {
        "index": 1,
        "gloss": "cup of sake used to drink to the establishment of a partnership, commitment to marriage, etc.",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
