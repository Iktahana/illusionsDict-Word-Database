        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はまだ学生気分の抜けない、どこか角張った話し方をする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "初めての商談で緊張し、挨拶さえも角張ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もっとリラックスして！そんなに角張らなくても大丈夫だよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
