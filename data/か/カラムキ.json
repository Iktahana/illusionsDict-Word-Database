    "definitions": [
      {
        "index": 1,
        "gloss": "shelling (e.g. of eggs, nuts, crabs and such)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
