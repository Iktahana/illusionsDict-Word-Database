        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ピーナッツの殻むきは、ビールを飲みながらやると楽しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このカニは殻むきが大変だけど、その分美味しいんだよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゆで卵の殻むきが苦手で、いつもボロボロにしてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "工場では、効率的な殻むき機械が導入されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "顔を血だらけにして泥まみれになった佐藤の跡から仁右衛門が這入って来るのを見ると、佐藤の妻は訳を聞く事もせずにがたがた震える歯を噛み合せて猿のように唇の間からむき出しながら仁右衛門の前に立ちはだかって、飛び出しそうな怒りの眼で睨みつけた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽器の中のマニラ人の黒い皮膚からむき出る歯。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二七年にかかれた「嘲る」という短篇は、大正末から昭和のはじめ頃のアナーキストの群の生活感情、ものの考えかたを、そのうちに息づいた女の側からむき出しに描いていて、これまでの婦人作家の文学にない世界を展開した。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛ば立った皮からむき出た牛蒡の種の表面には、蒔絵に似た模様が巧緻な雲形の線を入れ、蝋燭豆のとろりと白い肌の傍に、隠元が黒黒とした光沢で並んでいる。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "訶和郎を抱き上げようとして身を蹲めた奴隷は、足音を聞いて背後を向くと、反絵の唇からむき出た白い歯並が怒気を含んで迫って来た。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うちの先生、本にないのばア教へてむつかしいけエなう」　何時もの癖のやうに八ツ口からむき出しの両腕を出して、「おほけに」と由のひざの荷物を持つて立ち上ります。",
              "citation": {
                "source": "小さい花",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、裸に近い自分に赤面してしまって、とにかく、着物もないのですからむき出しのひざ小僧へ手拭をあてて縁側へ坐って挨拶しました。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒を飲むと、肌に赤味がさして、白い半袖からむき出した、すくすくとのびた腕が、ゆき子の眼をとらへる。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒で痛みを消すってやつさ」　いかさま、お吉の丹前であろう、紅裏のついた丹前を、身長は並み、肉附きは以下――中肉以下に痩せていて、精悍さを想わせる体の上へ、肩からかけて羽織っていたが、それからむき出した左足に、白衣が二ところばかり巻いてあった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この前来た時には短いスカートからむき出しの両足を随分蚊に刺されたが、今はその蚊もいなくなった。",
              "citation": {
                "source": "或夜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "この前來た時には短いスカートからむき出しの兩足を隨分蚊に刺されたが、今はその蚊もゐなくなつた。",
              "citation": {
                "source": "或夜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかと土と汗と雨とで、がばがばになった服、それにシラミがうごめき、ノミが跳び、やぶれからむき出した皮膚にはぼりぼり引っかいた爪あとに血がにじみ、いちめんのカイセンがさ。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "千円」　長平はポケットからむきだしの札束をつかみだして、二千円やった。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の両がわのしきりやさくの向こうから、馬の顔や、角のはえた顔や、耳の長い顔や、鼻のかわりにしっぽがはえ、口からむきだしの長い二本の骨がつき出ている、ふとった、ばかでかい顔など、いろいろなおそろしい顔が、こっちをのぞいていたのである。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからむきになって、たちまちぺろりと焼菓子をたいらげたんだ。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "松の枝かげを失い、楓の下枝からむき出された燈籠に、納りをつけようと、無造作に青木が植えこまれていた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋愛という言葉は知っていたが、その実体はたとえばこういうことなのかと、彼は芽生えたばかりの実体と、心のなかで正面からむき合ってみた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "取りだしたのは藁苞である、グイとしごいて、苞からむきだされたのは、蝋色鞘の滑らかな大小。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
