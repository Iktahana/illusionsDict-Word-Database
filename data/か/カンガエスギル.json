    "definitions": [
      {
        "index": 1,
        "gloss": "to think too much",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "選択肢が多すぎると、かえって考えすぎてしまって決められない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "失敗を恐れて考えすぎると、何も行動できなくなってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、些細なことでも考えすぎてしまう性格のようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "あんまり考えすぎるから、事がむずかしくなるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり物事を簡単に考えすぎるやり方だと思います。",
              "citation": {
                "source": "これでは囚人扱い",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕なんか、飯も食える方だし、夜もよく眠りますよ」「少し考えすぎるんでしょうね」彼は続けて言った。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものごとを物的に考えすぎるな。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が考えすぎるにはワケがあった。",
              "citation": {
                "source": "握った手",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えすぎるのはいけないことだ、とむろん彼も心得ていた。",
              "citation": {
                "source": "握った手",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもまた土地柄でそれだけ独特の土地風があって一概に甲乙はつけがたいが、日向の人々が自分たちの古墳群を過大に考えすぎるのにくらべて、群馬の人々が全然古墳なぞ念頭におかないのはおもしろい対照である。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察の旦那というものは、考えすぎるよ。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、現在の警察の取締りぶりには、酔っ払いの自業自得を認めるの余り、山賊の商法の方を合理的に考えすぎる傾きがあるようだ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "「物事を余り真面目に考えすぎるからいけないんだ。",
              "citation": {
                "source": "球突場の一隅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り考えすぎるからいけないんだとは知っていますけれど、隆ちゃんが始終暗い影を背負ってるように思われて仕方ありません。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "カラスキーは、ふふ、と小刻みに笑ってから、まるで自分のことのような親切な口調で、「先生としては、ここの空気に同化しようとして、一所懸命なすったのでしょうが、こんな場所で、あんな出鱈目をいうのは、すこし無考えすぎるようです。",
              "citation": {
                "source": "犂氏の友情",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あんまりものを深く考えすぎるんで。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう日本の民衆を以て、そのまま文学の民衆性の問題に役立てようというのは、物ごとをあまりに楽観することであり、容易に考えすぎることだ。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺達は色々な余計なことを考えすぎるようだ。",
              "citation": {
                "source": "小さな部屋",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事も深く考えすぎることは要らぬぞ。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手の生活や、気持ちを、あまり考えすぎるせいかもしれないけど、私のような、身も心も打ちこんでしまう性格では、大決心しなければ言えない。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            },
            {
              "text": "男親は、あまりに、多方面から考えすぎる。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
