[
  {
    "uuid": "f6ca7316-536a-5713-bf72-b8255556a881",
    "entry": "カビ臭い",
    "reading": {
      "primary": "かびくさい",
      "alternatives": [
        "カビくさい"
      ],
      "is_heteronym": false
    },
    "grammar": {
