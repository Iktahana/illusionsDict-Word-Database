      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "smelling of mold",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "地下室の空気がよどんでいて、なんだかカビ臭い匂いがする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年開けていなかった押し入れから、カビ臭い布団を取り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古着屋さんに入ると、独特のカビ臭いような匂いがする時がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」　私はさもさも物臭さうにふところ手のまゝ脊骨を棒のやうに突つ張らせてぶつ／＼いつてゐたが、銑太郎は物をも言はず先に立つて、夫々の手に提電灯の用意をすると、家内の者の眼を盗みながらカビ臭い土蔵脇の忍口から、颯つとばかりに荒波の中へ跳び込むやうに身を交して走り出た。",
              "citation": {
                "source": "冬物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりやア文学青年なんていふ代物は、十中の八九までそんなものさ、フツフツフ……あゝカビ臭い、カビ臭い。",
              "citation": {
                "source": "蝉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "揚げ蓋の下が、窖への、下り口になっているので、カビ臭い、しめっぽい匂いがムウと来る。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八、此處が臭いよ、開けて見な」「へエー」　八五郎の金剛力を出す迄もなく、空屋の戸はわけもなく開いて、中からはカビ臭い空氣――とは似もつかぬ、爽やかなものを感じさせる、明るさと華やかさが匂ふのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "閉された庭",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく、浩一郎｜母子の降りて来た道から、葉巻の匂いがプンと先ぶれをして来ました、冷たいカビ臭い地下の密室に、上等の葉巻の匂い、何んというそれは不思議な取合せでしょう？",
              "citation": {
                "source": "古銭の謎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムツとカビ臭い風が吹き上がつて、床下には何やら散らばつた物があるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "小判の瓶",
                "note": "青空文庫"
              }
            },
            {
              "text": "香椎六郎が先頭、次は麗子、殿は加奈子、カビ臭い風が顔を撫でて、その気味の悪さというものはありませんが、今はもう三人とも緊張し切って、ろくに口をきく者もありません。",
              "citation": {
                "source": "向日葵の眼",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段を降りたら、マッチが使えるからな」　慎重に階段を下りて、じめじめしたカビ臭い地下室へ行き、それから反対側の階段を上り、そこでガードンがマッチをつけた。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "カビ臭い汚いテイラの部屋から出た。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠い魏朝にあった故事などは早やカビ臭いわ。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、かびくさい坑道を別な道から足音かるくやって来た。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かびくさい卵と、鶏冠の焼いたのが一とうのごちそうでした。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下といえば、正吉の地下鉄の中のかびくさいにおいを思い出す。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間的なかびくさい臭ひがした。",
              "citation": {
                "source": "雨",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこの綱わたりは、あっちにもある、こっちにもあるというかびくさい綱わたりとはちがい、すこぶる奇想天外、大々奇抜なる綱わたりでございまする。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かびくさい室　その動くものは、たしかに大きな動力で動いているらしかった。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かびくさい部屋をいくつか通った。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてぷーんと、かびくさい匂いが鼻をうった。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす暗い部屋、ぷーンとかびくさい。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下といえば、正吉は地下鉄の中のかびくさいにおいを思い出す。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら考古学者が欲しいというかもしれません」「ははあ、考古学者ですかね」　僕は急に自分がかびくさい人間になってしまったような気がした。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぷうんとかびくさい。",
              "citation": {
                "source": "骸骨館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "トンネルの道は、自然に下り坂になって、今歩いているところは既に地下へもぐってしまったらしく、ぷーンとかびくさい。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、おれの手ににぎらせてくれ」　　　つのる蛇毒　蛇毒にやられて、かびくさい倉庫の床に、気息奄々のハルクほど、みじめな者はなかった。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくあけたこともなかったとみえ、中からはぷーんとかびくさい臭がただよってきました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎいっと大きな戸をあけると、かびくさいつめたい臭いがします。",
              "citation": {
                "source": "落ちてゆく世界",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時をまわっており、埃と湿気と布地の中のかびくさい臭いとの中で、品物をまとめたり片附けたり、藁くずを一ぱいかぶりながら働いていた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは、テーブルにすわって、なにやらすべすべしてしおからい、水っぽくてかびくさいものを食べ始める。",
              "citation": {
                "source": "かき",
                "author": "УСТРИЦЫ",
                "note": "青空文庫"
              }
            },
            {
              "text": "つらつら悲劇のもとをもとむれば、チッポケなかびくさい系図にとらわれた氏族の罰さ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その九　覆面屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "くる日も来る日も、お艶にはかびくさい囚われの朝夕があるだけ――しかしお艶の起居を看視するのはおさよの役だったので、おさよは誰にも疑われずに今のようにそっとお艶の部屋へ忍んでは話しこんで慰めることも、好きな食物も運び得たのだったが母と娘……とはまだ屋敷じゅうひとりとして見ぬいたものはない。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
