        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の冗談は、いつもカビ臭くて誰も笑わないんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「そのジェスチャー、ちょっとカビ臭いんじゃない？」と友人に指摘された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "いまだに電報を使うなんて、カビ臭い考え方だな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
