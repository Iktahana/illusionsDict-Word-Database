[
  {
    "uuid": "9c7338c2-8c02-5188-a031-911115449410",
    "entry": "片っぽ",
    "reading": {
      "primary": "かたっぽ",
      "alternatives": [
        "かたっぽう"
      ],
      "is_heteronym": true
    },
    "grammar": {
