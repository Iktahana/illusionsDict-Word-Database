        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お気に入りのピアスの片っぽを失くしてしまい、一日中ショックで落ち込んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "コンタクトレンズの片っぽを洗面台に落として、床を這いつくばって探している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「靴の片っぽが脱げちゃった！」と、幼い子供が道端で泣きべそをかいている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
