    "definitions": [
      {
        "index": 1,
        "gloss": "poor village",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この村の人は猿なり冬木立　田も畠も凍りついた冬枯れの貧しい寒村。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠治の墓は、荒寥たる寒村の路傍にあり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの北海岸の某寒村に、いまもなほ、太郎をまつつた神社があるとかいふ話を聞いた事がある。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは山のなかの寒村で、村は百姓と木樵で、養蚕などもしていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮靄寒村をこむる夕方、片品川の水声を聞きつつ淀屋というへ泊す。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "本當に奇妙な事だと思つて居ると、或日の事、ウルピノ山中とて、子ープルスの街からは餘程離れた寒村の、浮世の外の尼寺から、一通の書状が屆きました、疑もなき亞尼の手跡で、はじめて仔細が分りましたよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドッコイ、ドッコイ、ドッコイショと、爺様のような懸声をしながら漸く河を渡り、やがて町付という寒村に来掛かれば、もう時刻は正午に近い。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一八）焼酎の御馳走　一行は多少ヤケ気味に、それよりはブラリブラリと牛の歩み宜しく、またもや一里あまり進んで、南方村という寒村に来掛かれば、路傍の開放されたる一軒家では、褌一本の村の爺さん達四、五人｜集って、頻りに白馬か何か飲んでいる。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この度飛騨の国の山中、一小寒村の郵便局に電信の技手となって赴任する第一の午前。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕭条たる寒村の秋のゆうべ、不幸なる我子の墓前に立って、一代の女将軍が月下に泣いた姿を想いやると、これもまた画くべく歌うべき悲劇であるように思われた。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは油屋が一軒、豆腐屋が一軒、機織工七分に農民が三分という、物質には恵まれない寒村で、一生ほとんど給銀もなしに酷使われる若い男女は、日頃ひそかに二銭三銭と貯蓄して、春秋二期の恒例になっている、この村脱けに参加し、他国へ移動するのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "国運を賭しての大戦争のさいちゆうでも、本州の北端の寒村で、このやうに明るい不思議な大宴会が催されて居る。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し又僻地寒村より都會に出でて、美饌嘉肴を得るに至つたと云ふが如き場合にも、其の失つた良状態が得た所よりも少い時は、同じく其の人の身體状態が良好になる事は、但馬の牛が神戸附近に出でて、美食を得る爲に、俄に毛色も美しくなり、肉置も十分に發達するが如くで有らう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "峠の頂上から、バスで三十分程ゆられて峠の麓、河口湖畔の、河口村といふ文字通りの寒村にたどり着くのであるが、その河口村の郵便局に、私宛の郵便物が留め置かれて、私は三日に一度くらゐの割で、その郵便物を受け取りに出かけなければならない。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "してみると、いまから三十年ちかく前に、日本の本州の北端の寒村の一童児にまで浸潤していた思想と、いまのこの昭和二十一年の新聞雑誌に於いて称えられている「新思想」と、あまり違っていないのではないかと思われる。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上って見ると、沖から見た通りの、それは荒涼たる寒村であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "部落といっても全くの寒村で、急勾配の廂の長い丸太式の家が二戸か三戸か、ほんの飛び飛びに並んでいるきりであった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今、オホーツク海を北へ北へ、二百六十浬の彼方、ツンドラ地帯は敷香の寒村に向って直航中の高麗丸の船上にある。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "上陸して見ると、敷香はかなりの寒村であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "福沢諭吉氏が「西洋事情」は、寒村｜僻地まで行き渡りたりと聞けり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それがいわゆる雲朔に近い荒涼たる寒村であることは容易に想像される。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "向方の紫山巒※闇黒の裡、僅に其所在を認む可く、其下水田を隔てゝ寒村あり。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "加ふる今日過ぎし所、寒村のうちなほ悉く大に整ふをみる。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "澁は鐵泉の湧く所、浴舍の結構頗る見る可く、旅舍の整ふもの、豪も寒村辟邑に似ざるなり。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方の寒村にだって此の位の家は幾らでもある。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな寒村でも、寺の塔だけは高くそびえているのであった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして鎌倉を去り伊豆半島の先の或極めての寒村に一軒の空家を借りた。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "千曲川の上流長さ數里にわたつた寒村を川上村と云つた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "草鞋の話旅の話",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
