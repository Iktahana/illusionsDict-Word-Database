    "definitions": [
      {
        "index": 1,
        "gloss": "confectioner",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "街角にあるその小さな菓子店は、地元の人々に愛される隠れた名店だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、開店祝いに華やかなデコレーションが施された菓子店をデザインした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この辺で一番美味しいシュークリームが買える菓子店はどこ？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "たべものに掛けては、中華亭の娘が運ぶ新栗のきんとんから、町内の車夫が内職の駄菓子店の鐵砲玉まで、趣を解しないでは置かない方だから、遲い朝御飯に茶漬けで、さら／＼。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮の二十日頃になると、玩具屋駄菓子店等までが殆ど臨時の紙鳶屋に化けるのみか、元園町の角には市商人のような小屋掛の紙鳶屋が出来た。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "剰に、働盛りの若主人が、十年近く労症を煩つた末に死んで了つたので、多くもなかつた所有地も大方人手に渡り、仕方なしに、村の小児相手の駄菓子店を開いたといふ仕末で、もう其頃――私の稚かつた頃――は、誰も士族扱ひをしなかつた。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」餅菓子店の店にツンと濟ましてる婦人なり。",
              "citation": {
                "source": "神樂坂七不思議",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の頃は駄菓子店も滅多に無かつたので此れ丈のことがお品には餘程の心竭しであつたのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤に煎餅を食わせて居る太十の姿がよく村の駄菓子店に見えた。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼女のその兄であるといふ男と、洋菓子店で偶然に知り合つたのです、或る日私は若い友人とその店のテーブルを囲んで、熱心に話しこんでゐました、話が『自然科学』にふれたとき、一隅から私に声をかけた男があつたのです。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はとうとう激論になりました、洋菓子店を見渡すと、最初興味深さうに二人の話をきいてゐた三人組の私立大学生が、議論の激しさにあきれて店をとびだしてそこに居なくなつてゐた程です。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "記者の勘定するところに依ると、現在では十三軒の果物、菓子店があって、お化粧をつけた女の姿がチラホラしているだけである。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮れの二十日頃になると、玩具屋駄菓子店などまでがほとんど臨時の紙鳶屋に化けるのみか、元園町の角には市商人のような小屋掛けの紙鳶屋が出来た。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "道後から帰つてくると、驚いたことには、お寺への参道に――庵ちかく――露店が数々出てゐた、駄菓子店、おでん店！",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雌蝶」よりはいくらか粗くて靭い筆致で、久江という「細かい縞の羽織に襟のかからない着物をグッと首に巻きつけて着て、帯の間からチラチラくさりの見えるだけが飾りの束髪頭」の若い女性が、義兄の菓子店へ遊びに来て、帳場で本を読みながら店番をしてやったりしている。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "□安田｜皐月さんが白山前町三八に水菓子店を開業なさいました。",
              "citation": {
                "source": "編輯室より（一九一四年一一月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠行の子孫は、今川橋の南を東に折れた本白銀町四丁目に菓子店を開いてゐて、江戸城に菓子を調進した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞志屋の菓子店は新石町にあつて、そこに壽阿彌の五郎作は住んでゐた。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "新石町は諸書に見えてゐる眞志屋の菓子店のあつた街である。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから日輪寺方へ移る時、壽阿彌は菓子店を姪に讓つたのだらう、其時昔の我店が「愚姪方」になつたのだらうと云ふ推測は出て來るのである。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "菓子店を出した時、大名よりは増屋だと云ふ意で屋號を附けたと聞いてゐます」と、刀自は云ふ。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは壽阿彌の手紙を讀んで、壽阿彌は姪に菓子店を讓つて出家したらしいと推測し、又師岡未亡人の言に據つて、此姪を山崎某であらうと推測した。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞志屋の自立してゐた間の菓子店は、既に屡云つたやうに新石町、金澤の店は本石町二丁目西角であつた。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "青柳という菓子店は古くから覚えている。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ昼には間のある事とて、露店商人も数える程しかなく、ホンの子供対手の駄菓子店や安い玩具を売る店などが、老婆や中年のおかみさんによって、ションボリと番をせられているだけで、怪しげな薬を売ったり、秘術めいた薄ぺらな本などを売りつける香具師達の姿は一つも見当らなかった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本警備区域内では、北四川路の森永菓子店のすぐ近くに難民区があるのには驚かれる。",
              "citation": {
                "source": "上海の渋面",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隣はカバン製造業、洋品店、玩具問屋、煙草店、菓子店というような順序に並んでおり、路地に入ってみると、元庭であったところにもぎっしり家が建っており、そのあたりの住人も大体替ってしまっていた。",
              "citation": {
                "source": "三筋町界隈",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本を口に銜えて、燐寸の火を近づけながら窓硝子の上に注目すると、向いの洋菓子店の明るい飾窓がうつっていた。",
              "citation": {
                "source": "疑問の金塊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "八幡横手の阪道から、宮裏の雑木林をかけて、安小間物屋、鮨屋、柿蜜柑屋、大福駄菓子店、おでん店、ずらりと並んで、カンテラやランプの油煙を真黒に立てゝ、人声がや／＼噪いで居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は都内の菓子店がすつかり復興して、ありし日の如く和洋とりどりの菓子を売つてゐるが、これを買ふのは昔のやうに簡単にはゆかない。",
              "citation": {
                "source": "買食ひ",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤村は大学の横手にあるよい菓子店です。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝のうちは、女房が洗濯を終るまで子守しなければならぬので、駄菓子店である生家の軒先の床机を出して、懐中の三番めの女の児をヨイヨイたたきながら、弱い冬の陽だまりでじッとしている習慣だった。",
              "citation": {
                "source": "冬枯れ",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "「駄目だよ、陽氣のせゐだよ、誰だかはどうかしてんだからなア、おいとさん」　又さつきの少し離れた方から聲がした。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
