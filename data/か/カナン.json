[
  {
    "uuid": "1c57a99a-fe12-59d9-a1c5-ebd9706ef54f",
    "entry": "火難",
    "reading": {
      "primary": "かなん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
