[
  {
    "uuid": "8be87dfd-042b-5e6a-aba9-91a7262647a0",
    "entry": "感激",
    "reading": {
      "primary": "かんげき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
