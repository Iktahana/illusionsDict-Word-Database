[
  {
    "uuid": "47314951-3da4-5d60-a2a8-1bf298d338e9",
    "entry": "各員",
    "reading": {
      "primary": "かくいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "副詞"
      ],
