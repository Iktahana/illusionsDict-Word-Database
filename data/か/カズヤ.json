        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "三十三間堂の通し矢で使われるのは、大量生産された数矢だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "戦国時代の合戦では、兵士たちが数矢を雨のように降らせて敵の進軍を食い止めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この矢は装飾が施されているから、実戦用の数矢ではなく、儀式用だろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "深川数矢町で明治五年に取り払われた三十三間堂を、実地に見ている人はすでに少なかった。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然は地にみつ光なりや今日はめぐりて山に入れど見よかの大空姿｜優に夜の守月姫宮をいでて唱ふをきかずや人の子等は。",
              "citation": {
                "source": "感謝",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも昼の間は、誰も気付かずやっと夕刻、私が顔を見ようと出て行きましたらこのていたらくでございまする。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君聞かずや、むかし彌次郎と喜多八が、さもしい旅に、今くひし蕎麥は富士ほど山盛にすこし心も浮島がはら。",
              "citation": {
                "source": "九九九會小記",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この声を聞かずや、無限の感激は迸しつて迅雷の如く四大を響動せんとす。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一たび偕に嚢家（博奕場）に往かずや、いかなる境界をも詩人は知らざるべからずとは、吾友フエデリゴの曾て云ひしところなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何はせむと困りしが、宮崎氏、裏山行は明日にのばして、今日は共に金洞に赴かずやといふに、さらばとて、共にゆく。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞村、晩食しにゆかずやといふまゝに、諾してゆけば、われを不忍池畔の一酒樓に導きぬ。",
              "citation": {
                "source": "月の隅田川",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "『番頭の中、誰か行かずや』と誘へど、『いづれも都合惡し』といふ。",
              "citation": {
                "source": "沖の小島",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "日野驛にゆくも、立川驛にゆくも、距離はほゞ相同じ、鐵橋を渡りて、立川驛まで行かずやと云へば、過日の新聞に、工夫長が箱根の鐵橋を渡り居りしに、不意に汽車の來たるに逢ひ、周章てて、レールにぶら下り、指を斷たれて、溪流に落ちて死したりとの記事ありき。",
              "citation": {
                "source": "多摩川冒險記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "穩臥靜養して行かずやと云へば、宿屋よりは自家がとて、まだ子供氣の家が戀しく、大雨を衝き、尻に帆かけて、逃ぐるが如くに立ち出づ。",
              "citation": {
                "source": "北條より一ノ宮へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ともつかずやれば成績は上がらず、かえって邪魔をされ、邪魔されて師匠の没後の家のためにならぬにかかわらず、のんべんだらりで附いているはさらに嫌なり。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "身を引いた時のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だつて世間の女は一々流行を追うて拙らないものにずゐぶん手かずや金をかけて着てるんだもの。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかずやありけむ、二十日の夜の月出づるまでぞありける。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶あかずやあらむ、またかくなむ、「見し人の松のちとせにみましかばとほくかなしきわかれせましや」。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞かずや春の山ぶみに、林の奧ゆ、伐木の丁々として山更になほも幽なる山彦を。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫の道學先生の説く所を聞かずや、何ぞ其の拘々として缺々たる。",
              "citation": {
                "source": "美的生活を論ず",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "又｜夫の學究先生の訓ふる所を聞かずや、何ぞ其の迂遠にして吾等の生活と相關せざることの甚しき。",
              "citation": {
                "source": "美的生活を論ず",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　時々、皿におかずやら、一人前のおはちに五もく飯やらを、子供が好意らしく屆けて來ることがあるが、お鳥は口に入れたことがない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "その目には、広大無限の慈悲、輝かずや、一切衆生を済度せむとの御情、こもらずや。",
              "citation": {
                "source": "鎌倉大仏論",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "（勿論三代集以後には静心の意に用ゐてゐるけれど）友則の……春がすみ立ちかくすらん山の桜をことならばさかずやはあらぬ桜花みるわれさへにしづこゝろなし　といふ歌を、遠鏡に、見テヰルコチマデガ気ガソハ／＼スルハイと解してあるけれど、さうではなくて、「ことならば」がわが身へもひゞいてゐて、桜が散る。",
              "citation": {
                "source": "用言の発展",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜はひとやのやみならで今宵月照る戀の園、やすらひの戸もかげやけど、きかずやあはれ、　　　『君を戀ふ』と。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "さめよ種子、うるほひは充つ、さやかなる音をば聽かずや、流れよる命の小川涓滴のみなもといでぬ。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴かずや、過ぎゆく時劫のすゝみをして声あらしむるは、大海の限りなき調とぞ言ふなる。",
              "citation": {
                "source": "抒情詩に就て",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し又、一方「死馬の骨を買ひし者あるを聞かずや」といきり立つた清少納言と同様「我も昔は」とも言ふべき形を、含んでゐるとも見える。",
              "citation": {
                "source": "鸚鵡小町",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様こそ、卑怯なことや悪いことをかずかずやっているじゃないか。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "篠子　　（女中に）かずや、お前もお手伝して……。",
              "citation": {
                "source": "ママ先生とその夫",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞かずや昔、イリオンに流血破滅を加ふべく、　350アルゴス衆軍一齊にその船舶に乘りし時、神威無上のクロニオーン、我の願を納受しつ、＊右手に雷光閃かし、善き前兆を現はしき。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダナオイ族を思ふよりわれの憂怖は甚だし、心は安きことを得ず、搖蕩しつつ胸の中跳りてやまず、堅甲を帶ぶるわが四肢皆震ふ、　95君亦睡取るを得ず、心に思ふことあらば、こゝより去りて衞軍に共に行かずや？",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "その栗鼠は不思議と、余り遠くへ行かずやっぱり眼をパチクリさせて少年を見ています。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
