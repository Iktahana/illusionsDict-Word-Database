[
  {
    "uuid": "c6bb367e-1404-5cce-a4b0-7b5418b34c5b",
    "entry": "篝",
    "reading": {
      "primary": "かがり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
