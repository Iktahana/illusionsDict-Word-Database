    "definitions": [
      {
        "index": 1,
        "gloss": "to harden",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "コンクリートは打設後、数時間で完全に固まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゼラチンを入れたジュースが、冷蔵庫でしっかりと固まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "熱した金属が冷めると、やがて硬く固まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "皿鍋にこの血の汁を移し家鴨の薄身をいれて掻き廻しながら煮詰めると汁は肉の周囲にチョコレート色に淡く固まる。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と今更ながら畚を覗くと、冷い磯の香がして、ざらざらと隅に固まるものあり、方丈記に曰く、ごうなは小さき貝を好む。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "書生芝居が歌舞伎の本城を奪いしとて、好劇家は驚異の眼をみはり、書生芝居の地盤もここに漸く固まる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「モシモシ……」　私は全身の骨が一つ一つ氷のように冷え固まるのを感じた。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想とか主義とか何とか云ふものが固まるのは物事を一方に整理したのである。",
              "citation": {
                "source": "混沌",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれから身體が固まるやうに思ひながら、疎い白髮の梳られるのをも、微に感覺を有した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "匂ひが強いので諸虫の毒を消し、眼を明らかにし智を鋭くし、女が食ふと操が固まるというた。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、世間を思切って利慾を捨てた椿岳は、猿が木から木へと木の実を捜して飛んで行くように、金儲けから金儲けへと慾一方で固まるのを欲しなかった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「固まると、いかん。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母の心事を察するに、叔母はお勢の身の固まるのを楽みにしていたに相違ない。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "んだからよ、みんなして、貧乏人同士みんなして一つに固まるのよ。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏人はみんなして固まるほかに手はねえってことを。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがもう一層固まると、こうであったが変じて、かくあらねばならぬとまで高じて参ります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "省みて、供養をうける資格がない（応供に値するものは阿羅漢以上である）、拒まれるのが当然である、これだけの諦観を持して行乞すれば、行乞が修行となる、忍辱は仏弟子たるものゝ守らなければならない道である、踏みつけられて土は固まるのだ、うたれたゝかれて人間はできあがる。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "繁栄策もいろいろ考えられているようだが、古本屋さんが各店分立で、町を固めているのもよしあし、合同して図書文房具中心の百貨店にでも固まる方が買う方も便利だが、これはできない相談かもしれない。",
              "citation": {
                "source": "神田界隈",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この左翼の勢揃いの固まるにつれ、右翼の陣形もますます練り固まって来たという噂が久慈たちの耳にももれ伝った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ母のことだけは、あたくしの決心が固まれば固まるほど、暫くは母も意を和げてくれなさそうに思われますので、さぞあなたに御不快をお与えすることと存じまして、それだけは心配でございます。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い藥とみえて、散藥は落雁のやうに舌に固まる。",
              "citation": {
                "source": "屋久島紀行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "林房雄の「青年」などは、素朴な思念に救われているが、あれがもっと年をとり、もっと凝り固まると――云いかえれば、詩が観念になると、案外、象皮病にかかりそうな恐れがないでもない。",
              "citation": {
                "source": "傍人の言",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族制度の結合が固まるほど社会と極端に分離する性質のものであることは高田氏のお説の通りだと思います。",
              "citation": {
                "source": "激動の中を行く",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは富士男の命令は忠実にまもった、雨が降って地が固まるように、少年連盟は以前に倍した一｜致協力ですすんだ、四五日がすぎた、だが海蛇などの悪漢の消息はようとしてわからない、黒雲が頭をおしつけるように、一同は不安と恐怖のあいだに、心がおちつかない。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "張君は、それができるんだろう」「そういわれると、僕にも思いあたることがあるよ、ときによると、僕のたましいはピンポンの球ぐらいに固まることがあるよ」　と、張が、真面目な顔付で膝をのりだした。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸の固まる時分に一番菊五郎の相手もしたし、芸に触れた為である。",
              "citation": {
                "source": "役者の一生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のホンザーは白いのですがチョコレートのかかったのも色々ありますね」お登和嬢「ハイ、チョコレートのホンザーはチョコレート一斤に砂糖を九十目水を大匙五杯入れて四十分間弱い火で煮ますが水の中へ滴らしてみて餡のように固まるのが度合です。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し突起の出来た所は早く冷えるから先に固まる。",
              "citation": {
                "source": "寅彦夏話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそこへ余計に砂糖が附く、それで益々そこが突起する、従って余計に冷えてまた固まるという工合にして角が伸びて来るんじゃないかという気がする。",
              "citation": {
                "source": "寅彦夏話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしの身も、まず固まる。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "橇には、五人ずつ、或は六人ずつ塒にかたまる鶏のように防寒服の毛で寒い隙間を埋めて乗りこんだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「え、どつこい、どつこい」「そおらああ……」　と、ちやうど唄の應答の半であつた踊の人々は驚いて踊を休めてかたまる。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす暗い部屋のなかに三人の女が、かたまるやうによりあつまってゐた。",
              "citation": {
                "source": "かなしみの日より",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to become firm",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
