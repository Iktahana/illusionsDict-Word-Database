        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "どっちの服にしようかな…うーん、こっちの片方だけ試着してみようかな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この二つの案のうち、片方だけ採用するのは難しい。両方ともメリットがあるから。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の話を聞いていると、どうも片方の意見に偏っている気がするんだよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このセット、片方だけ壊れてしまった。修理できるかな？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
