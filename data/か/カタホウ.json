    "definitions": [
      {
        "index": 1,
        "gloss": "one side",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "イヤホンを片方だけなくしてしまい、買い直す羽目になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "靴下の片方だけが見つからず、出かけるのが遅れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "賛成と反対、意見はいつも片方に偏りがちだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プレゼンテーションの準備は片方だけ終わっている状態だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "枕につけた片方の耳の奥では、動脈の漲る音が高く明らかに鳴っている。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "比較的新しい方の例で自分の体験の記憶に残っているのは明治三十二年八月二十八日高知市を襲ったもので、学校、病院、劇場が多数倒壊し、市の東端｜吸江に架した長橋｜青柳橋が風の力で横倒しになり、旧城天守閣の頂上の片方の鯱が吹き飛んでしまった。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また片方の尖っている方が親鳥の腹の下へ沢山詰め込むのに都合がよいからだという説もある。",
              "citation": {
                "source": "卵の形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "片方は十八の青年、片方は十七の乙女。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "片方の仕切りにはテプラーポンプや附属のマノメーターなどを置いた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その八百屋の荷、片方が山盛で片方が少ない。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと片方は暗い二條通に接してゐる街角になつてゐるので、暗いのは當然であつたが、その隣家が寺町通りにある家にも拘らず暗かつたのが瞭然しない。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "客が情事めいたことをいって揶揄うと、ともよは口をちょっと尖らし、片方の肩を一しょに釣上げて「困るわそんなこと、何とも返事できないわ」　という。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭に十文字に繃帯をして片方のちぎれかけた耳朶をとめている者がある。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "森のまた、帰る方の道には、腕関節からはすかいに切り落された手や、足の這入った靴が片方だけ、白い雪の上に不用意に落されてあった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は、片方の腕を通しさしで、手を天井に突き上げたまま、テーブルに近づいた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一足二足進み寄るのを見ると足も片方不随であるらしい。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうするかと思っていると、このやや長味のある団塊をうまく二つに食い切って、その片方を丁寧に丸めた後に、それを銜えて前日と同じ方向へ飛んで行った。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄条網を丸めて、片方にのけた狭い出口から兵士たちの列伍は、電柱伝いに行進した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "片方の子供はいかにも弱さうだつた。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし片方はただ笑うだけでその話には乗らなかった。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "片方の眼だけが出て来てしばらくの間それに睨まれていることもある。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "極く丈の詰った影で、街燈が間遠になると鮮かさを増し、片方が幅を利かし出すとひそまってしまう。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと片方は暗い二条通に接している街角になっているので、暗いのは当然であったが、その隣家が寺町通にある家にもかかわらず暗かったのが瞭然しない。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アア、一対なら、おれの腕で売れば慥に三十両にはなるものだが、片方では仕方がない、少しの金にせよ売物にならぬものを買ったってどうもならぬと、何ともいえないその鐙の好い味に心は惹かれながら、振返っては見つつも思い捨てて買わずに大阪へと下った。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、それから道の程を経て、京橋辺の道具屋に行くと、偶然といおうか天の引合せといおうか、たしかに前の鐙と同じ鐙が片方あった。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ン、これが別れ別れて両方｜後家になっていたのだナ、しめた、これを買って、深草のを買って、両方合わせれば三十両、と早くも腹の中で笑を含んで、価を問うと片方の割合には高いことをいって、これほどの物は片方にせよ稀有のものだからと、なかなか廉くない。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、もとより片方しかなかった鐙を、深草で値を付けさせて置いて、捷径のまわり道をして同じその鐙を京橋の他の店へ埋めて置いて金八に掘出させたのだ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると片方の小鼻が途方もなくたれ下がっているのを手近で見る時には少しも気づかなかったりする。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれでは肝心の事故の第一原因はわからないのでいろいろ調べているうちに、片方の補助翼を操縦する鋼索の張力を加減するためにつけてあるタンバックルと称するネジがある、それがもどるのを防ぐために通してある銅線が一か所切れてネジが抜けていることを発見した。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもしろいのは、このローラーが全部木製で、その要部となる二つの円筒が直径一センチメートル半ぐらいであったかと思うが、それが片方の端で互いにかみ合って反対に回るようにそこに螺旋溝が深く掘り込まれていた。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも片方が「本家」で片方が「元祖」だとか言って長い年月を鬩ぎ合った歴史もあったという話を聞いたことがある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたほうの足も、ずいぶん高くあげていました。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとうさんは、かたほうの足を、からだの下に高く上げていました。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ブタ飼いが、ちょうど八十六回めのキスをもらったときに、かたほうのスリッパで、ふたりの頭を打ちました。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
