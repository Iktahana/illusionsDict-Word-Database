        "examples": {
          "standard": [
            {
              "text": "「またあの勘定取りが来たよ。居留守を使ってやり過ごすのも、もう限界かな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "勘定取りの足音が廊下に響くたび、店主は奥の部屋で息を潜めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「旦那、勘定取りを追い返すのも楽じゃありませんよ。少しは支払いの工面をしてください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「ははあ、勘定取りかえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そないに勘定や勘定やと云われてもな」といつか版木屋が勘定取りに来たときに、彼がきいきい声で云うのを房二郎は聞いた、「――こっちゃもしょうばいやよってに、あんじょう儲からんことには払えやしまへんがな」　記事部屋は北向きで、うす暗く、湿っぽく、九月にはいるともう隙間風が寒かった。",
              "citation": {
                "source": "へちまの木",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しぜん飲屋その他の勘定取りは編集室へやって来た。",
              "citation": {
                "source": "陽気な客",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日月給日、色々な勘定取り来る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
