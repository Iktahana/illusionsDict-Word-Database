    "definitions": [
      {
        "index": 1,
        "gloss": "summer school",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夏休みを利用して、山間の自然豊かな場所で開催される夏期学校に参加した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今年の夏期学校では、海外から講師を招いて英語漬けの三日間を過ごす予定です。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は夏期学校での共同生活を通じて、全国から集まった志の高い仲間と出会った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "避暑地での夏期学校は、勉強だけでなく野外活動も充実していて、子供たちに人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この夏期学校に来ますついでに私は東京に立ち寄り、そのとき私の親爺と詩の話をいたしました。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "でこの夏期学校にくるついでに、その山陽の本を再び持ってきました。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分には明治二十七年になったら、夏期学校の講師に選ばれるという考えは、その時分にはチットもなかったのです（満場大笑）。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日われわれが正義の味方に立つときに、われわれ少数の人が正義のために立つときに、少くともこの夏期学校に来ている者くらいはともにその方に起ってもらいたい。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏期学校の開かれると云う日も近づいていた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へえ、夏期学校というのが有るのかね――」　と主人は言って、捨吉が水を撒いて置いた庭の飛石づたいに、彼方此方と歩いて見て、やがてまた軽い浴衣の裾をからげながら細い素足のままで捨吉の方へ来た。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし書生を愛する心の深い人ではあり、日頃いかに気を引立ててくれるようにしてもとかく沈み勝ちな捨吉のためにはあるいはそういう夏期学校へ行って見るのも好かろう、という風に心配しつつ許してくれた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏期学校の方へ出掛けると聞いて、汗になった襦袢や汚れた紺足袋の洗濯まで心配してくれた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "捨吉は夏期学校の催しを思いやり、その当時としては最も進んだ講演の聞かれる楽みを思いやって、垣の根に蔓った草をせっせと毟った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は草むしりする手を土の上に置き、冷い快感の伝って来る地面に直接に掌を押しつけて、夏期学校の講演を聞こうとして諸方から集って来る多くの青年のことを思いやった。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「真勢さん、僕は明日から夏期学校の方へ出掛けます」　と話して聞かせた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホ、夏期学校へ」　と真勢さんは汗染みた手拭で顔を拭きながら言った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏期学校と聞いて真勢さんのように正直そうな眼を円くする人は、捨吉の身のまわりには他に無かった。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "真勢さんは捨吉からしきりに夏期学校の催しを聞こうとした。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏期学校の催しは構内のさまを何となく変えて見せた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏期学校を機会に、しばらく寄宿舎で一緒に成れるということも捨吉にはめずらしかった。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙台からも京都からも神戸からも学校の違い教会の違った人達が夏期学校をさして集って来ていた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本にある基督教界の最高の知識を殆んど網羅した夏期学校の講演も佳境に入って来た。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして思い思いに夏期学校へ来て見た心持を比べ合っていた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の夏期学校の校長で、東北の方にその人ありと言われ、見るからに慷慨激越な気象を示したある学院の院長が通った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "破鐘のような大きな声と悲しい沈んだ声とで互いに夏期学校の講壇に立って、一方を旧約のイザヤに擬するものがあれば、一方をエレミヤに擬するものがある、声望から経歴から相対立した関西の組合教会の二人の伝道者が通った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一方の摺硝子は白く午後の日に光って、いかにも岡の上にある夏期学校の思をさせた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏期学校は三週間ばかり続いた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰に憚るところもなく讃美歌を歌いながら樹の下を歩き廻る夏期学校の連中が右にも左にも見える。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "四「捨さん、お帰りかい」　夏期学校の方から帰って来た捨吉を見て、田辺のお婆さんは土蔵の内から声を掛けた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜焼が痛いと言って泣いた時分からの捨吉のことをよく知っているお婆さんは彼が平素に似ず晴々とした喜悦の色の動いた顔付で夏期学校の方から帰って来たのを見た。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
