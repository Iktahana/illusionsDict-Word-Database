        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "料理はからっ下手だから、いつも市販のルーだよ。情けないな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は絵を描くのがからっ下手で、棒人間しか描けないんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "歌うことはからっ下手で、人前では絶対歌えないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "正直、球技はからっ下手だから、運動会は毎年苦手なんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」とフランス語のからっ下手なマイダーノフが、フランス語で叫んだ。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、撞球はからっ下手でさほどの興味もない。",
              "citation": {
                "source": "阿亀",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お嬢さん、貴女は手習はからっぺただっていうんですが、この字は細くって綺麗ですね。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
