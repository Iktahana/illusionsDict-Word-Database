    "definitions": [
      {
        "index": 1,
        "gloss": "scribblings",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "机の上には、今日の会議の書き散らしが山積みになっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古いノートには、彼の若い頃の詩の書き散らしが残されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "落書き帳だと思っていたものは、実は天才画家の書き散らしだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "集中できない時に限って、無意味な書き散らしが増える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これと反対にまた世俗に有名ないわゆる大家がたまたま気まぐれに書き散らした途方もない寝言のようなものが、存外有名になって、新聞記者はもちろん、相当な学者までもそれがあたかも大傑作であり世界的大論文であるかのごとく信ずるような場合もあるのである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の軒には、青や赤の短冊に、歌か俳句か書き散らしたのが、隙間もなく下がって風にあおられている。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "云はでものことを云ひふらし、書かでものことを書き散らし、警察の厳重なる取締を受けなければならなくなつて、無暗と神経を昂らせ、反抗的気分を増進させ、とどのつまりは此の如き犯罪を計画した。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこのニヒリスティックな人生観から、社会のあらゆる道義観や風俗に挑戦し、故意に人生の醜悪を描き、人間性の本能を高調し、隠蔽されたものを引っぺがし、性の実感的｜卑猥を書き散らした。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ有り合ふ世だけに当嵌めて、その場その場に身を生すことを考へて来た――事実、恋ふべき過去でも無い、信じられる未来とも思へなかつた、業風の吹くままに遊び散らし、書き散らし、生き散らして来たと思へる生涯が、なぜか今宵は警めなしに顧りみられる。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことを書き散らして、工場の窓から、投文しようかとも思った。",
              "citation": {
                "source": "I can speak",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを大掴に、恋歌を書き散らして参った。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしは毎朝、お客さんの書き散らした原稿用紙、番号順にそろへるのが、とつても、たのしい。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新作の詩数篇、我ならでは読まれぬ様に書き散らしたるが、その儘浄書もせずにあり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "帳面は俳句日記かなんかの古物であったかと思うが、明けて見るとなるほどいろいろの人の手跡でいろいろの句がきたなく書き散らしてある。",
              "citation": {
                "source": "俳諧瑣談",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に銀杏がえしの女の頭がいくつもあって、それから Fate という字がいろいろの書体でたくさん書き散らしてあった。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「書き散らしたときの筆跡です。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど習字よりは画を好みて、夜は常に木偶の形など書き散らして楽みしが、ただみづから画くのみならで、絵巻物（註、錦絵の事なり）など殊の外よろこびて常に玩べりとか。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顏をよく見ますと、忘れもしない、代數の教科書に教師の似顏を書き散らしてゐた滿谷國四郎氏でありました。",
              "citation": {
                "source": "詩集の後に",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼鏡をかけて炬燵の中に背中を円るくして入り、その上に小さい板を置いて、私の原稿用紙の書き散らしを集め、その裏に鉛筆で稽古をし出した。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "文庫のなかには書き散らしの反古のようなものがいっぱいに詰めてあったが、その大部分はいろいろの地蔵さまの顔を模写したもので、問題の種になった村はずれの地蔵さまの顔は二十枚以上も巧みに模写してあったと伝えられている。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "摘み上げた手紙を、取る手遅しと開いてみれば、こは如何に、そこには唯、水兵が煙草を吸っているような漫画が書き散らしてあるばかりだった。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、何んなことを書き散らしたかしら？",
              "citation": {
                "source": "冬の風鈴",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａの机の周囲は、書き散らしの原稿で埋つてゐた。",
              "citation": {
                "source": "蔭ひなた",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　王献之は大喜びで、いきなり筆を取つて、草書楷書と手当り次第に好きな字を書き散らした。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからというものは、無暗に「ツノダ」という文字を紙という紙に書き散らしてまるで、私たちを呪うかのように駄々をこねました。",
              "citation": {
                "source": "呪われの家",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説を書くということも一つの願望で、庸三は手函に一杯ある書き散らしの原稿を見せられたこともあった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小夜子はこのごろも書いたとみえて、原稿｜挟みを持ち出して来て、書き散らしの小説を引っくらかえしていたが、庸三はこの女は書く方ではなくて、書かれる方だと思っていたので、「やっぱり五年十年と年期を入れないことには。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の僕の呑気な空想を助けたものは、四方の壁のあちこちに書き散らしてある落書だった。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "先きの長くないことを知つた兒童等は、教室の壁や、廊下の羽目に「へのへのもへ」さんなぞを書き散らした。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは、あなたのことを、感傷的な形容詞で一杯、書き散らしていたところですから、なにか照れ臭く、まごまごすると、慌てて手帳をベッドの上の網棚に、抛りあげ、そそくさ、部屋を出て行きました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "又此の頃から新しい手帳に鉛筆にて何やら論文のノオトらしいものを十頁ほど書き散らしてゐる。",
              "citation": {
                "source": "萩原朔太郎",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "開けて見ると、一冊の手帳に、大きな字で一杯自在奔放に書き散らしてある。",
              "citation": {
                "source": "臨終の田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "さばかり賢しだち、まなかきちらして侍るほども、よく見れば、まだいと堪へぬことおほかり。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その横の壁のうんと高いところに銀三四九〇とアラビア数字で白墨書きがあり、気がついて見ると、その電話のまわりには、謂わばところきらわず、がさつな事務所にでもありそうに番号変更の紙を貼りつけたり、番号をかきちらしたりしてある。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
