        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ひどい出血だ、とりあえず清潔なタオルで仮繃帯をして病院へ運ぼう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "山道で転倒した仲間の足に、シャツを裂いて作った仮繃帯をきつく巻きつけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "救急隊が到着するまで、彼は痛みに耐えながら自分の腕の仮繃帯を見つめていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "刈り取られた黍畑や赤はげの小山を超えて、およそ二千メートル後方の仮繃帯場へついた時は、ほッと一息したまま、また正気を失てしもた。",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　　＊　　　　＊　仮繃帯の下から生々しい血汐が潤み出して私はいうべからざる苦痛を覚えたが、駅長の出してくれた筧の水をグッと飲み干すとやや元気づいて来た。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "応急手当――仮繃帯だけはしてあつたけれども、腹部の貫通銃創にちがひないと私には思はれた。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして少年をなぐさめるとともに、持ってきた衛生材料でもって、手ぎわよく一彦の患部を消毒し、仮繃帯をぐるぐるまいてくれました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
