          "standard": [
            {
              "text": "During a regression therapy session, she described detailed scenes from what she believed was a past life as a medieval artisan.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "He often mused, 'This place feels so familiar, almost like I've lived here in a past life.'",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は天竺の仏のように無数の過去生を通り抜けた。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は天竺の仏のやうに無数の過去生を通り抜けた。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "―或精神的風景画―",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、天竺の佛が無數の過去生を通り拔けるやうに、イブセン、ドストエフスキイ、トルストイ、モオパスサン、ストリンドベリイを通り拔けた。",
              "citation": {
                "source": "芥川龍之介論",
                "author": "――藝術家としての彼を論ず――",
                "note": "青空文庫"
              }
            },
            {
              "text": "浄土其他の念仏に伴ふ、成仏得道の過去生譚をも語つた。",
              "citation": {
                "source": "組踊り以前",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "48　三宝絵詞・今昔物語では、動物の過去生を説いて、経を聴く為の仮身だと説く。",
              "citation": {
                "source": "漂著石神論計画",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが謂はゞ、――平野の里に感じた喜びは、過去生に向けてのものであり、今此山を仰ぎ見ての驚きは未來世を思ふ心躍りだ、とも謂へよう。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが謂はゞ、――平野の里に感じた喜びは、過去生に向けてのものであり、今此山を仰ぎ見ての驚きは、未來世を思ふ心躍りだ、とも謂へよう。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが謂はゞ、――平野の里に感じた喜びは、過去生に向けてのものであり、今此山を仰ぎ見ての驚きは、未来世を思ふ心躍りだ、とも謂へよう。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが謂わば、――平野の里に感じた喜びは、過去生に向けてのものであり、今此山を仰ぎ見ての驚きは、未来世を思う心躍りだ、とも謂えよう。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の過去生活には、見霞むような奥行のあることを、考えたり感じたりする習慣はちっともない。",
              "citation": {
                "source": "和州地名談",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る種の新たなる文芸の、特に一つの時代一つの国に起こらねばならなかった事情、それが民衆の過去生活のいかなる部分を表現しているかということを、尋ね究めようとした人は江戸の町学者の中にも幾人かあった。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
