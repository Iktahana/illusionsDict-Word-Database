        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このプロトタイプはまだ試作品だが、来週発表する完成度は自信がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このゲームのグラフィック、完成度がめちゃくちゃ高い！まるで映画みたいだよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "職人が丹精込めて作り上げたその作品は、驚くほどの完成度を誇っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "プロジェクトの最終段階では、細部までこだわり抜いて完成度を高める作業が進められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "話芸としての完成度に留まらず、ワシントンに乗り込んで辻説法に及ぶ迫力も加わり、実に鬼気迫るパワーがある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちにしろ、政治への傾斜とか、ギター小僧の天下とか、洗練や完成度が重んじられたり、ただのダンスビートになったり、さんざんだ」　足を手すりの下の桟にのせる高志のしぐさが、慶一の記憶を刺激する。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、人が彼の生活に於て果して眞に幸福を感じてゐるかどうかといふことは、どんな種類の生活に於てであらうと、さういふ一個の生活の完成度を見る上からは、簡單にしてしかも重要な見地なのだ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ彼が當の生活者の幸福感といふやうな主觀に個人の生活の完成度を見る規準を求めたのは尤もなことと云はねばならぬ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、これだけの完成度を備えた製品がわずか六〇〇ドル、当時の為替レートで換算して約一七万円と、ＴＫ―80二台分程度の金で手に入るという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "後藤富雄がＰＥＴの完成度に強烈な印象を受けた同じ会場で、青年と呼ぶにはいまだに稚気を面に残した二一歳の西和彦は、目の前で起こりつつあることと日本の現状との落差に、はがゆさを禁じえないでいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人が自分の主体性にもとづいて、パーソナルコンピューターに向き合おうとしている」　後藤富雄がプロの技術者としての目でＰＥＴの完成度に着目していたとき、西和彦はもう少し観念的に、大げさにいえば哲学的に会場の熱気をつかまえようとしていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "中世紀精神のカビが払い落とされると同時に、それにむすびついた革命が、同様の完成度と同様の深達度をもって、俗世の生活にも、権力の座の組織のなかにも起こった。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "明らかに最近の予定表の一部は丹念に仕上げられた古の魔法使いの筆跡の模写だったが、チャールズが驚嘆すべき完成度で成し遂げているようなのだ。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "技術者の作り出したものの方が、自然の作り出したものよりも、技術的に言って完成度が高いのです。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはこれらを更に発展させ、その上に彼らの個性および富の変化を刻みこんでハイピッチの完成度を持ち来たらしたが、最終的に王権および古代文明はインド・ゲルマン民族によって取り上げられた。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "この身長でこそ成り立つバランスだからこの身長なのだという、緻密な完成度の高さを僕はいつも彼女の体に感じる。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのショットも完成度は高く、静かな緊張感が、ひとこまごとに張りつめていた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして助走路が充分に出来たなら、ある日のこと、なにげなくふとそちらへ、乗り移ればいいのです」「なるほど」「次には、助走路の具体的な完成度の高さが問題になります。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシア科学は、非人間的な完成度や共同作業の際の知性および道徳における厳格な規律においてはドイツの流儀に及ばなかったが、しかし勇猛果敢にして幻想的な想像力を活かしてドイツを凌駕した。",
              "citation": {
                "source": "いえ、いえ、ラゴーフにはもう！",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
