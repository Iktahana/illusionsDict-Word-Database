  {
    "uuid": "61e8df31-48cc-5bfa-912e-3dda2f5135d1",
    "entry": "かや",
    "reading": {
      "primary": "かや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "助詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "indicates emotion, admiration, etc.",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「まあ、きれいなかや！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あら、もうこんな時間になったかや。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「そうかや、それは大変だったな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「まあ、よくやったかや。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「こんなところに置いてあったのかや。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "楊林宮沢賢治エレキに魚をとるのみか鳥さへ犯すしれをのこ捕らでやまんと駐在の戸田巡査こそいかめしきまこと楊に磁の乗りて小鳥は鉄のたぐひかやひとむれさつと落ち入りてしらむ梢ぞあやしけれ",
              "citation": {
                "source": "楊林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなかやると思っていますよ」私はむっとして、佐竹のまぶしいほど白い顔をもいちど見直した。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お魚屋さんのばーかやい。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お嬢ちやんのばーかやい。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かやうな都会の私立中学にあつては、編入者や退学者が大変多いために、生徒の愛校心は至つて乏しいのである。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその凡そで以て何やかや書き出すやうになる。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝶の舌ゼンマイに似る暑さかな暖かや蕊に臘ぬる造り花臘梅や雪うち透かす枝のたけ「蝶の舌」の句は、ゼンマイに似ているといふ目付け所が山であり、比喩の奇警にして観察の細かいところに作者の味噌があるのだらうが、結果はそれだけの機智であつて、本質的に何の俳味も詩情もない、単なる才気だけの作品である。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂しさや華のあたりのあすならふ「あすは檜の木とかや、谷の老木のいへることあり。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬して遠ざくるとかやいへば、よきほどにあひしらひて、言葉交はすほど、船つきぬ。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう大概にしないか、ばかだな」と言ってみたが、なかなかやめそうもないから便所へはいる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中老の男は私には丁寧に「自分も絵の端くれを描きますが、いや、その他、何やかや八百屋でして」　男はちょっと軒端から空を見上げたが「どうだ、日もまだ丁度ぐらいだ。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は大学を出ると美術工芸学校やその他二三の勤め先が出来た上、類の少ない学問筋なので何やかや世間から相談をかけられることも多く、忙しいまま、東海道行きは、間もなく中絶してしまった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では震災後、東京に飲食店が夥しく殖えたが、それは飲食店開業が一番手早くて、どうにかやって行けるからだと聞いた。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のことかやはりよく分らない。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御菓子を持って来い」がどうも分らないが、しかしその前々夜であったかやはり食後の雑談中女中にある到来ものの珍しい菓子を特に指定して持って来させたことはあったのである。",
              "citation": {
                "source": "夢判断",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何やかやそれぞれまとめて番ニョに乗せ、二人で差しあいにかつぐ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "後者の尖鋭なスマートな刺戟の代りに前者にはどこかやはり古典的な上品な滋味があるような気がする。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともあれ当時の詩壇はかやうな薄命の状態にあつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜに自分はかやうに肉体的に病み苦しまなければならないかとさへ叫んだ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五円札を出したんは、あいつだけなんだから、あいつがきっと何かやったんだな。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、一寸なにかやると、すぐ検束騒ぎをするここの警察をよく知っていた。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何かやってるぞ、おい、工場の奴が、何かやってるぞ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "即座に、誰かゞ、かげにかくれて、何かやっているな！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実際、俺等にゃ、支那人をやっつけることばかりしかやらせやしないじゃないか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の洞窟や、部落のなかや、原に八十八の寺や、庵があるのである。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は風呂敷に包んだ反物と蟇口の金とを胸算用で、丁度あるかどうかやってみるが頭がぐら／＼して分らなくなる。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」誰かやさしくもの云ひて、　　　いらへはなくて風吹けり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）ところがタスケの馬も馬でさあ、面白がってオペラのようにふしをつけて（なかなかやれないわたしのオート。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所のお婆さんが来て、勝子の絵本を見ながら講釈しているのに、象のことを鼻巻き象、猿のことを山の若い衆とかやえんとか呼んでいた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
