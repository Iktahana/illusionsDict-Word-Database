[
  {
    "uuid": "c0d58df3-f3fa-5601-9bcd-b4f26c8f99ec",
    "entry": "茅",
    "reading": {
      "primary": "かや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "grass used for thatching",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔ながらの茅葺き屋根の家は、夏は涼しく冬は暖かい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庭の隅に生えている茅を刈り取り、乾燥させて正月飾りに使う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "茅で編まれた縄は、丈夫で昔から様々な用途で使われてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域では、茅を栽培して工芸品の材料にしている農家もいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "茅草・尾花の布き靡く草の海の上に、櫟・榛の雑木林が長濤のようにうち冠さっていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茅ヶ崎駅の西の線路脇にチューリップばかり咲揃った畑が見えた。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たんぽぽの花を取ったり、茅花を抜いたり、又桑を摘みに山へつれられて行ってはシドミの花を分けて根についてある実を探したり、夢の様に面白かったことは、何十年という月日を過ぎても記憶に存している。",
              "citation": {
                "source": "井戸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　――彼は、内地の茅葺きの家を思い浮べた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "茅葺きの家も、囲炉裏も、地酒も、髯みしゃの親爺も、おふくろも――それらは安らかさと、輝かしさに満ちている――すべてが自分から背を向けて遠くへ飛び去ってしまった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七日には、なな草のあえもの、十五日には朝早くとんどをして茅の箸で小豆粥を食べる。",
              "citation": {
                "source": "四季とその折々",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此處は谷間に據る一｜小村で急斜面は茅屋が段を作つて叢つて居るらしい、車を出て見ないから能くは解らないが漁村の小なる者、蜜柑が山の産物らしい。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　軌道と直角に細長い茅葺の農家が一｜軒ある其の裏は直ぐ山の畑に續いて居るらしい。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の前は廣庭で麥などを乾す所だらう、廣庭の突きあたりに物置らしい屋根の低い茅屋がある。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "其日はそれで別れ、其後は互に誘ひ合つて釣に出掛て居たが、ボズさんの家は一｜室しかない古い茅屋で其處へ獨でわびしげに住んで居たのである。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日降った雪がまだ残っていて高低定まらぬ茅屋根の南の軒先からは雨滴が風に吹かれて舞うて落ちている。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼婆で名高い浅茅ヶ原に近いだけに、鬼娘の噂がそれからそれへと仰々しく伝えられて、残暑の強いこの頃でも、気の弱い娘子供は日が暮れると門涼みに出るのを恐れるようになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃、茅場町に変な奴があるのを知っているか」「へえ」と、半七は首をかしげた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "多吉のいう通り、茅場町辺の事件ならば、そこは瀬戸物町の源太郎という古顔の岡っ引がいるので、当然彼がその探索を云い付けられる筈であるが、源太郎はもう老年のうえに近来はからだも弱って昔のような活動も出来なくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七は源次に云いつけて、これから毎夜茅場町の近所に網を張って祈祷所へ出入りするものを偵察させることにした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七は途中で買物をして、更になにかの支度をして、日本橋茅場町の祈祷所へたずねてゆくと、以前は誰が住んでいたか知らないが、新らしく作り直したらしく門柱には神教祈祷所という大きな札がかけられて、玄関先に注連が張りまわしてあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "トシエの親爺の伊三郎の所有地は、蓬や、秣草や、苫茅が生い茂って、誰れもかえり見る者もなかった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長屋の背後の二すじの連山には、茅ばかりが、かさ／＼と生い茂って、昔の巨大な松の樹は、虫歯のように立ったまゝ点々と朽ちていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙々とした茅屋の黒い影。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日表にことさら明るんで見えるのは季節を染め出した雑木山枯茅山であった。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑木と枯茅でおおわれた大きな山腹がその桑畑へ傾斜して来ていた。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚く雪を被った百姓家の茅屋根からは蒸気が濛々とあがっていた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "茅屋根の雪は鹿子斑になった。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりの山では処々茅蜩殿、血と泥の大沼になろうという森を控えて鳴いている、日は斜、渓底はもう暗い。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋より下の方、東に向つて川の流るゝこと少許にして汽車のための鉄橋の下を過ぎ、右に○塩入村の茅舎竹籬を見、左に蘆葭の茂れるを見ながら一折して、終に南に向つて去る。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の後など古き茅屋の棟に咲ける、おもしろからずや。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにも枯れた茅がしげつてゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本道の兩側に三丁ほど茅葺の家が立ちならんでゐるだけであつたのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本道の両側に三丁ほど茅葺の家が立ちならんでいるだけであったのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼬のように一直線に門前の茅原の暗に消え込んだ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
