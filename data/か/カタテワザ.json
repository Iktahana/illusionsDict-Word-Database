        "examples": {
          "standard": [
            {
              "text": "熟練のバーテンダーは、シェイカーを片手業で見事に操り、カクテルを仕上げていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「見て見て！ 弟が片手業で懸垂を10回もやったんだよ。信じられる？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ピアニストが左手だけの片手業で弾く『シャコンヌ』は、両手で弾くよりも力強く心に響いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
