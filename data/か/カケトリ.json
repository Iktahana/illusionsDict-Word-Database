        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は昔、町の掛け取りをしていたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「いやはや、掛け取りの仕事は大変だよ。相手によっては態度が違うからね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "自転車に乗った掛け取りが、古い家々を訪ねて歩いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
