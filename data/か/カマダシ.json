        "index": 1,
        "gloss": "removing pots from kiln",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今日はいよいよ窯出しの日だ。どんな作品ができあがっているか楽しみだね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "窯出しを終えたばかりの陶器はまだ熱いので、注意してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ベテランの職人が慎重に窯出し作業を進めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "無事、窯出しが完了しました。ひび割れもなく、良い焼き色が出ています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "これはいずれもの人々が陶器師なる者さえ手許に連れ寄すること、よって思うまま欲するままに陶磁が窯出し得るものと、こともなげにも予断する軽々しいくせのある一事である。",
              "citation": {
                "source": "素人製陶本窯を築くべからず",
                "author": "――製陶上についてかつて前山久吉さんを激怒せしめた私のあやまち――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、何かまだしっくりしないものがあった。",
              "citation": {
                "source": "在学理由",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにもここの空気が気に入っていて（本当の空気です）、何だかまだしんにのこったかすまでがさっぱりしない心持ですから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "傷の上の方に何かまだしこりがあって、それを全くちらしたら完成です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
