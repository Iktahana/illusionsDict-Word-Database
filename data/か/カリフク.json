        "examples": {
          "standard": [
            {
              "text": "職人たちが、冬の間に刈り溜めた良質な茅を使い、古民家の痛んだ屋根を丁寧に刈り葺いていく。",
              "source": "幻辞"
            },
            {
              "text": "「今年は天候に恵まれたから、例年以上に瑞々しい萱で社殿を刈り葺くことができそうだ。」",
              "source": "幻辞"
            },
            {
              "text": "軒先から棟へと順繰りに、隙間なく等間隔で茅を刈り葺くことで、雨漏りを防ぐ強固な屋根が完成する。",
              "source": "幻辞"
            },
            {
              "text": "白川郷の合掌造り集落では、数十年に一度の葺き替えを「結（ゆい）」の精神で共に刈り葺く伝統が守られている。",
              "source": "幻辞"
            },
            {
              "text": "刈り葺く職人の手捌きは鮮やかで、厚く積み上げられた茅の束が、鋏で整えられるたびに美しい断面を見せる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "どんなに好きな人でも、五年ものあいだ、といの中にいて、水ですっかりふくれあがってしまっては、恋もなにもおしまいです。",
              "citation": {
                "source": "いいなずけ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの可愛いお猫さんのように、さ、お湯をつかって支度をしましょう――といった調子なので、テレサはテレサですっかりふくれ返って、その巨大な北極熊みたいな全身へ万遍なくおしろいを叩きはじめる。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「桑の芽がすっかりふくらんで、日あたりのよいところはもうほぐれていますよ。",
              "citation": {
                "source": "種紙の青む頃",
                "author": "前田夕暮",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「セリフ」の面白さは、いつでも、「こっけい」すなわち、「おかしさ」ばかりふくんでいるものとはかぎらない。",
              "citation": {
                "source": "劇の好きな子供たちへ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し警察がよくよく性に合はないと見え、Ｔさんが現れると、すつかりふくれて、突然麻雀に転向してゐた。",
              "citation": {
                "source": "囲碁修業",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "八、急げ」「一體これはどうした事でせう、親分」　八五郎はスタートに並んだまゝ、鼻ばかりふくらませてをります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "血塗られた祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは手紙、ゆっくりどっさりかきたいが強いてやめます、わけは、又右手の拇指の下がすっかりふくれて右手こまるのです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
