    "definitions": [
      {
        "index": 1,
        "gloss": "rice, meat and vegetable dish served in a small pot",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "駅弁で人気の釜飯は、蓋を開けるときの香りがたまらない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末は家族で温泉に行き、夕食には地元の食材を使った釜飯を堪能した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この店は、鯛の釜飯が名物で、遠方から食べに来る客も多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼はなんという目的もなく、ただ銀子が好きで、分寿々廼家へもひょこひょこ遊びに来、飯を食いに銀子を近所の釜飯屋へ連れ出し、にやにやしているくらいがせいぜいであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまに釜飯屋を附き合うくらいなのよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの男は天下に釜飯くらいうまいものはないと言ってるくらいだもの。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "・釜飯の話　　附、飯櫃の話・苔と垢三月九日　曇、晴れたり降つたり、風が吹いたり。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから薬湯のとなりに貝類の料理や釜飯を出す店があった。",
              "citation": {
                "source": "浅草むかしばなし",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし戦災後は米作も釜飯屋も見えなくなった。",
              "citation": {
                "source": "浅草むかしばなし",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんの信子女史が、鰹節の釜飯をたいて御馳走してくれた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "白菜なべ、おでん、かまめし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
