        "examples": {
          "standard": [
            {
              "text": "新しいマフラーを編むために、太めのかぎ針を新調した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この繊細なレース模様は、たった一本のかぎ針で編まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "かぎ針の持ち方には、ナイフ持ちと鉛筆持ちの二種類があるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "セットで買ったかぎ針の一本をなくしてしまい、同じ号数のものを探している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "ごらんなさい、引き綱は換気のための小さな穴の上のあたりで、かぎ針に結ばれて動かない。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
