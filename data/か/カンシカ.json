        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "容疑者は厳重な監視下で取り調べを受けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そのプロジェクトは政府の監視下で進められ、進捗が厳しくチェックされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は仮釈放の身であり、常に保護観察官の監視下に置かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "来るまでは、全員を私個人の監視下に置かねば。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の監視下にある弟がお粗相をした。",
              "citation": {
                "source": "神童の死",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼け落ちたとはいえ、その資料はヘルナー山頂に横たわり、今も我々の監視下にあるんだからね」　ホーテンスとドレゴは、新鋭砕氷船の特質につき大きな興味を沸かしているのだった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊によると、あいつは例の日本将校カワカミじゃないかねえ」　　　ピストルの監視下に「カワカミですって？",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はフランク大尉のピストルの監視下にあって、敵国のために最も重大な役わりを懸命に果しているのであった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一見すると衆人監視下で皇帝を盗みだすのは難しい。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一晩中この人物の監視下にあった。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな人物は監視下に置いて、泳がせておいた方がよろしゅうございます。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろゴーシ卿とマーシを監視下に置かねばなりません。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "監視下に置かないと心配だ」　相客がぶつくさ言ったが、座席を交換してもらい、すぐにウォードはレスブリッジと警部の間に座わらされた。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつら監視下にある限り、悪事は出来まい。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "政子は、聡明なので、世のつねの妻女のように、徒らに泣き狂ったり醜い嫉妬は口走らなかったが、一応、夫婦のあいだにはかなり派手な口論が交わされ、さしもの頼朝も彼女の正論には抗し難く、以後、彼の進退は甚だしく、御台所の監視下にあるという――下々にまで隠れないうわさを吉次も聞いていたからであった。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また子は子で、幕府の監視下におかれ、祖母はひそかに足利ノ庄へ落ち行くなど、三方四方への別離であったが、たれも泣いてはいなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "現朝廷の監視下に注意人物とされていた光厳の御脱出は、よほど困難だったはずである。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
