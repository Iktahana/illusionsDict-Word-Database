          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "平安時代の上達部は、宮廷政治において重要な役割を担っていました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "源氏物語には、上達部の華やかな暮らしぶりが克明に描かれています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "当時の上達部にとって、和歌の才能は出世の大きな要因だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は上達部の家系に生まれたが、武術の道を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "廿一日、己未、晴、将軍家大臣拝賀の為に、明年正月鶴岳宮に御参有る可きに依つて、御装束御車已下の調度等、又仙洞より之を下され、今日到著す、又扈従の上達部坊門亜相已下参向せらる可しと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親王興に入りたまいて、さらば足下のは、と問わせたまうに、旧上達部の檳榔毛の車に駕りたるが、時に其声を聞くにも似たらん、と申した。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "前司はかたちも美しい上、心ばへも善いさうでございますし、前司の父も受領とは申せ、近い上達部の子でもございますから、お会ひになつては如何でございませう？",
              "citation": {
                "source": "六の宮の姫君",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ず「上達部、殿上人」であったものが、「諸大夫、殿上人、上達部」になっている。",
              "citation": {
                "source": "『新新訳源氏物語』あとがき",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（臨時の客は二宮の大饗と同日に摂政関白家が、大臣以下の上達部を招いて催す饗宴で、大饗と別に変りがない。",
              "citation": {
                "source": "芋粥",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに大乱はじまりまして、都は大半烏有に帰し、公卿方｜堂上人上達部、いずれその日の生活にも困り、縁をたよって九州方面の、大名豪族の領地へ参り、生活するようになりまして、わが洞院信隆卿にも、過ぐる年｜周防の大内家へ、下向されましてござります。",
              "citation": {
                "source": "弓道中祖伝",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞの上達部や、伝統の絡んだ重苦しい氏の名などゝは違うて、きさくな、自由な感じのする、ありふれて居ない姓や、位も、官も脱ぎ棄てた様に、通り名や、法名だけで通つて居る隠者などから受けるさば／＼した気持は、想像出来なくはない。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇に次いでは、小忌――上達部がさうであつた。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "上達部とは通称であつて、官名ではない。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "上達部とは、上達の団体のことである。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其で貴族達――所謂上達部――の生活を見ても、大和に近いところに、国をなしてゐた人達の跡で、宮廷の生活信仰に触れることが多かつた。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "後期王朝では、上流の公卿を上達部といふ。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　上達部の意義故殿のおほん服の頃、六月三十日の御祓へといふ事に、いでさせ給ふべきを、職の御曹司は、方あしとて、官のつかさの朝所に渡らせ給へり。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "上達部のつき（着座）給ひしなどに、女房どものぼり、じやう官などのゐる障子を皆うちとほしそこなひたりなど、苦しがるもあれど、きゝもいれず（枕草子）前に述べた通り、上達部なる語も亦、平安朝に残留してゐたもので、これを以て、奈良朝以前の様子を窺ふことが出来る語なのだ。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安朝に於いて、かんだちめと云ふ語は、上達部と云つた字に宛てたゞけの聯想は持つてゐたに違ひないが、古代に於いては、祭時の宮廷を※と見て、其処に詰めて居る人々だから、上達部と云つたのである。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "後には、上達部の内容が変つて来るが、まづわれ／＼の考へでは、上達部が三位以上の公卿を指す、と云ふ様な制限があつたのではなく、もつと広い範囲をさしたもので、其上に、更に、所謂おみと称するものがあつた。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば、上達部といふ言葉は、平安朝になつて出て来るが、考へて見ると、決して平安朝に出来た言葉ではなく、宮廷と神社とを同じに考へてゐた、ずつと昔の言葉である。",
              "citation": {
                "source": "古代に於ける言語伝承の推移",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "上達部の意味は、文字からでは訣らぬ。",
              "citation": {
                "source": "はちまきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、神言を伝へさせ給ふ天皇陛下が、神であらせられるのは勿論のこと、更に、其勅を奉じて伝達する中臣、その他の上達部――上達部は元来、神に詰めてゐる団体人の意である――は、何れも皆、みこともちたる事によつて、天皇陛下どころか直ちに、神の威力を享けるのである。",
              "citation": {
                "source": "神道に現れた民族論理",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "また紅葉賀の試楽なども、「上達部、皇子だちも皆泣きぬ」と書かれてはいるけれども、何ゆえ泣いたかを肯かせるような描写は何もない。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "威儀正しい気品のある凛々しさがあふれ、古画に見る上代の旧上達部が、なにかの都合でこの世にたちかえってきたかと思われるほどであった。",
              "citation": {
                "source": "うすゆき抄",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の宰相頼定も、これがたたって、三条天皇の治世中は、殿上を遠ざけられ、半生、地下の上達部というばつの悪い地位にくすぶっていたようである。",
              "citation": {
                "source": "美しい日本の歴史",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "餘り仰々しくならないように、供の人数なども目立たぬ程にして参る、と云うことであったけれども、右大将定国、式部大輔菅根などゝ云った人々、―――いつも時平の腰巾着を勤める末社どもの顔ぶれを始め、殿上人や上達部が猶相当に扈従していて、平中も亦その中に加わっていた。",
              "citation": {
                "source": "少将滋幹の母",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、事のなりゆきを呆然と眺めていた公卿や上達部たちに声をかけた。",
              "citation": {
                "source": "少将滋幹の母",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして院が上達部や殿上人と御一緒に水飯を召しあがったという釣殿はどのへんにあったのだろうと右の方の岸を見わたすとそのあたりはいちめんに鬱蒼とした森が生いしげりそれがずうっと神社のうしろの方までつづいているのでその森のある広い面積のぜんたいが離宮の遺趾であることが明かに指摘できるのであった。",
              "citation": {
                "source": "蘆刈",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝには其一つとして、ものゝふ並びにかんだちめについて説かうと思ふ。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
