[
  {
    "uuid": "e90d5571-cce5-5fbf-bd10-3eff4df8061a",
    "entry": "から下手",
    "reading": {
      "primary": "からへた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
