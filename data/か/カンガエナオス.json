[
  {
    "uuid": "35abef58-f8a6-5a64-90f5-33529ef5dd1b",
    "entry": "考え直す",
    "reading": {
      "primary": "かんがえなおす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
