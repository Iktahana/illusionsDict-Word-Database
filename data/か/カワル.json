[
  {
    "uuid": "34e8d8d8-74b3-5a16-9ca3-c04c52bcc648",
    "entry": "変わる",
    "reading": {
      "primary": "かわる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
