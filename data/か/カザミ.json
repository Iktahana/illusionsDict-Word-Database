[
  {
    "uuid": "d359d853-a428-5cac-8f09-5e8daf83f068",
    "entry": "風見",
    "reading": {
      "primary": "かざみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "weather vane",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "屋根の上の風見がカラカラと音を立てて回り、これから天気が崩れることを予感させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よし、今の風見を見る限り、向かい風が強くなりそうだ。帆を少し絞って進もう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "少年は自作の風見を庭の杭に打ち付け、毎朝どちらの方向から風が吹いているかをノートに記録している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "飛行場にあるオレンジ色の吹き流しは、パイロットにとって最も信頼できるアナログな風見だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "虚無の鴉我れはもと虚無の鴉かの高き冬至の屋根に口を開けて風見の如くに咆號せむ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか知らねど萩原朔太郎なにか知らねど泣きたさにわれはゆくゆく汽車の窓はるばるときやべつ畑に日は光り風見ぐるまきりやきりりとめぐる日にわれはゆくゆく汽車の窓なにか知らねど泣きたさに",
              "citation": {
                "source": "なにか知らねど",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年九月三十日『東京朝日新聞』）　　　　　　　　　十　　　　　　新奇な風見鴉　これは倶楽部あるいは宿屋の室内に粧飾用を兼ねて据え置き、時々刻々の風の方向を知らせる器械である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "内部の仕掛けは簡単なものでただ屋根の上に備えた風見鴉から針金を引き電池一個を接続すればよい。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの烏の風見のある屋根の高い家の中に一人の画家がいるはずだ。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかたなしに風見の烏に相談しますと、画家は燕が大すきで燕の顔さえ見ると何もかもわすれてしまって、そればかり見ているからおまえも目につくように窓の回りを飛び回ったらよかろうと教えてくれました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこを風見の鷄が見てゐるのか冬の日のごろごろと※る瘠地の丘で　もろこしの葉が吹かれてゐる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこを風見の鷄が見てゐるのか冬の日のごろごろと※る瘠地の丘で　もろこしの葉つぱが吹かれてゐる。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくは彼等によって、文壇の風見が変るだろう。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十五年五月屋根の風見子を奪ろ、子｜奪ろ、鴻の巣の※に硝子が光る。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い燈が点く……向うの屋根に株の風見がくるくるまはる。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「南京さん」「屋根の風見」の二篇も七八年前に作つたのです。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根の風見子を奪ろ、子奪ろ、「鴻の巣」の窓に、硝子が光る。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸橋、荒布橋、青い燈が点く……向うの屋根に、株の風見がくるくるまはる。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごていしゅの像がほんの風見のにわとり代りにつかわれていました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "その風見は、小屋の戸にくっついていて、ごていしゅの風見がくるりくるりするとおりに、あいたりとじたりしました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と風見の鴉がくるりと廻って、少し北風が吹いて来る。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では一作目が風見潤によって訳され、『銀河ヒッチハイク・ガイド』として、一九八二（昭和五十七）年に新潮文庫から出ました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今回あらためて調べ直してみると、日本語版は風見潤訳で「銀河ヒッチハイク・ガイド」として、一九八二年十二月に新潮文庫から出ていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日むすびし若髮の解けがちにする風見ても、兄よ再び人妻の心化粧はいはずあれ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "風見係りの者が、いざと号令を懸けると、彼等は慌しい井戸換への連中のやうに綱を引いて一勢に駆け出すのである。",
              "citation": {
                "source": "鱗雲",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お婆さんが糸を巻くのは、もう風見の※さえ、羽交に首を突こんで一本脚で立ったまま、ぐっすり眠っている刻限でしたもの。",
              "citation": {
                "source": "ようか月の晩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁画のある、天井の高い大食堂の窓からは、灰色のうろこ形スレートぶきの小屋根、その頂上の風見の鳩、もと礼拝所であったらしい小さい四角い塔などが狭くかたまって見えた。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上には数知れぬ煙突や望楼や風見が聳え、ぐるりには傍屋だの来客用に建てたいろんな家屋だのの夥しく並んでいる白い石造の邸宅は、まるで宮殿のように見える。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがお前さん、その消えたり現れたりする所と云うのが、てっきりあの大矢車で――それも、クルクル早く、風見たいな回り方をしているように見えるんだよ」　と次第に、お筆の顔の伸縮が烈しくなって行って、彼女の述懐には、もう一段――いやもっと薄気味悪い底があるのではないかと思われて来た。",
              "citation": {
                "source": "絶景万国博覧会",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その――古風な風見が廻っている岬の一つ家には、痩せてひょろ高い浜草が、漆喰の割目から生え伸びているほどで、屋根は傾き塗料は剥げ、雨樋は壊れ落ちて、蛇腹や破風は、海燕の巣で一面に覆われていた。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の間からその庭の風見車が見えませう。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人は風見の鶏だつた。",
              "citation": {
                "source": "LOS CAPRICHOS",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "襦袢　源氏枕草子等に、かざみといへるもの字に汗衫と書くは即ちいまの襦袢なり。",
              "citation": {
                "source": "当世女装一斑",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの郷里の方で普通に取れます蟹は、俗にいばら蟹といいまして、甲の形がやや三角形になっていて、その甲や足に茨のような棘がたくさん生えているのでございますが、今晩のは俗にかざみといいまして、甲の形がやや菱形になっていて、その色は赤黒い上に白い斑のようなものがあります。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
