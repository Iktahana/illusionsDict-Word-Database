        "examples": {
          "standard": [
            {
              "text": "周期表は、すべての化学元素を原子番号の順に並べたものである。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "宇宙が誕生した当初、存在したのは水素やヘリウムなどの軽い化学元素だけだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "新しい化学元素の発見は、物理学と化学の歴史における大きな出来事だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この合金は、複数の化学元素を絶妙な比率で配合して作られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "純粋に理論的な研究（化学元素の周期律の研究など）の他に、木材から照明ガスの製法、古くなった絵の色を元に戻す方法など、種々の実用的研究を行った。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
