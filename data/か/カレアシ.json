[
  {
    "uuid": "2d65d09d-a288-5368-b1e7-d09a80635bd5",
    "entry": "枯葦",
    "reading": {
      "primary": "かれあし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "withered reeds (esp. reeds that have withered in the winter)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "冬の枯葦が風に揺れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "川岸には枯葦が密集していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "枯葦を燃やして暖を取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "枯葦の群落は冬の風景を彩る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "濕地には水芭蕉の青々とした廣葉が枯葦の間から、谷間には蕗の薹や福壽草が腐つた蕗の葉を蹴破つて、ずん／＼と延びて行く。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひ立つて山口へゆく、椹野川風景もわるくない、桜冬木、白梅紅梅、枯葦、枯草、ことに川ぞひの旧道は自動車が通らないのがうれしい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "洲には枯葦が淋しく凋落の影を示せてゐて、埃や芥もどツさり流寄ツてゐた。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁の一ヶ所に張り出たボツクスの上の几帳面な薄端に聖者風の枯葦とそれに献花してゐるやうな海竿三輪。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳河の街の子供はかういう時幽かなシユブタ（方言｜鮠の一種）の腹の閃きにも話にきく生胆取の青い眼つきを思ひ出し、海辺の黒猫はほゝけ果てた白い穂の限りもなく戦いでゐる枯葦原の中に、ぢつと蹲つたまゝ、過ぎゆく冬の囁きに昼もなほ耳かたむけて死ぬるであらう。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "つくづくと、うち見やる水、枯葦、まさしくもみ冬なり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "水は半ば凍り、泥濘も脛を没する深さで、行けども行けども果てしない枯葦原が続く。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兩岸の枯葦原に物凄い音を立てゝ風は鳴りはためいた。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯葦原に火を放つた。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "入江の渚幾里の枯葦、枯れに枯れた葦原に火を放つたのである。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯葦原の火は遠く燃え去つた。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳河の街の子供はかういふ時幽かなシユブタ（方言、鮠の一種）の腹の閃めきにも話にきく生膽取の青い眼つきを思ひ出し、海邊の黒猫はほゝけ果てた白い穗の限りもなく戰いでいる枯葦原の中に、ぢつと蹲つたまゝ、過ぎゆく冬の囁きに晝もなほ耳かたむけて死ぬるであらう。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲木、榛の林、掘切の枯葦、それに雪の野を描いたのもあった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "・風の枯葦のおちつかうともしない　晴れて風ふく草に火をはなつ　つつましく住めば小鳥のきてあそぶ　三月十三日　晴。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "追加　　　（伊豆海岸、信濃路、その他にて）また一枚ぬぎすてる旅から旅へ水の上はつきり春の雲はてなき旅の遠山の雪ひかるあれがふるさとの山なみの雪ひかる街の雑音しづもれば恋猫の月枯葦の一すぢの水のながれ春風のテープちぎれてたゞよふ手から手へ春風のテープ　三月一日　緑平居、雪、霜、霙。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・こどもに雪をたべさしたりしてつゝましいくらし・きたない池に枯葦の葉も大阪がちかい・春風の旗がはた／＼特別興行といふ・うらはぬかるみの、女房ぶりの、大根やにんじん・雲のゆききのさびしくもあるか　三月十一日ほつかり覚める。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづかな邸宅だ、雨乞山の巌壁もわるくない、水音がよい、枯葦もよい、小鳥が囀りつゝ飛んで、閑寂味をひきたてる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・父によう似た声が出てくる旅はかなしい今日はほんたうにうらゝかだつた、枯葦がびつくりしてそよいでゐた、私のやうに。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅か二三間先きに、枯葦の茂みを抜いて立っている杙があって、それに鴉が一羽止まっている。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは線路が、この辺一帯を蔽うている涯てしもない雑木林の間の空地に出てから間もない処に在る小川の暗渠の上で、殆んど干上りかかった鉄気水の流れが、枯葦の間の処々にトラホームの瞳に似た微かな光りを放っていた。",
              "citation": {
                "source": "木魂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたりは一面の荒涼たる枯葦原。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "合乗り乳母車　――仏蘭西縦断の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の端を描いた清親の板画は雪に埋れた枯葦の間から湖心遥に一点の花かとも見える弁財天の赤い祠を望むところ、一人の芸者が箱屋を伴い吹雪に傘をつぼめながら柳のかげなる石橋を渡って行く景である。",
              "citation": {
                "source": "上野",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯葦は一堪りもないわよ。",
              "citation": {
                "source": "命",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "背戸の柳緑の糸をかけそめて枯葦の間からぽつぽつ薄紫の芽がふく頃となれば、それ「雪は申さず先ず紫の筑波山」霞ゆえに遠くなって名詮自称霞が浦は一面春霞だ。",
              "citation": {
                "source": "漁師の娘",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに雪が降り出すと、空と湖と一かたまりになって、筑波処か、すぐ先も見えぬ位、ちらちらちらちら降って降って降りしきり、櫓の音もしなければ、鳥の声もせず、唯時々つもる雪の重みに枯葦のぽきぽき折れる音ばかりだ。",
              "citation": {
                "source": "漁師の娘",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　うるんだように白っぽく輝く空の下に、やや黄味を帯びた浅黄色の水面、金色のきらめく繊細な枯葦の上を、翼の淡紅色な鶴に似た鳥がゆるやかに円を描いて舞う光景が、暫く自分に我を忘れさせた。",
              "citation": {
                "source": "南路",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある干田の畔の枯葦の茂みで、ささきりが鳴いていた。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "土堤まで、背を没する高さの枯葦の中を行ってみたら、その先にも未だ白茶けた枯葦の洲が二十丁ばかりも予から海を遠ざけているのが見えた。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この雨が深くしみ込んで、よかれあしかれその後の生活に影響したような気がする。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれひとりの慾望から好き勝手な法を行った場合には、よかれあしかれ身体にくっついてしまって、どうしようもなくなるものだ。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
