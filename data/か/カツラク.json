    "definitions": [
      {
        "index": 1,
        "gloss": "sliding down (a slope, mountainside)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
