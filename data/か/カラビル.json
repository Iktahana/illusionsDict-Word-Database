        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長く使っていなかったペンはインクが乾びて、書けなくなっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "暑い日が続き、庭の土が完全に乾びてひび割れてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "畑の作物が乾びないように、朝夕の水やりは欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "コップに注ぎっぱなしにしていたジュースが、すっかり乾びてべたべたになっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "感情が乾びてしまって、何を見ても何も感じなくなってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一種の青臭い気が鼻に浸みて、それが為めに咽喉の乾びるのを感じた。",
              "citation": {
                "source": "暗い空",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく探して見たら直ぐ出て来るだろうと初めの中は思って、それほど心配はしなかったけれども、いくらそこいらを探しても、どうしても出て来ようとはしないので、だんだん心配になって来て、しまいには喉が干からびるほど心配になってしまいました。",
              "citation": {
                "source": "僕の帽子のお話",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この塩が干からびるように干からびてしまえ。",
              "citation": {
                "source": "春山秋山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "水玉という草に水をうって、涼しくかけたものだが、みんな一時のもので、赤くひからびるまではかけていない。",
              "citation": {
                "source": "大門通り界隈一束",
                "author": "続旧聞日本橋・その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地にしろ、草木にしろ、生物にしろ、乾からびるといふことは、養分がなくなることで、機能の衰退、死滅を意味します。",
              "citation": {
                "source": "戦争と文化",
                "author": "――力としての文化　第三話",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところどころ肉をむきだしにして転がるレモンは痛々しく、これを冷蔵庫に放置したなら、干からびるうち凄惨の気を帯びたりもして、正視に耐えない。",
              "citation": {
                "source": "鉄道模型の夜",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "残しておくと、日に当たって腐るか干からびるか分からないし、腹は減っていなくとも全部食べてしまったほうがいいな。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
