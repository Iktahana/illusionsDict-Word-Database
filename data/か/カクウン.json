[
  {
    "uuid": "9c519d66-5770-52aa-81f8-6b65d4dd22bf",
    "entry": "革運",
    "reading": {
      "primary": "かくうん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
