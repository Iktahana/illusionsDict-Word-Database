    "definitions": [
      {
        "index": 1,
        "gloss": "to cling to",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供は怖がって母親の足に掻き付いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "溺れそうになった男は、必死に浮木に掻き付いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "壁のわずかな突起に掻き付いて、彼はなんとか落下を免れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "悲しみに暮れる友は、私の腕に掻き付いて涙を流した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そのよしいさゝかものにかきつく。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史が前進しないものなら、過去の天才は文学のテーマをかきつくしてしまえたろう。",
              "citation": {
                "source": "新しい文学の誕生",
                "author": "――若い人に贈る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白きふし一ツ二ツかきつくべし。",
              "citation": {
                "source": "みちの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "御心ざしさきざきかきつくして、筆もつひゆびもたたぬ。",
              "citation": {
                "source": "尼たちへの消息",
                "author": "――よく生きよとの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その容子をぢろぢろ眺めながら、古法衣の袖をかきつくろつて、無愛想な頤をそらせてゐる、背の低い僧形は惟然坊で、これは色の浅黒い、剛愎さうな支考と肩をならべて、木節の向うに坐つてゐた。",
              "citation": {
                "source": "枯野抄",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ものかゝぬさうしをつくりてつねにかたへにうちおきてみきゝすること、おもひえたることどもを、わすれぬうちにそこはかとなくかきつくるれうのさうし」、「ことさらにかきあらはせりといふばかりのものならねば云々」という『松の落葉』の説は武藤氏によって引用され賛成されている。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬰寧は樹にかきつくようにして笑って歩くこともできなかったが、暫くしてやっとやんだ。",
              "citation": {
                "source": "嬰寧",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "「………そも／＼女人のやさしさ美しさ、絵にも文にもかきつくしがたく、何にたとえ何にくらべてか告げまいらせ候わん。",
              "citation": {
                "source": "二人の稚児",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to rely on",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "困難な状況で、彼は唯一の頼りである兄に掻き付いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最後の望みとして、彼女は神に掻き付くように祈った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "病気の母親は、成長した息子に掻き付くように生活の全てを任せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "窮地に陥った際、人は誰かに掻き付きたくなるものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "to obtain something after badgering someone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は部長に何度も掻き付いて、ようやく長期休暇の許可を得た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "粘り強く頼み込んで、先生から参考書を掻き付くことができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの手この手で親に掻き付いて、新しいゲーム機を買ってもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は取引先に毎日電話をかけ、やっと契約を掻き付いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
