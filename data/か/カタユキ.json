        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝早く、登山道は堅雪で覆われ、アイゼンなしでは歩けないほどだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "日中の日差しで表面が少し溶け、夜間に凍って堅雪になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スキー場では、新雪の下に堅雪の層があり、滑りにくい箇所があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「堅雪かんこ、しみ雪しんこ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「堅雪かんこ、凍み雪しんこ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくしいんとしましたので二人はも一度叫ぼうとして息をのみこんだとき森の中から「凍み雪しんしん、堅雪かんかん。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「凍み雪しんこ、堅雪かんこ、　　　野原のまんじゅうはポッポッポ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "凍み雪しんこ、堅雪かんこ、　　　野原のおそばはホッホッホ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「堅雪かんこ、凍み雪しんこ、鹿の子ぁ嫁ぃほしいほしい。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「堅雪かんこ、凍み雪しんこ、しかの子ぁ嫁ほしい、ほしい。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで四郎とかん子とは「堅雪かんこ、凍み雪しんこ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "堅雪かんこ、凍み雪しんこ、狐の子ぁ嫁ぃほしいほしい。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「堅雪かんこ、凍み雪しんこ、硬いお餅はかったらこ、白いお餅はべったらこ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キックキックトントンキックキックトントン　凍み雪しんこ、堅雪かんこ、　　　　　野原のまんじゅうはぽっぽっぽ　酔ってひょろひょろ太右衛門が　　　　　去年、三十八たべた。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キックキックトントン、キックキック、トントン、　凍み雪しんこ、堅雪かんこ、　　　　　野原のおそばはぽっぽっぽ、　酔ってひょろひょろ清作が　　　　　去年十三ばい喰べた。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……何しろ深い谷の底のことではあるし、堅雪にはなっていたが、上部の解けた所に踏みこむと胸まで埋まるくらい積もっているのだから、先生にはどうしていいか分らなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小十郎はまっ白な堅雪の上を白沢の方へのぼって行った。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくしいんとしましたので二人はも一度叫ばうとして息をのみこんだとき森の中から「凍み雪しんしん、堅雪かんかん。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「凍み雪しんこ、堅雪かんこ、　　　　野原のまんぢゅうはポッポッポ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "凍み雪しんこ、堅雪かんこ、　　　　野原のおそばはホッホッホ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
