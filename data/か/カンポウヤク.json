        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この絢尭斎というは文雅風流を以て聞えた著名の殿様であったが、頗る頑固な旧弊人で、洋医の薬が大嫌いで毎日持薬に漢方薬を用いていた。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その話をきいて、又別の年長の友達が私に一つの漢方薬を教えてくれた。",
              "citation": {
                "source": "鼠と鳩麦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に漢方薬のことについては、さまざまな専門的知識が織り込まれる。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の一方の壁一面にある戸棚には、各種の漢方薬がはいっている。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "階下は周夫妻の住居だが、一部を、漢方医局か或は漢方薬局かにしたい。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "根は山帰来という漢方薬ですが、併かし本当のサンキライではありません。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはつよい匂いのする漢方薬でね、まっ黒の汁が出て、ヤレと思いましたが、案外にのめます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢方薬の効能はトルレスたちにも認められた。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢方薬をすゝめて置いた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに胃の具合わるく、漢方薬二度服む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
