[
  {
    "uuid": "220c7a8a-7e2e-539d-bfe9-67ce7f5eb5f6",
    "entry": "片をつける",
    "reading": {
      "primary": "かたをつける",
      "alternatives": [
        "カタをつける"
      ],
      "is_heteronym": false
    },
    "grammar": {
