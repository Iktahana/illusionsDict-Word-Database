        "examples": {
          "standard": [
            {
              "text": "「あちゃー、野良猫をなでようとしたら結構深い噛み傷になっちゃった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この噛み傷、牙の跡が二つ並んでるから蛇かもしれないよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ドッグランで他の犬と喧嘩して、耳に痛々しい噛み傷を負っていた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ある時その道士が自分の着衣を何ものかにひどく噛み傷つけられてゐたことがあつた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここには蚤が全然いなかったが、すでに身体中に無数の噛み傷を受けていた私にとって、これは実に大なる贅沢であった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
