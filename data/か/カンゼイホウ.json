        "examples": {
          "standard": [
            {
              "text": "関税法は、輸出入貨物の通関手続きや関税の徴収について定めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "不正な輸出入を取り締まるため、税関は関税法に基づいて厳格な検査を行う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "海外から商品を個人輸入する際も、関税法の規定を理解しておく必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "関税法違反で告発された場合、重い罰則が科される可能性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "いつだつたか、同国の政府が、外国産の果樹を成るべくどつさり移植して、かうした果物の供給で、余り外国に金を払ひたくないといふので、外国産の果樹輸入は無税にするといふ海関税法を拵へた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
