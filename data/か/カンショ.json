    "definitions": [
      {
        "index": 1,
        "gloss": "government office",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "住民票が必要なので、明日は市役所の官署へ行こう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その書類は、複数の官署を経由して承認されるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は官署での長年の勤務を経て、先日定年退職した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ドュフランは官署へ出かけて行って警視長官チアベと向い合った。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は官署とか学校や先生とかいうものに無上の権威を感じ、何か阿諛の服従を以て迎えるという性質がありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中でも五〇万冊の本をすっかり焼いた帝国大学図書館以下、いろいろの官署や個人が二つとない貴重な文書なぞをすっかり焼いたのは何と言っても残念です。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「制芸を知っておりますか」　陸は、「よしあし位は知っておる」　と言って文章の談をし、それから冥途の官署の談をしたが、ほぼ現世と同じだった。",
              "citation": {
                "source": "陸判",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞記者をして居たとき、諸官署などの大きい建物の階段を駈け上ると、目ざす人の部屋へ通されても、息がはずんで、急には話を切り出すことが、出来ないことなどもあった。",
              "citation": {
                "source": "マスク",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の秋郷里の名古屋から上京して來たとかで亭主は目下某官署の腰辨を勤めて居るのである。",
              "citation": {
                "source": "一家",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日どこへ出かけるのか、古い友だちのつとめてゐる官署を訪ねて、普通の調子で話をして来るらしい。",
              "citation": {
                "source": "現代詩",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に官署から命令あらば骨折つて鑑定するのも面白いが、大概の場合には此種の勞して效なき事項は駄目であるの一言で早速逃げるのが賢いのである。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした官署へ告発すべく、内容が余りに怪奇で、曖昧で、確証が少しもないのだ。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "営口は遼河の河口左岸に位置し、清末に鎮海営と云ふ官署を置いたので「営子口」と名づけた地名が営口と略称せられたのである。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅の東南は一段の高地で新市街と呼ばれ、比較的閑雅な官署、銀行会社、中流人の住宅地になつてゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、砲兵工廠と大宮工場とは、労働運動の中心で、片山潜、高野房太郎などいふ指導者の名は、官署や会社の方面へは、蛇蝎のやうに響いて居た。",
              "citation": {
                "source": "幸徳秋水と僕",
                "author": "――反逆児の悩みを語る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処にては、衣の襟に一々番号札を縫ひ付け、姓名を言はずして第何番と呼ぶこと、官署の規則なり。",
              "citation": {
                "source": "鉄窓の歌",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは翌八月十日に至って統計寮と改められたが、官署の名に「統計」の名を附したのはこれが初めてである。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるほどに期限迫りて、果てはわが勤むる官署にすら督促のはがきを送らるる始末となりたれば、今はやむなくあたかも帰朝せる武男を説き動かし、この三千円を借り得てかの三千円を償い、武男の金をもって武男の名を贖わんと欲せしなり。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで京都の大きな官署を始め、有力なる社寺にも、大きな町村にも、大抵はこれを付属せしめて置いた。",
              "citation": {
                "source": "エタに対する圧迫の沿革",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都付近でこれまで小屋者と言われていた悲田院の部落のものの中で、今日なお特殊部落として認められているものは、僅かに柳原の一部に住んでいるもののみで、一般民からはなお多少の区別をするのがあっても、今は官署の統計上にもその別は認めておらんのであります。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "空地の多い、そしてまだ、あまり多く世間から嫌われなかった時分には、勝手に新村を作ることも出来たであろうし、官署の認可を得る事も容易であったのであろうし、ことに必要上彼らを優待して移植したという場合も少くなかった。",
              "citation": {
                "source": "特殊部落と細民部落・密集部落",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは各地に分散定住していたのみならず、京都の大きな官署内にも寓居して、雑工・駆使・掃除等に従事していたことは、大学寮の古図に余戸の一区が画されているのによって察せられる。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの官署付属の余戸は、朝廷の紀綱が弛んで、官署頽廃に帰するに及んで、自然その職を失い、主鷹司の餌取が取ったと同様の運命に陥る事は、けだしやむをえなかった。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意に一つの官署へ来た。",
              "citation": {
                "source": "連城",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大地震の発光は、他の事項と共に中央気象台その他の気象官署及び水路部によって調査されたが、前者の完全な調査報告はまだ出版されていない。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時（一八七七年）にあってすら、既に、軍隊の現代的調練、公立学校の広汎な制度、陸軍、財政、農業、電信、郵便、統計等の政府の各省、及び他の現代的行政の各官署といったような変化は起っていて、東京、大阪等の大都会には、これ等新制の影響が僅かに見られた。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "城内にある軍務司長官署へ着いたのは八時頃だった。",
              "citation": {
                "source": "雲南守備兵",
                "author": "木村荘十",
                "note": "青空文庫"
              }
            },
            {
              "text": "大分騒ぎましたけど官署のやることをどうにもなりはしませんや。",
              "citation": {
                "source": "雲南守備兵",
                "author": "木村荘十",
                "note": "青空文庫"
              }
            },
            {
              "text": "“鉱山の経理が云ったことは本当だ”　あの雲南府の官署で、荷物を持って行った副官の妙な態度も、左遷だと思ったのが、大佐にとってはなるほど吉報だった訳も初めて分ったのだ。",
              "citation": {
                "source": "雲南守備兵",
                "author": "木村荘十",
                "note": "青空文庫"
              }
            },
            {
              "text": "でかんしょ、でかんしょと、山家の猿は、ヨイヨイ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨウイヨウイ、でっかんしょ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "でかんしょ、でかんしょで、半年ゃ暮らす、ヨイヨイ、あとの半年ゃ寝て暮らす。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺縮みの着物に、手拭のように細いくたびれた帯をくるくる巻いて、かんしょうに爪をよく噛んでいた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
