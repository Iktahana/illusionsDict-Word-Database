        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古来より、関雎の歌は夫婦の理想的な関係を表すものとされてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "結婚式の祝辞で、新郎新婦の関雎を願う言葉が述べられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若い二人の間には、まるで詩歌に詠われる関雎のような慎ましくも美しい愛情が育まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "――「関雎の詩は歓楽を歌っているが、歓楽におぼれてはいない。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "」○　関雎＝＝詩経中の名篇だといわれている詩。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「楽師の摯がはじめて演奏した時にきいた関雎の終曲は、洋々として耳にみちあふれる感があったのだが――」○　摯＝＝魯の楽官ですぐれた音楽家であつた。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　関雎＝＝詩経の中にある篇の名。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "関雎は楽しんで淫せず、と古人のお言葉にありますが、大雅の声というものが、あれなんだろうと思われました、太古の民が地を打って歌い、帝力何ぞ我にあらん、と言った泰平の気分があの唄なんだろうと、わたくしは実に感心して聞き惚れていましたのに、それが半ばからすっかり壊れてしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "でかんしょ、でかんしょと、山家の猿は、ヨイヨイ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨウイヨウイ、でっかんしょ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "でかんしょ、でかんしょで、半年ゃ暮らす、ヨイヨイ、あとの半年ゃ寝て暮らす。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺縮みの着物に、手拭のように細いくたびれた帯をくるくる巻いて、かんしょうに爪をよく噛んでいた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
