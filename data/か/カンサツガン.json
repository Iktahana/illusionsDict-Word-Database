[
  {
    "uuid": "e40e98cf-0679-51a2-a6ab-bccb629683db",
    "entry": "観察眼",
    "reading": {
      "primary": "かんさつがん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
