    "definitions": [
      {
        "index": 1,
        "gloss": "a disgrace (to a whole group of people)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「仲間を裏切って自分だけ逃げ出すなんて、男の風上にも置けない奴だ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "弱者をいたぶるような卑劣な真似をする者は、武道家の風上にも置けない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おい、そんな不正をして勝って嬉しいのか？ 職人の風上にも置けないぞ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "平然と教え子を騙すような真似をするなんて、教育者の風上にも置けない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「諸人の害をなす狸を退治いたそうと思いまして」「たわけ者、狸と姫と区別ができないか、武士の風上にも置けない奴、せいばいして姫の仇を執ってやる」　国主は徒者の一人に持たしてある刀を執って、それをすらりと抜いた。",
              "citation": {
                "source": "村の怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気分だけは大変な芸術と取組んでいるつもりでも、ろくに腕も立たず、障子一枚、棧一つ削れない奴が、仏像を作ろうとしてもうまくゆくはずがない、職人の風上にも置けない奴だということになる。",
              "citation": {
                "source": "映画界・小言幸兵衛",
                "author": "―泥棒しても儲ければよいは困る※―",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く風上にも置けない連中だよ。",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう人物は万事信用のおけない人間で、公明正大な日本人の風上にも置けない人間だ。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋音楽などやる奴は風上にも置けないと思っていた。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前、常磐の前を詮議中、伯父のくせに、しかも源家の恩顧を蒙っているくせに、六波羅へ密訴したかどで、その後は取立てられて、四、五十名の侍を飼い、肩で風を切って歩き、いよいよ平家の問罪所へ、忠義立てているという風上にも置けない代物だ。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
