        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その柔道家は、師匠からの厳しく可愛がりを受けて、強くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「試合に勝つためだ」と言って、監督は選手たちを徹底的に可愛がり続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "伝統芸能の世界では、入門したての弟子に厳しい可愛がりがあるという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
