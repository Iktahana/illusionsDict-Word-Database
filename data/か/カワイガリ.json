    "definitions": [
      {
        "index": 1,
        "gloss": "doting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖父母の過度な可愛がりで、孫はわがまま放題になってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ペットへの可愛がりがエスカレートし、人間の子供のように扱っている人もいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あれもこれも買ってあげる」という両親の可愛がり方に、本人はうんざりしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "あなたは、ふだんからどうもこの雀を可愛がりすぎます。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんを可愛がりすぎるのも見ちやをられないものだが、あんなに無愛想なのもよろしくない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは私にも解らんよ」「そうで無えだ、先生のような人は誰でも可愛がりますぞ。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "母というはお豊といい、言葉の少ない、柔和らしく見えて確固した気象の女でしたが、僕を叱ったこともなく、さりとて甘やかす程に可愛がりもせず、言わば寄らず触らずにして居たようです。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんは、僕が八つの時から、お父さんの身代りになって僕を可愛がり、導いて下さった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしがどんなわがままを言っても、また、いけない事をしても、お母さんは一度もお叱りにならず、いつも笑ってあたしを猫可愛がりに可愛がっていらっしゃる。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのやうにお心ばえのうるはしい御台所さまでございましたから、あのお強い御気性の尼御台さまも、この御台所さまをお可愛がりなさる事ひとかたでなく、どこへおいでになるにもお連れになつて、お互ひ実の御親子以上にお打解けられ末しじゆう御睦じくして居られたやうでございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんの言に依れば、Ｎ君は可愛がりすぎる傾きさへあるさうだ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は私を非常に可愛がりました。",
              "citation": {
                "source": "薬指の曲り",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰でも可愛がるよ、可愛がりますともさ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう男達は大方老人でなかに若い男があっても矢張り彼女を娘の様に可愛がり出す。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルコ兵はこの罪もない片輪ものに、そんな暴虐をしたことを悔い、神の罰をさけるために、これまでよりもなほ一倍、彼をあはれみ可愛がりました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お貞が二人の子供を実子のように可愛がり、また自慢するのが近処の人々から嫌われる一原因だと聴いていたから、僕はそのつもりであしらっていた。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「駄賃取りの娘、大学校を卒業した人、三郎さんは大家の可愛がり子息、自分は小作人の娘」お小夜はただ簡単にそんな事を口の内で繰り返す。",
              "citation": {
                "source": "新万葉物語",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりは、政吉の方では、師匠と私とが大変に気心が合い、師匠は何事につけても、幸吉々々と弟弟子の私をまず先に立て仕事もさせれば、可愛がりもしましたばかりでなく、徴兵の一件などにも力瘤を入れて尽力されたことなどが、彼に取っては面白く思わなかったのも人間としては無理ならぬことと思われます。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "東雲師逝去のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "白鷹の奥さんも、やっぱり妾たちとオンナジ気持で、あの娘をお可愛がりになったに違いない事が、今やっとわかったのよ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は皆この白髪小僧を可愛がり敬い、又は気味悪がり恐れておりました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから非常に可愛がりました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "抱車夫を入れます時に『あの男おかみさん可愛がりますか』と尋ねます。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでもまあ、手前えのやうなビツコでも好興なお方もあつたもので、わざ／＼東京から可愛がりに来て呉れるとは……」　祝ひ酒でほのぼのとした若者は、そんな冗談を呟きながら老馬の背中に鞍をつけてゐた。",
              "citation": {
                "source": "夜見の巻",
                "author": "「吾が昆虫採集記」の一節",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその父親と言うのが、これが又無類の子煩悩で何かにつけてもトヨやトヨやと可愛がり、歳柄もなく娘が愚図り始めた時などは、さあもう傍で見る眼も気の毒な位にオドオドして、なだめたりすかしたりはては自分までポロポロと涙を流して「おおよしよし」とばかり娘の言いなり放題にしているとの事。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り可愛がり過ぎたもんだで……」「だから、子供を育てるのも、容易には出来ねえだ」　と他の老婆は言葉を合せた。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "先程の老婆の言ふ所によれば、祖父様が悪いのだ、あまり可愛がり過ぎたから、それで彼様な風に為つたのだと言ふけれど、単に愛情の過度といふのみで、それで人間が、己の故郷の家屋を焼くといふ程の烈しい暗黒の境に陥るであらうか。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "母様はますますあなたを可愛がり、あなたもますます母様に尽したのでした。",
              "citation": {
                "source": "少年・春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も一生懸命であなたをかわいがりますわ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンネ・リスベットは、この赤ちゃんを、心から、かわいがりました。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供のないさびしい人や自分の思うままになる愛撫の対象を人間界に見失った老人などがひたすらに猫をかわいがり、いわゆる猫かわいがりにかわいがる心持ちがだんだんにわかって来るような気がした。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子は、心のすなおな、かわいいこどもをかわいがるように、ひいさまをかわいがりました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、あなたをかわいがりました。",
              "citation": {
                "source": "誓之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜も昼もおかわいがりにばかりなって、いつまでも幼児であるように宮はお扱いになるのであったから、そこでは勉学ができないであろうと源氏が認めて、学問所を別にして若君を入れたわけである。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
