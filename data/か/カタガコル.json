      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to have stiff shoulders",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長時間パソコン作業で、肩が凝って辛い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "マッサージに行ったら、ひどく肩が凝っていると言われたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あー、もう肩が凝って肩が凝って！」と彼女は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "冷たい風に当たってから、肩が凝ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "アカシヤの樹の下には、カギをつけた長い竹竿で、子供達が、白い藤のような花を薄暗い街燈にすかして、もぎ取ろうと肩が凝るほど首を上に向けきっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、このごろまた、ブランドを読み返しているのだが、どうも肩が凝る。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はよく肩が凝ると言ふ方でして、銀さんと私とが叩かせられたものですが、肩一つ叩くにも只は叩かせませんでした。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく肩が凝るという父の背後へ廻って、面白くも可笑くもない歴代の年号などを暗誦させられながら、「享保、元禄……」とまるで御経でもあげるように父の肩につかまって唱えたり叩いたりしたあの書院の内を記憶でまだ見ることも出来た。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、女たちはよほど嬉しいのだらう、「肩が凝るでせうね、揉んであげよう」と、おかみさんは油を注いでくれる青年の肩に手をかけたりした。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔しながらの薄着で、肩が凝ると言つて襯衣は決して着ないから、襦袢の白い襟の間から茶褐色に痩せた斑點のある肌が見えてゐた。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　血圧が高いと肩が凝るものかどうか、その説明の代りに、あなたは高木君の方へ炬燵半分ほど体をずらせ、その手を執って、懐から肩へと持ちこんでしまいました。",
              "citation": {
                "source": "未亡人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、血圧が高そうだとか、肩が凝るようだとか言って、相手の手を懐に引き入れるなんて、ばかばかしいことをしたものですね。",
              "citation": {
                "source": "未亡人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩が凝ることがそれほどいやなら、その時は本など読まず、歌でも唱ふがいゝのです。",
              "citation": {
                "source": "戦争と文化",
                "author": "――力としての文化　第三話",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の忠寛は体格の大きな、足袋も図無しを穿いた程の人で、よく肩が凝ると言っては、庭先に牡丹の植えてある書院へ呼ばれて、そこでお種が叩かせられたもので、その間に父の教えたこと、話したことは、お種に取って長く忘れられないものと成った。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「叔父さん、今｜何事も用が有りませんが、肩が凝るなら、按摩さんでもして進げましょうか」「沢山」「すこし白髪を取って進げましょうネ」「沢山」「叔父さんは今日はどうかなすって？",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていくら長く仕事を続けましても決して肩が凝るナンテ事はありませんから、按摩は全く私には無用の長物です。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ときくと千代子は事もなげに、「肩が凝るから当分おやめよ。",
              "citation": {
                "source": "心づくし",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "……貴女は女無理して歩いて、さて旅籠へ着いてから、ソレ按摩じゃ、ヤレ灸じゃと、泣顔をして騒がれても、拙者決して取り合いませぬぞ」「貴郎様こそ旅籠に着かれてから、くるぶしが痛めるの肩が凝るのと、苦情めいたこと仰せられましても、妾取り合わぬでござりましょうよ。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからどことなく聴いていて肩が凝る。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「気の毒なことだね、――急に亡くなったのかい」「ヘエ、――あんまり急で、涙も出ません、ヘエ――」「平常から弱かったのかい」「とんでもない、丈夫が自慢の主人で、時々肩が凝るほかには、風邪一つ引いたことのない方でございます」　平次はズイと寄りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "百四十四夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "――眼の見えないお前に、そんなことが出來るのか」「あの板壁には、大きな割れ目があり、谷五郎親分を揉みに行くと、そこから風が入つて、寒くて弱りました」「谷五郎はあの若さで按摩なんか呼ぶのか」「あの人は癇症で、ひどく肩が凝るさうで時々私が揉みに參ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "敵の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩が凝るということが、全然なくなった。",
              "citation": {
                "source": "老人と鳩",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふこと、考へるだけで肩が凝る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の幕間に、なじみの易者久保田光山来り、肩が凝ると言ったら、お灸もやると、四所へ熱い灸を据えられた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂言四つ、実がありすぎて肩が凝る、音楽のない悲しさ、全く致命的である。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せがれの又八を尋ね、武蔵のありかを捜し歩いているのじゃ」「すこし脚でもお揉みいたしましょうか」「脚はさほどでもないが、陽気のせいか、この四、五日は肩が凝る。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to feel ill at ease",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "初めてのパーティーで、どう話したらいいか分からず、肩が凝ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼と二人きりで話すのは、いつも少し肩が凝るんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議の空気が重くて、みんな肩が凝っているのが伝わってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「大丈夫だよ、リラックスして」と言われても、なんだか肩が凝ってしまって。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "serious",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの件、どうなったんだろうね。なんだか心配で肩が凝るよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "納期が迫っているのに、この進捗では本当に肩が凝る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "親の病状を聞いて、とても肩が凝ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この裁判の行方で、多くの人の運命が決まる。まさに肩が凝る話だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
