[
  {
    "uuid": "6fdd38b3-1d4d-5253-989c-a3076e94d497",
    "entry": "肩が凝る",
    "reading": {
      "primary": "かたがこる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行"
      ],
