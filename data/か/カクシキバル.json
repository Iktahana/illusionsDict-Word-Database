        "examples": {
          "standard": [
            {
              "text": "「そんなに格式ばらずに、もっと楽な格好で遊びに来てくださいよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "同窓会なのに、彼一人だけが格式ばった挨拶を始めたので会場が少し冷めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "格式ばるのが苦手な彼は、ネクタイを締めなくていい職場を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "会議の冒頭であまりに格式ばった表現を使うと、若手社員が萎縮してしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「いやに格式ばるじゃないか」「馴染み客でないとあげないんだ」と弥十郎が友達に説明した、「その代り静かだよ」　あの座敷ではなく、べつの八帖にとおされた。",
              "citation": {
                "source": "屏風はたたまれた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
