        "examples": {
          "standard": [
            {
              "text": "寒冷地の農作業では、防寒のために耳まで隠れる兜頭巾が長く愛用されてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おばあちゃん、その兜頭巾を被ると雪ん子みたいで可愛いね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "時代劇のエキストラが、夜道を行く浪人役で兜頭巾を深く被って佇んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "革羽織、兜頭巾の火事｜装束をした人たちはそれらの火消し人足を引きつれて半蔵らの目の前を通り過ぎた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "数右衛門は敵の前に背を曝したのであったが、その背に当ったのは、氷柱であって、平八郎の切っ先は、彼の兜頭巾の錣を斬って、肩の辺りでカチンと刎ねた。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
