    "definitions": [
      {
        "index": 1,
        "gloss": "to worsen (the situation)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "正論を振りかざすのは勝手だが、伝え方を間違えると余計に周囲との角を立てることになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今はあえて何も言わず、角を立てないのが一番の解決策だ」と部長に諭された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は些細な言葉尻を捉えては角を立てる性格なので、チーム内では少し敬遠されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "宅と来た日にや、すぐ眼に角を立てるんですからね。",
              "citation": {
                "source": "隣の花",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "人斬庖丁を中にお国者が眼に角を立てるんだから、この席上に間違いの端を発したのも、あながちいわれがないでもない。",
              "citation": {
                "source": "寛永相合傘",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "といっても、奥さん方は、何も眼に角を立てる必要はない。",
              "citation": {
                "source": "パーティ物語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先手を打たれたくやしまぎれに、つまらぬけちをつけてもらうまいよ」「いや、そうまあがみがみとことばにかどをたてるもんじゃござんせんよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
