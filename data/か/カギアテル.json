        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "刑事は微かな手掛かりから犯人の潜伏先を嗅ぎ当てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新商品の売れ行きを嗅ぎ当て、すぐに発注をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は常に新しいビジネスチャンスを嗅ぎ当てる才能がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし我々は犬の言葉を聞きわけることが出来ませんから、闇の中を見通すことだの、かすかな匂を嗅ぎ当てることだの、犬の教えてくれる芸は一つも覚えることが出来ません。",
              "citation": {
                "source": "白",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの本能的な嗅覚は、常に好餌のある場所を嗅ぎ当てる。",
              "citation": {
                "source": "鰻の話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は無論、その目的を訝しむほどの世間知の持ち合せはなかつたが、一種の本態によつて、嗅ぎ当てるべきものだけは嗅ぎ当ててゐたのである。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "十歳の少年にとつて、それがなんの臭ひかを嗅ぎ当てることは、大してむづかしいことではない。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "神社の表カンバンの祭神ではなくて、横ッチョに小さく祀られている陰の神サマ、そして恐らく本当の祭神たる神サマをかぎあてるためであった。",
              "citation": {
                "source": "飛騨の顔",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
