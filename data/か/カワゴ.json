    "definitions": [
      {
        "index": 1,
        "gloss": "baskets wrapped in paper, bark or skin",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "蔵の奥から、先祖が旅に使っていたと思われる漆塗りの古い皮籠が出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史資料館には、保存状態の良い大名行列用の立派な皮籠が展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この皮籠、中には一体何が入っているんだろうね」と祖母と顔を見合わせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "時代劇の撮影現場で、役者が重そうな皮籠を担いで宿場町を歩いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "腰の皮籠には用意の獣の乾肉があるので空腹は気にしなかった。",
              "citation": {
                "source": "赤い土の壺",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の障子の上に、ちひさき棚をかまへて、黒き皮籠三四合を置く。",
              "citation": {
                "source": "方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "御部屋の中には皮籠ばかりか、廚子もあれば机もある、――皮籠は都を御立ちの時から、御持ちになっていたのですが、廚子や机はこの島の土人が、不束ながらも御拵え申した、琉球赤木とかの細工だそうです。",
              "citation": {
                "source": "俊寛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯母さんはまた草紙で丹念にはつた皮籠からいろいろな玩具をだして遊ばせてくれる。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮籠には山崎合戦の戦道具のほかにおもちやもはひつてたが、なかにも鼓と笙の笛は秘蔵の宝ものであつた。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが自分の深くも心を打ち込んだ人の物を入れてある容器かと思うと、直ぐには蓋を開けるのが惜しい気がして、なおよく見ると、普通にあるような皮籠ではなくて、金色の漆の塗ってある立派な筥であった。",
              "citation": {
                "source": "少将滋幹の母",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
