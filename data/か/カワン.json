        "examples": {
          "standard": [
            {
              "text": "転倒した際、下腕を強く地面に打ちつけてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の引き締まった下腕からは、日頃の鍛錬がうかがえる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重い荷物を持ち上げた時、下腕の筋肉がぴくりと動いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "人間はそれぞれの明白な心の目標があって、それに向かわんために充分納得して寒苦と戦っているが、犬はなんのためだか、ちっともわからないで、ただたよる主人の向かう所なら、さもうれしげに死の雪原に突進するのである、犬でもやはり苦しくなくはないであろう。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の歓心をかわんがためである。",
              "citation": {
                "source": "メリイクリスマス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜銭もつかわんで、ごっそりためておいて、大きな倉でもたてるつもりかや。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰ぞかわんなはらねえかって、艫からドンと飛下りただ。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が立ちし日には、いつになく独りにて燈火に向かわんことの心憂さに、知る人のもとにて夜に入るまでもの語りし、疲るるを待ちて家に還り、直ちにいねつ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "古のギリシャにあこがれの誠をいたすにつれ、今のギリシャの悲境を見るに見かねて、これが救済に馳せ向かわんとした情熱の人詩人バイロンに、風※において性行において大いに類似を示した兄には、そうした大志を自分はいかにもふさわしく考えるのである。",
              "citation": {
                "source": "茶の本",
                "author": "はしがき",
                "note": "青空文庫"
              }
            },
            {
              "text": "久慈い――おあとが閊えているよ、早くかわんな」　それを聞くと久慈恵介はきゅうに全身で真赤になった。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "領主　それではもうよいではないか（とまた窓に向かわんとするを従者は再び引きとめ）、従者　たとえ、女子の性質はよいと致しましても、お殿様の御性質お振る舞いを近頃のように変えさせますれば、何のためにもなりませぬ。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父中将は浪子が逗子に来たりしより間もなく、大元帥｜纛下に扈従して広島におもむき、さらに遠く遼東に向かわんとす。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つかわんまでも、相良どのは、たいそうな金持ちであったはずじゃ」「いいえ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜お母さんからお手紙で（三日づけ）お菓子も写真も私の手紙も一どきについて、お菓子は大変めずらしいから、お客膳のなかわんにもって出しますということです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたがそないに気をつかわんでも、ちょうどよかったんだから。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一斉に上に向かわんとする広大なる力は、人類の各事実を整理して、一定の時間を経れば、合理的なる状態、すなわち平衡なる状態に、すなわち公正なる状態に、すべてを導くであろう。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は、敵の先鋒へ立ちむかわん」　と、決意を告げた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
