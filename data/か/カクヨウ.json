[
  {
    "uuid": "2728eb38-b2df-57ca-b4b7-3aab42be44d1",
    "entry": "各様",
    "reading": {
      "primary": "かくよう",
      "alternatives": [
        "おのおのさま"
      ],
      "is_heteronym": false
    },
    "grammar": {
