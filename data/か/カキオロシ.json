[
  {
    "uuid": "b60f3c03-b531-5947-92ab-c381cf4a8540",
    "entry": "書き下ろし",
    "reading": {
      "primary": "かきおろし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "original (written) work (i.e. a new novel, play, music, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この文庫本には、単行本未収録の書き下ろし短編が特別に収録されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "あの劇作家の書き下ろし新作が見られるなんて、演劇ファンとしてはたまらないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雑誌の連載をまとめつつ、最後に書き下ろしのエッセイを加えて一冊の本にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "僕は意気地のない話にも、この自分で書き下ろした芝居の恋に、たあいなく溺れてしまったのだ。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れも純粋の意味に於ける詩として書き下ろしたので無い。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "知り合いの編集者から、「情報技術に関連した書き下ろし文庫の一冊を任せたい」とチャンスを与えられたときも、技術そのものではなく、技術と人、技術と社会について考えたいと思いました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き下ろし文庫の『パソコン創世記』の定価は三百九十円で、印税率は慣例通りの十パーセントでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八五年二月に書き下ろし文庫で出した途端、旺文社文庫その物が出版取りやめとなって、哀れな末路をたどった本だ。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻頭に置いた『崩れる鬼影』は昭和八年、博文館から創刊された少年科学雑誌「科学の日本」に書き下ろしたものである。",
              "citation": {
                "source": "『地球盗難』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は翌昭和三年に、処女作の探偵小説『電気風呂の怪死事件』を書いたが、その作以前に、実は科学小説三篇を書き下ろしていたのである。",
              "citation": {
                "source": "『地球盗難』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなとき、なにやかやと話し込むことの多かった編集者が、情報絡みの書き下ろし文庫シリーズの一冊を任そうかと声をかけてくれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『パソコンビジネスの巨星たち』はこの連載のうち、スキャネル氏の執筆分の中からメジャーどころを集め、書き下ろしを加えて構成されている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを下ろして、湯沸しの水を硯にたらして、ちび筆を、うつくしい前歯で噛んだが、ふところ紙に、金釘流ながら、スラスラと書き下ろした文句――お坊さん、左様なら、おまえさんが、島にしんぼうできなかったとおなじこと、あたくしも、あなぐら住居は、いや、いや、いや。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ラジィゲの詩はどうも譯しにくいし、譯しても效果のないものが多いやうに思ふので、これは二三篇に止どめ、その代り、リルケが佛蘭西語で書いた詩を、書き下ろし（？",
              "citation": {
                "source": "ランプの下で",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただおもう、私は、この厄払いじみた台詞こそ、じつに書き下ろし当時芝居噺の当時の残り香なのではなかろうか、と。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀部安兵衛が、この家のかんばんを達筆に書き下ろしたものが、また名うてゞある。",
              "citation": {
                "source": "東京の風俗",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから同じ室の床の間に、大字で「来者不拒、去者不追」と二行に書き下ろした草書の大幅がかかっていました。",
              "citation": {
                "source": "少年の食物",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから尊家が一作、不肖が一作、ともに敵討の新作を書き下ろして、どっちが世に受けるか競作というのをやってみましょう。",
              "citation": {
                "source": "仇討たれ戯作",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして紙ベースで赤入れしたものから（『不思議』書き下ろしの章なら『地底』の訳をするときに使っていたのと同じノートにぺけぺけしてから）、手元の『地底』訳文のテキストファイルを書き換えて、比較用の『地底』『不思議』訳稿をぞれぞれ整えていきます。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノンフィクション作家の富田には、処女作である書き下ろし文庫の『パソコン創世記』（一九八五年）が版元の文庫分野からの撤退によって廃刊になったという経験がある。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、別府大学の当該イベントでは、一、青空文庫のコレクションからの「別府」断片をめぐって討議、二、我々の書き下ろし「別府」断片披露、三、学生の参加、というように、この三本立ての実施となり、当日予定通りこれを実行した。",
              "citation": {
                "source": "三重塔にて",
                "author": "福永信",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを書き下ろしてみると――　昔、同じ藩中の人に殺されたお武家がありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "何年前のいつ頃か忘れたけれど、たしか改造社で維新小説全集の計畫があつて、自分も「櫻田事變」の一卷を書き下ろしで執筆する約束を持つてゐた頃と思ふから、さう遠い前でない事はたしかである。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『もう痛くない彼女』『いまはそれどころではない』『孤独をさらに深める』の三編は、二〇〇四年の夏に書き下ろした。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざ出陣となると、三ぴんの連中を前にして、安直先生がおびただしく大根おろしをかきおろしはじめました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういうつもりか、一心不乱に大根おろしをかきおろして、とうとう桶に十三杯もかきおろしてしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そないな時にな、その大根おろしのかきおろしたあんと食べておきますとな、毒消しになりますさかい、ちゃア」　それを聞いて一同がアッと感心しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
