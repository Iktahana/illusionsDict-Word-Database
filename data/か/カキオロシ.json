        "examples": {
          "standard": [
            {
              "text": "限定版の特典として、作者本人の描き下ろしイラストカードが付いてくるんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アニメのブルーレイボックスのジャケットが描き下ろしだと、つい欲しくなっちゃうよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ゲームの予約特典として、ヒロインたちの描き下ろしポスターがもらえるキャンペーンが始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "上の方から写し出してだんだん下の方に描き下ろして行きますと、美濃紙で綴じた私の帳面に、その図がはまり切れなくなりました。",
              "citation": {
                "source": "座右第一品",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざ出陣となると、三ぴんの連中を前にして、安直先生がおびただしく大根おろしをかきおろしはじめました。",
              "citation": {
