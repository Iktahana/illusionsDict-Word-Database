  {
    "uuid": "498b9eda-c91c-5f9f-81d3-61915635bbc3",
    "entry": "黄鶏",
    "reading": {
      "primary": "かしわ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "chicken meat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "鶏肉は「かしわ」とも呼ばれ、関西では特にそう呼ぶことが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今夜はかしわを使ったすき焼きにしようか、それとも唐揚げにしようか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母が作るかしわ飯は、いつも家族みんなに大人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしわけを聞いてみればその道理もないことはない。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわたくしの下駄も子供に揃えさせることもあり郵便をいれにやることもあります。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "その半分、裸のかしわが、クックッと逃げる情景　支那の老婆が日向ぼっこして、麦わら細工を縫み乍ら兵隊の行軍を見ている。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわたしの考では、そんな風に、因襲がどうにも極めていない場合が、却て面白い関係になるかも知れないでしょうと思いますの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "）しかしわたしはもう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわれわれ愚かな人間にはそれらの運動が何を意味するか、何を目的としているか全くわからない。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど今ごろ五月の節句のかしわ餅をつくるのにこの葉を採って来てそうしてきれいに洗い上げたのを笊にいっぱい入れ、それを一枚一枚取っては餅を包んだことをかなりリアルに思い出すことができる。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくこうした映画は別にどうといって説明することのむつかしい、しかしわれわれの生涯にとって存外非常に重大な効果をもつようなある物を授けてくれるような気がする。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわが貧乏国日本の忠実な少壮学者は貧乏な大学の研究所のために電池のわずかな費用を節約しつつ、たくあんをかじり、渋茶に咽喉を潤してそうして日本学界の名誉のために、また人間の知恵のために骨折り働いているのである。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうに、かしわばやしの青い夕方を、ひとりで通りかかったり、十一月の山の風のなかに、ふるえながら立ったりしますと、もうどうしてもこんな気がしてしかたないのです。",
              "citation": {
                "source": "『注文の多い料理店』序",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどかしわばやしの前まで来たとき、清作はふいに、うしろからえり首をつかまれました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こよいあなたは　ときいろの　むかしのきもの　つけなさる　かしわばやしの　このよいは　なつのおどりの　だいさんや　やがてあなたは　みずいろの　きょうのきものを　つけなさる　かしわばやしの　よろこびは　あなたのそらに　かかるまま。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かしわの木はちらっと清作の方を見て、ちょっとばかにするようにわらいましたが、すぐまじめになってうたいました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かしわの木大王が眉をひそめて云いました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつきさんおつきさん　まんまるまるるるん　おほしさんおほしさん　ぴかりぴりるるん　かしわはかんかの　　　かんからからららん　ふくろはのろづき　　　おっほほほほほほん。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かしわの木は両手をあげてそりかえったり、頭や足をまるで天上に投げあげるようにしたり、一生けん命｜踊りました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かしわは、何べんも古い葉を落して、新らしい葉をつけました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、かしわが云いました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かしわは、すっかり、うぬぼれて、枝をピクピクさせました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お空のちちは、つめたい雨の　ザァザザザ、かしわのしずくトンテントン、まっしろきりのポッシャントン。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわれわれ初心の者が連句を作る際に往々一句の長句あるいは短句の内にあまりたくさんの材料を詰め込むためにかえって連句の体を失し、その結果付け句を困難ならしめることがあるのは、畢竟俳句と連句との区別を忘れるためであると感じることがしばしばある。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこれに対する解説を近代的な言葉で発展させればいろいろむつかしくも言えるようであるが、しかしわれわれ日本の旧思想の持ち主の目から見れば実質的にはいっこう珍しくもなんともないことのように思われてしかたがない。",
              "citation": {
                "source": "ラジオ・モンタージュ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわれわれのような観賞者の立場からすれば配合調和相生というのも、対立衝突｜相剋というのも、作者の主観以外には現象としての本質的な差を認めなくても結果においてたいした差はないようである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……もうしかしわしは死ぬものとほぼ相場がきまった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわしはその時から、直に「原始の国」という処へ、生れ変ったのじゃ」「ああ、そうですかお祖父さん。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわれわれはそれは当然だろうと考える。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわたしには、また考えがあるから、そんなに心配しないでもいいよ。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "７　かしわばやしの夜桃色の大きな月はだんだん小さく青じろくなり、かしわはみんなざわざわ言い、画描きは自分の靴の中に鉛筆を削って変なメタルの歌をうたう、たのしい「夏の踊りの第三夜」です。",
              "citation": {
                "source": "『注文の多い料理店』新刊案内",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
