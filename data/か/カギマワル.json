        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はライバル企業の動向を探るため、関係者の周辺を嗅ぎ回っているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "週刊誌の記者が、事件の真相を求めて近所を嗅ぎ回っているようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "妹は私の許可なく、平気で部屋の中を嗅ぎ回るので困る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
