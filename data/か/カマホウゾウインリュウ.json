        "examples": {
          "standard": [
            {
              "text": "「突けば槍、引けば鎌とは、鎌宝蔵院流の十字鎌槍の恐ろしさを説いた言葉だ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は古流武術の門を叩き、鎌宝蔵院流の変幻自在な槍捌きを学び始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "演武会では、鎌宝蔵院流の使い手が敵の刀を鎌で絡め取る技を披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鎌宝蔵院流の修行者は、長い槍を体の一部のように操り、間合いを支配する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これは鎌宝蔵院流七十三手のうちには無い手です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
