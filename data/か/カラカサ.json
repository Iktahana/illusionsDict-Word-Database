        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔ながらの商店街には、風情のあるから傘を売る店があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "突然の雨に、彼女は慌ててから傘を広げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "舞妓さんが持つから傘は、日本の美意識を感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "お光が側から傘きせて居る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私からそれを言い出したのであったが、とにかく一家はそのつもりになって、穴を掘って食料を埋めたり、また鍋釜茶碗の類を一｜揃、それから傘や履物や化粧品や鏡や、針や糸や、とにかく家が丸焼けになっても浅間しい真似をせずともすむように、最少限度の必需品を土の中に埋めて置く事にした。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、途中で困ったから傘を借りたいと思ったんですが、もう雨も上りましたよ。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と謙造はもうここから傘ばッさり。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、照日が出て、次にから傘が出て次に照る日が出て次にから傘が出てという互い違いに追っかけっこの形を繰返してもおります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "照る日にから傘の謎に口慣れてしまえば、雨の日のから傘が却って魅力ある不安な謎となり、雨の日のから傘にしばらく住してしまえば茲にまた照る日のから傘の眼新しい謎に躍り出し度くなります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今の学者が飛竜と呼び、インドのマドラスや後インドに二十種ばかり産する蜥蜴ありて、長十インチ以内で脇骨が長くて皮膜を被り、伸縮あたかも扇様で清水の舞台から傘さして飛び下りるごとく、高い処から斜に飛び下りること甚だ巧い。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう日が翳ったから傘なしで行けるよ」　一時間余り、いしは、いそがしい思いをした。",
              "citation": {
                "source": "小村淡彩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みのるは重い包みを片手に抱へたまゝ戸締りをしたり、棚から傘を下したりした。",
              "citation": {
                "source": "木乃伊の口紅",
                "author": "田村俊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私から傘を突き出された青年は、「そうです。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "降りそうだから傘をやろうと投げ出した時、二本あれば遠慮をせぬが世間であるが、見す見すくれる人が濡れるのを構わずにわがままな手を出すのは人の思わくもある。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車から傘を持った男が一人下りてのそのそと村の方へ歩いて行った。",
              "citation": {
                "source": "吹雪のユンクフラウ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月二日　月曜　雨の夜、これだから傘が二本いるね十月三日　火曜　午後哲学の話　男ものの単帯、角帯は似合う　夕飯急にたか子たち来て、九時に立つ、べん当もつくれず。",
              "citation": {
                "source": "日記",
                "author": "一九五〇年（昭和二十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、権兵衛さんから傘を受け取る風をしながら、ふいにその下駄で、権兵衛さんの肩のあたりを力一ぱい打ちました。",
              "citation": {
                "source": "狐に化された話",
                "author": "土田耕平",
                "note": "青空文庫"
              }
            },
            {
              "text": "」母屋から傘もなしに、はんてんをスッポリかぶって、ころがるようにとびこんで来たのは、ひさしぶりにつづみの与吉だ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ま、勝負はお預けとしときやしょう――やい、奴」と軽く足許の勘次を蹴って、「一っ走りして長屋から傘を持ってこい。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "梅雨に咲く花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お君はそのあとから傘を差しかけて追って行こうとするのをお銀様が、「そっちへ行ってはなりません、そっちのお邸へ行ってはなりません」　命令するような強い声で呼び止めましたから、お君は立ち竦みました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "伯耆の安綱の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "春は目の前にきていながら珍らしく雪の降る中を、ひとバスおくれた大石先生は、学校前の停留所から傘もささずに走って、職員室にとびこんだとたん、異様な室内の空気に思わず立ちどまり、だれに話しかけようかというふうに十五人の先生たちを見まわした。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この傘をさしなさいよ」と少女はから傘を二人のほうへ差出した、「姉さんのとこへ持ってゆくんだから、方角ちがいじゃだめだけれど、さあ、さしなさいよ」　栄二は少女を見た。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「洒落っくせえッ」　二本の脇差を叩き払って、スポーンと投げつけたから傘が、血の雨を呼ぶ修羅の合図。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪どろんこ「兼好さん、兼好さん」「どこ行くの」「から傘抱えてどこ行くの」「酒瓶を提げてどこ行くの」　子供たちは彼の姿を囃した。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「謎々、なあに、照る日にからかさ」　この文句の句調から出る無邪気とも単的ともいいようのない謎々の謎なるものが自分が将来生みもしようこどもほどにもいじらしく可愛らしく感じられて来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、わたくしの人並ならぬ生の憩い、それは生活に於ては河沿いの土に起き臥し、こゝろに於ては謎の性質のいく重ねの層を経潜って、この程では、たゞ「謎々なあに、照る日にからかさ」というような稚純極まる心田の素地に朝夕をあくがれ遊ぶ身の上になってまいりました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は横に轉がした大籠からかさ／＼と掻き出しては燃え易い落葉を間斷なく足した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "からかさ小僧でも通ったのか」「ちぇッ、あっしがまじめな口をきくと、いちいちそれだからな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「誰からかさう云ふ書物に書いてあることを訊いた覚えはないか。",
              "citation": {
                "source": "マルクスの審判",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の往来するあちらでは数年来のさんざんな労苦があったが、枝をひろげたオンコ松のからかさは、その根もとに太古からの落葉や小枝を積みかさね、ふわりとする自然の褥で迎えてくれた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "墜ちがけに、からかさのように拡がった隣りのトド松の枝をつき飛ばした。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "木がこんもりとしげり、椰子や棕櫚が、からかさのやうに葉をひろげて、いろんな花がさきほこつてゐます。",
              "citation": {
                "source": "シロ・クロ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るい光がどこからかさし込んで来るようなここちがしだしました。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
