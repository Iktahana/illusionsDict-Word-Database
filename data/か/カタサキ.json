    "definitions": [
      {
        "index": 1,
        "gloss": "(top of) shoulder",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "小雨が降ってきたため、彼女のコートの肩先が少し濡れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "満員電車で揺れた拍子に、隣の人の肩先が顎に当たってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "美容師が鏡越しに私の肩先を指差し、髪の長さをどのくらい切るか尋ねてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ジイグフリイドほどの不死身の大勇者でも、その肩先に一箇所の弱點を持つてゐたではないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が姉を見上げた時に、姉の後に襷を掛けた守りのお松が、草箒とごみとりとを両手に持ったまま、立ってて姉の肩先から自分を見下して居た。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝境内　嘉助は五郎蔵の一太刀、肩先に受けアッと言って倒れる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一大殺陣の開始となる――　遂に典六も五郎蔵も倒されたが、　大吉も肩先深く斬られてしまった。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女はぎくりと肩先を顫はせた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は熱心に書いて居る草の上に腰から上が出て、其立てた膝に畫板が寄掛けてある、そして川柳の影が後から彼の全身を被ひ、たゞ其白い顏の邊から肩先へかけて楊を洩れた薄い光が穩かに落ちて居る。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "草の上に腰から上が出て、その立てた膝に画板が寄掛けてある、そして川柳の影が後から彼の全身を被い、ただその白い顔の辺から肩先へかけて楊を洩れた薄い光が穏かに落ちている。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の青年はビールの酔いを肩先にあらわしながら、コップの尻でよごれた卓子にかまわず肱を立てて、先ほどからほとんど一人で喋っていた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩いてゆく私の頭の影や肩先の影がそんななかへ現われては消えた。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある寒い夕方野こえ山こえようやく一つの古い町にたどり着いて、さてどこを一夜のやどりとしたものかと考えましたが思わしい所もありませんので、日はくれるししかたがないから夕日を受けて金色に光った高い王子の立像の肩先に羽を休める事にしました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水兵ヒラリと身を躱すよと見る間に、腰の大刀は※手も見せず、猛狒の肩先に斬込んだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と矢庭に彼の肩先を握んで後へ引戻した。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "下は毛布一枚敷かぬ堅い床板なので、腰骨や肩先が痛くなる。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "と剣を揮い、胸前目懸けて突込みしが、心｜急きたる手元狂いて、肩先ぐざと突通せば、きゃッと魂消る下枝の声。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、咄嗟の間に少しく体を躱したので、鋭い切尖は僅に其の肩先を掠ったのみであった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "久能はあとでこの鼓をさし上げたことを心から苦にして、或る時鶴原卿の邸内へ忍び入ってこの鼓を取り返そうとすると、生憎その頃召し抱えられた左近という若侍に見付けられて肩先を斬られた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジイグフリイドほどの不死身の大勇者でも、その肩先に一箇所の弱点を持つてゐたではないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれ船路のさまたげと、金内怒って荷物の中より半弓を取出し、神に念じてひょうと射れば、あやまたずかの人魚の肩先に当り、人魚は声もなく波間に沈み、激浪たちまち収まって海面はもとのように静かになり、斜陽おだやかに船中にさし込み、船頭は間抜け面で起き上り、なんだ夢か、と言った。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして源三が肩先を把えて、「またおまえは甲府へ行ってしまおうと思っているね。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞬間、グスタフソンの大きな顏もさつと青白み、肩先ががくりと戰いた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ちよつと立ちどまつて、又、ない左手の肩先をふりかへりましたが、つぎの瞬間には、右手一本で雨樋につかまつたと見ると、まるでりすかなぞのやうに、ものゝ四十秒もたゝないうちに、もう屋根のはしのところまでかけ上り、小猫をつかまへて上着のふところに入れました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは石川を追うよりもまず堀口を抱え起して介抱すると、疵は左の肩先を深く斬り下げられていた。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手でそれを支えようとした途端に、もう一人の敵の剣が肩先に喰い込む。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、趙一人おいて向うにいた趙の父親が私の肩先を軽く叩いて、覚束ない日本語で、笑いながら、「虎よりも風邪の方がこわいよ」と注意してくれた。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウワアッ」　と三好は夢中になって藻掻いたが、白坊主の力は意外に強く、肩先を羽がい締めにして来るので呼吸が詰まりそうになって来た。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手が立ち上りかけた肩先を斬り下げていた。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩先を斬られたまゝ逃れ、隣家の庭前に監視してゐた、桑藩士本間某を斬り、黒川某に重傷を被らせ、馳せて河原町の藩邸に向つた。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、殊子に肩先をつねられそうなのを、仰山に飛びのいて、「めんちゃい！",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　顔を伏せて右肩を突き出し、くすくす笑いながらその肩先で僕をぐいぐい押すのである。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　漸く僕が彼の肩先に蟷螂のやうな鉤型の腕をひつかけて、待つて呉れ！",
              "citation": {
                "source": "凩日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
