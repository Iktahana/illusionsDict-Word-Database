[
  {
    "uuid": "67f1d4bd-5059-5064-81d2-709e7a147651",
    "entry": "莞爾として",
    "reading": {
      "primary": "かんじとして",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
