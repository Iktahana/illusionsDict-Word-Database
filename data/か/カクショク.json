        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "明日の朝ごはん用に、角食を１斤買っておこう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "このパン屋の角食は、ずっしりと重くて食べ応えがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は角食をまるごと一本使って、巨大なハニートーストを作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "お定の家は村でも兎に角食ふに困らぬ程の農家で、借財と云つては一文もなく、多くはないが田も畑も自分の所有、馬も青と栗毛と二頭飼つてゐた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お定の家は、村でも兎に角食ふに困らぬ程の農家で、借財と云つては一文もなく、多くはないが田も畑も自分の所有、馬も青と栗毛と二頭飼つてゐた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "北米の大説教家ビーチアルは、曾て数塊の馬鈴薯を人に饗して曰くだ、此は吾輩の手作だ、而して一塊一｜弗はかゝって居るのだ、折角食ってくれ玉えと。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆、兎に角食っていく。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物事は兎角食い違う。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎も角食糧問題を根幹として、厭戦思想挑発のあらゆる手を打ちつつあるという報告を受取っているのであります。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "何が悪かったのか、兎に角食あたりに違ない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
