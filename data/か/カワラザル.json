        "examples": {
          "standard": [
            {
              "text": "お土産物屋さんで、素朴な瓦猿の置物を買った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祖母の家の飾り棚には、年代物の瓦猿が並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちが粘土で作った瓦猿は、一点一点表情が違って面白い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "とうぜん勝手がかわらざるを得なかったに相違ない。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四、数学　指を屈して物の数を計るをはじめとし、天文・測量・地理・航海・器械製造・商売・会計、ことごとく皆、数学のかかわらざるものなし。",
              "citation": {
                "source": "学校の説",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えばこの六年のあいだ、かわらざる親友でした！",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、あの男がこの期に及んでやっと、六年間のかわらざる友情で結ばれた心からの友達になってくれたのは、これは一體どうしたわけでしょうかね？",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            }
          ]
        }
