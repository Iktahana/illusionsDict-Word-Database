        "examples": {
          "standard": [
            {
              "text": "「わあ、おじいちゃんが関西医大に入院したから、放課後にお見舞いに行ってくるね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "関西医大のタワー病院は、夜になるとライトアップされて枚方のランドマークになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "学園祭の準備で、関西医大の学生たちが白衣を着たまま忙しそうに中庭を走り回っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "あそこの内科の先生、前に関西医大の教授をやってた名医らしいよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "千里山に住んでいる若槻という株屋の息子で、東京の医大を出て関西医大でインターンをやっているということだったが、毎夜のように病院を抜けだしてきて、「よっちゃん」に入りびたっている。",
              "citation": {
                "source": "虹の橋",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
