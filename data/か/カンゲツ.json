[
  {
    "uuid": "59c09807-88d9-5dde-91e9-ee828e4a71c6",
    "entry": "観月",
    "reading": {
      "primary": "かんげつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "moon viewing (esp. during the eight month of the lunar calendar)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「まあ、今夜の月はなんて綺麗なの」と彼女は感嘆し、ベランダに椅子を出して心ゆくまで観月に耽った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "澄み渡った秋の夜空を見上げ、縁側に月見団子とススキを供えて家族で静かに観月を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古都の寺院では、観月の名所として知られる広大な庭園が、満月の時期に合わせて期間限定で夜間公開されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "芭蕉の居を卜せしは即ちこの川の北岸にして、満潮の潮がしらに川角へさし来る水の勢に乗つて照り渡れる月に句を按じ、あるいは五本松あたり、一川の上下に同じ観月の友を思へるなど、皆こゝに居たるよりの風雅のすさびなりけんと想はる。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまから十八年前、画学生の逸作と娘歌人のわたくしとは、同じ春の宵に不忍池を観月橋の方から渡って同じくこの料亭のこの座敷でご飯を食べたのであった。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京ドームを借り切った電脳遊園地という名のはでな発表イベントを南野陽子がすっぽかし、宣伝担当が宮沢りえに、さらに観月ありさへと移り変わったあのマシンだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "南野陽子と宮沢りえに払ったギャラはドブに捨てたと諦めて観月ありさでがんばれば、マルチメディア・ソフトの再生器として人気を得初めたＴＯＷＮＳは、さらにもう一段伸びると思う。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋空一碧、今夜の月はうつくしからう、結庵三度目の名月、観月句会を催ほすのである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "観月会、――其中有楽。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "観月感慨無量、戦線をおもひ銃後をかへりみる、遠近親疎、有縁無縁、南無阿弥陀仏。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の若い職人が一人、順吉というお島の可愛がって目をかけている小僧と一緒に、熱い仕事場の瓦斯の傍を離れて、涼しい夜風を吸いに出ているのに、ふと観月橋の袂のところで出会した。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "観月の場所としては随一だらう。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳳嶺は千秋亭観月の詩を扇に題して、持つて来て見せた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "開けてみると上等な便箋に、今夜上野の観月橋まで来て欲しいと綺麗に叮嚀に書いてあった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "石山の観月台に立ちなまし夜の明けんまで弥勒の世まで　弥勒の世とは五十六億七千万年後の世であるから永遠といふ言葉のよき代用である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内厭きても来るし眠くもなつて観月台から引き上げたであらう。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "月が西山にはいつてしまへば観月台上は蔭となり、見るものは東方琵琶湖面から反射する月光のみとなる。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "余等は更に観月堂に上った。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『けれど、せっかくの思召さるる観月のお莚に、何も奉らないのは、さぞかしご本意なく思召さるるでありましょう』　と、公卿はさびしく、つぶやいた。",
              "citation": {
                "source": "にらみ鯛",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは天保の改革当年の世相を窺う一端として枕山が観月六首の中から次の一首を摘録する。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕山は例年の如く中秋観月の詩筵を開くがためにその時節には江戸に還っていた。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」〔古自リ佳期｜動スレバ相失ヒ／天時人事長吁スルニ足ル／独リ旧交ノ旧約ヲ尋ヌル有リテ／年年此夕余ヲ負カズ／観月ノ伴時トシテ闕クコト有ルモ／観月ノ遊歳トシテ無キコト無シ〕云々と言ってある。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕山は「惆悵今年観月社。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」〔惆悵タリ今年観月ノ社／六人ノ佳約五人空シ〕と言っているが、湖山の集には「己酉ノ中秋子寿九万ト同ジク墨水ニ遊ブ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕山らの観月が七回に及んだことは湖山枕山二人の言うところに違いがない。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕山が中秋観月の題言に、「庚戌中秋、湖山昆渓毅堂ト同ジク舟ヲ墨水ニ泛ベ棹月楼ニ登リ例年ノ遊ヲ為ス。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし枕山が中秋観月の作の題言に「中秋、毅堂、香巌、楽山ト同ジク舟ヲ墨水ニ泛ベ百花園ヲ訪ヒ薄暮棹月楼ニ抵ル。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの年中秋観月の会は八月十日に風雨の荒狂ったためかそのまま催されずにしまったようである。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕山らが年々催す中秋の観月はこれがために今年は廃せられた。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
