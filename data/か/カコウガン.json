        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "登山口付近には、風化した花崗岩の白い砂が広がっており、独特の明るい景観を作り出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この国会議事堂の外装には、広島県産の立派な花崗岩がふんだんに使われているんだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "墓石や建築材によく使われる御影石は、地質学的には花崗岩の一種として分類される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地下深くでマグマがゆっくりと冷え固まることで、花崗岩特有のキラキラとした大きな結晶が出来上がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あらゆるものは古代歴史と花崗岩のかなたの地平の目の色。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の方を仰ぐと、赤沢岳が無器用な円頂閣のように、幅びろく突ッ立って、その花崗岩の赤く禿げた截断面が、銅の薬鑵のような色をして、冷めたく荒い空気に煤ぶっている。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳳凰山地蔵岳の大花崗岩山は、その峻しい荒くれた膚を、深谷の空気に、うす紫に染めている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "灘をこえて、水が静かになると、両方の岸を見廻すだけの余裕が出てくる、河原には材木を伐り出す小舎がある、岩石は上流の花崗岩と違つて、小さな褶曲や白や褐色の岩脈が、横に帯をしめたやうな、筋を入れたのが、美しく見える。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば風化せる花崗岩ばかりの山と、浸蝕のまだ若い古生層の山とでは山の形態のちがう上にそれを飾る植物社会に著しい相違が目立つようである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花崗岩の板を贅沢に張りつめたゆるい傾斜を上りつめると、突きあたりに摺鉢のような池の岸に出た。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔一才のアルプ花崗岩を〕一才のアルプ花崗岩を、　　　　おのも積む孤輪車。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくやすんでから、こんどはみんなで先生について川の北の花崗岩だの三｜紀の泥岩だのまではいった込んだ地質や土性のところを教わってあるいた。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへも緑は影を映して、美しく洗われた花崗岩の畳石の上を、また女の人の素足の上を水は豊かに流れる。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドクトル、ベエアマンはここで花崗岩の破れ目の出来方について講釈をして聞かせた。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときにいつも目の前の夕やみの庭のまん中に薄白く見えていたのがこの長方形の花崗岩の飛び石であった。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学士は咽喉をこくっと鳴らし中に入って行きながら三角の石かけを一つ拾ひ「ふん、こゝも角閃花崗岩」とつぶやきながらつくづくとあたりを見れば石切場、石切りたちも帰ったらしく小さな笹の小屋が一つ淋しく隅にあるだけだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見るとなんでもこの辺にさっきの花崗岩のかけらがあるね、そいつの中の鉱物がかやかや物を云ってるんだね。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みちをあるいて黄金いろの雲母のかけらがだんだんたくさん出て来ればだんだん花崗岩に近づいたなと思うのだ。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学士は咽喉をこくっと鳴らし中に入って行きながら三角の石かけを一つ拾い「ふん、ここも角閃花崗岩」とつぶやきながらつくづくとあたりを見れば石切場、石切りたちも帰ったらしく小さな笹の小屋が一つ淋しく隅にあるだけだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その巨石を取巻く大小の墓の前には、それぞれに紅と白の桃の花が美しく挿し並べて在ったが、その墓の間々へ物見高い近隣の町の者や、通りかかりの肥汲みの百姓や柴売り、又は近道伝の太宰府参りらしい町人なんどが真黒く、犇々と押しかけて、中央の白い花崗岩の石甃の上を、折重なるように凝視している。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "国道から曲り込んで、深良屋敷へ上って来る赤土道に、一尺置ぐらいに敷並べてある四角い花崗岩の平石を、わななく手で指した。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "花崗岩の敷石を飛び飛び赤土道を降りて、到着した判検事一行の七名ばかりを出迎えた。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "モウ一つ飛ばないかナ……などと他愛ない事を考えながら、何の気もなく星空を見い見い歩き出すトタンに深良屋敷に通ずる道路の中央に埋めて在る平たい花崗岩の第一枚目に引っかかって、物の見事にモンドリを打った。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちる時手を放して、僕は左を下に倒れて、左の手の甲を花崗岩で擦りむいた。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "花崗岩を立てた大きな門の上には電燈が光っていた。",
              "citation": {
                "source": "黄燈",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岬に打ちつける波は花崗岩の如き白い柱を立てる。",
              "citation": {
                "source": "鉛筆日抄",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "花崗岩を爆裂させた趾のやうな白い所が幾つも見える。",
              "citation": {
                "source": "旅の日記",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "糞、小便は、長さ五寸、幅二寸五分位の穴から、巌丈な花崗岩を透して、おかわに垂れる。",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "二間位の広さで、花崗岩の腐蝕した白砂土が、太陽の直射に会って、照りかえして、足の下から部屋に射し込む。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラバンのバン白い雀花崗岩の上に樹がある、それは美しい桜の花であつた。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
