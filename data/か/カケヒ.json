    "definitions": [
      {
        "index": 1,
        "gloss": "open water pipe",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭の古い竹の筧から、チョロチョロと水が流れて、池に注いでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あ、見て！この古民家には、ちゃんと筧が設置されてるよ。趣があるね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夏場は、畑の水やり用に、庭の隅に簡易的な筧を作ったんだ。雨樋の代わりだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "筧の水は、物語る白髪の嫗にさも肖てる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉附近の路が酷くくずれている、宿の前で嗽いをした筧の水などは、埋没してしまっている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝振りのいい松に、頭を五分がりにした、丸々しいツツジや、梅などで囲んだ小池があって、筧からの水がいきおい込んで落ちている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな奇麗な前庭を持っている、そのうえ堂々とした筧の水溜りさえある立派な家の伜が、何故また新聞の配達夫というようなひどい労働へはいって行ったのだろう。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく死に際の幻覚には目にたてて見る塵もない自分の家の前庭や、したたり集って来る苔の水が水晶のように美しい筧の水溜りが彼を悲しませたであろう。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本の古びた筧がその奥の小暗いなかからおりて来ていた。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして筧といえばやはりあたりと一帯の古び朽ちたものをその間に横たえているに過ぎないのだった。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "筧は雨がしばらく降らないと水が涸れてしまう。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして花の盛りが過ぎてゆくのと同じように、いつの頃からか筧にはその深祕がなくなってしまい、私ももうその傍に佇むことをしなくなった。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に小田原の町を放れ、函嶺の湯本近に一軒、茶店の娘、窶れ姿のいと美しきが、路傍の筧、前なる山凡そ三四百間遠き處に千歳久しき靈水を引いたりといふ、清らかなる樋の口に冷たき其の土を洗ふを見て、山の芋は鰻になる、此の牛蒡恁くて石清水に身を灌がば、あはれ白魚に化しやせんと、そゞろ胸に手を置きしが。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その半腹にかかりある巌角の苔のなめらかなるに、一｜挺はだか蝋に灯ともしたる灯影すずしく、筧の水むくむくと湧きて玉ちるあたりに盥を据えて、うつくしく髪結うたる女の、身に一糸もかけで、むこうざまにひたりていたり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "筧の水はそのたらいに落ちて、溢れにあふれて、地の窪みに流るる音しつ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　腰をななめにうつむきて、ひったりとかの筧に顔をあて、口をおしつけてごっごっごっとたてつづけにのみたるが、ふッといきを吹きて空を仰ぎぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂として、谷の筧の趣あり。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "筧の水を受くるとて、嫁菜の莖一つ摘みつゝ、優しき人の心かな、何のすさみにもあらで、其の盥にさしけるが、引とき衣の藍に榮えて、嫁菜の淺葱色冴えしを、菜畠の日南に憩ひて、恍惚と見たる旅の男。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と打笑み）筧の下に、梨が冷してござんす、上げましょう。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "百合　裏の崕から湧きますのを、筧にうけて落します……細い流でございますが、石に当って、りんりんと佳い音がしますので、この谷を、あの琴弾谷と申します。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "月影ながらもる夏は、山田の筧の水とかや。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方が洗面所で、傍に大きな石の手水鉢がある、跼んで手を洗うように出来ていて、筧で谿河の水を引くらしい……しょろ、しょろ、ちゃぶりと、これはね、座敷で枕にまで響いたんだが、風の声も聞こえない。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "平家づくりで、数奇な亭構えで、筧の流れ、吹上げの清水、藤棚などを景色に、四つ五つ構えてあって、通いは庭下駄で、おも屋から、その方は、山の根に。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それで吻として、大な階子段の暗いのも、巌山を視めるように珍らしく、手水鉢に筧のかかった景色なぞ……」「ああ、そうか。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――三枚目の大男の目をまわしているまわりへ集まった連中の前は、霧のように、スッと通って、悠然と筧で手水をしたでしょう。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光りの流れは、こちらへも又、向うの横丁へも流れて行かず、筧をながれる水がそのまゝ氷結してしまった様である。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の茶屋には筧の水があふれて、ところてんが澄んでゐた。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸待て……顔を洗って来るから」　草川巡査は、裸体のまま直ぐに裏口へ出て、冷たい筧の水で顔を洗った。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その半腹にかかりある厳角の苔のなめらかなるに、一挺はだか蝋に灯ともしたる灯影すずしく、筧の水むくむくと湧きて玉ちるあたりに盥を据ゑて、うつくしく髪結うたる女の、身に一糸もかけで、むかうざまにひたりてゐたり。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "筧の水はそのたらひに落ちて、溢れにあふれて、地の窪みに流るる音しつ。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　腰をななめにうつむきて、ひつたりとかの筧に顔をあて、口をおしつけてごつごつごつとたてつづけにのみたるが、ふツといきを吹きて空を仰ぎぬ。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "婢は裏山から引いた筧の水を汲んで来てそれを足盥に入れ、旅人の草鞋擦のした蒼白い足を洗ってやった。",
              "citation": {
                "source": "立山の亡者宿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもあらばあれ、夕顏の薄化粧、筧の水に玉を含むで、露臺の星に、雪の面を映す、姿また爰にあり、姿また爰にあり。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
