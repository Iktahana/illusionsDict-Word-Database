        "examples": {
          "standard": [
            {
              "text": "彼は自分の犯した過ちを、家族にさえ最後まで隠し通した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "これだけの大きな秘密を、一体いつまで隠し通せるというのだろうか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女が病気であることを周囲に隠し通すのは、私にとって非常に辛いことだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "でも、こうした重要な郵便物を、父に隠し通すことは出来なかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、かうした重要な郵便物を、父に隠し通すことは出来なかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お増は言い張ったが、やはり隠し通すことが出来なかった。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間と交際して、生活を共にし、しかも本性を隠し通す修業を積まなければ、全国の狸界を統一し、それに君臨するわけには行かぬこととなっているから、これについて仙公狸は多年にわたり、思案を費やしてきたのである。",
              "citation": {
                "source": "純情狸",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちさえ平然としてれば、向うの方で参ってしまうよ」「あなたはいつもそんなこと云うけれど、嘘を隠し通すって、ほんとに苦しいことね。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかい、メアリ、秘密を隠し通すのは無駄だよ」　メアリ・サトーリスが目を大きく見開いてベリントン大佐を見た。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
