    "definitions": [
      {
        "index": 1,
        "gloss": "(formation of) three people sleeping side by side (esp. a child between two parents)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "疲れて帰ってきた日、真ん中に子供を挟んで夫婦で川の字になって眠るのが最高の癒やしだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初めての旅行で、旅館の一室で三人川の字になって寝た夜を思い出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "小さかった頃は、両親と三人で川の字になって眠るのが当たり前だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あれを着せて二人で行って来るからナ……貴様は頭痛がするんなら先に寝とれ……座敷に瓦斯ストーブを入れてナ……ハハ久し振りに川の字か。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "本の字と米だか林だかハッキリしない字と川の字、それから何とか内写真館と読めただけでした」「書損いの封筒の前にそれを見たんだね」「そうです。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真黒な三つの塊りが川の字形に跡を踏んで丑寅の角へ動いて行ったのは、あれで、かれこれ九つに近かった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "お茶漬音頭",
                "note": "青空文庫"
              }
            },
            {
              "text": "門番の代鍵は手提金庫に入れて、子の無い門番夫婦の間へ置いて川の字なりに寝る位ですから、盗み出して元へ返すことなどは思いもよりません。",
              "citation": {
                "source": "踊る美人像",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では川の字をあてたり、河の字を書いたりしているが、漢字の概念ではこれは解釈できないことである。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "『倭名鈔』の郷名に葛例または嘉礼があるというが、この類例は今日は多くは佳例川・嘉例川などと川の字を伴ないて存しかえって涸渓の説に背いている。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の父は芥川の字を見て彼も芥川に書いて貰ひ度と云ふ欲望を起した。",
              "citation": {
                "source": "芥川龍之介を憶ふ",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、ここに父母と私は川の字に寝た。",
              "citation": {
                "source": "生い立ちの記",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
