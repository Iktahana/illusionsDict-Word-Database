    "definitions": [
      {
        "index": 1,
        "gloss": "signboard",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たぐい稀な特質だ」「しどろもどろの看板」「懐疑説の破綻と来るね。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄汚い裏町のようなところの雑貨店の軒にロシア文字の看板が掛かっていたりした。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真店の看板を見る兵隊さん。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨催の空濁江に映りて、堤下の杭に漣※寄するも、蘆荻の声静かなりし昔の様尋ぬるに由なく、渡番小屋にペンキ塗の広告看板かゝりては簑打ち払う風流も似合うべくもあらず。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レールに近く養蚕広告のペンキ塗の看板が、鉛のような鉱物性の色をして、硬く平ったく烈しい日の光に向って立っていたが、汽車と擦れ違いさまに、仆れそうになって、辛くも踏み止まった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の宿屋というものを、思わせる「糸屋」と看板を出した旅籠屋には、椽側に紡車を置きっ放しにして、ひっそりかんとしている、馬車はここで停まった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は昨年｜塩山の停車場で、白ペンキ塗の広告板に、一の宮郷銘酒「白嶺」と読んで、これは「雪の白酒」ではあるまいか、さぞ芳烈な味がすることであろうと思った、また他で製糸所の看板に、白嶺社とあるのを見て、この社の糸の光には、天雪の輝きがあろう、衣に織ったらばさぞ、と考えたことがある。",
              "citation": {
                "source": "雪の白峰",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "古風な紅白の棒の看板を立てた理髪店がある。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れてこんなこと始めてだ」「麦とろの食べ過ぎかね」老妓は柚木がよく近所の麦飯ととろろを看板にしている店から、それを取寄せて食べるのを知っているものだから、こうまぜっかえしたが、すぐ真面目になり「そんなときは、何でもいいから苦労の種を見付けるんだね。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ駅の俥を雇って町中を曳かれて行くと、ほのぼの明けの靄の中から大きな山葵漬の看板や鯛のでんぶの看板がのそっと額の上に現われて来る。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根附の中風薬の金看板なぞ見える小さな町だが、今までの寒山枯木に対して、血の通う人間に逢う歓びは覚える。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど此処の酒店で、作楽井が言ったように杉の葉を玉に丸めてその下に旗を下げた看板を軒先に出している家がある。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "｛３｝米国国旗や理髪店の看板が縞模様でありながら何らの「いき」をももっていないのは、他にも理由があろうが、主として色彩が派手であることに起因している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "形状上では理髪店の看板とほとんど違わないが、色彩の効果によって「いき」な印象を与える。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し下りた処の洗濯屋の看板を見ると何某プラチェシナヤと露文字で書いてある。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "領事館御用の洗濯屋さんだからかと思ったが、電車通りを歩いていると、露文字の看板は外にも二つ見付かった。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔長崎を見物した時に見た露文の看板の記憶が甦って来るのを感じた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼前に銀座まで出掛けたら諸所の店前の立看板などが吹き飛ばされ、傘を折られて困っている人も少なくなかった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンキ屋が看板の文字を書くようにそれはどこから筆を起してどういう方向に運んで行っても没交渉なもののように見えた。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府の所属で、各種科学の特殊な専門的題目の研究所として看板をかけた処では、比較的にいくらか自由である。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時私は、未知の錯覚した町の中で、或る商店の看板を眺めていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その全く同じ看板の絵を、かつて何所かで見たことがあると思った。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "理髪店の軒先には、紅白の丸い棒が突き出してあり、ペンキの看板に Barbershop と書いてあった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次詰め寄って、Ｔ「誰に断って　俺の先生の表看板　横取りしたァ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝吉原神道流剣道指南　　　　　白倉源五左衛門の看板Ｓ＝道場の表　格子窓から覗き込んで居る人々。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でも、あれは、うちのかんばんですから。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの字位が、ちやうどかんばんにするには恰好です。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は、大学生から貰ったお金は一銭もわが身につけず、ほうばいの五人の女中にわけてやり、ばたばたと脛の蚊を団扇で追いはらって浅草まつりが近づいたころには、その食堂のかんばん娘になっていた。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで再び元気づいた私達は皆なで肩を組んで、その通りを無暗と先へ進み、突きあたるとひとりでに右に曲る露路をまはつて、出たら目に歩いて行くと、偶然にも薄暗い横丁の隅に、バア・パントムの「明るい」かんばんを発見しました。",
              "citation": {
                "source": "ひとりごと",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と吠えて、立ちあがりさうにすると、二人は、かんばんの腰高障子を蹴破つて遁走してしまつた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
