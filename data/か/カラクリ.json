    "definitions": [
      {
        "index": 1,
        "gloss": "mechanism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その古い時計は、複雑な絡繰りで動いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、おもちゃのロボットの絡繰りを分解して調べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この扉の絡繰りは巧妙で、開けるのに時間がかかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の発明品は、単純な部品の組み合わせで精巧な絡繰りを生み出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "自分に知らされていない大きな絡繰りがあって、自分が失敗を犯すのを、皆が寄ってたかって待ち受けているように感じた。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "神主さんの、からくりではないかとさえ、疑いたくなるのである。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神主さんの、からくりではないかとさへ、疑ひたくなるのである。",
              "citation": {
                "source": "春晝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた「清水」と「高瀬川」という題で、絵馬か覗きからくりの絵からでも進化したような絵があったが、あれにもやはり無限に近づこうとする努力の第一歩がないとは云われなかった。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "反｜蒋介石派の激化と、東支鉄にからんだ露支間の葛藤、南京政府の幣制の改革にたいする商人の思惑は、対支商談におけるワシントン政府の経済政策が、帝国主義戦争の一つの徴として、ワシントン当局者のからくりによって時局が平穏のうちに解決されると、南京政府は中央銀行を設け、上海造幣｜厰を開いた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場の一｜方の端を取つて、構内の出はづれの処に、火の番小屋をからくりで見せるやうな硝子窓の小店があつて、ふう／＼白い湯気が其の窓へ吹出しては、燈に淡く濃く、ぼた／＼と軒を打つ雨の雫に打たれては又消える。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいいち僕は、このやうな時間のからくりを好かない。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は町の夜店に「のぞきからくり」がまだ幅をきかせていた時代である。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小栗判官、頼光の大江山鬼退治、阿波の鳴戸、三荘太夫の鋸引き、そういったようなものの陰惨にグロテスクな映画がおびえた空想の闇に浮き上がり、しゃがれ声をふりしぼるからくり師の歌がカンテラのすすとともに乱れ合っていたころの話である。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに審美的のめがねをかなぐりすてて、一つの心理的なからくりの中の歯車や弾条を点検するような無風流な科学者の態度で古人の連句をのぞいてみたらどうであろうか。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆がしらでも中軸でも一味についた連名の、昼鳶がお尻を突く、駿河台の水車、水からくりの姉さんが、ここにも一人と、飛込もうか。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小僧は土間の隅にさながらのからくり。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お使僧の説教は、彼女にとつては覗からくりの歌声よりも猶無関心のものであつた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "貰いものの葉巻を吹かすより、霰弾で鳥をばらす方が、よっぽど贅沢じゃないか、と思ったけれど、何しろ、木胴鉄胴からくり胴鳴って通る飛団子、と一所に、隧道を幾つも抜けるんだからね。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分ではそれと気付かなかったゞろうが、自尊心のからくりによる、何ものかへの敵対意識に絶えず弾力づけられている少年であった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹一は、それに何か安二郎のからくりがあると安二郎に喰って掛った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫌悪しているものに逆に心を動かされるという自虐のからくりには気がつかなかった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　二人は抱き合って、今更ながら余りに理不尽と思える運命のからくりを嘆いた。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中の合法というもののほうが、かえっておそろしく、（それには、底知れず強いものが予感せられます）そのからくりが不可解で、とてもその窓の無い、底冷えのする部屋には坐っておられず、外は非合法の海であっても、それに飛び込んで泳いで、やがて死に到るほうが、自分には、いっそ気楽のようでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの兄さんのレヤチーズなどは、ハムレットと同じ歳なのに、もう、ちゃんと世の中のからくりを知っていらっしゃる。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、いまは、その興覚めの世のからくりを知った。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の景勝愉樂の郷にして、内湯のないのを遺憾とす、と云ふ、贅澤なのもあるけれども、何、青天井、いや、滴る青葉の雫の中なる廊下續きだと思へば、渡つて通る橋にも、川にも、細々とからくりがなく洒張りして一層好い。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫌悪しているものに逆に引きつけられるという自虐のからくりには気がつかなかった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでも今年は、去年のように、金色夜叉やロクタン池の首なし事件の覗きからくりや、ろくろ首、人魚、海女の水中冒険などの見世物小屋が掛っているはずだ。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――からくりの全部はこうなんですよ」「けれどなんだってこの男は、兄弟に化けたりなんかする必要があったんでしょう？",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その弁慶が、もう一つ変ると、赤い顱巻をしめた鮹になって、踊を踊るのですが、これには別に、そうした仕掛も、からくりもないようです。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間、風邪をひいて寝たはぢめに、いつかの君の小篇小説「からくり」を読み直して、仲々面白かつた。",
              "citation": {
                "source": "〔小林秀雄氏への公開状〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "怨む、怒る、泣く、笑う、それが覗きからくりのように瞬くうちに変ってゆく若い同士の埒なさを、綾衣はただ馬鹿らしいとばかりは思えなかった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなおそろしい景色が覗きからくりの絵のように彼女の眼の前に展開された。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのからくりの絵はまた変って、林之助と自分とが日傘をさして、のどかな春の日の両国橋を睦まじそうに手をひかれて渡ってゆく……。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
