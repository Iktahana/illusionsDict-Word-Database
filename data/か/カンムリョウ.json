        "examples": {
          "standard": [
            {
              "text": "長年の夢だった海外での個展が成功し、多くの人が駆けつけてくれて感無量だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "苦労して完成させたプロジェクトが無事に発表され、達成感と同時に感無量の気持ちになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "卒業式で友人たちと歌った校歌は、色々な思い出が蘇り、胸がいっぱいで感無量だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "江戸は底知れずおそろしいところだ、と苦労知らずの三粋人も、さすがに感無量の態であった。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」しばらくは、感無量であった。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞこの古戦場を見るために帰りの旅に陸路を選んだ甚兵衛は感無量であつた。",
              "citation": {
                "source": "わが血を追ふ人々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "開館の六月五日を思い返して、うたた感無量なるものがある。",
              "citation": {
                "source": "歴史の流れの中の図書館",
                "author": "――個人的なものから集団的なものへ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "サラリーマンでも土方でも、御指図通り、なんでも、やります」「うれしいわ」　感無量。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は金鍔神父の捕われた穴ボコの中にたち、海を見下して、感無量でしたよ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "長崎チャンポン――九州の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一力も話をきいて感無量。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その八　時計館の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "この植物にも人間の悩みがあるのかなア、と菅谷は感無量であった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十二　愚妖",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それから二時間後、クラヤミの氷川町へ現れた虎之介はガッカリしたように首をふりふり、感無量であった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十二　愚妖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この焼野原を眺めて、そなたはさぞや感無量であろうな。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺も感無量と言いたいところだが、実を云えば頭の中は空っぽうになりおった。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この焼野原を眺めて、そなたはさぞや感無量であらうな。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺も感無量と言ひたいところだが、実を云へば頭の中は空つぱうになりをつた。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "文覚を上座に据え、自分は庭に立って父の首を受取ると、感無量の面持で胸に抱えるのであった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "長年着なれた着衣と引かえに、墨染めの衣に着替えた時は、さすがに感無量の心持であった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "古染付に展示された描線表現のものには、中にいはゆる名画以上の名画に見るやうな感無量のものがある。",
              "citation": {
                "source": "古染付の絵付及び模様",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者の救癩記を読んで一入感無量である。",
              "citation": {
                "source": "小島の春",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "西尾氏が中心になり、水谷氏がスポークスマン、平野氏が選挙対策の責任者というわけだったが、現在、西尾氏が長老になり、水谷氏また病み、平野氏も違った陣営にあることを思うと、十年の歳月を感じて感無量である。",
              "citation": {
                "source": "私の履歴書",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は烏賊虎さんから先生の生涯の事蹟をきき終ると、感無量であった。",
              "citation": {
                "source": "肝臓先生",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "周到で、用心深くて、こんな狡猾な男は居ないし、誰にもこの恥辱を知られずに済むから、感無量でジョージ卿は小切手を同封してブラウンへ短信を書いた。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして感無量な面でながめ入るのであった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけに感無量なものがあった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
