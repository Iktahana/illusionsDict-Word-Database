        "examples": {
          "standard": [
            {
              "text": "相手フォワードのドリブル突破を阻止するため、ディフェンダーが必死でボールをカットオフした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "サッカーの試合で、ロングパスをインターセプトするため、中盤の選手がボールの軌道をカットオフした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「外野手が返球の途中でカットオフプレーを指示し、内野手がボールを正確に処理した。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
