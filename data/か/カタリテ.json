          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この物語の語り手は、登場人物たちの心情を巧みに表現し、読者を引き込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔話の語り手は、独特の節回しで、子供たちを夢の世界へと誘った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ドキュメンタリー映画では、実体験を持つ人物が語り手となり、重厚なドラマを伝えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そこに此の世の喜びの話や悲しみの話は、彼のためには大きすぎる声で語られ、彼の瞳はうるみ、語り手は去つてゆく。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、語り手の心も一緒にすつかり変つたことを表してゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二つの大阪弁の一人称小説を比較してみると、語り手が一方は男であり、他方は女であるという相違だけではなく、まるで同じ土地の言葉とは思えぬくらい違っているのだ。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "スティヴロン氏、或いはストレーヴン氏（彼の名を正確に発音できる土人は少かった）或いはツシタラ（物語の語り手を意味する土語）が、富豪であり、大酋長であることは、最早疑いなきものと彼等には思われた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "之で愈々私は彼等のツシタラ（物語の語り手）となるのだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜毎、島の各地方から来た語り手を灯の下に集めて円座を作らせ、彼等から、古い伝説や古譚詩の類を聞くのが、彼の唯一つの楽しみであった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その折、語り手が申しますのに、これから先うっかりとこの怪談を人に語らば、話し手に禍いがかかるか、聞き手の身に禍いが起るか、いずれにしても必ずともに何ぞ怪しい祟りがあるゆえ気をつけいと、気味のわるい念を押しましたゆえ。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家としての中野さんは、上手な語り手である。",
              "citation": {
                "source": "鼓舞さるべき仕事",
                "author": "――中野重治「汽車の罐焚き」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "民主主義文学は労働階級の動きを表面から模写してゆくのではなくて、すべての勤労者と小市民・インテリゲンチャが歴史の中で、一人一人の必然の過程を通ってどのように新しい推進力として民主革命に参加してゆくかという物語の語り手でなければなりません。",
              "citation": {
                "source": "討論に即しての感想",
                "author": "――新日本文学会第四回大会最終日に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "よかれ、あしかれ、日本の民主主義文学の運動にふれたり、それをまともに論議したりすることは、語り手自身のファッション・ショウめいているそのような場面ではもう｜流行はずれの気風がつくられた。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、ここで昔話の語り手は言う。",
              "citation": {
                "source": "博多にて",
                "author": "AT HAKATA",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ビールに飽いた頃、もう終りが近からうと見に行つて見ると、「必らず草木成佛」のところで、語り手の一特色なるほがらかなラ行音が直ぐ義雄の耳に這入つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "親しく仕えて見聞きした話をし、いつどんな時にこうお言いになったとか、自然の風物に心の動いた時々に、故人の詠んだ歌などを、不似合いな語り手とは見えずに、声だけは慄えていたが上手に伝え、おおようで言葉の少ない人であったが、そうした文学的なところもあったかと、薫はさらに故人をなつかしく思った。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "物語も語り手が根本で、そのやうに色々と印象を変へるらしかつた。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなあてこすりが、この凝つた言ひまはしに憂身をやつしてゐる語り手の気に入らう筈がない。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかにもう一人、語り手がゐたが、その人は（どうもそれを寝しなに思ひ出すのは、ちと具合が悪いけれど）実に身の毛もよだつやうな怖ろしい話をして聴かせたものぢや。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　ここでまたしても、むつかしやのチェレ※ークが語り手を遮ぎつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "語り手の面上には冷汗の玉が吹き出した。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "だのに、その悪魔めが、今度はあの委員の野郎を抱きこみやあがつて……」　かう言ひかけた言葉の半ばが語り手の唇のうへで消えてしまつた――窓が騒々しく打ち叩かれて、硝子が唸りを立ててけし飛んだ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はある時、彼女の贔屓連が催した義太夫会のおり、忠臣蔵が出たとき役々によって語り手が違い、平右衛門など下手から出て山台の下で語ったおり、彼女もお仲間に引出されて迷惑そうな顔もせずにこにこして語っていたのを思いだした。",
              "citation": {
                "source": "豊竹呂昇",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内に始まった饗応の演芸が、いかにも亜米利加三界まで流れてきたという感じの浪花節で、虎髭を生した語り手が苦しそうに見えるまで面を歪めて水戸黄門様の声を絞りだすのに、御祖母様は顔を顰め、「妾はどうしても、浪花節は煩さいばかりで嫌いですよ」といわれる。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は、これまで、自分の作品の中に人物を置く場合には、風景畫のなかに小さな點景人物を置くほどの用意しか持ち合はせなかつた――とまで言はなくとも、それはいつも「私」（語り手）の心のなかに獨得な屈折をして入つてきた幻像に過ぎなかつたのである。",
              "citation": {
                "source": "小説のことなど",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一人の娘を語り手に映つてゐる側からのみ描いていつた。",
              "citation": {
                "source": "小説のことなど",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の心理の動きがどうしても語り手に解らないままに、小説が進展し、その結末に及んでもその心理の上に何等の照明を與へずに、小説を閉ぢる。",
              "citation": {
                "source": "小説のことなど",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "讀後、讀者をもその語り手と共に、一種の謎めいた氣持の中にとり殘させる。",
              "citation": {
                "source": "小説のことなど",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、実際どの程度の語り手であつたかは、私には訣らぬ。",
              "citation": {
                "source": "戞々たり　車上の優人",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども僕が、語らない海を愛するのは、それがすばらしい語り手であることを知っているからだ。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が語り手でなくなることを嘆くまい。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十四曲言歩を、歩言をおそくせず、我等は語りつゝあたかも順風に追はるゝ船のごとく疾く行けり　一―三再び死にし者に似たる魂等はわが生くるを知り、我を見て驚愕を目の坎より吐けり　四―六我續いてかたりていふ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正四年十一月四日　穗積陳重博士淨見寺の墓に詣でて問ひてましかたりてましをあまた世を　　　　　　　　　へたてゝけりな道の友垣と詠ぜられ、穗積八束博士また參詣せられた、この二大法曹の參詣を受けては地下の大岡越前守も定めて滿足したであらう。",
              "citation": {
                "source": "大岡政談",
                "author": "尾佐竹猛校訂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
