        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供たちは、寒稽古で心身ともに鍛えられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "柔道部の寒稽古は、早朝の冷たい道場から始まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うわー、寒い！でも、この寒稽古を乗り越えれば強くなれるはず！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "およし　でも、今は寒稽古の筈ぢやありませんか。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに寒稽古には三尺も積った雪の中で乱どりをやった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその冬の寒稽古には、未明に起きて雪の積んだ二十丁の道を毎朝道場に通った。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私たちはそうして「かるた」を夜明しでとりながら、すぐその足で二十丁ある学校へ寒稽古に通ったのであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれを伊沢氏の寒稽古と謂つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた浜町河岸の大竹という道場へもやはり寒稽古などに通ったものである。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "とり分き日本では寒念仏の、臘八坐禅の、夜業の、寒稽古の、砧の、香の、茶の湯の季節、紫の二枚｜襲に唐織の帯の落着く季節、梅もどきの、寒菊の、茶の花の、寒牡丹の季節、寺寺の鐘の冴える季節、おお厳粛な一面の裏面に、心憎きまで、物の哀れさを知りぬいた冬よ、楽んで溺れぬ季節、感性と理性との調和した季節。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて寒に入って、寒稽古が始まった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり寒稽古の始まる日だ。",
              "citation": {
                "source": "安吾武者修業",
                "author": "馬庭念流訪問記",
                "note": "青空文庫"
              }
            },
            {
              "text": "その終るのが三月十七日で、まる二ヵ月の長い寒稽古だが、昔からの定めだという。",
              "citation": {
                "source": "安吾武者修業",
                "author": "馬庭念流訪問記",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦後は村の定めも実行されなくなって、寒稽古にでる若者の姿が甚しく少くなってしまった。",
              "citation": {
                "source": "安吾武者修業",
                "author": "馬庭念流訪問記",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからまた、冬には、寒稽古といって、千遍弾きということをやる。",
              "citation": {
                "source": "山の声",
                "author": "宮城道雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "また寒稽古といって、寒中に戸障子を明け放して、寒い方へ向って習った中の一番むずかしいものを、百篇とか、千篇とか繰返して弾く。",
              "citation": {
                "source": "私の若い頃",
                "author": "宮城道雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや寒稽古は終わったけれど、未明の冷気の熱汗をほとばせる爽快味はえもいわれず、誘いあわせて、霜ばしらを踏んでくる城下の若侍たちひきもきらず、およそ五十畳も敷けるかと思われる大板の間が、見る見る人をもって埋まってゆく。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この町道場の経験があったので、私は高等学校でも寒稽古に行った。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒稽古の時、痩せた相手とやると痛いので、私はいつでも岡松が来るのを待っていて、彼と組むことにしていた。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治二十六年に寒稽古をしてもらった相手で、まだ元気でいる人が一人いる。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋引きしごと喉強し寒稽古一月十八日　谷中本行寺。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒稽古病める師匠の厳しさよ一月十五日　大崎会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの連中は根気はいいな、寒稽古といって夜徹しやっていることがある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "如法闇夜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「は、は、は、は」　仏頂寺は声高く笑い、こんなことは朝飯前だといわぬばかりに、「修行盛りの若い時分には……」　吉原に流連していても、朝の寒稽古にはおくれたためしがない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "相談の結果、一月五日から柔道の寒稽古を始めることにきまった。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに当分の間柔道の寒稽古がある。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけの歳月を、寒稽古の、土用試合のと、竹刀でぽかぽか撲られた上、一ツ橋から小石川の果てまで、往復の足数だけでも、何千里歩いたことになるか、容易な根気で貰った免許皆伝ではない。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木剣の冷たい肌を頬に当てると、幼年のころ、寒稽古の床で、父の無二斎からうけた烈しい気魄が、血のなかに甦ってくる。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒稽古には、霜夜の庭の素むしろに坐らされて、喉も破れ、凍えた指は、琵琶の糸に、血のしたたりを濡らしまする。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
