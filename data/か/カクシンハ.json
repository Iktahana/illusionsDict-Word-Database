        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "党内では、革新派と保守派の間で意見が対立している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "歴史的に見て、革新派はしばしば既成勢力と衝突してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この運動は、革新派の若者たちが中心となって推進している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "革新派の某氏の議論はごく淺いところで空※りをしてゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、僕は革新派だからね。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が何んと云おうと、革新派の主張だけは僕は変らん。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "新劇復興の兆岸田國士　文学の上では、絶えず思想的な波の起伏が、直接にその時代の作家を――、殊に若いヂェネレエションを刺激して、あらゆる面での先駆的な運動となつて現れるのであるが、演劇の方面では、今日までのところ、所謂革新派と見做すべき一群の擡頭は、常に若干年数の周期を経て繰り返されてゐるやうである。",
              "citation": {
                "source": "新劇復興の兆",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "新たなといふ意味は、当時、巴里の演劇革新派は、エルヴイユウの名を既に見向きもせず、私も亦、時代は変つたと、早くもこの「新古典主義」作家の作品を行李の底にしまひ込んだ頃であつたから。",
              "citation": {
                "source": "「炬火おくり」について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "圓楽、小山三、小はん、龍生らの革新派。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのはつまり、最近の政治当事者は革新派であると共に革新派でなく、革新派でないと共に革新派である、という矛盾だ。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会党など革新派は首切り法案（定員法案）を葬るため頑張ったのだが、ついに審議引延しのタネが切れてしまった。",
              "citation": {
                "source": "私の履歴書",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる革新派にも同じような派閥があって、相剋とも言うべきその争いは、ひとしく錦旗革命を意図している青年将校の間にも分裂をもたらしていた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾垣大将は軍縮の元凶であり、革新派の青年将校と一時気脈を通じていたと見られて、軍中央部から嫌われていた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
