        "examples": {
          "standard": [
            {
              "text": "昭和初期の医療現場では、緊急時にカンフル剤が用いられることがあったそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "心臓の機能が低下した患者に、医師はカンフル剤を処方した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔のドラマで、弱った人を救うためにカンフル剤を打つシーンを見たことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "朝鮮戦争に伴う特需景気が日本経済のカンフル剤として機能したのちの一九五四年十月、三田、玉川両事業部の名称は製造所に戻され、一九六一年四月、事業部制の採用によって今度は事業所と呼ばれることになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
