        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "強風でボサボサになった前髪を直すため、彼女は慌てて手鏡を取り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、ごめん！ちょっと髪を直してくるから、先にお店に入っててくれる？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プレゼンの登壇直前、モニターに映る自分の姿を見て、必死に髪を直した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は話しながら、無意識に耳の横の髪を直す癖がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "朝寝が好きで、髪を直すに時間を惜しまず、男を相手に卑陋な冗談をいって夜ふかしをするのが好きであるが、その割には世帯持がよく、借金のいい訳がなかなか巧い。",
              "citation": {
                "source": "妾宅",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は女が髪を直す時の千姿万態をば、そのあらゆる場合を通じて尽くこれを秩序的に諳じながら、なお飽きないほどの熱心なる観察者である。",
              "citation": {
                "source": "妾宅",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
