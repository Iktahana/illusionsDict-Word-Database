[
  {
    "uuid": "71744ea7-80e0-5945-9b6a-5a66c6b2145d",
    "entry": "欠かす",
    "reading": {
      "primary": "かかす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
