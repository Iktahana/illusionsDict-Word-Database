    "definitions": [
      {
        "index": 1,
        "gloss": "hair (on the head)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「うわっ、このスープの中に髪の毛が入ってる……。すみません、店員さんを呼んでくれますか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女の長く艶やかな髪の毛が、春の風にふわりとなびいて、花の香りをあたりに振りまいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "毎朝、お風呂の排水口に溜まった髪の毛を掃除するのが、彼にとって憂鬱ながらも欠かせない日課だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "髪の毛も、濃くなったようですね。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は珈琲店の椅子で酒を飲み、大衆と共に「あなたと呼べば」を唄つた後で、自ら自分の髪の毛をむしりながら、自分に向つて「この大馬鹿野郎奴」と叫ぶのである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はまた川になる、川の面は、呼吸も吐かず静まりかえっているように見えるが、足を入れると、それこそ疾風が液体になったように全速力で走っている、流れの浅く、彎入した、緩やかなところに背を露わした石がある、苔が厚く活物の緑が蠢めいている、水草の動くのは、髪の毛がピシピシと流電に逆立つようだ。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "金魚藻、梅鉢藻だのという水草が、女の髪の毛のようになびいている中を、子供たちが泳いでいる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士の四合目から以上を輪切りにすれば、木山に対するいわゆる石山で、イワツメグサ、オンタデなど、薄い髪の毛のような草はあっても、眼にいらず、ただ見上げるばかりの岩石の堆積である。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "改札口でなしに、小荷物口の方に向って、三四十人の人の群が、口々に喚き、罵り、殴り、髪の毛を引っ掴みながら、揺ぎ出した岩のようにノロノロと動いて行った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　彼は、音のしないように髪の毛をひっ掴んだ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪の毛は汗でねばねばしていて、ふて腐れたように手にザワザワ捲きついて来た。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉毛と髪の毛がまっ白な北欧の女。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒繻子のゑりがかゝつたそのねんねこがすらつとした色の白い若い守女と眼の大きな髪の毛の黒々とした茫漠としたやうな女の児をつつんでゐたその頃の――明治三十年代のやや古びたおめしちりめんを想像して下さい。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさんはそれをあんまり悲しんでおうぎ形の黄金の髪の毛をきのうまでにみんな落としてしまいました。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊る女の髪の毛のいろいろまちまちなのが当り前だがわれわれ日本人の眼には不思議である。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃は日本人の顔がだんだんに西洋人に似てくるようで、銀座などを歩いているとあちらの映画スターに似たような顔つきをした男女を見かけることも珍しくないがただ髪の毛だけは、当り前のことだが皆申し合せたように真黒である。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒の中折を冠った下から黒い髪の毛が両耳の上に少しかぶさっていたように思う。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面の底のくらやみに、うらうら草の茎が萌えそめ、鼠の巣が萌えそめ、巣にこんがらかつてゐる、かずしれぬ髪の毛がふるえ出し、冬至のころの、さびしい病気の地面から、ほそい青竹の根が生えそめ、生えそめ、それがじつにあはれふかくみえ、けぶれるごとくに視え、じつに、じつに、あはれふかげに視え。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いく年もいく年もまへから、ここに倒れた椅子がある、ここに兇器がある、ここに屍体がある、ここに血がある、さうして青ざめた五月の高窓にも、おもひにしづんだ探偵のくらい顔と、さびしい女の髪の毛とがふるへて居る。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、それら人間の髪の毛にも、春の夜のかすみいちめんにふかくかけ、よせくる、よせくる、このしろき浪の列はさざなみです。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓬はやつれた女の髪の毛のやうに、へらへらと風にうごいてゐた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "干からびた髪の毛のやうなものをつかんだ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃く縮れた髪の毛を、程よくもじょもじょに分け仏蘭西髭を生やしている。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし四家フユ子は英介氏の腕輪のなかに障害馬のように飛こむと、棕櫚の毛皮のような髪の毛を乱雑にカールした黄色い額の波打際を仰向けにして、ずるそうに彼にわらいかけた。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、地震前には漆のように黒かった髪の毛が、急に胡麻塩になって、しかもその白髪であるべき部分は薄汚い茶褐色を帯びている事であった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「午後の御茶」の時間に皆で集まったときに、自分は、この玉虫がいったいどこであの婦人の髪の毛に附着して、そうして電車の中に運ばれたであろうかという問題を出した。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その森の中からとんで来る弾丸は髪の毛一本ほどにま近く、兵士の身体をかすめて唸った。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらはみなからだ中黒い長い髪の毛で一杯に覆はれてまっ白な手足が少し見えるばかりでした。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてだんだん眼がなれて来たときその闇の中のいきものは刀の刃のやうに鋭い髪の毛でからだを覆はれてゐること一寸でも動けばすぐからだを切ることがわかりました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた方の髪の毛一本にも及びません。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪の毛を前へおろして、糊の寝た浴衣を着、暑いのに黒足袋を穿いていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして解した髪の毛の先が触手の恰好に化けて、置いてある鉢から菓子をつかみ、その口へ持ってゆこうとしているのです。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "光かみのけにぞつくり麥穗滴る額からだ青空ひとみにひばりの巣を發見け。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
