        "examples": {
          "standard": [
            {
              "text": "「見て、あれがこと座にある環状星雲だよ。まるで宇宙に浮かぶ宝石の指輪みたいだね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "天体望遠鏡を覗き込むと、淡い光を放つ環状星雲の姿がはっきりと捉えられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "環状星雲は、寿命を迎えた星が放出したガスが輝いている姿なのだという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それから環状星雲といふのもあります。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから環状星雲というのもあります。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはきっと、私の未来の妻だ」「ええ、そうよ、あたし決して変わらないわ」「結婚指環をあげますよ、そら、ね、あすこの四つならんだ青い星ね」「ええ」「あのいちばん下の脚もとに小さな環が見えるでしょう、環状星雲ですよ。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このようにして星雲物質が集積されるために一種の巨大な環状星雲ができる。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "環状星雲の生成も多分これと同様なふうに考えてよいであろう。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
