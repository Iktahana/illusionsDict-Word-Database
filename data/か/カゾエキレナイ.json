[
  {
    "uuid": "eaeed592-c936-5075-bf3e-c10fa247091e",
    "entry": "数え切れない",
    "reading": {
      "primary": "かぞえきれない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
