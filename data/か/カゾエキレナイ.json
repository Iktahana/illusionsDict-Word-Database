    "definitions": [
      {
        "index": 1,
        "gloss": "countless",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "砂浜には数え切れないほどの星の砂が散らばっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼にはこれまで数え切れないほどのピンチを救ってもらった恩がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ライブ会場の熱気と、数え切れないペンライトの光に圧倒された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "新しくリリースされたアプリには、まだ数え切れないバグが潜んでいるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "人間が球を飛ばせたり転がしたりする遊戯の種類が一体どのくらいあるか数え切れないほどあるらしい。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「浮世の風」となるとこんな二つや三つくらいの因子でなくてもっと数え切れないほど沢山な因子が寄り集まって、そうしてそれらの各因子の結果の合成によって凪になったり風になったりするものらしい。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室には、人はたった一人居たきりであるが、壁には数え切れないほど沢山の外套と帽子が掛け列ねてあった。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々の美しいタチングな場面が丁度そのお伽噺の挿画のように順々にめくられて行く、そうした美しい挿画が数え切れないほど沢山あるのである。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には日本古来の知恵を無視した科学が大恥をかいた例は数えれば数え切れないほどあるのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の頃、神田の夜店の中に交じってコリント台を並べて客を待っているおばさんやおじさんが数え切れないほどあった。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "特にルクレチウスによって後世に伝えられたエピキュリアン派の所説中には、そういうものが数え切れないほどにあるようである。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座でコーヒーを飲ませる家は数え切れないほどたくさんあるが、家ごとにみんなコーヒーの味がちがう。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このただ一枚の飛び石の面にだけでも、ほとんど数え切れない喜怒哀楽さまざまの追憶の場面を映し出すことができる。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな人間はまず少ないであろうが、これとよく似た係蹄に我れとわが手にかかって人の虜になり生き恥をさらす人は実に数え切れないほど多数である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母が糸車で一生涯かかって紡ぎ得たであろうと思う糸の量が数え切れない機械の紡錘から短時間に一度に流れ出していた。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "数え切れないほど大勢の男がみんな丸裸で海水の中に立ち並んでいる。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れた日の午さがりで、大きな貨物船の沢山浮かんだ碧い品川の海や、数え切れない程の煙突や、とたん屋根や、洗濯物が一っぱいかかっている物干しや、いろんなものが見えました。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちいちとても数え切れない。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は今までに人情の上から吾に数え切れない借があろう。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "声を止めて返事に聞き耳を立てるが、おのれの叫び声のほか返ってくるものはなく、ものわびしい静かな谷あいにこだまするだけ、数え切れない響きが自分の耳へと戻ってくるだけだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "若杉裁判長が、いかにも人情を噛み分けた、同情の溢るるような判決を被告に下した実例は数え切れないほどあります。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり大宇宙には、本当に数え切れないほど無数の生物があると思っていいのだ」「なるほど、それは気味のわるいことですねえ」「気味のわるい以上のものだよ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと思い出して見たばかりでも、幻のように立つ像は数え切れないほどある。",
              "citation": {
                "source": "雪の障子",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、こういう種類のお上の御深切から出た「検束」ならちょっとは数え切れないほどあるが、それは何も僕の悪事でもなければ善事でもない。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日に幾度とちょっとは数え切れないほどみんなはよく屁をひった。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では作家の数は数え切れない程であるが、文壇ジャーナリズムに登場して来る専門の文芸評論家の数は可なり限られている。",
              "citation": {
                "source": "文芸評論の方法について",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま鳩麦をかじった鼠にも、格別の好意はないのだけれども、その齧りかたが一定の方法をもっていて、しかも何百粒か数え切れない粒を、その方法でかじりつづけて行ったところに一種の気持よさを感じた。",
              "citation": {
                "source": "鼠と鳩麦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、数え切れないくらいの形態がある。",
              "citation": {
                "source": "博多にて",
                "author": "AT HAKATA",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の数え切れないくらいの衣装は変化したが、農夫の藁の笠、蓑それに草鞋の履物は依然としてそのままである。",
              "citation": {
                "source": "石仏",
                "author": "THE STONE BUDDHA",
                "note": "青空文庫"
              }
            },
            {
              "text": "言うなれば彼女自身は、我々西洋人の観念とは違った過去に取り憑かれた精神的空間にすぎない――その過去とは、数え切れないほどの世紀を通して、すべての者たちが一つとなって生きて、感じ、そして思考してきたものである。",
              "citation": {
                "source": "勇子",
                "author": "一つの追憶",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその女は数え切れないほどの年月に渡って、たなびく霧を越え、杉の木陰の静寂の中を抜けて、美しい場所をたびたび訪れるだろう。",
              "citation": {
                "source": "勇子",
                "author": "一つの追憶",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫れは巨大な無数の蟇が其処を住家にして住んでいるからで、そう云えば本当に初夏の候になると、水草の蔭や浮藻の間に、疣々のある土色の蟇や、蒼白い腹を陽にさらして、数え切れない程の沢山の蟇が住んでいるのが、彼にも見えた。",
              "citation": {
                "source": "高島異誌",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに数え切れないほどたどってきた、神経細胞に刻み込まれたこの思考回路の先に「市場はＩＢＭ ＰＣを選んでいる」という結論と、「マイクロソフトからは互換ベーシックが調達できない」という結論の意味を喪失させる条件が控えていることを、薄く締めた唇を固く合わせながら浜田は噛みしめていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かぞえきれないほどたくさんのさかなたちが、ガラスのかべのほうにむかっておよいでくるのが見えました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
