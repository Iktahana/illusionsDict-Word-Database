[
  {
    "uuid": "7edf698b-35f6-5585-a795-6106e73de761",
    "entry": "乾かす",
    "reading": {
      "primary": "かわかす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to dry (clothes, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "洗濯物がたくさんあるから、ベランダに干してよく乾かしてね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "雨で靴がびしょ濡れになっちゃった。ストーブの近くで乾かさないと。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "デリケートな水彩画だから、柔らかい布でそっと乾かしました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "えー、まだ湿ってるの？もっと風通しの良いところで乾かしたいな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "地下室の中に作った天秤室の空気を乾かすのに、毛布を使ったりしたところにレーリーの面目が現われている。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五日続いた曇天に、茅で葺かれた収穫蔵の屋根も、その前面から広くとって、ずっと奥庭との境の垣根まで続いて春や秋、の頃の収穫物を干し乾かす場所に宛ててある外庭の土も、皆一様に灰色に、いじけて下駄の歯で荒らされた地面の上などは、こぶこぶのまま、凍り固まって居るのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍濡鼠のごとくなって陸に上がり、茶屋でボロ洋服を乾かす。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "下塗を乾かすために団扇で煽いだりしたものですが、今はそんな暢気な事をやっていられないから、はじめから濃いやつを塗る。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きいのは三寸位の本物の沙魚やドンク（ダボハゼの方言）の二三十位から、一寸にも足らぬハラジロの無数を、一々切出小刀で腹を割いて一列に竹串に刺し、行燈型の枠を取付けた白角い七輪のトロ火で焙り乾かして、麦稈を枕大に束ねて筒切りにしたホテというもの一面に刺して天日に乾かす。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして乾かす時に焦がされたんだ、とね。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "額にはワセリン、目にはベラドンナ、頬骨には紅、唇の周りには蜜蝋を薄くつけて乾かす。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡り上ると共に濡れた着物を乾かす智慧も出ず、長い間私は石の上につき坐つて息を入れた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "桃の實",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼過からがらりと晴上って、蛇の目の傘を乾かすような月夜になったが、昨夜から今朝へかけて暴風雨があったので、大川は八｜分の出水、当深川の川筋は、縦横曲折至る処、潮、満々と湛えている、そして早船乗の頬冠をした船頭は、かかる夜のひっそりした水に声を立てて艪をぎいーぎい。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日の長い、十一時間または十二時間の労働を終えて、草臥れ切った肩に、重い橋桁を担いで帰って、それを切って割って薪にするもの、その薪を、飯場の中の焚火の周りに立てかけて乾かすもの、そういう間接な好意でなく、いきなり睦ちゃんの、お尻を撫でる事によって、意志表示するもの。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで三ちゃんは、水洗をいい加減にして急に乾かすと、それを印画紙にやきつけた。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　現実的で、その上頭の鈍い私は、何事でも手近な例を取らないと話も出来ない私は、相手の折角の話材を乾かすやうにそんなことを云つた。",
              "citation": {
                "source": "環魚洞風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夕方帰庵したけれど、濡れた着物を乾かす火もなく、空いた腹を充たす米もない、そして無一文、無一物だ、――暮羊君を徃訪する、私を待つてゐてくれたが今日は実家へ行きました、と奥さんが残念さうにいはれる、詮方なく街へ出てＷ店に腰をおろす、酒を借り飯をよばれ、はては泊めて貰つた！",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご存知のように、日本の染物屋は天日で乾かすために、家の前で竹の柱と柱との間に、濃紺、紫、バラ色、薄青、パールグレイなど、さまざまな色の絹や綿の長い布を広げている。",
              "citation": {
                "source": "死生に関するいくつかの断想",
                "author": "BITS OF LIFE AND DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々蛙の背中を乾かす為にあるのである。",
              "citation": {
                "source": "蛙",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここには、チチコフ一家にとっては親戚にあたる、皺くちゃの梅干婆さんで、いまだに毎朝、市場へ出かけては、帰って来ると靴下をサモワールで乾かす婆さんが住んでいた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の従者は庭で徒渉に濡れた衣類を乾かすのであった。",
              "citation": {
                "source": "壁の眼の怪",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "やきものは正しい形を造つても乾かすうちに歪みがくる、素燒で又狂ひがくる、藥をかけて燒きあげると又多少の歪みが出る。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来上った絵は、よく乾かす事が必要です、乾くとその絵具のついてある面へ、その絵の調子によって、黒い紙かあるいは藍、あるいは鼠色の紙をガラスと同じ大きさに切って当てます、その紙の地色によって、絵の調子を、強めたり弱めたりする事が出来ます。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来上った絵は、よく乾かす事が必要です。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "掘り出した泥を天日で乾かすために、笹の葉で屋根をかけた棚に蚕を置くまぶしのようなものに泥をならべて、幾段も幾段も置いてある。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ弁｜足らず、筆伴わず、いわゆる濡れ鼠を乾かす用に立つものではないかと恐れております。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の甥は、紙を乾かすのを手伝ひながら、『軽いものですから、二階の焼落ちるときに跳ね飛ばされたんでせう』などと云つた。",
              "citation": {
                "source": "念珠集",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし洗えば天日で干すと碾きにくいから水を切って塗物の箱へ入れて乾かすのだ。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の着物は前に申しました通り、馬鹿に沢山綿がはいってるものですから、ぐっしょり濡れてる膝から下を乾かすのに、女中はいつも眉をひそめたのです。",
              "citation": {
                "source": "香奠",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪いのは、凍らして乾かす時の不出来に由来し、いざというときに固くてものにならないのや、やわらかすぎていけないものなどである。",
              "citation": {
                "source": "高野豆腐",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、雲霧も次第に薄らぐ、先ず安心、と濡た衣裳を乾かす。",
              "citation": {
                "source": "穂高岳槍ヶ岳縦走記",
                "author": "鵜殿正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで焚火をして、濡れた衣類を乾かす。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾たびとなく足をすくわれ、のめり、手を突きながらも、温度は手が凍えるまで下らなかったので、金剛杖や糸立を強くつかんで、大宮口の五合目へ、ほうほうの態でたどりつき、たき火でぬれた上衣を、かわかすのに暇取った。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "はでなおじさんだなァ黙っているから変だよ君はぬれたきものをいつかわかすのどこへでも水をもって旅行しているらんちゅうのおじさんどこから来たの君はだまっているからみんなが君を笑っているよ。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
