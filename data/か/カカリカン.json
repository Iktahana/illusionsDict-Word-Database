[
  {
    "uuid": "fe6ff765-b4a8-5dd1-9ed9-53abec681261",
    "entry": "係官",
    "reading": {
      "primary": "かかりかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
