          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「仕訳のルールがまだ曖昧なんだけど、資産が増えた時は借り方に記入すればいいんだよね？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "複式簿記の帳簿を確認したところ、借り方と貸し方の合計金額が一致せず、どこかで入力ミスがあるようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "銀行から融資を受けた際、現金の増加を借り方に、借入金を貸し方に計上する処理を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この振替伝票、借り方の科目が間違っているから、至急修正して再提出してください。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「小指は高くゝりの覚」で貸借の争議を示談させるために借り方の男の両手の小指をくくり合せて封印し、貸し方の男には常住坐臥不断に片手に十露盤を持つべしと命じて迷惑させるのも心理的である。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "エチオピアで同様の場合に貸し方と借り方二人の片脚を足枷で縛り合せて不自由させるという話と似ていて可笑しい。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "忍月居士｜嘗て外来物を論じて、詩人が外来物の補助を借り方便にすべき事を言ひたる事ありしが、他界に対する観念は補助又は方便にすと言ふが如き卑下なる者にあらず。",
              "citation": {
                "source": "他界に対する観念",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまの文芸家諸君は、論理よりも常識の方に親んでゐるから、あんな馬鹿げた問答もせず、あんな非常識な借り方もしようとはしないに違ひない。",
              "citation": {
                "source": "貸家を探す話",
                "author": "高田保",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも長い汽車の道中とか、つい隣席にゐる人の物なら分つた話だが、大阪人のはその借り方がいかにも不躾で、づうづうしい。",
              "citation": {
                "source": "阪神見聞録",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すつかりかたをつけてしまふんだつて。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはあれですっかりかたが着いたと思ってせいせいして働いていたのであります。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはもうすっかりかたづけられていて、矢部を正座に、父と監督とが鼎座になって彼の来るのを待っていた。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃこちらがすっかりかたずいたうえで、札幌にも出ておいでなさい。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとうそれが争いのもとになり、十年来の親類つきあいが今じゃすっかりかたきどうしとなったんだというんですがね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "栃のように目を丸めて、一大事とばかりかたずをのんだその鼻先へ、お冬は火のようにほおを染めながら、恥じに恥じつつ、上半身の玉なすはだをあらわにさらしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "……文債書債をすつかりかたづけた、ほつかりする、今日はとりわけて暑かつた、三十度を何度昇つたらうか。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今徹夜する程いそがしいのだから、二三日してすっかりかたづけましょう」　今机がいるのではないらしいから「――私はもう行くよ」「それなら尚問題ない」「ああ、私が居なくなればいつも問題はないよ」　アセモに粉をふらしている。",
              "citation": {
                "source": "無題（九）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三面の一寸した報道にもはやく報道すると云ふ方にばかりかたむいて、真実を報じやうと云ふ堅実な考へはまるでないやうに思はれる。",
              "citation": {
                "source": "女教員の縊死",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "この花は曼珠沙華のやうに葉がなしに突然と咲く花で、花の形は百合に似たやうなのが一本に六つばかりかたまつて咲いて居る。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "転位の世界に於ても、取扱われる現実的な事柄は、常に現実の現象の方へばかりかたよりがちであって、現実の精神へはなかなか高まり難い。",
              "citation": {
                "source": "神話と青春との復活",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋をすっかりかたづけて北をあける。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜具もすつかりかたづいて、ただ何となく女臭いいきれの漂つてゐるのが名殘だつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士の悔悟「やれやれ、谷博士は無事にこの研究所へ帰って来られたし、おそろしい超人間Ｘ号は、息の根をとめられてしまったし、これで長いあいだの怪事件も、すっかりかたづきましたな。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おひなさまというので、国男、美学の本をかりかたがた三越のおこわの折を持って来てくれた。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "其那有様で、今は西洋洗濯でまあどうやら行って居るのだけれ共、主人が考えなしにポンポンと借りて来る金を返すにいつも追われる様なので、子供の時分から貧困に頑なにさせられたお関の病的な気持は又もう一度巡って来た変転期にすっかりかたく強められて仕舞ったのである。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "書だけ分かって他のものは分からないというのは分かりかたが浅いに外なるまい。",
              "citation": {
                "source": "書について",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "書がその人の人となりを語るということも、その人の人としての分かりかたが書に反映するからであろう。",
              "citation": {
                "source": "書について",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「わかりかた」についての私の観察はたぶん間違つてはゐない。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ひとびとがどんな疑いをいだいたとしても、その疑いは、翌日になって正式の文書がとどいたので、すっかりかたがついた。",
              "citation": {
                "source": "幽霊花婿",
                "author": "ある旅人の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし亭主は、あそこに、萎びた草が少しばかりかたまって生えているところの下におります。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばかりかたいへん心配してある日、釣台で次郎吉を湯島までかえしてよこした。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "……でもね、惜しいことに、もう、すっかりかたがついてしまったんで。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "都鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれで二日ばかり、随分へんな御飯たべたわね」「ああ、ロシアだけでしょうからね、正餐が三時から五時だなんていう習慣のところは――」　秋山がそういうのを、瀬川が、「そりゃ吉見さんにも似合わないぬかりかたでしたね」と笑った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、その軽さ、フワフワ工合に於ては、すっかりかたまっていて、もう変りっこなしと皮膚で云っているような。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
