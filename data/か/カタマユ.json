        "examples": {
          "standard": [
            {
              "text": "彼は相手の提案に片眉を上げて、不信感をあらわにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女が冗談を言うと、父は面白がるように片眉を少し吊り上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "俳優は舞台上で片眉をぴくりと動かし、観客の笑いを誘った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "女神の片眉が潜められたが声は美しく徹っていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、いゝから／＼下に坐って落付きなさいってば、ほんとに大きな身体をしている癖に子供っぽいったらありゃしない、この人」　片眉を挙げて慈しみ深く、ころ／＼と笑ってやります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　宮子は頭を垂れた甲谷の首の上から、片眉を吊り上げた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかには、片鬚、片眉を剃り落とされた上で、放逐になったものが十三人ありました。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "抜いて見ろ」　……なが話を結んだ左膳、片眉上げて大笑する。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
