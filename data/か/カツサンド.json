        "examples": {
          "standard": [
            {
              "text": "新幹線の中で食べるカツサンドは格別においしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このカフェのランチメニューには、ジューシーなカツサンドがあるよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "駅弁といえば、やっぱりカツサンドは外せない定番だよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "既往の天子法皇を捉へて、地獄に墮すを、手柄めかすやうなる事をばなさず、その生れあひたる世に立ちて、男性のカツサンドラ（希臘の昔物語に見えたる巫女）となり、法皇王侯の嗔を懼れずして預言したるは、希臘悲壯劇の中なる「ホロス」の群の如くなりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食に、ゆふべとったカツサンドがある筈なので何うしたと言ふと、感じの悪い女中、「一夜たってゐるからと思って犬に食はせました」とヘラ／＼笑ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すし、カツサンド、なべやき、それに天丼といふ取り合せが可笑しい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
