        "examples": {
          "standard": [
            {
              "text": "授業が退屈すぎて、後ろの席の親友が丸めたプリントの紙礫を投げてくるのが唯一の楽しみだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「やめろよ！先生に見つかったらどうすんだよ！」と小声で言いながら、紙礫を投げ返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お祭りの最後、山車の上から色鮮やかな紙礫が雨のように降り注いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供たちが新聞紙を丸めて作った紙礫で、即席の雪合戦ごっこを始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それに、死人が埋もれている地底の世界からも、絶えず紙礫のようなものが、ヒューヒューと打衝って来るんだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "濡らして打ちつけたらしい紙礫が、額の面一面に附いていました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、お笑いなさいまし、御一緒じゃありませんが、金吾様も、今日は後から此処へ来るそうです」　次郎が揶揄うその顔へ紙礫をぶつけて、おりんは月江と共に玄関へ駈け出しました。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
