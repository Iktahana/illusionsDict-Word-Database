        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祝宴の合図とともに、威勢のいい掛け声で酒樽の鏡を叩き割った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「せーの！」という合図で鏡が開かれると、辺りに日本酒の芳醇な香りが漂った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新装開店の記念に鏡開きが行われ、集まった客に升酒が振る舞われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "木槌で樽の鏡を力強く叩くと、パカッと綺麗に割れて歓声が上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "page added at the beginning of a document mentioning its purpose, date, author, etc.",
        "register": "standard",
