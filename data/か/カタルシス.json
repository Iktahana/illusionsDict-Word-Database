        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「はぁー、泣いた泣いた。ラストシーンのカタルシスがすごかったね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "泥沼の愛憎劇の末、全てが灰になる結末に不思議なカタルシスを感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "溜まりに溜まった不満を一気に吐き出し、彼はかつてないカタルシスを得た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "最後に、じぶんにとって、ほんとうに重要なのはなにか、ということだけが、脅迫観念になるんだ」　カタルシスのようなものを感じながら、慶一は高志のことばに耳をかたむけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "美学者はこれを「カタルシス」と呼んだのであるが、プラトンの美学、アリストテレスの美学はこんな芸術の世界を、頭に描いているのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者でいうカタルシス（陶瀉）を起して、こころが、純化され、浄化されると考えるのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は依然劇場へカタルシスを求めて行く。",
              "citation": {
                "source": "美しいだけでは間にあはない",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の求めるカタルシスの概念そのものが既に變つて來てゐるのだ。",
              "citation": {
                "source": "美しいだけでは間にあはない",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "寫實主義の時代にはカタルシスの概念は個別的であつた。",
              "citation": {
                "source": "美しいだけでは間にあはない",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "可視的世界の描寫と人間性格のまことらしき再現に依つて人々は夫々の心裡に個別的なカタルシスを行つた。",
              "citation": {
                "source": "美しいだけでは間にあはない",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は人々の心にもつと此の時代に普遍的なカタルシスが行はれねばならないと思ふ。",
              "citation": {
                "source": "美しいだけでは間にあはない",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかでかれは、自殺は罪悪ではない、むしろカタルシスを目的とする、古風な錬金術のながれを掬むものだといふのである。",
              "citation": {
                "source": "希臘十字",
                "author": "高祖保",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの錬金術と遺書によるカタルシスは、どれほどわたしに、恐怖的な迷惑をかけたであらうか！",
              "citation": {
                "source": "希臘十字",
                "author": "高祖保",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな日常のなかで、蛇退治の物語はなんとわかりやすく爽快な、カタルシスであったことか。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
