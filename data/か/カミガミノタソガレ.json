    "definitions": [
      {
        "index": 1,
        "gloss": "Twilight of the Gods (music drama by Richard Wagner)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ワーグナーの「神々の黄昏」の終局で、舞台は炎と水に包まれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「バイロイト音楽祭で『神々の黄昏』を聴くのが長年の夢だったんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "指揮者のタクトが振り下ろされ、重厚な「神々の黄昏」の序奏が始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その映画のラストシーンは、北欧神話の「神々の黄昏」を彷彿とさせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "神々の黄昏中のジーグフリート、ブリュンヒルデは、ドイツのりっぱな夫妻として、たがいの眼に、とくに公衆の眼に、浮華｜饒舌な夫婦の情熱を盛んに見せつけていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "神々の黄昏が来て、ただ無信仰の眼に好奇的にさらされるであろう悄然たる古寺の姿を僕は想像するのである。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「ラインの黄金」「ワルキューレ」「ジークフリート」「神々の黄昏」の四部作はワグナーの楽劇の理想を具現した大傑作であるばかりでなく、実に古今の音楽史上に燦たる大金字塔でもあったのである。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニーベルンゲンの指環「ラインの黄金」「ワルキューレ」「ジークフリート」「神々の黄昏」の四部から成るこの大楽劇のレコードは、部分的にはかなりたくさん入っている。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神々の黄昏」もストコフスキーの大袈裟な総合音楽以外にはあまりレコードはない。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを要するに、ワグナーのレコードとは「バイロイトの祝典レコード」とトスカニーニの「ワグナー名曲集」とムックの楽劇「ニュールンベルクの名歌手」序曲、楽劇「神々の黄昏」、「パルジファル」前奏曲と、フルトヴェングラーの「パルジファル」、ワルターの「ワルキューレ」は逸することが出来ない。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
