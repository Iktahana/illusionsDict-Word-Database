        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その古い写真集には、19世紀の監獄での過酷な生活が写し出されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「まさか自分が監獄に入るなんて、夢にも思わなかったよ。」と、彼は深いため息をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ドキュメンタリー映画は、現代の監獄における受刑者の処遇に焦点を当てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ここにいるのは、過ちを犯した人間たちだが、彼らにも人間としての尊厳があるべきだ。」と看守は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "因に、集中の「郷土望景詩」五篇は、中「監獄裏の林」の一篇を除く外、すべて既刊の集に發表した舊作である。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "監獄裏の林監獄裏の林に入れば囀鳥高きにしば鳴けり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "監獄裏の林　　前橋監獄は、利根川に望む崖上にあり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷土望景詩（再録）　　郷土望景詩五篇、中「監獄裏の林」を除き、すべて前の詩集より再録す。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見返る門柳監獄の壁にかくれて流れる水に漣※動く。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園と監獄、すなわち、今の刑務所との境界に、昔は濠があった。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、監獄に抛り込んである首謀者共が、深夜そうっと抜け出して来て、ブン殴っておいて、またこっそりと監房へ帰って、狸寝入りをしている、と云う考えは穿ちすぎていた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな調子だと、善良な人民を監獄に入れて、罪人共を外に出さなけりゃ、取締りの法がつかない」と、「天神様」たちは思わない訳には行かなかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、乳色の、磨硝子の靄を通して灯を見るように、監獄の厚い壁を通して、雑音から街の地理を感得するように、彼の頭の中に、少年が不可解な光を投げた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺がよしんば死なないにした処で、――今度の事――で監獄に打ち込まれるとしたらどうだ！",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、自分が生れると直ぐの年から、母親の背に縛りつけられて、毎年、警察や、裁判所や、監獄の門を潜ったことを思い出した。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴あ死んでるぜ」　彼は監獄から出たての放免囚見たいに、青くなって云った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんが監獄へ入るやうなそんな悪いことをした筈がないんだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎ監獄懲罰日誌　（林房雄氏）　林氏に對する私の豫備知識は貧弱である。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹雪　（岩藤雪夫氏）　北海道の監獄部屋のことが書かれてゐる。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "監獄へこそ行かなかったが、警察へはたびたび呼びつけられていた。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんが監獄へ入るようなそんな悪いことをした筈がないんだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "拳闘場の鉄梯子道の岐路でこの二人が出会っての対話の場面と、最後に監獄の鉄檻の中で死刑直前に同じ二人が話をする場面との照応にはちょっとしたおもしろみがある。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんが監獄へはいるようなそんな悪いことをしたはずがないんだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんが監獄へ入るやうなそんな惡いことをした筈がないんだ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二歳ごろの時、浮浪少年とのかどで、しばらく監獄に飼われていたが、いろいろの身のためになるお話を聞かされた後、門から追い出された。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイヌと、熊と、樺戸監獄の脱獄囚との隠れ家だとされているこの千歳の山の中から、一個の榴弾を中央の学界に送るのだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "監獄に連れて行くからそう思え。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ監獄へ連れて行くぞ。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「自分がゆすられて、自分が監獄へ行つてたまるものか。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く監獄へいれてしまへば始末がつく。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て近所の女房たちと一しよに、茄子や胡瓜の籠をしよつて町へ売りに行つたとき、監獄と云ふものを態々見物に行つたことがあつた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの当時蕪木君は××の監獄へ送られて居たのでした……。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
