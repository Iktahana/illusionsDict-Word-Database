    "definitions": [
      {
        "index": 1,
        "gloss": "thus",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は長年の研究を続け、斯くて、ついに画期的な理論を打ち立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "両者は互いに譲らず、斯くて交渉は決裂した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "英雄は最後の力を振り絞り、魔王を打ち倒した。斯くて、世界に平和が訪れたのである。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "斯くて、カマは幾度かその後とも掛けられる。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて、ユマニテと詩と、仮りに全然無関係なものだとしても、ユマニテに感じる人にでなければ詩は生れないし又、観賞も出来ぬわけだといふことは云へる。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ　斯くて――Ｓ＝大広間　殿様の御座へ、殿様がお座りになる。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "喇叭も吹く、斯くて棧道にかゝつてから第一の停留所に着いた所の名は忘れたが此處で熱海から來る人車と入りちがへるのである。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて、慧鶴は生きる力を求めて、わずかに自分の中にある名望の慾に探り当てた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きかせばや信田の森のふる寺の小夜ふけがたの雪のひゞきを　斯くて三十四歳の時は、押しも押されもせぬ一廉の禅師になり、亡師のあとを継いで松蔭寺の住職となり、まだ破れ寺ではあるが、そこに蟠※してぽつぽつ集って来た雲水に向って教育をはじめた頃である。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて幸豐君は杢を擧げて、一國の老職となさむと思はれけるが、もとより亂世にあらざれば、取立ててこれぞといふ功は渠に無きものを、みだりに重く用ゐむは、偏頗あるやうにて後暗く、はた杢を信ずる者少ければ、其命令も行はれじ、好き機もがなあれかしと時機の到るを待給ひぬ。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯爵は三番目の娘の露子に向って、「露子、和女は何うじゃ」　露子は此時初めて口を開き、「ハイ、妾何んだか恐い様に思いますけど、阿父様の仰しゃる事なら参りましょう」　斯くて相談は定まり、三人の娘は一人ずつ流星の落ちた森林を探検する事となった。",
              "citation": {
                "source": "黄金の腕環",
                "author": "流星奇談",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて夜半まで草を分けて詮議したが、安行の行方は依然不明であった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて此処よ其処よと捜し廻る中に、夜が明けた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて約二十分の後には、大きい枝を組み合わせ、長い蔓を巻き付けて、人を容るるに足るほどの畚を作り上げた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて一年ばかりも過ぎると、或夜何者か城内へ忍び入って、朝高が家重代の宝物たる金の兜を盗み去ったのである。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて婦人が無体にも予が寝し衾をかゝげつゝ、衝と身を入るゝに絶叫して、護謨球の如く飛上り、室の外に転出でて畢生の力を籠め、艶魔を封ずるかの如く、襖を圧へて立ちけるまでは、自分なせし業とは思はず、祈念を凝せる神仏がしかなさしめしを信ずるなり。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて長谷場純孝氏の提議にて討論終結の動議成立し、杉田議長採決を宣したるに出席總數三百四十五票中決議案を可とする者　百六十八票否とする者　　　　　百七十七票にて戰は僅々九票の差にて政府黨の勝利に歸し申候。",
              "citation": {
                "source": "雲間寸觀",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "同年六月二十一日東京朝日新聞は「無政府主義者の全滅」と題し、和歌山に於ける大石、岡山に於ける森近等の捕縛を最後として、本件の檢擧も一段落を告げたるものとなし、斯くて日本に於ける無政府主義者は事實上全く滅亡したるものにして、第二の宮下を出さざる限りは國民は枕を高うして眠るを得ん云々の文を掲げたり。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて我々は、此革命が如何なる事情の下に、如何なる風に成し遂げられるかは分りませんが、兎に角萬人の自由、平和の爲めに革命に參加する者は、出來得る限り暴力を伴はないやうに、多く犧牲を出さぬやうに努むべきだと考へます。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて滅亡とならずして立派な革命は成就せられた。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて永らく女から遠ざかっていたわたしは女の肉体なるものに仄かな月明りを感じ、神聖な白い碑を感じ、長生の霊果を感じるのだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて、わが運正しき紅玉の妙音楽は極みある命数の大歓楽に鳴りひびく。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて余は公然｜独逸帝国に対する敵となり終れるものの如し。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　斯くて、若くして自分の寿命の短かいであろうことを覚悟させられた時、当然、一つの安易な将来の途が思浮かべられた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くてギラ・コシサンと其の妻のエビルとは二人とも、但しめいめい別々にではあるが、幸福な後半生を送ったと、今に至る迄村人達は語り伝えている。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "越中｜殿して討死つかまつらん」と晴賢を落し、斯くて、三浦越中守、羽仁越中守、同将監、大和伊豆守等骨を砕いて戦った。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "元就は斯くて十月五日に二十日市の桜尾城に於て凱旋式を挙行しているが、彼は敵将晴賢の首級に対してもこれを白布にて掩い、首実検の時も、僅かに其白布の右端を取っただけで、敵将をみだりに恥かしめぬだけの雅量を示している。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて、大阪方は明石全登、御宿正友、仙石｜宗也の諸部将相次いで戦死し、城内では内通者本丸に火をかけ、城内狼狽を極め、遂に松平忠直第一に城に入り斬獲二万余に上る。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて二十七日には、家康や信雄に迎えられて沼津城に入って居る。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて「小田原城中群疑蜂起し、不和の岐となつて、兄は弟を疑ひ、弟は兄を隔て出けるに因て、父子兄弟の間も睦じからず、況や其余をや」の乱脈振りとなった。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて、会津藩と新撰組は、午後八時を期して、祇園会所に集合する筈であつたが、会津側が人数の繰出しに時間がかゝり、午後十時近くなるのに、約束の場所に参着しない。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くても尚詩といはるべき歟。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くても精進日なるか。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
