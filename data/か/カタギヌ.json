[
  {
    "uuid": "103d59a3-d72a-540a-a662-51bf560ae637",
    "entry": "肩衣",
    "reading": {
      "primary": "かたぎぬ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
