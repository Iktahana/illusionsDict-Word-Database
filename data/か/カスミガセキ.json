          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "霞ヶ関の官庁街は、日本の政治の中枢として機能している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学生時代、霞ヶ関で働くことを夢見ていた時期があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ニュースでよく霞ヶ関からの発表が報じられているのを見かける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "霞ヶ関駅を降りると、背の高いビル群が立ち並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "此の平太郎は江戸の霞ヶ関にあった藩の上屋敷に来たこともあったので、逢って本人から其の話を聞いたものもあった。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "訣れに池上は昼、霞ヶ関の茶寮で会席料理を御馳走して呉れました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "訣れに池上は昼、霞ヶ関茶寮で会席料理を御馳走して呉れました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　前記明治二十五年喜多能静氏追善能のため只圓翁は上京し、野中到氏宅に滞在していたが、翁は毎夜のように侯爵黒田長知侯のお召を受けて霞ヶ関に伺候した。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「明朝午前十時東亜局長遠山彦太郎は霞ヶ関の東亜局を九十六号の自動車で出て、桜田門を通過して東京駅に向かうことになっている。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　その翌朝の九時頃、霞ヶ関の東亜局の一室で、露木秘書官が、朝の一便で着いた手紙の整理をしていた。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、麹町霞ヶ関に江原桂助という旗下（これは漢学に達して、後には御目附に出身した人）が住んでいた。",
              "citation": {
                "source": "お住の霊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……霞ヶ関まで、一両でやってくれ」「一両は要らねえ。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は毎晩社を出てから、丸之内や銀座方面をブラブラして、どこかで一杯引っかけてから、霞ヶ関の一番左の暗い坂をポツポツと登って、二時キッカリに三年町の下宿に帰る習慣がついていたので……そうしないと眠られないからであったが……今夜はサテどっちへ曲ろうかと考えたのであった。",
              "citation": {
                "source": "冗談に殺す",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸橋の方から、霞ヶ関の方から、群衆と、役人とが――馬上で、徒歩で、それから、その近くの邸の人々は、足軽を出して、群衆を追っ払い始めた。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "福岡の城主五十二万石、松平美濃守のお邸は霞ヶ関の高台にあったが、勾坂甚内は徒党を率い、新玉の年の寿に酔い痴れている隙を窺い、金蔵を破って黄金を持ち出した。",
              "citation": {
                "source": "三甚内",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "霞ヶ関の義挙が世を震動させたのは柳まつりの翌月であった。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "真暗な霞ヶ関から永田町へ出ようとすると各省の大臣官舎を警護する軍隊でここも亦往来止めである。",
              "citation": {
                "source": "花火",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "霞ヶ関の日比谷公園寄りにある海軍省などは、何は無くとも、諸外国に新興日本の「威」を示すために、官庁のイレモノは立派にと、当時の伊藤政府が心をくだいて打建てた記念物で、これがコンドル博士の設計に成るものである。",
              "citation": {
                "source": "東京の風俗",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日までなんとなく一日延しにしていたが、軍から慈善団体の認可をとらなくてはならないと思い、車をかえしてまっすぐ霞ヶ関へ行った。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "一の鳥居のまえへ詰め、お通り筋は、星野山より半蔵御門へ入り、吹上竹橋御門、大下馬より常盤橋、本町、十間店本石町、鉄砲町、小船町、小網町、れいがん橋を過ぎ、茅場町お旅所にて奉幣のことあり、それより日本橋通町すじ、姫御門を抜けて霞ヶ関お山に還御也。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日、二人乗りのリンタクに大男の米兵を二人乗せて霞ヶ関の大通りをエツサラホツサラとペダルを踏んで走つて行く男、それが彼だつた。",
              "citation": {
                "source": "老残",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車は虎の門から霞ヶ関の方へ。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかもこの頃、霞ヶ関、内務省警保局の秘書官室では、大きな机の前に坐った谷口秘書官が絶えず扉の方に眼をやりながら、苛立たしげに口髭を捻り上げている。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し血に汚れているが、洗い浄めて旧主芸州侯にお還し申上げ、せめて亡き父上の妄執を晴らしたいと、それは誰はばかる者もなく持ち帰り、本日はこれから、霞ヶ関御屋敷に参上するところであった」　砧右之助の言葉は、立派に筋が通りますが、疑えばまだ、いくらでも疑えます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お秀の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "現地解決ということを知らないユレニエフ大使は、ウッカリ問題を霞ヶ関などに持ち込んで来たので、逆にとんだ負担を負わされて引き下らざるを得なくなった。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "霞ヶ関書房より天皇への公開状執筆依頼あり。",
              "citation": {
                "source": "同居人荷風",
                "author": "小西茂也",
                "note": "青空文庫"
              }
            },
            {
              "text": "野村曰ク、デモハ夜遅クマデ続キ、霞ヶ関カラ銀座ヘ出テ十時ニ解散スル、今カラ浜作ヘイラッシャレバ、八時迄ニハ帰レマスカラ大丈夫デス、但シ少シ遠廻リシテ市ヶ谷見附カラ九段ヲ経、八重洲口ヘ出テ行ケバ、デモニ打ツカル恐レハナイト思イマス、ト云ウ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の行動に曇りと疑惑を残さぬ意味においても、外務大臣としての大隈をやっつける場所は霞ヶ関のほかにはないことが、彼の心の中でいよいよ確定的になってきたのである。",
              "citation": {
                "source": "風蕭々",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隊伍を組んだ警官の一隊が駈け足で霞ヶ関の方角へ駈けてゆくあとから、群衆が騒ぎたてながらあとからついてゆくのが涙に曇る彼の視野をチラチラとかすめる。",
              "citation": {
                "source": "風蕭々",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後四時半、宮廷を退出すると大隈は、ひと先ず霞ヶ関の官邸へ帰るつもりで、馬車を走らせて桜田門をぬけ、外務省正門にちかい坂にさしかかった。",
              "citation": {
                "source": "早稲田大学",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間も、霞ヶ関ゴルフ場から、帰りにわざと、高麗川をのぼって飯能から金子十郎の金子村を通り、山越えして来たが、この辺はもう武蔵野のつき当りといってもいいほど秩父、多摩山岳へ寄っているので、中央沿線や都心の文化とは、まったく無縁のように見える。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
