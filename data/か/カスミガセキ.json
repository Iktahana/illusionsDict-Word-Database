        "examples": {
          "standard": [
            {
              "text": "霞ヶ関の官僚たちが夜遅くまで会議を重ねている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい政策は、霞ヶ関で議論された後、国会に提出されるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は霞ヶ関でのキャリアを捨て、故郷に戻って事業を始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
