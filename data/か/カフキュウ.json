        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この仕事では、過不及なく任務を遂行することが求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "料理の味付けは、過不及にならないよう常に注意を払っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の哲学は、何事も過不及を避け、中庸を重んじる点にある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "修業に修業が積み、生命の流れが過不及なしに流れている人、すなわち正念を常に保ち得ている人は、何事をしても決して過不及なしに、物事の本当のところにはずれることなく、ちゃんと当て嵌って行く。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまたたんたんたる言葉をもって過不及なしの話を語りつづける。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この過不及のない補い方は全く実相の理に明るい達識の人に望まれます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "認めて、過不及なく使って行く事が生命である。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "書を讀めば其の書と我が全幅の精神とが過不及無く相應じ相對して居り、算盤を取れば算盤の上に我が全幅の精神が打向つて居るのが張る氣の氣合である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ一つの能力の優秀さが全然目立たないほど、過不及無く均衡のとれた豊かさは、子路にとって正しく初めて見る所のものであった。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気を一巡するもの六期を一備となし、地紀を終わるもの五歳を一周と為す、君火は明を以ってし、相火は位を以ってする、五と六と相合して七百二十気を一紀となす、凡て三十年なり、千四百四十気、凡て六十年なり、そして太過不及（過ぎたり及ばなかったり。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれに飯を盛るに、婢をして盛らしむるときは、過不及を免れぬといって、飯を小さい櫃に取り分けさせ、櫃から椀に盛ることを、五百の役目にしていた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "只その過不及なきを要するのみ。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽以来また天籟に耳を傾くるなし」「聖人は常の人なり、過不及なき人なり。",
              "citation": {
                "source": "臨終の田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "故學以致中和、歸於無過不及、謂之復性之學。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に學んで以て中和を致し、過不及無きに歸す、之を復性の學と謂ふ。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "合衆国大統領は別段飛び離れたる願いは仕らず、合衆国人民へ過不及なき平等の儀、御許しのほど願いおり候ことに御座候。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "この譲歩を人間社会に最も必要なものとしてその精神に基づいて建てた鉄則が道徳と法律とであって、擅ままに跋扈する優勝劣敗の自然力を調節し、強者を抑え弱者を助け、そこで過不及なく全人間の幸福を保証したものだ。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "歪みなく、過不及なき形ではあるが、素材のまゝで、との謂ではない。",
              "citation": {
                "source": "「私」小説と「心境」小説",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」○　中庸＝＝過不及なく、常に平正を保ち、過激極端にならぬこと。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを正直に、素直に表現しているので、作意は短歌形式に盛りきられて、程のよい、過不及のない物となっている。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
