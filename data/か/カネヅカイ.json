[
  {
    "uuid": "02d43a82-3b08-5341-8d9b-fb35ff866a45",
    "entry": "金使い",
    "reading": {
      "primary": "かねづかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
