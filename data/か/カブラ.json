[
  {
    "uuid": "5fd58224-d267-5eed-ae3a-0eda3c612859",
    "entry": "鏑",
    "reading": {
      "primary": "かぶら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
