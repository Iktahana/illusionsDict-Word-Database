    "definitions": [
      {
        "index": 1,
        "gloss": "kanaka",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "19世紀のハワイでは、多くのカナカがサトウキビ農園で過酷な労働に従事していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はカナカの血を引いていることを誇りに思い、伝統的な航海術を学んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、あのカヌーに乗っているのはカナカの人たちかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ハワイのプランテーションで働くカナカたちの間では、独自の文化や音楽が育まれていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしこの秘密を具体的に探り出すのはナカナカ容易な仕事でないことが最初からわかり切っていた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人同士もナカナカの乗気で、この三月の末には祝言という処まで進んでおったという話……」「ホンニなあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナカナカの理屈じゃ」「それに引換えまして私共の一生は、まことに貧乏神様々で御座います。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の手線電車が田町に停まったら、降りた人が入口を開け放しにして行って寒くてしようがないので、入口を閉めようとしたがナカナカ閉まらない。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が相手だったことがわかるかも知れないが、その夜がナカナカ明けない。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ……」　と重役の一人が味方の仮装マネージャーを浴びせ倒しに掛かっていたが、ナカナカ腰が砕けない模様である。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし爺さんは、どうしたものかナカナカ止めなかった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃから云うて聞かすが、お前の母親というのは、ああ見えても若いうちはナカナカ男好きじゃったのでナ。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々小作米とか小遣の帳面を枕元の一｜燭の電燈で調べる位のことで、直ぐに寝てしまいます」「老人というものはナカナカ寝付かれぬものというが、やっぱりソンナに早く寝てしまうのか……」「さあ。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで気が付かなかったが……ナカナカ君は熱心ですなあドウモ。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その草川巡査の取調べが全然予想と違った順序で、極めて、注意深く事件の核心に突込んで来るらしい事に気がつくと、もう恐ろしくて恐ろしくてたまらなくなって、飯を喰ってみてもナカナカ気持が落つかなかった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソンナ　グアヒデ　コドモノ　タヌキハ　ナカナカ　ウマク　バケル　コトハ　デキマセンデシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども将軍家はおだやかに、ナカナカ、世捨人デハナイ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御度量のひろい将軍家に於いては、もちろん、御計画の頓挫をいつまでも無念がつていらつしやるやうな事は無く、あの、大かたり者の陳和卿に対してもいささかもお怒りなさらず、医王山ホド、ウマクイカナカツタヤウデス。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "スランプトハ、コノ様ナ、パッション消エタル白日ノ下ノ倦怠、真空管ノ中ノ重サ失ッタ羽毛、ナカナカ、ヤリキレヌモノデアル。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園にはいると、カナカナ蝉の声が、降るようだった。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しも日本がかつた所が無く、又西洋がかつた所も無い（南洋で一寸顏立が整つてゐると思はれるのは大抵どちらかの血が混つてゐるものだ）純然たるミクロネシヤ・カナカの典型的な顏だが、私はそれを大變立派だと思ふ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、マリヤン自身は、自分のカナカ的な容貌を多少恥づかしいと考へてゐるやうである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふのは、後に述べるやうに、彼女は極めてインテリであつて、頭腦の内容は殆どカナカではなくなつてゐるからだ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、マリヤンは斯うした環境にゐるために、自分の顏のカナカ的な豐かさを餘り欣んでゐないやうに見えた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しも日本がかった所が無く、また西洋がかった所も無い（南洋でちょっと顔立が整っていると思われるのは大抵どちらかの血が混っているものだ）純然たるミクロネシヤ・カナカの典型的な顔だが、私はそれを大変立派だと思う。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、マリヤン自身は、自分のカナカ的な容貌を多少恥ずかしいと考えているようである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、後に述べるように、彼女は極めてインテリであって、頭脳の内容はほとんどカナカではなくなっているからだ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、マリヤンはこうした環境にいるために、自分の顔のカナカ的な豊かさを余り欣んでいないように見えた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋日のカンカン照っているテニス・コートの上で、菜葉服の職工連が、コスモスの花を背景にして、向い合ったり、組み合ったりして色々なシグサを遣るのはナカナカの奇観であった。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその癖に、そんな趣味の小説や絵画はナカナカ好きな方で、つまらないと思う作品にまでもツイ引きつけられて行く。",
              "citation": {
                "source": "ナンセンス",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱歩氏が「久作論」を書かれるのは何でもないにしても、私の方はナカナカそうは行きませぬ。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでその名前の選み方であるが、これがナカナカ容易でない。",
              "citation": {
                "source": "創作人物の名前について",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと読者はペテンにかけられたような不愉快を心の片隅に残すところがあるのだから、ナカナカ事が面倒である。",
              "citation": {
                "source": "創作人物の名前について",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだまだ創作人物の名前については重要な事を沢山に書残しているようであるが、さてこうして書き初めてみるとナカナカ重大な問題らしく、あとから――書く事がイクラでも出て来るのに驚いている。",
              "citation": {
                "source": "創作人物の名前について",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
