        "examples": {
          "standard": [
            {
              "text": "旅館の仲居さんが、朱塗りの角盆に載せた温かいお茶とお菓子を客室まで運んできてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お正月のお屠蘇セットを用意するから、戸棚の奥にある漆塗りの角盆を出してくれる？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖母は来客があると、いつも使い込まれた木の角盆で手作りの漬物を出してもてなしてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "お邪魔でしょう、退ります」「今日は素直ね……せっかく来たんだから、じゃ、五十雄さんに、夕食を持っていらっしゃい」　そういって、食器の載ったアルミの角盆をおしてよこした。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "片木作りの角盆」とあるから、あまり上等なものではなさそうである。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他茶筒、茶入などは型を用いて作られ、硯箱、角盆などは板を素地とします。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくぼんやりしてはゐられない、勉強することだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかくぼんだ穴の中におちこんでほえているのじゃなかろうか」「ほえているのは、こっちの方角だが、どこなんでしょう」　玉太郎は沼のむこう岸をさした。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくぼんやりと気のついたとき、僕はしきりに口から水を吐いていた。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいした変り方もなく続いている間は、そう云う事があると承知していながら、人間はとかくぼんやりと見過ごすだけである。",
              "citation": {
                "source": "雨粒",
                "author": "石原純",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
