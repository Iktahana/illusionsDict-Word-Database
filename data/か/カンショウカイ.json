        "examples": {
          "standard": [
            {
              "text": "来週、美術館で特別に修復された名画の鑑賞会（かんしょうかい）が開かれるそうです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あのインディーズ映画の監督が、限定上映の鑑賞会（かんしょうかい）に来てくれるらしいよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "親睦を深めるために、週末に家族でアートギャラリーの鑑賞会（かんしょうかい）に参加する予定です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "同じフレッシュのヴァイオリンで「ソナタ第五番イ長調」がポリドールの鑑賞会レコード第三集に入っている。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアノ曲にはなかなかの佳作があり、「ピアノ・ソナタ第九番」と「同第一〇番」はシュンキエウィッツの演奏で十数年前日本ポリドールの名曲鑑賞会から出ているが、さすがに吹込みが古い。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに日本ポリドールが数年前名曲鑑賞会からアマール・ヒンデミット四重奏団の演奏した「弦楽四重奏曲第二番」を頒布したことがある（ポリドール四五一五七―六〇）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヴァイオリン協奏曲＝ニ長調」をドゥシュキンのヴァイオリンで作曲者がコンセール・ラムルウ管弦団を指揮したのが近頃の面白いレコードだ（ポリドール鑑賞会）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
