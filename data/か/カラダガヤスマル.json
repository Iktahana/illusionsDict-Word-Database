        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あー、やっと家に帰って体が休まるよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "温泉に入ったら、体の芯から休まる感じがした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "週末は何もせず、ただ体が休まるのを待っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一と眠りして身体が休まると、すぐあなたのことを思います。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体が休まるにつれて、わたしの気持ちは穏やかになってきた。",
              "citation": {
                "source": "謎の街",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて少し体が休まると、手を洗って、カラアをつけ変えて、柔らかい絨氈の上を伝って、食堂に出て行く。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳の上で体が休まるということを伺って、きわめて具体的にいろいろ理解いたしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうにからだがやすまるってないんでしょう。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
