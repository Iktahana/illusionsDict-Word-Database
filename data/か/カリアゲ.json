    "definitions": [
      {
        "index": 1,
        "gloss": "close-cropped hair",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は夏に向けて、サイドをすっきりと刈り上げにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "美容師さんに「刈り上げの部分は短めにしてください」とお願いした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "流行のツーブロックは、刈り上げの高さで印象が変わる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「うんと、うしろを短く刈り上げて下さい。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "マシマロのように豊かな顔の輪廓に思い切り短く刈り上げてしまったお河童がちっとも不自然でなくよくうつっていた。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はことの意外に呆れてしまったが、果して間もなくあるビルディングの地下室にある理髪店へ行くと、金縁眼鏡をかけたそこの主人はあなたのような髪は時局柄不都合であると言って、あれよあれよと驚いている間に、私の頭を甲型か乙型か翼賛型か知らぬがとにかく呉服屋の番頭のような頭に刈り上げてしまった。",
              "citation": {
                "source": "髪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日明日とみっちり刈れば明後日は早じまいの刈り上げになる。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "刈り上げの祝いは何がよかろ、省作お前は無論餅だなア」　そういうのは兄だ。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉は突然、「おとよさん、家ではおかげで明後日刈り上げになります。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮れがたになってはさしもに大きな一まちの田も、きれいに刈り上げられて、稲は畔の限りに長く長城のごとくに組み立てられた。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲刈りは稲さえ思うだけ刈り上げさえすればよいわけだが、仕事の興味という点からいうと、二軒いっしょになって刈るというところに仕事以外の興味がなければならないのに、今度の稲刈りはどうもそれが欠けておった。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　今日は刈り上げになる日であったのだが、朝から非常な雨だ。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも昨日の日暮れおれが寄ったら、刈り上げで餅をついたから食っていかねいかって、二人がうんやなやでやってたよ」「うん、あん嬶いつもそうさ。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "と泣き出してしまった……　明日は三時半頃から田へ出て、他の人より遅れている一番草を刈り上げてしまわなければならない。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜、自分らの田を全部刈り上げた参右衛門夫妻が、鳥の巣をもって帰って来て仏壇にそなえた。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりくさんと云ふのは、島でも一流の置屋の主人で、女のくせに髪を男のやうに短く刈り上げ、筒袖の意気な着物に角帯を締めて、その帯には煙草入れなぞぶらさげ、二三人の若い女を連れては、角力取りのやうにのつしのつしと歩いてゐる女のひとでした。",
              "citation": {
                "source": "小さい花",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大昔から、田植ゑより刈り上げまでの間には、村の為に良くしてくれる神と、良いも悪いも考へないものとの争ひの形式の演劇が行はれて来た。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「牛追唄」も、山唄のある物も、それから「刈り上げ唄」なども、此類に這入るものであるのだが、南部の「牛方節」は、牛方の饗宴に用ゐられる事が多い為か、少しのどかさに過ぎた所があつた。",
              "citation": {
                "source": "東北民謡の旅から",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずつと古代には、春祭りと刈り上げ祭りとは、前夜から翌朝までの行儀でした。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "農休み・刈り上げの後などの芝居興行は、田舎普通のことになつてゐた。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが大体に、刈り上げを待つて行ふ処は数へる位であらう。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "神々は、村の田の植わりきつて、村全体としてのさなぶりの饗応を供へられた夜に帰るものと考へられたらしく、稍日長く逗留する事が、秋の刈り上げまで居るものゝ様に思はれて行つたらしい。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬祭りは、刈り上げ祭りと、鎮魂祭とが本体であつた。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此内、刈り上げ祭りは、十一月中旬の新嘗祭りが代表的なもので、処によつては、今尚、此日を重く見る処もあり、由来不明な為来りで祝ふ家々もある。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "暦は冬になつても、農村では、刈り上げまでは秋であつた。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "刈り上げのあるじを享けに来たまれびとが、家あるじの生命・健康・家屋の祓へをして、其上に力強い威霊を身中に密著させる。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二秋の祭りは、誰もが直ぐ考へる通り、刈り上げの犒ひ祭りである。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、実際の刈り上げ祭りは、正しくは、仲冬に這入つてから行はれるので、近代までもさうせられてゐる。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "神嘗祭りの原義は、今年の稲作の前兆たる「ほ」を得て、祝福する穂祭りの変形であつて、刈り上げ祭りよりも早くからあつたものとは言はれない。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "此穂祭りが神社に盛んに行はれ、刈り上げ祭りは、一家の冬の行事となつたのであるらしい。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく／＼県下の社でも特殊神事とせられてゐるのでなければ、冬も霜月・師走に入つて、刈り上げ祭りらしいものを行うてはゐない。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂々たる祝詞や、卜ひを伴ふ宮廷風の穂祭りは、神社の行事になり、村の昔の、もつと古くから続いた刈り上げの新嘗は、家々の内々の行事となつて行つた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆、刈り上げ祭りの夜の供物や物忌みの行はれた痕跡である。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
