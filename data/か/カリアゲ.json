[
  {
    "uuid": "7e723c02-0252-52b9-a307-f49b0c7e7e52",
    "entry": "刈り上げ",
    "reading": {
      "primary": "かりあげ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
