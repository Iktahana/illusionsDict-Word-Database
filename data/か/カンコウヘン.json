        "examples": {
          "standard": [
            {
              "text": "肝硬変の初期段階では、自覚症状がほとんどないことが多いんです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年の飲酒が原因で肝硬変になり、体調を崩してしまった友人がいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この病状は肝硬変と診断され、長期的な治療が必要だと医師から告げられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "定期的な検査で肝硬変の兆候が見られたため、生活習慣の見直しを勧められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "例えば、腹水で死んだ男の肝臓が石のようになっていること（＊肝硬変）を見た。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺炎、胃潰瘍、肝硬変、子宮がん、は単に臨床症状群だけによってではなく典型的な解剖学的変化によって特徴づけられるようになった。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "肝硬変症になる酒飲みはタンパク質が少ないバランスの悪い食事をとっていて、食事の改良によって良い効果が見られた。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "Zimnicki［22］は肥大性胆汁性肝硬変の男子におけるホモゲンチジン酸の間欠的排泄を私が読むことのできないロシアの雑誌に刊行した。",
              "citation": {
                "source": "アルカプトン尿の発現",
                "author": "THE INCIDENCE OF ALKAPTONURIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルカプトン尿が間欠的であった彼の患者は肥大性の肝硬変を患っていた。",
              "citation": {
                "source": "先天性代謝異常",
                "author": "INBORN ERRORS OF METABOLISM (1909)",
                "note": "青空文庫"
              }
            }
          ]
