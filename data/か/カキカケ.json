[
  {
    "uuid": "82feb51f-3bdd-5bd8-bada-07207e903fdc",
    "entry": "書きかけ",
    "reading": {
      "primary": "かきかけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
