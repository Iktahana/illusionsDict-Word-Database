    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unfinished (letter, text, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "机の上には、途中で力尽きたのか、書きかけのレポートが散乱していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お母さん、その書きかけの手紙、出しといてあげようか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "コーヒーをこぼしてしまい、せっかくの書きかけの小説が台無しになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "仕事の合間に、書きかけのメモに目を通してアイデアを整理する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "右脇には句集など取散らして原稿紙に何か書きかけていた様子である。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私は今書きかけた端書のさきへこんな事を書き加えた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「初恋の記」――私が或る新進作家の名前でもって、二三行書きかけているその原稿を本気に書きつづけようとしたのであった。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめに少し書きかけて置いたあのようなひとりの男が、どうしておのれの三歳二歳一歳のときの記憶を取り戻そうと思いたったか、どうして記憶を取り戻し得たか、なお、その記憶を取り戻したばかりに男はどんな目に逢ったか、私はそれらをすべて用意していた。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道子は書きかけた手紙を破ると、改めて姉の名で激励の手紙を書いて、送った。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざまを見ろと書きかけた答案を消し意気揚々と白紙のまゝで出した。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に書きかけたのは、長いものであつたが止して、其中に「埋れ井戸」と云ふものを書いて桐生君の紹介で春陽堂に賣つた。",
              "citation": {
                "source": "自傳",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいま、とっても面白い小説を書きかけているので、なかば上の空で、対談していました。",
              "citation": {
                "source": "「晩年」に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）　かの女はむす子が曾て、あれだけの感情家である自分の感傷を一言も手紙に書いて来たためしのないのを想い出しながら、書きかけの原稿紙にいつかこんな字を書いていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（数枝）（あさのほうを見て、机上の書きかけの手紙を畳んでふところにいれ、それから、立ってあさのほうへ行き、あさをゆり起し）お母さん、お母さん。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ふところから先刻書きかけの手紙を取り出し、小さくはしゃいで）ちょっと読んでみるわね。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己弁護なんかじゃ無いと、急いで否定し去っても、心の隅では、まあそんな事に成るのかも知れないな、と気弱く肯定しているものもあって、私は、書きかけの原稿用紙を二つに裂いて、更にまた、四つに裂く。",
              "citation": {
                "source": "作家の像",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「随筆には虚構は、許されないのであって、」と書きかけて、あわてて破る。",
              "citation": {
                "source": "作家の像",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、そこまでは、まず大過なかったのであるが、「けれども」と続けて一枚くらい書きかけ、これあいけないと、あわてて破った。",
              "citation": {
                "source": "作家の像",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は書きかけの原稿用紙に眼を落してしばらく考へてから、題を猿面冠者とした。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は書きかけの原稿用紙に眼を落してしばらく考えてから、題を猿面冠者とした。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時に――　と、書きかけて、そのままになっていた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の六畳に閉じこもって、原稿用紙、少し書きかけては、くしゃくしゃに丸めて壁に投げつけ、寝ころんで煙草吸ったり、また起き上って、こつこつ書いたり、毎夜、おそくまで、眠らずにいる。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時に――　と、書きかけて、そのままになつてゐた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の六畳に閉ぢこもつて、原稿用紙、少し書きかけては、くしやくしやに丸めて壁に投げつけ、寝ころんで煙草吸つたり、また起き上つて、こつこつ書いたり、毎夜、おそくまで、眠らずにゐる。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私みたいな、不徳の者が、兵隊さんの原稿を持ち込みするということに、唐突の思いをなされるかも知れませんが、けれども人間の真情はまた、おのずから別のもので、私だって、」と書きかけて、つい、つまずいてしまうのだ。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、書きかけた創作を、結ばなければいけない。",
              "citation": {
                "source": "めくら草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいつか書きかけて置いたこの原稿を、今夜いそいで書き足したが、時計を見ると既に午前一時を過ぎてゐる。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざまあ見ろと書きかけた答案を消し、白紙のままで出し、胸を張って教室を出た。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　この序文を書きかけてから三日経つた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その失はれた心の落ち付きを迫めて無理にも取り返すつもりで、今書きかけてゐる議論――それは藝術と實行とは合致すべき物だと云ふ説明――の筆を轉じて、かの女を慰める手紙を書いた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "二四　あわてたところで、だめなものはだめだから、まず書きかけた原稿を終ってしまおうと、メレジコウスキの小説縮写をつづけた。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "革鞄をあけて、中の書物や書きかけの原稿などを調べながら、つくづく思うと、この夏中の仕事は――いろんな考えを持って行ったのだが――ただレオナドの紹介ばかりが出来たに過ぎない。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一々事実にくっ付けて一分一厘｜隙のないようにキチキチとキメツケて行く苦しさに、いつも書きかけては屁古垂れさせられて終います。",
              "citation": {
                "source": "涙香・ポー・それから",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにその書きかけの文章が不愉快で不愉快で、筆を入れる勇気も何もないくらい詰まらないものに見えて来るのです。",
              "citation": {
                "source": "スランプ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
