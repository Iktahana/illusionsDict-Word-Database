        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「はっけよい！ 角力の熱気に包まれて、境内の観衆からは割れんばかりの拍手が沸いた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "江戸時代の古文書を開くと、奉納角力に興じる庶民の姿がいきいきと描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "角力の稽古は日が昇る前から始まり、土俵に体が叩きつけられる鈍い音だけが響く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
