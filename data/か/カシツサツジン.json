        "examples": {
          "standard": [
            {
              "text": "不注意運転が原因で、過失殺人の罪に問われる可能性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、工事現場での安全管理の不備による過失殺人の疑いで逮捕された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "裁判では、過失殺人の立証が争点となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「まさか、あんな事故が過失殺人になるなんて…。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "過失殺人の場合、故意の殺人と比べて刑罰が軽くなることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そうして子供を電車で潰されたという女にとって不仕合せな事柄が過失殺人罪として罰せられる。",
              "citation": {
                "source": "婦人の創造力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
