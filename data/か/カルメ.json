      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "on the light side (weight)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今日のランチは軽めに済ませて、午後に備えよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このスーツケースは見た目より軽めなので、持ち運びが楽だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "運動後は軽めのストレッチで体をほぐすのが良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "晩御飯は軽めにして、胃腸を休ませたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "はじめ太祖、太子に命じたまいて、章奏を決せしめられけるに、太子仁慈厚くおわしければ、刑獄に於て宥め軽めらるゝこと多かりき。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも準備の必要を考えたよりは、彼らに手仕事を授けて、いたずらに懊悩することを軽めようと思った方が多かった。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、油汗を搾るのは責めては自分の罪を軽め度いという考えからで、羊頭を掲げて狗肉を売る所なら、まア、豚の肉ぐらいにして、人間の口に入れられるものを作え度い、という極く小心な「正直」から刻苦するようになったんだ。",
              "citation": {
                "source": "予が半生の懺悔",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ少数の商人が、巧智に長けた眼を窃かに働かして旅人の財布を軽めるにもせよ。",
              "citation": {
                "source": "「奈良」に遊びて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、自分が、実際母の苦痛を軽めるには、何の足しにもならなかったのを回想した。",
              "citation": {
                "source": "心の河",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "互いに慄える手を探り合って握りつつも、どこかに身の近づけぬもののある画廊ながら、矢代は、もしこれで千鶴子にいのちを失う踏絵のような場合が来れば、あの、細川ガラシヤの死の苦痛を軽めで死んだ小笠原少斎のように、自分もともに千鶴子と死ぬかもしれないと思った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "林町では、両親、スエ子と常盤館に行かれたので、自分の苦痛は余程軽められた。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "津軽め、命冥加な」　良輔が呟きつつ、ついて行った。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑ふことによつて、人生の苦渋の荷は軽められるものと思つてゐるらしい。",
              "citation": {
                "source": "実川延若讃",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは勿論医者として親族から受けなければならない不快な感情や責任を軽める逃口上であると云えない事はない。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浩の十円は、役には立ったに違いないが、孝之進の苦労を軽めることはもちろん出来ない。",
              "citation": {
                "source": "日は輝けり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生懸命にもがけばもがくほど、枷はしっかりと食いこんで来るように、僅かの機会でも利用して借金も軽め生活も楽にさせたいとあせればあせるほど、経済は四離滅裂になって来る。",
              "citation": {
                "source": "禰宜様宮田",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働の辛さを、気持のよい音か拍子かで軽めるとは、面白い国民性である。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはその欲するところ・企てるところ・のすべてをその全意志をもって熱心にするが、この世には足をとられるような深みがたくさんあるから、最も安全であるためにはいささか軽めに・浅く・世を渡るべきである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう労働の苦痛を軽めるためには、改良の歓迎せられたのは当然の話である。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "呂布は、眦をあげて、「この足軽め」　方天戟をふりかぶって、真二つと迫ったが、張飛はすばやく、鞍横へ馳け迫って、「おうっッ」　吠え合わせながら、矛に風を巻いて、りゅうりゅう斬ってかかる。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……かるめら焼のお婆さんは、小さな店に鍋一つ、七つ五つ、孫の数ほど、ちょんぼりと並べて寂しい。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓矢取っては一万石、大名株の芸人が、イヤ楊枝を削る、かるめら焼を露店で売る。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "博多小女郎の心意気なんか江戸ッ子にゃあわかるめえ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "編集にまつわるさまざまな作業の中で、もっぱら手間のかかるめんどうな仕事を下請けでこなすプロダクションには、思い入れを育てる余地はなかなかありませんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめえのようなあわて者では、いわれるまでわかるめえが、ねらわれたところは心の臓だ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "居場所についてはわかるめえ」「ああいう荷厄介な生き物だ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、おめえにア這個の消息、なんのことだかわかるめえ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの子供とかるめらを焼いて遊ぶ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹の莖のやうな甘蔗をモオタアのかゝつた絞り機械で、汁を絞り、それを煮て、白いにがりで固めると、丁度かるめらのやうな色をした砂糖が流し箱へうつされる。",
              "citation": {
                "source": "屋久島紀行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前に手をついて、ぬけぬけと、一身一命、御自由でござります――などと、並べ立てている奴の、奴根性は、ちょいと、この世で、二人とは見つかるめえ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し秋めいた夏の陽が濃緑の葉を明かるめている。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな処に僧正さまもめっかるめえからな。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝には秋冷を覚ゆる九月に入ると、降伏後の混乱もおのずから鎮まり、患者も大体助かるめどがついてほっとした。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が降らなければ村中……村中どころか、日本中の人の命が助かるめえ。",
              "citation": {
                "source": "旱天實景",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
