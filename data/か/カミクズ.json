        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "書き損じた書類は、すべて紙くずとして処理された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "机の周りが紙くずで散らかってきたので、掃除機をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あっ、間違えた！」と、彼はいきなり紙くずを丸めてゴミ箱に投げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ただし市会議員のよこしたのだけは紙くずかごに入れるようである。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "死に物狂いの大晦日の露店の引き上げた跡の街路には、紙くずやら藁くずやら、あらゆるくずという限りのくず物がやけくそに一面に散らばって、それがおりからのからび切った木枯らしにほこり臭い渦を巻いては、ところどころの風陰に寄りかたまって、ふるえおののきあえいでいるのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋一ぱいに、れいのかつぎの商売道具らしい石油かんやら、りんご箱やら、一升ビンやら、何だか風呂敷に包んだものやら、鳥かごのようなものやら、紙くずやら、ほとんど足の踏み場も無いくらいに、ぬらついて散らばっている。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、さっき一ぺん紙くずのようになった二人の顔だけは、東京に帰っても、お湯にはいっても、もうもとのとおりになおりませんでした。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、夕方お君と二人で、紙くずや藁を庭先で燃やしていると、お母さまも、お部屋から出ていらして、縁側にお立ちになって黙って私たちの焚火を見ていらした。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その柿の皮があかあかと紙くずとごったになって敷き石の上に散っていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがなければ世界はたんなる土くれの巨大な塊にすぎないし、あらゆる本は紙くずである。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は、にぎやかな町ほど、砂ほこりが立ち、紙くずがとびまわり、路上にはきたないものがおちていたものだ。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この町はほこりは立たず、紙くずはなく、路面ははだしで歩いても足の裏がよごれないように見えた。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家も仕事をもってる」それから丁寧に鉛筆の削り屑を机の下の紙くず籠へすてて「……リベディンスキーの『一週間』というのは日本に知られてるだろうかな？",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こればかりでなく、今朝机に向ったら、硯屏の前に小さい紙くずが一つのって居た。",
              "citation": {
                "source": "木蔭の椽",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙くず籠を見てもやはりないのです。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大工、職工、画家、紙くず屋、大臣、不良少年等、皆似合いの帽子を被っている。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに、丸められた、汚血のにじんだ紙くずが転がっていた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も大急ぎで懐の中のはこせこを出して中に入って居た紙くずなんかぬいてそっと紫のふくさの入って居た袂に入れた。",
              "citation": {
                "source": "ひな勇はん",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番おしまいの紙くずをなげ込んだ時、「千世子さあーん」　Ｈが呼んだ。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十日後には紙くずのようになる。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞を大変気に入ったところがあったので切りぬいておいたら、紙くずと一緒されてしまった。",
              "citation": {
                "source": "日記",
                "author": "一九一三年（大正二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし目が働いているならば、ほうきの先のみすみす重くなる紙くずを庭中ころがしまわるのも不思議です。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、下の暖炉の中には紙くずが詰まります。",
              "citation": {
                "source": "煙突と柳",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いま、鉄くずでも、紙くずでも、値になるのだよ。",
              "citation": {
                "source": "雪の降った日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか、原っぱのごみ捨て場で、紙くずや、菜っ葉を拾っていた女の人だ。",
              "citation": {
                "source": "雪の降った日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと、おまえが、紙くずや、すえぶろの灰を原っぱへ捨てるときに、いっしょにまちがって捨てたのです。",
              "citation": {
                "source": "雪の降った日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、紙くずが、風にふかれて、その上をとんでいます。",
              "citation": {
                "source": "かざぐるま",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそこで、紙くずが踊っていたのです。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も手をかけるものがないのに紙くずがしきりに踊っている。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるものは、くずかごの中へ、ほかの紙くずなどといっしょに、破って捨てられました。",
              "citation": {
                "source": "飴チョコの天使",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごみ箱の中で、お人形は、黄色なみかんの皮や、赤いりんごの皮や、また、魚の骨や、白い紙くずや、茶がらなどといっしょにいましたが、もとより箱の中には、光線がささないから、真っ暗でありました。",
              "citation": {
                "source": "風の寒い世の中へ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうせ一日か二日すれば会うんだから……」　こんな事を思ってうす青のライティングペーパアを原稿紙ばっかりのかみくずかごの中に点を打った様にコロッと一つなげ込んだ。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "くずやは、そばにおいたくずかごの、かみくずをかきわけて、二つの黒いウルシぬりの箱を取りだして、テーブルの上にならべました。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
