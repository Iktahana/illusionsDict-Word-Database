[
  {
    "uuid": "22c98704-8541-5237-9152-d7cbab83468d",
    "entry": "窯場",
    "reading": {
      "primary": "かまば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "kiln-equipped pottery workshop",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "窯焚きが始まると、窯場には近寄るのも躊躇われるほどの熱気が充満する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「次の個展に間に合わせるために、今は一日のほとんどを窯場で過ごしてるんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "薄暗い窯場の中で、職人が黙々とろくろを回し、土に命を吹き込んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私はこの春さばを入手すべく、且つ視察かたがた意を決して窯場を発足、若狭小浜へ二月下旬に着いた。",
              "citation": {
                "source": "若狭春鯖のなれずし",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、私はこの窯場では、少なくとも自分の名のつく作は、なにからなにまで自分でやっているのであります。",
              "citation": {
                "source": "食器は料理のきもの",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "陶器を自分で作る責任として、そもそも最初の用意として、朝鮮に二回、その他、内地では瀬戸、唐津を初め、各地の古窯場を遍歴して、様々な古陶を発掘し、偶然ながら志野、織部などの古窯を発見したりしました。",
              "citation": {
                "source": "陶器鑑賞について",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで古陶磁の蒐集を思い立ち、窯場星岡に参考館を設け、徐々に蒐集品を陳列し始めた。",
              "citation": {
                "source": "なぜ作陶を志したか",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "備前焼、瀬戸焼、信楽焼、九谷焼、織部焼、伊万里焼、有田焼等々、日本には、各地方に、それぞれの土地に固有の型と技術とをもつ陶磁器が発達しているが、これらの窯場の特定の産物には、各々素晴らしく、芸術上時に高い作品が見出されている。",
              "citation": {
                "source": "日本のやきもの",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "古備前、古瀬戸、古九谷、織部等と呼ばれる古い時代のこれらの窯場の産物の中、ある茶碗、ある水指、皿等は、先に述べた偉大な陶匠の作品と共に、国宝に指定されているものすら数多くある。",
              "citation": {
                "source": "日本のやきもの",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "無数の窯場が今も各地に散在して、烟を絶やしたことがないのです。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこんなにも多く手工による窯場が現存している国は他にないでしょう。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中で琉球の壺屋は忘れられない窯場の一つです。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくは日本中で伝統的な窯場としては第一に推すべきものでありましょう。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠隔の地ではありますし、小さな窯場と考えられてか、注意する人がなかったのです。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの窯場には釉薬を施したものの他に、いわゆる「南蛮」を焼く大きな窯が幾つもあって、仕事は今も盛なものです。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窯場としても、村全体が美しい一風景をなしている点で他では見られない所です。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや批評家は朝鮮の窯場の事、作り方の事、作った人たちの事等をまるで知らない所から来る反論なのである。",
              "citation": {
                "source": "四十年の回想",
                "author": "『民藝四十年』を読んで",
                "note": "青空文庫"
              }
            },
            {
              "text": "町を過ぎれば峠の左右は凡て窯場である。",
              "citation": {
                "source": "雲石紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ惰性で動くなら、あの立派な石見の窯場はやがて見すぼらしいものになるであろう。",
              "citation": {
                "source": "雲石紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがないために今までどんなに多くの窯場が倒れたことか。",
              "citation": {
                "source": "雲石紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しても特色ある窯場で、少くとも伝統を守っているものは、一つとして醜いものはありませんでした。",
              "citation": {
                "source": "沖縄の思い出",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この巨大な窯場の濫觴かと思えば感慨無量である。",
              "citation": {
                "source": "北九州の窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "琉球壺屋　琉球の窯場を壺屋と呼ぶ。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古くは色々の個所に窯場があった。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦焼は別だが、沖縄では今も壺屋町だけが焼物を作る窯場として現存している。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その意味で日本国中の窯場の中で、最も興味ありまた最も大切にされていい生産地の一つといわねばならない。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠隔の地であるため、その存在やその価値を今まで省る人が少かったが、当然重要視されていい窯場である。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の人といえども、他の窯場に対してどんな位置にあるかを熟知しないため、余り熱意を有たず、当事者も改良をのみ志して、在来の伝統を軽んずる傾向があるが、逆にこういう窯場をこそ、特色ある地方の産業として尊敬し保護しその固有性を発展せしめねばならない。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "壺屋の仕事で著しいことは、一つの窯場でありながら驚くほど多様な種目や手法を有っていることである。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前述のように三つの系統がここで繋がったせいもあろうが、その変化の多い点で、他のどんな窯場にも見ない趣きを呈する。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが中で特筆されていいのは線彫で模様を描きこれに飴釉や呉州を差したもので、ほとんど他の窯場に見ない手法である。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体どこの窯場でも絵附をする力がほとんど絶えているが、壺屋ばかりはまだ活々した絵を描く。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかまばゆいシャンデリヤに、灯が入って、雨の日の昼の光では、やや重苦しく冴えなかった部屋が、急に花やかに照り返った。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
