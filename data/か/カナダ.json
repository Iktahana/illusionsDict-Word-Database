        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "来年の夏は、家族で加奈陀の雄大な自然を巡る旅に出たいね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "加奈陀で有名なメープルシロップを使ったパンケーキは格別だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ニュースで見た加奈陀のオーロラ、いつか現地で見てみたいなぁ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "高校時代、交換留学で加奈陀の小さな町に住んでいたんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "俄然として英領｜加奈陀の缶詰業に火が移った。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦力と料理人の喧嘩５・25（夕）　ながく支那に居て、彼国の事情によく通じてゐる加奈陀出身の青年将校が、西部戦線の後方勤務に支那苦力を使つたらといふので、その募集に最近支那へ派遣せられて往つた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "加奈陀の太陽はあなたのうえに輝くでしょう。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "６６７――加奈陀のウィリアムス。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "『事実は私は女秘書聯盟の書記になって午飯の休憩時間を一時間増すための全国的運動を起してそのかげに隠れて加奈陀総同盟の最左翼と結託しようか、それともハリウッドへ行って映画女優になろうかとずいぶん考えたのです。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "加奈陀の退役陸軍少佐でポウシェンという人が乗っていた。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "経済財務、軍備縮少、社会問題、保健、交通、情報会計等の各部に部長があり、英、仏、伊、日、蘭、波蘭、和蘭、加奈陀、諾威、等の国人より成り、毎週一回二時間位の部長会議を開き、各種の問題を打合せまたは討議する。",
              "citation": {
                "source": "国際聯盟とは如何なものか",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方は今日横浜にお出でになって、メキシコ石油商会の競走用モーターボートをお買求めになって芝浦にお廻しになるのと一緒に、横浜を今夜の十時までに出帆する亜米利加と加奈陀と智利通いの船の名前をすっかり調べておいでになるではございませぬか。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "紐育は暑いから、加奈陀へ行くと書いてある。",
              "citation": {
                "source": "田端日記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十代に、加奈陀ロッキーの未踏氷河 Athabaska をきわめて以来、十年、彼は恒雪線とたたかっている。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二回戦は、独逸、加奈陀、新西蘭とぶつかり、これも日本は、第三着で、到頭、準決勝戦に出る資格を失ったのでした。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで旅館へ帰ると、二人の英国婦人に二人の加奈陀青年、二人の子供を伴れた一人の英国婦人、其れに主婦と、ヴウヴレエ市の学校で独逸語の教師をして居て春の休暇で帰つて来た一人息子とが既に食卓に就いて居た。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、バファロウの街の遠明りが闇に呑まれて、汽車が唐黍の畑に沿って、加奈陀との国境を走出した頃には、フリント君も少しずつ、諦め始めて、隅の座席に腰を据えて新刊の『科学的犯罪の実例』を読み出した。",
              "citation": {
                "source": "夜汽車",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "隊員たちは、さっきすこし寒くなったから、汽船は、ニューファウンドランド沖を、加奈陀の方へ北航しかかったのだろうぐらいに思っていたのであった。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、加奈陀と豪州から入ってくる小麦粉に政府が高い関税をかけて防ぎとめたために、日本で耕した小麦の相場が、今のように高くなったのだけれど、それと当時に産額も増してきた。",
              "citation": {
                "source": "うむどん",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "沙港の華盛頓大学の学生は、go-getting の気性がさかんで、加奈陀に伐木夫に傭われたりアラスカの袖珍工場へ行ったりするが、学生のシイズンは二、三日で行けるケチカンかジュノオあたりがせいぜいで、こんな荒っぽい契約に出てくる向う見ずなやつは一人もいない。",
              "citation": {
                "source": "南部の鼻曲り",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "滞空時間六十三時間二十五分をもって二十日午前八時、加奈陀ヴァンクーバーの飛行場に到着し、征空一万二千キロの新記録を樹立した。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂ29を使って、フェアバンクスから加奈陀の北氷洋岸に飛び、そこから真直に北極の上空に達し、ポイントバローを廻って帰ってくるのだそうである。",
              "citation": {
                "source": "アラスカ通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたらアラスカの第一区（加奈陀の太平洋岸）の氷冠（万年雪で蔽われている地帯）では、一回のストームに十メートル積ることがあるという。",
              "citation": {
                "source": "アラスカ通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このミシガン湖を渡って、よく加奈陀の方から、寒い気塊が襲来してくる。",
              "citation": {
                "source": "ウィネッカの秋",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからアラスカに石油発見の見込があり、また加奈陀の北氷洋側にウラニウムの鉱山が発見されたので、この数年来、北極圏内の開発という問題が、大きく表面に出てきた。",
              "citation": {
                "source": "ウィネッカの冬",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともそれは原理としては、という話であって、実際に氷河の氷を、アラスカから加奈陀を通り、アメリカ大陸のあの荒漠たる沙漠を横切って、シカゴまでもってくることは、大変な難事業である。",
              "citation": {
                "source": "ウィネッカの冬",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカゴの北方へ三百マイルも行くと、加奈陀との国境近いところに、たくさん雪の降るところがある。",
              "citation": {
                "source": "ウィネッカの冬",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、「Ｎ・Ｂの新生涯に関する未発表の筆録集」という本に集成されている「仏領加奈陀、ポオル・ロアイヤル小教区、ノートルダム・ド・ルルド附属墓地埋葬帳より転写」という記録を見ると、一八三〇年　二月二十一日　フランス伯、前皇帝Ｎ・Ｂ、死去。",
              "citation": {
                "source": "フランス伯Ｎ・Ｂ",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖体秘蹟、聖餐並に終油　同二十二日　侍医アントン・マルシィ氏、塑面（デス・マスク作製）　同二十三日　埋葬式、聖砂鎮魂　とあって、ナポレオンはセント・ヘレナで似非ナポレオンが死んでから九年後、ジャック・カルチイエが開拓した仏領加奈陀の一邑で、悠々六十一歳の天寿を全うしたことになっている。",
              "citation": {
                "source": "フランス伯Ｎ・Ｂ",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまな人間が別々な場所で思い思いに書いた筆録を、註解もなくただ雑然と並べているだけだが、かれこれと読み合せて行くうちに、ナポレオンがどんな方法でセント・ヘレナを脱けだし、どういう経過で仏領加奈陀へたどり着いたか自然にわかるようになっている。",
              "citation": {
                "source": "フランス伯Ｎ・Ｂ",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか、カナダのタール教授が来て氷河に関する話をしたときなど、ペンクは色々とディスクシオンをしながら自分などにはよく分らぬ皮肉らしいことを云って相手を揶揄しながら一座を見渡してにやりとするという風であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八四年カナダのモントリオルで大英学術協会が開かれたときにレーリーが会長に選ばれた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「科学と英国と貴族とを代表しなければならない」と云い、また眼前の政治的危機に対するカナダ新聞界の判断は、レーリーの印象によって左右されるだろうと云ったりした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カナダから帰るとすぐケンブリッジへ辞表を出した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
