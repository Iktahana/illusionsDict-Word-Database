  {
    "uuid": "95a3ed2b-d09d-513a-9ce8-6254c594a20f",
    "entry": "佳酒",
    "reading": {
      "primary": "かしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
