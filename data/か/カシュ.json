    },
    "definitions": [
      {
        "index": 1,
        "gloss": "good wine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「くぅーっ、この佳酒、五臓六腑に染み渡るなあ！ 最高の週末だよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「さあ、今夜は秘蔵の佳酒を振る舞うぞ。心ゆくまで楽しんでくれ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "芳醇な香りが広がる佳酒をゆっくりと味わいながら、彼は更けゆく夜を惜しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一瓶の佳酒が有ると假定する。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瓶の佳酒が有ると仮定する、之を自分一人で飲み尽せば酔いを得るに足り、他人と共に之を飲めば自他共に酔いを得るに足りないという場合に際して、自分一人で之を飲み尽して、同座又は同寓の人に分かち与えないのは、福を専にするのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらを順々に歓迎すべく、ラ・ポウト郡フレモント丘のガンネス邸には、夫人の微笑と、佳酒の美味と、まだ充分熱の残っている未亡人の寝台と、それから最後にコロロフォルムと斧とが用意されている。",
              "citation": {
                "source": "斧を持った夫人の像",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓上には、美味と佳酒と伯爵夫人の愛嬌とがある。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、いかにも、（こんな食膳には飽いている）　という顔して、珍味佳酒のまえに、泰然としているのは辛いだろう。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿舎の結構、調度の善美、朝暮の佳酒珍膳など、もちろんのことだが、信長が家康にうけてもらいたいものは、やはり市井人の長屋交際とか、田舎人の炉辺の馳走とも違わない、その「物」よりは「心」であったこというまでもない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜樽の佳酒と、鹿の脯を携えて、あした南山を訪えと。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、出立の前に、兄の馬良が亡くなりましたので――」と、逆さまながら私事を先にのべて、まず孔明の心をなだめてから、「天子が、それがしを、ご陣中へお遣わしなされたのは、何の異変も都にあるわけでなく、夷蛮の熱地を征く将士の労をおしのび遊ばされ、成都の佳酒百駄を軍へご下賜あらせられました。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝に美姫の肩の柳絮を払い、夕べに佳酒を瑠璃杯に盛って管絃に酔う耳や眼をもっては、忠臣の諫言は余りにもただ苦い気がした。",
              "citation": {
                "source": "三国志",
                "author": "篇外余録",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手な歌みたいなものまで書いて、恥ずかしゅうございました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは、――年とって、もろもろの物慾が出て来て、お恥かしゅうございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿をぬかしゅな！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
