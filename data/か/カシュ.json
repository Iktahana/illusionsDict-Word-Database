    },
    "definitions": [
      {
        "index": 1,
        "gloss": "good taste",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ほう、この茶室の設えには、亭主の繊細な佳趣が随所に感じられますな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「まあ、なんて佳趣に富んだ織物かしら。色使いがとても上品ね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "庭園に配置された自然石のバランスが、独特の佳趣を醸し出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "神田川の中、水道橋辺より○御茶の水橋下流に至るまでの間は、扇頭の小景には過ぎざれども、しかもまた岸高く水｜蹙りて、樹木鬱蒼、幽邃閑雅の佳趣なきにあらず。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の中の小島の松、汀の柳、小さな柴橋、北戸の竹、植木屋に褒められるほどのものは何一ツ無く、又先生の眉を皺めさせるような牛に搬ばせた大石なども更に見えなくても、蕭散な庭のさまは流石に佳趣無きにあらずと思われる。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "東　楽あれば苦あり西　来年の事云へば鬼が笑ふ　近を釈きて遠を謀るは愚人の常態にして、陋なること笑ふべければ、西の諺の方は甚だ佳趣あり。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "共に嘉言にして佳趣あり。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "東の方の諺佳趣あり。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣魚もおもしろいが養魚はなほ更佳趣の多いことで、二ヶ所の養魚場を見て、自分も一閑地を得たら魚を養ひたいナアと、羨み思ふを免れなかつた。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "能く何物にも犠牲たらざるものは、人間として何の佳趣をも備へざる者なり。",
              "citation": {
                "source": "「桂川」（吊歌）を評して情死に及ぶ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手な歌みたいなものまで書いて、恥ずかしゅうございました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは、――年とって、もろもろの物慾が出て来て、お恥かしゅうございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿をぬかしゅな！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生意気なことをぬかしゅと承知がならんぞ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなつかしゅう御座います。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい、お恥かしゅう存じます。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この土手へ出ちゃ、何時までもこうしていますのに、唯いては、谷戸口の番人のようでおかしゅうござんすから、いつかッからはじめたんですわ。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "念仏さえ碌に真心からは唱えられんでございまして、御祈祷僧などと思われましては、第一、貴下の前へもお恥かしゅうございますが、いかがでございましょう。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お恥かしゅうござんす。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰に見せても恥かしゅうない刺青や。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「与四郎は変った」「おかしゅうならはった」というのが風雅社会の一般の評であった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見知らぬ他人から、兄さん、おなつかしゅう、など言われて、ふざけた話だ。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は恥ずかしゅうございました。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「世渡りのためとは申しながら……前へ御祝儀を頂いたり、」　と口籠って、「お恥かしゅう存じます。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧都　いやいや、鱗一枚、一草の空貝とは申せ、僧都が承りました上は、活達なる若様、かような事はお気煩かしゅうおいでなさりましょうなれども、老のしょうがに、お耳に入れねばなりませぬ。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那さま、泣いたりしてお恥ずかしゅう思います。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほほほほ多一さん、貴下、そうむつかしゅうせずと、胡坐組む気で、杯しなはれ。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もこう申してはお恥かしゅうございますが、昔からこうばかりでもございません、それもこれも皆なり行だと断念めましても、断念められませんのはお米の身の上。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の、贔屓になすって下さるお客様を大事にしたって、何が、何が、おかしゅうござんすえ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきも庭で蝶ちゃんに話したんだが、僕は、飲めば飲むほど酔わなくなるんだ」　すると嘉六は解せない顔をして、「そりゃ、おかしゅうございますね。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはわたくしの映像に向って、「しばらくね、おなつかしゅう」　と挨拶しました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――おなつかしゅうござります。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかんなくずの上に、何だかしゅろであんだ、ぼろぼろの靴ぬぐいをまるめ上げたような、そういう色とかっこうをしたものがころがっています。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
