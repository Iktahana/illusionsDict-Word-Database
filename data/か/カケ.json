        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夏休みの自由研究で、毎日欠かさず月の満ち欠けをスケッチした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今夜は月が少し欠けていて、なんだか寂しげな夜空に見えるね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "海の潮の満ち引きは、月の欠け具合と密接に関係しているんだって。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "望遠鏡を覗くと、月の欠け際のクレーターがくっきりと影を落としていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
