        "examples": {
          "standard": [
            {
              "text": "「カブールの市場は活気にあふれているけれど、夜になると冷え込みが厳しいから防寒着が必要だよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "特派員としてカブールに駐在していた兄は、現地の伝統的なパンの美味しさについて熱心に語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "飛行機から見下ろすと、カブールの街並みが険しい山々に囲まれている様子がよくわかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「カブールの歴史を調べているんだけど、シルクロードの要所として栄えた時代の記録が面白いね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "諸君は今日のようなグラグラ政府には飽きられただろうと思う、そこでビスマークとカブールとグラッドストンと豊太閤みたような人間をつきまぜて一鋼鉄のような政府を形り、思切った政治をやってみたいという希望があるに相違ない、僕も実にそういう願を以ています、しかし僕の不思議なる願はこれでもない。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョッキとアフガンに従軍し、キャラシァブ、シャープール及びカブールに駐屯したる事あり。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "アマヌラ今年に入ってカブールから逃げ出した。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カブールにはバチェ・サカオ Баче-Сакао が居たが、一月三十一日には逃げ出したがって居る。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近東空路を、はるばるアフガニスタンの首府カブールまで伸ばしてきた、独逸航空会社には一層の野心があるのだろう。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は国家経綸の大綱を提げ、蒼生をして衆星の北斗に拱ふが如くならしむるカブールが大略あるにあらず。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから針路をインドの北どなりにとり、まるで天然の万里の長城のようなヒマラヤ山脈を越え、チベットやネパールやブータンの国々の間をぬい、そして一気にアフガニスタン国のカブールという都市まで無着陸の飛行をつづけなければならなかった。",
              "citation": {
                "source": "氷河期の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして今や露国の密使は憧々としてその都城たるカブールに往来せり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が公文書の遒麗富贍にして、而も指画明晰なる、而してその措置の尋常に非ざる、決して誣ゆべからざるものありといえども、これを以て真個の経世家カブールの手腕に比すれば、実にその十が一を望む能わず。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の王政維新（一八六七年）よりはすこし前、すなわち一八六一年に、イタリアでは、サヴォア王家のヴィクトル・エマニュエルの下に、賢明な政治家カブールら二、三の人が奮起して、オーストリアと戦い、イタリア国家の統一が完成された。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
