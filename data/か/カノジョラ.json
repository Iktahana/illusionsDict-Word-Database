[
  {
    "uuid": "bdabd8b2-625f-5540-ad20-2b49d82344f1",
    "entry": "彼女ら",
    "reading": {
      "primary": "かのじょら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "代名詞"
      ],
