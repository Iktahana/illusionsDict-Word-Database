        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「一人でゆっくり飲みたかったから、隅っこのカウンター席をお願いした。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「カウンター席だと、大将が寿司を握る鮮やかな手つきを間近で見られるのがいいよね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「『あ、カウンター席ならすぐにご案内できますよ』と言われて、待たずに入店できた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「オープンキッチンのカウンター席は、料理の香りがダイレクトに伝わってきて食欲をそそる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "カウンター席に里見※先生在り、嬉しくなり、サントリーハイボール飲みつゝ、大いに語る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "カウンター席、おやぢ在り、「クリスマスらしくないものにしてくれ」で、お任せ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
