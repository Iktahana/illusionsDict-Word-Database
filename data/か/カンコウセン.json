    "definitions": [
      {
        "index": 1,
        "gloss": "sightseeing boat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
