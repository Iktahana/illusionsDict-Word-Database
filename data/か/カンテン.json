[
  {
    "uuid": "ee3a4227-3c24-55ea-b9c5-eae57096c4e5",
    "entry": "寒天",
    "reading": {
      "primary": "かんてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "freezing weather",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "予報通り、昨夜からの寒天で水道管が凍結し、朝から水が出なくて困っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "山小屋では、寒天をしのぐため、暖炉に常に薪をくべていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ここ数日の寒天で、公園の池には厚い氷が張り、子供たちがスケートを楽しんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "個人の一挙一動は寒天のような濃厚な媒質を透して伝播するのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんの足が、寒天のようで、夢のような色で、無暗に長いのでした。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また塩魚類｜鰹節の乾燥とか寒天の凍結とかいう製造方面の事柄にも物理学応用の範囲は意外に広大であるように見受けられる。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは骨が寒天のような肉に透き通って、腸が鰓の下に小さくこみ上っていた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒天をいれて、ねばりをつけた。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸されるような暑苦しい谷間の坂道の空気の中へ、ちょうど味噌汁の中に入れた蓴菜のように、寒天の中に入れた小豆粒のように、冷たい空気の大小の粒が交じって、それが適当な速度でわれわれの皮膚を撫でて通るときにわれわれは正真正銘の涼しさを感じるらしい。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、寒天のような、柔かい少年の心を傷つけずにいないのは、勿論だった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者造園学のテキストに、　　　おのれが像を百あまり、著者の原図と銘うちて、　　かゝげしことも夢なれやと、青き夕陽の寒天や、　　　　Ｕ字の梨のかなたより、革の手袋はづしつゝ、　　　しづにおくびし歩みくる。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "開化郷士と見ゆるもの、　　　いと清純とよみしける、寒天光のうら青に、　　　　　おもてをかくしひとはねむれり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍事連鎖劇キネオラマ、　　寒天光のたゞなかに、　　ぴたと煙草をなげうちし、上等兵の袖の上、　　また背景の暁ぞらを、　　雲どしどしと飛びにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから教室はあの水車｜小屋みたいな古臭い寒天のような教室でした。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その黒いことは寒天だ。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寒天の中へ俺ははいる。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでおみちははじめて晴れ晴れじぶんの拵えた寒天もたべた。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒天みたいなすきとおしてそらも見えるようなものがたくさん落ちているからそれをひろってはいけないよ。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂の一とこが円くぽとっとぬれたように見えてそこに指をあててみますとにくにく寒天のようなつめたいものでした。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い車海老はパセリの葉の蔭に憇ひ、ゆで卵を半分に切つた斷面には、青い寒天の「壽」といふ文字がハイカラにくづされて畫かれてゐた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い車海老はパセリの葉の蔭に憩い、ゆで卵を半分に切った断面には、青い寒天の「壽」という文字がハイカラにくずされて画かれていた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃色のペラペラの寒天でできているんだ。",
              "citation": {
                "source": "若い木霊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペラペラの桃色の寒天で空が張られまっ青な柔らかな草がいちめんでその処々にあやしい赤や白のぶちぶちの大きな花が咲いていました。",
              "citation": {
                "source": "若い木霊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんの足が、寒天のやうで、夢のやうな色で、無暗に長いのでした。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北上川の水は黒の寒天よりももっとなめらかにすべり獅子鼻は微かな星のあかりの底にまっくろに突き出てゐました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北上川の水は黒の寒天よりももっとなめらかにすべり獅子鼻は微かな星のあかりの底にまっくろに突き出ていました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷川の水、流れとともに大海に注がないで、横にそれて別に一小沢を造り、ここに淀み、ここに腐り、炎天にはその泥沸き、寒天にはその水｜氷り、そしてついには涸れゆくをまつがごときである。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の浅草のまるで濁った寒天のような空気をうまく太平洋の方へさらって行って日本アルプスのいい空気だって代りに持って行ってやるんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩はばひろくけらを着て、汗ですっかり寒天みたいに黒びかりする四匹か五匹の巨きな馬をがらんとくらい厩のなかへ引いて入れ、なにかいろいろまじなひみたいなことをしたのち土間でこっそり飯をたべ、そのまゝころころ藁のなかだか草のなかだかうまやのちかくに寝てしまったのだ。",
              "citation": {
                "source": "家長制度",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "積荷の塩魚のにおいの間から、ふとすると、寒天や小豆粉のかすかなにおいがする。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒天風雪の時に当って宿を仮さなかったり敷物を仮さなかったり、薪や諸道具を供することを拒んだ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは主観と客観ということばの場合と同一でイワユルなんかんてんところてんの相違である。",
              "citation": {
                "source": "だだをこねる",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "○家に居なくなった母　○雲が母の顔に見える　○子供山の向うに行ってしまう　　　　　○茅野　○かんてんをつくる木のわく沢山雪の上にある。",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "agar-agar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夏の暑い日には、冷やした牛乳寒天が最高のデザートだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "理科の実験で、バクテリアの培養に寒天培地が用いられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "和菓子職人は、寒天の固まる性質を活かし、美しい錦玉羹を作り上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "健康志向の彼女は、食物繊維が豊富な寒天を使った料理をよく作る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
    ],
