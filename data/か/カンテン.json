  {
    "uuid": "60ea1a7e-5793-52cc-a61e-0ff87add4304",
    "entry": "官展",
    "reading": {
      "primary": "かんてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "exhibition sponsored by the government",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "著名な画家が今年の官展で最高賞を受賞し、その作品には連日多くの来場者が詰めかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若手芸術家の登竜門として、官展は長年にわたり多くの才能を発掘してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回の官展では、伝統的な日本画から現代アートまで、幅広いジャンルの作品が展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "政党大臣や大学教授や官展無審査員ならば、ところてんのようにお代わりはいつでもできる。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "印象画派生き残りの唯一の巨匠で、現在官展の元老であるピサロは貧乏ではあるまい。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は胎龍と年雅塾の同門だったのですが、官展の出品で当選を争った際に、胎龍は卑怯な暗躍をして、父を落選させ自分が当選しました。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "官展に於ても、工芸美術なんて二流美術の名称を授けられ、軽蔑を受けながら多としているなどは、全く駄人という奴である。",
              "citation": {
                "source": "愛陶語録",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄新水会で威張つてゐたのが、官展になつて急に追ひ落されたくはないやね。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、明石、室井、水谷の三頭目なんだが、こん中から官展の審査員に推されるのは多分一人だ。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フオーヴやシユールがゝつた連中が二三人ゐるけど、まだチヤチだしね、やつぱり官展になつてから特選級になれるやうな大物で、しかも新しい物の描ける奴が欲しいんだよ。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは主観と客観ということばの場合と同一でイワユルなんかんてんところてんの相違である。",
              "citation": {
                "source": "だだをこねる",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "○家に居なくなった母　○雲が母の顔に見える　○子供山の向うに行ってしまう　　　　　○茅野　○かんてんをつくる木のわく沢山雪の上にある。",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "革命とは水っぽい艶々の羊かんかんてん　かんてん　かんてんの泥人間一人が孤独で戦う群勢はいりません家柄やお国柄では飯は食えぬ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今はみつ豆のかんてんをぽちぽちたべながら、「……私エスペラントなんて柄じゃないんだけれど……でも、講習会へ来てるひと、わりかたみんな気持いい人ばっかりね。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
