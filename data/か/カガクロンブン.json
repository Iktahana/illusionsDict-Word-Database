        "examples": {
          "standard": [
            {
              "text": "最新の科学論文を引用して、自説の妥当性を客観的に証明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は一晩中、海外の科学論文を読み漁って最新の知見を取り入れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この科学論文、図表が非常に整理されていて分かりやすいね」と教授が感心した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "専門誌に投稿した科学論文の査読結果が届き、彼は緊張した面持ちでメールを開いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "科学論文や報告書などをバサバサ拾い読んだり飛ばし読んだりする程度ならいいが、それによって小説やエッセイや哲学や歴史の本を読もうなどという気分にはとてもなれない。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代的な科学論文なるものは、恰もこの事情を最も明らかに自覚して書かれるものに他ならない。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "なる程少し位い文章がまずくても、内容が正確で観点が高ければ、立派な科学論文である。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏の啓蒙的な科学論文はまことに平明明晰であって、論理的思索の力と文筆の才能とが並々ならぬことを示している。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "新たに移動された書物は全て現代のもので、歴史書、科学論文、地理書、作文法、哲学書、および最近の新聞雑誌類だった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "フラカストロは文才があり奇知に富む手紙を外国にいる友達に送りよく整ったラテン語の詩および科学論文を書く。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった２編の科学論文を書いたのはここであった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の科学論文を知っていて多数は「内科学の理論と実際」に親しみを持っている。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
