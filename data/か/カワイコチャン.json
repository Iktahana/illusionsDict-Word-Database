        "examples": {
          "standard": [
            {
              "text": "あら、かわいこちゃん、このお菓子食べる？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "道でばったり会った、あの写真のモデルさん、本当にかわいこちゃんだったね！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うちの子、かわいこちゃんなんですよ」と、母親が嬉しそうに話していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ガラスの向こうにはっきりと見えるのに、せいいっぱいテーブルの足からのぼろうとしても、すべるすべる、しまいにはくたびれて、かわいそうにかわい子ちゃんはへたりこんで大泣き。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとに来るのが王子さま王女さま、１０まいいらっしゃて、このかわい子ちゃんたち２人１組で手をつないで、うきうき軽やかに進む、そろってハートがらのおあしらい。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいにはくたびれて、かわいそうにかわい子ちゃんはへたりこんで大泣き。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "やるなら、北部にいる仲間のかわい子ちゃんだよ、絶対。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやすみ、かわい子ちゃん」第二章　男の守りが一番弱い所は一番強い所、つまり一般人はほとんど知らないが、偉大な男でさえバカなことをするということである。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "『｜かわい子ちゃん』って呼ばれるの嫌？",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも好きなんだろ、かわい子ちゃん」　愛を引き留めようとイシドレが言った。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かわい子ちゃんにやらせなさい。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            }
          ]
        }
