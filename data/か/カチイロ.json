[
  {
    "uuid": "8ad4af8f-8d7a-59ed-b227-75ffbbc9c554",
    "entry": "褐色",
    "reading": {
      "primary": "かちいろ",
      "alternatives": [
        "かついろ",
        "かちんいろ"
      ],
      "is_heteronym": true
    },
    "grammar": {
