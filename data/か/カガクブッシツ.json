    },
    "definitions": [
      {
        "index": 1,
        "gloss": "chemical substance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この新しい素材は、人体に有害な化学物質を含んでいないとされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "特定の化学物質に触れると、皮膚に炎症を起こすことがあるので気をつけよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "環境中に放出された化学物質が、生態系に深刻な影響を与えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの独特な臭いは、どこかの部屋から漏れている化学物質のせいかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "調剤で使われる最も有効な薬品および化学物質の10のうちの９つは（＊始めは疑われないで）最後に疑われるような商人が売っている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時から後には化学物質をモルトとホップの代わりに使う指導の書類や料理献立書がそれぞれよく売れた。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにおける中心的なアイディアとは、絶えず組織において化学物質は循環している代謝「プール」に放出されるとともに代謝「プール」から取り込むことである。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "生体内の生化学物質における原子の配列に関与する力についての問題は今でも実験室における研究の及ぶところではない。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の風変わりな研究と奇妙な化学物質の輸入は広く知られており、彼の墓所愛好趣味も広く疑われていた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃には家族とはほとんど絶縁状態で、ほとんどの時間を欧州で購入した奇妙な書物や、イギリス、フランス、オランダから船で取り寄せた異様な化学物質と共に過ごした。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に質問を受けた地元の薬品店と科学機器店は、彼が購入した驚くほど奇妙で無意味な化学物質と器材の一覧を提供した。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "その合間にはガラスの触れる音や化学物質のシュウシュウいう音、水が流れる音、炎の燃え盛る音が聞こえてきた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い説教の終わりに彼は、父親の言うことは正しく、騒音や呟きや詠唱や化学物質の臭いが不愉快だったのには弁明の余地がないと認めた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が二つの標識の意味に戸惑い、この化学物質の組が実験室本体の棚に置かれたガラス瓶の中身とこれほど厳密に分けられているのはなぜだろうかと思った。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝説によると、有史以前の星間飛行では、彼らはある種の化学物質を吸収して、食餌、呼吸、温度に影響されない状態になった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも効果がある治療薬は化学物質すなわちパラケルススの秘薬である。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後に薬理学の目的は動物実験を用いて化学物質によって身体の機能がどのていど変化させられるかを示すこととなった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "化学的な憶測によって正しい結論に達するとは期待しないが身体の化学物質が健康者だけでなく病人で如何に結合し分解するかを研究し説明すべきであると主張する。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では特定の細胞と特定の化学物質のあいだに特有な親和性があることを知っている。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある種の化学物質はこれらの有毒物質を無毒化することを彼は示した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時まで感染性生物に対する戦いは主として化学物質が用いられとくに種々の酸が使われたがコッホは蒸気消毒がもっと信頼性のあることを示した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "微生物は化学物質で殺すことができる筈である。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "化学物質は生体内で独自の所属があり反応する場所のあることは以前から知られていた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "化学物質は生体内で特異的な攻撃点を持つという前と同じ考えで彼は導かれていた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は体細胞には殆ど親和性が無く細菌に親和性の強い化学物質を見つけようとした。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにより彼は人体を構成する化学物質を得たがこれらの物質を使い化学反応を起こさせる錬金術者として別な概念を追加する必要があった。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "錬金術は時に宗教運動的な性格を持ち化学物質の引力と斥力はシンボルの意義を持つものとされた。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある種の化学物質は人体の特定の細胞にはっきりとした親和性を持つことが見つかっていたからであった。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬理学は身体のある部分と化学物質のある反応グループの間の親和性を発見して今では期待するような効果をもつ化学物質を系統的に作ることができるようになった。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "20世紀の初めにエールリッヒは患者を殺さないで細菌を殺す化学物質を系統的に探し始めた。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし我々の主な敵である細菌はひとたび体内に入って隠れてしまうと化学物質に頑固に抵抗するように見えた。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "食品中にあって病気に抵抗する役割を持っているような栄養素ではない化学物質についての研究は、ほんの始まったばかりである。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
