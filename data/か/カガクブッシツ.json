[
  {
    "uuid": "5902d4aa-dc01-5f61-8d5d-18e4743a47c2",
    "entry": "化学物質",
    "reading": {
      "primary": "かがくぶっしつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
