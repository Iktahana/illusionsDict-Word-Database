        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今週末、私の「カー」を洗車する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は毎日「カー」で通勤している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しい「カー」は燃費が非常に良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あのスピードを出している「カー」に気をつけろ！」と彼女は警告した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "田舎を観光するために、「カー」を一台借りました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「コートリ、タマゴ、ハーカマ、ハオリ……」「アーメ、カサ、カーラカサ、アサヒ……マツ、ツル、シカノ……ツノ、ウシノツーノ。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "又生徒達は、彼の修身の時間、吃度三つは引用される、カーライルかそれでなければスマイルスかの言葉を、暗誦してはその後に「さう、なくちや――さうなくちやならぬ」と喰ッ付けた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵葉書屋へはいったら一面に散らした新年のカードの中には売れ残りのクリスマスカードもあった。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カール総長の握手の力の強いのにびっくりした。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しおれた白百合やカーネーションが流しの隅に捨ててある。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーネーションの匂。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーテンを上げて覗いてみると、人気のない深夜の裏通りを一台の雪橇が辷って行く、と思う間もなく、もう町のカーヴを曲って見えなくなってしまった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この先生はたいていいつも少し茶色がかった背広の洋服に金縁眼鏡で、そうしてまだ若いのに森｜有礼かリンカーンのような髯を生やしていたような気がする。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "単調な声でゆるやかな拍子で「ナーンモーンデー」と唱えると鉦の音がこれを請けて「カーンコ、カンコ」と響くのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）わが家へと入りてみれば　　なごやかにうちまじりつつ秋の日の夕陽の丘か炊煙か　　　　われを暈めかすもののあり　　　　　　　　　　　　古き代の富みし館の　　　　　　　　　　カドリール　ゆらゆるスカーツ　　　　　　　　　　カドリール　ゆらゆるスカーツ　　　　　　何時の日か絶えんとはする　カドリール！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェンロッカー（錨室）の蓋の上には、安田が仰向きに臥ていた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば（サル）（ワ）（カー）（マ）（サ）（ムリ）（ダ）（シア）（アシユ）（ワ）（メ）（ダ）（シア）（ヤト）（フア）（ラム）。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎も角も榛名湖畔迄上ぼつて見ようといふので、ケーブルカーの停車場のある谷底へ下りて行つた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この瓦斯はカーバイドと称える人造の石塊に水をかければ発生するから、使用は軽便である。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花屋の店の氾濫、カード屋のカード字も独逸風のややっこしい装飾文字が太く賑やかに刷られて居るのも、他の国のとは自然違う感じです。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "褄は花の如く開かねば趣ないといふ廃頽的の江戸趣味も困るが、この理由をもつて、だからこそ和服も行灯式のスカートにせよといふ改良論者はまた行き過ぎる。",
              "citation": {
                "source": "風と裾",
                "author": "――何人か良案はないか？――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイデルベルクでもベデッカーの案内記にはグランド・ホテルとなっている旅館もハイデルベルゲル・ホーフと改名していた。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人の球が時々途中から右の方へカーヴを描く。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十分後には帽が三重のスカーフ雲の笠になっていた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船は大きなカーヴを描いて出て行くので色さまざまの灯をちりばめた山腹の街の眺めがだんだんに変りながら遠くなって行く。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱作りに適するローヤル・スカーレットという薔薇がある。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばビーカーをアルコールランプで下から熱すると水蒸気が出てそれがビーカーの外側にあたって冷却され、水粒がビーカーに附着する。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見て児童はどうして出来るかと質問したときに、教師がそれをいいかげんに答えるのはいうまでもなく悪いが、これを知っている場合に、何でもないことだ、アルコールの燃える際に生ずる水蒸気がビーカーにあたって露になって着くのだといって、あまり無造作に片づけてしまうのは面白くないと思う。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
