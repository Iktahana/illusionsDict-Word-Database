      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "paper store",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "活版印刷を依頼するため、こだわりの和紙を扱っている老舗の紙屋を訪ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お探しの厚さなら、この奥にある在庫が丁度いいですよ」と紙屋の主人が勧めてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "商店街の角にある小さな紙屋には、カラフルな千代紙が所狭しと並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ただこの頃折々｜牛込の方へ出ると神楽坂上の紙屋の店へ立寄って話し込んでいる事がある。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この紙屋というのは竹村君と同郷のもので、主人とは昔中学校で同級に居た事がある。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も夕刻から神楽坂へ廻って、紙屋の店で暮の街の往来を眺めていた。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は中学校を出るとすぐに生真面目な紙屋の旦那になっている主人と、自分のような人間との境遇の著しい違いを思い較べていた。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日ちらと見た紙屋の娘の帯に似ている。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙屋の娘も水々しい島田で乗っている。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころは既に広重の出世作、『東海道五十三次』（保永堂板）は完成され、葛飾北斎の『富嶽三十六景』が、絵草紙屋の店頭に人目を驚かしていたのであるが、その地図にある定火消屋敷で、広重が生れ、西の丸のお膝下で、名城と名山の感化を受けていたのだと思うと、晩年に富士三十六景の集作があったのも、偶然でない。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "花道へ現れた紙屋治兵衛に「モダンボーイ」と呼びかける弥次馬の声などもただ笑って聞いてばかりもいられないような気がする。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "為さんが川へ引き込まれた」　為さんというのは、町内のちいさい紙屋の亭主で、草履屋とはまったく縁のない商売でありながら、藤吉とは子供のときの手習い朋輩といい、両方がおなじ釣り道楽の仲間であるので、ふだんから親しく往きかいして、岡釣りに沖釣りに誘いあわせて行くことも珍らしくなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "越前屋は小半町しか距れていないので、すぐに行き着くと、紙屋の店は表の戸をおろしてひっそりしている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "死骸は大きい御膳籠に入れて、富蔵と出前持ちふたりが持ち出して行ったのです」「では、紙屋の亭主はなんにも係り合わなかったのですか」「まったくなんにも知らないんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙屋の亭主こそ実に迷惑で、それがために思いもよらない災難をうけて、一旦は召し捕られたり、その後もたびたび番所へ呼び出されたり、どうもひどい目に逢いましたが、右の事情が判って無事に済みました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "葺屋町に炭団伊勢屋という大きい紙屋があります。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その中でたった一人かかさずに来る奴があります」「紙屋の息子か」「あ、源次の奴ほじくり出しましたかえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、紙屋の久次郎は色仕掛けでたくさんの祈祷料をまきあげられているに相違ないと云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "その報告はいつも同じことで、夜になっては紙屋の息子のほかに誰も出這入りするものは無いとのことであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分、紙屋の息子が二、三日前から姿を隠したようです」「行者はどうした」と、半七はすぐに訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "それについて、行者の家の式部という奴がなにか紙屋へ掛け合いに行ったらしいんです」　そう云っているところへ源次も来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "源次は多吉の報告以上に、紙屋の息子が姿をかくした事件を詳しく知っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでにこないだも東の紙屋の若い奴が、桜木町である女と出来合って、意気事を極めるちゅうから、癪に障ってな、いろいろ験べたが何事もないで、為方がない、内に居る母親が寺｜参をするのに木綿を着せて、汝が傾城買をするのに絹を纏うのは何たることじゃ、という廉をもって、説諭をくらわした。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうか――そこの中ほどに、さきが古道具屋と、手前が桐油菅笠屋の間に、ちょっとした紙屋があるね。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙屋で治兵衛は洒落ではないのか。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「成程、紙屋――あの雑貨店の亭主だな。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙屋は黙って、ふいと離れて、すぐ軒ならびの隣家の柱へ、腕で目をおさえるように、帽子ぐるみ附着いた。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょろひょろの小僧は、叩きつけられたように、向う側の絵草紙屋の軒前へ駆込んだんです。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　西郷星　かの西南戦役は、私の幼い頃のことで何にも知らないが、絵双紙屋の店に色々の戦争絵のあったのを記憶している。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙屋の店を継いではじめて商売を手がけてみた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うと、袖を斜めに、ちょっと隠れた状に、一帆の方へ蛇目傘ながら細りした背を見せて、そこの絵草紙屋の店を覗めた。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "酸漿屋の店から灯が点れて、絵草紙屋、小間物｜店の、夜の錦に、紅を織り込む賑となった。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてどんじりが、「繪草紙屋の四十島田。",
              "citation": {
                "source": "神樂坂七不思議",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
