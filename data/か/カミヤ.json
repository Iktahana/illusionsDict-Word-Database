  {
    "uuid": "41d664d6-e173-56c8-92ed-2e230332b279",
    "entry": "神矢",
    "reading": {
      "primary": "かみや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "divine arrow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "破魔矢と同じく、災厄を射抜く神矢として授与品所に並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "儀式のクライマックスで、神職が空に向かって放った神矢が風を切る音を立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "宝物殿には、伝説の英雄が使ったとされる巨大な神矢が安置されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "近江屋の一家に隠れた悪業があって、大国魂さまが罰をあたえるためにお神矢を放ったというわけでもありますまい。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "猫眼の男",
                "note": "青空文庫"
              }
            },
            {
              "text": "行って見ると、なるほど、藤右衛門の言った通り、本殿のほうから五六間おきに一人ずつ、近江屋鉄五郎、お源、お沢、お源の許婚者の青梅屋の新七という順序で、いずれも鷹の羽朱塗のお神矢で深くぼんのくぼを射られ、水浅黄の水干の襟を血に染めて俯伏せになって倒れている。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "猫眼の男",
                "note": "青空文庫"
              }
            },
            {
              "text": "顎十郎は、胡※を持ちながら五造の前にあぐらをかき、「おい、五造さん、胡※に入っていたお神矢の数は十二本。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "猫眼の男",
                "note": "青空文庫"
              }
            },
            {
              "text": "……桜場清六が近江屋一家を鏖殺しにしてやるなどとふれまわってるのに引っかけ、夜眼のきくのを幸いにお神矢で鉄五郎以下四人を射ころし、それを桜場に塗りつけようなんていうのはひどいじゃないか」　五造は血相かえて膝行だし、「と、と、飛んでもない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "猫眼の男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも古くは『吾妻鏡』建久四年富士の狩の条に「御狩｜訖りて晩に属し、そこにおいて山神矢口等を祭らる」とある。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "九日續き陣中に神矢あまねく降り注ぐ、十日に至りアキリュウス、衆を評議の席に呼ぶ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ははにかみやの癖にそれが辱かしくない程隠れん坊が嬉しかつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく「はにかみや」であったのでこの時の演説はよく聞き取れないくらいであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はただやたらにコップ酒をあおり、そうして、おもに、おでんやのおかみや女中を相手におしゃべりした。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども生れつき臆病ではにかみやの私は、そのような経験をなにひとつ持たなかった。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、今度は生きながら人情のあたたかみや、憎みや、征服慾が生れ出て、それがもつれ絡んだままスランプに陥ってしまっただけ始末が悪かった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやどす……」　と、言おうとしたが、文の家のおかみや桔梗家のおかみの顔が怖かった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鶴雄さん、鶴雄さん……」　鈴子は文の家のおかみや、桔梗家のおかみにうながされて、二階への階段を上って行きながら、今はもうはっきりと恋をしていると判った男の名を、ひそかに叫び続けていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "はにかみやであったが、一週間に五人の同級の男の子が彼に撲られて泣いた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの小心で、羞かみやで、いつもストイツクに感情を隱す男が、その時顏色を變へて烈しく言つた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの小心で、羞かみやで、いつもストイツクに感情を隠す男が、その時顔色を変へて烈しく言つた。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その為に世間知らずの非常なはにかみやになって終いました。",
              "citation": {
                "source": "わが半生を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんは人一倍はにかみやの、神経の繊細な人らしい。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんになんに附けても、はにかみやあがるだろう。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "女王のは木綿の片に、そのかみやいかがはありし木綿襷心にかけて忍ぶらんゆゑ　とだけ書いてあった。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かみやげをとて、物賣る家を見廻したれども、これはと思ふものなし。",
              "citation": {
                "source": "越ヶ谷の半日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い女性にはそのはにかみやな所から今まで絶えて接していなかったので、葉子にはすがり付くように親しんで来た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で村瀬ひとりだけが、変なはにかみやで冗談はおろか、大きな声では笑ひ声ひとつたてられぬ程の内気者で、これはまた明るい花園の中のたつた一本の日蔭の蔓のやうであつた。",
              "citation": {
                "source": "女に臆病な男",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、そんな不体裁な眼玉を関はずに容れてゐる癖に、一方に変なはにかみやであつて、何んな切端詰つた場合にも眼玉の脱された眼窩を決して他人には示さなかつた。",
              "citation": {
                "source": "木枯の吹くころ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私がはにかみやのことを知つてゐる癖に彼女は難題を持かけるのです。",
              "citation": {
                "source": "早春のひところ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "停年教授はと見ていると、彼は見掛によらぬ羞かみやと見えて、立つて何だか謝辞らしいことを述べたが、口籠ってよく分らなかった。",
              "citation": {
                "source": "或教授の退職の辞",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあの如く余程成長してから始めて父親の姿に接し、元来はにかみやであつた所為か容易に日本語では即座に「お父サン」などゝ云つて親しめなかつた。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際紫蘇や、茗荷や、はじかみや、そんなものの折り重つて生え繁つてゐるこの勝手口には、間のぬけた、辛味のきかない、愚者のぼんつく蓼の一本ぐらゐあつた方がよかつた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "内気ではにかみやの烏瓜は、かへつてそれをよいことにして、身辺の無関心のうちにわが性の孤独をのみ見つめて、ひたすらにみづからの生命をいたはり育ててゐた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "青野がさうした吾家のことに就いてはにかみやであるといふことばかりでなしに、青野があんなものを振り回してゐる自身の姿に此方の方には決して無いのだが惨めな滑稽感を抱き兼ねない怖れが想像されて――。",
              "citation": {
                "source": "鶴がゐた家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
