[
  {
    "uuid": "d01d3e73-b6a3-58b4-a338-61b1db338896",
    "entry": "紙屋",
    "reading": {
      "primary": "かみや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
