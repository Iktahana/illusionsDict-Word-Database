  {
    "uuid": "c7c3aed4-26ed-5ee3-be5f-8174e7f934da",
    "entry": "寛延",
    "reading": {
      "primary": "かんえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Kan'en era (1748.7.12-1751.10.27)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この古地図は、寛延年間に製作されたものらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "寛延の飢饉は、江戸幕府に大きな影響を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は寛延期の風俗を研究している歴史学者だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この寺院は寛延年間から続く由緒ある建築物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "墓は大きい台石の上に高さ五尺ほどの楕円形の石を据えてあって、石の表には慈望遊謙墓、右に寛延○年と彫ってあるが、磨滅しているので何年か能く読めない。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓碑に寛延の年号が刻んであるのを見るとよほど長命であったらしい。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛延年間のことであったらしい。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "登の子四郎右衛門は物奉行を勤めているうちに、寛延三年に旨に忤って知行宅地を没収せられた。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛延｜年不詳、霜月のしかも晦日、枯野見からお定まりの吉原へ。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛延二年には六三郎が十九になった。",
              "citation": {
                "source": "心中浪華の春雨",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓は大きい台石の上に高さ五尺ほどの楕円形の石を据えてあって、石の表には慈望遊謙墓、右に寛延○年と彫ってあるが、磨滅しているので何年かよく読めない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓碑に寛延の年号を刻んであるのを見ると、よほど長命であったらしい。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛延元年九月十三日夜の亥の刻（午後十時）から夜明けまでのあいだに、五人の若い男が即死、二人が半死半生という事件が出来したので、村中は大騒ぎになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "小女郎狐",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛延三年に淡淵が四十二歳を以て先づ江戸に入つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛延元年の生で、此年五十七歳、蘭軒は二十八歳であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛延三年に播磨国姫路の城主酒井｜雅楽頭忠知の重臣犬塚純則の六男に生れ、同藩青木某の女婿となり、江戸に来て昌平黌の員長に推された。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛延元年二月二日に菅波喜太郎として生れたからである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹亭は元文四年に生れ、寛延三年十二歳にして元服し、宝暦五年に、十七歳にして正右の儒者にせられた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "書上は此を「寛延三庚午年」としてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "北山は寛延三年生で文化九年に六十一歳で歿したから、束脩百疋の時代は、恐らくはまだ二十に滿たぬ天民、壽阿彌が三十幾歳の北山に師事した天明の初年であらう。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川九代家重の寛延元年七月廿七日の禁令には（百八十八年前）おつて供※り徒士の者、中間、奴共風俗｜不宜がさつに有之、供先にても口論仕不屆に候自今風俗相改かうとふと致し、相愼め　とある。",
              "citation": {
                "source": "凡愚姐御考",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛延二年の暮の話である。",
              "citation": {
                "source": "相馬の仇討",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "貰ひの詩歌いろ／＼　寛延三年正月上旬、芝邊の寺町に行倒れの非人がありました。",
              "citation": {
                "source": "物貰ひの話",
                "author": "三田村鳶魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩を作つた乞食は時々あつたものと見えまして、「兎園小説」に延享五年――寛延と改元された年の正月十三日の明方、大坂の四ツ橋で金五十兩拾つたやつがある。",
              "citation": {
                "source": "物貰ひの話",
                "author": "三田村鳶魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして、寛延二年正月酒井忠恭は播州へ転封となり、その後へ松平大和守朝矩が来たり、この厩橋城へ入ったのである。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その画は元祖清信が歿年（享保十四年）の頃より寛延三年の頃まで続いて出しが故に、時として元祖清信の作と混同して大に今日の研究者を苦しましむ。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "元文より寛保延享寛延に至る頃奥村政信｜及その一派の画工は室内の遠景を描ける大板の紅絵漆絵を出せり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛延年代には幕府は長崎入港の唐船を十五艘に制限し、さらに寛政三年よりは一か年十艘以上の入港を許さなかった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "海賊赤格子九郎右衛門が召捕り処刑になったのは寛延二年三月のことで、所は大阪千日前、弟七郎兵衛、遊女かしく、三人同時に斬られたのである。",
              "citation": {
                "source": "赤格子九郎右衛門の娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛延二年から十五年を経た明和元年のことであったが、摂州萩の茶屋の松林に正月三日の夕陽が薄黄色く射していた。",
              "citation": {
                "source": "赤格子九郎右衛門の娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本木二世初太夫（三谷氏では三世）は寛延二年五十六で死んだ。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛延二年の春、桃の節句のすんだあと、雅楽頭の御前で、犬塚がなにげない顔でこんなことをいった。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛延四辛未の年転じて塘氏家茂の所有に帰した。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、寛延二己巳年七月朔日、夕方より小雨ふり、夜入候ても、鳴神とふくに聞へ、さほど雨にてはこれなく、やはりいつもの通り、相撲など取候所へ出、九ツ時前にみな／＼引取。",
              "citation": {
                "source": "三次実録物語",
                "author": "稲生武太夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
