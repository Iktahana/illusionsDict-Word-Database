      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "judgement",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「この絵が本物かどうか、プロの鑑定を仰ぐことにしたんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鑑定の結果、その古びた茶碗は室町時代の貴重な名品であることが分かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あーあ、鑑定してもらったけど、結局ただのガラス玉だったよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "専門家による厳正な鑑定を経て、その歴史的建造物は重要文化財に指定された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "電気窃取罪の鑑定人として物理学者が法廷に立った事もある。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年七月四日『東京朝日新聞』）　　　　　　　　　八十七　　　　　　死産児の鑑定法　嬰児の死体を検してこれが果して本当に死んで後分娩されたかあるいは出産後死亡したかという事を容易に判別する新法が近頃仏国学士院の報告に発表された。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鸚鵡の持ち主はどんな女だか知らないがきっと、海山千年の女郎だろうと僕は鑑定する。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここまでお話をすれば、あなた方にも大抵鑑定が付くでしょう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その戸棚のなかに男を隠まってあるものと半七は鑑定した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "心中というのは自分だけの鑑定で、成程おみよの書置に心中ということは書いてないらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは一種のかどわかしで、身分のありそうな武士や女に化けて来て、容貌のいい娘をさらって行ったに相違ない、と半七は鑑定した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱりおれの鑑定通りだな」「そうです、そうです」　かれが摺り寄ってささやくのを、半七は一々うなずきながら聴いていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日ならば死骸の疵口をあらためただけで、人間が咬んだのか、獣が咬んだのか、そのくらいのことはすぐ鑑定が付くでしょうが、昔はそれがよく判らなかったんですね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして世におのずから骨董の好きな人があるので、骨董を売買するいわゆる骨董屋を生じ、骨董の目ききをする人、即ち鑑定家も出来、大は博物館、美術館から、小は古郵便券、マッチの貼紙の蒐集家まで、骨董畠が世界各国｜都鄙到るところに開かれて存在しているようになっている。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二種の糞を拾って行って老測夫に鑑定してもらったらどちらもうさぎの糞で、小さいのは子うさぎ、大きいのは親うさぎのだという。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一々鑑定が出来たら肝を潰すであろう。",
              "citation": {
                "source": "お茶の湯満腹談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆、真偽のわからない掛物に対する鑑定家みたいに、いい加減な否定や肯定ばかりしている。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『吉さんはきっとおかみさんを大事にするよ』と、女は女だけの鑑定をしてお常正直なるところを言えばお絹も同意し『そうらしいねエ』と、これもお世辞にあらず。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に、好奇心半分とは言いながら、人物鑑定癖のある秀吉にとっては、実は相当真剣な襲撃でもありました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "贋もの沢山になって、鑑定が大切だが、その鑑定を頼まれて確かなのが自分だって、按摩、（掌に据えて、貫目を計って、釣合を取って、撫でてかぐ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉味噌の鑑定とは、ちくと物が違うでな、幾ら私が捻くっても、どこのものだか当りは着かねえ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それや是やを綜合して考えると、賊はピキシーと云う怪物でも何でも無い、恐く古代の羅馬人であろうと鑑定した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判所は坪内逍遥博士に鑑定を命じ、結局原告の勝訴となる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はおそらく其金を分配して、新宿の妓楼に足を入れたであらうと鑑定したのである。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鑑定は適中して新宿の伊賀屋といふ店へ登楼した一人の客が右の小指に火傷をしたと云つて、相方のおせんと云ふ女郎から山崎の守符を借りたことが判つた。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々の鑑定によれば、女を殺した者がその死骸をうづめる時に銭六文を添へて置いたのであらう。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡っ引の人達の鑑定では、おそらくお角さんをかどわかす手段であったろうというのです。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "元八も道楽者であるだけに、この二人を唯の客ではないらしいと鑑定して、女中にそっとたずねると、彼らは三河町の半七とその子分であるという。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日ではどうだか知りませんが、江戸時代の検視では睡り薬で死んだのを鑑定することは出来なかったようです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私の鑑定では、おまんが持っていたんでしょうね」",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "「口を利いたことはありませんけれど、あの人はなんでも山崎さんというんですよ」　中小姓の山崎平助に相違ないと半七はすぐに鑑定したので、彼はお六に別れてそのあとを追って行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『蛋白石と云うのですが、僕には宝石の鑑定などは少しも出来ないのでしてね。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも話がおかしいというので、駐在所の旦那が色々と取調べたあげく、一週間ばかりしてから郡の医師会長の学士さんに来てもらって、件の白骨を見てもらうと、犬の骨に間違いない……という鑑定だったので又も大評判になった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
