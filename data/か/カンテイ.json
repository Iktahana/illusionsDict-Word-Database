  {
    "uuid": "08d3a916-d22d-5159-b509-15b072fdbd10",
    "entry": "鑑定",
    "reading": {
      "primary": "かんてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
