    "definitions": [
      {
        "index": 1,
        "gloss": "treasure house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大富豪の邸宅には、美術品が所狭しと並べられた金蔵があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の商家では、奥に頑丈な金蔵を設けて貴重品を保管していたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖父の家の蔵は、古い壺や掛け軸がたくさんあって、まるで金蔵のようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その博物館の地下には、世界中の珍しい鉱物が集められた金蔵がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "鈴木町というのは十年ばかり前まで田村さんが代々住んでおられた内久宝寺町の古い町名で、田村さんのお屋敷は代官の金蔵があった跡である。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "志す旅籠屋は、尋ねると直ぐに知れた、有名なもので、柏屋金蔵。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　入交って亭主柏屋金蔵、揉手をしながらさきに挨拶に来た時より、打解けまして馴々しく、「どうも行届きませんで、御粗末様でございます。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言ったばかりで、金蔵はまじりまじり。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると隣家の金蔵であった。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや酒気をおびた金蔵じいは、みょうな笑いようをして自分を見つめながら、「ここにこんな人がいようとは思わねいもんだからははははは。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "トムさんは何だか背中がくすぐつたいやうな、着なれない王様の衣裳を着て、自分の思つてゐた通りのお金蔵のお金を全部街の人々に分けてやつてしまひました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "女すなわち答えていわく、われ能わざるなり、汝もしよく我子の金蔵を示さば、然るのちにすなわちまさに速やかに汝のために作すべし、と。",
              "citation": {
                "source": "易の占いして金取り出だしたること",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "その浪人の申し立てによると、自分は中国なにがし藩の伊沢千右衛門という者で、父の兵太夫は御金蔵番を勤めていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに或る夜、その金蔵を破って金箱をかかえ出した者がある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "郡蔵は自分の不心得を深く詫びて、どうぞ内分にしてくれと頻りに頼むので、兵太夫も承知して、そんならその金箱を元のところへ戻して置けと、二人が金蔵の方へ引っ返そうとする時、郡蔵は不意に兵太夫を斬り倒して、金箱をかかえて逃げてしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると、山路郡蔵は重々の悪人で、お家に取っては金蔵破りの盗賊、千右衛門に取っては親のかたきと云うことになります。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "野口武助の親父は武右衛門といって、屋敷の金蔵番であったのは本当です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "せがれの武助は放蕩者、同藩中の森山郡兵衛と共謀して、自分のおやじが鍵預かりをしている金蔵へ忍び込み、五百両の金をぬすみ出して出奔した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はともかく、千両箱のしまわれてあった金蔵を一見しなくばと、名人はすぐさま人形大尽を案内に立てて、屋の棟つづきの土蔵へやって参りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売がらが商売がらでしたから、そのがんじょうさ、いかめしさというものは説明の必要がないくらいなもので、戸前には特別大の大阪錠をピシリとおろし、見るからに両替屋の金蔵らしい構えでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる西国大名と名のつく大名だけでも、優に百二三十藩くらいはあるに相違ないのであるから、参覲交替の季節が訪れると共に、街道を上下の大名行列が数繁くなるや、忽ち右の「挨拶」が御陣屋の玄関に山をなして、半年とたたぬうちに御金蔵が七戸前程殖えました。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いゝですか、お次は天狗が大小、養漁場の宇佐見金蔵……」　御面師は節をつけて夫々の宛名を私に告げるのであつた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰度、養魚場の金蔵なども柳下の家に集つて酒を飲みながら何かひそ／＼と額をあつめて謀りごとに耽つてゐるところだつた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　御面師は包みを直して幾度も立上つたが、忠吉と金蔵が巧みになだめた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その話を聴くと、私達ばかりが、矢面の犠牲者と見えたが、柳下父子を始めとして、法螺忠や金蔵の悪評は、桜の時分に此処に私達が現はれると直ぐにも聞いたはなしで、彼等が夜歩きや踊り見物に現れるのを見出す者は無かつた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "スツポンといふのは養魚場の宇佐見金蔵の仇名で、彼は自ら空呆けることの巧みさと喰ひついたら容易に離さないといふ執拗振りを誇つてゐた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いいですか、お次は天狗が大小、養魚場の宇佐見金蔵……」　御面師は節をつけてそれぞれの宛名を私に告げるのであった。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、養魚場の金蔵なども柳下の家に集って酒を飲みながら何かひそひそと額をあつめて謀に耽っているところだった。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　御面師は包みを直して幾度も立上ったが、忠吉と金蔵が巧みになだめた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その話を聴くと、私たちばかりが、矢面の犠牲者と見えたが、柳下父子を初めとして、法螺忠や金蔵の悪評は、桜の時分に此処に私たちが現われると直ぐにも聞いたはなしで、彼らが夜歩きや踊り見物に現われるのを見出す者はなかった。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "スッポンというのは養魚場の宇佐見金蔵の渾名で、彼は自ら空呆けることの巧みさと喰いついたら容易に離さないという執拗ぶりを誇っていた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには榎本君と有名な金蔵｜老爺というのが住んでいて、居士は昼間だけ其処に出張して、夜は本宅に寝泊まりしているのであった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間まで始終上履の音をぴしゃぴしゃ云わして歩いていたが、この二三日まるで顔を見せないので、三沢も自分も、どうかしたのかねぐらいは噂し合っていたのである。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
