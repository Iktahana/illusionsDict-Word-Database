        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭の手入れを怠ると、すぐに唐草が生い茂って困るんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "牧草地で唐草を見つけたので、調べてみたらマメ科の植物だと分かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "靴の裏に唐草の種子がたくさんついていて、家の中に持ち込んでしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "唐草の葉はクローバーに似ているが、小さくて可愛らしい花を咲かせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
