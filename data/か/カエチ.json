        "examples": {
          "standard": [
            {
              "text": "区画整理事業に伴い、AさんとBさんの間で土地の替え地が行われることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "隣接する土地の所有者と交渉し、互いの土地の一部を替え地することで双方が使いやすい形に整えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この度の替え地により、長年の懸案であったいびつな土地境界が解消される見込みだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
