[
  {
    "uuid": "bd0d991a-5aa5-5aed-bff2-156d622dcae5",
    "entry": "片割れ",
    "reading": {
      "primary": "かたわれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
