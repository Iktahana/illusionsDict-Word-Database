    "definitions": [
      {
        "index": 1,
        "gloss": "temple dedicated to Kannon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
