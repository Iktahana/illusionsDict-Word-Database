[
  {
    "uuid": "fc1c9f2d-e60a-5eef-9682-124d900107a9",
    "entry": "金ずくで",
    "reading": {
      "primary": "かねずくで",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
