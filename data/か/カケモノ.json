    "definitions": [
      {
        "index": 1,
        "gloss": "hanging scroll",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "床の間に季節の絵が描かれた掛け物を飾った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "美術館では、歴史ある書道の掛け物が鑑賞できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お茶室にはシンプルな掛け物が似合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "床の間に山水花鳥の掛け物をかけるのもまたそのバリアチオンと考えられなくもない。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "千駄木時代の絵はがきのほかにはこれが唯一の形見になったのであったが、先生死後に絵の掛け物を一幅御遺族から頂戴した。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸末期より明治時代にわたる劇壇大道具の名人にて、新しき仕掛け物はその工夫に成るもの多し。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "真中に鉄色のふっくりした座布団が二つ、金蒔絵をした桐の丸胴の火鉢、床の間には白｜孔雀の掛け物と大きな白｜牡丹の花活けがしてあって、丸い青銅の電気ストーブが私の背後に真赤になっていた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁のところどころには、偶然ここで落ち合ったというような掛け物が幾つもかけてある。",
              "citation": {
                "source": "普請中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」義雄は思はずまた妻にふり向いて、「掛け物一つ買へないほど貧乏してきた、さ、然しまた面白いこともあつた、さ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "話題は大抵、和尚の浮気で、やれどこの細君と関係しているとか、やれ小学校の女教員に、いくらいくらする掛け物をやったとか、一晩中そんな類の話を、幾晩も幾晩も繰り返していた。",
              "citation": {
                "source": "再度生老人",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の掛け物もこれはよしてもらって、大木さんから子規先生の物を貸りてきてかけよう。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "在来の怪談劇の狙い所は、事件そのものの怪奇と云うことよりも、早替りとか仕掛け物とかいう一種のケレンにあったらしい。",
              "citation": {
                "source": "怪談劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中部屋を除いた五つの部屋はいずれもなげし付きになって、三つまでは床の間さえあるのに、どうして集めたものかとにかく掛け物なり置き物なりがちゃんと飾られていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま手もとに集めている書画の掛け物はおおかた二、三百幅もあるんでしょうが、一本だっててめえが金を出して買った品はねえんですよ」「では、いずれも盗みとった品物じゃと申すのか」「いいえ、もっと根のふけえやり口で巻きあげるんですがね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "笹村は近ごろの増築らしいその部屋の壁にかかった、正宗やサイダの広告、床の間の掛け物や、瓶に※した彼岸桜などを眺めていたが、するうちにいいつけたものが、女中の手で運ばれた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の広い土間から、裏二階の座敷へ案内された笹村は、落着きもなく手擦り際へ出て庭を眺めたり、額や掛け物を見つめたりしていたが、階下に飼ってある小禽の幽かな啼き声が、侘しげに聞えて来た。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わたしだツて」と、女は答へる、「お嫁に行つて、人の細君になる時がありますから、ね、」　元祿女郎を書いた掛け物がかかつてゐる半間の床の間には、女學世界、婦人世界などが積み重ねてある。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "義雄が初めて面會した時、奧から出して來て見せた物徂徠の掛け物で、この支那崇拜家が例の變挺な宇畫をひねつてあるのも、一方の壁に釣してある。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍は万事を賭して、この宝を救い出そうと決心して、燃える御殿に飛び入って、例の掛け物をつかんだ、が、見ればはや、火炎にさえぎられて、のがれる道はなかったのである。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の間には掛け物がかかっている、それは昔ある僧の手になった不思議な書であって浮世のはかなさをかいたものである。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "利休は例の掛け物とともにいろいろな品を客の前におく。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の高い天井の低い割には、かなりに明るい六畳の一間で、申しわけのような床の間もあって、申しわけのような掛け物もかかって、お誂えの蝋石の玉がメリンスの蓐に飾られてある。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度雨が降り出したので温泉宿｜千明の番傘をさして町へ出掛け物聞橋の辺まで歩いて見た。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛けてある掛け物も違うようであった。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その喜撰のお掛け物は」「お父上からゆずられたものだ。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは大変寒い日で、彼等はやがて焚火をし、「やあここに掛け物がある」「やあここにも掛け物がある」「一つ二つ……五つ六つ、六つも掛け物落ってるだあよ」「何んて穢ねえ掛け物だあ。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "名ばかりの兄弟「蚤ばかりではない、生きとし生けるもの、何んであろうと可愛いものでござる」　戸外の日光が部屋の中へ射し込み、古びた畳、古びた襖、黒光っている柱などを照らし、みすぼらしいながらも清掃されている様子を床の間に置いてある花瓶の花や、掛け物と一緒に浮き出させていた。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道中彼はあぶれものの雲助や、同じくあぶれものの馬子の類を集め、それとなくしばしば民弥と梶子をとらえ、喧嘩を仕掛け物云いをつけたが、先方が相手にしなかったので、事を起こすことが出来なかった。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く海は暗くなりそのほのじろい波がしらだけ一列、何かけもののやうに見えたのだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く海は暗くなりそのほのじろい波がしらだけ一列、何かけもののように見えたのだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何枚も重ねて着た上に、何かけものの皮を鞣して裏打ちにした袖なしを着てゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の入口から入ったところに、長い幅ひろい机をおいた裁縫室があって、窓の下にオルガンがあり、壁に音階表がかけもののように下っていた。",
              "citation": {
                "source": "藤棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘレネは美しさにおいては、ヴィナスのようにも美しかったのであろうが、社会的な存在としてホーマーが彼女を描いているところをみれば、美しきヘレネは当時の支配者たちの、闘争における一人の「かけもの」のような立場におかれている。",
              "citation": {
                "source": "女性の歴史",
                "author": "――文学にそって――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
