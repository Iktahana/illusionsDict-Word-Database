          "standard": [
            {
              "text": "お茶請けに、かわいらしい形の掛け物が出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "七五三のお祝いに、鶴亀の形をした掛け物を贈った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "京都のお土産に、金平糖のような掛け物を買ってきた。",
