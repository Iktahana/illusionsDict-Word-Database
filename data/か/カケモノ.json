  {
    "uuid": "b7b56e94-531d-5f98-9c07-b3339630dc86",
    "entry": "賭け物",
    "reading": {
      "primary": "かけもの",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "友人の結婚式の二次会で、ちょっとした賭け物を用意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "競馬では、馬券が賭け物となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「よし、このコインが裏か表か、賭け物だ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼女を賭け物とさえ見なしていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方には、別にまた自分の女房らしいのを賭け物に引据えて置いて、しきりに丁半を争う二人組もある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋する女性を、賭け物にするなんて……」と、気の優しい将頼すら、義憤をもらして、「――それで、野霜の伏見掾は、娘を、そのどっちかへ、与えるつもりなのでしょうか」「いや、あの翁は、職は具足師でも、心は硬骨だ。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将と将との一騎討は、賭け物である。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂上から――坂下から――閃々と勝助の身ひとつにつめよる無数の槍は、その馬印と、勝家なりと信ずる彼の首とを、賭け物のように、「われこそ獲ん」　と、競い合った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "花競べ、歌競べ、虫競べなどの遊戯にならって、十種二十種の国々の銘茶をそろえ、香気や色味をのみくらべるのを“闘茶”といい、その闘茶にはまた、莫大な賭け物をかけたりする婆娑羅な人々もあるとは――高氏も、聞きおよんでいたことだった。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "着かざッた男女は遊山気分で矢来にむらがり、飲んだり唄ったり、また大びらに銭や賭け物を賭け、競馬のような声援や雑鬧をみせるのだった。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "――勝てば、執権高時の賞辞や、莫大な“賭け物”を一挙につかむ。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、闘犬そのものに熱している者は少なく、多くは、何か“賭け物”を賭けているらしいことが分る。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く海は暗くなりそのほのじろい波がしらだけ一列、何かけもののやうに見えたのだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く海は暗くなりそのほのじろい波がしらだけ一列、何かけもののように見えたのだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何枚も重ねて着た上に、何かけものの皮を鞣して裏打ちにした袖なしを着てゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の入口から入ったところに、長い幅ひろい机をおいた裁縫室があって、窓の下にオルガンがあり、壁に音階表がかけもののように下っていた。",
              "citation": {
                "source": "藤棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘレネは美しさにおいては、ヴィナスのようにも美しかったのであろうが、社会的な存在としてホーマーが彼女を描いているところをみれば、美しきヘレネは当時の支配者たちの、闘争における一人の「かけもの」のような立場におかれている。",
              "citation": {
                "source": "女性の歴史",
                "author": "――文学にそって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "シーツも枕もかけものも、みんなそっくりそのまま入れたままになっています。",
              "citation": {
                "source": "よろこびの挨拶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　狹い部屋のなかを、洋服の長い脚で歩き廻りながら、床の間の松に鶴のかけものを、わざと叮嚀に見たり、縁側に出て川の景色を眺めたりした。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "客間へ入ると、sofa の赤い縞の布の上に軽い黄色絹のかけもの、それよりうすい黄色の毛糸の室着をつけた夫人横になって居る。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとややはなれて雪の中でなにかけものが転がり回ったようなあとがあった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "また勝川春章の至れるをまるで我々が時々欧羅巴の画人を羨望さへ籠めた子供つぽい感嘆を交へて話すと同じやうに、その春章の女姿のかけものをそここゝと指されながら、居ずまひさへかまはずに乗り出して、話して下すつた。",
              "citation": {
                "source": "鏑木さん雑感",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代風の洋式客間で、明快な色調の広い部屋だのに、一方の壁に床の間めいた高いところがこしらえてあって、そこに日本画のかけものと、紫檀の板の上に香炉がおかれている。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は横たわっているベッドの白いかけものの下でかすかに身じろぎをした。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いそぎ足に伸子のベッドのわきへよって来て、「さようなら、おやすみなさい」　右手で伸子のかけものを直しながら、婚約指環をはめた方の手で伸子の手をにぎってふった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見当のつかないまま伸子は、「スカジーチェ（おきかせなさい）」と云って、両方の手を、半身おきあがっているかけものの上においた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は、ベッドのかけものの上へ出している両手の間で電報をひろげたり畳んだりしながら思いめぐらした。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　握りあわせた両手をすとんとベッドのかけものの上へうちおろしながら告げた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は思わずかけものの下で少し体を横へずらせた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう大柄ではないが重い彼女の体と、伸子の体ごしにつっぱった彼女の手との間で伸子のベッドのかけものは息ぐるしく伸子の胸の上でひきつめられた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台のかけものの上にのばしている手のところに、二つに裂かれた手紙がある。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台にふる紙雪のような手紙のきれは、伸子の手に掬われ、指の間からチラチラと寝台のかけものの上におとされる。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台のかけものの上で掬ってはおとしていた手紙のきれを、伸子は少しずつつまんで傍の封筒へいれて行った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
