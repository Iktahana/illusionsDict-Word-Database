    "definitions": [
      {
        "index": 1,
        "gloss": "photographer, usually an amateur, who likes to take pictures of models and presenter ladies in exhibitions",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あー、またカメコたちがモデルの周りに壁を作っちゃってて、全然前が見えないよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最新の望遠レンズを構えたカメコが、モーターショーの華やかな舞台を真剣な表情で切り取る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よし、今の表情は完璧だ！」とカメコが満足げにカメラの液晶を確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は有名なカメコで、撮影したコスプレイヤーの写真はいつもSNSで何万回も拡散される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "カメコオバサンハ　マルコオバサンノ　ウチヘ、ノソリノソリト　ハツテ　ユキマシタ。",
              "citation": {
                "source": "オマツリ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルコオバサンハ　セツカク　カメコオバサンガ　キタノダカラ、オキヤクサマノ　マヘデ　ネムツタラ　タイヘン　シツレイダ　トオモヒマシタ。",
              "citation": {
                "source": "オマツリ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　カメコオバサンハ　オホキナ　アクビヲ　カミコロシナガラ、イヒマシタ。",
              "citation": {
                "source": "オマツリ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　カメコオバサンガ　イヒマシタ。",
              "citation": {
                "source": "オマツリ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　カメコオバサンガ「イイエ――ヤツパリ――ハデ――デスワ。",
              "citation": {
                "source": "オマツリ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　マルコオバサンガ「マア――ソンナ――コト――」　カメコオバサンガ「ダツテ――イイエ――ヤツパリ――」　ソシテ　フタリトモ、コヱガ　ダンダン　チヒサクナリ、クチガマワラナクナリ、ヤガテ　グツスリ　ネムリコンデ　シマヒマシタ。",
              "citation": {
                "source": "オマツリ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カメノ　カメコオバサンハ、キンジヨノ　マルコオバサンノウチヘ、ノソリノソリト　ハツテユキマシタ。",
              "citation": {
                "source": "カメサン　ノ　サウダン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソノウチ、カメコオバサンモ　トロトロト　マブタガ　オモクナリマシタ。",
              "citation": {
                "source": "カメサン　ノ　サウダン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カメコオバサンハ　オホキナ　アクビヲ　カミコロシナガラ、「デモネエ、ワタクシ　スコシ　ハデスギヤシナイカト　オモフノデスケレド。",
              "citation": {
                "source": "カメサン　ノ　サウダン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ト　イヒマスト　カメコオバサンハ「イイエ、ハデデスワ。",
              "citation": {
                "source": "カメサン　ノ　サウダン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ト　イフト　カメコオバサンガ「イイエ――ヤツパリ――ハデ――デスワ。",
              "citation": {
                "source": "カメサン　ノ　サウダン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　カメコオバサンガ「ダツテ――イイエ――ヤツパリ、ムニヤ、ムニヤ――。",
              "citation": {
                "source": "カメサン　ノ　サウダン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレカラ　マイニチノヤウニ　カメコオバサンハ　マルコオバサンノ　トコロヘ　サウダンニ　ユキマス。",
              "citation": {
                "source": "カメサン　ノ　サウダン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
