        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "厚手のカルトンを使えば、しっかりとした作りの箱ができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この画材店では、様々な厚さのカルトンを切り売りしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "カルトンをカットして、パズルの土台を作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "模型製作で、カルトンを骨組みとして使うことがあります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それは、オールドカルトンとかニューカルトンとかカフェマキスィムとか云ったたぐいの家々と共に上海一流の酒樓であるところの、「上海の赤風車亭」と呼ぶ家の地下室にあった倶楽部なのです。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、あんまり打ち沈んでいる僕の様子を見かねたのでしょう、マドレエヌは僕にむかって、今宵ニューカルトンの仮装舞踏会に行こうと云い出しました。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにニューカルトンの踊場の豪勢さは噂でこそ兼々聞いてもいたが、ついぞ未だ一度も行ってみたことがなかったので日本への土産話に見ておきたいとも思ったのでした。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故ならば――彼等はつい最近までニューカルトンの舞踏会の夜殺した郁少年を全く僕だと信じて疑わなかったのです。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには扉の図案をも添へ、カルトンの体裁をも考へた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルトンを抱へこんで江川の玉乘の二階に、ドガ氣取りで構へ込んで、毎日やつてゐたこともあつた。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これからカルトンまで歩いていこう。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで悪病みたいに静物にとりつかれて――さう開きなほると、寒子は方向転換に、毎日カルトンをさげてセーヌの石畳の上にスケッチに出かけた。",
              "citation": {
                "source": "瑪瑙盤",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "両足を男の子のやうにふんばらして、カルトンを持ちあげた。",
              "citation": {
                "source": "瑪瑙盤",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはきっとカルトン・カッフェへ、舞蹈に行っていたのに違いない。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャモニー　Chamonix　雪車に曳かれて着いた宿は、停車場から程遠からぬカルトン・ホテル 〔Carlton Ho^tel〕 で、まだ新築の奇麗な家であった。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンのサボイ・ホテルやカルトンで腕を揮っていた頃には、どれほどの喰いしん坊がはるばる海を渡って彼の皿を求めに来たか知れない。",
              "citation": {
                "source": "世界の「料理王逝く」ということから",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "但上海には是以外に「ブリュー・バード」などというダンスホールがあり、雄大そのものと噂に高い「カルトン」ダンスホール、等々々、沢山あるので、そういうものを全部見なければ、上海のダンス界を論じることは不可能であるとは云えようがね。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "マットレスを積みあげた正方形のデヴァン・リのそばに大きな夜卓があって、その上にカルトンの笠をつけたスタンドランプが置いてある。",
              "citation": {
                "source": "雪間",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "副総督チェースの「覚書」によると、それまではカルトンという英国人の園丁が密偵の役をし、ナポレオンの毎日の行動をハドソン・ロオに報告していたが、ナポレオンがカルトンを解雇してしまったので、まるっきり手がかりがなくなってしまった。",
              "citation": {
                "source": "フランス伯Ｎ・Ｂ",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "○カルトンの夜光時計が、Ｐ、Ｍ、Ｑ。",
              "citation": {
                "source": "上海の絵本",
                "author": "三岸好太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
