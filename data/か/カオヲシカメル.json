        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供は見慣れない苦い野菜を味見して、顔をしかめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うわ、この匂いは何？」彼女は顔をしかめて言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "肘をぶつけて、彼は痛みに顔をしかめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "散らかった机を見て、先生は不満そうに顔をしかめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "けれども人は、その十分の一以上の発表に対しては、必ず顔をしかめる。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは顔をしかめる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）米良は昨日に変るリー・シー・ツワンの偶像に対する名誉心を見て顔をしかめるのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二本では足りないので、おかみさんの義侠心に訴えて、さらに一本を懇願しても、顔をしかめるばかりで相手にしない。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私は顔をしかめる。",
              "citation": {
                "source": "秋風記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗汗の洪水の中で、眼をさまして家人の、そのような芝居に顔をしかめる。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして、あんなに顔をしかめるの？",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、老人は顔をしかめる。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで腕斬りが三年つづく事になるのであるから、御幣かつぎの者でなくても、又かと顔をしかめるのが人情である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "）長吉　（飲まうとしてわざと顔をしかめる。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はこれが解らんですか」　田中は低頭いて顔をしかめると思ったら、涙がはらはらとその頬を伝った。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "十右衛　（顔をしかめる。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人たら、甘い時にはあんな風に顔をしかめる習慣かしらと思ったけれど、そんなことないわねえ」　傷ついた体を敵の手にゆだねていなければならぬ杉田の胸中がわからないのか、看護婦たちは勝手なことばかりしゃべっている。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "女学校の教師をしてゐながら、お弟子の娘と思ひ合つたといふと、日本の教育者達は変に顔をしかめるかも知れないが、なに生徒みんなを愛する事が出来なければ、そのなかのたつた一人を愛したつて差支ないので、クレマンソウはとうとその娘と結婚をして仏蘭西へ連れてかへつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本画家をすべて芸術家扱ひにしたら、芸術の神様は美しい顔をしかめるかも知れないが、でも、その日本画家にそれぞれ悪魔がついてゐる事だけは真実である。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「最高学府の生徒はレディに対してはグレースフリーでなくてはならぬ」　かるた会の席で娘たちに失礼なことを言うものがあると、堀野が一番に顔をしかめるようになった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んじまってよ」「お暇いただいて、呑気に養生するわ」　志野は、顔をしかめるようにして尋ねた。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっちゃんが注射すると、痛い、と太宰は顔をしかめる。",
              "citation": {
                "source": "太宰治との一日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　乞食は顔をしかめるようにした。",
              "citation": {
                "source": "保吉の手帳から",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "無頼の力で、人が顔をしかめるやうなことを平気でどん／＼書いてゐます。",
              "citation": {
                "source": "無頼の徒の芸術",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもあのヱヴェレストの頂上だけは、見上げたゞけでも目が眩んで、何度もそこまで飛んで見ようとしては、半分もゆかないうちに、疲れてしまつたラランはゾグゾクしながら、その度に羽を縮めて残念さうに顔をしかめるのだつた。",
              "citation": {
                "source": "火を喰つた鴉",
                "author": "逸見猶吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあ、土匪の斬罪か何か見物でも出来りゃ格別だが、………」　僕はこう答えながら、内心長沙の人譚永年の顔をしかめるのを予想していた。",
              "citation": {
                "source": "湖南の扇",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃあ皆さんの御座興に、僕がちょっと余興をやらせてもらいます」　帆村の申出に、一座には顔をしかめる者もあったが、長谷戸検事はすぐ警官を手招きして、亀之介をここへ連れてくるように命じた。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち幽霊にあったら、幽霊の浮力を観察すればいいんだし、鬼火が出れば、それは空中から酸素をとって燃えているにちがいないんだし、こういう風に、おちついて幽霊をだんだん観察していくと、幽霊がどんなことをする能力があるかが分る」「むずかしいね」　二宮少年は顔をしかめる。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "患者達がぞろぞろと集まつて来るのを見ると、名士達は誰も同じ恰好に顔をしかめる。",
              "citation": {
                "source": "癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹痛が来ても、顔をしかめるだけで我慢し、すすんで手足をさすらせることもなかった。",
              "citation": {
                "source": "父の形見",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔をしかめる者、ぺっぺっと唾を吐く者。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が顔をしかめると、相手も顔をしかめる。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
