        "examples": {
          "standard": [
            {
              "text": "図鑑で調べたところ、公園にあるあの木はカバノキ科のハンノキという種類だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "カバノキ科の植物は花粉症の原因になることもあるため、春先には注意が必要な人も多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アルダー材として家具に使われる木材も、実はカバノキ科の樹木から取れるものが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "森林公園の散策路には、カバノキ科の様々な樹木が植えられており、名札を読みながら歩くのが楽しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ハリすなわちハンノキはカバノキ科の落葉樹で、山間の湿りたる地を好んで生じ処々に林を成している。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
