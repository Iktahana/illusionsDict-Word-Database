        "examples": {
          "standard": [
            {
              "text": "高校生の頃、漢文の授業で先生に勧められて漢和辞典を使い始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古い文献を読むために、分厚い漢和辞典を引くのが日課になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この単語の意味が分からない？ほら、漢和辞典で調べてごらん。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "資料提供に際しては、「どんな外字が、どの本に収録されているなんという作品の何ページ、何行目に出てくるか」を確認し、「その字が、どの漢和辞典のどの項目で確認できるか」という情報をそえることを求められた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の教えた所によれば、古い一冊の玉篇の外に漢和辞典を買うことさえ、やはり「奢侈文弱」だった！",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の教へた所によれば、古い一冊の玉篇の外に漢和辞典を買ふことさへ、やはり「奢侈文弱」だつた！",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "―或精神的風景画―",
                "note": "青空文庫"
              }
            }
          ]
        }
