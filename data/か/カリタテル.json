[
  {
    "uuid": "679462b6-96e0-5289-a967-1ec9690361c8",
    "entry": "駆り立てる",
    "reading": {
      "primary": "かりたてる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
