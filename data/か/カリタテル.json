    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to flush out (a hare, fox, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "猟犬がけたたましく吠えながら、茂みに隠れていた一羽のキジを空へと駆り立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "勢子たちが一斉に鳴り物を鳴らし、獲物のイノシシを逃げ場のない谷底へ駆り立てる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よし、そこを棒で叩いて！ 隠れているウサギを広い場所に駆り立てるんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "枯れ草を足でガサガサとかき回すと、驚いたバッタが四方八方へ駆り立てられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そのむずかしい役目を勤めてくれた医師が帰って後の、お前たちの母上の顔を見た私の記憶は一生涯私を駆り立てるだろう。",
              "citation": {
                "source": "小さき者へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョア・地主の利益のために、大衆を戦争に駆り立てる軍事的・警察的・絶対主義的体制が強められたことは、明らかである。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして約半日｜闇黒に慣らしたのち、やにわに戸をあけて「運命の戦場」へ駆り立てるのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、これには単なる探険心以上に、僕を駆り立てる理由があったのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬ごもりの期間にどうやら継続的に文学の仕事にたずさわることが出来るとして、ずっと辺鄙な地方での生活は文化的な雰囲気というものに欠けていて、その点でのいい刺戟を求める心持の激しさは、やはり東京へ、という思いに駆り立てる。",
              "citation": {
                "source": "文学と地方性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただどうもあそこへ行くのがいやでならんというのは、あの町へ行くときは旦那を馬車に乗っけて行くのでな、馭者というものが旦那の言いつけでわしらを駆り立てるのじゃ。",
              "citation": {
                "source": "夢がたり",
                "author": "TO, CHEVO NE BYLO",
                "note": "青空文庫"
              }
            },
            {
              "text": "師匠のその潔癖さは、そのまま徒弟を孚むうえでの鞭ともなり、ただひたむきにその道へと駆り立てる。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして意外な方向に彼を駆り立てる。",
              "citation": {
                "source": "意欲の窒息",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当の意欲を窒息さして現実から遊離した想念のうちに人を駆り立てる神経衰弱は、社会の各方面に、各種のサラヴァンを作り出している。",
              "citation": {
                "source": "意欲の窒息",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "予想されるこれからの時代は、或は人間を精神的狂乱に駆り立てるかも知れない。",
              "citation": {
                "source": "文学に於ける構想力",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "行動へと駆り立てる何か盲目的な本能から、彼は周りの下生えを掻き分けて、もっと開けた場所に出た――右手には小川、左手にはまばらに木が生えたなだらかに上る傾斜があった。",
              "citation": {
                "source": "チカモーガ",
                "author": "Ａ. ビアス　A.Bierce",
                "note": "青空文庫"
              }
            },
            {
              "text": "個性ある俳優を使はずに、人形なり、またその名に甘んずる「奴隷」を駆り立てるがよい。",
              "citation": {
                "source": "演出について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　白い花車な指の又に残された凝血が女を猟に駆り立てるのだらうか？",
              "citation": {
                "source": "麓",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を考えていいか分らなかったが、頭の中に雑多な幻影が立ち罩めて、それが酔のために、非常に眼まぐるしく回転して、自分を駆り立てるがようだった。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その落胆と焦躁は、文学と絶縁せずにゐられぬ思ひに、人を駆り立てるものである。",
              "citation": {
                "source": "囲碁修業",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "みずから満ち足りて過去をふりかえり、そこから新しい希望のみこみを立てる、あの良心の清らかさのかわりに、言語に絶する激しい苦痛の地獄へと私を駆り立てる悔恨と罪悪感に捉われたのだ。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "実戦を知らぬ将校が自己の名誉心を満足さすために、何も知らない部下を叱咤して戦場に駆り立てる傾向がありはしないでしょうか。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "が真実への熱望と不撓の意志とが、前へ前へと駆り立てる。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "主観はどうでも、結果として国臣も雲浜同様、諸地方産商業家をより広い組織とより激しい政治戦線に、やがて駆り立てることとなった。",
              "citation": {
                "source": "志士と経済",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さて、ああいう立て札を立てて、吉野十八郷の者どもに、御首級掻きをそそのかし、裏手からわれらがそれを駆り立てる。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして畑の作物は掠み取られ、いやがうえに村人の憤りを駆り立てることになったのである。",
              "citation": {
                "source": "野に臥す者",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺たちをおびやかし駆り立てる亡霊だ。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは小ブルジョアの生活の窮迫が一方に於ては小ブルジョアを積極的なファッショ運動へと駆り立てる。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神国防動員は青少年（海軍も青年訓練所を通じて海軍思想の普及を企てる）、学生（「愛国学生連盟」の閲兵式、七大学の「国防研究会」の結成）、女性（「大日本国防婦人会」）、小商人、その他各方面の軽頭分子を駆り立てることに現に成功している。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には自分が夢を見ているのでも幻覚を見ているのでもないという不愉快な程に確かな感覚があり、まさにこの感じが――自らの経験が齎すであろう驚くべき結論からみて――この記録の続行を駆り立てるのだ。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に述べるように政治の手段として「神話」や「ユトーピア」が重大な役割を演ずるけれども、それは初めから実現の不可能なその内容が問題なのではなく、神話やユトーピアが人間の感情を刺戟して、現実の行動に駆り立てる力がたいせつなので、政治にとって問題となるのはあくまでその現実の力なのである。",
              "citation": {
                "source": "政治学入門",
                "author": "矢部貞治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神話は端的に大衆の激情に訴えて、直ちに行動と闘争に駆り立てる力があればよいので、それが客観的な真理に合うとか、実現の可能性があるとかいうことは問題ではない。",
              "citation": {
                "source": "政治学入門",
                "author": "矢部貞治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神話を高唱し、駆使し、その心理的効果を利用するには、冷徹な知性と打算がなければならぬけれども、知性や打算だけでは、大衆を魅了して行動に駆り立てることはできない。",
              "citation": {
                "source": "政治学入門",
                "author": "矢部貞治",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽、美術、文学、芸能に、子供を無暗と駆り立てる近頃の親とは正反対だったのだ。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの経験は人々を行動に駆り立てることもあろう。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to drive (cattle, sheep, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "牧童が馬を巧みに操り、群れからはぐれそうになった子牛を中央へ駆り立てる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「さあ行け！ 日が暮れる前に、すべての羊たちを山の上の牧舎へ駆り立てるんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "凍てつく吹雪の中、トナカイの群れを次の給餌場へと必死の思いで駆り立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "広大な平原でカウボーイたちが、砂煙を上げながら数千頭の荒駒を西へと駆り立てる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "to drive (to do)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「自分でも説明できないけど、何か目に見えない力が私をこの無謀な挑戦へと駆り立てたの」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "激しい競争心が常に彼を駆り立て、周囲が驚くほどのハードなトレーニングを強いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ふとした瞬間に湧き上がる焦燥感が、作家を深夜の執筆作業へと駆り立てる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一体何が彼をそこまで駆り立てるんだろう。あの目標への執着心は並大抵じゃないよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
    ],
