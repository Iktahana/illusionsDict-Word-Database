        "examples": {
          "standard": [
            {
              "text": "刀鍛冶は精神を統一し、不純物を叩き出すように一心不乱に槌を振るって刀を打つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今日こそは、自分の生涯で最高と言える一振りの刀を打ってみせるぞ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鋼を幾度も折り返して鍛錬することで、折れず、曲がらず、よく切れる刀を打つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "当時の刀鍛冶としても、老人は一番年長者だそうでしたが、いい刀を打つものがだんだんなくなりますから、今のうちに学校を造っておきたい、そして刀鍛冶を育てたいとの話があったのも、そこでした。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "――刀を打つなら、御先祖様のような、お心になって打て。",
              "citation": {
                "source": "山浦清麿",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
