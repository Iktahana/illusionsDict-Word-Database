    "definitions": [
      {
        "index": 1,
        "gloss": "large sketchbook used during TV filming to notify the cast of special stage direction, relay messages, etc.",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "司会者は、カンペに書かれた指示をちらりと確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大物俳優がセリフを忘れた際、スタッフが慌ててカンペを出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歌番組で歌詞を忘れないよう、ステージ袖にカンペが用意されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「はい、カメラ目線で！…とカンペが出てるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "此智恵鏨を読みながら、私は十八世紀の啓蒙家カンペの修養書「テオフロン」の事を想出したが、之に就ては嘗て書いたこともあり、又紙数も尽きたから今は触れない事にして、ただ所蔵書の吹聴をすることに止めて置く。",
              "citation": {
                "source": "春水と三馬",
                "author": "桑木厳翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月八日　火　晴　カンペイ式にＡの兄、六時頃から出かけ、昼すぎ頃までかかって見物。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンペイ式や何かある。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "村田さんの手紙によりますと、年恰好から云ってちょうど美津子ぐらいの、大変美しいお嬢さんだそうですから、私もお点を甘くしてあげたいのですが、復員殺人事件の審査はゲンカクで、カンペキな正解でなければ賞金はあげられませんから、その節はウラミをよせないようにたのみます。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしの　なは　ラザロ・カンペオッチ。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば新聞社自身が自発的に新聞紙上で行なう広義のプレスカンペーンなどは一種の宣伝であるが、一般に宣伝は一種の広告とも見做されねばならぬ。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、カルパントラスの者、ポントアーズの者、カンペル・コランタンの者。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンペラ門兵衛ハ特ニ浅草ノ宮戸座カラ中村勘五郎ガ買ワレテ来テ演ジタガ、コレガ妙ニ印象ニ残ッテイル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンペールに生まれナントで大人になり医師である伯父と住んでいた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "crib sheet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "試験中、隣の席の生徒がカンペを隠し持っているのを見つけてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "結局、バレて没収されたカンペは、ほとんど使われることはなかったらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「おい、今日のテスト、カンペ作ってきた？」と友人が小声で尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カンペを用意する手間を考えたら、真面目に勉強した方が早かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
