        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "神に誓って、私はその場にいませんでした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「神に誓って、あなたを裏切るようなことはしない」と彼は固く言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "神に誓って言うが、これは本当に私の正直な気持ちだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "神に誓って、この計画は成功させます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "いいか、あの人に、こう言ってくれ、レヤチーズの妹を、なぐさみものにしたならば、どいつこいつの容赦は無い、どのようなお身分の方であっても生かして置けぬと、レヤチーズが鬼神に誓って言っていました、とそう伝えてくれ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、新子の面倒を見ていて、いつかどうしようという野心は、神に誓ってないと前川は自分で思っている。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "神に誓って、みなさん、偽りはひとつもねえ。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "お夏は神に誓って、戯にもかかる挙動をすべき身ではないのであった。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど私は神に誓って言う、先生を前に置いて言う、三年は芳を私から進んで嫁にやるようなことはせんじゃ。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "我ら十七名の会員はこの問答の真なりしことを上天の神に誓って保証せんとす。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "アレキセエ」法官「その三人の友達は、イサクが殺された其時刻にお前が室内に居たということを、お前の為めに神に誓って屹度証明するだろうな？",
              "citation": {
                "source": "死の復讐",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「アッタスン、僕は神に誓って、」と博士は大声で言った。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神に誓って、もう二度とあの男には会わないつもりだよ。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして誰れも機上の情況を見ていた者はなかったのだ」「でも私は神に誓って座席から一寸も離れはしなかったのです」　池内は狼狽した。",
              "citation": {
                "source": "旅客機事件",
                "author": "大庭武年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僭越ながらも自ら神命を受けたりと称し、神に誓って国王の位に即くものが、かかる非人道的の行為を為すを忍ぶとは心得ぬ。",
              "citation": {
                "source": "永久平和の先決問題",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はトリガーセン島の支配者だし、神に誓って、全世界の女性に申し訳ないが、地位に留まる」　部屋中に声が響き、昔の狂信的な激しさで目が輝き、けちな専制君主が目覚めた。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "神に誓って否と言います。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある老年の検事長は、血色の法服のうちに老いて白髪となり、血に浸った論告のパンを生涯かじってきた男だったが、突然哀れっぽい様子をして、神に誓って断頭台を憤る旨を述べた。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神に誓って、違う。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにをするつもりだ」「いますぐわたくしを放さないと、神に誓って、真相をぶちまけます」第七章　リッチフォードが仁王立ち、激怒してぶるぶる震えている。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "神に誓って、あなたは女王になるべく生まれ、最高の美貌、善意、優しさを持ち、幸運・歓喜の国民を統治します。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
