[
  {
    "uuid": "98a160c1-70db-51c8-bf96-193fd148d771",
    "entry": "管轄",
    "reading": {
      "primary": "かんかつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
