        "examples": {
          "standard": [
            {
              "text": "会社の倒産後、選任された管財人が滞りなく資産の処分を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遺産相続の問題がこじれ、裁判所から管財人が指名される事態となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "不動産の管理が適切に行われず、最終的に管財人の監督下に入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "何でも、連盟の欠員を埋める人間が足りないらしくて、遺産管財人が宙に浮いた金をどうしていいか途方に暮れているらしいそうですぜ。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "てなもんで、死んだときに莫大な遺産を管財人に預けて、その利子を使って、自分と同じ色の髪を持つ男が楽に暮らせるように金を分配してくれ、と死に遺したらしいんです。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "管財人がつかまえることのできなかった一羽の黒い雛鶏――夜のように黒くそして沈黙で、のどもならさないのでただ狐の餌食になるのを待つばかりなのが、それでもまだ隣りの部屋にもぐりこんでいた。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "管財人に渡すまで、そのままにしておきます」「仕方ない。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
