        "index": 1,
        "gloss": "kanji \"metal\" or \"gold\" radical at left",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
