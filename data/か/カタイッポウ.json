[
  {
    "uuid": "22060227-4572-5a58-b3cc-5e58d0d0261b",
    "entry": "片一方",
    "reading": {
      "primary": "かたいっぽう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
