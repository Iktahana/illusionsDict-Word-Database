    "definitions": [
      {
        "index": 1,
        "gloss": "to write down",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "電車の中でふと思いついた企画のアイディアを、忘れないうちにスマホのメモ帳に書き留めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "おばあちゃんが教えてくれた秘伝のタレの分量を、急いでカレンダーの裏に書き留める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "旅先で見つけた美しい景色の描写を、日記帳の端にそっと書き留めておいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一同は小部屋のなかへ通され、主任の警部が捕らえた男の名と、犯した殺人の被害者らの名を書き留める。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ホームズは書き留める。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな物の中から何かしら見出しては、例の紺珠に書き留めるのである。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜は相宿の人々と炉を囲んで、見るもの聞くもの一々日記帳に書き留めるので、警察の探索方と誤られて、非常に丁寧に取り扱われたなどという※話がある。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ホームズは書き留めると、「もう一つ、質問がございます。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しながら、傳記者が書き留めるか否かといふことから獨立に行はれる客觀的な出來事の見地からするならば、「歴史無き」如何なる民族も存しない。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "航海日誌を書く船員が端から其号令を書き留める。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏の長者としての勢力によつて、大中臣――藤原氏が分れてから、中臣は、大中臣と称した――に伝つてゐた神秘な寿詞をも、書き留めることが出来たのである。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも丹念に書き留めるくせのある男だった。",
              "citation": {
                "source": "吹雪のユンクフラウ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "参詣の子供たちの氏名を書き留めるのであろう。",
              "citation": {
                "source": "母親",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへ行くにも矢立てを腰にさして胸に浮かぶ発句を書き留めることを忘れないようなところは、風狂を生命とする奇人伝中の人である。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まさかいち／＼書き留めるわけにも行かないからぼんやりした顔でわたしはそれらを聞いていた。",
              "citation": {
                "source": "雷門以北",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕を差し伸べさえすれば、ペンを取ってそれらの詩的な幻像を書き留めることができるのだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が往来を歩いていて通り過ぎた、明るく、風通しがよく、そして涼しい一軒の茶店のことを書き留める。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、僕の一言一句を、彼等が争つて書き留めると云ふ風になるに相違ないね。",
              "citation": {
                "source": "鰐",
                "author": "ドストエウスキー　Fyodor Mikhailovich Dostoevski",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、諸君はわたしの言葉尻をつかまえて、たとえば、『もしきみが本当に読者を念頭においていないとすれば、順序も体系も取り入れないとか、ただ思い出すままを書き留めるのだとか、そういったような条件を自分一人で、おまけに紙のうえで取り決めるのは、いったいなんのためだろう？",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り黙って立ち上ると、机の上から部厚なノートを一冊抜いて来て、それに要点を書き留めるべく、視線を私の顔からそのノートの方へ移してしまった。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、その前にちょっと名前を、言ってもらいましょう」　名前はカイ・ハンセン、住所はどこそこ……探偵が手帳に書き留める。",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれを云わないとどうも話の都合が悪いし、そのくらいのことを遠慮しては、結局この記録を書き留める意義がなくなってしまう訳ですから、ナオミが十五の歳の八月、鎌倉の海辺に立った時に、どう云う風な体格だったか、一と通りはここに記して置かねばなりません。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれ一応――」　と、彼方此方に横たわっている十幾つかの死骸を見て、一寸覚えを書き留める程度の事務を執って、「取片づけは、役所からさせる。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁はわたくしと相対して並木の下に腰をかけている間に、万茶亭と隣接したラインゴルト、向側のサイセリヤ、スカール、オデッサなどいう酒場に出入する客の人数を数えて手帳にかきとめる。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「じぶんの星のかずを、ちいさな紙きれにかきとめるってことだ。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどからは稿料をかきつけておきましょう、そう思うけれど、まるで蠅の子のような小さいものを一々かきとめるついそれより先に消滅するのですもの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
