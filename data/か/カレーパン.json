      {
        "index": 1,
        "gloss": "curry bread (usu. deep-fried)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "焼きたてのカレーパンは、外はサクサク、中はとろーりで最高だよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "パン屋さんの前を通ると、カレーパンの匂いに誘われてつい買ってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冷めても美味しいカレーパンを見つけたんだけど、どこのお店だったかな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近のコンビニのカレーパンは、具がたっぷりで食べ応えがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "サンドイッチを三種類とカレーパンをひとつ彼は買った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは誰もいないそのスペースのなかで、ヨシオはひとりでまずカレーパンを食べた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼食のサンドイッチといつものカレーパン、そしてコーヒー牛乳を前にして、彼は店の奥の食べるためのスペースでストゥールにすわっていた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ――と言って、これは一体、何時ごろから売っていたものなのだろう――カレーパンだの、コロッケパンというものがある。",
              "citation": {
                "source": "駄パンその他",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "カレーパンというのは、カレーライスの上にかかっている、カレー汁を、パンで包み、それを、ドーナッツの如く揚げてあるのだが、兎に角これが十円は安い。",
              "citation": {
                "source": "駄パンその他",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "母上がやって来られ、昼食はお土産の中村屋のカレーパン二個のみ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "カレーパン食ひ、ピョン／＼して十二時に寝る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕へのお土産カレーパンで昼食。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼は、カレーパンを一個半食って、正岡から送って来た、田村西男の古い本「文楽」を読み出す。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
