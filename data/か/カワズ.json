    "definitions": [
      {
        "index": 1,
        "gloss": "frog",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "雨上がりの庭で、かわずがゲコゲコと鳴いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "池のほとりで、かわずがぴょんと水に飛び込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜の田んぼからは、多くのかわずの声が聞こえてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "息子はかわずを見つけると、いつも大喜びする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あたり一面、稲田の中で蛙が雨のように鳴いていたのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に虫や鳥やの小動物を愛し、蛇、蛙、蝉、蜘蛛、蜻蛉、蝶などが好きであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "周圍は眞闇の田舍道で、田圃の中に蛙が鳴いてる。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あたし、桜を見ていると、蛙の卵の、あのかたまりを思い出して、――」家内は、無風流である。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蛙の卵よりは、いいのね。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、蟇蛙が一匹、ピクピク／＼しながら何時の間にか、庭の真中に匐ひ出してゐた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者が拑子を突つ込むと赤坊が踏まれた蛙ののどのやうにヒクツヒクツとなつた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "閣に座して遠き蛙をきく夜｜哉「閣」というので、相応眺望の広い、見晴しの座敷を思わせる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「古池や蛙とびこむ水の音」の句境の如く、彼は静の中にある動、寂の中にある生を見つめて、自然と人生における本質的実在を探ろうとした。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "The ancient pond!A frog plunged splash!（古池や蛙とび込む水の音）　小宮氏は言ふ。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "句はその切字で分離されて居り、以下の「蛙飛び込む」は、目前の現実的印象を表現してゐる。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな池へ蛙が一疋跳び込んだところで、何の詩趣も意味もあるものか。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "且つ「蛙」といふ動物は、日本人にはとつては特殊の俳味的詩趣をもつて居り、夏の自然を背後に感じさせるやうな季節感をさへ有してゐるが、西洋人にとつては何等特殊の連想がなく、食用蛙の醜怪を思ひ出させる位のものであらう。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日はしばし、鐘が淵の杜を焦がして、八百代小田にうつろひしが、次第に光淡くなりもてゆきて、をちこちに蛙の聲聲聞え、下ゆく水も音冴えたり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やゝ曇り初めし空に篁の色いよ／＼深くして清く静かなる里のさまいとなつかしく、願わくば一度は此処にしばらくの仮りの庵を結んで篁の虫の声｜小田の蛙の音にうき世の塵に汚れたる腸すゝがんなど思ううち汽車はいつしか上り坂にかゝりて両側の山迫り来る。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の曲目の内に管弦楽で蛙の鳴声を真似するのがあった、それはよほど滑稽味を帯びたものであった。",
              "citation": {
                "source": "蛙の鳴声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はあるきながら、その蛙の声を真似して一人で面白がってはさもくすぐったいように笑っておられた。",
              "citation": {
                "source": "蛙の鳴声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから神田の宝亭で、先生の好きな青豆のスープと小鳥のロースか何か食ってそして一、二杯の酒に顔を赤くして、例の蛙の鳴声の真似をして笑っていた。",
              "citation": {
                "source": "蛙の鳴声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あたし、櫻を見てゐると、蛙の卵の、あのかたまりを思ひ出して、――」家内は、無風流である。",
              "citation": {
                "source": "春晝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙を呑んだ蛇見たいにな」　彼は、拷問の事に考え及んだ時、頭の中が急に火熱るのを覚えた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "病が苦しいから死のうと思うだけだ」「蛙の声が穴の中まで聞えて来る。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙よ、唄ってくれ唄ってくれ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙を食べ始めたのもフランス人だと聞いた。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食用蛙は近来日本でも養殖されるが、本場のフランスに於てさえまだなかなか普遍的な食物とはなっていないようだ。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その点から云えば蛙より蝸牛の方が遥かに優っている。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙料理は上等のバタでフライにしてトマトケチャップをかけて食べる。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙は寧ろラードのようなものでからりと揚げた方があっさりしていてよくはないだろうか。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙や蝸牛などのグロテスクなものを薄気味悪い思いをしてまで食べなくとも、巴里には甘い料理がいくらもある。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な「古池やかわず飛び込む水の音」はもちろんであるが「灰汁桶のしずくやみけりきりぎりす」「芭蕉野分して盥に雨を聞く夜かな」「鉄砲の遠音に曇る卯月かな」等枚挙すれば限りはない。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな前生の縁だったかわずかな間の関係であったが、私はあなたに傾倒した。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
