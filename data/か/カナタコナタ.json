[
  {
    "uuid": "b3f599ea-f596-5aea-8a79-1b2b6c4c45cd",
    "entry": "彼方此方",
    "reading": {
      "primary": "かなたこなた",
      "alternatives": [
        "あなたこなた"
      ],
      "is_heteronym": false
    },
    "grammar": {
