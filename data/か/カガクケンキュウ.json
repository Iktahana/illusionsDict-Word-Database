[
  {
    "uuid": "f1677c7e-a74b-5e53-be70-ad638c03a8c4",
    "entry": "科学研究",
    "reading": {
      "primary": "かがくけんきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
