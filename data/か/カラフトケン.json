        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "映画「南極物語」に登場するタロとジロは、樺太犬だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "樺太犬は、寒さに強く、昔からソリ犬として活躍してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "毛並みの美しい樺太犬の姿に、思わず見とれてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "絶滅の危機に瀕している樺太犬の保護活動が続けられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "樺太犬の力強い眼差しには、厳しい自然を生き抜いてきた歴史が感じられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "駛る駛る駛る、樺太犬が、一匹二匹三匹、五匹六匹、二列だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい、犢ほどの樺色の樺太犬がのそりと、その前には出ていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事は休んでいると見えて、その板敷きの広間はガランとして、例の大きな樺太犬なるものが獅子のように傲然とその真ん中に蹲っているだけであった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画で見る樺太犬の橇引きとたいして違いはなかった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "南極越冬隊の樺太犬も一年間二頭が生きていて話題になって騒がれ、去年は人工衛星へ乗ったライカ犬も、ぼくは『雪てん』という落語に使わしてもらった。",
              "citation": {
                "source": "犬",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
