        "examples": {
          "standard": [
            {
              "text": "テンパイはしたが、四索のカンチャンではあがりを拾うのは難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よしっ、狙い通りのカンチャン一発ツモだ！」と、彼は勢いよく牌を卓に置いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "不要な字牌を切り出しながら、カンチャンの受け入れが広がるのをじっと待つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこにまた露宿してその翌日石壁の間の二里の急坂を踰えて山の原を行くこと二里、カンチャンという大きな寺がある。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
