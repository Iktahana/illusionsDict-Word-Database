[
  {
    "uuid": "c3b8f76e-c3fd-5626-96e8-cfef76b1db48",
    "entry": "霞む",
    "reading": {
      "primary": "かすむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
