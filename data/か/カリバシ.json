        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "本来の橋が修復されるまでの間、工事現場の横に鉄骨造りの仮橋が架けられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "増水の影響で仮橋が流される恐れがあったため、一時的に通行止めになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "重機を通すために設置された仮橋は、見た目以上に頑丈な造りをしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "大きな丸太を針金で縛り合せた仮橋が生ま／＼しく新しいのを見ると、前の橋が出水に流されてそのあとへ新造したばかりであらうかと思はれた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな丸太を針金で縛り合せた仮橋が生ま生ましく新しいのを見ると、前の橋が出水に流されてそのあとへ新造したばかりであろうかと思われた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほとんど狼の食い散した白骨のごとき仮橋の上に、陰気な暗い提灯の一つ灯に、ぼやりぼやりと小按摩が蠢めいた。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はただ広い世の中に母様と、やがて、私のものといったら、この番小屋と仮橋の他にはないが、その時分はこの橋ほどのものは、邸の庭の中の一ツの眺望に過ぎないのであったそうで。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時仮橋ががたがたいって、川面の小糠雨を掬うように吹き乱すと、流が黒くなって颯と出た。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "川に仮橋をかけることにしよう。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫁入りの俥を通す橋を」　直助は毎日仮橋の架設工事の監督に精出してゐた。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな仮橋がありますね。",
              "citation": {
                "source": "提灯",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾時仮橋ががた／＼いつて、川面の小糠雨を掬ふやうに吹き乱すと、流が黒くなつて颯と出た。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十二年十一月、渋柿）　　　　　　　＊　震災後の十月十五日に酒匂川の仮橋を渡った。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此方から向うの町に行く仮橋の上には、をりをり自転車や車が通つて行つた。",
              "citation": {
                "source": "浴室",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "両国橋は天保十年四月に架け換えたのであるが、何分にも九十六間の長い橋で、昼夜の往来も繁しい所であるから、十七年目の安政二年には所々におびただしい破損が出来て、人馬の通行に危険を感じるようになったので、ことしの三月から修繕工事に取りかかることになって、橋の南寄り即ち大川の下流に仮橋が作られていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "その仮橋から何者かが飛び込んだらしいのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに列んで仮橋が架けられている、木材や石のたぐいを積み込んだ幾艘かの舟も繋がれている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し暗夜のことであるから、不完全の仮橋から何か粗相で墜落したのかも知れない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの長げえ仮橋のまん中に、提灯一つぶら下げて置くだけじゃあ不用心だ」と、半七は顔をしかめた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はきのうの午すぎに、何かの仕事の都合で上の方の流れを少し堰いたので、西寄りの仮橋の裾の方が浅くなって干上がった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、御免だ」「あんまりそうでもあるめえ」　作事場の役人にことわって、半七は仮橋のあたりを一応見まわった後に、西の橋番をたずねた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "その明くる日の朝、ようよう夜が明けた頃に、ひとりの男が仮橋の上に突っ立って、暫く水の上を眺めていたのです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "お光はそれにも気がつかないらしく、狭い仮橋の中程を行きつ戻りつしていたが、やがて立ち停まって四辺を見まわしながら、川にむかってそっと手をあわせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はきのう両国の仮橋の下から女の死骸が揚がって、それが金の蝋燭をかかえていたという噂を聞きまして、すぐに訊きに行きますと、確かに見おぼえのある人でしたから、そこで正直にお係りのお方に申し上げようかと思ったのですが、なんだか気が咎めて其のままそっと帰って来てしまいました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん帰り路で二度の喧嘩をはじめて、おかみさんは両国の仮橋から飛び込んだのだろうと思います。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしたものかと思案しながら、幸次郎と一緒に錺屋を出て、両国の方へぶらぶら引っ返して来ると、仮橋の中ほどに一人の男が突っ立って、ぼんやりと水をながめている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "市電は天満町まで通じていて、そこから仮橋を渡って向岸へ徒歩で連絡するのであった。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "この仮橋もやっと昨日あたりから通れるようになったものと見えて、三尺幅の一人しか歩けない材木の上を人はおそるおそる歩いて行くのであった。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と次兄とは川の堤に出て、天満町の仮橋の方へ路を急いだ。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "市電は天満町まで通じてゐて、そこから仮橋を渡つて向岸へ徒歩で連絡するのであつた。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "この仮橋もやつと昨日あたりから通れるやうになつたものと見えて、三尺幅の一人しか歩けない材木の上を人はおそるおそる歩いて行くのであつた。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
