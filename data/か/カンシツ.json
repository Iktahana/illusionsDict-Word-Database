    },
    "definitions": [
      {
        "index": 1,
        "gloss": "stroma",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「病理検査の結果、腫瘍の周囲にある間質に強い炎症反応が見られることがわかった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「臓器の機能をつかさどる実質細胞に対し、間質はそれらを支える支持組織としての役割を担っている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「顕微鏡を覗くと、間質の部分が青く染まっていて、組織の立体的な構造がはっきりと確認できるね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "おそらくジャイルズ・ギルマン興行師に長時間質問して、細長い桃色紙幣を渡したことと、何か関係があるのだろう。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
