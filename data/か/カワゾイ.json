[
  {
    "uuid": "f1f942a1-a2bf-516f-aaa4-f88e5a052a3a",
    "entry": "川沿い",
    "reading": {
      "primary": "かわぞい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞"
      ],
      "ctype": null,
