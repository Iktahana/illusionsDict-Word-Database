        "examples": {
          "standard": [
            {
              "text": "デスクトップの壁紙を毎日違う風景写真にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいパソコンを買ったら、まずお気に入りのキャラクターの壁紙を設定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この夕焼けの写真、壁紙にしたら綺麗だろうな」と彼は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スマートフォンの壁紙を季節ごとに変えるのが私の小さな楽しみだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "動く壁紙アプリを試してみたが、バッテリーの消費が激しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
