        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昨夜、友達と話しすぎて声が掠れてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "腫瘍の影響で声帯が傷つき、声が掠れるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あー、もう声が掠れてきたよ。水を飲もう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
