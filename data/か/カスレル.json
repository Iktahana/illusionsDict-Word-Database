        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "自転車が歩行者の腕をかすれるように通り過ぎた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "投げたボールがフェンスをかすれて、目標から外れてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「危ない！もう少しで車がお父さんの手をかすれるところだった！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
