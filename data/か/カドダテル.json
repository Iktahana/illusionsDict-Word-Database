        "examples": {
          "standard": [
            {
              "text": "ささいなミスなんだから、そんなに角立てて怒鳴らなくてもいいじゃないか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "わざわざ波風を立てたくないから、今回は角立てずにこちらが引き下がることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は何に対しても角立てるような態度を取るから、正直チームの中では浮いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "岡村は何に生意気なことをと目に角立てる。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おお、まあ、なんてこの娘は、いやな――と、呆れて、眼を反むけながら角立てるに違いはない。",
              "citation": {
                "source": "田沢稲船",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は手紙を前にして考えましたが、改まって彼を訪ねていったり呼寄せたりして角立てるのは却って悪いから、こんど彼がやって来た時にゆっくり逢って、彼の考えなり行いなりをはっきり聞いた上で、何とか方法を講じようと思いました。",
              "citation": {
                "source": "香奠",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
