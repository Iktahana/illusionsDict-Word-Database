        "examples": {
          "standard": [
            {
              "text": "クロールは苦手だが、昔からカエル泳ぎだけは誰よりも速く泳げる自信がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "市民プールで、ゆっくりとしたペースでカエル泳ぎの練習をしているお年寄りをよく見かける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "息継ぎのタイミングが掴めず、顔を上げたままの自己流のカエル泳ぎでなんとか25メートル泳ぎ切った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "……お湯へおはいりなさいよ」　そういうとお蘭は、背中を湯面へ浮かせ、蛙泳ぎをして湯槽の向こう側へ泳いで行き、振り返るとぼんのくぼを湯槽の縁へかけ、フーッと、唇をとんがらかして湯気を吹き、男と向かい合った。",
              "citation": {
                "source": "猿ヶ京片耳伝説",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いふんどしの子供たちは、犬かきや、蛙泳ぎや、平泳ぎを、唇が青くなつてガタ／＼ふるへるまで、練習します。",
              "citation": {
                "source": "プールと犬",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いふんどしの子供たちは、もう犬かきや、蛙泳ぎばかりしてはゐません。",
              "citation": {
                "source": "プールと犬",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻　　蛙泳ぎでせう。",
              "citation": {
                "source": "明日は天気（二場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵の通せんぼうをかい潜りかい潜り、立泳ぎ、蛙泳ぎ、抜き手、片抜手、美しき筋肉運動の限りを尽して、美少年のお尻へと追い縋る。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
