          "standard": [
            {
              "text": "電子書籍が普及しても、紙媒体で読む「活字文化」は根強く残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の書斎には膨大な蔵書があり、まさに活字文化の担い手と言えるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔は活字文化が教育の中心であり、読書によって多くの知識が得られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ヴエニスのマヌチウス父子、ウエストミンスターのカクストン、パリのロバートらその他、それぞれに華やかな第一期西洋活字文化の花を咲かせた人々として有名である。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            }
          ]
