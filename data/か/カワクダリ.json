    "definitions": [
      {
        "index": 1,
        "gloss": "going downstream (in a boat)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "熟練の船頭さんが操る小舟に揺られて、のんびりと渓谷の川下りを楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「川下りの途中で急流があるから、しっかり手すりに捕まっていてくださいね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "嵐山での川下りは、紅葉の季節になると予約が取れないほどの人気ぶりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ラフティングで川下りに挑戦したが、予想以上の激流で全身ずぶ濡れになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "尾張側の雀のお宿は後まわし後まわし」で笑って、「木曾川下りといえば昔はこの笠松までときまっていたものだ。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる一山｜飛で一山来るとも云うべき景にて、眼｜忙しく心ひまなく、句も詩もなきも口惜しく、淀の川下りの弥次よりは遥かに劣れるも、さすがに弥次よりは高き情をもてる故なるべしとは負惜みなり。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、いつ立ったのだね」「きのうの朝、立ちました」「それじゃあすぐには帰るめえ」「帰りは富士川下りだと云っていました」「ことしの正月に、石町の金蔵を捕りに行ったのは、誰だね」と、半七は訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思うと、いくら都踊りや保津川下りに未練があっても、便々と東山を眺めて、日を暮しているのは、気が咎める。",
              "citation": {
                "source": "西郷隆盛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "教へて頂いた源河節なども、清明節の浜下り・川下りの風から出た歌で、節の水で身禊ぎをする村人の群れに、娘たちもまじつた。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "清明節以外の祭りの日にも、川下りしたり、水浴びをしたかも知れない。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、常世浪は皆いづれの岸にも寄せて、海の村の人の浜下り、川下りの水になる。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車を人吉に下りた唯一の目的は球磨川下りであつた。",
              "citation": {
                "source": "八月の霧島",
                "author": "吉田絃二郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
