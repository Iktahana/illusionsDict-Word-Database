    },
    "definitions": [
      {
        "index": 1,
        "gloss": "khaki (colour)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "店員さんに「もう少し濃いカーキ色のパンツはありますか？」と尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "秋になると、街中でカーキ色のコートを着ている人を多く見かけるようになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この部屋の壁は、落ち着いた雰囲気のカーキ色で塗られていて心地よい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "兵営は暗く、新しく着せられるカーキ色の羅紗の服は固ッくるしい。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あゝ、早く、あの、カーキ色の軍服を着た兵隊さんが来て呉れるといゝんだがなア！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄土のほこりに襦袢が、カーキ色に変ってしまっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけの理由で、この支那人は、自分が日本人であるかのように、カーキ色の軍隊が、自分の保護者となり、自分の勢力となり、自分の樫の棒に怨を持つ、不逞の奴等や、回々教徒を取りひしいで呉れるものと、一人ぎめにきめこんでいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "着剣した銃を持って、四五人のカーキ色の兵士が、ばらばらと立っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　ユフカ村から四五露里｜距っている部落――Ｃ附近をカーキ色の外皮を纏った小人のような小さい兵士達が散兵線を張って進んでいた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隊長とその附近にいた将校達は、丘の上に立ちながら、カーキ色の軍服を着け、同じ色の軍帽をかむった兵士の一団と、垢に黒くなった百姓服を着け、縁のない頭巾をかむった男や、薄いキャラコの平常着を纏った女や、短衣をつけた子供、無帽の老人の群れが、村に蠢き、右往左往しているのを眺めていた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーキ色の方は、手あたり次第に、扉を叩き壊し、柱を押し倒した。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それともこっちのカーキ色の軍服だろうか！",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘の上に整列していた別の中隊は、カーキ色と、百姓服が入り乱れ、蠢く方をめがけてウワッと叫びながら馳せくだりだした。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーキ色の軍服がいなくなった村は、火焔と煙に包まれつつ、その上から、機関銃を雨のようにばらまかれた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　パルチザンは、山伝いに、カーキ色の軍服を追跡していた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弾丸は逃げて行くカーキ色の軍服の腰にあたり、脚にあたり、また背にあたった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーキ色の軍服は、こっちで引鉄を握りしめると、それから十秒もたたないうちに、足をすくわれたように草の上へ引っくりかえった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰り路に虎渓橋の上でカーキ色の軍服を着た廃兵に逢った。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーキ色の軍服を着て、軍歌を高唱して歩けば、リイプクネヒトだって、忠勇な兵隊と見えたに違いない。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのおしゃれな人が、軍服のようなカーキ色の詰襟の服を着て、頭は丸坊主で、眼鏡も野暮な形のロイド眼鏡で、そうして顔色は悪く、不精鬚を生やし、ほとんど別人の感じであった。",
              "citation": {
                "source": "女神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "門の入口に請願巡査の小屋があってそれから道の両側に欅の並木があり、その先は折れ曲っているので玄関はどのくらい先にあるか判らない金持の邸の並木の欅五六本目のところでカーキ色の古ズボンを穿いた老人が乾した椎茸を裏返している。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だぶだぶの帆布のようなカーキ色の服を着て居る。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーキ色の飛行船が爆発した、空の遥かで。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと以前に石狩川の方向で、二三発の銃声が聞えて以来、パッタリと影を消してしまった自分の夫を、監獄からの追跡者に殺されたものとばかり思い込んでいた妻の久美子が、カーキ色の登山服に、ライフルを担いだＡの姿をチラリと見るや否や、おなじ監獄からの追跡者と早合点したのは無理もない話でしょう。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日々々耳をすますうちに、カーキ色に赤い条の入った軍服のズボンを出して廻診衣を着た、いつもにこ／＼した赤い顔の軍医のスリッパの音を呑み込んでしまって、彼女の見当は当らない時はなくなった。",
              "citation": {
                "source": "青白き夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーキ色のシヤツの袖をまくしあげて、唇をしつかりと引き結んだ娘は、早朝から一杯機嫌の父親が、槌に合せて、飄逸な掛声で音頭をとつても、眉一つ動かすことなしに、夢中で重い合槌を打ち続けた。",
              "citation": {
                "source": "パンアテナイア祭の夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜜柑の季節になるとカーキ色のシヤツで、まるで少年のやうな姿で、畑の手伝ひをしたり、口笛を吹きながら御者台に乗つて問屋へ運ぶ荷物の馬車を駆つたりしてゐる八重といふ娘である。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーキ色の軍人が軍器を噛るやうな音だ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本将校石川半山７・11（夕）　新聞記者石川半山氏が昨年米国へ往つた時、あちらは軍人全盛といふ事を聞いてゐたので、態々カーキ色の軍服まがひの洋服を着込んで船に乗つたものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車に乗つても、電車に乗つても、乗客は石川氏のカーキ色洋服を見ると、吾がちにすつと立つて席を譲らうとした。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "話対手の顔は見えず、学生帽のような形をしたカーキ色の帽子や同じ色の外套の裾などが見えるばかりだ。",
              "citation": {
                "source": "東京へ近づく一時間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸見ると青年団員か何かかと思われるカーキ色ずくめのその若い男は、汽車が古河という小さい駅に停った時、どうしたわけかグズグズに繩のゆるんだ白布張りの行李を自分でかついで乗り込んで来た。",
              "citation": {
                "source": "東京へ近づく一時間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "懷古カーキいろの山脈の皺に夕映が滴り空氣いろのつよい反映が加はつて爽涼たる景觀の線を發してゐるのを見てはどうして旅行者自身の精神を鎭靜な香爐のやうに思念せずにはゐられようあの寛濶で古雅なひろがり！",
              "citation": {
                "source": "季節の馬車",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
