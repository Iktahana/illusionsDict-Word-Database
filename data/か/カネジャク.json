        "examples": {
          "standard": [
            {
              "text": "江戸時代の書物には、建物の寸法が曲尺で記されていることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この巻物は長さが一曲尺ちょうどで、昔の基準がわかる貴重な資料だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "茶室の広さは四畳半と定められているが、これは曲尺を基準にしたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の反物の長さは、おおよそ一反が曲尺で計られた約10丈だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
