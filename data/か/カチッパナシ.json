        "examples": {
          "standard": [
            {
              "text": "彼は最近、ポーカーで勝ちっぱなしで、すっかり鼻高々だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの投資家は、ここ数年勝ちっぱなしで、資産を大きく増やしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "連戦連勝のチームだが、あまり勝ちっぱなしだと逆に怖い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "麻雀で勝ちっぱなしだった彼は、珍しく大負けしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "なんだか初めてらしくて、賽の目も、張りかたも、よく知らなかったそうですが、半方の定張りで、一度もくずれず、勝ちっぱなし、玄人連の度胆を抜いたといいます。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
