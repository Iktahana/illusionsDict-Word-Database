        "examples": {
          "standard": [
            {
              "text": "真っ赤に熱せられた鉄の塊が、巨大な加熱炉の出口からゆっくりとローラーコンベアへ運ばれてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「加熱炉の温度が10度ずれるだけで、製品の強度に致命的な欠陥が出てしまうから気が抜けないよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "熟練の職人が加熱炉ののぞき窓から中をじっと凝視し、炎の色だけで鋼の状態を見極めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "金属研究所の加熱炉の中では鋼鉄の塊が千六百度の猛火で焼かれているのだ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "原動機は廻転し、ベルトはふるえ、軸は油をなめまわし、攪拌機はかきまわし、加熱炉は赤く焔え、湯気は白く噴き出し、えらい騒ぎが毎日のように続いた。",
              "citation": {
                "source": "毒瓦斯発明官",
                "author": "――金博士シリーズ・５――",
                "note": "青空文庫"
              }
            },
            {
              "text": "小型の加熱炉を造って何でも作れるようになり、二日間で潜水艇の残骸を溶かして、大きな金属容器を七〜八個造った。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
