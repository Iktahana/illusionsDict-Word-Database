    "definitions": [
      {
        "index": 1,
        "gloss": "outside one's jurisdiction",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
