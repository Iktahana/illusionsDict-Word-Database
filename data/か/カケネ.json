        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の話はいつも掛け値が入っていて、どこまで本当かわからない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「とんでもない大物だった」と、彼は少し掛け値をして話した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、宝物を見つけたと大げさに話していたのは、ただの石ころだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
