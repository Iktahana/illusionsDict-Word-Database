        "examples": {
          "standard": [
            {
              "text": "道路の下に埋められたカルバートが、雨水の排水路として機能している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大雨でカルバートが詰まり、道路が冠水してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古くなったカルバートの補修工事が、今月中に始まる予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このカルバートは、小さな川の流れを変えずに道路を横断させるために設置された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "フリーチェの芸術社会学やカルバートンの社会学的批評などがこの例で、今日でも大いに教える処のあるのは疑えない事実であろう。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "読売ホール、一時より、ジョン・カルバートの魔術ショウ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
