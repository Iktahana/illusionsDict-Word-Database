[
  {
    "uuid": "c3f126ac-d0a1-5a7d-a449-f825c6a630ed",
    "entry": "嗅ぎ出す",
    "reading": {
      "primary": "かぎだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
