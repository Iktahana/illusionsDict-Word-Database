    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to scent out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "警察犬は、麻薬を巧みに嗅ぎ出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はどんな些細な情報からでも真実を嗅ぎ出すことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "キノコの香りを嗅ぎ出して、森の奥深くへと進んでいった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はいつも新しいトレンドを嗅ぎ出すのが得意だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "更に明確にぶちまけるならば、この小品の原作者 HERBERT EULENBERG さん御自身こそ、作中の女房コンスタンチェさんの御亭主であったという恐るべき秘密の匂いを嗅ぎ出すことが出来るのであります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "倅はそう云う人は危険思想家だと云っているが、危険思想家を嗅ぎ出すことに骨を折っている人も、こっちでは存外そこまでは気が附いていないらしい。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "三とせ前からこうして矢場を開き、うぬら初め家中の者共の弓の対手となっていたは、みな御老中の命によって当藩の秘密嗅ぎ出すための計りごとじゃ。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでなくとも、外から帰って来る笹村の顔から、その行き先を嗅ぎ出すくらいは、お銀にとってそんなむずかしいことでもなかった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、隣室からへだたったこの部屋の潤いの籠った明るさは、久しぶりに千鶴子と二人で自分の部屋に帰ったときの、パリのある夜の寛ぎに似たものを思い出し、そのときの灯の匂いを嗅ぎ出すように首をのんびりと廻しあたりを見た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の罪科、見分けて嗅ぎ出す。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国劇を勉強するのもいいが、そこから、何かかう特別な「作劇術」とか、思想的背景とかいふやうなものばかりを探し出さうとして、それらの戯曲が、「戯曲として傑れてゐる所以のもの」を嗅ぎ出すことができなかつたことは、慥かに日本の現代劇を本質的に発達させなかつた唯一の理由であるやうに思はれる。",
              "citation": {
                "source": "対話させる術",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しながら近頃文章を批評するに、この文章には真実（実感）がある、真実がない、といふ言ひ方が流行し、この実感を嗅ぎ出す神経が極度に発達してゐるやうに見受けられるが、私はこの傾向を余り歓迎しない。",
              "citation": {
                "source": "文章の一形式",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく無能な職業的俳優が自ら指導者の地位に立つたよりも、原則として無難であるべき筈だが、事実は、俳優の演技的センスを消滅させ、脚本から直接舞台の生命を嗅ぎ出す能力を衰退させたことは、何と云つても、「無理な指導的演出」の罪であつた。",
              "citation": {
                "source": "演出について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりごとであつたなら、その冷めたさに、親しさを嗅ぎ出すこともできたであらう。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫は、背中を丸くして、自分のよく識っているひからびた手が、毛を撫でてくれるのを待っているが、それも待ちくたびれて、地べたのにおいを嗅ぎ出す。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当の話は人喰鬼が新しい血を嗅ぎ出す話や、妖精がとうなすを馬車にしたり蜥蜴を従者に化けさせたりする話よりは、もつと本当に面白い筈だ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも五人や三人の口が揃つたのぢやない、――三味線と小唄も聽えて居たといふし」「でも、變ぢやありませんか、親分」「何が變なんだ」「何んとなく變ですよ」　八五郎はキナ臭いものを嗅ぎ出すやうに鼻の穴を大きくしました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "二枚の小判",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上は三十八人の子分の顏から、曲者の匂ひを嗅ぎ出す一手です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鐘五郎の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角、覗いて見るとしようか――尤も俺が行つて、反つて困るやうなことを嗅ぎ出すかも知れないが、それは承知だらうな」　平次は煙草入を腰に差し乍ら、お靜の持つて來た羽織に手を通しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "買つた遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "八五郎の早耳は、早くもそれを嗅ぎ出すと、「親分、少し遠いが、赤坂御門外までお願ひしますよ、何が何んでも、同じ家で二人殺されちや放つて置けません」　明神下の平次のところへ飛んで來ました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "旅に病む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も拔け荷や禁制品を扱ふ者は口が堅いから、うつかり用心させると、田螺見たいになるぜ」「心得たよ、親分」「言ふ迄もないが、拔け荷や和蘭渡りの禁制品を扱ふ問屋を嗅ぎ出すのが第一だよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "和蘭カルタ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも五人や三人の口が揃ったのじゃない、――三味線と小唄も聴えていたというし」「でも、変じゃありませんか、親分」「何が変なんだ」「何となく変ですよ」　八五郎はキナ臭いものを嗅ぎ出すように鼻の穴を大きくしました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二枚の小判",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上は三十八人の子分の顔から、曲者の匂いを嗅ぎ出す一手です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鐘五郎の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎にも角にも、一つの事件を嗅ぎ出すと、柄の無いところに柄をつけ、半分以上は誰かに対する嫌がらせの記事を、三段でも五段でも捏ち上げる特別な腕を持っていたのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "第四次元の恋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日と請合った日は今日限りとなりましたが、どこへどう隠されたか、お雛の在処を嗅ぎ出す手掛りも、その誘拐の悪者の当ても付かないのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幽霊にされた女",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の代りに、この男を差上げますから、私だと思つて、いろ／＼御相談なすつて下さいまし、――大丈夫で御座いますとも、人間は甘くても、なか／＼良い鼻を持つて居りますから、どうかしたら、御墨附を嗅ぎ出すかもわかりません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "名馬罪あり",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻がよくて、いろ／＼の消息を嗅ぎ出すことにかけては、天稟の妙を得たガラツ八ですが、理詰めに手繰つて、下手人を擧げることとなると、まるでだらしがありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "許嫁の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも抜け荷や禁制品を扱う者は口が堅いから、うっかり用心させると、田螺みたいになるぜ」「心得たよ、親分」「言うまでもないが、抜け荷や和蘭渡りの禁制品を扱う問屋を嗅ぎ出すのが第一だよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "和蘭カルタ",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、覗いて見るとしようか――もっとも俺が行って、かえって困るようなことを嗅ぎ出すかも知れないが、それは承知だろうな」　平次は煙草入を腰に差しながら、お静の持って来た羽織に手を通しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "買った遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の代りに、この男を差上げますから、私だと思って、いろいろ御相談なすって下さいまし、――大丈夫でございますとも、人間は甘くても、なかなか良い鼻を持っておりますから、どうかしたら、御墨付を嗅ぎ出すかもわかりません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "名馬罪あり",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る朝、神田から銭形の平次が駆け付け、三輪の万七もやって来ましたが、庭の足跡は、踏み荒らされない代り、今度は雪に埋まってしまって、八五郎が入ったのも定かでない有様、曲者はどこから来て、どこへ逃げたか、嗅ぎ出す手掛りというものは一つもありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の精",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻がよくて、いろいろの消息を嗅ぎ出すことにかけては、天稟の妙を得たガラッ八ですが、理詰めに手繰って、下手人を挙げることとなると、まるでだらしがありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "許嫁の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘密をかぎだすには女に限ることは、僕たち探訪記者が永い経験によって体得したモットーなのである。",
              "citation": {
                "source": "或る探訪記者の話",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
