    "definitions": [
      {
        "index": 1,
        "gloss": "to wear the mantle of (borrowed) authority and misuse it",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "親のコネを笠に着て、会社で好き放題やっているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は先輩の権威を笠に着て、新人に無理難題を言っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "そんなやり方で人を動かそうとするなんて、彼女の役職を笠に着ているだけだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "困難どころか、彼が典型的な收賄官僚であり、權勢を笠に着る奸惡邪智な人物であつたといふ解釋は、どのやうな善政の實績をもつてしても到底くつがへすことのできないものだといふことが次第にハッキリしてきたのである。",
              "citation": {
                "source": "生きている忠臣藏",
                "author": "――忠臣藏は何故流行するか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「知らない家の書生なら大目に見てやるんだが、社長の権威を笠に着る以上は堪忍出来ない」　と二つ三つ続けさまに食わせた。",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、そういえば、妻が夫の威光を笠に着るのも、何とまた鼻もちならぬ思いあがりであろう！",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
