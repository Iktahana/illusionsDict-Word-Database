    "definitions": [
      {
        "index": 1,
        "gloss": "to act on one's emotions",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はいつも大事な局面で感情に走ってしまい、後で後悔するんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "突然のニュースに、観客たちは一斉に感情に走って、拍手喝采を送った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの頃の私は、まだ自分の感情に走る制御ができなくて、いろいろと失敗したな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "物語の主人公は、復讐心から感情に走った行動をとってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "――「斯んなに騒いでゐる俺達の誰ひとりもが、彼女の脚にさへも触れることなしに……」「慨嘆も好いが、きはどい感情に走るな――左う聞いたゞけで俺の胸から腹へかけて、突如、稲妻のやうな冷いものが猛烈な勢ひで駆け抜けたわい！",
              "citation": {
                "source": "まぼろし",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "情熱を傾けることと、興奮することとは別であることを知り、人との接触に於ても猥りに感情に走るやうな言動を慎み、すべての浪費を蓄積に代へることであります。",
              "citation": {
                "source": "戦争と文化",
                "author": "――力としての文化　第三話",
                "note": "青空文庫"
              }
            },
            {
              "text": "女つていふもんは、なんともはや……すぐ感情に走るから始末にわるい。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だまったり」　　　　　　　八　せつ子は事の判断に於ては、感情に走ることはなかった。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは一つは議論に加わって、感情に走るのを好まなかったためでもあろうが、主として自分の発見に全力を集めるためであった。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
