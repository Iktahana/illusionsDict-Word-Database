        "examples": {
          "standard": [
            {
              "text": "若い頃は尖ってた彼も、部長になってからだいぶ角が取れて丸くなったよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この煮込み料理、一晩寝かせたおかげで調味料の角が取れてまろやかな味わいになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長年使い込んだ革財布は、四隅の角が取れて手にしっくり馴染むようになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "厳しい指摘の中にも、最近はどこか角が取れたような優しさが感じられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "去年不首尾で帰ってから一年たったので、元来父は藩では才力のあった方ゆえ、長く休ませて置くでもないということになり、それにしても、父は頑固な方ゆえ、京都あたりの留守居でもさせたら、少しは角が取れるだろうとの考えから、こういう役をいい付かった様子である。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            }
          ]
