[
  {
    "uuid": "d535f81f-76d8-5cda-81c6-6db669280632",
    "entry": "彼自身",
    "reading": {
      "primary": "かれじしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
