[
  {
    "uuid": "c10c54cb-f3df-5401-9a87-b0fb6ab50ba1",
    "entry": "書きぶり",
    "reading": {
      "primary": "かきぶり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
