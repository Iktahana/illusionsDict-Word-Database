[
  {
    "uuid": "5ff42f1c-e9f8-53a5-b343-9126513717cf",
    "entry": "角度",
    "reading": {
      "primary": "かくど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "angle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「自撮りするときは、少し上からの角度で撮るのが一番盛れるんだって」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プレゼン資料のグラフは、見せ方の角度によって印象操作ができてしまうので注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "椅子をリクライニングさせて、腰に負担がかからない最適な角度を探る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "専門外の人の意見を聞くことで、自分では思いつかなかった角度からの解決策が見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼の眼は絶えず微妙にも正確な角度をなして活々してゐる。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "火口壁は四十度以上の急角度で、胸突八丁よりも峻嶮に、火口底までは直径約一千尺の深さで、頂上内院大火口よりも深いものである。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故というに、キャリフォルニアからオレゴン州への、境近い街道に、山が聳えて、複式二重の成層火山、シャスタとシャスチナと、二人の容姿端麗なる姉妹が、見る角度に依っては、並んで手を繋ぎ合ってもいるし、また背中合せに丈くらべをしているようでもあり、何となく人｜懐かしい山に見えるからである。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場近くの神社で花崗石の石の鳥居が両方の柱とも見事に折れて、その折れ口が同じ傾斜角度を示して、同じ向きに折れていて、おまけに二つの折れ目の断面がほぼ同平面に近かった。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巧く作れば動揺の角度が半分くらいにはなる、これは実際今日でも用いられている。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち「意気地」は媚態の存在性を強調し、その光沢を増し、その角度を鋭くする。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔面に対してかなり大きな角度をして突き出た三角形の大きな鼻が眼に付く。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうすれば、言葉と白墨の線とによって、大きさや角度や三角函数などの概念を注ぎ込むよりも遥かに早く確実に、おまけに面白くこれらの数学的関係を呑み込ませる事が出来る。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな蛾の複眼に或る適当な角度で光を当てて見ると気味の悪いように赤い、燐光に類した光を発するのがある。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、実地ではこんなに演奏者を八方から色々の距離と角度で眺めることは不可能であるが、そればかりでなく映画のカメラは吾らの眼の案内をして複雑な管弦楽の編成の内容を要領よく解明してくれる。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでここではむしろ少しちがった角度からこの問題を考えてみたいと思う。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから五つの煙の塊が空中に描く屈曲した線が色々の星座のような形をして、またそれが垂直に近くなったり、水平に近く出たり、あるいは色々な角度に傾斜するのも面白かった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後になって、日がいつもの角度に傾くと、この考えは堯を悲しくした。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "角度を急に曲つて、橋を乗る時を思はれよ。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八九九年の探険でスウェン・ヘディンがタリム川の流路を追跡して行った時、川がある点から急角度で南東に曲がって、そうして砂漠の南のほうに湖水を作っているのを見いだし、それがプルジェワルスキーの見たのと同じものだとわかった。",
              "citation": {
                "source": "ロプ・ノールその他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの普通日常用いる時計の針の回る角度がたまたま時の代用となるのもやはり自然の経験にほかならぬ。",
              "citation": {
                "source": "時の観念とエントロピーならびにプロバビリティ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のほうでもひそかにこの人の有名な耳と鼻の大きさや角度を目測していた。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二三日たって気がついて見ると、一つは紙ひもがほどけかかってつぼみの軸は下方の鉛直な茎に対して四五十度ぐらいの角度に開いて斜めに下向いたままで咲いていた。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種の映画でよくある場面は一群の人間と他の一群の人間とが草原や川原で追いつ追われつする光景をいろいろの角度からとったものである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたあとで、テナシティのデッキの上から「あしたは出帆だ」とどなるのをきっかけに、画面の情調が大きな角度でぐいと転回してわき上がるように離別の哀愁の霧が立ちこめる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかロシア映画を思わせるような編集ぶりとカメラの角度が見られる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに近い範囲の電線に止まっている三十五匹のとんぼの体軸と電線とのはさむ角度を一つ一つ目測して読み取りながら娘に筆記させた。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果を図示してみるとそれらの角度の統計的分布は明瞭に典型的な誤差曲線を示している。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の郷里では、今は知らず二十年も以前は、婚礼の三々九度の杯をあげている座敷へ、だれでもかまわず、ドヤドヤと上がり込んで、片手には泥だらけの下駄をぶら下げたままで、立ちはだかって花嫁や花婿の鼻の高低目じりの角度を品評した。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合では、一つの場所の光景をいろいろな角度に見たスケッチを総合したような形式になっている。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際多くの連作は一つの植え込みをいろいろな角度から飽かずいつまでもながめているような趣があって、この点ではどうしても静的であり絵画的である。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このようにカメラの距離の調節によって尺度の調節ができるのみならず、また、カメラの角度によって異常なパースペクティーヴを表現し、それによって平凡な世界を不思議な形態にゆがめることもできるのは周知の事実である。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、セロの曲中に出て来る急速なアルペジオをひくのに、弦から弦と弓を手早く移動させるために手首をいろいろな角度に屈曲させる。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の六月妻が乳癌の手術を受けて退院して來たあと、自分は二人の子供達のために今後の自重養生を聊かくどいほどに説き頼んだ。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、実際は額に汗をかくどころでは無い、鶏肌立つくらい寒かったので、諸士軍卒も聊か怯んだろう。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
