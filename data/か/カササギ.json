[
  {
    "uuid": "cabebc6a-e0d3-5ac6-b14a-59c0557f4def",
    "entry": "鵲",
    "reading": {
      "primary": "かささぎ",
      "alternatives": [
        "カササギ"
      ],
      "is_heteronym": false
    },
    "grammar": {
