    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Eurasian magpie (Pica pica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭の柿の木に、白と黒のコントラストが美しい鵲が巣を作り始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "カチカチと鳴く鵲の声で、朝の訪れを知る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "七夕の夜、天の川に鵲が橋を架けるという伝説を祖母から聞いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "電線に一列に並んだ鵲たちが、何かを語り合っているかのようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "つまり人間の体内に耆婆扁鵲以上の名医が居て、それが場合に応じて極めて微妙な調剤を行って好果を収めるらしいというのである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵲豆のは殊にめでたし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と銀河を仰ぎ、佩剣の秋｜蕭殺として、鵲のごとく黒く行く。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外の道は、弓形に一條、ほの／″＼と白く、比企ヶ谷の山から由井ヶ濱の磯際まで、斜に鵲の橋を渡したやう也。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも八つ花形でもなければ柳鵲の装があるのでもない。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の『墨子』という本にも、公輸という発明家が、竹で作った鵲を墨子に示して、この玩具は空へ放つと三日も飛びまわります、と自慢したところが、墨子は、にがい顔をして、でもやっぱり大工が車輪を作る事には及ばない、と言ってその危険な玩具を捨てさせたと書いてあります。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三国の代の英雄の曹孟徳が、百万の大軍を率いて呉の国を呑滅しようとしつつ、「月明らかに星｜稀にして、烏鵲南に飛ぶ」と槊を馬上に横たえて詩を賦したのも丁度斯様いう夜であった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは白雲の瀧といふので、その瀧の末の流れを鵲の橋によつて渡つて對岸へ路はつゞく。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し鵲の橋の上に立つてゐると瀧が近いので、瀧飛沫は冷やかに領に下ちて衣袂皆しめり、山風颯然として至つて、瀧のとゞろき、流の沸りと共に、人をして夏のいづこにあるかを忘れしむるところ、捨て難いものがある。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外の道は、弓形に一条、ほのぼのと白く、比企ヶ｜谷の山から由井ヶ｜浜の磯際まで、斜に鵲の橋を渡したよう也。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾いた手拭で身体をふきながら、彼は、すぐ眼の前の、梨の木の枝に、鵲が一羽止って、こちらを見ているのに気がついた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三造がその木から二間ばかりの所へ来たとき、鵲は短い濁った鳴声を残して、飛立ってしまった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪は鵲の尾のごときものの刎ね出でたる都髷というに結びて、歯を染めしが、ものいう時、上下の歯ぐき白く見ゆる。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵲唐画鵲のつどへる見れば、黒き羽や、尾白鵲。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いやすし、この草深野、鵲の幾羽居りとも。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵲われは筑後の国に生れぬふるさとの合歓の木かげをながれゆく水の音なり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵲のしろき下羽根、月の夜と移る空なり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "童みな鵲を追ひ、鵲と影をうしなふ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "子の鵲飛ぶ一羽、子の鵲。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　追つかけてまた手紙が来る、俺も火のつくやうに旅行支度をする、それでも待てないであのお跳ねさんは到頭身体がもう変だ、見るものも見なくなつたと云つて寄越した、かと思ふとその手紙より先きに大和の笠置から鵲の立つやうに飛んで来た。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "くさ／″＼の歌滿洲落葉松と樅とをわかず、はひ毛虫林もむなに、喫み竭し枯らさむときに、鵲はい群れて行きぬ。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵲の尾の、しだり尾の靡きはせずや。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　　　　　　　二　往年、雨上りの朝、ちょうどこの辺を通掛った時、松の雫に濡色見せた、紺青の尾を豊に、樹の間の蒼空を潜り潜り、鵲が急ぎもせず、翼で真白な雲を泳いで、すいと伸し、すいと伸して、並木の梢を道づれになった。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお前途の空を視め視め、かかる日の高い松の上に、蝉の声の喧しい中にも、塒してその鵲が居はせぬかと、仰いで幹をたたきなどして、右瞻左瞻ながら、うかうかと並木を辿る――大な蜻蛉の、跟をつけて行くのも知らずに。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（栗の林へ鵲の橋が懸りました。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……鵲の橋とも、白瑪瑙の欄干とも、風の凄じく、真水と潮の戦う中に、夢見たような、――これは可恐い誘惑でした。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かささぎですねえ、頭のうしろのとこに毛がぴんと延びてますから。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなかささぎだ」カムパネルラがまた何気なくしかるように叫びましたので、ジョバンニはまた思わず笑い、女の子はきまり悪そうにしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かささぎですねえ、頭のうしろのとこに毛がぴんと延びてますから」青年はとりなすように言いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かささぎですねえ、頭のうしろのところに毛がぴんと延びてますから。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
