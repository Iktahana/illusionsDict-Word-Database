    "definitions": [
      {
        "index": 1,
        "gloss": "paper feed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あー、また紙送りのミスだよ。裏紙を混ぜて使うとすぐ詰まるなあ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プリンターの紙送りが途中で止まってしまい、赤いエラーランプが激しく点滅している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スキャナーの自動送り機能を使えば、一枚ずつセットしなくても一気に読み込めるから楽だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "きょう枝元老人から手紙が来て（企画用紙送り来る）「この用紙を届けに行くべきながら、お粥腹で歩けないので、郵便にします」と断りの文句があった。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑摩書房より「来訪者」再版検印紙送り来る。",
              "citation": {
                "source": "同居人荷風",
                "author": "小西茂也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
