        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "悪霊を退散させるため、彼は厳かな神送りを行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "村では疫病が流行ると、神送りをして災いを鎮めたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この家には悪い気が満ちている。神送りが必要だ」と霊能者が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
