[
  {
    "uuid": "c3bde49c-f634-5f1c-a98a-ef9e148eefdf",
    "entry": "神送り",
    "reading": {
      "primary": "かみおくり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rite seeing off the gods on their way to Izumo Shrine (held on the last night of the ninth lunar month and first night of the tenth lunar month)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "出雲大社の神送り神事には、全国から多くの参拝者が訪れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旧暦十月二十六日の夜は、八百万の神々を神送りする日とされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "神送りの祭りは、五穀豊穣と人々の幸福を願う大切な行事だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "や、これは話が横道に逸れてしまいましたが、砕けたところでは、碓氷峠の権現さまよ、わしがためには守り神送りましょかよ送られましょか、せめて峠の茶屋までもというようなものになっています。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊りは専ら、伊勢踊り・念仏踊り・神送り踊りの類の激しいものになつて行つた。",
              "citation": {
                "source": "舞ひと踊りと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "又精霊の物語や、踊り神中心の、神送りの乱舞をも行うた。",
              "citation": {
                "source": "組踊り以前",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、行疫神の来るのをはぐらかす、神送りの踊りの様に考へられて、御霊の社や祇園社の信仰と混淆して、田楽の一派として、怨霊退散を第一義とした念仏踊りを形づくつて行つた。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪辺の社でも、昔は九月尽の日には、神送りを行うた。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "春祭りの「春田打ち」の繰り返しのような行事が、だんだん疫神送りのような形になった。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人早川孝太郎さんと見た、三河田峯の村境の山に、くゝりつけられてあつたおかた人形は、神送りに送られる神の様に見えて居るけれども、実は、送つて出た精霊と、巫女とを兼ねたもの、とも見える。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一〇　神送りと祓除との結合茲で、一体ひなとは何かを考へて見たい。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに、三月・五月の人形は、流して神送りする神の形代を姑く祀つたのが、人形の考へと入り替つて来た、と見るのがよい。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この季節に、少女が神を迎へる資格を得る為のものいみ生活をする風習のあつた事は前に述べたが、重陽を後の雛と言ひ、七夕にも、此を祀る地方がある事、又、今も北九州に行はれる、八朔の姫御前などから考へれば、此季節に、やはり神を迎へ、神送りをした風習のあつた事は、いよ／＼確かだと言へる。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月・五月の人形は、流して神送りをする神の形代を姑らく祀つたのが、人形の考へと入り替つて来たのである。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "神送りはいづれも、さうするのであつた。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "春祭りの「春田打ち」の繰り返しの様な行事が、段々疫神送りの様な形になつた。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この県の地名として神送り場、もしくは虫ヶ原・雲霞山などというのが折々ある。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛知県｜北設楽郡｜段嶺村大字豊邦字笠井島の某という十歳ばかりの少年が、明治四十年ごろの旧九月三十日、すなわち神送りの日の夕方に、家の者が白餅を造るのに忙しい最中、今まで土間にいたと思ったのが、わずかの間に見えなくなった。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをこしらえるのは旧十月の神送り、冬春両度の山の神祭の時などで、家々の楽しみだけには作るということもないが、小児は好奇心が多いから決して軽蔑せず、今でも口を白くしてその供物の卸しを食べまわっているという話も聴いた。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩手県では一般にこれをシットギと謂い、風の神送りの日に作って藁苞に入れて供え、または山の神祭の際に、田の畔に立てる駒形の札に塗りつけた。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の終りの神送りの日には、是は欠くべからざる神供であった。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワアホイはもちろん鳥を追い散らすおどしの声、ホンヤラも後から駆り立てる声だったとみえて、二月・十二月の風の神送りなどにも、こういう囃しを用いている例がある。",
              "citation": {
                "source": "こども風土記",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "神送りの起原　村々の社の神が、遠い出雲の国へ旅をなさるという言い伝えは、いつの頃どういう風にして始まったろうか。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと多くの類似が出て来るとよいのだが、愛知県の東部、三河の南設楽郡のうちには、九月｜晦日の神送りの宵を、田の神送りと呼んでいる村がある。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから東に来て静岡市のまわりでも、やはり同じ日を田の神送りと名づけて、もとは家毎に餅を搗き、あるいは小豆飯を炊いて祝いごとをしていた。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二つの中間地帯、ことに天龍川の流域などは、田の神とは言わぬがこの日の神送りが近い頃まで盛んで、あるいはこれをコトの神送りとも呼んでいた。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "出雲への旅行をいう他の地方の神送りとちがうのは、ここでは一ヵ月過ぎての神迎えの祭というものが全くないことと、その神送りの式がよそでする虫送りや、病い神送りの行事とあまりにも近いことであった。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが同じ天龍川も上流に溯って、信州の部内まで入って行くと、コトの神送りの行列その他は同じであって、日だけが十二月の八日と二月の八日になっているのである。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の解したところでは、一年の祭の終りを神送りといったのは古い名で、それは至って丁重な行事であった故に、元は旧十月朔日の前後から、この十二月八日まで続いていた。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
