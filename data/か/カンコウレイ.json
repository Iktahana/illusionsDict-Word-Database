        "examples": {
          "standard": [
            {
              "text": "裁判所は、事件関係者に対して緘口令を発令した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この件については、一切口外しないよう厳重な緘口令が敷かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "公判中に、証人への緘口令が議論された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "私はもちろん何事にかかわらず知り得たことは、早速読者諸君の前に提供することを、私の光栄ある本務と信じているが、しかし本件だけは、彼から固い緘口令が布かれてあったのであった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "その緘口令の解除となったのは、つい先月の三日のことである。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾向　一九四五年八月以後戦時中緘口令をしかれていた綜合雑誌が急速に創刊、再刊された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "松田文相に呼びつけられて、管下の美濃部派自由主義教授達に緘口令を敷いたと聞いているのは本当だろうか。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て正造が自ら予言したごとく、その地方から鉱毒被害のこえを葬ることによって彼もまた緘口令を敷かれた感があった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
