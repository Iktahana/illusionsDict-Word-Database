        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "かつてここは王族専用の狩場として厳重に管理されていた森だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "オンラインゲームのアップデートで、経験値効率の良い新しい狩場が開放された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "猛禽類にとって、遮るもののないこの平原は絶好の狩場となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は週末になると、カメラを片手に野鳥たちの「狩場」を求めて山に入る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「わしは、狩場を見てから帰る。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "狩場の主任のハドソンは蠅取紙の注文の一切を必ず受けると知らせた。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで文節に切って、ひとつおきに読んでみたが、『もはや順調にロンドンへ終わった』や『鶏肉はすべて出荷が狩場の』では何の光も見えない。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、この「狩場」や「雌雉」というのは、何だろうね。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は Morois の沢辺に出て、狩場を遁れた獣のやうに、疲れて眠る。",
              "citation": {
                "source": "魔睡",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし真面目な時の馬は確かに情款濃く、撫愛されて悦び他馬の寵遇を嫉み同類遊戯するを好み勇んで狩場に働く。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "お身たちは狩場の鳥獣じゃ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "事変の起りやすい狩場などでも、彼は軽捷に立ち回って、怪我一つ負わなかった。",
              "citation": {
                "source": "恩を返す話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　象牙の机　贋せ藍丸王は狩場から宮中へ帰って、晩の御飯を済ますと直ぐに、家来に云い付けて、自分の室に新しい椅子を四ツ運ばせて、象牙の机の周囲に並べさせた。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、石狩場所を目当てにして募られた漁夫のうちにいた一人であった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫吉は、王様のご前へ出ると、うやうやしくおじぎをして、「王様、わたくしは、主人カラバ侯爵からのいいつけで、きょう狩場で取りましたえものの兎を一ぴき、王様へけん上にあがりました。",
              "citation": {
                "source": "猫吉親方",
                "author": "またの名　長ぐつをはいた猫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからふた月三月のあいだというもの、しじゅうカラバ侯爵のお使だと名のっては、いろいろと狩場のえものを、王様へけん上しました。",
              "citation": {
                "source": "猫吉親方",
                "author": "またの名　長ぐつをはいた猫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　ある日のこと、猫吉は、いつものように狩場のえものをけん上しに行きました。",
              "citation": {
                "source": "猫吉親方",
                "author": "またの名　長ぐつをはいた猫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　王様は、このさけび声を聞くと、なにごとかとおもって、馬車の窓から首をお出しになりました、見ると、しきりにどなっているのは、これまでに、たびたび狩場から、いろいろと、けっこうなえものを持ってきてくれた猫なので、王様はおそばの家来に、はやく行って、カラバ侯爵をお助け申せ、といいつけました。",
              "citation": {
                "source": "猫吉親方",
                "author": "またの名　長ぐつをはいた猫",
                "note": "青空文庫"
              }
            },
            {
              "text": "農耕が発達するに連れて、平地の生存に堪えられない是等狩猟を生命とする民衆の一団は、狩場であった森林の喪失と獲物の減少と相待って、次第に其生活に都合の好い山奥に逃避することを余儀なくされたであろう。",
              "citation": {
                "source": "山の今昔",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな場合にも恋人同志は手を取り合わなければならないものと見え小次郎と浮藻とが手を取り合い、戦いは味方が勝っているので狩場で獣でも追うかのように勢い込んで追い駈けて来た。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "してお狩場はどの辺かな？",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へい、あの山でございます」「幾人ほどのご同勢であのお狩場へ参られたな？",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そういう噂でございました」　前髪立ちの美しい武士は裸身の大男を見返ったが、「お聞きなされたか、はだか武兵衛殿、花村殿の狩倉に浪人組の勇士達も狩場に向かったという噂。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「向こうに見えるあの峰に、さては狩場があると見える。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて峰まで行き着いたので二人は四方へ眼を配り狩場やあると見廻わした。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其傍から左に杉並木の間を上って行けば、物見塚という小丘の上へ出られる、頼朝が狩場の働きを見物した場所であると伝えられている。",
              "citation": {
                "source": "春の大方山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "辰の下刻、鳥見役の案内で狩場に立ちいでる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "丹頂の鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この文覚に逆ろうては後で罰が当りますぞよ、などと申し上げてもお聞き入れなくてのう、わしも今度という今度は、もう駄目かと思ったが、丁度那須野で狩があってのう、文覚もその間中狩場へついていって、ご機嫌を見計らっては申し上げたので、鎌倉殿もわしの根気よさにとうとう根負けなされたというわけじゃよ。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "狩場はほかの場所でもない。",
              "citation": {
                "source": "うすゆき抄",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「逃がしゃしませんが、手紙の作者は小僧じゃありませんぜ」「当り前だ、手紙を書いたのはお狩場の四郎という、日本一と言われた大泥棒だ」「えッ、そうと知っていたら、もう少し責めようがあったのに、――そのお狩場の四郎が、親分へどんな事を言って来たんで？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "巨盗還る",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三年前江戸で鳴らしたお狩場の四郎。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "巨盗還る",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし天下の大盗と言われたお狩場の四郎はこのまま老い朽ちる気は毛頭ない。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "巨盗還る",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、渡り鳥が海のうえで深い霧などに襲われたとき方向を見失い光りを慕ってただまっしぐらに飛んだ罰で燈台へぶつかりばたばたと死んだところなのですよ。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "常念坊は、そのきつねのことを、わすれようわすれようとするように、ちょうちんのあかりばかりを、見つめて歩きました。",
              "citation": {
                "source": "のら犬",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
