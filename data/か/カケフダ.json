        "examples": {
          "standard": [
            {
              "text": "パン屋の入り口に、「本日焼きたてのパン」と書かれた小さな掛け札が掛かっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「すみません、しばらく閉まっています」とドアに手書きの掛け札が。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「静かにしてください」という注意書きの掛け札が、壁に掛けてあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "四　翌朝になると、寿平次の家では街道に接した表門のところへ新しい掛け札を出す。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "信濃国、妻籠駅、郵便御用取扱所　　　　　　　　　　　　　　　青山寿平次　こんな掛け札もお民としては初めて見るものだ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネチーブか達磨を気取る寒かな　汽車の上等室に「Europeans only」の掛け札あるを見る。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "面会はお断りです」などという手厳しい掛け札さえぶら下がっているのだから、流石の本田も辟易して、空しく帰る場合も一度ならずあった。",
              "citation": {
                "source": "陰獣",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
