        "examples": {
          "standard": [
            {
              "text": "「このヨガスタジオでは、火木金に朝ヨガクラスがありますよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「月末は締め作業で忙しいので、火木金は残業になることが多いんです。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「来週の火木金は、出張で不在になりますので、何かあれば事前にお知らせください。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このショップの限定セールは、火木金だけの特別価格なんだって！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それから週間の日の月火木金の四日、午前十一時半から十二時まで校長先生の新約聖書の研究があつた。",
              "citation": {
                "source": "身についたもの",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天は唯一絶対ですが、その功用は水火木金土、その気候は春夏秋冬、日月星辰を引き連れて、風師雨師を支配するものと、私はこんなように承わって居ります」「ふうん、大変むずかしいんだな。",
              "citation": {
                "source": "岷山の隠士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある書の序文に曰く、　およそ天地の間、万物を生じて、水火木金土の五行の気をしき、万物その気を受けざるはなし。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
