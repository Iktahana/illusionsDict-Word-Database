        "examples": {
          "standard": [
            {
              "text": "「先生、この問題は角座標を使って解いたほうが計算が楽になりそうです」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "レーダー画面には、目標物の位置が原点からの距離と角座標で刻々と表示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "三次元空間における位置特定には、デカルト座標の他に角座標も多用される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「えーっと、ここの角座標を正確に割り出すには、まず原点を再設定しないと」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "日本の絵画には概括的に見て、仏教的漢詩的な輸入要素のほかに和歌的なものと俳句的なものとの三角形的な対立が認められ、その三角で与えられるような一種の三角座標をもってあらゆる画家の位置を決定することができそうに思われる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
