[
  {
    "uuid": "30244ca7-a593-5321-815d-e684cb76f936",
    "entry": "勝手気まま",
    "reading": {
      "primary": "かってきまま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
