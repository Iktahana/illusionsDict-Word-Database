        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "おとぎ話に出てくる鬼は、常に恐ろしい金棒を携えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祭りの出し物で、赤鬼が手に持った金棒を振り回して観客を沸かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はまるで鬼に金棒を得たように、さらに力を増した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鍛冶屋の店先には、様々な大きさの金棒が飾られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
