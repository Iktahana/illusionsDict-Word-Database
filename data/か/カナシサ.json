[
  {
    "uuid": "6b9d4ba9-4376-56ee-b504-a25d1c8986de",
    "entry": "悲しさ",
    "reading": {
      "primary": "かなしさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
