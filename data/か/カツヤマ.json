    "definitions": [
      {
        "index": 1,
        "gloss": "Katsuyama hairstyle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "現代風にアレンジされた勝山結い、これがまた粋でいいね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔の映画で、太夫さんが見事な勝山を結っていたのが印象的だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "舞妓さんの本格的な髪型は、月ごとに変わるんだけど、勝山は少し特別な日にも結われることがあるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この着物には、やはり勝山のような古典的な髪型がよく似合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "洪水には荒れても、稲葉の色、青菜の影ばかりはあろうと思うのに、あの勝山とは、まるで方角が違うものを、右も左も、泥の乾いた煙草畑で、喘ぐ息さえ舌に辛い。",
              "citation": {
                "source": "栃の実",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞳を勝山通のアパートまで送って行き、アパートの入口でお帰りと言われて、すごすご帰る道すうどんをたべ、殆んど一文無しになって、下味原の家まで歩いて帰った。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは二十六七に見える女で、髪を勝山｜髷にして紫の手柄をかけていた。",
              "citation": {
                "source": "偶人物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日、勝山通の日本畳新聞社へ出掛けた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝山通四丁目で降りて、新開地らしく雑然と小売店や鉱業事務所が両側に並んでいるコンクリートの道を勝山通八丁目の生野女学校の傍まで行ったが、それらしい会社は見つからなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝山通八丁目まで行って、飯屋で労働者にまじって十二銭の昼食をたべたあと、喫茶店の長椅子の上で死んだようになって横たわっていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅に、（しかし、社長はあの不正の手段で、五、六万円の金を溜めて来たんだ）と思うと、気が楽になり胸を張って勝山通四丁目の停留所の方へ歩いて行ったが、直ぐに気の抜けた歩き方になった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お友達御免を蒙ります、手前はその日本橋人形町通り、勝山と申しまして、」「勝山さん、」取次は聞き馴れないという顔色。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いえ、手前がその勝山と申すんじゃあございませんので、」「ははあ、」「御当家先生様の、ええ、お弟子でございまして、その勝山と申しますお嬢さんからちょいと頼まれました、手前｜使の者でございます、少々お目に懸りとうございますが、お宅でいらっしゃいましょうか、お友達、お取次を願いとう存じますんで、へい。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」八「はあ、貴方がその勝山さんのお使？",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その勝山から託りましたので、奥様にもお目にかかって御挨拶を。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙って額着くと、鴨川大人は御自慢の細君、さもあらんという顔色、ぐッと澄して、「勝山さんの使の方です。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」十「そう、貴方よくいらっしゃいましたね、勝山さん、あのお夏さん、お変りはないの、ああ、ついこないだおいでなすったのね。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勝山さんのお使ですって、」と令夫人｜傍から引取って引合せる。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私等が畠のよ、勝山さんのお夏さんを何だと思ってるんだ、何と見損いやあがったい、いけ巫山戯た真似をしやあがって、何だ小股がしまってりゃ附合がむずかしい？",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛吉は紋床で謂った、鴨川はその敵で親の仇とも思う怨がある、それは渠がかねて愛顧を蒙る勝山の女お夏というのに就いたことである。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小間使はともあれ半季がわりの下働きは、上の弟子なる勝山さえを知らずして、その浴衣、その帯、その雪踏、殊に寝惚目なり、おひるに何か取ったらしい、近い辺の鳥屋の女中と間違えたのである。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（そうだ、勝山さん煽いでお上げ、）とお夏が直に命を奉ぜぬのを、歌詠の大人は寛仁大度、柔かに教えるがごとく仰せられる。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だってその、あの毛唐人奴等、勝山のお嬢さん、今じゃあ柳屋の姉さんだ、それでも柳橋｜葭町あたりで、今の田圃の源之助だの、前の田之助に肖ているのさえ、何の不足があるか、お夏さんが通るのを見ると、大騒動をやりますぜ。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "診察室を出て来たが、深川の勝山、まだ世盛の頃で、お夏その時は高島田の、年紀十七であった。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜッてますと、あとで分りましたが、そのお夏さんの勝山という家は、私の亡くなりました父爺が、船頭で、奉公人同様に久しい間御恩になったのでございました。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が勝山に伺うようになりました翌年、一昨年ですな。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体この橋も、池を渡った向うも、旧はやっぱりその時分の勝山さんぐらいな御大家の庭だったんで、橋がまた庭の景色の一ツだったそうですが、馬、車なんざ思いも寄らず、人ッ子だって通りやしません。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中綺麗にして、藤棚の池へ倒れ込んでるのなんぞ直したら、お夏さんの祈祷所みたようのもの、勝山さんだけの弁天様の堂を建立しようなんてね、いっていなすった、その埋地へ遁げて来たんでさ。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえ、私ばかりじゃあなかったんで、火事場では、官女が前後を取巻いて、お夏さんが東の方に、通ったと謂う評判で、また勝山が焼けるちっとばかり前、緋の袴を穿いた素白な姿の者が、ちょうどその屋根の上あたりを走るのを、汐見橋の上で見た者がある、前兆だなんて種々なことを謂ったもんです。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういいますと、お夏さんが我儘三昧、親御は甘いばっかりに聞えましょう、けれども因縁事なんですよ、だって勝山のものといったら、池に浮してあった材木まで焼けッちまいましたから。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と莞爾したが、勝山の世盛には、団扇車で侍女が、その湯上りの霞を払った簪の花の撫子の露を厭う日覆には、よその見る目もあわれであった。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
