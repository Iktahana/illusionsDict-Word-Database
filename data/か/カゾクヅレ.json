    "definitions": [
      {
        "index": 1,
        "gloss": "taking the family along",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "公園は、週末になると家族連れで賑わっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あのレストラン、子供椅子もあるし、家族連れにはいいかもね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あ、見て！あそこ、可愛い家族連れが写真撮ってるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "家族連れで出かけるとその上に家族にこだわるので疲れ方が一層はげしかった。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルの食堂へはいって見ると、すぐ向うの席に有名な某音楽家の家族連れがいる。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々は家族連れの客も来ていたが、みんなつつましい、静かな人達のようであった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "椰子やゴムの木の鉢と入り乱れて並んだ白いテーブルを取りかこんだ人々の群れには、家族連れも多かったが、ともかくも自分らのように不景気な男ばかりの仲間はまれであるように見受けられた。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十年四月、中央公論）　　　　　十六　歌舞伎座見物　二月の歌舞伎座を家族連れで見物した。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後にも家族連れの海水浴にはとかく色々の災難が附纏ったような気がする。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里の珈琲店は給仕も男で、客は家族連れで行ける極めてさっぱりしたものです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十年五月、渋柿）曙町より（二十五）　六月九日の日曜に家族連れで上野精養軒の藤棚の下へ昼飯を食いに行った。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し家族連れの移住費を差し引くと、一年の開墾にしか従事することが出来なくなる。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "その壮観を見物しようとして押しかけて来た家族連れの群集で、夜の赤い広場がまたえらい人出だ。",
              "citation": {
                "source": "勝利したプロレタリアのメーデー",
                "author": "――モスクワの五月一日――",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛らしい小女給を置いて、普通の喫茶店にあるものの外、しる粉やお手の物の和菓子も食べさせるといった風で学生や家族連れの客でいつも賑っている。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度持ち山の検分に家族連れでやって来て、二三日吉野屋に滞在して行った福本の小兵ないかにも精悍な顔付をみんなは思ひ浮べた。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊丸の船の中で御一緒になつた、東京灣汽船の林專務の話では、此島をやがては家族連れの遊山地にしたい心組だと云ふ事でありましたが、いゝ意味での遊山地にするには、仲々前途遼遠な事でせう。",
              "citation": {
                "source": "大島行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうあのやうな流行なぞは早く根をたつて、林專務の云つてゐられた、家族連れの小樂園が早く出來るといゝと思ひます。",
              "citation": {
                "source": "大島行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の暑い盛りになると、例年の通り、中野さんは家族連れで常陸の海岸へ行った。",
              "citation": {
                "source": "叔父",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は大きな松の木蔭に並べてある食卓にビイルを傾けた後、ホテルの車を雇つて、長崎へ帰るべき峠を越して行くと、またしても同じ道を行く米国人の家族連れが、峠や谷川の景色の美しい事をば、まるで自分の家の庭でも賞めてくれるやうに、自分に向つて話しかけるのであつた。",
              "citation": {
                "source": "海洋の旅",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車の中から寒そうに現れる家族連れがある。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って湯治場の景気もたいそうよくなり、おっつけ晴れて乗り込んでくる家族連れの一団体や、芸者半玉を引き連れたお大尽連が絶えなかった。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "この貝は、この付近の渚でいくらでもとれるそうで、ちょうど日本の潮干狩のように、家族連れでこの貝を掘りにいくのが、土地の風習になっている。",
              "citation": {
                "source": "西洋の浜焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中にあって、比較的成功したのは、いわゆる家族連れの客を主とするように経営の方針を進めて行った少数の人々である。",
              "citation": {
                "source": "温泉１",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり管理部長と契約部長の間の契約なので、いちいち当ってみないかぎり、どんな人間が入っているのかわからないことが多いので……」「おたずねしたのは、そういうことじゃない……最初、シュラーというひとが、家族連れで、むこうの洋館に住むようになった。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族連れのＧＩが、窓ガラス越しにカメラをむけて、しきりにシャッターをきっている。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生は、今、おめかしの最中……家族連れで旅行の相談がまとまつたところなの」　と、凜子は、かくさずに言つた。",
              "citation": {
                "source": "菜の花は赤い",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "デッキには、すでに大勢の子供や家族連れが詰めかけ、フェリーの欄を埋めていた。",
              "citation": {
                "source": "湯けむり",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "この湖畔の小村では、夏になると附近の都会から多勢の避暑客が家族連れで来るので、大抵の家は二間三間宛よぶんな部屋を拵えて、夏場に金を儲ける工夫をしている。",
              "citation": {
                "source": "一つの出来事",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の東京湾の釣り場　毎年秋の彼岸の声を聞くと、東京周辺の川筋一帯、多摩川下流の六郷川口、大森、品川、深川、東雲橋、洲崎、葛西橋、小松川と東京湾へ流れ出す川口は、日曜ともなると、女子供、家族連れで、陸張りが何千人というくらいたいへんな人出になる。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戰後二年しかたつてゐないのに、花見電車は滿員でしたし、山道は家族連れの行樂の列でたいへんな賑はひです。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真機をぶらさげ子どもをかかえた家族連れ。",
              "citation": {
                "source": "他人の夏",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時のざわめきは、いつの間にか止んで、大分静かになった九月の浴湯を楽しんでいるのは、富山あたりの町かたの、冨裕らしい家族連れの湯治客など、それも幾組か数えるほどにすぎない。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈日劇東宝〉と〈丸の内ピカデリー２〉でかけている映画が両方ともちょうど今終わったばかりらしく、パンフレットを持ったアベックや家族連れと一緒にエレベーターに乗り、一階まで降りる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
