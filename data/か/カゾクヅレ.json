[
  {
    "uuid": "16627eb5-3b3b-52c3-a106-155df92d8086",
    "entry": "家族連れ",
    "reading": {
      "primary": "かぞくづれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
