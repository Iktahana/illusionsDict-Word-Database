[
  {
    "uuid": "fe825423-1393-5753-a241-76a82a1f9541",
    "entry": "蚊柱",
    "reading": {
      "primary": "かばしら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
