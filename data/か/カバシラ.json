    "definitions": [
      {
        "index": 1,
        "gloss": "mosquito swarm",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夕暮れの川沿いを歩いていたら、目の前に大きな蚊柱が立っていて思わず息を止めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自転車に乗っている最中に蚊柱に突っ込んでしまい、目の中に虫が入って散々な目に遭った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわっ、あそこの電柱の下、すごい蚊柱だよ。別の道を通ろうか」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "街灯の周りに集まった蚊柱が、薄暗い夜道で不気味に揺れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それからまたどの映画にも必ず根気よく実に根気よく繰返される退屈な立廻りが、どうも孑※の群や蚊柱の運動を聨想させる。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の子供の時分、郷里ではそういう場合に「おらのおととのかむ――ん」という呪文を唱えて頭上に揺曳する蚊柱を呼びおろしたものである。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊柱の声の様に聞こえて来るケルソン市の薄暮のささやきと、大運搬船を引く小蒸汽の刻をきざむ様な響とが、私の胸の落ちつかないせわしい心地としっくり調子を合わせた。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊柱のように唸るんでございますもの、そんな湯呑には孑孑が居ると不可ません。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "可恐い夕立雲は、俥の行くにつれて、峠をむかう下りに白刃を北に返した電光とともに麓へ崩れて走つたが、たそがれの大良の茶屋の蚊柱は凄じかつた。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜘蛛の圍の幻は、却て鄙下る蚊帳を凌ぎ、青簾の裡なる黒猫も、兒女が掌中のものならず、髯に蚊柱を號令して、夕立の雲を呼ばむとす。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は茂れる中より暮れ初めて、小暗きわたり蚊柱は家なき處に立てり。",
              "citation": {
                "source": "森の紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色く暮れ残った空に蚊柱の廻る音を聞きながら、三造はその前にしゃがんで手を合わせる。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お葉は門にぴたりと身をよせて、そこに蚊柱のたつのを、ぢつと眺めてゐたのであつた。",
              "citation": {
                "source": "三十三の死",
                "author": "素木しづ子",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに不幸が蚊柱のように徒党を組んで押し寄せてくる可能性は、確実に存在するということだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "檐に立つた蚊柱が崩れて軈て座敷を襲うた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうたそがれ時で、電灯がともって、その周囲におびただしく杉森の中から小さな羽虫が集まってうるさく飛び回り、やぶ蚊がすさまじく鳴きたてて軒先に蚊柱を立てているころだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕暮になると、夥しい蚊が軒に蚊柱を立てた。",
              "citation": {
                "source": "ある僧の奇蹟",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこいらにいくつかの蚊柱が立ち、蝙蝠が不器用な羽叩きをして、音もなく飛びまはる夕闇の、ほんのちよつとした間に烏瓜の花は咲き、そして誰もの眼に触れるのを厭ふやうに呼吸をひそませて、花弁の白みをあたりの薄暗がりにそつと沈ませてゐた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち、細な綿の粉は動揺する小女たちの一群の上で、蚊柱のように舞い上った。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のない聳え立った円塔の上では、燕が蚊柱のように群り立って飛んでいる。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "御忌の鐘皿割る罪や暁の雲つま猫の胸の火や行く潦夜桜に怪しやひとり須磨の蜑蚊柱の礎となる捨子かな人魂は消えて梢の燈籠かなあさましや虫鳴く中に尼ひとり火の影や人にて凄き網代守　句の佳否に関らず、これらの句が与へる感じは、蕪村にもなければ召波にもない。",
              "citation": {
                "source": "点心",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊柱や新粧の女門にたつ（明治四十年）",
              "citation": {
                "source": "飛鳥山遠足",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の夕暮、家の玄関に立って、その二階の方を眺めると、簷のところに蚊柱が揺れていて、蝙蝠の姿も閃いた。",
              "citation": {
                "source": "昔の店",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥州方面へ落ちようとして、三十郎とおきたとは夏の夜の、家の軒へ蚊柱の立つ時刻に、千住の宿を出外れた。",
              "citation": {
                "source": "一枚絵の女",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちよいと／＼兄さん」「おぶだけ上つてよ」「知つてますよ、さつきの旦那」の嬌聲から、「何言ふんでえ、溝ツ蚊女郎」「ヘツ、芥溜野郎」のやりとりまで、すべてこの蚊柱の下で演ぜられる。",
              "citation": {
                "source": "荷風翁の發句",
                "author": "心猿",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は誰をも恨まぬ、私はたゞ私を憤る、私の心を嘆く………　不忍の池に星が映り、絃歌が聞え、根津の裏町に蚊柱の立迷ふ頃、私は全く疲れて家へ歸つて來た。",
              "citation": {
                "source": "歡樂",
                "author": "永井壯吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤八猿の着ている赤いちゃんちゃんこと、お葉の冠っている白手拭とが、もう蚊柱の立ち初めている門の、宵闇の中で際立って見えた。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めに「音の触感」に関する研究の報告の紹介があって、そのあとに呪文によって蚊柱を呼び下ろすという子供の頃の経験の追憶が書かれている。",
              "citation": {
                "source": "露伴先生と科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸のもの音が、去った夏の夕べの蚊柱のように、かすかに耳にこもるきり、大川の水は、銀灰色に濁って、洋々と岸を洗っています。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お高は、夏の宵の蚊柱がくずれるように、ぶうんと音を発して飛びかわす拳や下駄や、棍棒の下をくぐって、しなやかな手をふって逃げまわっていた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄子さんの事は思ひ出すまいとしても、蚊柱めいた蟲の群が、本堂の軒に立つ靜かな夕方などは、暗澹たる心の中に思ひ出された。",
              "citation": {
                "source": "受驗生の手記",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "発句は、蚊柱やけづらるゝなら一かんな　　宗因宗因の発句にはこの他にもいろいろの種類のがありまして貞徳時代のようなものもあり、また後年の芭蕉時代に似よったものもありますが、まずこの句のごときが彼の程度を代表したものといってよかろうかと思います。",
              "citation": {
                "source": "俳句とはどんなものか",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊柱が立っている随分大きな蚊柱だ、柱という以上は一かんな削ってやりたいというのであります。",
              "citation": {
                "source": "俳句とはどんなものか",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
