      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "improvement (to a piece of writing or painting)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "小説のコンクールに出す前に、プロットの矛盾を解消するために第3章へ大幅な加筆を加えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "画家は展覧会の前日までキャンバスに向かい、波のしぶきの表現に細かな加筆を繰り返していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「先生、この部分に少し加筆するだけで、随分と文章の印象が良くなりますね」と編集者が提案した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "脚本家は締め切り直前まで、主役の心情を補強するための加筆を続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ところが、信吉はその反響を感じているうちに、それが自分の知らぬ間に誰かの手で加筆追加された幕だということを、ふと忘れてしまうくらい、だらしなくやに下り、その幕の成功がそのまま自分の成功だと錯覚してしまった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたたび、先日の贋百姓の描写に、あれこれと加筆して行きながら、私は、市井に住むことの、むずかしさを考えた。",
              "citation": {
                "source": "市井喧争",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つの章の冐頭に、簡單な解説は試みたが、更に多少の加筆が必要に思ふ。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでゐて、以来加筆せねばならなくなつたといふことは羞恥に堪へぬ次第ではある。",
              "citation": {
                "source": "文庫版『雀の卵』覚書",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つの章の冐頭に、簡単な解説は試みたが、更に多少の加筆が必要に思ふ。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も第一編は春廼舎の加筆がかなり多かったから多分の春廼舎臭味があった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや謙遜な二葉亭は文章の造詣では遥に春廼舎に及ばないのを認めていたから、己れを空うして春廼舎の加筆を仰いだ。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "春廼舎の加筆した『浮雲』第一編は別として、第二編となると全然従来の文章型を無視した全く新らしい文体を創めた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの際この書に色々の点において加筆したいのであるが、思想はその時々に生きたものであり、幾十年を隔てた後からは筆の加えようもない。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜痴居士が席を起って行ったあとで、団十郎は今度の「黄門記」の江戸城中で光圀が護持院の僧を説破するくだりは、桜痴居士の加筆に成ったことを話して、「どうして河竹にあんなことが書けるもんですか。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠慮なく加筆したところもあり、削ったところもございます。",
              "citation": {
                "source": "日記・書簡",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ジャンヌ・ダルク」以来彼女が傾倒し師事していた当時の大家ルパアジュが加筆したような噂がつたえられた。",
              "citation": {
                "source": "マリア・バシュキルツェフの日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九四九年一月加筆）　一九三一年、十月、十一月、十二月とかかれたこの文章はここで終っている。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "全面書き改めてもらうか、編集者の方で徹底的に修正加筆するか（もし可能なら）、いずれにするにしても一度原稿を拝見したいと思います。",
              "citation": {
                "source": "平野義太郎宛書簡",
                "author": "一九三二年九月八日",
                "note": "青空文庫"
              }
            },
            {
              "text": "今これを一冊子にまとめて公にせんとするに当たり、余は幾度かこれが訂正増補を企てたれども、筆を入るれば入るるほど統一が破れて襤褸が出る感じがするので、一二文字の末を改めたほかは、いったん加筆した部分もすべて取り消して、ただ各項の下へ掲載された新聞紙の月日を記入するにとどめておいた。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの二個所がおもなる加筆であるが、しかしそれでさえ、こうして印刷してみると、いかにもよけいなこぶができたようで、むだなことをしたものだと後悔している次第である。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手紙の署名と日附を変えて、ちょいちょい加筆しただけでも、熱情的な、すばらしい恋愛小説が出来ます。",
              "citation": {
                "source": "ふみたば",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこゝに最近二ヶ年間の作品を随処に加筆し又二三は改題をしたりしてまとめたのは、作品として読んでもらうためにではない。",
              "citation": {
                "source": "障子のある家",
                "author": "尾形亀之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして更に、近年の大衆向きの作品には、勿論加筆はしたろうが代作がいくつもあったということを聞いては、私ならずとも驚く人が多かろう。",
              "citation": {
                "source": "十一谷義三郎を語る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し私も次第に年をとり、何時までもコンな事に勉強するでもなし、老余は成る丈け閑静に日を送る積りで、新聞紙の事も若い者に譲り渡して段々遠くなって、紙上の論説なども石河幹明、北川礼弼、堀江帰一などが専ら執筆して、私は時々立案してその出来た文章を見て一寸々々加筆する位にして居ます。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、散々加筆した原稿をながめ涙の出そうな気になった。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「船中」と「同窓」は中途で厭になつて止めたのを後に加筆稿了し「楡の樹蔭」はその頃の日記の中から拾ひ集めた彼地の夏の小景を敍したものでこれだけは新しく書いたと云ふ方が適當かもしれない。",
              "citation": {
                "source": "貝殼追放",
                "author": "「海上日記」の序",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に調子は莊重を旨として八七調に定めたがそれにしても、坪内、東儀、島村諸氏の意見を斟酌し最後に坪内教授の校閲、加筆を請うてさしもの大作を完成した。",
              "citation": {
                "source": "校歌「都の西北」と私",
                "author": "相馬御風",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなら、誰が見たって、まさかこんな加筆をやったと思うまい。",
              "citation": {
                "source": "すり替え怪画",
                "author": "烏啼天駆シリーズ・５",
                "note": "青空文庫"
              }
            },
            {
              "text": "加筆されて怪画となり果てた名画「宝角を持つ三人のニンフ」は、そのよき静かな応接間に睡りをとったのであった。",
              "citation": {
                "source": "すり替え怪画",
                "author": "烏啼天駆シリーズ・５",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや手前と致しましては加筆の必要認めませぬのみかかえって蛇足と心得まする」「えい自惚も大抵にせい！",
              "citation": {
                "source": "北斎と幽霊",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――尤も、茲に掲出するからには、作意が主で技法はどうでもよいことであるからして、吉村がそれに加筆したならば恐らくこういうものになったろうかと、その結果のものを持出すのである。",
              "citation": {
                "source": "在学理由",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "理論は理論でちやんと言つてゐるのだから、その合ひの手に時々読者を笑はせたところで、それによつて理論自体が軽薄になるべきものではないのだから、ちよつと一行加筆して読者をよろこばせることができるなら、加筆して悪からう筈はない。",
              "citation": {
                "source": "大阪の反逆",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑木雑木こそうれしけれ、そのもみぢも、こもごもに、日のひかりさしかひつつ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月までは、胸にふくらんで大きかった両方の乳房が、すっかり肋骨にくっついてしまって、乳首が黒く小さくかたく、丁度花のしぼんだあとのやうになってるのを見ると、もうなんの誇る所もない、美しさもない、つかひつくした、老いはてた身体のやうに思ったりした。",
              "citation": {
                "source": "秋は淋しい",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
