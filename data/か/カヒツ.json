[
  {
    "uuid": "52b976f1-ef91-543a-aac4-5b38b2b868bc",
    "entry": "加筆",
    "reading": {
      "primary": "かひつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
