[
  {
    "uuid": "c56d10da-c5b7-5f32-bada-762cd2b782b6",
    "entry": "噛み締める",
    "reading": {
      "primary": "かみしめる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
