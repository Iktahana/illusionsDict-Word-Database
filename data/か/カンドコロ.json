    "definitions": [
      {
        "index": 1,
        "gloss": "position on the fingerboard (of a shamisen, koto, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そののち、この固い土台の上に自らを据え、いかなる推論を引き出しうるか、謎全体の要となる勘所がどこにあるかを見定めることこそ我らの役目。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、作品ファイルには、晴眼者がパソコンで読む以外のさまざまな利用の可能性があることを意識していなかったように、公有となった作品の取り扱いにあたって、何を重視し、どう振る舞うべきかの勘所を、我々は明確には意識できていなかった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か生活といふものの勘所を握つてゐるといふ感じだ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "否応なしに――全く、否応なしに、私は――いはば自我といふ意識が、何かしら中心となるべき勘所が、私の中に見当らないのだ。",
              "citation": {
                "source": "蝉",
                "author": "――あるミザントロープの話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その難問題をいとも簡単に勘所を掴んで説き起こし、説き去られるということは女史の聡明さを証明するものであろう。",
              "citation": {
                "source": "鮟鱇一夕話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙な勘所を押えることの天才である。",
              "citation": {
                "source": "詩人への註文",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいう不思議な勘所を押える力は天賦のものであろう。",
              "citation": {
                "source": "詩人への註文",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも今さら杜詩をひき出すまでもなく、芥川の芭蕉論などにも、この勘所を押える力については、見事な説明がある。",
              "citation": {
                "source": "詩人への註文",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学に縁の近い立場から、こういう勘所について、我流の解釈をしてみよう。",
              "citation": {
                "source": "詩人への註文",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその引き金が巧く働けば、それが勘所にひびくのであろう。",
              "citation": {
                "source": "詩人への註文",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前だつて一生懸命になりや、ちやんと勘所を押へて來るぢやないか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "がらツ八手柄話",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前だって一生懸命になりゃ、ちゃんと勘所を押えて来るじゃないか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "ガラッ八手柄話",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、媒介が媒介自身に於て完了出来るようなアウトノミーを有っているかのように絶対化されることが、絶対媒介という観念の勘所なのだ。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "態度の不作法なるに拘らず、この婦人の建築のながめ方には勘所を心得たものがある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに道具屋をはじめたのは勘所だ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは神尾が今日までの体験の持越しで、今以てうだつが上らないのみか、ますます深みへ落ちて行く勘所だ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じような配慮から、その年齢と代数とが組み合わされているのであったら、教えかたで、面白さのかんどころの掴みかたを先ずわからせて行かなければ、なかなか苦しい課目になると思う。",
              "citation": {
                "source": "私の科学知識",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝのかんどころを外さねば大丈夫である。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つぐらいきっと、かんどころがずった。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の生活感情にいろいろなかんどころがあるのね、そのことに関しては敏感であるという、かんどころがあるのね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
