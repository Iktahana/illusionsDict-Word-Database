[
  {
    "uuid": "a9fc11b1-8e26-5155-ac86-481f429e16bf",
    "entry": "勧説",
    "reading": {
      "primary": "かんぜい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "urging",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は、ボランティア活動への参加を熱心に勧説した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の進路について、親が先生から勧説を受ける場面がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい健康食品の購入を、友人に勧説された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の勧説もあって、私はそのプロジェクトに参加を決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "峠は近道（いひかへれば旧道）を歩いた、道連れとして面白い人物が待つてゐた、彼は酒好きの左官、女房に死なれて焼糞になつてゐるが、近く後妻を貰ふつもり、どうでせうかと訊く、是非お貰ひなさい、それが最も賢明な策ですと勧説して別れた。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは母にまさか、その通りにも言えませんから、ただ池上が勧説したことだけを母に申しますと、母は「ふーむ」と鹿爪らしい顔で諾いていましたが、顎を大きくしゃくって、「いよ／＼あの男は、本気になってそう言い出したのかい。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "碧蹄館血戦之事　平壌敗れたりとの報が、京城に達したので、宇喜多秀家は三奉行と相談して、安国寺｜恵瓊を開城へ遣して、小早川隆景に、京城へ退くよう勧説した。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の父は嘗つて藩の宗門改めに会って斬られた者達であるが、角蔵、三吉は各々の父の髑髏と天主像を秘かに拝して居たのを、此頃に至って公然と衆人に示して、勧説するに至った。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "形勢｜暗澹たるを憂いた尾、越、土の三侯は、慶喜が大阪にいては、いよいよ朝幕の間が疎隔するばかりであるから、再度おだやかに上京したらどうかと、勧説したが、幕府側の識者は、今おだやかに上京するなど、最も不利である。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は本より論壇の上にこそ紅葉と対敵したが、先方はどうあろうと私交上ではやはり親友のツモリでいたから、胸襟を開いて黒岩の意嚮を話し、紅葉一身の利害のために黒岩との提携を勧説した。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで三山初め有力なる朝日の社員は二葉亭をしていよいよ力を文学方面に伸ばさしめようと百方勧説した。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "針のみぞから天を覗くようなことを言い前にして、金を集めようという、大騙りじゃ」と、中には市九郎の勧説に、迫害を加うる者さえあった。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "有王が、涙を流しての勧説も、どうすることもできなかった。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今少し何とか景気を盛りかえすまで、麹町の屋敷に止まっているように、くどく彼女に勧説したのであったが、小夜子は七年間の不自然な生活も鼻についていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　押問答をしているうちに、一人の青年がそう言って庸三を勧説した。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その六十九　矢島優善をして別に一家をなして自立せしめようということは、前年即ち安政六年の末から、中丸昌庵が主として勧説した所である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この尊王旨義ははなはだ明白なり、然りといえども当時論者は政府部内の人にあらずして一個の人民なり、しかしその述ぶるところは時の政府に忠告するにあらずして同胞人民に勧説するにあり、しからばこの立論は少しく奇なりと言うべし。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の勧説にしたがって、この夜廻に加った事を、益々悔んでいる様に見えた。",
              "citation": {
                "source": "遺産",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ実に法典実施延期論の開戦であって、英法派は法学院を根拠として戦備を整え、仏法派は明治法律学校を根拠として陣容を整え、双方とも両院議員の勧誘に全力をつくし、或は意見書を送付し、或は訪問勧説を行い、或は商工会その他の実業団体より請願書を出さしめなどした。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も松平春嶽公あたりよりも同じ勧説があったので、慶喜公は遂に会桑侯等を率いて急に下阪せられることになった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "また維新の際にも或る米人のごとき、もしも政府において五十万｜弗を支出せんには三｜隻の船を造りこれに水雷を装置して敵に当るべし、西国大名のごときこれを粉韲する容易のみとて頻りに勧説したるものあり。",
              "citation": {
                "source": "瘠我慢の説",
                "author": "瘠我慢の説に対する評論について",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも大切な原則は自薦の原稿を警戒すること、しかもじっとして居ては有っても知ることが出来ないので、自分が主とし馳け廻って、よい著述を持つ人を見つけて勧説し、それを又同人に告げて承認してもらった。",
              "citation": {
                "source": "予が出版事業",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "報徳社などもこのチョコ米を勧説した。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の勧説してみたいのは、精細なる限地的の調査に伴のうて、ぜひとも遠近の各地方の事実を比較することである。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、そういう勧説を持って行っても、藤次が予算していたように、おいそれと寄進帳へ筆をつけてくれるのはすくない。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういった方法を少しずつ勧説してみたいと私は思っている。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓は百姓、山子は山子と、誰に勧説せられなくともみな一様の材料・形式のものを、つい近頃までは着て働いていたのである。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが私たちの、昔話と、それと繋がりの多い土地ごとの言い伝えとを、今後の南島研究の出発点として、勧説してみたいと思う理由である。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "是には帰化文人の支援勧説も推測せられるのみならず、興国期の文物制度の中には、名と実とをさながらに彼から採用した例も稀なりとせぬが、嘗をもって表示するところの我邦の一儀式のみは、少なくとも民族固有のものであって、遠い神代の昔から、連綿として記紀律令の時代まで、持続し来ったものと認められている。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶんあの辺を旅行してみたら、よい機会が横たわっているかもしれぬと、推測し勧説しうる場処はいくらでもあろうが、とてもそれ以上の約束を天然から徴することは不可能である。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
