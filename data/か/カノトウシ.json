        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖母は辛丑の生まれで、非常に働き者で忍耐強い人だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この国にとって辛丑の年は、変革の年として記憶されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "2021年は辛丑の年に当たり、コロナ禍からの回復が期待された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "三十四年（辛丑）　一九〇一○一月十日、三代目河竹新七死す、六十歳。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日、辛丑、霽、申刻甚雨雷鳴。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿六日、辛丑、晴、山城大夫判官行村、使節として上洛す、院御悩の事に依りてなり。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "程伊川先生の高弟｜趙顔子の子｜趙仲修が宣和辛丑の年、李彦平の落選を慰めて云う、「公は既に論語を知る。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "状に「天明元年辛丑冬、本藩有司伝命、擢為儒員、食俸三十口」と云つてあるのが即是である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」試に癸酉から九十三年溯つて見ると隋の開皇元年辛丑となるらしい。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天保十二辛丑小天台暁行口占。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」其二と三とは「天保十二辛丑途上口占」と題してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "晋安帝の隆安五年辛丑正月五日の作である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "辛丑は淵明三十七歳の時であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十　天保十二年辛丑の歳、枕山は二十四歳になった。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年辛丑十月に枕山は下総結城に赴き十一月半頃まで弘経寺に留っていた。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "『枕山絶句鈔』辛丑の集に「結城雑題寓弘経寺。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘化丙午より六年前は則天保十二年辛丑の歳である。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "天文十年辛丑六月二日、今日武佐より言上、地の三四尺或は一丈下に、木葉枝の朽たるを掘出す。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "天保十二年｜辛丑　前将軍家斉｜薨ず〔文恭公〕。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
