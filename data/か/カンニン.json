[
  {
    "uuid": "897b1e6e-28f0-575f-9b20-779ed75809f7",
    "entry": "堪忍",
    "reading": {
      "primary": "かんにん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
