      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "patience",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕はよくここにこうして坐りこみながら眼のまえをぞろぞろと歩いて通る人の流れを眺めているのだが、はじめのうちは堪忍できなかった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の無礼な嘲笑に対して、堪忍出来なかった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後から靠掛る樣に抱きついて密接顏を押し附けると、切なげに身を悶えて『堪忍してよ、芳ちやん………』『………』男は何か言はうとして、僅に手先を動かしたが『阿※』と一｜唸呻、言下に反繰返つて仰樣に僵れた。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子は母の枕元近くへいって、どうか私が悪かったのですから堪忍して……と両手をついてあやまった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さん、まアどうしたんでしょう」　僕の詞に励まされて母はようやく涙を拭き、「政夫、堪忍してくれ……民子は死んでしまった……私が殺した様なものだ……」「そりゃいつです。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ堪忍してくれ、政夫……私は民子の跡追ってゆきたい……」　母はもうおいおいおいおい声を立てて泣いている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民や、堪忍して、私は悪かったから堪忍してくれ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタニスラウスは先づ心配げな顔に、堪忍の表情を蓄へられる丈蓄へて、矢張さつきの肩の運動を繰り返して、溜息を衝いて云つた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "）どうぞ堪忍して下さい。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "親も兄弟もない僕の身には、こんな晩は頗る感心しないので、おまけに下宿住、所謂る半夜燈前十年事、一時和雨到心頭といふ一｜件だから堪忍たものでない、まづ僕は泣きだしさうな顏をして凝然と洋燈の傘を見つめて居たと想像し給へ。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子も可哀そうだし、近所も迷惑だ」　長屋のひとりが堪忍袋の緒を切ってこう云い出すと、長屋一同もすぐに同意した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは土間に坐って、堪忍してくれと拝んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "「次第によったら堪忍してやるめえものでもねえが、お慈悲が願いたければ真っ直ぐに白状しろ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "「阿母さん、こればかりは堪忍してください」と、歌女代は泣いてことわった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "表向きにすれば、お叱りの上で町役人にでも預けられるのですが、それも可哀そうでもあり、面倒でもありますから、その場でわたくしが叱っただけで、まあ堪忍してやりましたよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一日もあの屋敷にはゐられないから暇を貰つてくれと、今年二十一になる武家の女房がまるで駄々つ子のやうに、たゞ同じことばかり繰返してゐるので、堪忍強い兄もしまひには悶れ出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも最初のうちはあやまって堪忍されたのであるが、あまりにそれが度重なるので、ほかの芸人がすべて彼女と一座するのを嫌うようになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云つてあなたはそれで堪忍出來るのですか。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにつむじ風吹くと柱動く恐しさに、わななき取つくを抱きしめつつ、「あれ、お客があるんだから、もう今夜は堪忍しておくれよ、いけません。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しくなりて泣出せしに、あわただしく背をばさすりて、「堪忍しておくれよ、よ、こんなかわいそうなものを。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち巡査のことをちっとでも忘れると、それ今夜のように人の婚礼を見せびらかしたり、気の悪くなる談話をしたり、あらゆることをして苛めてやる」「あれ、伯父さん、もう私は、もう、ど、どうぞ堪忍してくださいまし。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "堪忍ならぬのである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世の中は堪忍が大事ぢゃ。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "堪忍が大事じゃぞえ。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたら何ぼ英国だって堪忍袋の緒を切るに違いないだろうということになったんですが、生憎、その爆薬だけが足りないので、こうして汽車で先まわりをして御無理をお願いに伺ったんです」　青年はいつの間にか雄弁になっていた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "堪忍して頂戴」　と言うなりに空気銃を投げ出して逃げて行きました。",
              "citation": {
                "source": "ドン",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　その若い妓は、可愛い人形を抱くように、胸へ折った片袖で、面を蔽う姿して、「堪忍して下さいな。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かんにんして呉れよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かんにんしてお呉れ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かんにんして、ね」「だめよ、お酒飲みの真似なんかして」　男の酔いは一時にさめた。",
              "citation": {
                "source": "あさましきもの",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
