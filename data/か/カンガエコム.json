    "definitions": [
      {
        "index": 1,
        "gloss": "to ponder",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は難しい顔をして、しばらく考え込んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "どうすればこの問題を解決できるか、夜も眠れずに考え込んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "突然の出来事に、彼女はしばらく考え込んでしまい、何も言えなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "子供は煎餅を持った手を控えて、しばらく考え込む。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人は六尺もある筆の先へちょっと絵の具をくっつけて、鳥でも刺すようにして一点くっつけてはまたながめて考え込むというのである。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議がるには、何も吉野山まで汽車に乗って行って、桜の下で毛虫にびくびくしながら考え込む手数などは要りません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとではなおさら気がめいッて、ただしょんぼりと考え込むと、また、いつもの（死ねばいい）が見えるようなの。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏頂面をして考え込む時の顔は、ちょっと人間離れのした怪奇な残忍さを呈する。",
              "citation": {
                "source": "牛人",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」新吉（すゝり泣いて）「うん」鶴三、暫らく考え込む。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてズボンのひざをかかえていっそう考え込むのである。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　平三爺は、口をもぐもぐと動かしながら、げっそりと肉の落ちた面を伏せて考え込むようにした。",
              "citation": {
                "source": "山茶花",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い作業服の吉本は自分で自分が分からないらしく、首を傾けて考え込むようにした。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "深く考え込むようにして煙草を吸った。",
              "citation": {
                "source": "駈落",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とホームズは考え込む。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "考え込む友人の前で突然、それも一五分も沈黙したあとで、もっともらしい意見を述べる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三郎さんは厭な人どころではないけれど、あんな立派な家の人だから、旦那様やお母さんはあんなむずかしそうな人だから、何だか気味が悪い」お小夜は胸の動悸をはずませて考え込む、米を研ぐ手も上の空に動かしてる。",
              "citation": {
                "source": "新万葉物語",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のなすべき事は、ただおっくうで気が向かなく、とかくこんなふうにばかり考え込む、こりゃいけない。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めはやはり陽気に騒ぐ質であったが、次第に段々｜沈欝となって、ややともすると考え込むようになった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "煩悩の情ありありと顔に浮かび、しばらく考え込む）浅太郎　おい、爺さん。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生涯、それに溺れてしまって、身にも魂にもしみ込んだ道楽を、封ぜられたためでしょうか、祖父は賭博を止めてからというものは、何となくほうけてしまって、物忘れが多く、畑を打ちながら、鍬を打つ手を休めて、ぼんやり考え込むことが多かったそうです。",
              "citation": {
                "source": "勝負事",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　知慧自慢の第二の雀が焦茶色の円い頭を傾げて、さもさも当惑したように考え込むと、残りの雀も同じように腑に落ちなさそうな顔をして、きょろきょろしていました。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしすぐにガックリとなり、茫然として考え込む。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして将棋が難しくなつて親分が考え込むと、ツケギツパ、ほら昔マツチのかはりに使つたあれさ、あれに五六歩なり五八飛なりと書いて女中に渡すんだ。",
              "citation": {
                "source": "本因坊と私",
                "author": "関根金次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今食う米が無くて、ひもじい腹を抱て考え込む私達だ。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、そういう性質であればこそ桝本に尻を叩かれて、ストライキを起こそうとしたのでしょう」「さあ」　と冬木刑事が考え込むと、その時、長谷川は、「あ、分かった、変装の理由が分かった！",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "署長はすこぶる当惑したらしく、例のごとく、ふむ――と言ったままじっと考え込む。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と新吉は考え込むように、「彼奴も己の気の荒いにはブルブルしてるんだから、お袋や兄貴に話をして、子供でも産んでしまったら、離縁話でも持ちあがるか、どうせこのままで収まりッこはありゃしない。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬売りは腕を組んで、首を捻って考え込む態をする。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その節子が年の暮あたりには何となく楽まないで、じっと考え込むような娘になった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時は御飯をいただくことすら忘れて一日も二日も考え込むことがある。",
              "citation": {
                "source": "棲霞軒雑記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇平は腕組をして何やら考え込む。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、じっと考え込む。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
