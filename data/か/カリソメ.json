[
  {
    "uuid": "4efdf024-92c8-54c1-b111-e1ceb9f504d6",
    "entry": "仮初め",
    "reading": {
      "primary": "かりそめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
