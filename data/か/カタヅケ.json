    "definitions": [
      {
        "index": 1,
        "gloss": "tidying up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あー、連休中にクローゼットの片付けを終わらせるつもりが、結局寝て終わっちゃった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「パーティーの後の片付けって、なんでこんなに虚しいんだろうね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ほら、出しっぱなしにしないで！片付けまでが遊びでしょ？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「急な来客で、リビングの片付けに追われてヘトヘトだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "食事がすんでそこらを片付けるうち風呂がわいたから父上から順々にいってからだを清める。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "居間の時計がねむそうに十時をうったから一通り霊前を片付けて床に入った。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "数学の宿題も午前の中に片付けたれば午後半日は思うまま遊ぶべしと定まれば昼飯待遠し。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの事だからいつだかわからんと云ったような事を云うてザブ／＼とすまし、机の上をザット片付けて革鞄へ入れるものは入れ、これでよしとヴァイオリンを出して second position の処を開けてヘ調の「アンダンテ」をやる。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高松という処の村はずれにある或る神社で、社前の鳥居の一本の石柱は他所のと同じく東の方へ倒れているのに他の一本は全く別の向きに倒れているので、どうも可笑しいと思って話し合っていると、居合わせた小学生が、それもやはり東に倒れていたのを、通行の邪魔になるから取片付けたのだと云って教えてくれた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんの大體の色と調子の見當をつけた計りで急いで繪具箱を片付けてしまつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さなバスケットや信玄袋の中から取り出した殘りものゝ鹽煎餅やサンドウイッチを片付けて居た生徒達の一人が、さういふものゝ包紙を細かく引き裂いては窓から飛ばせ始めると、風下の窓から手を出して其れを取らうとするものが幾人も出て來た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "繪具箱を片付ける頃には夕日が傾いて廢墟の汀の花薄は黄金の色に染められた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私はそう答えながら、ものごとを片付けるなら一番あとにして下さいと頼む。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど私には、片付けられるまでの途中の肌質のこまかい悩ましさが懐かしく大事なのだから。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　八十三で亡くなった母の葬儀も済んで後に母の居間の押入を片付けていたら、古いボールの菓子箱がいくつか積み重ねてあるのに気がついた。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこれらの問題がことごとく科学的に片付けば、すべては、「学」になって、もう「術」はなくなってしまう。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれもこれもことごとく偶然の現象だとして片付ける前にともかくも何かしら合理的な方法のふるいにかけて吟味しなければならない。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の手術で「速度の相対性」を片付けると、必然の成行きとして「重力と加速度の問題」が起って来た。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は大いそぎで棉を採り片付け、さんざん面白いことをして遊ぼうなどと相談しながら歩く。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "後日彼は、あるアメリカの農夫が『百科全書』を買ってＡからＺまで通読しているという噂をして「私の波動論をどう片付けるか見ものだ」と云った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう問題を、少し立入って考究し論議するとなると、事柄は存外複雑になって来て、おそらく、そうそう簡単には片付けられないことになるであろう。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度米国の某鉄道会社で試験した結果によれば、人夫が六人掛かりで半日にやっとする仕事を、この器械でやれば四人でわずか一時間に片付けてしまうそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眺め渡した処「御気に召した題」が一つも見つからぬので面倒臭くなって片っ端から一瀉千里に片付けてやる決心をする。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お静、店を片付けて居ると、七五郎がやって来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり日中だけの営業で、日が暮れたら店を片付けて住居に帰る）　三次の奴が境内の茶店に腰をかけて嫌に嬉し相にしている。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の女達は慌てて縁台を片付けはじめる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "中止に氣落ちした面々がまた心を取直して何の希望もない經濟的なまた勞力的なあと片付けを默々とやりはじめたときの氣持は今思ひ出しても涙が零れる。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも君も旧思想が取片付けられてしまうということだけは認めているのですね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれを取片付けるのが当然だということも認めていらっしゃるのでしょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜというのに、折角旧思想を取片付けてしまっても、その跡の、石瓦に覆われた地面の上には、新思想は芽ざして来ないかも知れませんから。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにあらまし片付けてしまわなくちゃならないからね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（さっさと為事にかかり、卓の上を片付けつつ、にこやかに。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして随分疲れてもゐるし、厭でもあるが、それを片付けてしまはうと決心した。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と其処らの物を片付けにかかる。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
