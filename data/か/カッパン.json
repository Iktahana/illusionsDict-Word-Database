        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この古い書籍は、活字を組んだ活版を使って丁寧に印刷されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "印刷博物館では、かつて使われていた活版の展示を見ることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "誤字脱字がないか、組まれた活版を何度も確認する作業は根気がいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それでも彼が二十六の歳に学校を卒業してどうやら一人前になってから、始めて活版刷の年賀｜端書というものを印刷させた時は、彼相応の幼稚な虚栄心に多少満足のさざなみを立てたそうである。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔二、〕活版所ジョバンニが学校の門を出るとき、同じ組の七八人は家へ帰らずカムパネルラをまん中にして校庭の隅の桜の木のところに集まってゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へは帰らずジョバンニが町を三つ曲ってある大きな活版処にはいってすぐ入口の計算台〔に居ただぶだぶの白いシャツを着た人に〕おじぎをしてジョバンニは靴をぬいで上りますと、突き当りの大きな扉をあけました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、活版所　ジョバンニが学校の門を出るとき、同じ組の七八人は家へ帰らずカムパネルラをまん中にして校庭の隅の桜の木のところに集まっていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へは帰らずジョバンニが町を三つ曲ってある大きな活版処にはいってすぐ入口の計算台に居ただぶだぶの白いシャツを着た人におじぎをしてジョバンニは靴をぬいで上りますと、突き当りの大きな扉をあけました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランドンのヨークシャイヤも又活版刷りに出来ているその死亡証書を見た。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも道理千万な談で、早い譬が、誤植だらけの活版本でいくら万葉集を研究したからとて、真の研究が成立とう訳はない理屈だから、どうも学科によっては骨董的になるのがホントで、ならぬのがウソか横着かだ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "右側の回廊の柱の下にマドンナの立像があってその下にところどころ活版ずりの祈祷の文句が額になってかけてあります。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "細かい活版を一々読んでいるところがどうしてもドイツ人らしいと思いました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "町名番地が変わったからという活版刷りの通知状であったが、とにかく年賀状以外にこの人の書信に接したことはやはり四五年来一度もなかったはずである。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　活版所　ジョバンニが学校の門を出るとき、同じ組の七、八人は家へ帰らずカムパネルラをまん中にして校庭の隅の桜の木のところに集まっていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へは帰らずジョバンニが町を三つ曲がってある大きな活版所にはいって靴をぬいで上がりますと、突き当たりの大きな扉をあけました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　活版所　ジヨバンニが學校の門を出るとき、同じ組の七八人は家へ歸らずカムパネルラをまん中にして校庭の隅の櫻の木のところに集まつてゐました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へは歸らずジヨバンニが町角を三つ曲つてある大きな活版所にはいつて、靴をぬいで上りますと、突き當りの大きな扉をあけました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は日本屈指の大新聞、東都日報の外交部につとめる傍ら、本郷｜西片町の小さな活版屋で、家庭週報という四｜頁新聞を、毎日曜｜毎に発行していた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも親父は、私が活版所に出かけた留守のうちに、台所の窓から帯を垂らして首を引っかけたまま死んでいたのだそうで、寝床の煎餅蒲団の下には、「何事も天命です。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんど一世紀以前、日本の片隅に於て活版術を実用化せしもの既にありといっても過言で無い。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中庭の側には活版所がある。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中庭の側には活版所があるのです。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の貧しい作家の勘で以てすれば、この活版所は、たしかに、そこに在ったのです。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎月活版に組まれる創作の数も余程の数に上って来た。",
              "citation": {
                "source": "長塚節氏の小説「土」",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者は多少思考を費した上、此説に同意して、直に煤煙の前半、即ち要吉が郷里に帰つて東京に出て来る迄の間を取敢ず第一巻として活版にする事に決心した。",
              "citation": {
                "source": "『煤煙』の序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも道理千万な談で、早い譬が、誤植だらけの活版本で何程万葉集を研究したからとて、真の研究が成立たう訳は無い理屈だから、何様も学科によつては骨董的になるのがホントで、ならぬのがウソか横着かだ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お品が少うげして、へへへ、当節の九星早合点、陶宮手引草などと云う活版本とは違いますで、」「何だか知らんが、さんざ汚れて引断ぎれているじゃないか。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "話が色々になりますが、僕が活版本を始めて見たのは結城合戦花鍬形といふのと、難波戦記、左様です、大阪の戦のことを書いたのです。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚い表紙で赤い絵具をつけた活版本なんです。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "友達が持つて居たので、其時初めて活版になつた本を見ました。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
