        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "剣道の練習で、先生が唐竹の基本を丁寧に指導してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試合の最後の瞬間、彼は渾身の唐竹で相手の面を捉えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「よし、次は唐竹を五本！」師範の声が道場に響き渡る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
