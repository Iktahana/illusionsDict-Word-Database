        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その大きなソファを、部屋にかき入れるのに苦労した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "引っ越し業者たちは、新しい冷蔵庫を慎重にかき入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "建設作業員が、重い資材を建物にかき入れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このピアノ、どうやって階段にかき入れるんだ？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
