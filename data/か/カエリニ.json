[
  {
    "uuid": "8c662e58-b17d-57ac-8f70-637bf14c8a33",
    "entry": "帰り荷",
    "reading": {
      "primary": "かえりに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
