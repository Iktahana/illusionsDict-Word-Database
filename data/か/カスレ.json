        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今夜はフレンチで、カスレを注文した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの店のカスレは豆の煮込み加減が絶妙だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "寒い日にぴったりの、温かいカスレを楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "どうぞ」と妻木君は変にカスレた声で云った。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……ア……ア……アナタハ……サッキ……ノ……」　彼女はカスレた声でこう言いさしてグッと唾を呑んだ。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "低い、カスレた声であった。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "カスレた声で囁いた。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "心持ちカスレた真情の籠もった声であった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作は大日美術院賞だが、迫力がある作風と、カスレタ描き方の魅力がある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "声もカスレ乍らふるえた。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもお母様のお声はいつもと違って、ふるえてカスレておりました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとはやと云ふのを野田のやうに、半分肚の底へのんで、たやア――とひゞくやうに、頤を引いて叫んだのですが、出さうとした音声が思はず鵜呑にされて、いかにも間の抜けたカスレ声がぴいつと響くやうに震えたまゝ飛んで行つたのです。",
              "citation": {
                "source": "早春のひところ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "）咽喉にからまるやうなカスレ声で性急に口吟んだ。",
              "citation": {
                "source": "くもり日つゞき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（例えば毛筆のカスレ、ニジミ、紙と墨との特殊の味、線のカレやふくらみ、東洋風の色調の持つ味その他無数）これは保存すべきものであり、或る特殊の個性にとっては持って来いのよき質料である。",
              "citation": {
                "source": "想像と装飾の美",
                "author": "それを持つ特殊の個性によって生かさるべし",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の眼と耳を同時に疑いつつカスレた声を上げた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までと丸で違った妙なカスレた声で……。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その私の耳の穴へ正木博士のカスレた声が、一句一句明瞭に飛込んで来た。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……………………まず、案内状の回答用葉書に新しく「同　シズ子」と書いたのを照し「欠席」の文字の上のカスレタペンの痕を検め、次いでインキに濡れたピンセットを照し出す。",
              "citation": {
                "source": "涙のアリバイ",
                "author": "――手先表情映画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは腸のドン底から絞り出る戦慄を含んだカスレ声であった。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……イヤ……夢を見たんです……ハハハ……」　と私はカスレた声で笑いながら、右足の処の毛布を見た。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "カスレた声が切れ切れに云った。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはカスレた金属性の、低い、老人の声で、しかもハッキリした日本語であった。",
              "citation": {
                "source": "人間レコード",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い段通を敷いた六畳程の部屋、下を硝子戸の本棚にして金字の書巻のギッシリ詰まった押入を背にして、蒲団の上に座って居る浅黒い人が、丁寧に頭を下げて、吸い込む様なカスレ声で初対面の挨拶をした。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初其カスレた声を聞き苦しく思い、斯人に談話を強うるの不躾を気にして居た彼は、何時の間にかつり込まれて、悠々と話込んだ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば３章のコーカスレースの描写。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし、会って話してみるわ」　シヅは殺気だった喧嘩のかまえになって、部屋のなかを歩きまわりながら、カスレたような声でつぶやいた。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "（口中がかわいてしまったカスレ声）（そこへ、ダダダと足音がして、廊下をこちらへ走って来る監守。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
