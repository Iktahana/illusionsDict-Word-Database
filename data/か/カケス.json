    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Eurasian jay (Garrulus glandarius)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "森の中を歩いていると、懸巣がけたたましい声で鳴いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "懸巣は、その鮮やかな青い羽が特徴的な鳥だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "庭の木に懸巣が遊びに来て、しばらく観察することができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あっ、懸巣だ！ きれいな色！」と、子供は指をさして興奮していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "また壁と壁の支えあげている天井との間のわずかの隙間からは、夜になると星も見えたし、桜の花片だって散り込んで来ないことはなかったし、ときには懸巣の美しい色の羽毛がそこから散り込んで来ることさえあった。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たださへや幽けきに、懸巣啼きて、雨は隠る木のま、不二の裏べ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "啼けよ早や深山懸巣、日は若し、かの稚神、ひむがしはすでにかぎろふ。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷に近い森の奥では懸巣が頻りに鳴いています。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "萱の花誰に見よとて　　　髪結ふた西の山には　　　萱の花誰に解かそと　　　帯締めた東の山にも　　　萱の花萱の枯葉に　　　だまされたお綱さまはと　　　懸巣啼く。",
              "citation": {
                "source": "別後",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "懸巣が林で啼いている。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか此処で鷹の捕えた懸巣を奪い取ったことを思い出す。",
              "citation": {
                "source": "朝香宮殿下に侍して南アルプスの旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こうの大きな白山茶花の枝々を揺がせて、葡萄いろをした懸巣が一羽おどろいたように飛び立っていった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "懸巣がいてね、それが、よく馴れて面白いことをする……光るものを投げてやると、嘴でヒョイと受けるよ」　離屋の書斎！",
              "citation": {
                "source": "キャラコさん",
                "author": "ぬすびと",
                "note": "青空文庫"
              }
            },
            {
              "text": "背中が葡萄色で、翼に黒と白の横縞のある美しい懸巣である。",
              "citation": {
                "source": "キャラコさん",
                "author": "ぬすびと",
                "note": "青空文庫"
              }
            },
            {
              "text": "「懸巣さん、こんちは。",
              "citation": {
                "source": "キャラコさん",
                "author": "ぬすびと",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに懸巣の眼は円くて睨み続けているように美しい、何時か眉の毛を一本籠の中に入れたら、すぐ下りて来て咥えた程眼が利くのである。",
              "citation": {
                "source": "人真似鳥",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは人間でもそうであるが凡ゆる動物はみんな左うらしい、鳥の眼瞬きほど美しいものはないが、懸巣の眼瞬きは迅くてぴりぴりした神経的なものであって、何とも言えぬ美しさを持っている。",
              "citation": {
                "source": "人真似鳥",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう珍しい懸巣は再び手にはいるまいと思い、きき羽根を三四本剪って置いた。",
              "citation": {
                "source": "人真似鳥",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵯などは手にそっと握って庭の中を持って歩いて、蜘蛛や梅擬の実などを喰べさせているが、放したら狎れていても子飼いでないから逃げるであろう、懸巣は赤裸の時分からそだてたので外部の生活を知らないから、放れても餌につくけれど、子飼いでない鳥はそう行かないらしい。",
              "citation": {
                "source": "人真似鳥",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "懸巣から見ると人間の声ほど珍しいものがないらしい、大きな人間を毎日籠の中にいて見ていると、とても変化があって面白いらしい。",
              "citation": {
                "source": "懸巣",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで私は終日机のところで懸巣と懸合いをしているようなものである。",
              "citation": {
                "source": "懸巣",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は決して教えないのであるが、懸巣の方でひとりでに覚えるのである。",
              "citation": {
                "source": "懸巣",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "家には外に鵯が一羽いるがその叫ぶような声はどちらが本物の鵯だかが分らない程懸巣がうまく真似声をする。",
              "citation": {
                "source": "懸巣",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯やみそさざい、ひわやまたかけすなどからだが小さく大へん軽い。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜鷹ふくろう、ちどり、かけす、　来よとすれども、できもせぬ。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「栗の木食って　栗の木死んで　かけすが食って　子どもが死んで　夜鷹が食って　　かけすが死んで　鷹は高くへ飛んでった。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小禽とは、雀、山雀、四十雀、ひは、百舌、みそさざい、かけす、つぐみ、すべて形小にして、力ないものは、みな小禽ぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かけすが、「清夫さんもうおひるです。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かけすが、「やあ象さん、もうおひるです。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小禽とは、雀、山雀、四十雀、ひわ、百舌、みそさざい、かけす、つぐみ、すべて形小にして、力ないものは、みな小禽じゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その樹の言葉に綾をかけて、かけすが雨に居所を襲はれて、けたゝましく鳴きかはした。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋になつてから、山から里の方に下つて來たかけすが百舌鳥よりも鈍い、然しある似よりを持つた途切れ／＼の啼聲を立てゝ、その黒い枝から枝へと飛び移りながら、人眼に遠い物蔭に隱れてゆく。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、　「そら、こいつをかけておくと、とんぼでも蜂でも雀でも、かけすでも、もっと大きなやつでもひっかかりますぜ。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当にその中には、かけすと鶯と紅雀と、ひわと、四｜疋はいってばたばたしておりました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
