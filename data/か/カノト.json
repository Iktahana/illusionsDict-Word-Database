        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "干支の「辛」は、陰陽五行説の金の陰に当たる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い文献では、日付や年を特定する際に「辛」の干支が用いられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "来年の暦の発表で、最初の干支が「辛」の文字で始まることに気づいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "こんなに良いお天気の日に　　お別れしてゆくのかと思ふとほんとに辛い　　こんなに良いお天気の日にさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（辛いこつた辛いこつた！",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ定説といふものを云ひ出す方は案外呑気に云ひ出すのであるが、云はれる方は辛いものである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに牧野さんが酔ふと発しはじめるのなぞは、当人に自制力がないよりも、周囲が彼にとつてはあまりに不真面目に見える所から起るのであつたと考ふべき点もあるのであるから、さういふ定説が呑気に繰返されることは辛かつたのである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔雪とひのきの坂上に〕宮沢賢治雪とひのきの坂上に粗き板もてゴシックを辛く畳みて写真師の聖のねぐらを営みぬぼたと名づくる雪ふりていましめさけぶ橇のこらよきデュイエットうちふるひひかりて暮るゝガラス屋根",
              "citation": {
                "source": "〔雪とひのきの坂上に〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯かる時芸術家が、否応なしに逐ひやられるのは風物の方へであり、世間がセチ辛くなればなる程、詩の方は却て浮世離れがして来るなぞといふことも、ありさうでないことではない。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、『詩もなければ韻文もない、辛うじて文学が……』ラフォルグはコルビエールの作品を愛してゐたが、部分的にしか了解してはゐなかつた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの失敗の原因が何であるか、それを確言することは困難であるが、辛じて私に言へることは、世界が忘念の善性を失つたといふこと、つまり快活の徳を忘れたといふことである。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して「伝統がない」、謂はば「型がない」とか「見本がない」とかいふやうなこと程、詩人にとつて辛いことはないのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人が辛いばかりではない。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者も亦辛いのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとなると、今度はそのことは詩人にとつて辛いのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時には芸術的素質の所有者は必要以上に辛いのである。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは辛いことと云へる。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、この辛さの由来する所にこそ精神の客観性は依拠するのである。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しこつちは寧ろウソが明白にされたので過去三ヶ年半の可なり辛い自責感を去る。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さん、自分がむしやくしやするからつて子供にまで辛く当らなかつたつて……」「またあんたが出て来て事を大きにしてもらつてはお母さんが何時も真中で一番困るから。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、辛じて詩人は神を感覚の範囲に於て歌ふ術を得るのだ。",
              "citation": {
                "source": "地上組織",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかく浮世は辛いといふことは屡々浮世は辛くなければならぬといふやうにして発音されるのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮世とて、辛くなくてすめば辛くない方がよいのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大風の朝も赤し唐辛子　暴風雨の朝、畠の作物も吹き荒され、万目荒寥として枯れた中に、ひとり唐辛子の実だけが赤々として、昨日に変らず色づいているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは僕にとって非常に辛く、客と両方への気兼ねのために、神経をひどく疲らせる仕末だった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村外れの茶店で昼飯を食った時に店先で一人の汚い乞食婆さんが、うどんの上に唐辛子の粉を真赤になるほど振りかけたのを、立ちながらうまそうに食っていた姿が非常に鮮明に記録されている。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか有田の乞食婆の喰っていたあの唐辛子のかかった真赤なうどんと、ポツオリの旗亭のトマトのかかった赤いスパゲッティとの類似のためであろうとも思われない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどくがっかりして、しかし結局あきらめて辛抱して待って、さてもういいかと思って催促すると、今度は何とかがどうとかして何とかで工合が悪いからもう二、三日待てという、その何とかが実に尤千万な何とかで疑う余地などは鷹の睫毛ほどもないのだから全く納得させられる外はなかった。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして杖にすがったまま辛うじてかがんだ猫背を延ばして前面に何物をか求むるように顔を上げた。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔われかのひとをこととふに〕宮沢賢治われかのひとをこととふになにのけげんもあらざるをなにゆゑかのとき協はざるクラリオネットの玲瓏をわらひ軋らせわらひしや",
              "citation": {
                "source": "〔われかのひとをこととふに〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にも迷惑をかけないやうに努めて上品な暮しをしてゐるのに、それでも人は、何のかのと言ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のかのと言つて、私の宿命をお前たちの宿命にまで引下げようとしてゐるが、しかし、天の配劑、人事の及ばざるところさ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のかのと、ろくでも無い料理をうるさくすすめて、くだらないお世辭を交換し、をかしくもないのに、矢鱈におほほと笑ひ、まあ！",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
