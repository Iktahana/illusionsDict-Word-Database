[
  {
    "uuid": "b9c06109-4547-52bf-84a0-84f371a91b37",
    "entry": "金入れ",
    "reading": {
      "primary": "かねいれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
