        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "鍛冶屋の店からは、金床を打つ音が規則的に聞こえてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "熱した鉄を金床の上で叩き、形を整えていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古びた金床が、作業場の隅に静かに置かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "鉦鼓淵、盗人谷、その天上の風格は亭々と聳立する将軍台、また厳として平なる金床台。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "真赤に焼けた鉄片を金床の上に取り出して父親がコツコツと金槌で叩いてゐる間に八重は、仕事場に続いた畳の居間に這ひあがつて、畜音機を廻しはじめた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親が調子をとつて小槌を振りあげ、蹄鉄を続け打ちにした後に、そら来たツーカーンと金床を打ち鳴らすと、大上段に振り翳されて合図を待つてゐた八重の槌が火花の中に振り落された。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "レールはすでに全速力で接近してくる汽車の振動で金床のように唸っている。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたたび、仕事場にもどって、鉄槌で、コツコツと赤く焼けた鉄を金床の上でたたいていました。",
              "citation": {
                "source": "般若の面",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには神棚があつて、手先仕事だけに小綺麗に片付いてはをりますが、それでも金床や鞴や大小の鑢や鏨やがいろ／＼の材料と共に配置され、未完成の大きい櫓時計が三つと、置時計の修繕物が三つ、部屋の隅に片寄せてあるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "御時計師",
                "note": "青空文庫"
              }
            },
            {
              "text": "金床のうえでチンカン、チンカンと鉄を叩く音。",
              "citation": {
                "source": "鈴が通る",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（金テコで火の中から引き出した鉄を金床の上にコツンと置き）ありがてえもんじゃねえかよ！",
              "citation": {
                "source": "鈴が通る",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はまた川になる、川の面は、呼吸も吐かず静まりかえっているように見えるが、足を入れると、それこそ疾風が液体になったように全速力で走っている、流れの浅く、彎入した、緩やかなところに背を露わした石がある、苔が厚く活物の緑が蠢めいている、水草の動くのは、髪の毛がピシピシと流電に逆立つようだ。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人のに似通った日本人の絵も沢山あるようだが、でも、この人のにはどこかに、こせこせしない、のびやかなところがあるような気がする。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誇張したようなところにもどこか素直な、のびやかなところがあると思う。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして静かなところで、ボツリボツリと話し合っているうちに、酒に酔うことを忘れていつしか相手の、又時には自分の言葉の味に酔っている。",
              "citation": {
                "source": "気まま者の日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして静かなところを、求めて林の中に入ってじっと道理を考えていましたがとうとうつかれてねむりました。",
              "citation": {
                "source": "手紙　一",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲鳴は最も微かなところからはじまる。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなとこ雲　東の方に築地をつきたる如く立つ白雲を、かなとこ雲といふよしなり。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなとこは鉄砧にて、其形鉄砧にも似たればなるべし。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "東に白雲の築地の如く見えたるは眼にしたれど、猶かなとこ雲の風情といふを知らず。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれが少しどうかなとこう考えだしてごらん、そら、それは次の頁だよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし間近く上野をひかえているだけに、何処か明るい花やかなところもあった。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このほか有価証券、預金の類をひっくるめると、十五万はたしかなところですから、銀行の方でも信用をしてくれるとは思っているんですが」　そういう間にも、その男は金縁の眼鏡の奥から、おせいの様子をちらりちらりと探るように見た。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浄らかなところは、永遠に人を飽かさない。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　皇帝の住んでいる大きな町は、たいへんにぎやかなところでした。",
              "citation": {
                "source": "はだかの王さま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのわづかなところを、鳥右さんはたいへん長くかかりました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで武士は面白くなり、腕をまくつて、柔らかなところに虱をのせて見た。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――静かなところに帰つてゆきなさい。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は賑かなところで死にたい」彼はそれをもって京極の裏店に引越した。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は顔なんて問題じゃない、精神さえきよらかなら大丈夫、立派に社会生活ができるという事は、僕も堅く信じているが、俊雄君のように若くて、そうして慶応の文科のような華やかなところで勉強している身が、あんな顔では、ずいぶん苦しい事だってあるだろうと思う。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯れた細い枝が五六本、空にむかい、手ぢかなところにある枝は、たいていぶざまにへし折られていた。",
              "citation": {
                "source": "猿ヶ島",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　手を伸ばせば取れるほど真近かなところに林檎は赤く光っていた。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう点が、ほらふきの兵太郎君のばかなところであると、久助君は思って見ていた。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
