  {
    "uuid": "59d4e4a0-5aee-5637-b784-682cfd497125",
    "entry": "閑居",
    "reading": {
      "primary": "かんきょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "quiet and secluded life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "都会の喧騒を離れ、山奥で閑居を送るのが彼の長年の夢だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "退職後は、趣味に没頭し、静かな閑居を味わいたいと考えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、世間から離れて、自らの内面と向き合うための閑居を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "静かな田舎町で、古民家を改築して閑居を営むのが理想だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "閑居鳥寺見ゆ麦林寺とやいふ　夏の日の田舎道、遠く麦畑の続いた向うに、寺の塔が小さく見える。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空では高く、閑居鳥が飛んでるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの巴里人のならわし通りこの男も老後を七、八十｜里巴里から離れた田舎へ恰好な家を見付けて買取り、コックに一人の女中ぐらい置いて夫婦の後年を閑居しようという人達だ。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "津田君はかつて桃山に閑居していた事がある。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白秋氏を通じて聞く所によれば、この物侘しい先輩の閑居を、それでも時々訪ねてくる地方の文學青年があるさうである。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また紹巴が「誰か参りて御閑居を御慰め申しまするぞ」と問うた。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処がすなはち長柄川の閑居だつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も六十に手が届くやうになり、田舎の閑居で退屈まぎれに、同棲三十年近くで、はじめて妻といふ女を見直して見るのであつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "読んで見ると、自分の放埒時代にしじゆう留守をさせられた彼女の、若き妻としての外出中の夫に対する心遣ひを、こまごまと打開けたものや、子の無い自分が長柄川閑居時代に、ふと愛した近隣のこどもに死なれ愁歎の世にも憐れなありさまを述べたものなどであつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑居の気持も全く同様、一切を放下し、方丈の庵にあけくれ起居してみなければ、わかるものではござりませぬ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の源信と寂心との間の一寸面白い談は、今其の出処を確記せぬが、閑居之友であったか何だったか、何でも可なり古いもので見たと思うのである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の此の超脱的閑居の精神もそこにある。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "真間では真間閑居の記を書いたが、大正五年の五月から六月まで二た月しか居なかつた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "）福岡市｜須崎お台場に在る須崎監獄の典獄（刑務所長）となり、妻帯後間もなく解職し、爾後、数年閑居、日清戦役後、台湾の巡査となって生蕃討伐に従事した。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどきの消息に、帰国ののちは山中に閑居するとか、朝鮮で農業をやろうとか、そういうところをみれば、君に妻子を忘れるほどのある熱心があるとはみえない。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "利章は「浮浪の身の上なれば、御ことわり可申歟とも存候へども、閑居徒然の折柄、御尋に預候はば、面談可申候」と返事をした。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑居のことであるから、そんな人もやや近い所でほのかに源氏の風貌に接することもあって侍は喜びの涙を流していた。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "用が無いから、ソコデ小人閑居して不善を為す、男にも小人は多いが、女には男よりも更に一層小人が多い、碌な事をしをらん。",
              "citation": {
                "source": "家庭の読書室",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　朝日新聞社に入る　北京から帰朝したのは三十六年の七月で、帰ると間もなく脳貧血症に罹って田端に閑居静養した。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを思うと、器は粗末な方がいいようだといって、老年になって鷹ヶ峰に閑居するときには、茶器の立派なものは、それぞれ知人に分けて、自分には粗末なもののみを持って往ったということだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてこそ、如来はすでに三界の火宅を離れて寂然として閑居し、林野に安処せり今この三界は、皆是れ我｜有なりその中の衆生は、悉く是れわが子なりしかもいま此処は、諸の患難多し唯だ我一人のみ、能く救護をなす　という、われらに対する、仏陀の限りなき慈悲の手は、さし伸べられたのではありませんか。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "空中の音楽　西暦一八七四年九月八日詩人メーリケはス市の閑居で七十回の誕生祝をやった。",
              "citation": {
                "source": "怪談綺談",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "目もくらむばかりのシムラの高原に閑居する全印度の統治者が、平原に住む餓えたる数百万の苦悩を理解し得ざるは、我々にとってはあたかも日を仰ぐがごとく明瞭である。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "然も彼らは、数百万民衆の不断の労苦の庇護によって、シムラの閑居が可能ではないか。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを思ふと、器は粗末な方がいいやうだと言つて、老年になつて鷹ヶ峰に閑居するときには、茶器の立派なものは、それぞれ知人に分けて、自分には粗末なもののみを持つて行つたといふことだ。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "山手閑居の場、私の現在はかういつた様子。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑居――読書――回顧――微苦笑。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――魚売の声よそにふけ青嵐――これは也有翁の閑居吟であるが、私の場では、豆腐屋のラツパも寄らない青葉若葉である、呵々。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日も今日も閑居、読書三昧、無言行。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑居句作、その外に私の生きる道があるかよ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
