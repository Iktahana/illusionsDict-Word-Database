        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "秋になり、田んぼでは稲の鎌入れが始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "農家の人々は、鎌入れの時期に合わせて準備を進める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔ながらの鎌入れの風景は、日本の原風景の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地域住民総出で、小麦の鎌入れを手伝った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この畑では、鎌入れが終わるとすぐに次の作物の準備に入る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "小作をして居た田圃に水がついて鎌入れする張合もない。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "――が尊氏は、多年｜培っていた沃野に鎌入れをしたまでのこととし、すぐ、別な旨を言いだしていた。",
              "citation": {
                "source": "私本太平記",
                "author": "筑紫帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
