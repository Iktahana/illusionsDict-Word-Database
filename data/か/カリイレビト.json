        "examples": {
          "standard": [
            {
              "text": "教会の壁画には、黄金の麦畑で働く刈り入れ人たちが描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古代の農村では、刈り入れ人たちが歌いながら共同で作業を進めていたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "聖書の一節に、「収穫は多いが、刈り入れ人は少ない」とある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "厳しい日差しの中、経験豊富な刈り入れ人たちが黙々と稲を刈り取っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それからまた、刈り入れ人や、人夫や、農場の牛飼い小僧や、耕作人などとして、雇われていった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
