    "definitions": [
      {
        "index": 1,
        "gloss": "first calligraphy of the year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新年には、家族全員で書き初めをするのが我が家の恒例だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "書き初め大会で、彼は見事な筆さばきを披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "小学校の書き初めで書いた「夢」の字を今も大切にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今年の書き初めのテーマは「飛躍」に決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "かねてから考えている著書を早く書き初めなければならぬと思う事もある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "独慎――この二字を今年の書き初めとして、私は心の紙にはっきりと書いた。",
              "citation": {
                "source": "独慎〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時桐生君は法科の二年であつたが、始終シエークスピーヤだとか、トルストイなぞを説いた、僕はそれに依つて泰西の文學を知り、眞面目に文學を研究し眞面目な意味に文學を了解して來て、其所に三四月居る中に、何であつたか書き初めた。",
              "citation": {
                "source": "自傳",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも書き初めた時と、終る時分とは余程考が違って居た。",
              "citation": {
                "source": "処女作追懐談",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "勉強をする時間が出来たわけだが、目的の脚本は少しも筆が取れないで、かえって読み終ったメレジコウスキの小説を縮小して、新情想を包んだ一大古典家、レオナドダヴィンチの高潔にしてしかも恨み多き生涯を紹介的に書き初めた。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだまだ創作人物の名前については重要な事を沢山に書残しているようであるが、さてこうして書き初めてみるとナカナカ重大な問題らしく、あとから――書く事がイクラでも出て来るのに驚いている。",
              "citation": {
                "source": "創作人物の名前について",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず唐織から書き初めてもらいましたのを、只圓は何の五六枚と思って墨を磨っていたのがアトからアトから際限もなく出て来る。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "△十一月号に書いた「青白き公園」は、あれはたゞその前置で正月号から改めて私が計画してゐる新しい童話の方法で先づ書き初めるつもりで、で、その本筋の第一は来月号から順当にする考へなのですから左様御承知下さい。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠はズツとそれに目を通して、唯「成程」と云つたが、今自分が或非常な長篇の詩を書き初めて居ると云ふ事を話し出した。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが自分の言文一致を書き初めた抑もである。",
              "citation": {
                "source": "余が言文一致の由來",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "十　斯の手紙を書き初めたのは昨年四月のことでした。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月十一日　十二日　十三日今日から新らしく書き初める。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋をたたへよ、秋をうたへよ、秋風日記を書き初める。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから菊池（幽芳）さんに手紙を書かうと思つてペンをとりますと、先づやつぱりあなたに書きたいので書き初めたのです。",
              "citation": {
                "source": "書簡　大杉栄宛",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後一時、これから雜誌人間十二月號の爲めの小説を書き初めるのだ。",
              "citation": {
                "source": "鹽原日記",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして互ひに別室へ別れてから、僕は中央公論の續きを書き初めて、午前の一時半まで起きてた。",
              "citation": {
                "source": "鹽原日記",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしても、原稿を書いて、勇夫婦に安心させて置くべしだ」かう考へて、義雄は、その月の一日の中央公論に出た、某氏の自分に對する長論文（執筆者から送つて呉れた）の反駁を書き初めた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "みのるは其の翌る日から毎日机に向つて、半分草しかけてあつた或る物語の續きを書き初めた。",
              "citation": {
                "source": "木乃伊の口紅",
                "author": "田村俊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はそこで又、幾度となく歎息を繰り返しましたが、その中に弟のマチラは何か思い付いたらしくノートの一片を引き裂いて何かしら書き初めました。",
              "citation": {
                "source": "霊感！",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでだ……そこで何から書き初めていいかトント見当が付かないが……何しろ遺言書なぞを書くのは後にも先にも今度が初めてだからね。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大急ぎでこの室へ来て書類をスッカリ焼き棄てて、この遺言書を書き初めたんだが、そのうちに夜が明けてみると、君が覚醒しかけたというので、兼ねてから待ちかねて準備していた若林が時を移さず馳けつけて、早速｜彼の美少女に引き合わせた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……………………間もなく慌てて机に帰り、ペンを取り上げ、レターペーパーを拡げて手紙を書き初める。",
              "citation": {
                "source": "涙のアリバイ",
                "author": "――手先表情映画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ドウするか見ろ……というので事件の翌る日から毎日事務所に立て籠もって向う鉢巻でこの報告書を書き初めたもんだが、サテ取りかかってみるとナカナカ容易でない。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜はこれを書き初める前に三通手紙を書かされた。",
              "citation": {
                "source": "出奔",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上のごとき、数多の外国小説の翻訳に依って、我国の江戸時代よりの小説類に全く欠けていたものを外国文学中に発見し、外国小説の面白さをつくづくと感じた読者自身が、今度は、自ら創作欲に駆られて、書き初めたのであった。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａの字の歌　　　（少年雑誌のために）Ai （愛）の頭字、片仮名とアルハベツトの書き初め、わたしの好きなＡの字をいろいろに見て歌ひましよ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月の二十五日の午後から書き初めたのでした。",
              "citation": {
                "source": "遺書",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と落ちる雨だれの音を五月蠅く思いながら久しく手紙を出さなかった大森の親しい友達の処へ手紙を書き初めた。",
              "citation": {
                "source": "千世子（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はかう書き初めて其頃楠さんの年齢はいくつぐらゐであつたのであらうと思つて見ますが解りません。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "友ちゃんもきのう届いた机で達ちゃんへの速達のかきぞめをいたしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
