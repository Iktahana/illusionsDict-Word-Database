        "examples": {
          "standard": [
            {
              "text": "新しい皮むき器は、トマトのような柔らかい皮もきれいに剥ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この皮むき器は、持ち手が滑りにくくて使いやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "料理中に皮むき器が見当たらず、包丁で代用した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は皮むき器を使って、あっという間に大量の野菜の下ごしらえを終えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
