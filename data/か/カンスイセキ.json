    "definitions": [
      {
        "index": 1,
        "gloss": "whitish marble (from northern Ibaraki)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭に敷き詰められた白く輝く石は、茨城北部で採掘された寒水石だそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "建物のエントランスを格調高く見せるため、壁材の一部に寒水石をあしらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この寒水石のざらつきが、枯山水の砂紋をより美しく引き立てるんだ」と庭師が語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お土産屋の隅に、寒水石を削って作られた素朴なフクロウの置物が並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "雪はチカチカ青く光り、そして今日も寒水石のように堅く凍りました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お涌は今では、日比野の家の格子戸を開けて入ると女中の出迎えも待たず玄関の間を通り中庭に面している縁側へ出て、その突当りの土蔵の寒水石の石段に足をかける――「いるの」という。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと崖を登りきったらそこはまばらに栗の木の生えたごくゆるい斜面の平らで雪はまるで寒水石という風にギラギラ光っていたしまわりをずうっと高い雪のみねがにょきにょきつったっていた。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪はチカチカ青く光り、そして今日も寒水石のやうに堅く凍りました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お涌は今では、日比野の家の格子戸を開けて入ると女中の出迎へも待たず玄関の間を通り中庭に面してゐる縁側へ出て、その突当りの土蔵の寒水石の石段に足をかける――「ゐるの」といふ。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "義直は青い服を着た男のゐるテーブルの前を通つて、其所に見えてゐる寒水石の階段をあがつて行つた。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十一時十分だ、ほんとうに来るかね」「きっと往くわ」「じゃあ、往って待ってる、ここの勘定をしてもらおうね」「会計」　お葉は正面の寒水石の売台の前へ往って、そこから小さな書附を執って来て天風の前へ置いた。",
              "citation": {
                "source": "文妖伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二条か三条かに寒水石の食卓を据えた店には、数多の客が立て込んでいた。",
              "citation": {
                "source": "水魔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには白い滑かな方形の寒水石がある。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオンの寝室では、寒水石の寝台が、ペルシャの鹿を浮かべた緋緞帳に囲まれて彼の寝顔を捧げていた。",
              "citation": {
                "source": "ナポレオンと田虫",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "椅子の上寒水石のてえぶるに薄い硝子の花の鉢。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は寒水石ではないが純白な色の円卓子へ向き合って坐った。",
              "citation": {
                "source": "あめんちあ",
                "author": "富ノ沢麟太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
