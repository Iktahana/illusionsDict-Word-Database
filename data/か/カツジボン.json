        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "図書館の書庫には、手書きの写本と並んで貴重な活字本が多数収められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "電子デバイスばかり見ていると目が疲れるので、たまには活字本を開いてゆっくり読書したい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "グーテンベルクの活字本は、情報伝達に革命をもたらした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "活字本だと、もしか九年の誤植であるかもしれない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒山詩が所々で活字本にして出されるので、私の内の子供が其廣告を讀んで買つて貰ひたいと云つた。",
              "citation": {
                "source": "寒山拾得縁起",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒山詩が所々で活字本にして出されるので、私のうちの子供がその広告を読んで買ってもらいたいと言った。",
              "citation": {
                "source": "寒山拾得縁起",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "池辺義象さんの校訂した活字本で一ペエジ余に書いてある。",
              "citation": {
                "source": "高瀬舟縁起",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の活字本の万葉集は、甚だ読み易くなつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "とすれば、ディスプレイ画面にふさわしい文字の大きさが活字本のそれとちがってきたとしても、なんのふしぎもない。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "テキスト・データに簡単な指定記号を書き入れ、このツールキットに読みこむと、ほぼ瞬時に、タテ組み（ヨコ組みでもいい）、適切な余白つき、ページに分割され、目次や索引をそなえた、いまある活字本にきわめてちかいかたちに変形させることができる。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手写本や木版本から活字本への転換は、ほとんど一瞬のうちに終わった。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同様に、活字本から電子本への転換は、一つの印刷技術から別の印刷技術への転換ではない。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "池邊義象さんの校訂した活字本で一ペエジ餘に書いてある。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同様に、活字本から電子本への転換は一つの印刷技術から別の印刷技術への転換ではない。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又參考せる書中、太平御覽は未だ宋本を見るの機會を得ざれば我が倣宋活字本を主として、極めて希れに鮑刻本を參照したり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮑刻本は明板本を宋本にて校したる者によりたるが、四夷部倭國の條は、明板の粗惡殊に甚しく、鮑刻本は又之を汲古閣本の三國志にて校改したる跡ありて、校宋本として取るべき處殆ど之なく、我が活字本の影宋本を墨守せるに如かざるなり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "池邊｜義象さんの校訂した活字本で一ペエジ餘に書いてある。",
              "citation": {
                "source": "高瀬舟縁起",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあの時代の活字本には、当世の本よりも誤植が少い。",
              "citation": {
                "source": "本の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ歴史的な発見なのさ」　法水は頭から信じないように、「世界最初の活字聖書は、一四五二年版のグーテンベルク本だが、それと同じ年に和蘭ハーレムの人コスターも、印刷器械を発明して、聖書の活字本を作ったという記録が残っているんだ。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文禄時代の羅馬字訳を初とし慶長元和以来古活字本となり、其他の諸版で世間に流布したのが、遂に此戯作者の筆にまで伝ったことは、また文壇の一奇談といわなければならぬ。",
              "citation": {
                "source": "春水と三馬",
                "author": "桑木厳翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の写本、木版本でない現今の活字本で見る人は一目瞭然とわかるはずである。",
              "citation": {
                "source": "『新新訳源氏物語』あとがき",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、これは寛永二十年の活字本で珍しいものだ、今日の万葉集はすべてこれを底本にしているが、普通には千蔭の略解本が用いられている、よほど好書家でないとこれを持っていない」　そうして、北原賢次とお雪ちゃんのために、日本の活字の来歴を一通り話したことでありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、活字本と、普通の木版本の相違をも、よく説明して聞かせたことでありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一は活字本当世新刊和洋の書籍雑著を主として和本唐本を置かず、他は和本唐本を主となし活版本は僅に古書の翻刻物を売買す。",
              "citation": {
                "source": "古本評判記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
