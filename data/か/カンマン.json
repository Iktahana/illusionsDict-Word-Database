[
  {
    "uuid": "707ca232-33a0-5037-8fc7-169727f21d00",
    "entry": "干満",
    "reading": {
      "primary": "かんまん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
