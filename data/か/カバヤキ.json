        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "土用の丑の日になると、近所の鰻屋から香ばしい蒲焼の匂いが漂ってきて食欲をそそられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今日の夕飯は奮発して、デパ地下でサンマの蒲焼を買ってきたよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "秘伝のタレに何度もくぐらせて焼き上げた蒲焼は、身がふっくらとしていて口の中でとろける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父は昔から、泥臭さを抜いたナマズを蒲焼にして食べるのが一番の贅沢だと言っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "宿の裏の瀦水池で飼つてある鰻の蒲焼も出た。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の裏の瀦水池で飼ってある鰻の蒲焼も出た。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うなぎの蒲焼（鑵詰）ライスカレー（同上）あずきようかん（同）栗のきんとん（同）ほーじ茶、ココア、角砂糖（斯うたくさんは食えんわい）小包は厳重にして置いて呉れ。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦場だからな」「鰻でも取りますか」「それがよかろう」　鰻の蒲焼を註文して、二人は早い夕飯を済ませると、七月の日もかたむいて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「細君がいないので、せっかくおいで下さっても、何のおもてなしも出来ず、ほんの有り合せのものですが、でも、これはちょっと珍らしいものでしてね、おわかりですか、ナマズの蒲焼です。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お盆には、その蒲焼と、それから小さいお猪口が載っていた。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はすすめられて、ここの奥さんの創意工夫に依るものだというナマズの蒲焼にも箸をつけた。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "咽から手が出て蒲焼を引摺り込むかと思われた。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓の下の三洲園という蒲焼屋では三味線の音が騒がしくきこえる。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいしい蒲焼でもたべさせる家があるといいんだが、どうも、仙台の鰻には筋がある。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本酒が無かったら、焼酎でもウイスキイでもかまいませんからね、それから、食べるものは、あ、そうそう、奥さん今夜はね、すてきなお土産を持参しました、召上れ、鰻の蒲焼。",
              "citation": {
                "source": "饗応夫人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はみやげだといって蒲焼のおりを三造に与えた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかだにした蒲焼、きも吸い、う巻の玉子焼。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲焼が好で、尾張屋、喜多川が常に出入した。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲焼の代りを待っているあいだに、彼は静かに言い出しました。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ蒲焼のお代りを運んで来ましたが、わたしはもう箸をつける元気がない。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お代りの蒲焼は二人ともにちっとも箸をつけなかったので、残して行くのも勿体ないといって、その二人前を折詰にして貰うことにしました。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊手と唐の芋と、うなぎの蒲焼と、重ね重ねのおみやげを貰って、なんにも知らない伊佐子さんはどんなに喜ぶことかと思うと、わたしはいよいよ寂しいような心持になりました。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ゆうべお土産だといって、うなぎの蒲焼をくれたでしょう。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　伊佐子さんの説明によると、ゆうべあの蒲焼を貰った時はもう夜が更けているので、あした食うことにして台所の戸棚にしまっておいた。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがきょうの午前中に忍び込んできて、女中の知らない間に蒲焼の一と串をくわえ出して、裏手の掃溜のところで食っていたかと思うと、口から何か吐き出して死んでしまった。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてここの二階へあがって、飯を食う時はうなぎの蒲焼ということに決めてあったが、酒のあいだにはいろいろの川魚料理が出た。",
              "citation": {
                "source": "鯉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、客がその奥座敷へ通って、うなぎの蒲焼や泥鱒鍋をあつらえた時には、かのすっぽん共は平気で遊んでいるが、もし泥鼈をあつらえると、かれらは忽ちに水のなかへ飛び込んでしまう。",
              "citation": {
                "source": "魚妖",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ある日の午飯にうなぎの蒲焼を取寄せて出しますと、叔父は俄に顔の色を変えて、いや、鰻は真っぴらだ。",
              "citation": {
                "source": "魚妖",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが普通の職人ならば、うなぎの蒲焼などを食わせる訳もないのですが、職人といっても叔父のことですから、わたくし夫婦も気をつけてわざわざ取寄せて出したのに、見るのも忌だと言われると、こっちもなんだか詰まらないような気にもなります。",
              "citation": {
                "source": "魚妖",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには「よせ鍋はま鍋」「蒲焼三十銭」「○○大特売大安売り」などという文句が読まれる。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……鰌を串にしたのだそうだが、蒲焼など、ひとつずつ、ただその小さな看板にだけ、売名呼名をかいて、ほんのりと赤で灯が入っていて、その灯に、草の白露が、ほろほろと浮く。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネイおふじ、網ならどうかして捕れたんだよ」「そうか、そりゃ惜しいことをしたなア、蒲焼にしたら定めて五人でたべ切れない大きいものであったろう。",
              "citation": {
                "source": "水籠",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳原を両国の方へ歩いているうちに、古賀は蒲焼の行灯の出ている家の前で足を留めた。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四）　隣家の妻君が朝飯の最中純白な西洋皿に、体裁よくならべた泥鰌の蒲焼を盛つたものを手にして裏口に現れた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
