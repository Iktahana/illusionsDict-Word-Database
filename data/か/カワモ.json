    "definitions": [
      {
        "index": 1,
        "gloss": "river surface",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夕日が川面に映り込み、あたり一面が茜色に染まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ボートが滑るように川面を進んでいく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "風のない穏やかな日、川面は鏡のように周囲の景色を映していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "川面に揺れる木々の影を見ていると、心が落ち着く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（Ｆ・Ｏ）Ｓ＝川端　川面に垂れ下った柳。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "川上はだいぶ降ったと見えて、放水路の川面は赭土色を増してふくれ上った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺りは荒川西より東に流れて、北の岸は卑湿の地なるまゝいと荒れたれば、自然の趣きありて、初夏の新蘆栄ゆる頃、晩秋の風の音に力入りて聞ゆる折などは、川面の眺めいとをかしく、花紅葉のほかの好き風情あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "堤の上はそよ吹く風あれど、川面は漣だに立たず、澄み渡る大空の影を映して水の面は鏡のやう。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "入江に近くにつれて川幅次第に廣く、月は川面に其清光を涵し、左右の堤は次第に遠ざかり、顧れば川上は既に靄にかくれて、舟は何時しか入江に入つて居るのである。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは川面の漣波に、蘆荻のそよぎに、昼顔の花に、鳥のさえずりに、ボロ服とボロ靴にあるのではないか。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば極貧を現わすために水道の止まった流しに猫の眠っている画面を出すとか、放免された囚人の歓喜を現わすのに春の雪解けの川面を出すとか、よしやそれほどの技巧は用いないまでも、とにかく文学的の言葉をいわゆるフォトジェニックなフィルミッシな表現に翻訳しなければならない。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何んということもなくそこに佇んで川面を眺めやった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時仮橋ががたがたいって、川面の小糠雨を掬うように吹き乱すと、流が黒くなって颯と出た。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "手長蝦だか、足長蟲だか、びちや／＼と川面ではねたと思ふと、岸へすれ／＼の濁つた中から、尖つた、黒い面をヌイと出した……」　小さな聲で、「河、河、河童ですか。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見馴れねえ旅の書生さんじゃ、下ろした荷物に、寝そべりかかって、腕を曲げての、足をお前、草の上へ横投げに投出して、ソレそこいら、白鷺の鶏冠のように、川面へほんのり白く、すいすいと出て咲いていら、昼間見ると桃色の優しい花だ、はて、蓬でなしよ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（爺様、あれあれ、）」　その時、宰八川面へ乗出して、母衣を倒に水に映した。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘆のまわりに、円く拡がり、大洋の潮を取って、穂先に滝津瀬、水筋の高くなり行く川面から灌ぎ込むのが、一揉み揉んで、どうと落ちる……一方口のはけ路なれば、橋の下は颯々と瀬になって、畦に突き当たって渦を巻くと、其処の蘆は、裏を乱して、ぐるぐると舞うに連れて、穂綿が、はらはらと薄暮あいを蒼く飛んだ。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた何んといふこと無く川面を覗込むだ。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "川面の處々に洲があツた。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "流の彼方此方で、何うかすると燦爛たる光を放つ……霧は淡い雲のやうになツて川面を這ふ……向ふの岸に若い婦が水際に下り立ツて洗濯をしてゐたが、正面に日光を受けて、着物を搾る雫は、恰で水晶のやうに煌く。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の日の、山國の、名にしおふ越路なり、其日は空も曇りたれば、漸く町をはづれると、九頭龍川の川面に、早や夕暮の色を籠めて、暗くなりゆく水蒼く、早瀬亂れて鳴る音も、千々に碎けて立つ波も、雪や！",
              "citation": {
                "source": "雪の翼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾時仮橋ががた／＼いつて、川面の小糠雨を掬ふやうに吹き乱すと、流が黒くなつて颯と出た。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ってごらん」　お秀はまた相通ぜぬ二人の問答が始まったと思いながら手をあてゝ、アセチレンの灯で照し出される川面を見ていました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の夜は舳にほおずき提灯を立てたこれ等の船が川面を賑かしました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この物凄い声が川面に鳴り響いた。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、二階をあがりつめて廊下に出ると、神田川の裾になった川面に微藍の色をした潮が中高にとろりと湛えて、客を乗せた一｜艘の猪牙船が大川の方へ出ようとして、櫓の痕を泥絵の絵具のように一筋長く印しているのが見えた。",
              "citation": {
                "source": "鼓の音",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川面はますます明い、船こそ数多あるけれども動いているのはこの川にこれただ一｜艘。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳許にドンと一発、船頭も驚いてしゃっきり立つと、目の前へ、火花が糸を引いて※と散って、川面で消えたのが二ツ三ツ、不意に南京花火を揚げたのは寝ていたかの男である。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と誦するのが、いうべからざる一種の福音を川面に伝えて渡った、七兵衛の船は七兵衛が乗って漂々然。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ花火を見る舟は出ないので、川面は存外込み合っていない。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "エアーポケットが、川面や、両岸の断崖へかけて出鱈目にあるのに違いない。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう次第で、この谿谷の川面に近い、街道筋では各々様々の色をした白色レグホンが、餌を拾っているのが見受けられるのである。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "川面には薄い靄が流れて、列び茶屋にはもうちらちらと提灯の火が揺らめいて見えた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして半町も行かないうちに、心持眼下に、石狩川の川面が見えた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
