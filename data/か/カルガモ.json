        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「見て見て！カルガモの親子が横断歩道を渡ってるよ」と、通行人が足を止めて微笑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "公園の池では、軽鴨が器用に首を羽に突っ込んで昼寝をしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都会のビルの屋上の庭園に、どこからともなく軽鴨が飛来して巣を作ったらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雨上がりの水たまりで、一羽の軽鴨が熱心に羽づくろいをしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "月に軽鴨飛んで来る。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "えぞせんにゅう、えぞおおあかげら、くまげら、しめ、赤ばら、えぞやまどり、しまえなが、のびたき、かけす、きびたき、るりびたき、しぎ、うみがらす、つつどり、きんくろはじろ、かるがも、こおりがも、おおせぐろかもめ、おいらんかもめ、うみしぎ、ちどり、うのとり。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは少し時間がかかるがもっと優しい。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            }
          ]
        }
