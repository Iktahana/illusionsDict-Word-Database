        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "消防署の仮眠室には、出動指令がすぐ聞こえるようにスピーカーが備わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「会社の仮眠室、アロマの香りがしててめちゃくちゃリラックスできるんだよね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "宿直明けの看護師さんが、静まり返った仮眠室で深い眠りについていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そのなかは仮眠室のように作ったスペースで、物置として使われていた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくたちオートバイの原稿輸送員が臨時に泊まるときに使う仮眠室につながった廊下に出た。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社の仮眠室の、かいこ棚のようなベッドへこれからいけば、七時間は眠れる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
