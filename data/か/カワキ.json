[
  {
    "uuid": "16ee1176-3f99-5168-8a3f-ae23cc587d30",
    "entry": "渇き",
    "reading": {
      "primary": "かわき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
