[
  {
    "uuid": "b4260d1a-7496-5ad8-8e19-b576f1537fdd",
    "entry": "花瓶",
    "reading": {
      "primary": "かびん",
      "alternatives": [
        "はながめ",
        "かへい"
      ],
      "is_heteronym": false
    },
    "grammar": {
