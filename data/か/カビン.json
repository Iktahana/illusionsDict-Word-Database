      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(flower) vase",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "玄関に季節の花を生けた花瓶があるだけで、家の雰囲気がパッと明るくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "不注意で手があたり、お気に入りのガラスの花瓶を粉々に割ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一輪挿しの小さな花瓶を窓際に並べて、ささやかな彩りを楽しんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "自分も縁側へ出て新しく水を入れた手水鉢で手洗い口すすいで霊前にぬかずき、わが名を申上げて拍手を打つと花瓶の檜扇の花びらが落ちて葡萄の上にとまった。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁に出した花瓶の枯菊の影がうら淋しくうつって、今日も静かに暮れかかっている。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアノが台の下の小滑車で少しばかり歩き出しており、花瓶台の上の花瓶が板間にころがり落ちたのが不思議に砕けないでちゃんとしていた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしやこの縁を厭ひたりとも、野末の草花は書院の花瓶にさゝれん物か。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "困り入ってどうしたものかと考えながらその解釈を捜すような心持で棚の上を見ると、そこに一つの白釉のかかった、少し大きい花瓶が目についた。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局私は白い花瓶と、こわれない別の青い壷との二点をさげておめおめと帰って来た。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その女が髮を結はうとして、その腕をやさしい花瓶のやうに、もち上げでもしたら、どんなにか、それを目に入れただけでも、私達の失意は一瞬にして力づけられ、私達の不幸は赫くことだらう！",
              "citation": {
                "source": "窓",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　ホテルの部屋で僕はかの女が花瓶の中の花の茎のように華奢な肉体なのに気が付いた。",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い天井、白い壁、その上ならず壇の上には時ならぬ草花、薔薇などがきれいな花瓶にさしてありまして、そのせいですか、どうですか、軽い柔らかな、いいかおりが、おりおり暖かい空気に漂うて顔をなでるのです。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋でも花瓶に花卉を盛りバルコンにゼラニウムを並べ食堂に常緑樹を置くが、しかし、それは主として色のマッスとしてであり、あるいは天然の香水びんとしてであるように見える。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "食卓には、いつも、切子ガラスの花瓶に、時節の花が挿してあった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の間の花瓶には撫子がしおらしく生けてあって、壁には一面の琴が立ててあったが、もう眼が眩んでいるお蝶には何がなにやら能くもわからなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "花が枯れて水が腐ってしまっている花瓶が不愉快で堪らなくなっていても始末するのが億劫で手の出ないときがある。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "適当な花瓶がなかったからしばらく金盥へ入れておいた。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく宅から持って来た花瓶にそれをさして、室のすみの洗面台にのせた。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さびしい花瓶の菜の花もそのたびに淡いあわれの情趣を誘うた。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかここでたいへんおもしろいと思う花瓶を見つけてついでのあるたびにのぞいて見た。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと始めのうちに同居していたたくさんの花瓶はだんだんに入り代わって行くのに、これだけは木守りの渋柿のように残っていた。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこのあいだ行って見ると、もうこの自分の好きな花瓶も見えなくなっていた。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓上の花瓶に生けた紫色のスウィートピーが美しく見えた。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴェランダの上にのせた花瓶代用の小甕に「ぎぼし」の花を生けておいた。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだ、ありがたかろう」　床の正面に、半分枯れかかった樺色と白との野菊を生けて、駄菓子でこね上げたような花瓶のおいてあったのを、障子の隅におろしてしまって、その代りに自分の懐ろから制帽を取りだして恭しく飾りながら、ガンベが拝むような様子をしてこういったっけ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "がらくた壇上に張交ぜの二枚屏風、ずんどの銅の花瓶に、からびたコスモスを投込んで、新式な家庭を見せると、隣の同じ道具屋の亭主は、炬燵櫓に、ちょんと乗って、胡坐を小さく、風除けに、葛籠を押立てて、天窓から、その尻まですっぽりと安置に及んで、秘仏はどうだ、と達磨を極めて、寂寞として定に入る。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その先生の右手から、黄の綾を着た娘が立つて、花瓶にさした何かの花を、一枝とつて水につけ、やさしく馬につきつけた。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三間に七間程もあらうかと思はれる可なり細長い部屋の廻りは本箱やら、飾棚やらが不秩序に押し並んで居て、一一記憶に残る程の品物ではないが、雑然としてあちこちに置かれてある置物や豹の皮や、時計や花瓶などが、彼の交際範囲を説明するに十分参考になるものであつた。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の間は一間の板敷なるが懸軸も無く花瓶も無し。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "時は丁度五月の始めで、おきよさんという十五、六の娘が、菖蒲を花瓶に挿していたのを記憶している。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の花瓶には彼の椿が生けてあって、手入の好い所為でもあろう、紅い花は已に二輪ほど大きく綻びていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "少々お邪魔をいたします」　こう云って、半七は仏前の香炉、花瓶、そのほかの仏具を一々｜検めたが、やがて小声で松吉に云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、いつかびんの口から、のぞいて見た景色だ！",
              "citation": {
                "source": "びんの中の世界",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
