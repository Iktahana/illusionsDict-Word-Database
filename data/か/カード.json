    "definitions": [
      {
        "index": 1,
        "gloss": "card (information, filing, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "絵葉書屋へはいったら一面に散らした新年のカードの中には売れ残りのクリスマスカードもあった。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花屋の店の氾濫、カード屋のカード字も独逸風のややっこしい装飾文字が太く賑やかに刷られて居るのも、他の国のとは自然違う感じです。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女将のアレキサンドラは片隅で亭主の白系露人とポーカーを七枚のカードを並列してやっていた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "向いのＮ万ビルのマネキン事務所には、アメリカン・スタイルの女たちが地面にカードをひろげたように、緋の絨氈の上でお化粧を始めていた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりかすかに舌打てば、　　ひとりは古きらしゃ鞄、黒きカードの面反りの、　　　わびしきものをとりいづる。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八、ノルデは野原にいくつも茶いろなトランプのカードをこしらえた。",
              "citation": {
                "source": "ペンネンノルデはいまはいないよ　太陽にできた黒い棘をとりに行ったよ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "九、ノルデがこさえたトランプのカードを、みんなは春は桃いろに夏は青くした。",
              "citation": {
                "source": "ペンネンノルデはいまはいないよ　太陽にできた黒い棘をとりに行ったよ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は今リカードの鉄則と取っ組合をしている。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕許には型の如く小さなカードが置いてあつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この店創始以来の客数とそれに奉仕した家鴨とを同一数に附号付けたカードを客に渡すことをこの店の特色としている。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "店を出るとき家鴨の番号を記入したカードをマネージャーが恭しく客に差し出す。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "野原は目の前から、遠くのまっしろな雲まで、美しい桃いろと緑と灰いろのカードでできているようでした。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日ごとに桃いろのカードも緑のカードもだんだんつぶされて、泥沼に変わるのでした。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀色の紐を通した一組七枚重ねの、葉形カードに仕上げて、キャバレエの事務所へ届けに行くと、一組分買え、いやなら勘定から差引くからと、無理矢理に買わされてしまった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀吉は何思ったか、寄って行って、その復員軍人が、カードに、「小沢十吉……」　と、書いたのを、素早く読み取った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お加代をはじめ、青蛇団の連中はハナヤの前に落ちていた青い蛇の絵カードを見て、かけつけて来たのだ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのカードの裏には「十時、中之島」と亀吉の下手な字が書かれてあった――と今ここで説明するのは、それこそ蛇足であろう。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのトランプの家というのは、トランプのカードの絵のあるほうを、内側へむけて、作ったものでした。",
              "citation": {
                "source": "とびくらべ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "良心のカードの中に、迷信のカードがまぜられて、その中から一枚、引きぬかれたのです。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに理智の反省は、これを概念によって分析し、有機的な統一を無機的に換え、部分を箇々の戸棚に別け、見出しカードの抽斗を付けて索引に便利にする。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめはカードのように四角にきって、つぎに角をまるくする。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この往来を電車と並行して来る美事な旧式パッカードの箱自動車の中に並んでいる――燕尾服の紳士と夫人らしい夜会服、それがソックリ伯父と玉兎女史に見えたのだ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、左の方から疾走して来たパッカードのオープンが烈しい警笛を鳴らしながら、行きすぎた。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのパッカードの中に黄色いルームに照らされて並んでいたのは疑いもなく私の弟と、アダリーではなかったか。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "香奠十円送ります」　という奇特な方や、色々であったが、一番痛快でタタキ付けられたのは敬弔の文字を印刷したカードを二銭の開封にして来た一通であった。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は日本国中を皆殺しにするつもりで、こんなカードをフンダンに印刷して用意しているのじゃないか知らんと思って茫然となった。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
