        "examples": {
          "standard": [
            {
              "text": "一瞬の隙を見て、男はカウンターに置いてあったスマホを掻っ払って走り去った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、お兄ちゃんのマンガをこっそり掻っ払って読んでいたのを思い出すよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "店の入り口で、女性がハンドバッグを掻っ払われる被害に遭った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、いつも人のものをおもしろがって掻っ払うから困る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その男を捜しに来たのだ」「おい、ふざけるなよ、博戯もせずに、賭場へ何しに来やがったんだ」「すみません」「向う脛を掻っ払うぞ」「すみません」　ほうほうのていで出て来ると、追いかけて来たガチャ蠅の一人が、「野郎待て。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "──かっぱらうこと。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "掏摸が一度、豪勢な身なりをしている男の懐中物をくすねて鼻をあかしてやると、その快味が忘れられず、何回もそれを繰りかえし、かっぱらう。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その騒ぎにつけこんで、回々教徒が、人がつめたマッチを、自分がつめたようにかっぱらうんだな。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「郷票をかっぱらうんなら、まだ分るが、鐚一文もない軟派の娘をかっぱらってどうするんだい。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、いつ主人のものをかっぱらうか油断もすきもありゃしない、とこう、見られているんだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　薄板をかっぱらうことについてゴーリキイは説明する。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "当人はヴァンドンゲンを愛していて、青色の人物をよく描くのだが、勘三に言わせると「空家に住む人物」だと酷評するので、三石は、十七歳の蓮子をかっぱらうと同時に、勘三の所へはちっともやって来なくなった。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムクはいい犬だったなあ――ムクは可愛ゆい奴だなあ――ムクは……　やや暫くした瞬間に、ハッと気がついて、例の責任感がこみ上げて来ると矢も楯も堪らず、土産物屋の熊胆をかっぱらうようにさらって、走り出しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、おじいさん、あんなくず屋が、くつなんかをかっぱらうのだろう。",
              "citation": {
                "source": "雪の降った日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何をかっぱらうのでしょう、きっと林さんの何かでしょう」と目玉をクリクリさせました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
