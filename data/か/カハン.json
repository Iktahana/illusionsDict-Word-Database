    "definitions": [
      {
        "index": 1,
        "gloss": "riverside",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夕暮れの河畔を歩いていると、遠くから子供たちの笑い声と、水鳥が羽ばたく音が風に乗って聞こえてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あそこの河畔に新しくできたカフェ、テラス席から夕日が綺麗に見えるらしいよ。今度行ってみない？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都会の真ん中にありながら、この河畔の公園だけはまるで時間が止まっているかのような静けさに満ちている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "えびのいる清洌な小川の流れ、それに緑の影をひたす森や山、河畔に咲き乱れる草の花、そういうようなもの全体を引っくるめた田舎の自然を象徴するえびでなければならない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の歴史の恐怖時代といふべき、平家の末路から、鎌倉の執権政治にかけて、悲壮なる運命劇は、何故か東海道の河畔で演ぜられたのが多い、承久の乱に鎌倉に囚はれて、東下りの路すがら、菊川の西岸に宿つて、末路の哀歌を障子に書きつけた中御門中納言宗行卿もさうである。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "河畔の蘆の中でしきりに葭切が鳴いている。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして数刻を経た後ガロンは共産軍を組織し、陳独秀の率いた工人と苦力の暴民を合して南北の橋路に支那軍隊と衝突して河畔に対峙し遂に市街戦となり、各国の陸戦隊が出動して共産軍は撃退され、一時間後上海は平穏に還った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明前には奥漢鉄路で捕えられた二百名からの党員が銃殺されて、珠江に投げ棄てられた死体が河畔の摩天楼の下に櫛比して河底に埋もれ、蛋民によって水葬されたのだ。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の傲がんなこころがすこしの反省もなく、イズモ町の彼女経営の流行品店を素通りして、築地河畔のコルビジェ風のアパートメントの一室を訪れた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "戎橋河畔の新京阪電車の広告塔のヘッド・ライトが、東道頓堀の雑鬧が奏でる都会の嗄れ声に交錯して花合戦の幕が切っておとされた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲田桑畑芋畑の連なる景色を見て日本国じゅう鋤鍬の入らない所はないかと思っていると、そこからいくらも離れない所には下草の茂る雑木林があり河畔の荒蕪地がある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一段降りて河畔の運動場へ出ると、男女学生の一と群が小鳥のごとく戯れ遊んでいた。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして河畔に茂った「せんだん」の花がほろほろこぼれているような夏の日盛りの場面がその背景となっているのである。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人とも黄河の河畔で、犬に喰われて白骨が出ていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冒頭のドニエプル河畔の茫漠たる風景も静的である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "観音の境内や第六区の路地や松屋の屋上や隅田河畔のプロムナードや一銭蒸汽の甲板やそうした背景の前に数人の浅草娘を点出して淡くはかない夢のような情調をただよわせようという企図だとすれば、ある程度までは成効しているようである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてわれ今再びこの河畔に立ってその泉流の咽ぶを聴き、その危厳のそびゆるを仰ぎ、その蒼天の地に垂れて静かなるを観るなり。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は今ワイ河畔の詩を読んで、端なく思い起こすは実にこの一年間の生活及び佐伯の風光である。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "セーヌ河畔の釣り人や、古本店、リュクサンブールの人形芝居、美術学生のネクタイ、蛙の料理にもどこかに俳諧のひとしずくはある。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "河畔の営舎の昼飯後の場面が、どこかのどかでものうげで、そうして日光がまぶしいといったような気持ちをだしている。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて尋ねた先生の家は白川の河畔で、藤崎神社の近くの閑静な町であった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "救助隊を出さねばなるまいという者もあったが、ナァニあの先生が捕虜になる気遣いはないと、一同は一足お先に那河川に架けたる橋を渡り、河畔の景色佳き花月｜旅店に着いて待っていると、間もなく杉田先生得意満面、一行の荷物を腕車に満載してやって来た。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりで故郷へ歸り、廣瀬川の河畔を逍遙しながら、私はさびしくこの詩を誦した。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――廣瀬河畔を逍遙しつつ――附録散文詩自註　　前書　詩の註釋といふことは、原則的に言へば蛇足にすぎない。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――廣瀬河畔を逍遙しつつ――附録散文詩自註前書　詩の註釋といふことは、原則的に言へば蛇足にすぎない。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "広瀬河畔の晩翠を知らむと欲せば、必ずしも之を詩を知る者に聞くを要せざる也。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "建てて数十年を経たる古家なれば、掃除は手綺麗に行届きおれども、そこら煤ぼりて余りあかるからず、すべて少しく陰気にして、加賀金沢の市中にてもこのわたりは浅野川の河畔一帯の湿地なり。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "河畔へ出て見ると、休憩所の周りは既に群集で埋っていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "石井柏亭、山本鼎、高村光太郎、木下杢太郎、長田秀雄、吉井勇等の諸君と、初めて“PAN”の盛宴を両国河畔に開いて以来、Younger generation の火の手はわかい感傷的な私達を愈狂気にした。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "河畔の貧しい生活者にもこうした天与の恩恵はある。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらえらい良えとこイあんた、行きはりまんねんなアとひとびとは言うのだが、肚の中ではおたかはんも到頭いたたまれんようにならはったと、さすがに見抜いていた。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは祇園の家々の軒を「ものもお、ものもお」と紙を配りながら大聲で誰とかはんのお妹はんが云々と呼んでゆく人達であらう。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、あんた――」妻君は義眼でない方の眼をふっと細めて、「こないだ中までいてくれはった菅はんいうお人をね、わてと怪しいいうて追い出したり、そら焼餅やかはんのどっせ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
