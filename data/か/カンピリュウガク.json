        "examples": {
          "standard": [
            {
              "text": "厳しい選抜試験を勝ち抜き、ついに憧れの官費留学への切符を手に入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "官費留学から帰国した彼は、欧米で学んだ最新の技術を国内に広めるべく奔走した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「官費留学は経済的な負担が少ない分、国を背負って学ぶという責任も重いんだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「切角今まで遣って来て、卒業しないのは残念だが、所詮官費留学生になれない僕がこの機会を失すると、ヨオロッパが見られないからね」「そうだとも。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "当人の咄では官費留学生の候補者ださうだ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に官費留学生として渡ってきたのは一九一五年で、労農革命より三年近くも前のことである。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
