  {
    "uuid": "2414588a-0f3a-5726-bcd1-2681d5ce1b57",
    "entry": "変え",
    "reading": {
      "primary": "かえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "changing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "気分転換に部屋の模様変えをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の言葉は、私の考えに変えをもたらした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "季節の変え目に体調を崩しやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会議の進行に変えがあったため、急遽アジェンダが変更された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "話が佳境に入って来ると、ヘルンは恐ろしそうに顔色を変え、『その話、怖いです、怖いです』といっておののきふるえた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへＣやＤやＥやＦやＧやＨやそのほかたくさんの人物がつぎつぎに出て来て、手を変え品を変え、さまざまにＢを中傷する。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君は転々と職を変えた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母が顔色を変えて走って来ました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日常見慣れた現象をただ時間の尺度を変えて見せられただけの事である。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って私はもしも歌人が自分の顔を気にしてそれを色々に変えようとするような事があるとすれば、それは大して努力するだけの意義のある事ではないように思う。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また子を生むといつでもその子を取り上げられるので色々隠し場所を変えた末に、とうとう主人の書斎の書棚の奥に隠した猫もある。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平野のどこからも眺められるその山は、朝は藍に、昼はよもぎ色に、夕は紫に色を変えた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "目的の発明が空想されているうちは、確に素晴らしく思ったが、実地に調べたり、研究する段になると、自分と同種の考案はすでにいくつも特許されていてたとえ自分の工夫の方がずっと進んでいるにしても、既許のものとの牴触を避けるため、かなり模様を変えねばならなくなった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、よだかでないただのたかならば、こんな生はんかのちいさい鳥は、もう名前を聞いただけでも、ぶるぶるふるえて、顔色を変えて、からだをちぢめて、木の葉のかげにでもかくれたでしょう。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、名前を変えるには、改名の披露というものをしないといけない。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども毒もみは卑怯だから、ぼくは厭だと答えたら、しゅっこは少し顔いろを変えて、卑怯でないよ、みみずなんかで、だまして取るよりいいと云って、あとはあんまり、ぼくとは口を利かなかった。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなも顔色を変えて叫んだのです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その語をフランスが輸入して、次第に趣味についての 〔e'le'gant〕 に近接する意味に変えて用いるようになった。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にユダヤ人の後裔にとっての一つの神なるエホバは自ずから姿を変えて、やがてドルになりマルクになった。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治十九年に両親と祖母に伴われて東海道を下ったときに、途中で祖母が不時の腹痛を起こしたために予定を変えて吉浜で一泊した。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの沢山の不愉快な顔が醸す一種の雰囲気は強い伝染性を持っていて、外から乗り込んで来る人の心に、すぐさま暗い影を投げないではおかない、そして多くの人の腹の虫の居所を変えさせようとする傾向がある。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今電子の質量が純粋な電磁的のものかあるいは一部分は速度に無関係なものであるかという問題を決するには、速度種々に異なる電子が電磁場でその径路を変える模様を見れば分るはずであるので、カウフマン以後種々の人が精密な実験を行うたその結果は電子の質量はほとんど全部電磁的のものであるらしい。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また微弱な気流でもその落下の方向速度を変える事は明白である。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔(Ar.)gharib, ghuraba_〕「異常」は喉音のｇをとると「わらふ」にも似てるし、ｈをｂに変えると「べらぼう」のほうに近づく。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なすの「しぎ焼き」の「しぎ」にもいろいろこじつけがあるが、「しき」と変えてみると、結局「すき」と同じでないかという疑いが起こる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それであるから外国から言葉が入って来る場合に、聞く人の言語のもっている音に合わないような音があると、その音を変えて、聞く人の言語にある諸音の中のどれかに合うようにするのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで気を変えるために休暇の必要を感じた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから座敷へ上ると、妻が洋服をぬがせて和服に着かえさせてくれる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "たったいま教ったばかりのフランスの叙情詩とは打って変ったかかる無学な文句に、勝手なふしをつけて繰りかえし繰りかえし口ずさみながら、れいの甘酒屋を訪れたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ私は、こんな男から逃げ出さずに、かえって親密になっていったのか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場はときたま、てかてか黒く光るヴァイオリンケエスを左腕にかかえて持って歩いていることがあるけれども、ケエスの中にはつねに一物もはいっていないのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は実にしばしば服装をかえて、私のまえに現われる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の平然と呟くところに依れば、彼がこのようにしばしば服装をかえるわけは、自分についてどんな印象をもひとに与えたくない心からなんだそうである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、振りかえりざま、叫ぶようにして言った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
