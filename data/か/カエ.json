    "definitions": [
      {
        "index": 1,
        "gloss": "change",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅行には、予備のTシャツと靴の替えをいくつか持っていくと安心だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「すみません、千円札の替えはありませんか？」とレジで尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そのレストランでは、ご飯のおかわり自由で、何杯でも替えがもらえる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は気分転換の替えに、最近ジョギングを始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "風呂から出て奥の間へ行くと一同の着替えがそろえてある。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい自分は両親にとっては掛け替えのない独り子で、我儘にばかり育ったが、病気となると一層の我儘で手が付けられなかったそうである。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥居は六十一年目に立て替える定めだそうで、今のは二十七回だと、立札がしてあるが、そんなことはどうでもいい。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "老妓は柚木のいうままに家の一部を工房に仕替え、多少の研究の機械類も買ってやった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分で襖を張り替えてそれに書や画もかく。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな姉妹は下駄を取り替える。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥へ床を移さねばならぬといって、奥の床の前へ席を替えさした。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは皆して参ってくるがよかろう……いや着物など着替えんでよいじゃないか」　女達は、もう鼻啜りをしながら、それじゃアとて立ちあがる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "男親の口からこんなことをいうも如何ですが、民子は命に替えられない思いを捨てて両親の希望に従ったのです。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜の幾枚目かの衣裳を着替えて化粧室からあらわれてくる踊子は、その小脇にかかえた口紅棒の汚点のついたハンド・バッグを離さない。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が夜会服に替えてサルーンに設けられた席に着くと、金モールの事務長の植民地通いの海員らしい頑丈な腕がさしのべられて関西｜訛のある社交的なバスが、ようこそ、Ｙさん。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "観客は亮の兄弟と自分らを合わせて四五人ぐらいはあったが、映画技師、説明者が同時に映画製造者を兼ねるのみならず、肝心のガラス板がやっと二枚ぐらいしか掛け替えがないのだから亮の骨折りは一通りでなかったろうと思われる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに引き替えて、母のおまきは近所の評判がだんだんに悪くなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蝶は長い紅い総のついている枕のうえに、幾たびか重い頭の置きどこを取り替えてみた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼がさめると枕もとにはゆうべの女たちが行儀よく控えていて、さらにお蝶に着物を着替えさせてくれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "物狂おしい奥方は、替え玉のお蝶を夜も昼もときどき覗きに来て、死んだ姫の魂が再びこの世に呼び戻されたものと思っているらしく、それからは忘れたようにおとなしくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏が過ぎても、かれは白地一枚のほかには洗い替えの浴衣すら持たなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はかわるがわる黙って茶椀を替えた。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　待っていた為替が家から届いたので、それを金に替えかたがた本郷へ出ることにした。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　で、父が一伍一什を話すと――「立替えましょう、可惜ものを。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、ここは一ツ、私に立替えさしてお置きなさい。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "構わないけれど、唯立替えさして気が済まない、と言うんなら、その金子の出来るまで、僕が預かって置けば可うがしょう。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳の葉の翠を透かして、障子の紙は新らしく白いが、秋が近いから、破れて煤けたのを貼替えたので、新規に出来た店ではない。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくもここには人間の好意が不思議な天秤にかけられて、まず金に換算され、次に切手に両替えされる、現代の文化が発明した最も巧妙な機関がすえられてある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうじゃ、今朝も今朝とて穂吉どの処を替えてこの身の上じゃ、」　説教の坊さんの声が、俄におろおろして変りました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいさして足を替えつ。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の譬えに比較してみますと、こちらは、無理なことをして温泉行きなどせずに、只今の住みにくいこの我が住家について、どこが住みにくいのか、襖が破れていたら張り替えもしよう、雨漏りがしていたら、穴も葺き防ごう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの井戸は多摩川から上水を木樋でひいたもので、その理由から釣瓶で鮎を汲むなどと都会の俳人の詩的な表現も生れたのであるが、鮎はいなかったが小鯉や鮒や金魚なら、井戸替えのとき、底水を浚い上げる桶の中によく発見された。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ばけつ持ってお出で」井戸替えの職人の親方はそう云って、ずらりと顔を並べている子供達の中で、特にお涌をめざして、それ等のさかなの中の小さい幾つかを呉れた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供達は井戸替え連中の帰るのを見すまし、まだ泥土でねばねばしている流し場を草履で踏み乍ら、井戸替えの済んだばかりの井戸側のまわりに集ってなかを覗く。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "substitute",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
