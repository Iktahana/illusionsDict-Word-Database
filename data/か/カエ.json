[
  {
    "uuid": "9f5926d6-b90b-577a-8d32-e85c58fa1f61",
    "entry": "替え",
    "reading": {
      "primary": "かえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
