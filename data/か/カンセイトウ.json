        "examples": {
          "standard": [
            {
              "text": "パイロットは離陸の最終許可を管制塔から得る必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「こちら管制塔、滑走路24、離陸を許可します。」静かな管制塔からの声が響いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "管制塔にいる航空管制官は、数マイル先からでも航空機の動きを正確に把握している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの管制塔、夜でもライトがすごく明るいね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その場合はまず空港管制塔に通じて承認を求める。",
              "citation": {
                "source": "「もく星」号の謎",
                "author": "――白鳩号遭難事件を回顧して――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
