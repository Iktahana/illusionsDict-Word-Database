          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "そのドキュメンタリーは、都市の片隅に生きる下層社会の人々の、知られざる日常を克明に描いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、過去に下層社会での経験があったため、困難な状況でも生き抜く術を知っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの裏通りは、夜になると下層社会の連中が集まる場所だから、一人で近づくのは危ないよ。」と、地元住民は警告した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "例えば下層社会の低劣な品性の如きも教育の不備よりはむしろ精神欠陥に帰し、一時好んで下層社会に出入するやライフの研究者を任ずると共に下層社会に共通する悪俗汚習の病因たる精神欠陥を救うの教師を自任し、細さに下級の生活状態を究めて種々の自己流の精神医療の方法を案出して試みた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩年或る時、この時代の誤解や失敗の経験を語って曰く、「あの時代、むやみと下層社会が恋しかったのは、やはり露国の小説に誤まられたのだ。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果が意外な根柢ある革命的｜煽動が下層社会に初まったり、美くしいヒューマニチーが貧民の間に発現されたりする。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "露国の小説にはこの間の消息がしばしば洩らされて下層社会のために気を吐いている。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう小説に読耽ったもんだから自然下層社会に興味を持つようになったが、日本の下層社会は根本から駄目だ。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「震災後、私等は下層社会の堕落よりも、上流社会の堕落を余計に見せ付けられるようです。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "下層社会の者は、革命と云えば、人殺し泥棒勝手次第という意味に考えるのと同様に、上流社会の人々は、平民的と云えば、不義乱倫自由自在と解釈するのは止むを得ないかも知れぬ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや下層社会に住む職業婦人がどうして身を護り得よう。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "下層社会安飲食店の女　東京の上流社会の紊乱は既に書いた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら下層社会はどうか。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "下層社会の堕落の対象は、大体に於て所謂低級な醜業婦、即ち単純な意味の職業婦人である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災前の不良少年は、大抵、下層社会の、割合いに無教育な親を持つ子弟であった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一は震災後の東京市民が一体に文化的――言葉を換えて云えば理智的に気が弱くなった事、第二には一時減少した人間がその後急に殖えて、家数が建込んだ事、第三は復興気分で下層社会の景気がよくなった事等であるが、その中でも第一の原因が最も有力であるらしい事を警視庁の統計が示している。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "下層社会の女などがよくあの人は様子が宜いということをいうが、様子が宜い位で女に惚れられるのは、男子の不面目だと思います。",
              "citation": {
                "source": "模倣と独立",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体このロシアという国は、下層社会の者が上流社会で行われるいろんなゴシップの受売りをしたがる国だから、忽ちこの話は、チチコフのことなどは知りもしなければ、顔を見たこともない手合いの、荒ら家でまで云々されるようになり、いろんな尾鰭がつけられて、ずいぶん振った解説が加えられたものである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏蘭西革命時代に自由論が教育ある中流社会に唱えられていた間は大した過もなかったようであるが、無教育な下層社会に唱えられ出してからは、有らゆる暴行を促すようになって、遂に乱暴狼藉に反対し合理的の民権自由を主張した者は片端より断頭台上の人となされた。",
              "citation": {
                "source": "デモクラシーの要素",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして善人を賞し悪人を罵る講釈師、落語家、デロレンなどが教導職と称せられ、下層社会の教育を掌った観がある。",
              "citation": {
                "source": "教育家の教育",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "下層社会の人気が集まる。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、寧ろ下層社会の嗜好に属するものが大部分である。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "前述の下層社会の描写に対して、上流社会の生活は、コンスタンチヌス皇帝の髯剃の一状景を見れば充分であろう。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "（press）黄色新聞（原 1898 年に Spain との戦争を唱うるため米国に起り、現今にては一般に下層社会の人気を取る新聞）。",
              "citation": {
                "source": "熟語本位英和中辞典",
                "author": "Y",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも、労働者のやうな人相の悪い男でしたがあんまり、図々しいので尺取虫が外へ追ひ出したんですがね、あなた方には一寸想像出来ない事が下層社会の人間には平気で出気るんですよ。",
              "citation": {
                "source": "こほろぎの死",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この本の著者――猪子蓮太郎の思想は、今の世の下層社会の『新しい苦痛』を表白すと言はれて居る。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『左様ですなあ、僕の読んだのは「労働」といふものと、それから「現代の思潮と下層社会」――あれを瀬川君から借りて見ました。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時丑松は日頃愛読する先輩の著述を数へて、始めて手にしたのが彼の大作、『現代の思潮と下層社会』であつたことを話した。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホラ、君の読んで下すつたといふ「現代の思潮と下層社会」――あれを書く頃なぞは、健康だといふ日は一日も無い位だつた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
