        "examples": {
          "standard": [
            {
              "text": "厳粛な葬儀で、神父はゆっくりと「棺を覆う」ために、黒いビロードの布をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "親族たちは、最後の祈りの前に順番に「棺を覆う」作業を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "伝統に従い、長男が敬意の印として「棺を覆う」ように頼まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祭壇係が、儀式に則り慎重に「棺を覆う」作業を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "棺が運ばれた後、葬儀ディレクターが「棺を覆う」ことを指示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "むかしの人のいったごとく人生は棺を覆うて始めて定まるものである。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから人を批評せんとならば、その人が棺を覆うてからでなければ完全な事はいえない。",
              "citation": {
                "source": "現代能書批評",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
