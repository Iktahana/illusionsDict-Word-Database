[
  {
    "uuid": "523e78bd-06f8-52a9-a9e7-4464cbb1e351",
    "entry": "顔向け",
    "reading": {
      "primary": "かおむけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "showing one's face in public",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "失敗続きで、みんなに顔向けできない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は堂々と会社に顔向けして、自分の非を認めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "恩師に顔向けできるよう、必死に努力した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "石・苔・偃松（白河内岳に登る記）　野営を撤して、濡れそうなものは油紙で包み、岩伝いに北を向いて、大籠山と後で名をつけた一峰に達した、三等三角測量標が立っている、霧が吹雨を浴びせかけて、顔向けも出来なかったが、白峰山脈で、初めての三角標に触れたのだから、ちょっと去りにくい気がした。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでになつて此話が破れれば、私は金主に対して済まないことにもなるが、それはまだいいとして、私の本人に申訳が無いし、相手方の代理人の大草さんにも顔向けが出来なくなる。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな真似をした日には、二度と再び世の中に顔向けができない。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世に生きていないつもりなら、羞汚も顔向けもありはしない。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その窓に時々姿を見せて、われに笑顔向けたまうは、うつくしき姉上なり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれだけの大きい店でもあり、旧家でもあり、お父さんは町長を勤めたこともある位ですから、その家の娘たちが色気違いのようになってしまっては、世間へ対しても顔向けが出来ません。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一この縁談が破れたなら、わたしは井戸屋に顔向けが出来ないばかりでない。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今もいう通り、組内でもいろいろの噂をしているので、もし仕損じるようなことがあったら、人に顔向けも出来ないので……。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ず力を合わせて満月を泥の中に蹴落し、世間に顔向けの出来ぬまで散々に踏み躪って京、大阪の廓雀どもを驚かしてくれよう。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "稼がせるために忠太郎を美津の聟にしたとなると、それこそ、世間さ顔向けが出来なくなる。",
              "citation": {
                "source": "栗の花の咲くころ",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "里へ帰って親兄弟や親類にも顔向けが出来ない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋の戸を開けると顔向けも出来ないほど雪が吹き込んだ。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ云って置けば、二度と顔向けは出来ないよ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はお前にも顔向けが出来ないのだ！",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、修学旅行の仲間入りのできないことを、友達にも顔向けのできないほど、恥かしいことだと思い詰めていたものですから、一晩中でも泣き明かすような決心で、父の枕元で、いつまでもぐずぐず駄々をこねていました。",
              "citation": {
                "source": "勝負事",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりはげしい昂奮に理性を失った彼女は、博士の大事な実験を滅茶滅茶にして博士を世間へ顔向けのできぬようにし、どこか地球の果てというようなところへ行って自分と二人で恋愛三昧の生活を送ろうと考えたのである。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝のような中途半パで帰って来た不埒な奴を家に置いたとあっては、俺が世間へ顔向けが出来ない。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "一度家に帰り父に誡められたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなしい彼女は世間にもう顔向けができないように思って、その事実の有無を弁解するよりも、いっそ死んだ方が優であると一途に思いつめた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "小女郎狐",
                "note": "青空文庫"
              }
            },
            {
              "text": "科人の仕返しが怖くって、仲間の知恵を借りたなぞと云われちゃあ、世間に対して顔向けが出来ねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤吉はふところに短刀を呑んでいて、見つけ次第に三甚を突き殺すつもりだったと云いますから、まあ逃げていた方が無事だったかも知れません」「三甚はその後どうしました」「こうなっちゃあ旦那方の信用をうしない、仲間の者に顔向けも出来ず、とうとう二代目の株を捨てて、さつきの婿のようになってしまいました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ云つて置けば、二度と顔向けは出来ないよ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたずら娘を持ったと云われては、世間へ顔向けができない。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もこの子には引かされますし、一度｜失敗ってもいるものですから、今度またまごつくようなことでもあれば、それこそ親類に顔向けも出来ませんのでございます。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "転向して生を守ろうと欲する人は、自分にも他人にも顔向けのできない思いで、うそをつき、仮面をつけて、現れなければならない。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第十巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を教えるものが妻と別れて平気で顔向けが出来るかという　七月八日　坪内先生へ手紙　足の工合がわるい　一人での生活をしたい心、そのときのことを楽しく空想する　七月二十二日　順天堂に通う。",
              "citation": {
                "source": "「伸子」創作メモ（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "救命艇が尠かったこと、船員の間に救助作業の組織的な訓練が出来ていなかったこと、これは会社として世界に顔向けの出来ない犯罪的な責任ですから、どさくさ紛れに他に世間の注意を外らして一時誤魔化そうとしたのです。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな恥しい目に遭って、私ゃ人にも顔向けできない、死んでやる！",
              "citation": {
                "source": "世間師",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "同監いたしましてから間もなく支倉の申しますには、自分は耶蘇教の牧師であるが、こう云う辱めを受けては再び社会に顔向けが出来ない、この上は自殺するよりないから、どうか見逃して呉れと云いました。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
