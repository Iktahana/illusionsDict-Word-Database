        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この商店街の一角にある小さな店は、新しいパン屋の店主が借り店として利用していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夏祭り限定のポップアップストアは、この借り店で展開される予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は裏通りで格安の借り店を見つけ、修理屋を始めることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」（書く）農民四、五（驚嘆す）この人ぁ医者ばかりだなぃ。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎杖とすかんぽばかりだな。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかしな奴ばかりだな」　すると後の籠舁が云った。",
              "citation": {
                "source": "山寺の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しようのねえどじばかりだな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "「成程野郎ばかりだな。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんな派手なものばかりだな。",
              "citation": {
                "source": "質物",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "働かす条件が悪くても、どうせまだ親がかりだなどといういいわけで、職場の設備の悪いことも、厚生施設のないことも、第二の問題のように扱います。",
              "citation": {
                "source": "質問へのお答え",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの子｜可哀想に、やられてばかりだなア」　梶は投げつけようとしていた餅もやめにして云った。",
              "citation": {
                "source": "罌粟の中",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「千円借して四百円天｜刎ねて……判こ押してさへ居りゃ懐手で身上がふえて行くばかりだなんて、人を馬鹿にしとるなあ」　昇三は考え込むやうにして、「ん、それよか第一福本は町の人間じゃないか？",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど、みんな子どもばかりだな」　かれはつぶやくようにいって、ジロジロ洞中を見まわした。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "学問なりその他の名誉を得て傲る者を見ると、彼奴も近ごろ一円｜貰ったばっかりだな、ああいう風にやっては明日の日の登る前に形無しになるであろうと思う。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんに、この世は、ままならぬことばかりだなあ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が政治に凝らないのは世のため人のため大助かりだなぞと考えた。",
              "citation": {
                "source": "握った手",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "競輪人種は暴動の元兇どもの集りと見て、最も警戒せられ、殆ど人間的には信用せられていないのだが、フシギなるかな、全部鉄筋コンクリの建物に改造しないと再開を許可しない筈の競輪場が、全然木造ばかりだなア。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかも枯れたものばかりだなんて、思ってもぞっとしますわ。",
              "citation": {
                "source": "二つの途",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一三「粉雪」と一般に呼ばれているのは牡丹雪に対してサラサラした雪のことを指している場合が多いので、北海道では冬の初めと終りには牡丹雪も降るが、真冬の間は、粉雪ばかりだなどという場合に使われる粉雪はこの意味である。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……でも良い子ばかりだな。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「――姉さんにいっても知らない人ばっかりだな」　考えていて、保は、「姉さん、東大路、知っているでしょう？",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――俺も若い頃にゃあ、どんな女にもまけなかったが、こうなっては死ぬばかりだなあ――針のめど通すに縫うほどかかるごんだ」　皆が、八十の祝いを、来年の正月早々しようと云ってくれるが、無駄な費えだと云った。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけでも六百マルクになると――それからあとの席がすっかりだな。",
              "citation": {
                "source": "神童",
                "author": "DAS WUNDERKIND",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はぬるくなった茶を飲んで、「そう言えば、公園の踊り子さんたちは、いつも子供ばかりだな。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は甲が随分あるのに」「加減したんだよ、一寸」「一年の時から乙ばかりだなんて、加減にも程がある。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっとがっかりだな。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "「確かに異常な手がかりだな。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "時鳥に借りしをわきまふると也」と顕昭が言っていれば、俊頼もまた時鳥の啼く五月頃は、百舌は沈黙して垣根などをつたいあるき、ただ時々声低く「ほとゝぎすこそ」と喚ぶばかりだなどといっている。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "立往生というのも実は溺死で、衣川の岸近い岩と岩との間に挟まって、倒れなかったばかりだなどと、自分は生き延びて逃げた癖に、人にけちを付けるようなことばかり言っている。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "足下は周瑜と親交でもあるのか」「それがしは九江の生れなので、周瑜とは郷里も近く、少年時代から学窓の友でした」「それはよい手がかりだな。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
