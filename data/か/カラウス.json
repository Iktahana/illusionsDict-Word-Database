        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔の農村では、収穫した穀物を唐臼で挽いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "大きな石でできた唐臼は、かなりの力仕事だっただろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「こんな大きな唐臼、見たことないよ！」と、子供たちは目を丸くした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この道具は、穀物の殻を剥いだり、粉にしたりするのに使われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "苅った稲も扱きばしで扱き、ふるいにかけ、唐臼ですり、唐箕にかけ、それから玄米とする。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「籾擂を機械に頼みゃ、唐臼をまわす世話はいらず、らくでええけんど、頼みゃ、頼んだだけ銭がかゝるんじゃ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして手伝ひといつても鳥右さんは、唐臼をまはすとか、田を耕すとか、俵をかつぐとか、いちばん力のいる仕事をしてくれたので、百姓家ではたいへんたすかりました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "良寛さんは黙つて本を閉ぢて、台唐臼の蹈台にのぼつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　良寛さんは台唐臼を下りて、国仙和尚の前に行つた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごほごほと雷以上の恐い音をさせる唐臼なども、すぐ寝床のそばで鳴るように聞こえた。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏が六條のほとりの、夕顏の宿に寢て、はしぢかにきこえてくる、物賣りの聲や、町人の話聲や、夜明けに隣家の下僕が嚔をするのや、唐臼の音がとどろいてくるのや、螽※が枕上ちかく飛んでくるのを見るあたりの、あの心持や、その書きかたが心憎いほどにまざまざと浮びあがつてくるのだつた。",
              "citation": {
                "source": "夏の夜",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し、唐臼を踏むが、大したきりやうさ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋へ入つて來るのをよく見て居ると、右足は左の足に比べると、どうしても二寸は短かいやうです、唐臼を踏むやうな大跛者で、それに左の肩の下がつた猫背も、何となく、不具者の痛々しさを強調します。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "双生兒の呪",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはまた恐ろしいお侠で、「父さんはあんな事を言うけれど、私は勇次郎さんは大嫌い、歩くと唐臼を踏むようなんですもの。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "北冥の魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐臼で籾を挽いて米を取つた殘りを、中國地方は一般にさう謂つて居る。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐臼で挽いた時に、すくもの屑などゝ共に殘る小米のことで、斯ういふのはヒキグヒ即ち粉食にするより他に用途は無かつた。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを掘り出して鉈ではつり、唐臼でつき、水に浸けて粗皮を取去り、底に溜つたものを握つて食べた。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐臼で籾を挽いて米を取った残りを、中国地方は一般にそういっている。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐臼で挽いた時に、すくもの屑などとともに残る小米のことで、こういうのはヒキグイすなわち粉食にするより他に用途はなかった。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを掘り出して鉈ではつり、唐臼でつき、水に浸けて粗皮を取り去り、底に溜ったものを握って食べた。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋へ入って来るのをよく見ていると、右足は左の足に比べると、どうしても二寸は短いようです、唐臼を踏むような足どりで、それに左の肩の下がった猫背も、なんとなく痛々しさを強調します。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "双生児の呪",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し、唐臼を踏むが、大したきりょうさ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは又恐しいお侠で、「父さんはあんな事を言ふけれど、私は勇次郎さんは大嫌ひ、歩くと唐臼を踏むやうなんですもの。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "北冥の魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠れ座頭は弘く奥羽・関東にわたって、巌窟の奥に住む妖怪と信ぜられ、相州の津久井などでは踏唐臼の下に隠れているようにもいっていた。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カラとはすなわち新種改良品のことで、農具には唐臼・唐鋤のごとく、カラとかタウとかいう語を冠したものが多い。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわく石の挽臼、いわく入口右手の地唐臼である。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しびっこで恐ろしく背の高いやせこけた老翁であったが、破れ手ぬぐいで頬かぶりをした下からうすぎたない白髪がはみ出していたようである。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "克巳はからうすをめずらしがって、米をつかせてくれとせがみました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "雫がだんだん茶いろになつて、それからうすい黄いろになつた。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "克巳は、からうすをめづらしがつて、米をつかせてくれとせがみました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "女も、まだしやべり續けてゐる三人の男も、山路に差しかかつたらしい機關車の喘ぎも、何時となく意識からうすれて行つた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、しばらく物をも云はずに考へ込んだやうにしてゐると、急に日が短かくなつたやうに、開けはなしてある椽の方からうす暗い影が見え初めるのであつた。",
              "citation": {
                "source": "追憶",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、まだ支那人たちは橋の欄干からうす黒い顔を並べて彼の方を眺めていた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶っぽい帯の傍からうす色の帯上げが少しのぞいて白い足袋に蹴り上げられる絹の裾が陰の多い襞を作るのを篤は静かに見て居た。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
