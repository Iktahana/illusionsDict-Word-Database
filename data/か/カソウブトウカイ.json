    "definitions": [
      {
        "index": 1,
        "gloss": "fancy dress ball",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今年のハロウィンパーティーは、豪華な仮装舞踏会形式で行われます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「どんな仮装で参加しようかな？」「そうだ、神秘的な仮面をつけた仮装舞踏会にしよう！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "王侯貴族が集まる仮装舞踏会は、華やかで謎めいた雰囲気でした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "仮装舞踏会では、個性豊かな衣装を身につけた人々が楽しんでいました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その、あんまり打ち沈んでいる僕の様子を見かねたのでしょう、マドレエヌは僕にむかって、今宵ニューカルトンの仮装舞踏会に行こうと云い出しました。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡同様、無慙にも顔面の皮膚を剥ぎそられ何処の者とも判明せざれど年齢二十三四歳位にて、サムライの仮装着を着けたるところより多分前夜何処かの仮装舞踏会に出席したる日本人にあらざるかと推測さる。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎晩、仮装舞踏会へ出かけたり、お金の札でたこをこしらえたり、海へ行けば、石のかわりに、金貨で水切りをしてあそんだりしました。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮装舞踏会からかえって来た人たちかな。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎晩、仮装舞踏会へでかけたり、お札でたこをはってあげたり、小石の代りに、金貨で海の水を打ってあそんだりしました。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮装舞踏会で注目の的になつたと喜んで、それを着た写真を寄したあれでせう、あれなら、あたしも欲しいな。",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この楯は、つい先頃村の酒場で、バツカスの灌奠祭を行ふた時の余興の仮装舞踏会に、私達三人はスパルタの兵士に身をやつして出場したのであつたが、紋章の代りに私が花文字をもつて書き誌したボール紙の楯であつた。",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それあさうと此間誰かゞ提言した仮装舞踏会を今夜あたり開かうぢやないか――」「皆なが、水着ひとつ――で、といふやつわ、あれあ実に花やかな思ひつきだ、近代的のバアバリズムも此処に至つて、その極致に達したと云ふべきだ。",
              "citation": {
                "source": "夜の奇蹟",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仮装舞踏会と云へば――」　とまた誰やらが、真面目さうに云ひ出した。",
              "citation": {
                "source": "夜の奇蹟",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時も話だけで、思ひ／＼の着想に酔つて、それつきりになつてしまふが今夜こそは、あの仮装舞踏会を是非とも実現させようではないか――。",
              "citation": {
                "source": "夜の奇蹟",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大変なことになつてしまつたよ、滝尾――ほんとうに仮装舞踏会を始めるんだつてさ。",
              "citation": {
                "source": "夜の奇蹟",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はシノンの恋人に扮してゐる私の妻に楯を持たせ、その妹に扮つた居酒屋の娘の肩を抱いて、「さあ、これで――」　と、三人は並んだが二人は、私が厭に武張つてゐて変だ、もう仮装舞踏会は終つた後のことなのだから、もつと／＼打ち寛いだ姿を執つて貰ひたい、でなければ一処に並ぶのは厭だ！",
              "citation": {
                "source": "出発",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ彼は、人をかつぐ名人として通っていたし、仮装舞踏会などで、まんまといっぱいくわせる妙技を謳われていたからである。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は仮装舞踏会に出る士官学校生徒のような、身体の輪廓に喰い込んだ水色の男装をしていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど仮装舞踏会のように、自分と踊っている女が、その無表情な仮面の下で、何を考えているのか。",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、四月二十日、伊藤首相の主催で、日比谷の鹿鳴館に内外紳士貴婦人の仮装舞踏会。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは翌日の夜、船内に開かれるところの仮装舞踏会の招待状であった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしに彼女の話をしてくれた人は、ある仮装舞踏会で彼女を見たことがあった。",
              "citation": {
                "source": "傷心",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちをあいてに劇をやったり、仮装舞踏会に出たりしたがったが、そのときの人物は、ロンスヴァルやアーサー王の円卓の英雄たちや、キリストの墓所を異教徒の手から取り戻すために血を流した一団の騎士から取ったものであった。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "各人は決して終ることのない仮装舞踏会のために衣服を著けているのであった。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "テュイルリーの宮殿★から、モンセーニュールと全宮廷とを経て、議院や、法廷や、すべての社会（あの案山子たちだけを除いて）を経て、その仮装舞踏会は下賤な死刑執行吏にまで及んだ。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大臣、国家の山師、収税請負人、医師、法律家、僧侶、大歌劇、喜劇、燦然たる間断なき流れをなした全仮装舞踏会は、馳せ過ぎて行った。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮装舞踏会は晩餐の席で輝かしく照されていた。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、馬車で流れ去る仮装舞踏会のように著飾った上流人士。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼は夜となり、仮装舞踏会は晩餐の明るい灯火に輝き、鼠は暗い穴の中でくっつき合って眠り、万物はそれぞれの道を流れる。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「実は昨夜八時ごろ政商加納五兵衛が仮装舞踏会の席上何者かに殺害されました。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その一　舞踏会殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　この仮装舞踏会は、最初の計画では鹿鳴館でやるはずであった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その一　舞踏会殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "今回の仮装舞踏会も表向きではないけれども、内々は満太郎の帰朝記念、一人前の日本紳士として彼を世におくりだすのが五兵衛の願いであり、よろこびであった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その一　舞踏会殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイカラ風俗のそこから下って来た山の高嶺――欧化の絶頂――が「鹿鳴館」にあることは衆知のところだが、そこに有名な仮装舞踏会のあったのが明治二十年四月で、それから二年経つと、明治二十二年二月十一日を期して憲法が発布された。",
              "citation": {
                "source": "ハイカラ考",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時は最も猛烈な裸レヴィュウが迎えられて、その狂態の限りを尽し、或時は仮装舞踏会を開いて、夜と共に踊り狂い、或時は名ある板前が呼ばれて、全国津々浦々から集めた、美食悪食の珍味に舌鼓を打たせるのでした。",
              "citation": {
                "source": "法悦クラブ",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
