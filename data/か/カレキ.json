    "definitions": [
      {
        "index": 1,
        "gloss": "dead tree",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "丘の上に立つ一本の枯れ木が、荒涼とした風景に寂しさを添えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "病害虫の蔓延で、森の木々が次々と枯れ木になっていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "冬の薪にするため、乾いた枯れ木を集めてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "するとキャッという女の声、驚いて下を見ますと、三人の子供は何に恐れたのか、枯れ木を背負ったままアタフタと逃げ出して、たちまち石垣のかなたにその姿を隠してしまいました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もういっそう悲惨なのは田んぼ道のそばの小みぞの中をじゃぶじゃぶ歩きながら枯れ木のような足に吸いついた蛭を取っては小さなもめんの袋へ入れているそういうばあさんであった。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜田は、昼間に見ておいた枯れ木を取りに、初年兵の後藤をさそった。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠一向平気で、背負っていた枯れ木の大束をそこへ卸して、旦那は絵の先生かときくから先生じゃアないまだ生徒なんだというとすこぶる感心したような顔つきで絵を見ていた。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし枯れ木の花が虱に変わる、ということがどこから来たかなかなか思いつかれない。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は開墾場に近い深林の中に枯れ木を焚いて一夜を明かした。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上から枯れ木が加えられた。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは声も立てないで、枯れ木を倒したように泥濘のなかに横たわった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の痩た老人夫婦は、おたがいの膚に触れあつて、たがひの背中を流し合つてゐる様子が、いまにも崩れ折れさうな枯れ木が、押あつてゐるやうであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝葉は半分葉をつけ、半分は枯れ木のままで、それがぬっと深夜の空にそびえ立っているあんばいは、それだけでも化けいちょうといいたいくらいな趣でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に東の空はほのぼのと明け渡って、向うの庭の枯れ木立の間から眩しい旭の光りが、この室の中へ一パイに映し込みました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには青眼先生が鉄になった紅矢の死骸と氷になった美紅姫の死骸とを二つ並べてじっと睨み詰めたまま、枯れ木のように突立っていました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋人というやつは、なぜにこう人間味がなくて枯れ木のようなんだろうと。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お糸雑木林の啄木鳥は杉の枯れ木を啄いて啼いた杉の枯れ木を啄木鳥は無性　やたらに啄いて啼いた掛けた襷の解けたも知らず涙うかべてお糸は見てた。",
              "citation": {
                "source": "別後",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯れ木がたばねて捨ててあるようだ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スッカリ枯れ木のようになってしまう桜です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとどうでしょう、そこらに枯れ木のまま立っていたうめの木や、さくらの木が、灰をかぶると、みるみるそれが花になって、よそはまだ冬のさなかなのに、おじいさんのお庭ばかりは、すっかり春げしきになってしまいました。",
              "citation": {
                "source": "花咲かじじい",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに、いっそ、ほうぼうの木に花を咲かせてやりましょう」　そこで、おじいさんは、ざるにのこった灰をかかえて、「花咲かじじい、花咲かじじい、日本一の花咲かじじい、枯れ木に花を咲かせましょう」と、往来をよんであるきました。",
              "citation": {
                "source": "花咲かじじい",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではそこのさくらの枯れ木に、花を咲かせて見せよ」といいつけました。",
              "citation": {
                "source": "花咲かじじい",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとまた、おとなりの欲ばりおじいさんが、それをきいて、うらやましがって、のこっている灰をかきあつめてざるに入れて、正直おじいさんのまねをして、「花咲かじじい、花咲かじじい、日本一の花咲かじじい、枯れ木に花を咲かせましょう」と、往来をどなってあるきました。",
              "citation": {
                "source": "花咲かじじい",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹木は皆枯れ木ばかり。",
              "citation": {
                "source": "浅草公園",
                "author": "――或シナリオ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから大きい硝子戸棚の中に太い枯れ木をまいている南洋の大蛇の前に立った。",
              "citation": {
                "source": "早春",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯れ木のような老人夫婦、まことの伜や孫に棄てられて、仏壇の前にふるえておる、これこれ、身どもらは賊でも何でもない――」「なるほど、さアさ、歩きながら伺いましょう――」と阿賀妻は促すのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、彼を歴代の勅撰集撰者や、師範家の如く、歌の枯れ木とはならしめなかつた。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯れ木仆しにそのままに、前方へドッと仆れたので、前に仆れていた死骸の上へ、蔽うようにして転がった。",
              "citation": {
                "source": "怪しの館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨というような山国にあっては、猛獣や毒蛇や山賊などに、しばしば人は襲われるもので、そういう場合の警報として、いろいろの里や、いろいろの郷や、さまざまの村に住居している、住民達は里別郷別に、木を叩くとか竹法螺を吹くとか、枯れ木に火をかけて煙りを上げるとか、そういうことをすることにしていた。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうでも扉はひらかなければいけない」　洞窟の入り口に屯している、丹生川平の郷民達は、こう口々に喚きながら、枯れ木や枯れ草をうず高いまでに、洞窟の扉の前に積んだ。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つかれきったふたりの顔に、かすかにわきあがる力のいろが見えました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "手足はつかれきって、もう、しびれはじめていたのです。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、そのうちの一羽は、つかれきって、もうこれ以上つばさを動かして、飛んでいくことができなくなりました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
