        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "冬の澄んだ空の下、葉を落とした枯れ木が静かに佇んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "春を待つかのように、木々は裸の枯れ木となって枝を広げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その絵画は、一本の枯れ木だけを描くことで、冬の厳しさを表現していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
