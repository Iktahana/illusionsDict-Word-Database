    "definitions": [
      {
        "index": 1,
        "gloss": "one-sided",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「一方の主張だけを鵜呑みにするのは、ジャーナリズムとしては片手落ちだろう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「機能面だけ充実させてデザインを疎かにするのは、製品として片手落ちだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「君の言い分はわかった。でも、向こうの話も聞かないと片手落ちになるからね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「被害者のケアだけでなく加害者の更生まで考えないと、対策としては片手落ちだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "尤もこれとてもそういう時にひいた風邪だけが特に記憶に残るので、それでそういう片手落ちの結論に導かれたのかもしれないが、しかし、そうばかりでもないと思われる理由はたしかにある。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手な片手落ちの若返り法などを試みて造化に反抗するとどこかに思わぬ無理ができて、ぽきりと生命の屋台骨が折れるようなことがありはしないか。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな片手落ちな成敗にへえへえと云って居られるかい。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この心境を説明するのに、人間の言葉に詰って「極楽世界」とか「三昧王三昧」とか、いろいろなことを言いますが、やはり片手落ちの表現に過ぎません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、会社のほうでは穏便がいいというので、むろん片手落ちの裁判だけれど、私が因果を含められて、雇を解かれたのさ」　白糸は身に沁む夜風にわれとわが身を抱きて、「まあ、おきのどくだったねえ」　渠は慰むる語なきがごとき面色なりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "世にはこれよりも更に大なる悪、大なる罪を犯しながら白昼大手を振りて、大道を濶歩する者も多かるに、大を遺れて小を拾う、何たる片手落ちの処置ぞやなど感ぜし事も数※なりき。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋の女子｜特に独立自営の力なき婦人に取りて、この主義は余り極端なるが如くなれども、そもそも女子はその愛を一方にのみ直進せしむべき者、男子は時と場合とによりて、いわゆる都合によりてその愛を四方八方に立ち寄らしむるを得る者といわば、誰かその片手落ちなるに驚かざらんや。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方共を逃がしては、それこそまさしく片手落ちじゃ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "事、ひとたび流血沙汰に及んだとすれば、農民達にいか程正義正当の理由があったにしても、士農工商、階級の相違、権力の相違が片手落ちならぬ片手落ちの裁きをうけて、結局悲しい処罰をうけねばならぬ者は、正しいその農民達なのです。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "信頼していた警官たちまで、こんなに私を憎み、私を疑い、卑怯な片手落ちをして少しも自ら耻じないんです。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいかにも片手落ちの捌きではないかという不満が胸一ぱいに漲っているのです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしだけ逐ひ出されるのは片手落ちでございます。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雄之助　いや、片手落ちのお捌きではわたくし飽までも不承知でございます。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "また年も若く無智な暁子がその様ないきさつに這入った事には、今日の映画会社の経営方法、スターの製作法、給金は少いのに派出にばかり振舞わなければならない映画会社での無理、その他実に多くの今日の社会の矛盾や、片手落ちが暁子の例の中に集約されています。",
              "citation": {
                "source": "「女の一生」と志賀暁子の場合",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "全日本の私たち、すべての人間が、これまでいく久しい歳月の間、民主日本の発足とともに、子供に話してやることさえも出来ないような片手落ちに書かれた日本歴史で養われて来ていたのであったという深刻な反省をもとめられるのである。",
              "citation": {
                "source": "『くにのあゆみ』について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自我離脱の天才論を唱えていたらいてうも、今や妻・母としての現実から、日本の民法が女子というものをどんなに片手落ちに扱っているかをも切実に省察するようになって来たことがうかがわれる。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし芭蕉の付け合を見ずに、蕪村の小説的構想などを前人未発のやうに賞揚するのは甚だしい片手落ちの批判である。",
              "citation": {
                "source": "芭蕉雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな片手落ちのことがあるものかと、よくみんなの問題になるのだ。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かしだす動機を深く反省する心の力は欠けて、知識の力が片手落ちなのだ。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪之丞にすれば、何も、兄弟子平馬に先んじて、秘伝伝授を受ける心はないが、折角の折柄を妨げられて、不安を感じていたのを、師匠が、片手落ちなく両方へ、披見を許すといってくれたので、やっとほっとして、白い手を恭しく差し伸べたのだった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "バーター・システムの取引を承知しておきながら、かの燻精を変質させて送りかえすとは、片手落ちも甚だしい。",
              "citation": {
                "source": "毒瓦斯発明官",
                "author": "――金博士シリーズ・５――",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年三月の片手落ちなお裁きから見ても、また今度の大学様の手重い御処分から見ても、吉良家に乱入したものをそのまま助けておかれるはずはない。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は空腹であっても、親の愛情に特に飢えたりヒガまなければならないほどの片手落ちを痛感する理由は少なかったであろう。",
              "citation": {
                "source": "親が捨てられる世相",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女と安彦氏のほかは、みんな怪しいというワケだね」　と私がきくと、巨勢博士は、「イヤ、女のほかは、と云う方が正しいですよ」「なぜ」「とにかくアリバイのない人間は、みんな疑ってみなければ片手落ちというもんですよ。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
