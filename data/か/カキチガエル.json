        "examples": {
          "standard": [
            {
              "text": "彼女の名前を書き違えてしまい、謝った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大事な書類で日付を書き違えて、提出し直した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "メモの数字を書き違えて、大きなミスにつながった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "急いでいたので、住所の一部を書き違えてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "実際発音が違っているならばそれを書き違えることはないはずであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は「か」と「き」とを書き違えることはない。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから、その当時の人から見ると、こういう風に二類の仮名で「キ」を書き分けるということは、今の人が「カ」という音と「キ」という音を書き分けるのと同じことで、むしろ書き違える方が不思議であります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
