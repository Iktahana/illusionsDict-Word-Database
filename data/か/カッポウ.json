        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "誕生日のお祝いに、予約していた銀座の割烹へ向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "隠れ家のようなその割烹は、静かで落ち着いた雰囲気だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海外からのゲストを連れて、地元の美味しい割烹を訪れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの割烹は、いつも予約でいっぱいの人気店だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
