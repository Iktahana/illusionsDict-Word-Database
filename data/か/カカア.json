          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「うちのかかあが、この店のケーキが一番うまいって言うもんだからさ。」彼は同僚にそう言って箱を見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "一杯やりながら、「なんだかんだ言っても、俺のかかあは俺の好物を一番よく分かってるよ」と彼は呟いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「おめえんとこのかかあは元気にしてるか？」旧友との久しぶりの電話で、そんな会話が出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "やり切れねえなあ、嬶は又腹を膨らかしやがったし、……」彼はウヨウヨしている子供のことや、又此寒さを目がけて産れる子供のことや、滅茶苦茶に産む嬶の事を考えると、全くがっかりしてしまった。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬶が病院に行ってるから、一人は俺が見てやらなけゃ、ならないんだよ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう男は選挙に際して、嬶や子供が饉えようが、蚕が桑の葉をなくして死のうが、そんなことはかまわずに、只で運動をして歩く。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの嬶、猫婆の話をしたら少し変な面をしていましたね」「むむ、大抵判った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとゝいまで、嬶の妹のところから、粟を貰って来て食ったが、妹のところにも、なんにもなくなっちまったんです。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――嬶や、親が、かつえるなんて、あいつら、生大根でも、人参の尻ッポでもかじっとりゃいいんじゃないか！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……気に入りゃ、かっぱらって嬶にするし、いやになりゃポイポイ売ッとばすんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方の宿場の混乱の中に遂に二人を捕えると、宿の二階を見上げて、敬四郎ペコペコ頭を下げて、Ｔ「これで嬶ァに威張れます」　浪之助とお類、上を見ると宿の二階の手摺りに右門と伝六おふみに伊吉。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に嬶が出来たり餓鬼が出来たり何かしてマゴマゴしている中にコンナに頭が禿げちゃっちゃあモウ取返しが付きやせん。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――御身たちもよく覚えて、お社近い村里の、嫁、嬶々、娘の見せしめにもし、かつは郡へも町へも触れい。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "先月八人目の嬶ににげられたんだ。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとあの離縁状は私の本心でないからつて、嬶が手紙をよこしたが、それはもう届を発送したあとだつたから、今頃は驚いてるでせう。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでさ、女は戀人として男に苦痛を與へると同時に歡樂を與へるけれども、妻としては所天に何等の滿足も與へぬ、與へたとしても其は交換的で、而も重い責任を擔はせられやうといふものだから、大概の男は嬶の頭を撲るのだ。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "金さへ呉れたら自分の嬶を解剖する世話でもするだらう。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "……第一あの嬶あ面が俺ア気に喰わん。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなヒョロッコイ嬶が何じゃい。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの別嬪の嬶も好人物過ぎる位、好人物という話です」「ウム。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "長屋の上品な嬶どもそこのきたない煉瓦の窓から乞食のうす黒いしやつぽの上に鼠の尻尾でも投げつけてやれ。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬶が破れるやうに怒鳴つてるので、亭主もかなしい思ひを感じてゐる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ嬶を叩き出して、宿場の女郎でも引きずり込みたいと思つてゐる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "意地の惡い土方の嬶等が、いつせいに窓から顏を突き出し、ひひひひひと言つて笑つた。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "意地の悪い土方の嬶等が、いつせいに窓から顔を突き出し、ひひひひひと言つて笑つた。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長屋の嬶にお情もくそもあるものか。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬶や餓鬼を愛することが出来るに至って人間並の男で、好漢を愛し得るに至ってはじめて是れ好漢、仇敵を愛し得るに至ってホントの出来た男なのだ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかあもせっ角拵えたのお客さんに食べていただかなぃと恥かきますから。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乞食乙　――坊さん、うちに伜とかかあが待って居るんだ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはあとをつけながら、なんだかかあいそうなような気もちになりました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又バクテリヤの意識だってよくはわかりませんがとにかく私共が生れつきバクテリヤについては殺すとかかあいそうだとかあんまりひどく考えない。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「儀平とこのかかあ。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まことに勝手なこといってすまんが、あの胡弓は三十年も使って来たもんで、俺のかかあより古くから俺につれそっているんで」　女主人の心を和げようと思って木之助はそんなことをいった。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
