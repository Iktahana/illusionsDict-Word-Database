    "definitions": [
      {
        "index": 1,
        "gloss": "brown coal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この地域では、発電の主要な燃料として褐炭が採掘されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "褐炭は石炭の中でも比較的品位が低く、水分を多く含む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "環境負荷の低い褐炭利用技術の開発が期待されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "……そしてわが国が、石炭といつても主に褐炭をしか産出しない現実、まづそこから考へを出発させたいのだ。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "その詩の書き出しは、「褐炭　泥炭　無煙炭　それは階級ではない」というのであったが、そのあとはもう忘れてしまった。",
              "citation": {
                "source": "私の青年時代",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてそれを知らせてくれなかったんだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "動きがとれなかったんだ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が予め読者諸氏に、ことわって置く必要があると云うのは、これから、第三金時丸の、乗組員たちが、たといどんな風になって行くにしても、「第一、そんな船に乗りさえしなければよかったんじゃないか、お天陽様と、米の飯はどこにでもついて、まわるじゃないか」と云われるのが、怖しいためなんだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　何だって、コレラ病患者は、こんなことが知りたかったんだろう。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死んだのかい」「死んだらしい」「どうしたんだい」「やけに呷ったらしいんだ」「フーム」「………………」「で、水葬はいつかい」「一運に一度訊いて見よう」「酒が、わるかったんだね」「ウム、どうもはっきり分らねえ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとからあなたと民子は非常な仲好しでしたから、それが判らなかったんです。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「二十年も逢わなかったんですって……その人、妾の顔を見ておっ母さんにそっくりだって云ったわ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "源兵衛はしんみりと、　「石松、俺が昔やくざだったから……俺がやくざだったから、お前だけはやくざにしたくなかったんだ」（Ｆ・Ｏ）　三年の月日が流れました――Ｓ＝茶店の表　秋晴れの或る日の事。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「お半さんに一目会って行きァよかったんだが……」　お半、二階から下りて来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今夜は一文もなかったんだ。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故自分は遠くへ逃げなかったんだろう。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "）ほんにあんな事があるという事をきのうより前に己にいうものがあったら、己だって信じはしなかったんだろうよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺が前以て注意をしたんだ、――兎狩りにさえ出なけりゃ、こんなことになりゃしなかったんだ！",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほいたらいつまでもこんな百姓をせいでもよかったんじゃ！",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの鍬をやってしまわずに、一挺持って来たらよかったんじゃがな。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なか／＼内地へ帰りとうて仕様がなかったんだからな。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もっと思うさまやってやればよかったんだ！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗本は、一本の藁にでもすがりたい気持をかくして、殊更、気軽く、「こっちの中尉がメリケン兵を斬りつけたんが悪かったんかい？",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は藤二のことを思い出すたびに、「あの時、角力を見にやったらよかったんじゃ！",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちは踊りの師匠ですから、身振りや仮声も巧かったんでしょう、なんだか仔細らしく物すごく持ち掛けて、まんまと首尾よくその鯉をまきあげて行ったのには、芝居ならばこのところ大出来大出来というところかも知れません」「いや、わかりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで泣き寝入りにしていれば何事も無かったんですが、藤吉にも金の要ることがある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしも丁度そのときに買物に行って、帰りに路地の角で逢ったもんですから、七之助さんと一緒に路地へはいって来て、すぐに別れればよかったんですが、きょうは盤台が空になっているからおふくろさんがどうするかと思って、門口に立ってそっと覗いていると、七之助さんは土間にはいって盤台を卸しました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "今思えば、いっそその時に思い切ってどうかすればよかったんですが、わたくしも両親はあり、弟や妹はあり、それを打捨って駈け落ちをするわけにも行かないので、ともかくも師匠をなだめて無事に帰したんですが、それから間もなく師匠はどっと寝付くようになって、とうとうあんなことになってしまいました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おふくろもその当座は気が転倒しているもんですから、なんにも気が付かなかったんですが、きのうの朝、長火鉢のまん中の抽斗をあけようとすると、奥の方に何かつかえているようで素直にあかないんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくしも初めは何がなんだか見当が付かなかったんですが、浅草へ出かけての鶏の一件にぶつかってから、どうもその鶏の一件と鬼娘の一件とが何かの糸を引いているらしいと思い付いたんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日ならば死骸の疵口をあらためただけで、人間が咬んだのか、獣が咬んだのか、そのくらいのことはすぐ鑑定が付くでしょうが、昔はそれがよく判らなかったんですね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "上陸ししなに税関で見つかったんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、猪川さん、まだご存じなかったんですか？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
