[
  {
    "uuid": "8372b721-7f26-56b8-9f10-a22d27007c70",
    "entry": "褐炭",
    "reading": {
      "primary": "かったん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
