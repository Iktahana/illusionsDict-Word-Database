        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "偏片を失った手袋が、雪道にポツンと落ちていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あれ、このお気に入りの靴下の偏片はどこに行ったんだろう？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "二つで一つの対になる花瓶だが、今はその偏片だけが棚に残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "白馬のかたはらに、伯は身を反らせて立つてゐた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の小止みなき生のかたはらには、右側にも左側にも、有力な證人が控へて居つたとは云へ。",
              "citation": {
                "source": "モオリス・ド・ゲラン",
                "author": "「そしてこの稀有で、偉大で、しかも果敢ないもの、一個の詩人」",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かたはらに秋草の花語るらく　　　ほろびしものはなつかしきかな」　という牧水流の感情に耽ることも、許されていない。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この長い間私は重に思索生活に沒頭したのであるが、かたはら矢張詩を作つて居た。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は詩人としての出發以來、一方で抒情詩を書くかたはら、一方でエツセイ風の思想詩やアフオリズムを書きつづけて來た。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　鳥右ヱ門について歩いてゐたしもべは、かたはらの小山の頂ちかい崖道を、一匹の鹿がのぼつていくのを見つけました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたはらでとつぜん大砲が発砲されたやうなぐあいだつた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたはらには、生木の枝をまげて作つた下手な弓がおいてあつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処でかたはらへ又沢山課目書を積んで、此処へ辞書を斜めにして建掛けたものです。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "下部いそがはしく燭をみぎひだりに立つれば、メエルハイムは「いづれの譜をかまゐらすべき、」と楽器のかたはらなる小卓にあゆみ寄らむとせしに、イイダ姫「否、譜なくても」とて、おもむろに下す指尖木端に触れて起すや金石の響。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "お七の墓のほとりにある阿弥陀像の碑について、円乗寺の寺記には、「又かたはらに弥陀尊像の塔あり。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "函館のたよりなき日は何となく唯我一人荒れし野に追放されし思ひして、心クサクサ、訳もなく我がかたはらの、猫の糞｜癪にぞさわれ。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "型を押したやうな父の週末の帰宅は、蘆屋で病院を経営するかたはら、大阪の大学病院へも出て忙しいためだとの母親の言葉は、尤もらしかつたが、修一は欺されなかつた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　上田君がわたしにこんなことを説明すると、かたはらから武藤君が、「おい、上田、止さんか――大田黒の顔を見い！",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と絶叫しかたはらの電信柱にもたれかゝつてゲーといふ。",
              "citation": {
                "source": "託児所をつくれ",
                "author": "小熊秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀑布見物のかたはら、一見すべき價値あるもの也。",
              "citation": {
                "source": "足柄の山水",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十九あはれ、人妻、ふたつなきフランチエスカの物語かたらふひまもみどり兒は聲を立てつつ、かたはらを匍ひもてありく、君はまた、たださりげなし。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒造のかたはら、舊くより魚類及※物の問屋を業としたるが故に古問屋と呼びならはしぬ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今ではお互はちりぢりばらばらになって、おのがじし女房のかたはらで暮してゐるのである。",
              "citation": {
                "source": "四五ニズム述懐",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、かたはらに妻がゐると云ふことがもう古代からのことのやうに思へた。",
              "citation": {
                "source": "よみがへる父",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の生の途のかたはら、「物影」の亡骸守るわが「願」の通夜を思へば。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣きさけぶ声で目がさめると、妻はかたはらにねむつてゐた。",
              "citation": {
                "source": "小さな庭",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはかたはらにゐて聴いてゐても堪えがたいのに、まるでおまへを揉みくちやにするやうな発作であつた。",
              "citation": {
                "source": "小さな庭",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "古寺の閻魔堂のかたはらに、掘立小屋のやうな小やかな庵を結んで、乞食にも劣つた貧しい生活のなかにも、蘭の花のやうな清く高い心持を楽んでゐました。",
              "citation": {
                "source": "桜の花",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
