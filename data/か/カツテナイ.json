[
  {
    "uuid": "940d3b80-4636-5e78-82ba-9637e0b124f6",
    "entry": "嘗てない",
    "reading": {
      "primary": "かつてない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
