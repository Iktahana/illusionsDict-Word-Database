        "examples": {
          "standard": [
            {
              "text": "長年の研究が実を結び、世紀の大発見と報じられた時、研究室は歓天喜地に沸いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "待望の赤ちゃんが生まれたという知らせに、家族全員が歓天喜地、涙を流して喜んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "劇的な逆転勝利を収めた選手たちは、歓天喜地の表情でサポーターの声援に応えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "嗚呼近世の小説は歓天喜地愉快を写さずして、総て悲哀を以て終らざる可からざる乎と。",
              "citation": {
                "source": "舞姫",
                "author": "石橋忍月",
                "note": "青空文庫"
              }
            },
            {
              "text": "漆桶を抜くがごとく痛快なる悟りを得て歓天喜地の至境に達したのさ」　あまり迷亭の言葉が仰山なので、さすが御上手者の鈴木君も、こりゃ手に合わないと云う顔付をする。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
