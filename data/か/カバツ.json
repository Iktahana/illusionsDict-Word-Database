[
  {
    "uuid": "2d0215e1-6746-5cd9-9b44-f5558956a06b",
    "entry": "科罰",
    "reading": {
      "primary": "かばつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
