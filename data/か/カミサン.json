[
  {
    "uuid": "d228dd96-f159-58d7-9549-4ae56e63d4d6",
    "entry": "上さん",
    "reading": {
      "primary": "かみさん",
      "alternatives": [
        "カミさん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
