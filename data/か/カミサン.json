      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(one's) wife",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "うちのかみさんが作った料理は最高だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "かみさんに相談してから決めるよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末はかみさんと映画を観に行く予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "かみさんにはいつも感謝しているんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "○井上さんにはとことん迄御世話をかけて済まんと思います。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて外より戸を開け、先にモデル娘、続いてウェエベルの上さん、箒、バケツ、雑巾を持ち、登場。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "こないだ女中殺しのあつた……」「ははは、物騷な方か……」と、引き取つて咳き、水上さんが顏を笑ひ崩した。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日私が局から帰ったら母上さんと相談して……四時頃又来ましょうよ。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなくお清がはいって来て「江上さんから電話でございます。",
              "citation": {
                "source": "疲労",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうさ、お前に任したのだから……ところで母上さんが見えたら最早下宿屋は止して一所になって下さいと言ってみようじゃないか」「言ったところで無益で御座いますよ」「無益ということもあるまい。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「母上さん、そりゃア貴女軍人が一番お好きでしょうよ」とじろりその横顔を見てやる。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣くな、泣くな、可いじゃないか母上さんの方から母でもない子でも無いというのなら、致かたもないさ。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先刻｜母上さんが置手紙を書くってお開けになりましたよ！",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃア母上さんが……」と言いかけるのを自分は手を振って打消し、「黙っておいで、黙っておいで」と自分は四囲を見廻して「これから新町まで行って来る」「だって貴所……」「否や、母上さんに会って取返えして来る。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の可怕い顔と自分の真面目な顔とを見比べていたが、「それからね母上さん、お鮨を取って下さいって」「そう、幾価ばかり？",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから母上さんにもお入なさいって」「あア」と母は言って妙な眼つきでお光の顔を見たが、お光はそのまま自分の方は見向もしないで二階へ上って了まった。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方がお前達のお徳じゃアないか」「母上さん。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪々しい皮肉を聞かされて、グッと行きづまって了い、手を拱んだまま暫時は頭も得あげず、涙をほろほろこぼしていたが、「母上さん、それは余りで御座います」とようように一言、母は何所までも上手、「何が余だね、それは此方の文句だよ。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "又も文句に塞ったが、気を引きたてて父の写真を母の前に置きながら「父上さんをお伴れ申してのお願いで御座います。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "母上さん、何卒……お返しを願います、それでないと私が……」と漸との思で言いだした。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "父上さんの写真が何だというの？",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ最早帰りましょうよ、母上さんが待っているから」と甘ったるい声。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何故母上さんは一所に出なかったのだろう、君知らんかね」と一人の男が言うと、一人「頭が痛むとか言っていたっけ」というや三人急に何か小さな声で囁き合ったが、同時にどっと笑い、一人が「ヨイショー」と叫けんで手を拍った。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「食って来た」「母上さんの処で？",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自転車に乗って三鷹の駅前の酒屋へ用達しに来て、酒屋のおかみさんに叱られてまごついている事もある。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお爺さんのおかみさんは、ひどく若い。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、それはね、このひとのおかみさんよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "惡いおかみさんではないんだけれど、あの日は蟲のゐどころがへんだつたのでせう、いきなり、お照さんの舌をひきむしつてしまつたの。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれもこのひとの家の事はよく知つてゐるけれど、どうもこのひとは、おかみさんを馬鹿にしすぎてゐたよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんを可愛がりすぎるのも見ちやをられないものだが、あんなに無愛想なのもよろしくない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "処々どっしりした旧独逸の高級品屋が在り、柵を引しめる棒柱のように見えるので、下品には決して墜さないで、あとは軒並みの戦後独逸の安物屋、街のかみさんや、あんちゃん、ねえちゃんといった処へ、時々素晴らしい毛皮の令嬢奥様も交った調和が、かえって淋しく品の好い高級品屋の店頭より綺麗なのです。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちがおかみさんの運んで来た渋茶を飲んでいると、古障子を開けて呉絽の羽織を着た中老の男が出て来て声をかけた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "覗きに来る子供を叱りながらおかみさんが斡旋する。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また同書巻之一に「意気な美しいおかみさんが居ると言ひましたから、それぢやア違ツたかと思つて、猶くはしく聞いたれば、おまはんの年よりおかみさんの方が、年うへのやうだといひますし云々」の言葉があるが、すなわち、ここでは「いき」と形容されている女は、男よりも年上である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "(someone's) wife",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "〇〇さんのかみさんもお元気ですか？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "店の奥で、ご主人の手伝いをするかみさんの姿があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "町内会の集まりで、田中さんのかみさんと久しぶりに会った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "かみさんの作るお菓子が評判で、いつもすぐに売り切れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "landlady",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅館のかみさんが温かく迎えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "おかみさんに、おすすめの料理を尋ねてみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "店のかみさんは、昔からの常連客の顔をよく覚えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "毎朝、かみさんが手ずから掃除をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
    ],
