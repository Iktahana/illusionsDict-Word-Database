        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "台風で橋が流されたため、迂回して別の場所で川を越えるしかなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、秘密基地に行くためには、いつも小さな川を越える必要があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "登山道の途中で、水量の少ない川を越える場所があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "徐々に道幅が広がり、やがて手すりのついた広い橋に差し掛かって、ゆっくりと流れるよどんだ川を越える。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿河路は、竹の下みちから所領、中日向とまわって、　甲斐筋は、勘治村から道士川を越える。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "主水の率いる三百余人は、倉兼川を越えると直ぐ、橋を焼き落して日光街道を、蘆野原の関所を押して通り、二股山で槍薙刀鉄砲を棄てて関東へ向って行ってしまった。",
              "citation": {
                "source": "討たせてやらぬ敵討",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "同勢のうちには、さらに川下の細間の渡し場から渡った者もあり、また無理やりに追いかえされた者も多かったが、とにかく夜の明けるまでに五六千が利根川を越えることができた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒匂川を越えると、並木の風にも、北条氏三代のきびしい秩序が、颯々と、威厳をもって、旅人を襲ってくる。",
              "citation": {
                "source": "篝火の女",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けたら川を越えるばかりにして兵も将も甲冑をつけたまま小屋や幕の蔭に眠っている。",
              "citation": {
                "source": "篝火の女",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、やがて町屋川を越えると、そこここの蘆荻や民家のかげに、昨夜のうちに配置された味方の将士が、かくれていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵が、かんが川を越える途中を、不意に打つべしだ」　昌幸を中心に、諸将の意志が一致した。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "山路の上、有年川を越える難儀もあるが、朝立てば、やがて早や播州側の登り道へさしかかっているはず、こうしてはいられまい」「いやまだ、お急ぎにはおよびません」「なんで」「またも帝のご不例か、前日の疲れか、同勢は今朝まだ有年の山寺を出てはおりませぬ」「はてな？",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけて海道一の大河、天龍川を越えるには、しょせん一ト難儀はとしていたのである。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "苗代の青や近江は真つ平ら　瀬田川を越える。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
