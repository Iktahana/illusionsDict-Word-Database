    "definitions": [
      {
        "index": 1,
        "gloss": "cover",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "車に埃がかからないようにカバーをかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ソファのカバーを新しいものに取り替えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "雑誌の表紙は、人気女優の鮮やかなカバーだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このレンズには保護カバーが必要です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "まもなく、カバーをかけたタクシーが夜間薬品店のまえでとまると、なかから、林田三郎が仕掛花火のように商館にかけこんだ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは顯微鏡のカバーの上に薄らたまつた埃を隻眼で見やりながら、實驗室に出入しなかつたこの十日間程の出來事を、涙ぐましく思ひかへしてゐた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは顯微鏡のカバーの上の埃から物惰氣に眼を兄の方に轉じた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "制服を絡いたる判事、検事は、赤と青とカバーを異にせるテーブルを別ちて、一段高き所に居並びつ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "むこうのすみにあった、古い椅子カバーが、それを見ると、思わず、ほころびてしまいました。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "只電燈に桃色のカバーがかかっているだけが最前と違う。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンドルが水牛の角のやうな形をし、ブレーキと荷｜掛けとチエーンのカバーがない。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は幾晩もこの白いシーツの上に白毛布を包んだ白いカバーを引っかけて眠った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は白カバーの毛布をはだけた彼の浴衣の胸まで引き上げて、それから、そうっと、その二分刈りの坊主頭の汗じみた額の上へと私の左の手を当てて見た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にもこの真向うの姿見、硝子棚、バリカン、廻転椅子、カバーの白白白、立ち廻る理髪師の背広の、ズボンの白、掻き立てなすりつけた客の頬や頤の石鹸の白、琥珀の香水、剃刀の光、鋏のチャキチャキ、そうした銀と緑との小夜景がまるで近代劇の或る場面かのように私の前に展開された。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "木造りのほんの型ばかりのベッドが、奥への通路の赤い更紗のカーテンの傍にたった一つ、ベッドには白い藁蒲団に白い枕に白いカバー。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄紅色の浮織りのクッション、白い蒲団のカバー。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから自分がベッドカバーとして使っているペパーミントの葉を取って来て、ツバメの頭にかぶせました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "全一巻で、宇宙のあらゆる領域をカバーしてしまいます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅の途中で遭遇する危機に際してのアドバイスもかねて、プラスチックの電子本のカバーには大きく、「あわてるな（Don't panic）」と書いてあります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもう一つ、原本には格調高く『宇宙船＝太陽』のマークを箔押ししてあるという『事典』が、古めかしい装丁を採用しているのに対し、『ガイド』のカバーには、「あわてるな」と書いてあること。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした紙の本でもできたことをカバーしたうえで、Expanded Book はエンジンとして利用したハイパーカードを活かして、強力な検索機能を提供した。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "策定チームは、小学校から高校までの教科書や、ＮＴＴ電話帳、地名に関する行政資料、現行法令、文部省学術用語集をはじめさまざまなソースをカバーして文字選定を進めていたが、文学に関しては、より広範な資料にあたってデータを取りたいと考えていた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "上はクレイがシェアを握るスーパーコンピューターから下はマッキントッシュの領域まで、ＳＰＡＲＣアーキテクチャに貫かれたＳＰＡＲＣｉｎｃｌａｙ（クレイに引っ掛けたダジャレ）からＳＰＡＲＣｉｎｔｏｓｈ（マッキントッシュに引っ掛けたくだらないシャレ）に至るマシンによってカバーするというのである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが理想主義者のおせっかいを存分に発揮してワークステーションがカバーする領域を一挙に拡大しようとするサンの日本市場へのアプローチは、異種格闘技に燃える基本路線の攻撃性とは対象的に、いかにも大人風である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かに余白に書き込みを入れる、ページの端を折ったりクリップをはさむなどして目印とする、覚えに線を引く、書体をボールドにしたり下線を付したりするなど、従来の本でできることは（多少のおまけもついて）カバーされている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫らは、デッキを洗う波浪からダンブル内への浸水を護るために、ハッチカバー（船艙のおおい）や、それを押えた金具や、またその上から厳重にロープを通して縛らねばならなかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、ブリッジからあやつるスティームギーア（蒸気｜舵機）の鎖と、そのカバーとの間に、わざとのように、水夫見習いが、右半身をうつ伏しにもぐり込ませていたのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるものは、カバーの金板をバーで動かそうと試みた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫全体の力と小倉との力は水夫見習いを、鎖とカバーの間から引っぱり出すことができた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そのまま、全部彼らは船尾ハッチのカバー作業に駆けて行った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽罐に浸水してから、どこかのカバーでもはずしてマストに縛りつけたものであろう。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "マストのカンバス（帆布）は、ハッチの上部カバーであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの航海に、舵機の鎖とカバーの間に食い込まれたんだよ」ボーイ長はあの時の様子を、ここで初めて語り始めた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に舵機ががらがらと動いたもんだから、私ゃ鎖に食い込まれてしまって、カバーの中へからだを半分入れたらしいんだよ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
