        "examples": {
          "standard": [
            {
              "text": "北の空を見上げると、カシオペアが「M」の字を描いているのが見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "神話では、カシオペアは自分の美貌を誇りすぎたために罰を受けたと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "星座早見盤でカシオペアを探してみよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの明るい星が、カシオペア座の一部であることを最近知ったんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "空には、獅子座が頭をさげて西の空へ下りかけ、やがて東からのぼる東亜の太陽の前駆、白鳥、ケフェウス、カシオペアが薄明のなかをのぼってくる。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな織女は見上げる前山の梢の中から、刺すように冷たい青光を放ち、千挺木の尾の上高くカシオペアが屈曲し、カペラらしい大星は徐々に山の端から生まれて、光を弾き出すように震えながら昇ってくる。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "入浴して、ねころび、カシオペアのランチを食って、さて又ねころぶ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
