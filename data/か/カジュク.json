[
  {
    "uuid": "95927b1c-ba56-57a2-9715-db0a7d183110",
    "entry": "家塾",
    "reading": {
      "primary": "かじゅく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "government-backed school operated by a scholar out of his home",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "江戸時代末期、その藩では優れた儒学者が開いた家塾に多くの若者が集まり、熱心に書物を読んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼は役人を辞した後、郷里に戻って小さな家塾を開き、近隣の子供たちに読み書きを教え始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「ほら、あそこの古い蔵、昔はひいおじいちゃんが家塾を開いて近所の子供たちに教えてたんだって」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "幸吉は家産と共に近い土地の重縁の親戚に守られて十三歳まで育った後修業の為に或る家塾に遣られ、十九の年に帰宅してお邦と云うかやの母を、三里程離れた豪農の家から娶ったのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その門弟達のゐる家塾には昔の師弟のやうな純な関係を見ることが出来た。",
              "citation": {
                "source": "尾崎紅葉とその作品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "高谷塾というは『日本全史』というかなり浩澣な大著述をしたその頃の一と癖ある漢学者高谷龍洲の家塾であって、かなり多数の書生を集めて東京の重なる私塾の一つに数えられていた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉本さんは曽て浅見先生の家塾に身を寄せていたこともあるという。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし躋寿館においても、家塾においても、大抵養子｜竹逕が代講をしていたのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "是において世には往々昔の儒者の家塾を夢みるものがある。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陽は文化六年十二月二十七日に広島を立つて、二十九日に備後国｜安那郡神辺の廉塾に著き、八年｜閏二月八日に神辺を去つて、十五日に大坂西区両国町の篠崎小竹方に著き、数日の後小竹の紹介状を得て大坂を立ち、二十日頃に小石｜元瑞を京都に訪ひ、元瑞の世話で新町に家塾を開いた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その芝三島町に起した家塾が則ち叢桂社である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋で本氏に復し、黌職を辞し、本郷に家塾を設けた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに家塾を譲ると云ふことと、菅氏を名乗らせて阿部家に仕へさせると云ふこととの間には、初より劃然とした差別がしであつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "昌栄は蘭門の椿庭業広で、家塾は本郷壱岐坂上にあつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "）巻首の四大字は東久世通禧公、次は養素軒柳原大納言｜前光公、愛古堂磐渓、秋月公、大給亀崖公（即松平｜縫殿頭の事也）、跋は片桐玄理と申せし家塾に居りし御存之者、今文部の督学寮に出仕いたし居申候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以外には家塾の賄方、格之助の若党、中間、瀬田済之助の若党、中間、大工が一人、猟師が一人ゐる位のものである。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "奚疑塾は北山の家塾である。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "家塾を開きて業を授くる者あるいは必ずしも政論を教ゆるにあらず。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "この塾は昔時国富論派の代表なる福沢諭吉氏の創立にして、これに次ぎ泰西の経済説を教えたるは古洋学者の巨擘たる尺振八氏の家塾なりという。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵馬｜騒擾の前後に、旧幕府の洋学校は無論、他の私塾家塾も疾く既に廃して跡を留めず、新政府の学事も容易に興るべきに非ず、苟も洋学と云えば日本国中｜唯一処の慶應義塾、即ち東京の新銭座塾あるのみ。",
              "citation": {
                "source": "〔気品の泉源、智徳の模範〕",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこの母人はやはり江戸に残って、そのまま家塾で幼年男女の教授をせられていたのであるそうな。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "西氏が前に家塾育英舍を開かれた時の通規に、「読書はなるたけ黙読せよ。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "唖々子はかつて文学博士｜島田篁村翁の家塾にあり漢学の素養浅からざるの人。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "嚶鳴館は細井平洲の躬ら家塾に命じた名である。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝暦紀元｜辛未の年二十四歳にして始て江戸に来り芝三島町に家塾を開いたが宝暦十年二月の大火に遭い、身を以て免れ日本橋｜浜町山伏井戸の近くに移居した。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "天保六年大沼捨吉が鷲津氏の家塾に寄寓していた時、松隠は隠居し嫡子徳太郎が家学をついで門生を教えていた。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳太郎、名は弘、字は徳夫、益斎と号しその家塾を有隣舎と名けた。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷲津益斎の家塾に学んでいた。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "その書庫を二、三千巻書閣と名けその書斎を対古人斎といい、その家塾を止至善塾と称し常に酒を置いて来訪の士を迎え放談豪語することを好んだ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "維新の後横浜｜野毛に家塾を開き生徒を教えていたが、明治八年七月東京に来り十月十七日浅草｜三筋町なる知人某の家に没した。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京府師範学校教諭、中学校教諭ニ歴任シ、傍家塾ヲ開キ徒ヲ聚メテ業ヲ講ズ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三の春おあかが奥方となりし年の翌年、父に乞ひてある漢学先生の家塾住居。",
              "citation": {
                "source": "誰が罪",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば此の家塾で放任主義を行ふのは畢竟獨立心を養ふ爲であつて、この狹い小さな家塾で其の習慣をつけて置くのは他日大なる社會、廣き世界へ出て事の缺けない仕度で御在ます。",
              "citation": {
                "source": "女教邇言",
                "author": "津田梅子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
