[
  {
    "uuid": "832616cf-3bb7-556d-9565-506ae943b313",
    "entry": "煥発",
    "reading": {
      "primary": "かんぱつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
