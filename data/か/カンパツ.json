    },
    "definitions": [
      {
        "index": 1,
        "gloss": "brilliance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "畳に置かれた白々とした紙の上に、小さな宝玩は其の貴い輝きを煥発した。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻の田氏は魏の豪族田氏の一族中から荘子の新進学徒時代にその才気｜煥発なところに打ち込んで嫁入って来たものであった。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くの如く諸般の差別より観察し来れば、平民は実に徳川氏の時代に於て大に其思想を煥発したるものにして、族制的大隔離の余を受けて、或意味に於ては高等民種に対して競争の傾きを成し来れるなり。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ外交問題ほど国民の元気を煥発するものはあらざる也。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さすがの夫人も、才気｜煥発、恐ろしい者知らずの美和子には、ややてこずっている気味である。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがある一人のデザイナーの美意識が徹頭徹尾貫徹した社会に放り込まれたとして、才気煥発で人に頭を抑えられることが大嫌いなあなたは、そこで何をするのだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この理屈に拠って帰納すれば、俊秀な人なども偶然に現れた生れ付きの才能の所有者と云うよりは、俊秀な器質の遺伝、即ち不断の努力の堆積の相続者、もしくは煥発者と云う方が適当である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それではどんなに聡明な人でも何の得るところも無く、知識を得て啓発される（識得煥発）ということが少しも無く終ってしまう。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "識得煥発ということが無ければ読書は何の意味も無い。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "このようにしている間に、次第に粗より精になり、偏より円に至り、礙より通に進み、小より大に進化して、何時となく純熟して、終には識得煥発・欣喜雀躍の境地に至る。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし菊池契月氏を指して、才気煥発でないなどといつた人の顔をみたいのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "契月は才気は煥発してゐない、しかし翻つてその人は契月の絵を系統的に見たかといふことと、その作品の本質を吟味したかといふこと芸術上の才気とはどんなものかもつと皮肉な言ひ方をすれば菊池契月氏の作品は才気が煥発しないで描ける絵であるかどうかといふことになつてくる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはその人と私との『才気煥発』なるものの解釈見解の相違なのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその才気煥発か、否かといふことを吟味するには、契月を俎上にあげることはいちばん適当なやうである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊池契月氏こそ真個うの意味での、才気煥発と呼ばれるべきものではないかと、私は考へられるのだ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "才気煥発、運筆自在、縦横馳駆の川端龍子氏の画の過程は、そのフワンたるものの心を躍らすに足る充分なものがある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ私は才気煥発な華楊といふ作家の、その精神的動きの方に遙かに興味をもつてゐるのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "五雲の作は、ずつと躍動的であるし、それこそ才気煥発である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し私は前の稿で、華楊もまた才気煥発だと述べてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "着実な手段を選び、煥発する才気をじつと抑制する力はこれまた作家の実力の一部といふことができよう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "）才能ある人間が過渡期に生れたため、その才能を畸型的に発達させられた一例であつて悲劇的といえば悲劇的であるが、ちようどそういう時に出くわしたればこそ我々同時代のものは才気煥発する彼の一連の作品によつて楽しまされたとも考えられる。",
              "citation": {
                "source": "人間山中貞雄",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、「虞美人草」「三四郎」などの中に、いわゆる才気煥発で、美しくもあり、当時にあって外国語の小説などを読む女を、それとは反対に自然に咲いている草花のような従来の娘と対置して描いているのは、注目をひくところである。",
              "citation": {
                "source": "歴史の落穂",
                "author": "――鴎外・漱石・荷風の婦人観にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "清少納言という人は当時の女流の文筆家の中でも才気煥発な、直感の鋭い才媛であったことは枕草子のあらゆる描写の鮮明さ、独自な着眼点などで誰しも肯うところだと思う。",
              "citation": {
                "source": "山の彼方は",
                "author": "――常識とはどういうものだろう――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、日清戦争前後のロマンティックな文学的雰囲気に触れ、非常に才気煥発で敏感な葉子にあっても、やはり環境的にもたらされてそこから脱ける意力ははぐくまれていなかった不幸の最大の原因であったということを、葉子が理解しないと同時に、作者もはっきり作品の中にこの点を描き出していない。",
              "citation": {
                "source": "「或る女」についてのノート",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はちょうどこの教育勅語煥発の際にドイツから六、七年ぶりに帰朝し、いくばくもなくその教育勅語を解釈し、『勅語｜衍義』と題してこれを世に公にするの光栄を得たのである。",
              "citation": {
                "source": "明治哲学界の回顧",
                "author": "序論",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからちょうどその教育勅語の煥発せられた頃より東京大学に教授となって教鞭を執り、三十三年間継続し、その間、宗教に関しては仏教を中心として比較宗教を講じ、哲学の側においては東洋哲学史とともに西洋哲学史を講じ、殊にカントとショーペンハウエルとを講じたのである。",
              "citation": {
                "source": "明治哲学界の回顧",
                "author": "序論",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の知つてゐた先生は才気｜煥発する老人である。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一面美しくもなし、話は下手だし、字は拙し（後には旨くなつたが）、才気煥発などとは凡そ縁の遠い地味な存在でもある。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、閑日月に富んだ今さえ、こう溌剌としているようじゃ、康有為氏を中心とした、芝居のような戊戌の変に、花々しい役割を演じた頃には、どの位才気煥発だったか、想像する事も難くはない。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
