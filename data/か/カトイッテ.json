[
  {
    "uuid": "22ceaacd-017e-51e8-ba4f-afc34aa58c13",
    "entry": "かと言って",
    "reading": {
      "primary": "かといって",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "having said that",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この仕事は大変だ。かと言って、他にやりたいことがあるわけでもない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "確かに今日の会議は長かった。かと言って、結論が出なかったわけじゃないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は少し口下手なところがある。かと言って、不親切な人ではないんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このケーキ、ちょっと甘すぎるな。かと言って、食べられないほどじゃないけど。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日の天気は微妙だね。雨が降るかと言って、降らないかと言われると微妙だな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あるいは、〔ki:〕は東北地方にあるようなイとウの間の音）という発音ではないかと言っております。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人にある時私は眼前の若葉の美しさについての話をしたら、その人は、なるほど今は若葉時かと言ってはじめて気がついたように庭上を見渡した。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかと言ってルノアルふうの風景小品にもルノアルの甘みは出ていない。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は相手の今までの話を、そうおもしろがってもいないが、そうかと言って全然興味がなくもないといった穏やかな表情で耳を傾けていた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇術が何とか座にかかっているのを見にゆこうかと言っていたのを、峻がぽっと出てしまったので騒いでいたのである。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかと言っていつになったらそれができるという確かな見込みも立たない。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかと言って、いつまでもなんらかこの種の方法をとらなければ、独断と独断との間の討論の終結する見込みは立たないように思われるのである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと言ってみずからこれらの多くの問題のどれもに手を着けることは到底不可能である。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと言って陶器の需要のない所には陶土の要求もあるはずはないのは言うまでもないことである。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そうかと言ってその結果がいくぶんか科学知識普及に役立つことになってもそれはさしつかえはないであろうと思っている。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんこれは大風が吹いて桶屋が喜ぶというのと同じ論法ではあるが、そうかと言ってそういうことが全然ないということの証明もまたはなはだ困難であることだけは確かである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それかと言ってその金属の粉をなめたのでは何もならない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで案内記ばかりにたよっていてはいつまでも自分の目はあかないが、そうかと言ってまるで案内記を無視していると、時々道に迷ったり、事によると滝つぼや火口に落ちる恐れがある。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと言って邦楽の大部分や俗曲の類は子供らにあまり親しませたくなし、落語などというのは隣でやっているのを聞くだけでも私は頭が痛くなるようであった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそうかと言って虫食いや黴菌のために変色した葉ばかりを強調した表現主義にも困る、ドイツあたりの近ごろの絵画にはそんな傾向が見えるのもありはしないか。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそうかと言っていわゆる音楽者のほうでは楽器や人間の声帯の発する音以外のものはいっさい取り扱わないのであるから、連句はもちろん音楽者からも顧みられない。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと言っていつまでも手をつけずにおくべきものでもない。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと言ってまた短歌連作の多数のものは連句とあまりに距離が大きい。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによると学校を卒業して役所へはいって属僚になってもあまり一生懸命にまじめに仕事をするとかえっていけない、そうかと言ってなまけても無論いけないのだそうである。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳諧の理解ある嘆美者クーシュー（Paul-Louis Couchoud）はアメリカ文化と日本文化の対蹠的なことを指摘し自分らフランス人はむしろ後者を選ぶべきではないかと言っている。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと言って死ぬのを嫌がっても、人間は死ななければならないので、何とかして諦める理由を考え出します。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、あの、二度あることは三度とやら申しますから、今日の内また誰かお入りなさりはしまいかと言って、内の父様も案じておりますから、貴方またその姉さんをお助けなさろうの何のッて、あすこへいらっしゃるのはお止し遊ばしまし。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時には、肌が蕩けるのだって言いますが、私は何んだか、水になって、その溶けるのが消えて行きそうで涙が出ます、涙だって、悲しいんじゃありません、そうかと言って嬉しいんでもありません。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そうかと言って、こう張っちゃ、身も皮も石になって固りそうな、背が詰って胸は裂ける……揉んでもらわなくては遣切れない。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼まれて、よっしゃ、今ないけど直ぐこしらえて来たる、二時間だけ待っててくれへんかと言って、教室を飛び出すものの、じつはあの人には金策の当てが全くないのだ。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんぞ飲みに行こうやないかと言ってね、喫茶店へ珈琲を飲みに行ったんだよ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした日蔭者の気楽さに馴れてしまうと、今更何をしようという野心もなく、それかと言って自分の愚かさを自嘲するほどの感情の熾烈さもなく、女子供を相手にして一日一日と生命を刻んでいるのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "均平はこの年になっても持前のわがままがぬけず、別にこれと言って希望もなく、今後の生活の設計があるのでもなかったが、そうかと言ってそこに全く安住している気にもなれず、絶えず何か焦躁を感じていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子が話すと、悲惨なことがそう悲惨にも聞こえず、それかと言って、均一たちの身分との対照のつもりでもなかったが、加世子が気をまわせば、自分のしていることが、少し大袈裟だというふうに取れないこともなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は銀子を追究して真相をはっきりさせることも怖く、それかと言って商売人の銀子の言葉を言葉通りに受け容れることもできず、病院の仕事もろくろく手に着かないのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
