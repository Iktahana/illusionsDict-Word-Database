[
  {
    "uuid": "01a45e2c-3288-5b9a-badc-74acb9ec6808",
    "entry": "刈り込む",
    "reading": {
      "primary": "かりこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to prune",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "週末に庭の伸びすぎた茂みを刈り込みたいな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は秋の終わりにバラを刈り込むのが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "定期的に刈り込まないと、植物が手に負えなくなっちゃうよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "あなたの頭を刈り込むのに。",
              "citation": {
                "source": "床屋",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「刈り込むにしても」と、千代子はしつツこく、「あなたの五分刈りあたまのやうに坊主にして貰つちやア困ります。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の木を刈り込むなどと云ふことは、夢にも見なかつた初めての經驗で――「不馴れだから、あぶないですよ」と注意する千代子の言葉には耳も傾けず、枝にかかつてぐらぐらするはしごを半ば攀ぢ登つた時、渠はあたまがふら／＼して目まひを感じた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれを救うにはなんとかして少しこの文明を刈り込む必要がありはしないかと考えた。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "理髪師が間違ひをした時には、髪の毛をもつと短く刈り込むといゝ。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三は前にも一度、どこかのホテルで鏝をかけさせられたことがあったが、葉子が耳にかぶさるまで蓬々と延びた彼の髪を彼女流に刈り込むようには器用に行かないので、熱い鏝の端が思わず頸に触って、彼女は飛びあがって絶叫したことがあった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そよとの風もない黄金色の麦畑に、さっくさっくと刈り込む節調的な鎌の歌がまたつづいた。",
              "citation": {
                "source": "麦畑",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "軒を平らに刈り込むと、濃淡二色の藁の帯が、かわるがわるに見える（図430）。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時半に出て、銀座コロムバンへ、ニッサンの新井氏と会ひ、三時半、小松理髪店へ、ふき代へに使ってる平野来り、同じやうに刈り込む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to reap (a crop) and put into storage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "農家の人たちは、収穫した作物を刈り込み、保管するのに忙しい時期だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "小麦はついに刈り込まれ、貯蔵の準備ができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "冬が来る前に、このお米を刈り込むのがこの季節の仕事だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "to prune (a manuscript)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "編集者は、作者に長すぎる原稿を刈り込むよう求めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "私は一日中、小説の不要なシーンを刈り込んでいたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "自分の作品をより良くするためには、時には刈り込むことも必要だ。つらいけどね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
    ],
