        "examples": {
          "standard": [
            {
              "text": "この万年筆はインクの出も滑らかで、書き味がとても良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "試し書きコーナーで、色々なペンの書き味を比べながら選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "カリグラフィー用のペンは、独特の書き味があって面白いんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "さまざまな書き味の絵筆をマウスで操作し、気に入らないところがあれば画面上で自由に修正を加え、好みのパターンを選んで網掛け処理を行う――。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
