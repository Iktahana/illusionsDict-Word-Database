  },
  {
    "uuid": "623b6f11-3f29-5880-9f50-2f7065c9a0ef",
    "entry": "かたり",
    "reading": {
      "primary": "かたり",
      "alternatives": [
        "かたん",
        "カタン"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞-と",
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "with a clatter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "風で窓が、かたりと音を立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "静かな夜、何かが、かたりと落ちる音がした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は椅子の脚を、かたりと鳴らして席を立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "二　夜、丸の内の淋しい町を歩いていたとき、子供を負ぶった見窄らしい中年の男に亀井戸｜玉の井までの道を聞かれ、それが電車でなく徒歩で行くのだと聞いて不審をいだき、同情してみたり、また嘘つきのかたりではないかと疑ぐってみたりしたことがあった。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いと嬉しうて、今やこの事かたり出ん、しばししてや驚かすべき、さこそは人の羨やましがるべきをと、嬉しきにも猶はゞかられつゝ、あらぬ事ども言ひかはすほどに、折しもかの子規軒端に近う鳴く声のする。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、すぐに、かたりと小皿が響いた。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "天に年わかき男星女星ありて、相隔つる遠けれど恋路は千万里も一里とて、このふたりいつしか深き愛の夢に入り、夜々の楽しき時を地に下りて享け、あるいは高峰の岩｜角に、あるいは大海原の波の上に、あるいは細渓川の流れの潯に、つきぬ睦語かたり明かし、東雲の空に驚きては天に帰りぬ。",
              "citation": {
                "source": "星",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐわた／＼、かたり／＼と橋の上を曳く荷車。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも同じように、舷へ一方から欄干らしいものを嵌めた、かたり、と響く。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此のおなじ火事に、靈岸島は、かたりぐさにするのも痛々しく憚られるが、あはれ、今度の被服廠あとで、男女の死體が伏重なつた。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼神に横道なし、と云う、情に抵抗う刃はない筈、」　枢をかたかた、ぐっと、さるを上げて、ずずん、かたりと開ける、袖を絞って蔽い果さず、燈は颯と夜風に消えた。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かたりと門の戸を外から開ける。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、村の人たちに相談をかけてみると、村の人たちも、それはもっともなことだ、そんなすばらしい番犬は、あとあとの代まで、かたりつたえるべきであると思いました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を見さえすれば、こいつ、かたりじゃないか、すりじゃないかと思うようなわけさ。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "御度量のひろい将軍家に於いては、もちろん、御計画の頓挫をいつまでも無念がつていらつしやるやうな事は無く、あの、大かたり者の陳和卿に対してもいささかもお怒りなさらず、医王山ホド、ウマクイカナカツタヤウデス。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その学年末の或る日の、黴菌学の時間にも、れいに依って、二〇三高地の激戦とか、三笠艦とかの画面が出て、私たちは大騒ぎで拍手し、そのうちにかたりと画面が変って、ひとりの支那人が、露西亜の軍事探偵を働いた罪に依って処刑せられる景があらわれた。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠かと思ったそうで、斜に棚の上を見遣ったが、鍋も重箱もかたりとも云わず、古新聞がまたがさりともせぬ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とお源は飛上って、慌てて引窓を、くるり、かたり。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（小さな声で、）――大儀、」「はッ、主税｜御供仕りまする上からは、御道中いささかたりとも御懸念はござりませぬ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と椅子をかたり。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたり草、言の花は、蝶、鳥の翼、嘴には限らない、其の種子は、地を飛び、空をめぐつて、いつ其の實を結ばうも知れないのである、――此なども、道芝、仇花の露にも過ぎない、實を結ぶまではなくても、幽な葉を裝ひ儚い色を彩つて居る、たゞし其にさへ少からぬ時を經た。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "道理こそ、いまし方天幕へ戻って来た時に、段々塗の旗竿を、北極探検の浦島といった形で持っていて、かたりと立掛けて入んなすった。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　座敷に引返そうとして、かたりと土間の下駄を踏んだが、ちょっと留まって、「どんな風采をしている。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何より聞怯じをした事は、いささかたりとも神慮に背くと、静流がひらめくとともに、鼻を殺がるる、というのである。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに三画伯の扮装を記したのを視て、衒奇、表異、いささかたりとも軽佻、諷刺の意を寓したりとせらるる読者は、あの、紫の顱巻で、一つ印籠何とかの助六の気障さ加減は論外として、芝居の入山形｜段々のお揃をも批判すべき無法な権利を、保有せらるべきものであらねばならない。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですからこの地方では、その後いつも四月のはじめになりますと、女たちがみんな下袴の糸をぬいて、飯粒を餌にしてあゆを釣り、ながく皇后のお徳をかたりつたえる印にしておりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かたりをはるとき午夜の時計ほがらかに鳴りて、はや舞踏の大休となり、妃はおほとのごもり玉ふべきをりなれば、イイダ姫あわただしく坐を起ちて、こなたへ差しのばしたる右手の指に、わが唇触るるとき、隅の観兵の間に設けたる夕餉に急ぐまらうど、群立ちてここを過ぎぬ。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、それから次には……」　かたりと荷車がとまりました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "いひつがひかたりつがひて。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "メンチといふものを玩ぶとて常に飯粒もてつけ合せけるよし母なるものゝきゝて笑ひつゝかたりけり。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方、例の『敦盛』と同じように好んで居た「死のうは一定しのび草には何をしよぞ、一定かたりのこすよの……」　と云う小唄でも口ずさんで居たのであろう。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、大抵の場合、人殺しや、強盗は凶悪な面構えをしているし、かたりやすりは、ずるそうな顔をしている。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
