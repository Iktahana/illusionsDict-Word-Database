    "definitions": [
      {
        "index": 1,
        "gloss": "swimming in the middle of winter or the cold season",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "降りしきる雪を物ともせず、勇壮な掛け声と共に参加者が寒中水泳へと挑む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「冷たーい！ けど、終わった後は体がポカポカして気持ちいいよ！」と小学生が笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "成人の日を記念した寒中水泳が、今年も地元の海岸で賑やかに行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そして今でも、小石川のその修養塾のそばに道場を造って柔道の先生をし、また夏は子安辺で水泳の先生をして、毎年の冬隅田川で寒中水泳を催している。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "且又水や寒気などにも肉体的享楽の存することは寒中水泳の示すところである。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し寒中水泳には少し早いが、一体何でしょうね。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
