[
  {
    "uuid": "d6baeb65-1827-5763-ae18-49c1fb2c1690",
    "entry": "片付く",
    "reading": {
      "primary": "かたづく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
