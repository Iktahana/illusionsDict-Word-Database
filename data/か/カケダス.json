        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ゴールテープが見えた途端、彼は最後の力を振り絞って駆け出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "宝探しゲームの開始合図で、子供たちは一斉に駆け出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "遠くから聞こえる楽しそうな音楽に誘われ、彼女は思わず駆け出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「遅れる！」と焦った彼は、カバンを掴むと勢いよく駆け出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
