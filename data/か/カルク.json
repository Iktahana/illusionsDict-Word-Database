        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「家計簿をつけるなら、無料のカルクでも十分に高機能だよ」と友人に勧められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "カルクで作成した売上集計表を、PDFに変換してメールで送信した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はプログラミングの知識を活かして、カルクのマクロ機能を使いこなし業務を自動化した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そら、むすこが、エングランド、ロンドンにいて、おやじがスコットランド、カルクシャイヤにいた。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえは英語はわかるかい、ね、センド、マイブーツ、インスタンテウリイすぐ長靴送れとこうだろう、するとカルクシャイヤのおやじめ、あわてくさっておれのでんしんのはりがねに長靴をぶらさげたよ。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、むすこが、エングランド、ロンドンにゐて、おやぢがスコツトランド、カルクシヤイヤにゐた。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまへは英語はわかるかい、ね、センド、マイブーツ、インスタンテウリイすぐ長靴送れとかうだらう、するとカルクシヤイヤのおやぢめ、あわてくさつておれのでんしんのはりがねに長靴をぶらさげたよ。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "都ハ、アカルクテヨイ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが大ヒットとなったアシストカルクのＵＮＩＸ版を出したり、ＭＳ―ＤＯＳ版にも一万九千四百円でより強力な製品を出したりと、ベテラン・ユーザーやプロにもターゲットを広げている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳朶にはアウリカルクムの輪が嵌めてある。",
              "citation": {
                "source": "クサンチス",
                "author": "XANTHIS",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっかけを作ったのは、ビジネススクールの学生だったダニエル・ブリックリンがアップル※を使って書いた、ビジカルクと名付けられたプログラムだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてフランクストンとともにブリックリンはソフトウエアアーツ社を起こし、パーソナルソフトウエアを販売の窓口として、ビジカルクと名付けたソフトウエアを世に問うた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "見える計算機（VISIble CALCulator）を略してビジカルクと名付けられたこの製品は、一九七九年の五月に開かれた第三回ＷＣＣＦに出展されて話題を集めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面上に表示された表の縦横の空欄にキーボードから数字を入れていくと、あらかじめ指示しておいた計算の手順に従って、ビジカルクは自動的に処理を行った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビジカルクを使えば、たとえば税率を現行の三パーセントから五パーセントに上げるとどうなるか、七パーセントまで上げるとどうかなど、さまざまなシミュレーションを簡単に行うことができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙と鉛筆と電卓を使う人なら誰でも、ビジカルクによる計算の自動化のメリットを享受できた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年の十月に正式に発売となるや、ビジカルクは爆発的なヒット商品となった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当初ビジカルクはアップルを購入する人が現われた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八〇年九月、アップルコンピュータは総売上台数の約五分の一にあたるアップル※が、ビジカルクを走らせる必要条件として購入されたとの推定を行った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後ビジカルクには、表計算ではじき出したデータをグラフ化するためのビジプロットや、データを整理して保存するためのビジファイル、電話回線を通じてデータをやり取りするためのビジタームなどの関連商品が生まれていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七九年の半ばに売り出されたワードスターは、ビジカルクとともにパーソナルコンピューターに仕事の道具としての新しい顔を与え、この分野のソフトウエアがビジネスとして成立することを実証してあまたのライバルの誕生を促す呼び水となった★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜田俊三がアストラでアメリカ市場に食い込もうと動きはじめた一九七九年は、ビジカルクとワードスターが登場し、パーソナルコンピューターが仕事の道具として急速に認知されることになるまさにその年だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに発表によれば、ＩＢＭはＰＣ用にパーソナルソフトウエアのビジカルクやピーチツリーソフトウエアの三種類の会計プログラムなど、これまで八ビット機で人気を集めてきたソフトウエアを自社から供給するとしていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "知り合いの大学院生のために、グラフ作成や統計、数式処理の機能を組み合わせたタイニートロールと名付けたプログラムを書き、一九七九年には、ビジカルクの発売元となっていたパーソナルソフトウエアと契約して、表計算にタイニートロールの機能を与える二本のソフトウエアを開発することになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "転属となった計画部でアストラの巻き返しにあたった早水の目の前で、ビジカルクが爆発的なヒットを遂げ、ＣＰ／Ｍに対応したワードスターが人気を集めていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビジカルクは表計算の可能性をまざまざと見せつけたが、アップル※の専用ＯＳに対応したアセンブラーで書かれていたためにＣＰ／Ｍでは当初、動かなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "八ビットの標準となったＣＰ／Ｍ上では、代わってスーパーカルクがヒットした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＢＭはＰＣの開発中に、ビジネス用として人気を博しているソフトウエアのメーカーを中心に移植を働きかけ、マシンと同時にビジカルクやイージーライターなど、利用可能なアプリケーション八本を発表していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダニエル・ブリックリンによって書かたビジカルクは、一九七九年五月のＷＣＣＦで発表され、この年の終わりになって発売された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブリックリンは煩雑な手計算から逃れるための道具として、ビジカルクを書いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがビジカルクを手にした多くのユーザーは、ブリックリンの想定を超えて、考えるための道具として電子集計表を使いはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったん作り上げた画面上の表を前にして、この条件をこう変えたらどうなる、ああしたらどうなると試行錯誤を繰り返し、最終的な結論を導き出すためのシミュレーションの道具として、ユーザーはビジカルクを利用した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マシンの処理能力の値段を一挙に引き下げるマイクロコンピューターがあってはじめて、一人ひとりの人間のための強力な思考の道具となるビジカルクは誕生できたのではないか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
