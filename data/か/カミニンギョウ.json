        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「これ、おばあちゃんが作ってくれた紙人形なの。着物も全部千代紙で手作りなんだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "文化祭の劇で使う背景に、クラス全員で小さな紙人形をたくさん貼り付けて賑やかにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雑誌の付録についていた紙人形を丁寧に切り抜いて、厚紙を貼って立たせて机の上に飾った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それも花火に仕掛けられた紙人形のように、身体のあらゆる部分から力を失って。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦屋根に落ちている紙人形の亡骸。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "性来｜頗る器用人で、影画の紙人形を切るのを売物として、鋏一挺で日本中を廻国した変り者だった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしから見れば、夫なんて紙人形に等しいお馬鹿さんだ。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しがたの花火から現れた紙人形の風船が、海の方へ向つてフワ／＼と飛んでゐた。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次の日、小さな紙人形を写生してしまふた頃丁度午後の三時頃であつたらう、隣のうちの電話は一つの快報を齎らして来た。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすっくらい悪い事の胞子がいっぱいとび散って居る様なまがりっかどの、かどに居る露店のおばあさんのところに先有楽座の美音会の時にあった様なとんだりはねたりや、紙人形やなんか私のすきらしいものばっかり並んで居るのを母は目ざとく見つけて呉れました。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「紙人形は首人形と同じ位、私の大好きなお人形さんだ。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い錦絵、紙人形、赤いつまみの櫛の歯の黒髪、これだけの間に切ってもきれないつながりがある様に――又その間からしおらしい物語りが湧いて来はしまいかと思われた。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　雛人形と女神と此までの学者の説明では、其時に穢れを移して、水に流す筈の紙人形が流されずに、子供・女の玩び物になつたのが、雛祭りの雛だ、といふことになつてゐる様である。",
              "citation": {
                "source": "雛祭りの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来の学者の説明では、此穢れを移して、水に流すはずの紙人形が流されないで、子供・女の玩び物になつたのが雛祭りの雛だ、と言ふことになつて居る。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お休み時間には、鉛筆だの、ガラス玉だの、紙人形やなにかと、とりかえっこするの。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、嘗つてものした愚作「紙人形春の囁き」とか「狂恋の女師匠」とか云ふ、所謂下町情話物が、私の作品の中では割合に強い記憶を与へてゐるので、人々は、それを土台として、今度の「日本橋」に対して、とやかく云ふのかも判らない。",
              "citation": {
                "source": "日本趣味映画",
                "author": "溝口健二",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は毛糸の襟巻をし、腰から下を毛布で包み、紙人形をこしらへてゐる。",
              "citation": {
                "source": "クロニック・モノロゲ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四五とも見えますが、何んとなく華奢な体質で、地味ではあるが贅沢な総模様を縫った羽織が、ソロリと肩を滑り落ちそう、何んか紙人形のような感じのする弱々しさです。",
              "citation": {
                "source": "葬送行進曲",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙人形のように薄手で弱そうな子であった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "八津がもって遊んでいた貝がらや紙人形もそばにおいた。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
