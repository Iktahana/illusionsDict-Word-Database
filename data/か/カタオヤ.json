        "examples": {
          "standard": [
            {
              "text": "シングルマザーとして、片親で子育てするのは本当に大変だよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "片親の集まりに参加して、情報交換をすることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最近、片親世帯の経済的支援の必要性が叫ばれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
