    },
    "definitions": [
      {
        "index": 1,
        "gloss": "boy or doll dressed in ancient Chinese clothes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古い屏風には、楽しそうに遊ぶ唐子の姿が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "中国から伝わった唐子の絵柄は、日本の陶磁器にも多く見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お土産物屋さんで、唐子の模様が入った扇子を買った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "博物館で見た唐子の人形は、生き生きとした表情をしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また開いた山百合の幾つかの隙間にルノワアルばりの裸形の女を、ちやうど朝鮮の李王家の美術館に在る葡萄の蔓の間に唐子を染付けた水差の模様のやうにあひしらはうかと思つたが、それは失敗した。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐子売南京小情総角の唐子、唐子よ、子を売ろよ、売ろよ、子を売ろ。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄の服の唐子、唐子よ、かつがれて、籠にゆられて。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼子よ、唐子、唐子よ、まろき目を寄せて、集めて。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "総角の唐子、唐子よ、物珍ら、街を眺めて。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "選りどりよ、唐子、唐子よ、子を売ろよ、売ろよ、子を売ろ。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐子のやうな人が二人で笑つてゐた。",
              "citation": {
                "source": "寒山拾得縁起",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐子のような人が二人で笑っていた。",
              "citation": {
                "source": "寒山拾得縁起",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日は両人で来て、仕事を頼むというので、どういう御注文かというと、唐子が器物を差し上げている形を作ってくれという。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "店初まっての大作をしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐子は生地だけを作ってくれれば、彩色は自分の方でするということであった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "店初まっての大作をしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、今も申す通り、丈五尺の唐子で一対という注文、今日ではなんでもないが、その当時、徳川末期のドン底の、すべて作品が小さくなっている時代の彫刻界では、丈五尺というと、まずなかなかの大物であって、師匠の店においても、店初まって以来の大作であった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "店初まっての大作をしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐子の下絵は楓湖氏の筆になったもので、それを見本として雛形を作る。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "店初まっての大作をしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その唐子というものはお約束通り、ずんぐりとした身長のもので大層｜肥太っている。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "店初まっての大作をしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐子には唐子の約束があるんだ。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "店初まっての大作をしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋人は唐子の約束なんか分らず、人間なら人間のようにもっとすらりと身長が高ければ好いので、あんなに、ぶよぶよ肥太って、ちんちくりんでは第一物を捧げている台として格好が附かないと、まあ、こういった訳なんですから、今度は当り前の人間だと思って、当り前にやって見て下さい。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "店初まっての大作をしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり思い切りこなしてから唐子の服をつけさせるという寸法に彫って行ったのです。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "店初まっての大作をしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、十一年の十一月頃、全く製作を終り、店に飾り、先方の検分を終って唐子の彫刻は引き取られて行きました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "店初まっての大作をしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くは浅黄地にて裾回りに色とりどりの図案にて七福神の踊りとか唐子遊戯の図などが染出された木綿の長襦袢のようなものである。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾回かの襲撃の間に、うちのぐるりもひどくやられて、唐子の前髪のように動坂のところから団子坂にかけて浅い奥ゆきが残った。",
              "citation": {
                "source": "田端の汽車そのほか",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐子童子　南京の紫金山というのは、私の泊っていた宿の窓のところからちょうど額縁にはまったように見られたが、夕方などになると大へん美しい山に見えるのであった。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中にやはり貧しい子供には、昔の唐子をおもわせるような髪をしたのがいた。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "前のほうや、耳の上だけやに毛をのこして、あとはくりくりに剃って、残した毛を三つ組に編んだのや、つまんでしばったのや、いかにも昔の絵にある唐子のような風俗がこんな片田舎に却って残っているのを、不思議ななつかしみをもって眺めずにはいられなかった。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのなかにかあいらしい子供、唐子をおもわせる、そんな子供も交っているのを見受けたのである。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々と詩論は毎月の雑誌にも現れてをりますが、此の雑誌に訳載中のアランの論文と、それからこれは直ちに詩論と呼べる限りのものではありませんが、フィードレルの芸術論、まづまづ此の二つが此の数年来に読みました詩論の中で心に残つたものであります。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　まさか、こんなばかげた問答は起るまいが、けれどもこの場合の柿にしろ、窓にしろ、これこれだからこうだ、という、いわば二段論法的な、こじつけではないわけだ。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまだからこそ、こんなふうになんでもない口調で語れるのであるが、当時は、笑い話どころではなく、私は死のうと思っていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の部屋の窓を夜どおし明けはなして盗賊の来襲を待ち、ひとつ彼に殺させてやろうと思っているのであるが、窓からこっそり忍びこむ者は、蛾と羽蟻とかぶとむし、それから百万の蚊軍。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ、兄貴の言葉ではないが、教育界にゐてそんなことをしたからこそ、失敗なので、あれで、當時の政黨にゐて動いてゐたなら、あるひは成功したのかも知れない。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの同じテーマからこの二つの俳句が同時に出来たため、蕪村自身その取捨に困ったらしい。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年夏始めに、程近い植物園からこのわたりへかけ、一体の若葉の梢が茂り黒み、情ない空風が遠い街の塵を揚げて森の香の清い此処らまでも吹き込んで来る頃になると、定まったように脳の工合が悪くなる。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
