        "examples": {
          "standard": [
            {
              "text": "七五三のお祝いに、娘は可愛らしい唐子の髪型を結ってもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "時代劇の幼い姫君役は、いつも唐子に髪を結っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "江戸時代の浮世絵には、唐子のような髪型をした少女が描かれていることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
