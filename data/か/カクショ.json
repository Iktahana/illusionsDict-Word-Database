    "definitions": [
      {
        "index": 1,
        "gloss": "each place",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "台風の影響で、市内の各所で道路が冠水した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ビルの改修工事のため、各所に立ち入り禁止の表示が出ています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "イベント期間中は、公園の各所に案内係が配置されます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "サミット会場の周辺では、警察が各所に検問所を設けていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "そして各所で成績を挙げるらしいのだが、無理もない、私も二三度ダマされた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前五時、午前九時、正午十二時、午後三時、午後六時には取入口から水路、発電所、堰堤と、各所から凄じい発破の轟音が起った。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の受持の寺院で大勢の聴衆に対して説教すると、その声は同時に電話で市中の各所へ配布された。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その冒頭に、先ず有能な学者を日本に派遣して大学地震研究所におけるあらゆる研究の模様を習得せしめよということ、次に末広所長を米国に迎えて講演させ、また米国における将来の研究方針についてその助言を求め、また末広式の地震分析器を各所に据え付けて地盤の固有振動の検出を試みよといったようなことが書いてある。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラカトア火山の爆破の時に飛ばされた塵は、世界中の各所に異常な夕陽の色を現わし、あるいは深夜の空に泛ぶ銀白色の雲を生じ、あるいはビショップ環と称する光環を太陽の周囲に生じたりした。",
              "citation": {
                "source": "塵埃と光",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈路　この地名は土佐各所の山中にある。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その暑さに冬服を着て各所を歴訪した。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○九月、日露戦争の講和条件不満のために、市内各所に焼撃ち騒動勃発し、それがために六、七の二日間は各劇場の興行を休む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "饑餓行進は数隊に分れ、その夜の宿所の有無を問はれ、無いものは各所の労働者宿泊所に引取られた。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度、二度と間を置くうち、去年七月の末から、梅水が……これも近頃各所で行われる……近くは鎌倉、熱海。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのくらい勝手をおしのおまえさんなら、また、そのくらいの工夫の出来ないおまえさんでもあるまいじゃないか」　わたくしが湯に入っていると、各所の停車場へわたくしを捉える張番に行ってたらしい近所の出入りの若者たちがぽつ／＼戻って来て、嘉六に犒われ御祝儀包を貰って帰って行きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛政は秀吉の各所要害を一層に整備するのを見て、勝家に一日も早くこの難所を打ち通らなければ、ついには味方手詰りになると報じたが、時既におそしである。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほ、自分は「小学生全集」宣伝のため、五月中旬から六月中旬まで、全国各所に講演旅行を試みるつもりである。",
              "citation": {
                "source": "小学生全集に就て（再び）",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらば、弟｜義経と不和となるや、義経逮捕を名として、全国に守護を配置して軍事、警察を司らしめ、又｜兵粮米徴発のために、各所の荘園に地頭を置いた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五月ごろ全国の各所でほとんど同時に山火事が突発する事がある。",
              "citation": {
                "source": "藤の実",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金子洋文『鴎』「鯡船が河に十数艘｜入港つた、鯡がピラミツド型に波止場の各所に積みあげられた。",
              "citation": {
                "source": "文学に現れたる東北地方の地方色",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人は盗癖を持つ良家の令嬢のようでもあるが、一時に三個を窃取した点から推して、いつも同一手段で市内各所でこの種の店頭を荒らし廻っていた窃盗常習犯の疑いがあり、目下厳重に取り調べ中である。",
              "citation": {
                "source": "秘密の風景画",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "各所の太鼓の音が興味は却て此れからだといふ樣に沈んだ夜を透して一｜直線に響いて來る。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "大生産業ノ徴集ニ於テ其等ヲ有シ、更ニ土地徴集ニ於テモ各所ニ其等ヲ有スル大富豪等ハ、要スルニ只一百萬圓ヲ所有シ得ルノミナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "後頭部の打撲傷や身体各所の激しい擦過傷を思い出し給え。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が招いた人達は園内の各所に散って、春の半日を楽しく遊び暮している。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "市内外各所の活動写真館は続いてイルミネーションを付けた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の事はない、千束町の女は、醜業道の宣伝と奨励と講習のため、その筋の鞭に追われて、東京市内外の各所に派遣されたようなわけになった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "各所の有名な富豪を訪れて金を強要したが、「今日金が無ければ、明日何時に貰いに来る。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "目下、市内各所の公園付近に市から建てられたバラックがある。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、何といっても江戸ッ子が一番よけいに逃げ込んでいるのは、東京市内の各所にある市営の避難民バラックである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと見ると、どれがどうやらわからぬし、納豆を売って見ても、その買いぶりに各所共通の避難民式というのが出来ていてわかりにくいが、流石に育ちは争われぬもので、よく気をつけて見ると、どことなく買いぶりが違う上に、言葉が第一争われぬそうである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそのほかの大部分は、市内各所のバラックに納まっていることがわかる。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷を初めとして東京市内各所の避難バラックに逃げ込んだ避難民の中で、江戸ッ子が一番多いに違いないという推測は、この事実からでも推測されることである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後は、会社の、各所属工場や、事務所などを写したものだった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
