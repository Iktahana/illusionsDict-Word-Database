    "entry": "仮面をかぶる",
    "reading": {
      "primary": "かめんをかぶる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行"
      ],
