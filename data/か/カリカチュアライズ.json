        "examples": {
          "standard": [
            {
              "text": "その週刊誌は、時の首相の顔立ちを極端にカリカチュアライズした風刺画を掲載し、大きな議論を呼んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「彼の独特な喋り方をそこまでカリカチュアライズして真似しなくても、十分に特徴は伝わるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "劇中の悪役は、現代の拝金主義を痛烈にカリカチュアライズした存在として描かれており、観客に強い印象を残した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "伝統的な神話の神々をポップなアニメ調にカリカチュアライズしたアート作品が、若者の間で人気を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いつか本誌〔『新青年』〕に訳載された誰かの作品に、ホームズのこのマンネリズムをカリカチュアライズ〔風刺〕したものがあった。",
              "citation": {
                "source": "ホオムズの探偵法",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの晩はＹも大して面白いと云わぬし自分も不満だったが、一日二日たつとセクレタリーの姿（カリカチュアライズされた）、最後のマッスの形（セクレタリー排撃の）、白い紙が前後左右から降って来たビュラクラティスト地獄等、或感じをのこして居る。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "カリカチュアライズされた後家女がギターをかかえて bed にかけて居た。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
