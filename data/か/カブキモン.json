        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古い寺院の入り口には、趣のある冠木門がそびえ立っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "冠木門をくぐると、静謐な庭園が広がっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この邸宅の象徴である冠木門は、格式の高さを物語っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "黒い冠木門の両開き戸をあけるとすぐ玄関で案内を乞うと右脇にある台所で何かしていた老母らしきが出て来た。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その靴は霜のいと夜深きに、空谷を鳴らして遠く跫音を送りつつ、行く行く一番町の曲がり角のややこなたまで進みけるとき、右側のとある冠木門の下に踞まれる物体ありて、わが跫音に蠢けるを、例の眼にてきっと見たり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "冠木門は、旧式のままで敷木があるから、横附けに玄関まで曳込むわけには行かない。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ、うそうそとまた参った……一度｜屈腰になって、静と火薬庫の方へ通抜けて、隣邸の冠木門を覗く梅ヶ枝の影に縋って留ると、件の出窓に、鼻の下を伸して立ったが、眉をくしゃくしゃと目を瞑って、首を振って、とぼとぼと引返して、さあらぬ垣越。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "国麿という、旧の我が藩の有司の児の、われより三ツばかり年紀たけたるが、鳥居の突あたりなる黒の冠木門のいと厳しきなかにぞ住いける。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰いで高し厳しと見し国麿が門の冠木門も、足｜爪立つれば脊届くなり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち、庄亮と同じく褞袍着のタゴール老人と私とは、うち連れて、冠木門に見越しの落葉松といった風の軒並の前の、うち湿った暗い通りをあるいていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人連は、八には読めないが、荒川と書いた点燈会社の軒燈の点つてゐる、黒い冠木門のうちへ這入つた。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "八は往来を斜に横切つて、黒い冠木門に近づいた。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒竹の生けがきをめぐらした冠木門をはいると、玄関のわきの坪には蓆を敷き並べた上によく繭を干してあった。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」六　戴いたのは新しい夏帽子、着たのは中形の浴衣であるが、屹と改まった様子で、五ツ紋の黒絽の羽織、白足袋、表打の駒下駄、蝙蝠傘を持ったのが、根岸御院殿｜寄のとある横町を入って、五ツ目の冠木門の前に立った。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "串戯にも、これじゃ居たたまらないわけなんですが、些とも気にならなかったのは、――先刻広い、冠木門を入った時――前庭を見越したむこうの縁で、手をついた優しい婦を見たためです。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ト向うが勲三等ぐらいな立派な冠木門。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿、柳、梅、桜、花の師匠が背戸と、冠木門の庭とは、草も樹も、花ものを、枝も茎にたわわに咲かせて、これを派手に、わざと低い生垣にし、――まばらな竹垣にしたほどあって、春夏秋の眺めが深く、落葉も、笹の葉の乱れもない、綺麗に掃いたような小路である。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "冠木門の内にも、生垣の内にも、師匠が背戸にも、春は紫の簾をかけて、由縁の色は濃かながら、近きあたりの藤坂に対して、これを藤横町ともいわなかったに。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい冠木門の家で、生け垣の外には小さい小川が流れていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い生垣を繞らして、冠木門が立ててある。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸口に掛けてある簾を透して、冠木門を出て行く友の姿が見える。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い冠木門のある陰気なような家であった。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天台宗講中宿泊所」「一般參詣者宿泊所」といふ風の大きな木の札の懸つてゐるその冠木門を見ると、もう脚が動かなかつた。",
              "citation": {
                "source": "比叡山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その門から一二間の広さでゆるやかに曲りながら十四五間ほど小砂利が敷かれて、其処にまた蔦のからんだ古びた冠木門がある。",
              "citation": {
                "source": "村住居の秋",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "冠木門の草葺屋根には蓮華の芽が伸びてゐた。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　なる程彼が、裏口を回つて五六間の距離のある草葺の冠木門までの梅の木の下を、五六歩進むかと思ふと、後ろ髪を曳かれるやうに二三歩後退りによろ／＼としたり、覚悟を決めた点頭きをしてまた前にのめつたり、不精無精に首垂れて後ろに靡いたりしてゐる態たらくは、花道で止惑ふてゐる性格俳優の見得の通りであつた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　天狗洞の冠木門が梅林の奥に仄見えるのを目ざして、訪ねて来る途中でＲ氏は私に云つたのであつた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼瓦のついた冠木門の屋根には、青草がすい／＼と天にのびて陽炎を呼んでゐた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "白壁の土蔵、樫の刈り込んだ垣、冠木門、物心がついてから心から憎いと思ったのは、村の物持ちで、どうしてこの身ばかりこう賤く、こう憎まれ、こう侮られ、こう打たれるのかと思った。",
              "citation": {
                "source": "ネギ一束",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "田畝を越すと、二間幅の石ころ道、柴垣、樫垣、要垣、その絶え間絶え間にガラス障子、冠木門、ガス燈と順序よく並んでいて、庭の松に霜よけの繩のまだ取られずについているのも見える。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "招魂社の裏手の知れ難い家で、車屋に散々こぼされて、辛と尋ね当てて見ると、門構は門構だが、潜門で、国で想像していたような立派な冠木門ではなかった。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "古風な冠木門のわきの潜門を彼は中へ入つて行つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
