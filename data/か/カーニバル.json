        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "リオのカーニバルは、鮮やかな衣装とサンバのリズムで世界中を魅了する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは仮面をつけ、街中を練り歩くカーニバルのお祭りに大興奮だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "毎年この時期になると、地元の広場で小さなカーニバルが開催される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友達と仮装して、ベネチアのカーニバルに行くのが夢なんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ところが、それから一、二ヶ月後に、エスピノザはこういうフォスコロの書翰を受取ったのだが、同封の紙片に描かれたマッツオラタ（中世伊太利でカーニバル季における最も獣的な刑罰）の器械化を見て、思わず一驚を喫してしまった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体的に「女性の小カーニバル」と笑って呼ばれた(33)。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "来る七月十四日、ジロ楽園カーニバル祭の当夜、殺人遊戯の大団円が来るのだ。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この、ジロ楽園カーニバル祭っていうのは本当ですか」「本当です。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジロ楽園のカーニバル祭。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのカーニバル祭とかを中止して、ここの人達がもっと安全な場所へ避難してはどうですか。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは兎も角、例の楽園のカーニバル祭という、馬鹿馬鹿しい催しの日が近づいて来た。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにもそんな危険を冒してまで、カーニバル祭とかを催す必要はないではないか。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このカーニバル祭こそ、我々がジロ楽園を始めた時の、最大の目標であったのです。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、カーニバルの日に殺人が行われるなんて、取るにも足らぬおどし文句に過ぎません。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "傭人達は我々以上にカーニバルを待ち兼ねて居ります。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しカーニバルを中止したなら、あの莫大な費用をかけた大砲が、全く無駄になってしまうではありませんか」　治良右衛門が主張した。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "口径は十二｜吋もありますけれど、弾丸はでっかいキルク玉で、しかも一丁位しか飛びやしないのです」「だが、そんなものを一体どうするのですか」「カーニバルの余興です。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、押問答の末、結局治良右衛門その他の云い分が通り、奇妙なカーニバル祭は兎も角挙行されることになった。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、実に面倒な次第であったが、カーニバルの当日は、警戒の為に数十名の警官を楽園内に派遣しなければならなかった。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これが、恐らくカーニバル第一の余興だよ。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが巨人の射的場なんか、カーニバル全体の一種気違いめいた、大仕掛けな、世にも華やかな乱痴気騒ぎの、ホンの一部分に過ぎなかったことが、やがて分る時が来た。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴンドラの唄　カーニバルの当日が来た。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客様はカーニバルの衣裳とお召替なさらなければなりません」「アア、夢の国には、夢の衣裳か」紳士は漸く納得して、その衣裳を受取った。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーニバル祭にふさわしい様にと、これでも智恵を絞ったのです。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃場内は已にカーニバルの酒気に満ちていた。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳山がライオン歯磨の会へ出るので「海のカーニバル」の時はゐなくなり、等々といふうち十一時近く、めでたく終った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「海のカーニバル」中、僕の歌「酔へば大将」の受けることも嬉しい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＪＯＢＫより「海のカーニバル」を放送、徳山の作、実は上山の作。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、ユーモア郵便局　二、東京読本　三、海のカーニバル　四、歌ふ金色夜叉六月二十四日（木曜）　十二時までねる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カーニバル」では「酔へば大将」の歌が大した受け方。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「金色」の三景で、天井に「海のカーニバル」の提灯が、ついたまゝになってるのをふと発見し、徳山・能勢の三人で笑っちまひ、ます／＼しまらず。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「海のカーニバル」の中程で藤山と徳山と僕、三人でいろ／＼歌ってサービスした。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その町には、恰もカーニバルの御祭騒ぎが演じられていたが、突然、この学究的な会合の最中に、戸が開かれてけばけばしい衣裳をつけた一人の道化が、狂気の様に飛び込んで来た。",
              "citation": {
                "source": "Ｄ坂の殺人事件",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "類を絶したカーニバルの狂気が、全島を覆い始めました。",
              "citation": {
                "source": "パノラマ島綺譚",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
