        "examples": {
          "standard": [
            {
              "text": "不明な点があれば、まず管理事務所にお問い合わせください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "マンションのゴミ収集日や駐輪場の利用ルールは、管理事務所で確認できます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "建物正面玄関を入ってすぐ右手に、管理事務所の受付があります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "すこしも早く警察と連絡をつけたいふうだが、湖水の近くで電話のあるところは、キャンプ村の管理事務所か伊東ゴルフ場のクラブ・ハウスだけ。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お参りなら、管理事務所に頼んで、納骨堂に案内しておもらいなさるとよござんすよ」　教えられた通り、管理事務所の扉を開けた。",
              "citation": {
                "source": "情鬼",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は驚いて、早速墓地管理事務所に参り、いろいろ調べてみましたが、お預けしてある骨壺には何の異状もなく同じ場所に安置されてあるのでございます。",
              "citation": {
                "source": "情鬼",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　Ｓ夫人と私は早速墓地管理事務所を訪ねた。",
              "citation": {
                "source": "情鬼",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            }
          ]
        }
