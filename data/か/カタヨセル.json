        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "肩寄せて座る恋人たちを、彼は遠くからそっと見つめていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女が不安な時、友人は何も言わずにただ肩寄せてそばにいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夕暮れのベンチで、老夫婦が肩寄せて静かに海を眺めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
