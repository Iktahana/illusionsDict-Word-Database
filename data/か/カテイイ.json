[
  {
    "uuid": "c8a5329d-59b7-5e73-9dca-93ffffba9adc",
    "entry": "家庭医",
    "reading": {
      "primary": "かていい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
