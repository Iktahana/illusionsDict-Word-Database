          "literary": [
            {
              "text": "しばらく、バスは、官庁街の広い通りを揺れて行く。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "官庁街の素気なく白々しい建物の数々。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車は物凄い唸りをたてて巨大なる建物の並ぶ真夜中の官庁街を駆け抜けて行きました。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "官庁街と事務所街と殷賑街とを除いて、東京が一種の村落都市と云われる所以である。",
              "citation": {
                "source": "高千穂に思う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "官庁街の周辺に自動車の流れはすくなくなっていた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その日、旅籠を出た時遷は、城内の官庁街をうろついていたが、やがて太衛府の横をぐるっと歩いて来て、「もしもし、禁門の金鎗組ってな、どこを入って行ったらいいんです？",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
