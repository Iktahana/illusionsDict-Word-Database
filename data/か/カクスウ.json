        "examples": {
          "standard": [
            {
              "text": "「憂鬱」って漢字、画数が多くて書くのが大変だよな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供が書いた字の画数を、辞書で調べてあげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "書道では、一本一本の線の重みや、全体の画数を意識して書くんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ダ・ヴィンチは、入れられぬ故郷の町を後に、自作の画数枚を背負つて雪のアルプスを越え………「今に………！",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "上木し得るまでに浄写した美麗な巻で、一勇斎国芳の門人国友の挿画数十枚が入っている。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "恒豊号と言う店に入り、喇嘛仏の画数枚を購う。",
              "citation": {
                "source": "北京日記抄",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者居村の風物を撮影したる印画数葉を插みて、趣を助く。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "槐大の画三枚、関根正二の画二枚、黒田清輝の画数枚、それから高橋由一の画を見た。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "画数にして六十面がせい一杯である。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時に銀座へ出てヤングで理髪、Ｐ・Ｃ・Ｌへ寄ると森さん不在、試写室でワーナーの漫画数本見た、とてもよろしい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
