        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "二人の老舗企業は、長年にわたり市場で肩を並べてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の数学の才能は、国内トップクラスの学生たちと肩を並べるほどだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ほら、あの新人俳優、ベテランたちと肩を並べて堂々と演技してるじゃない！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この研究所の成果は、世界中の著名な機関と肩を並べるレベルに達した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
