[
  {
    "uuid": "03951f45-0c4a-53b2-b81d-6d2095337087",
    "entry": "肩を並べる",
    "reading": {
      "primary": "かたをならべる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-一段"
      ],
      "ctype": null,
