        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "目の前の風景を、キャンバスに描き起こす作業を始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、心に浮かんだイメージを素早くスケッチブックに描き起こした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃から夢見ていたキャラクターを、ついにイラストとして描き起こすことができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「さあ、この構図で描き起こしてみよう！」と、画家は意気込んで筆を手に取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
