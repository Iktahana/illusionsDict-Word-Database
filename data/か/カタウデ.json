        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "社長にとって、彼はまさに片腕のような存在だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このプロジェクトの成功は、彼女という片腕がいたからこそだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年支えてくれた片腕を、新しい部署に異動させることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
