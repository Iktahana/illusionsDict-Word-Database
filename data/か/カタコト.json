    },
    "grammar": {
      "pos": [
        "副詞",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "click-clack",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "静かな廊下を、ヒールの先がかたことと音を立てて響いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古いタイプライターを叩くかたことという音が、深夜の書斎に心地よい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "おもちゃの荷車を引いて歩く子供の後ろで、木製の車輪がかたことと回る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "遠くの方で、荷馬車が石畳の道をかたことと進んでいく音が聞こえる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あなたのさいしょのかたことを耳にしたのは、このわたし。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎はあくびをいくつもいくつもしてからタアナカムダアチイナエエというかたことを叫んだ。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "惣助は夜、寝てからやっとこのかたことの意味をさとった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍目もふらずかたことと驅けて來るのを見ると、器械力と云ふよりも一動物の運動といふ感じがするのである。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞室の『かたこと直し』慶安三年印本に、冠具。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うまもなく、かたことと、位牌でもが動くような物音があがりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛籠の中では、黄金の飾りのついた兜や剣や古判などがかたことと触れ合つて実にも頼もしい響きを囁やいてゐた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "時鐘　　　　　　エミイル・ヴェルハアレン館の闇の静かなる夜にもなれば訝しや、廊下のあなた、かたことゝ、※杖のおと、杖の音、「時」の階のあがりおり、小股に刻む音なひは　　　　　　　　　　　これや時鐘の忍足。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "時鐘舘の闇の靜かなる夜にもなれば訝しや、廊下のあなた、かたことと、※杖のおと、杖の音、「時」の階のあがりおり、小股に刻む音なひは　　　　　　　　　　これや時鐘の忍足。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして天国の黄金の梯子でも下りるやうな足つきをしてかたことと廊下を歩んで、騒ぎの聞える一室の前に立つた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつしよに出かける、君は丸ビルへ、私はかたこと庵へ。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛する日本が、また再び作家にかたことを云わせるような非条理な強権に決して屈することのないように。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第五巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室では早くも眠る準備の椅子を動かすらしい音がかたこととしていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、かたことの日本語を少し話した。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」わがをひやよをさなこよなれが目の　　さやけき色をたとふれば夕のそらの明星か　　たわゝに肥えし頬の色は濃染の梅に白ゆきの　　かゝれる色か唇の深紅の色は汝をば　　はてなくめづる此をばのま心にしも似たるかな　　かたことまじり※様と我が名よばるゝそのたびに　　あゝわがむねに浪ぞ立つ。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "下におかれた釜は、しばらくすると、またかたことと、からだをゆすぶり出した。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは静かな家の中でたゞ一つの物音のやうにかたことと音を立てて煮えた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お乳が無くて悪かったね、いい坊やだから泣いてはいけません」　ようやくかたことを言えるくらいの男の子。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろとかたことまじりに、女中に問いましたので、彼女は、「坊ちゃんのお母さんは、遠いところへいってしまわれたのですよ。",
              "citation": {
                "source": "遠方の母",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのかたことまじりにものをいう、りんごのように紅いほおをした、かわいらしい正ちゃんが病気で悩んでいると知ると、正ちゃんのお母さんといっしょになって、正ちゃんの眠りを守ってやらなければならないという気が起こったのです。",
              "citation": {
                "source": "幼き日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人のヒトから他のヒトに５代にわたって通過させても、雌牛から受け取ったウィリアム・サマーズから次々と受け取った５番目のＪ・バージまで、元来の性質の何も失われていなかたことが証明された。",
              "citation": {
                "source": "イングランドの西部の諸州とくにグルスターシャーで見つかった病気で、牛痘の名で知られているウシ天然痘の原因および効果についての研究",
                "author": "AN INQUIRY INTO THE CAUSES AND EFFECTS OF THE VARIOLAE VACCINAE, A DISEASE DISCOVERED IN SOME OF THE WESTERN COUNTIES OF ENGLAND, PARTICULARLY GLOUCESTERSHIRE, AND KNOWN BY THE NAME OF THE COW POX.",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗いので姿は見えないが、咳をしたり、戸をかたこといわせたりするのが聞こえる。",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "長屋には、もうすっかり灯がはいって、主人のいない作爺さんの家には、狭い水口でお蓮様が、かたことささやかな夕餉のしたくを急いでいる。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えいちゃん」とは、ねえちゃんのかたことなのです。",
              "citation": {
                "source": "「の」の字の世界",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖母さんは仏間で何かかたことと音を立てていた。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "海からあらわれたカニ怪人が、千葉の別所少年に、へんなかたことで、しゃべったところによりますと、Ｒすい星は、怪星人が宇宙をとびまわる巨大なのりものだというのですが、それはほんとうなのでしょうか。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "銚子の近くの海からあらわれたときには、まだ、かたことにしかいえなかったのに、あれから、十日もたたないうちに、こんなにうまく、日本語がしゃべれるようになったのでしょうか。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "禰宜の山辺守人は、時鳥や仏法僧の啼音ばかりを友として、お宮の脇の小さい社家に住んでいたが、甚助の姿が見えると、かたこと木履の足音をさせて出て来た。",
              "citation": {
                "source": "剣の四君子",
                "author": "林崎甚助",
                "note": "青空文庫"
              }
            },
            {
              "text": "近世の文学はもとよりのこと、古くは『庭訓往来』などにも「囲炉裏」の文字は用いられ、従うてヰロリと発音するのが正しいので、これと異なる語はみな「かたこと」だと、学問のある人は誰でも考えているようだが、甚だ心もとない話である。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
