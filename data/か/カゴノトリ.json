    "definitions": [
      {
        "index": 1,
        "gloss": "caged bird",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あのインコは、いつも窓辺の籠の鳥になって、外を眺めているよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、友達の家で飼っていたカナリアは、まさに籠の鳥だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ペットショップの籠の鳥たちが、一斉に鳴き始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "大佐の心では、吾等兩人が意外の椿事の爲めに、此樣な孤島へ漂着して、之から或年月の間、飛ぶに羽なき籠の鳥、空しく故國の空をば眺めて暮すやうな運命になつたのをば、寧ろ不憫と思つて居るのであらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "出るに出られん籠の鳥さ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、こんどはストトン節、籠の鳥、枯れすすき、鴨緑江、まったく以て休憩なしのぶっつづけとござい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「籠の鳥はどうやな、籠の鳥。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「出るに出られぬ………籠の鳥。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ草木の茂った加賀屋敷のどこかに住んでいたのがこの頃の気圧の変調を感じてさまよい出て、途中でこの籠の鳥を見附けたものだろう。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "井伊直政は今こそ秀吉を討ち取る好機だと、家康に耳語したところ、「自分を頼み切って居るのに、籠の鳥を殺すような酷いことは出来ない。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は吉野路を通って、五条橋本など云う処を経てその夜は籠の鳥と云う山の辻堂で一泊し、十日になって紀州路から泉州の牛滝と云う処へ越え、それから葛城山へ往った。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんといっても向うは籠の鳥だ。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ家にいながら、村川にとっては倭文子は籠の鳥である。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は、「籠の鳥」の歌や看板の珍文句なぞを、たった二三枚だけ書いた本社用の新しいノートを見ていた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙な洋食や支那料理、凝ったアイスクリームを求め、カフェー女の本名を探り、ヤゾーを作って大向うから怒鳴る代りに、亜米利加ものや新派の甘い筋に手をたたき、歌沢の心意気よりも、マンドリンに合わせた「籠の鳥」のレコードを買う。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い小鳥知らぬ男のいふことに、青い小鳥よ、樫の木づくり、わしの寢床が見馴れたらせめて入日につまされて鳴いておくれよ、籠の鳥、牛乳が好きなら牛乳飮まそ、野芹つばなも欲しかろがわしの身體ぢやままならぬ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ娘のいふことに、青い小鳥よ、擔荷の上のわしの姿が見えぬとてひとの涙のうしろからちらと鳴くのか、籠の鳥、弔むそなたの眞實は金の時計か、襟どめか、惜しい指輪の玉であろ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしの從兄弟がいふことに青い小鳥よ、樫の木づくり、おなじ寢どこに三人まで死ぬる命の贐に鳴いて暮らすか、籠の鳥、ケレオソートにや馴染みもしよが、いつも馴染まぬ人の眼が今ぢやそなたも厭であろ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "源助さんは、郷里（と言つても、唯上方と許りしか知らなかつたが、）にゐる父親が死んだとかで、俄かに荷造をして、それでも暇乞だけは家毎にして、家毎から御餞別を貰つて、飼馴した籠の鳥でも逃げるかの樣に村中から惜まれて、自分でも甚く殘惜しさうにして、二三日の中にフイと立つて了つた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "源助さんは、郷里（と言つても、唯上方と許りしか知らなかつたが、）にゐる父親が死んだとかで、俄かに荷造をして、それでも暇乞だけは家毎にして、家毎から御餞別を貰つて、飼馴した籠の鳥でも逃げるかの様に村中から惜まれて、自分でも甚く残惜しさうにして、二三日の中にフイと立つて了つた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那様は又た、奥様を籠の鳥のように御眺めなさる気で、奥様の独り焦る御心が解りませんのでした。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "籠の鳥は、目眩しい電燈に照らされてきよろ／＼してゐた。",
              "citation": {
                "source": "籠の小鳥",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝起きてみると、兄の淳二は小鳥を物干場の柱の上高く括りつけた、長い棹に仕かけられた、長さ一間ばかりの籠掛に、籠の鳥を一つ／＼かけて、吊しあげてゐた。",
              "citation": {
                "source": "籠の小鳥",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "空たかく掲げられた籠の鳥は、爽やかな朝風を受けて、どれもこれも大空へでも放たれたやうに、元気よく籠のなかを駈けまはつてゐた。",
              "citation": {
                "source": "籠の小鳥",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "・晴れたり曇つたり籠の鳥　曇り日、珠数をつなぐ四月廿五日　晴、行程七里、直方市外、藤田屋（二〇・上）どうしても行乞気分になれないので、歩いて、たゞ歩いてこゝまで来た、遠賀川風景はよかつた、身心がくつろいだ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつには当時の上流と目される大名の奥方や、姫君などは、籠の鳥同様に檻禁してしまったので、勢い下々の女の気焔が高くなったわけである。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは幕府が大名の奥方、姫君などを籠の鳥同様、人質として丸の内｜上屋敷に檻禁させていたので、美しき女の伝もつたわらぬのでもあれば、時を得て下層の女の気焔が高まったのでもあろう。",
              "citation": {
                "source": "明治大正美女追憶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "person whose freedom has been restricted (esp. a prostitute, mistress, concubine, etc.)",
        "register": "standard",
        "nuance": null,
