        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は親の言いなりで、まるで籠の鳥。自分の人生を歩めないんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔の遊女は、世間から隔絶された花街で、文字通り籠の鳥だったのでしょうね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「自由になりたい！」って、彼女はいつもため息をついていた。籠の鳥のようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
