        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夜中、金棒引きが「火の用心！」と声を上げながら町を回っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の日本では、金棒引きが夜間の警備と時間のお知らせを兼ねていたそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遠くから聞こえる金棒引きの音が、夜の静けさを一層際立たせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、金棒引きの「ご用心！」という声が聞こえると、もう寝る時間だと知った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
