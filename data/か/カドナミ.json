        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古い町並みを歩くと、趣のある門並みが続いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "川沿いに建つ門並みが、夕日に照らされて美しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "門並み焼け落ちたなかで、この家だけはちやんと残つてゐたんです。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "細い釘店の往来は場所｜柄だけに門並みきれいに掃除されて、打ち水をした上を、気のきいた風体の男女が忙しそうに往き来していた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもその年の二月、長崎へ来た外国船からはやり出したもので、三月頃には京大坂に伝わり、それが東海道を越えて五、六月頃には江戸にはいって来ると、さあ大変、四年前の大コロリと負けず劣らずの大流行で、門並みにばたばた仆れるという始末、いや、まったく驚きました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蟹のお角",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧書生が「われに万両の金あれば、明日より日本国中の門並みに学校を設けて家に不学の輩なからしめん」と言う者を、今日良縁によりて三井・鴻ノ池の養子たらしむることあらば、はたしてその言のごとくなるべきや。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは僕の住んでゐた元町通りに比べると、はるかに人通りも少なければ「しもた家」も殆ど門並みだつた。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天神様」　僕等は門並みの待合の間をやつと「天神様」の裏門へ辿りついた。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは僕の住んでいた元町通りに比べると、はるかに人通りも少ければ「しもた家」も殆ど門並みだった。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "天神様　僕等は門並みの待合の間をやっと「天神様」の裏門へたどりついた。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "登山用具、絵はがき、洋服屋と、さっきの店を門並みにのぞきながら、ヒルシェングラーベンのホテルに帰る。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は殆ど門並みに知っていた深川の大通り。",
              "citation": {
                "source": "深川の唄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "金は持つて居ないだらうと思ふが――」「不斷百も持つて居ない人間だが、この二三日馬鹿に景氣がよくて、伊太郎などは近在の賭場を門並み荒して歩いたさうだよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "狐の嫁入",
                "note": "青空文庫"
              }
            },
            {
              "text": "三文｜賭博を打つ元手のない時は、この辺の飲屋を門並み荒して歩いていますよ」「そいつを探してみようじゃないか」「わけはありません」　二人はそれから、二三軒｜縄暖簾を漁ると、全くわけもなく見付かってしまいました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "殺され半蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕自慢のお武家が門並み持て餘した相手だ」　平次も緊張しきつてをります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "辻斬",
                "note": "青空文庫"
              }
            },
            {
              "text": "金は持っていないだろうと思うが――」「不断百も持っていない人間だが、この二三日馬鹿に景気がよくて、伊太郎などは近在の賭場を門並み荒らして歩いたそうだよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "狐の嫁入",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいつは大変だ、手を洗ってすぐ行くからそこで話せ」「それっ切りの事ですよ、今日はお琴が逆立ちで日本橋を渡るんだと言って、通り一丁目から門並み空家だ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "橋の上の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座は親方の竹松の外に、囃子も仕る、藝達者の女房のお六、木戸番の三太郎に、口上と道化方と、手品も少々は心得てゐる、珍々齋といふ四十男、それで全部ですが、眞珠太夫の人氣が大變で、門並みの小屋を壓して此處だけはハチきれさうな入りです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "眞珠太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の昔の正月気分浮身をやつした凧あそび　初春の賑わい、正月気分に変りはないが明治時代は遥かにのんびり、土蔵造りの大商店は赤毛氈に家重代の金｜屏風、門松のうつりもよく、市中大通りはもちろん場末の町々まで門並み新しい紺の暖簾。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "藩邸の御長屋で、数右衛門並みの同僚ばかりで十四、五名で、持ち寄りで一酌やった。",
              "citation": {
                "source": "※かみ浪人",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まうしご冥加ご報謝と、　かどなみなみに立つとても、　非道の蜘蛛の網ざしき、　さはるまいぞや。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうしご冥加ご報謝と、　かどなみなみに立つとても、　非道の蜘蛛の網ざしき、　さわるまいぞや。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
