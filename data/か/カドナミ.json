        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この地域では、門並みごとに庭の手入れが行き届いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祭りの飾り付けは、門並みそれぞれが工夫を凝らしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「いやー、ご近所の門並み、みんな気合い入ってるね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
