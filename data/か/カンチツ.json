        "examples": {
          "standard": [
            {
              "text": "書斎の壁一面を埋め尽くす膨大な巻帙に、訪れた客は言葉を失った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古典籍の保存状態を確認するため、一巻ずつ丁寧に巻帙を改めていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「これほど貴重な巻帙が散逸せずに残っていたとは、まさに奇跡ですよ」と学芸員が呟いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その間、年を閲する二十八、巻帙百六冊の多きに達す。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
