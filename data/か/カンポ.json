    "definitions": [
      {
        "index": 1,
        "gloss": "slow walk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "情のために道を迂回し、あるいは疾走し、緩歩し、立停するは、職務に尽くすべき責任に対して、渠が屑しとせざりしところなり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "緩歩不休は山登りばかりの秘訣ではない、人生の事すべて然り。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "独逸路は海より広き大野なり、雲のはてまで山かけもみず　夜に入りて、さらに同氏の宅にて晩餐をおわり、食後街路を緩歩す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、セーヌ河南に散策し、夜また市街を緩歩して帰る。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "行をみだし、法に反く者は立ちどころに斬って捨てん」　彼は――そう云い終ると、踵をめぐらし、緩歩して、南面した。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「孔明の退く手口を見ると、緩歩退軍の策です。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
