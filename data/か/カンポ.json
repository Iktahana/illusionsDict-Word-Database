    },
    "definitions": [
      {
        "index": 1,
        "gloss": "postal life insurance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "花のき村の入り口のあたりは、すかんぽやうまごやしの生えた緑の野原で、子供や牛が遊んでおりました。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京ではすかんぽといふ。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「すいは」と云ふのはここに云ふすかんぽではない。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この川に添うて、またかのすかんぽが簇生して居り、幼年の者しばしばそれを嗜むのである。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる因縁の有るすかんぽだから學校の庭にそれを見付けると、ああこんな處にも生えてゐると思つて、なつかしく感じたわけであつた。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけの事を思ひ出すのも、これから話すすかんぽからの聯想ゆゑである。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の流の一方にさはさはと、其すかんぽの一群が繁茂してゐたのである。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すかんぽに關する第二の話は正味これだけである。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月、すかんぽの花のくれなゐ。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所がすかんぽの話に後日譚が湧出した。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで最後に殘つたすかんぽの話へと急ぐ。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大學構内の公開の場所には今やどこにもすかんぽは見つからなかつた。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すかんぽの話は之を以て終る。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「や、すかんぽだ、すっかり枯れてる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "や、また、すかんぽだな。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎杖とすかんぽばかりだな。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "木柵、木柵、木柵、　海老茶だ、あ、すかんぽだ、あ、お襁褓だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほう、すかんぽだ、枯れ花だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "すかんぽ、すかんぽ、紅更紗。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪かづく穂高の山と湖と葡萄茶の繻子の虎杖の芽と　昔は皆とぼとぼと登つていつた峠の尾根の展望で、榛名湖を中心とする早春の快い光景を写真の様に遠くから順に写し最後に脚下のすかんぽの芽に及んで最も精しく之を叙し読者を現場に誘引する手法である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰌釣り、鰻の夜釣りなどもちよつとよいが、面白いのは鯰釣り、長竿で太糸で、大鉤へ蛙をつけて、夕暮の沼や川の藻の中を、ぽかんぽかんと叩く、すると貪婪な鯰がガバと来る、一名ポカン釣りといつて滑稽な釣りの一課目である。",
              "citation": {
                "source": "夏と魚",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうたくさんか、たくさんでなけりゃ、まだ撲ってやる」とぽかんぽかんと両人でなぐったら「もうたくさんだ」と云った。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、きつと、きつと、この仇を取つてやります……」　曾ては、すかんぽの莖のやうに水々しく美しかつたおきみのうなじも、今はどす黒く痩せて、カサカサに乾いてゐた。",
              "citation": {
                "source": "天國の記録",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "春になれば草の雨、三月桜、四月すかんぽの花のくれなゐ、また五月には杜若、花とりどり、人ちりぢりの眺め。",
              "citation": {
                "source": "旧東京と蝙蝠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "すかんぽ原櫻間中庸すかんぽ原は夕やけしてた赤ん坊おぶつて探していつたすかんぽ原はつくしのにほひどこかで子供のうたごゑしてたすかんぽ原はトンネルつづきこもつたおとで汽笛がしてた",
              "citation": {
                "source": "すかんぽ原",
                "author": "櫻間中庸",
                "note": "青空文庫"
              }
            },
            {
              "text": "家畜は、前年の旱魃により冬期間いずれも皆極度に損害をうけ、そして収穫の約一月前の七月には、多数の人民は、樅の中味や乾したすかんぽで作り、味や栄養をつけるために碾割を少しも混じていない、パンで生活したのである。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
