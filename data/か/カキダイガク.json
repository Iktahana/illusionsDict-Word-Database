        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今年の夏は、語学力向上のため夏期大学に通う予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "専門知識を深めるために、毎年夏期大学で短期集中講座を受けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夏期大学では、普段受講できない特別講義が魅力だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "もう一つの新聞の方には吾々両名が佐渡の夏期大学で講義を終えてその帰りに新潟で大講演会をやるように書いてあるのである。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐渡の夏期大学云々というのは全くウソで、所謂大佐渡のシベリヤ寄りの海岸線を彷徨したり、偶然来合わせた一組の女学生上り達と一緒に「おけさ」を見たり御馳走にあずかったり（尤も一夕座談会はやったが）しただけだったが、何にせよ之は大変なことになったと思ったのである。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏期休暇中帰省する学生、教師などと協力して各地方でも夏期大学や農村講座がもたれた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "教坊の楽と脂粉の香のまじる夏の夕に会へるものかな　昭和八年八月高野山の夏期大学の講義を終へた夫妻は大阪へ出て然る人の饗宴に列した、南地宗右衛門町の富田屋らしい。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは七百人の夏期大学となり、ついに広島県十三万人の労働文化協会となった。",
              "citation": {
                "source": "聴衆０の講演会",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この協会が夏期大学をやろうとして、二十一名の大学教授連を二十二カ町村へ送り込もうと計画した時は、何か私は、大海戦にでもぶつかるように腹の底で煮えるものがあった。",
              "citation": {
                "source": "地方の青年についての報告",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾道でも、ちょうど夏期大学中青山君が私の家にいるとき、一農村青年が、「やっとカントの『純粋理性批判』を読み終りました」と言って、貸した本と南瓜を二つ持って来たので、青山君はとてもびっくりしていた。",
              "citation": {
                "source": "地方文化運動報告",
                "author": "――尾道市図書館より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこの夏、夏期大学を機会に、待望の高知行が実現された。",
              "citation": {
                "source": "桂浜",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの頃、夏休みになると、信州の木崎湖に夏期大学が毎年開かれた。",
              "citation": {
                "source": "私の履歴書",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは現在までも続いているそうであるが、あの時代の木崎湖の夏期大学といえば、若い連中の間に大した人気のあったものである。",
              "citation": {
                "source": "私の履歴書",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
