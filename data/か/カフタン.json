        "examples": {
          "standard": [
            {
              "text": "暑い国のリゾートでは、鮮やかな色のカフタンを着て過ごすのが一般的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はビーチで、涼しげなコットン素材のカフタンを羽織っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "異国情緒あふれるカフタンは、ゆったりとした着心地が魅力だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "モロッコ土産にもらった刺繍入りのカフタンは、部屋着としても重宝している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それからカフタンといふ上着と毛皮とを脱いで、赤い肌着に、土地の者の穿くずぼんを穿いたまゝで、己と向き合つて煖炉の側に腰を掛けた。",
              "citation": {
                "source": "樺太脱獄記",
                "author": "コロレンコ　Vladimir Galaktionovick Korolenko",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
