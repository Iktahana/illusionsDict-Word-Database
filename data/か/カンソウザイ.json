        "examples": {
          "standard": [
            {
              "text": "靴の中に湿気がこもらないよう、乾燥剤を入れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このお菓子の袋には、乾燥剤が入っているので食べないように注意書きがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "クローゼットの隅に置いた乾燥剤が、湿気を吸ってパンパンに膨らんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "乾燥剤を入れたセメントを使えば、一日でかわきます。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
