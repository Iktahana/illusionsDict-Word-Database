        "examples": {
          "standard": [
            {
              "text": "カニクソ（胎便）は新生児の最初の便である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "羊水中のカニクソ（胎便）は胎児の苦痛を示唆する可能性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "医師は出生後に赤ちゃんにカニクソ（胎便）の着色がないか確認する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それは物凄く汚いどろどろのかたまりのようなもので、三好が看護婦から聞いたのでは、胎児の毒素が口の方へ出るのだと云うことであったが、幸子が見ると、赤ん坊が分娩後に始めて排泄するあの蟹屎と云うものに似ていた。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
