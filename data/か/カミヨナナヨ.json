        "examples": {
          "standard": [
            {
              "text": "日本神話における神代七代は、天地開闢からイザナギ・イザナミの神々へと続く重要な系譜だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古事記に登場する神代七代の神々は、それぞれ異なる役割を持ち、この国の成り立ちに関わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "神代七代の伝承は、日本の文化や信仰の根底にあるもので、その影響は今も色濃い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "研究者たちは、神代七代の神話がどのように形成され、後世に伝えられたのかを探っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "このクニノトコタチの神からイザナミの神までを神代七代と申します。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
