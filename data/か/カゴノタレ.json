        "examples": {
          "standard": [
            {
              "text": "祭りの行列では、豪華な籠の垂れが風に揺れていました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古い寺院の宝物館で、かつて使われた籠の垂れを見学しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この絵巻物には、高貴な人物が乗った籠と、その美しい籠の垂れが描かれています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "真新しい白い浴衣が切子灯籠の垂れ紙にも見えたのでした」　女学校を卒業した先生は、それから一人で頻りに赤城の山頂へ閉じ籠って勉強するようになった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お駕籠の垂れは深ぶかとおろしてありますから、お姿を拝むことはできなかったのです。",
              "citation": {
                "source": "尼になった老婆",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――駕籠の垂れを排してそこに姿を見せたものは、それも百化け中のうちにある変装の一つと見えて、巧みにつくった大名姿の十吉です。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "籠の垂れを内から掲げながら、立ち出でた総髪の男を見たとき、彼は嬉しさのあまり躍り上りたかった。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "血にぬれた懐剣をひっさげて、駕籠の垂れを刎ねてお小夜坊が、姿を現わしたからです。",
              "citation": {
                "source": "怪しの者",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、ヒラリと駕籠の垂れが、風もないのに飜えったかと思うと、電光のように飛び出して来たのは白毛を冠った犬であった。",
              "citation": {
                "source": "紅白縮緬組",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今わしが、この三十本の刀を引き抜くから、誰でもよい、すぐこの綱を取り払って、駕籠の垂れを上げてほしい。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の一本が抜き取られるのを待って、群集の中から飛び出した二、三人が、素早く縛ってある細引きを取り外け、駕籠の垂れを開けると、中から千浪がにっこり笑いながら、駕籠を出て来た。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "先なる駕籠の垂れをはぐって、白髪あたまをのぞかせたのは、柳生対馬守の江戸家老、田丸主水正で、あとの駕寵は若党｜儀作だ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その時、後の駕籠の垂れをはぐって覗いていた武士の顔！",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "出しぬけにつれて来て驚かしてやろうという肚、二梃駕籠を打たせて来る途中、九段下のまないた橋で、琴二郎と間違えて洒落た真似をした村井長庵を、駕籠の垂れから一刀を覗かせて難なく追っ払ったのち、こうしてこの築土八幡の喬之助留守宅へ、眼立たないように裏口に廻って駕籠をつけさせたのだった。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "油を浮かべたような菊屋橋の堀割りへ差しかかったとき、女は駕籠の垂れを上げて背後を見た。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "祝言は多賀屋の身代にしては出来るだけつつましやかに、当日の客は余儀ない親類を五六人だけ、聟入りもほんの型ばかりということにして、偽首の八五郎が、仲人宝屋祐左衛門夫婦に護られ、駕籠の垂れを深々とおろして、多賀屋へ乗込んで行ったのは、秋の宵――酉刻半（七時）そこそこという早い時刻でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "ガラッ八祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "駕籠の垂れから、僅かにさしこむ残照のほの明りで、自分の指がふるえているのをおしのは見た。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平八は駕籠の垂れをあげ、向うを見るなり「おい、おろしてくれ」と云った。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あにいはきせるの吸殻をはたき、立っていって、駕籠の垂れをあげた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "醒めんのかっ』　一方の駕籠の垂れを蹴とばしたのである。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
