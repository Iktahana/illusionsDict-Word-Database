[
  {
    "uuid": "abc09c99-bf82-5692-aa62-30a4191ad806",
    "entry": "踵",
    "reading": {
      "primary": "かかと",
      "alternatives": [
        "きびす",
        "くびす",
        "あくと"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "heel (of foot, shoe, stocking, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しい靴は踵が少し硬くて痛む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "転んで、足の踵を強く打ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "踊っているうちに、靴の踵がすり減ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供は母親の踵を追いかけるように歩いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それからもう一つには、この年に相踵いで起った色々の災害レビューの終幕における花形として出現したために、その「災害価値」が一層高められたようである。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると少年は苦痛な顔をして受取りもせず、踵を返してすごすごと他の店先へ掃きに行った。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その憧憬が此頃は地べたに踵をつけて来た。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイレンが鳴り、花火が上がり、半鐘が鳴っている最中に踵を接して暖簾を潜って這入って行く浴客の数は一人や二人ではなかったのである。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「てっきり彼奴」　と独り言、Ｔ「朝ッぱらから一稼ぎしてやがるかも知れ無えぞ」　其辺で鉄五郎クルッと踵を反して走り去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、くるっと踵を返して走り出す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "フリツツは踵を旋らして、ポツケツトに両手を入れた儘、ぶら／＼広場へ戻つて来た。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "外は倫敦の深い霧が立ちこめて、青い幻灯の街路を、外套の襟に顔をうずめて各国の女が相変らず男から男に身を売って、凍った地面を高い踵で音楽のように敲いて行ったり来たりしていた。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、ユーストンの街路の銀鈴の響が尾をひいて、馬の踵の音が静寂な空気の中に運命的な号びをたてた。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなのにものの一間もがたがたと床を踏んだかと思うと踵をかえして大胆に私を藪睨して、英国人らしく鼻に疣をつくって、　――まあ、Ｙ。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は彼等に貴族の末路を象徴するブカレスト生れの軽騎兵の肖像と、人間の過去のミイラと、女の踵を提供した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マジエスチック・ホテルのティダンスは閑散として、ロシア人の踊子の赤い踵が見えず、他の金髪美人連がアクビをかみころしていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと米良はロシア女の踊子達の踊靴が帝政時代そのままの黒い踵で近代を象徴するのを見るのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は彼等に貴族の末路を象徴するブカレスト生れ軽騎兵の肖像と、人間の過去のミイラと、女の踵を提供した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "奔流、ごろつきのような波の音が僕に英国少女メリーの靴の踵と、乳房に鬘をかむったような女主人を思い出させた。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "空はリキュール酒のようなあまさで、夜の街を覆うと、絢爛な渦巻きがとおく去って、女の靴の踵が男の弛緩した神経をこつこつとたたいた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　太く短い女は立あがると、いらいらして部屋を踵のない靴であるいた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　陽気に、口笛を吹いて女タイピストが踵をかえした。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンスはツレブラ、そのシステム、ウォーク、右廻転、左廻転、プロムナード、チロ、踵を床から浮離するツレブラを愛す。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣持を變に浮き立たせる樂音の渦卷、靴の踵と床の擦れ合ふ響、踊りながらする男女の囁き、その間に時時洩れる女達の淫蕩な笑ひ聲。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈の高い男の嚴丈さうな腕に、もたれるやうに腰を抱きかかへられながら、女は踵の高い赤革靴の運び輕げに踊つてゐる。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もそれに續いたが、高かつた踵の、横に曲つてへつてしまつた女の黒い編上靴がおづおづと動いて行くのを眼の前にすると、私の胸には變な不快さが込み上げて來た。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "重い背嚢に締め著けられる肩、銃を支へた右手の指、足の踵――その處處にヅキヅキするやうな痛みを感じながら、それを自分の體の痛みとはつきり意識する力さへもなかつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝２＝痛まし專門棋士　名人｜决定｜戰の金、花田｜兩八｜段の對局、相踵いで大崎、木見｜兩八｜段の對局を觀戰して、僕は專門｜的な棋戰の如何に苦しく辛きものであるかをつくづく思ひやつた。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "太い、しっかりした腕に、娘はぶら下って、ちょか／＼早足に踵の高い靴をかわした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "踵を失った大西は、丸くなるほど繃帯を巻きつけた足を腰掛けに投げ出して、二重硝子の窓から丘を下って行くアメリカ兵を見ていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「踵を一寸やられた位で呉れるもんか。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳朶のちぎれかけた男も、踵をそがれた男も、腰に弾丸のはまった男も、上膊骨を折った男も、それ／″＼、憐れみと、懇願の混合した眼ざしを持って弱々しげに這入ったきた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏は、対岸から、踵の高い女の白靴や、桜色に光沢を放っている、すき通るような薄い絹の靴下や、竹の骨を割った日傘が、舟で内密で持ちこまれてくる。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みなつらなめて逃れゆく、黎明の林を出づる旅びとら、その足竝に音はなけれど、水ながれいでて靴のかかとをうるほせり。",
              "citation": {
                "source": "黎明と樹木",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
