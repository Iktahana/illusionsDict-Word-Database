        "examples": {
          "standard": [
            {
              "text": "同じ商品でも、店舗によって数円の価格差がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "輸入品と国産品では、輸送コストの分だけ価格差が生じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ネット通販と実店舗の価格差を比較してから購入を決める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "為替レートの変動が、両国間の製品価格差に影響を与えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "来週から又一日置きの稽古にすると云ったところ、Ｙが居ないとき、自分に「何故そうしたのか、どうかかくさず云って下さい。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その本の表紙の帯紙に、あなたは「朝鮮戦乱勃発のその日から、私は（何かかくされている）という疑惑に悩まされつづけてきた。",
              "citation": {
                "source": "清水幾太郎さんへの手紙",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりが、からくも、すがたを隠したかかくさないうちである、八風斎の目のしたへ、潮の流れるごとき勢いで、さしかかってきた蛇形の行軍、その人数はまさに四百余人。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
