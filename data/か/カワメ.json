[
  {
    "uuid": "d602ebf3-9b2e-50fb-ac8a-d840578ee06a",
    "entry": "皮目",
    "reading": {
      "primary": "かわめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
