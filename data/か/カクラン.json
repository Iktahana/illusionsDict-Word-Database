    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sunstroke",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "炎天下で長時間作業をしていたため、霍乱で倒れてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "昔の人は、夏の急な病を霍乱と呼んで恐れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "旅の途中で霍乱にかかり、数日間宿で寝込む羽目になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "伊右衛門はますます恐れて｜雑司ヶ谷の鬼子母神などへ参詣したが、怪異はどうしても鎮まらないで女房が病気になったところへ、四月八日、芝の増上寺の涅槃会へ往っていた権八郎がその夜｜霍乱のような病気になって翌日歿くなり続いて五月二十七日になって女房が歿くなった。",
              "citation": {
                "source": "四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御成道の道具屋の女房はこの七月に霍乱で死にました。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　森山が、疲労と睡眠不足との身体を炎暑に煎りつけられて、日射病系の急性｜霍乱で死んでから、そこの小作人達は、代る代るに水揚げ水車を踏んだ。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔のはばが広くほっぺたが真っ赤に光っている助手さんがあって、いかにも赤鬼のお面を聯想させるのだが、さすがに、そこは遠慮して避けて、鬼の霍乱というわけで、カクランだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "霍乱に頑張られては、かなわない。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家内の者もおどろき騒いで、すぐに近所の医者を呼びにやると、医者は暑気あたりの霍乱であろうと診察した。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は霍乱と診立てた医者も、後には普通の暑気あたりではないらしいと言い出した。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それから三、四年経つうちに、親分の吉五郎は霍乱で死にました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "『霍乱にでもなると大変だよ』　主婦は下から首を出して、時々声をかけて呼んだ。",
              "citation": {
                "source": "朝",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親が霍乱で夜明まで持つまいと申すことでござります。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎列拉には三種ありて、一を亜細亜虎列拉といい、一を欧羅巴虎列拉といい、一を霍乱という、此病には「バチルレン」というものありて、華氏百度の熱にて死す云々。",
              "citation": {
                "source": "みちの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "伴ふどち可笑しがりて、くわくらん（霍乱）の薬なるべしと嘲笑ひ候まま、それがし答へ候ははくらん（博覧）病が買ひ候はんと申しき。",
              "citation": {
                "source": "芭蕉雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の三つの時の七月に母は霍乱で死んだ。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は鹿児島の藩士にて、維新の戦争に討死し、母は安彦が六歳の夏そのころ霍乱と言いけるコレラに斃れ、六歳の孤児は叔母――父の妹の手に引き取られぬ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は客の方を見ながら、「お重が心持が悪いなんて、まるで鬼の霍乱だな」と云って、今度は自分に、「先刻｜綱（母の名）の話では腹が痛いように聞いたがそうじゃない頭痛なのかい」と聞き直した。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は客の方を見ながら、「お重が心持が悪いなんて、まるで鬼の霍乱だな」と云って、今度は自分に、「先刻綱（母の名）の話では腹が痛いように聞いたがそうじゃない頭痛なのかい」と聞き直した。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夏の日盛りに、二人して、長い竿のさきへ菓子袋を括り付けて、大きな柿の木の下で蝉の捕りくらをしているのを、宗助が見て、兼坊そんなに頭を日に照らしつけると霍乱になるよ、さあこれを被れと云って、小六の古い夏帽を出してやった。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、医者の診断では、卒中でも霍乱でもない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蕃拉布",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んでいたのか眠っていたのか、それとも霍乱でも起してひっくりかえってたのか。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "両国の大鯨",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう若様十次郎を伴れて鎌倉町の親のところへ帰ったのはツイ一と月ばかり前、お邸から人橋かけての迎えを蹴飛ばしているうちに、――五日前」「その十次郎様というのが霍乱で死んだというのだろう」「ヘエ、親分は知っているんで――？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "「季節外れの霍乱で、源太郎の孫がやられたという話は聞いたが、それが大名の跡取りとは知らなかったよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その霍乱が、駿河台の御屋敷から届いたお菓子を喰った晩から起って、翌る日の陽の目も見ずに、若様が冷たくなっていたとしたら、どんなもんで」「それは知らなかった」　平次も予想外な顔色です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前の智恵じゃあるまい」「霍乱になる菓子を捨てるくらいの智恵はあるよ」「よしよし、お前は思いの外｜悧巧そうだ、がこれは隠し切れる事じゃないよ」　平次はそれっきり手を引きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、霍乱か何かのような、一時は臓腑まで吐くんじゃないかと思いました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "受難の通人",
                "note": "青空文庫"
              }
            },
            {
              "text": "――石津右門というのは、五十前後の鬼が霍乱を患ったような悪相の武家、眼も鼻も口も大きい上に、渋紙色の皮膚、山のような両肩、身扮も、腰の物も、代表型な浅黄裏のくせに、声だけは妙に物優しく、折目正しい言葉にも、女のような柔かい響きがあります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "城の絵図面",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼の霍乱が萎れ返った様子は、物の哀れを通り越して可笑しくなるくらい。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "城の絵図面",
                "note": "青空文庫"
              }
            },
            {
              "text": "名乗るとすぐ通してくれたのは、奥まった一室、石津右門相変らず鬼の霍乱みたいな顔に、鬱陶しい皺を刻んで出て来ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "城の絵図面",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しめたと思ったから、飛んで行って勘三郎を挙げるつもりだったが、いけねえ、――肝腎の勘三郎は、三日前から霍乱に罹って、死ぬような騒ぎだ」「本当か」「吐く瀉すで、げっそり痩せているから、嘘じゃないでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "許嫁の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによると赤痢及び小児｜霍乱は全く無く、マラリヤによる熱病はその例を見るが多くはない。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "海｜蛇たちは遠く去ったらしい、洞の付近には人影もなく、厩舎も養禽場も、なんらの異状がない、湖のほとり、川辺のだちょうの森も、かくらんされたあとは見られなかった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
