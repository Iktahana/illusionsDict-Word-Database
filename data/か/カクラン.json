[
  {
    "uuid": "4f8dff96-4411-5e6a-9289-81117b78a855",
    "entry": "霍乱",
    "reading": {
      "primary": "かくらん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
