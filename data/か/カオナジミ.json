    "definitions": [
      {
        "index": 1,
        "gloss": "acquaintance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "駅前で顔なじみの店員さんに会った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "引っ越したばかりで、まだ近所に顔なじみは少ない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "飲み屋で昔からの顔なじみとばったり会った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの喫茶店は顔なじみの客が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "庄太は土地の者だけに、そのなかには顔なじみの者もあるらしく、一人の男に声をかけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　私は搭乗券を売る娘と顔なじみになった。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、ここには、友だちひとりいるわけではありませんし、あいさつの声をかけてくれるような顔なじみもなかったのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔なじみの部員に古い○○館出版の西鶴全集の下巻を出して貰って。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "受験生も、みんな顔なじみの四年生だ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでふたりは道具箱から、日ごろ顔なじみの、だが手をにぎったのはこれが最初の、道具をつかみ出してはいじくった。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "月あかりで透かして視ると、かれらはこのごろ顔なじみになった町役場の書記と小使で、これから近所の川へ夜釣りに行くというのであった。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで百石積の玄海丸という抜荷専門の帆前船を探し出して顔なじみの船頭に酒手を遣り、水揚人足に命じて車の上の荷物を全部積込ませると、念のためもう一度上陸してこの間の福昌号の裏口に行き、人通りの絶えたところを見計らって地下室の小窓に鼻を近付け、今一度中の様子を窺いてみた。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも細君が大病かあるいは亡くなったのではないかと思われたのであるが、犬のジョンだけは相変わらずいつものどかな勇ましい姿をして顔なじみの僕の通るのを見迎え見送るのであった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何度も赴くうちに、農場でも顔なじみになっていった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はずっと店へはいって床几に腰をかけると、これも顔なじみのお染という若い女が愛想よく茶を汲んで来たが、茶釜の前にもお里のすがたは見えないので、林之助は一種の失望を感じた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "番台には今日と同様、湯屋の亭主か女房か又は娘が坐っていたのであるが、顔なじみの客が来れば何とか挨拶して話しかける、客の方でも何か話しているのが多かった。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんないい人はないね」　と、最初はこんなことをいっていましたが、そのうちに杉浦は、Ｍ侯爵といつの間にか顔なじみになったらしいのです。",
              "citation": {
                "source": "Ｍ侯爵と写真師",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり殖えた、三人にしろとゆうべお使いがござりましたんで、ちやんと平土間が取ってござります……」「じゃ兄さん……」　顔なじみの出方に迎えられて導かれていった桟敷は、花道寄りの恰好な場所でした。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、ようこそ……」　たびたび来ているとみえて、顔なじみらしい女中がふたり、あたふたと顔を並べ乍ら下へもおかずに新兵衛を請じあげた。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔なじみのおまえたちだから打ち明けるが、あんな無理をいう女房ってえものはねえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで一度顔なじみになれば、別の専門へ紹介してくれるのもあるそうな。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのスパイは前から顔なじみだった。",
              "citation": {
                "source": "母たち",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも半月以上もつゞけて通っているうちに、幾人も顔なじみが出来て、家にいるよりは面白いということになりました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか得体のわからない会合であると思いながら、まずひと通りの挨拶をして座に着いて、顔なじみの人たちと二つ三つ世間話などをしているうちに、私のあとからまた二、三人の客が来た。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "路はいよいよ暗くなったので、僕は顔なじみの茶屋から提灯を借りて、雨のなかを下山した。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、そのなかには、前々から顔なじみの人もありますので、一同うちとけて話しはじめました。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうの葬式で近所の人とも顔なじみになっているので、半七はそこらにいる人達から徳蔵の死について何か手がかりを聞き出そうとしたが、どの人もただ呆気にとられているばかりで、何がなにやらよく判らなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "弁天娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから、ここまで来て貰って、おめえの知っているだけのことを……」「その留吉だって昨日きょうの顔なじみだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎老と婦人５・14東京日日（夕）　いつだつたか、アメリカの旅人が三四人、パリーで、かねて顔なじみのクレマンソーと会食をしたことがあつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い女性の心にうごく願望に導かれて、それらの人はばらばらに図書館に来て、学校の課目や勤めの義務以外の勉強をしているうちに、段々互に顔なじみになり、話しがはじまり、御弁当のとき一緒に食堂へ行くようなことから、一つの集りが出来た。",
              "citation": {
                "source": "図書館",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "繰り返し訪れる早水に、顔なじみとなったソフトハウスのスタッフも率直にマシンへの注文を口にするようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから僕なんか、こうしてぶらぶらしていると、何度も同じ人に出会わすよ、のみならず、ここを歩いている人達はみんな顔なじみという気がするんだ。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう人たちの中には、いつとはなしに要吉と顔なじみになっている人もありました。",
              "citation": {
                "source": "水菓子屋の要吉",
                "author": "木内高音",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ですから、お客さまのほうのお鳥目にしたがいまして、遊女のほうでもそれぞれの禄高のものが参りますが、どなたかおなじみでもござりましょうか」「なじみと申すと、親類の者かな」「さ、さようです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
