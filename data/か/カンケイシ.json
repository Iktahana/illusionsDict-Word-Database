        "examples": {
          "standard": [
            {
              "text": "英語の文法で、先行詞を修飾する役割を果たすのが関係詞です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "関係詞節は、複雑な情報を簡潔にまとめるのに非常に便利です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この英文では、どの関係詞を使えば適切か、考えてみましょう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "関係詞の「that」は、人にも物にも使えるため汎用性が高い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その文字のうちでも、動詞、関係詞、形容詞、副詞等をつとめて節略する。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
