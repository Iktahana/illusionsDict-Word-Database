[
  {
    "uuid": "5579ba0a-a8e6-5d05-a448-cf5820656e03",
    "entry": "空っぽ",
    "reading": {
      "primary": "からっぽ",
      "alternatives": [
        "カラッポ"
      ],
      "is_heteronym": false
    },
    "grammar": {
