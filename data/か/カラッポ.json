    "definitions": [
      {
        "index": 1,
        "gloss": "empty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "財布が空っぽで、今月はもう金欠だ。どうしよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "冷蔵庫の中が空っぽだから、今日中に何か買いに行かないと。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "試験に落ちてしまって、頭の中が空っぽになったみたいだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の言葉は空っぽで、何も響かなかったよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あれ？この箱、中身が空っぽじゃないか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そうしてそれらの挿図の説明はというとほとんど空っぽである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分が電車で巡り合った老子の虚無は円満具足を意味する虚無であって、空っぽの虚無とは全く別物であった。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もない空っぽの真実の世界に返してみたくなるのです」「アンタ……それじゃ虚無主義者ね」「そうですよ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな出て行っておもちゃ箱は空っぽになりました。",
              "citation": {
                "source": "キューピー",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたしてデストゥパーゴは空っぽな声でどなりだしました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんてわざと空っぽな大きな声を出すものもあるんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷も石瓦、古新聞、乃至、懐中は空っぽでも、一度目指した軒を潜って、座敷に足さえ踏掛くれば、銚子を倒し、椀を替え、比目魚だ、鯛だ、と贅を言って、按摩まで取って、ぐっすり寝て、いざ出発の勘定に、五銭の白銅｜一個持たないでも、彼はびくとも為るのではなかった。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『うん、まるで破れた大太鼓みたいに空っぽになった。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……村井だ……村井だ……」「完全な犯罪」の側杖を喰って、星田以上の恐怖に打ち拉がれていた彼は、最早、自分の意志を無くした空っぽの人形として動いているだけであった。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めに四つ五つ私を追い越して喰っているばかりでなく、私が三つ喰ううちに四つか五つの割りで頬張って飲み込むので、見る見るうちに箱の半分以上が空っぽになってしまった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの袋戸棚から竈の下とその向う側、洗面所の上下の袋戸、物置の炭俵や漬物桶の間、湯殿と台所との間の壁の厚さ、女中部屋の空っぽの押入れ、天井裏にかけた提灯箱なぞいうものを、妻木君は如何にも慣れた手付きで調べて見せたが何一つ怪しいところはなかった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそれと同時に、タッタ今の感激のうちにスッカリ空っぽになった彼の頭が、彼自身のものではないかのように力なく、ゴロリと草の株から転がり落ちた。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにひろげられた枕屏風の蔭に、空っぽの飯櫃がころがって、無残に喰い荒された漬物の鉢と、土瓶と、箸とが、飯粒にまみれたまま散らばっている。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "体内が、空っぽになった感じ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子の居ない一ヶ所｜空っぽうのような現実の生活と、息子の帰って来た生活のいろいろな張り合いのある仮想生活とがかの女の心に代る代る位置を占めるのである。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）それから二三日続けて毎日寄って見たが、何時も小舎は空っぽである。",
              "citation": {
                "source": "南島譚",
                "author": "※",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の中が空っぽになって日が暮れると、千六は提灯を一つ点けて忙がしく働き初めた。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "新子も、反感めいた気持で、空っぽの寝床に背を向けて、今夜は美和子の帰らない内に、どうでも寝つこうとし、寝つくために、何か下らない古雑誌でも読もうと、床を這い出して、机の前にいざり寄ると、階下からしのびやかに、母が上って来る足音がした。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は二階に上っていってみましたが、しかし誰もいない空っぽの部屋が二つあるのを見出したばかり。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は家の中がたしかに空っぽであると云うことを確かめるために、なおまだ長い間そこに立っておりました。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こう云うわけで、あの男が這入っていった時には、家の中は空っぽだったのさ。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その屋根裏に、空っぽの誰もいないほこりだらけな、敷物もしいてなければカーテンもかけてない小さいな二つの部屋があって、その中へ私は案内されました。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "君たちこそ彼の女の馬車に乗っているから、君たちこそ知っているはずだ」「いや、我々は道でこの馬車に逢ったんだが、中は空っぽだったんだ。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで僕は二階に上ってみましたが、ひとけのない空っぽの部屋がふたつあるだけで、家じゅうどこにも、人っ子ひとりいません。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「昨日は空っぽでした。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "「下からだって……」とメリウェザー氏はそう言い、ステッキで床に並んだ敷石を叩いたが、「ん、何だ……空っぽみたいな音がする……！",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、この諸君が現在の酒亭へやって来た時には、ポケットはすでに空っぽだったのである。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、おしまいにはその眼の光りもドンヨリと消え失せてしまって、何の事はないキョトンとした空っぽの人形みたいな心理状態になる。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなり狡いところのある男であるが、殆んど空っぽになっている電車の片隅に、私の姿を発見すると、ビックリした表情をしながら、ツカツカと私の横に来て、二十貫目あるという大きな図体をドタリと卸した。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "空っぽの胃の腑に一本の酒が、まるで吹きつけるように、浸み込み、それで一層食慾を刺戟された、若い衆たちは、驚くほど馬食して、それが済むと、もう眠くなるのだった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
