    "definitions": [
      {
        "index": 1,
        "gloss": "good guest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "国際会議のレセプションパーティーには、各国の要人や文化人が佳賓として列席していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "恩師の退官記念パーティーを「素晴らしい佳賓をお迎えして開催できることを嬉しく思います」と司会が始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "老舗旅館の主人は、今日到着する佳賓のために自ら玄関を掃き清め、生け花を整えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "結婚披露宴に招かれた佳賓の方々から、新郎新婦へ温かい祝辞が贈られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そうして、みだりに鞭を瘠せ骨に加えて、旅客の御機嫌を取るのは、女房を叱って佳賓をもてなすの類だと思った。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "喬老、そなたも、佳賓におすすめ申しあげて賜も」　母公のご機嫌は一通りでない。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
