        "examples": {
          "standard": [
            {
              "text": "「ねえ、彼ピと最近どうなの？デートとか行ってる？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友達がSNSに彼ピとのツーショット写真を上げていて、羨ましかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末は彼ピとずっと行きたかった映画を観に行く予定なんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あのカフェ、彼ピと初めて行った思い出の場所なんだよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼ピントはポルトガル生れの貧乏人であるが、西暦一五三七年に一身代を起すべく東洋に出掛けた。",
              "citation": {
                "source": "東西交通史上より觀たる日本の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "こはファリナータとてピサなるスコルニジアーニ家のマ―ルヅッコの子なり、彼ピサの市民に殺されしとき、その頃故ありてフランチェスコ派の僧となりゐたりし父マールヅッコ、他の僧侶と共にいでてその葬儀を營みかつ神の旨に從はんため殺害者の罪を容せりと【強きを】わが子を殺せる者を赦せるをいふ一説に曰。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、これで、よく分ったよ」　彼ピート一等兵は、あんがい、おちついたこえで、ひとりごとをいった。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時僕は、彼ピョートル・ペトローヴィッチ・ルージンなんか、ありたけの長所を集めても、彼がかくも悪しざまにいっているソフィヤ・セミョーノヴナの小指だけの価値もない、とこう言いそえたのです。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
