        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「竹の中から現れた輝夜姫の美しさは、 celestial beauty そのものだった」と翁は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "帝は輝夜姫に求婚したが、彼女は月へ帰る運命だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、絵本で読んだ竹取物語の輝夜姫が忘れられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ああ、満月を見ると、輝夜姫が月へ帰っていく場面を思い出すよ」と祖母が懐かしそうに言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "Kaguyahime (manga series by Reiko Shimizu)",
        "register": "standard",
