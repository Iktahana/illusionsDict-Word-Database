        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「この『輝夜姫』っていう漫画、絵がすごく綺麗で、ストーリーも感動的なんだよ！」と友人が勧めてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "作者の清水玲子さんが描く『輝夜姫』の世界観にすっかり引き込まれてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔読んだ『輝夜姫』の漫画を、久しぶりに電子書籍で買い直した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの漫画の主人公、美しかったなあ。まさに『輝夜姫』だわ」と作品を振り返った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
