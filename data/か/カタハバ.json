        "examples": {
          "standard": [
            {
              "text": "船の型幅を測ることで、収容できる貨物の最大量を計算する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この狭い水路を通るには、本船の型幅ではギリギリの設計だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "設計図を確認したところ、型幅が当初の予定より数センチ広く修正されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
