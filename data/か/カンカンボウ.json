    "definitions": [
      {
        "index": 1,
        "gloss": "boater",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夏祭りに着ていく浴衣には、カンカン帽がよく似合うと思うの。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このヴィンテージのカンカン帽、すごくおしゃれじゃない？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、お母さんがカンカン帽をかぶってピクニックに連れて行ってくれたのを覚えてる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "避暑地のカフェで、カンカン帽をかぶって読書なんて、優雅だわ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "頭が奇麗に禿げていて、カンカン帽子を冠っているのが、まるで栓をはめたように見える。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と一緒に地方版の編集をやっていた松石という男は、月末近くなると、茶褐色に変色したカンカン帽を持って、一巡する。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かなくなってやしないこと……」　松石君の古いカンカン帽が、その日から新しくなった。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の上に置かれた帽子は、安サラリーマンのカンカン帽以上に豪華にも見えなかった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも弟はリュウとした紺と茶縞の――彼の好きだと云っていた柄のサックコートに青光りするカンカン帽を冠っていた。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は旧友から貰ったという竹製のカンカン帽に、手織｜木綿縞の羽織着流し、青竹の杖、素足に古い泥ダラケの桐下駄、筆者は五リン刈の坊主頭に略法衣、素足に新しい麻裏という扮装である。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々、大勢の人々がやって来て告別の焼香をして下すったが、その中に古びたカンカン帽、素足に駒下駄、浴衣がけにステッキ一本の書生さんが、アッサリと焼香し、叮嚀に叩頭して行ったのを、参列の人々の中で喜んでいる人が相当あった。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "路地の両側の軒ごとに、一業二業、三業の軒燈が押合って、灯は入らないでも、カンカン帽子の素通りは四角八面に照らされる。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を洗つて会はうと急いで夜具をたたんでゐると啄木は赤く日に焼けたカンカン帽を手に持つて洗ひ晒しの浴衣に色のさめかかつたよれよれの絹の黒つぽい夏羽織を着てはいつて来た。",
              "citation": {
                "source": "札幌時代の石川啄木",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "杜はカンカン帽を手に、さきへ階段を下りた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ僕も、ここで失敬しますよ」　杜はカンカン帽のつばに、指をかけた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "背広で、ネクタイをつけ、カンカン帽をかぶった四十男が運転台にいる。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むこうから一台、ワイシャツの前にネクタイをたらし、カンカン帽の運転手に運転された電車が来た。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一台ポールの向きをかえるごとに、安全地帯の上をコツ、コツ、歩いている赧ら顔に新しいカンカン帽をかぶり、縞ズボンに白い襟がついた黒チョッキ、黒上衣といういでたちのずんぐりした四十男が、「××橋行きでございます。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だめだよ」「おい、おい、車掌忘れてっちゃ困るよ」　そして、ハハハハとカンカン帽を仰のけて笑った。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ズボンのポケットに一寸手をつっこんで、カンカン帽子をあみだにかぶり、妻楊枝をガムのように噛んでいる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷村さんは凉しい風に何気なく帽子を取りましたが、一夏中被つたカンカン帽子が黄に焼けて、一寸気恥ずかしい思いでありました。",
              "citation": {
                "source": "清修館挿話",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「隨分安つぽい家になつたんだなア……」　周次がカンカン帽を床へ置いて縁の籐椅子へ腰をかけると、くみ子も立つたなりそつと四圍を眺めてゐる。",
              "citation": {
                "source": "多摩川",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程、煙突の掃除棒みたいな頭に底の無いカンカン帽を冠っている。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "背広を着てカンカン帽をかぶっている田沢の眼鏡の隅がキラリと日光に反射しているところが、宏子が好きになれないその人物の性格を表現しているようで不快であった。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひどい暑気ですなあ、フー、そとはやり切れたもんじゃない」カンカン帽で風を入れながら、「ここも扇風機がたった一つじゃ無理だね、お偉がただけふかれて、こっちまでは当らん」　さっさと上座の方へ行って白塗の扇風機のスウィッチを入れた。",
              "citation": {
                "source": "築地河岸",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞお先になどと譲合つたり、風に吹飛ばされたカンカン帽をオットットなどと拾つてやる。",
              "citation": {
                "source": "総理大臣が貰つた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、なに」　練吉は、癖だと見えて、折角きちんとかぶつて出たカンカン帽をいきなり指で突き上げて阿弥陀にすると、いかにもだらりとした様子で歩き出した。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、同時に右の手が無意識に働いて、麦藁のカンカン帽が頭から離れると、二尾の鮎は帽子の底に、音を立てて跳ね続けた。",
              "citation": {
                "source": "想い出",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞には疎開荷物の中にカンカン帽があったとか、ピアノがあったとか、そんなことばかり書いてある。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかに出かけて帰って来たばかりなのか、或はこれから出かけるところなのかいつも外出の時に着る白の詰襟服にカンカン帽をかぶり、ステッキまでもっている。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして父がカンカン帽をかぶりなおしながら鶏舎の方に行くのを見おくっていたが、急に自分も立ち上っておも屋の方に行き、二階にかけあがるとぐったりと畳の上に寝ころんで、大きなため息をついた。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔちゃんのカンカン帽があって、それ一つだけがどこにも入らない。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばＴちゃんが洗面器のようなカンカン帽のつつみを見て笑いながら、又来年かついで思い出すさ、というようなことを云うと、小母さまはそれを狭く女のことを思い出すという風にとって何か仰云る。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいたずさえて駅を降り、畠中道を家路に急ぐとき、一陣の風来たりて、臼井君のカンカン帽を吹き飛ばす。",
              "citation": {
                "source": "Ｓの背中",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
