[
  {
    "uuid": "93c0ceeb-d9df-5697-aab3-a6e678af34ea",
    "entry": "斯くも",
    "reading": {
      "primary": "かくも",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
