    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fair",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "わー、この勧工場、昔ながらのお祭りの雰囲気で楽しいね！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "勧工場では、珍しい手作りの工芸品とか、お団子とか売ってるんだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "お祭りの最終日には、この勧工場で花火大会もあるらしいよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "勧工場って、色々な屋台が出たり、ちょっとしたアトラクションがあったりして、歩くだけでワクワクするよね！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "其処へ美術学校の方から車が二台｜幌をかけたのが出て来たがこれもそこへ止って何か云うている様子であったがやがてまた勧工場の方へ引いて行った。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上には旅人宿めいた室、勧工場然たる物産陳列所、郵便局、それから中央の奥宮社殿は、本殿、幣殿、拝殿の三棟に別れて、社務所、参籠所も附属している。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "新橋詰めの勧工場がそのころもあったらしい。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　百貨店の先祖　百貨店の前身は勧工場である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新橋や上野や芝の勧工場より以前には竜の口の勧工場というのがあって一度ぐらい両親につれられて行ったような茫とした記憶があるが、夢であったかもしれない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、その勧工場のもう一つ前の前身としては浅草の仲見世や奥山のようなものがあり、両国の橋のたもとがあり、そうして所々の縁日の露店があったのだという気がする。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "礼ちゃんが新橋の勧工場で大きな人形を強請って困らしたの、電車の中に泥酔者が居て衆人を苦しめたの、真蔵に向て細君が、所天は寒むがり坊だから大徳で上等｜飛切の舶来のシャツを買って来たの、下町へ出るとどうしても思ったよりか余計にお金を使うだの、それからそれと留度がない。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "深窓の美姫、紅閨の艶姐、綾羅錦繍の袂を揃えて、一種異様の勧工場、六六館の婦人慈善会は冬枯に時ならぬ梅桜桃李の花を咲かせて、暗香堂に馥郁たり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座にはうまい珈琲や菓子を食べさす家が出来、勧工場の階上に尖端的なキャヴァレイが出現したりした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなしくよるべなき無智……瓦斯の点いた勧工場のはいりくち、明るい硝子棚、紗の日被、夏は朝から悩ましいのに花が咲いた……あはれな石竹と釣鐘草。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "勧工場で買ったのだそうである。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「勧工場の店番」「姉さんは？",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十一年八月、渋柿）　　　　　　　＊　シヤトルの勧工場でいろいろのみやげ物を買ったついでに、草花の種を少しばかり求めた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "数分の後私たちはある大きい賑やかな勧工場へやって来たが、この場所はその男のよく知っているところらしく、ここでは、大ぜいの買手や売手の間を、何の目的もなく、あちこちと押しわけて歩いている時に、再び彼のもとの態度が現われたのであった。",
              "citation": {
                "source": "群集の人",
                "author": "THE MAN OF THE CROWD",
                "note": "青空文庫"
              }
            },
            {
              "text": "高く鳴る時計が十一時を打ち、そこにいる人々はぞろぞろと勧工場から出て行った。",
              "citation": {
                "source": "群集の人",
                "author": "THE MAN OF THE CROWD",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人一座の二人までは敷かせる座蒲団の模様が違って、違った小紋も、唐草も、いずれ勧工場ものにあらざるなく、杯洗と海苔とお銚子が乗って出るのも、牛屋のちゃぶ台の真中へ丸く木を填めてあろうという組織であるのに、お座料がまた必ずしもお安くない。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察署に着くや否や、先ず国事｜探偵より種々の質問を受けしが、その口振りによりて昼のほど公園に遊び帰途｜勧工場に立ち寄りて筆紙墨を買いたりし事まで既に残りのう探り尽されたるを知り、従ってわれらがなお安全と夢みたりしその前々日より大事は早くも破れ居たりしことを覚りぬ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "違棚には箱入の人形を大小二つ並べて、その下は七宝焼擬の一輪挿、蝋石の飾玉を水色縮緬の三重の褥に載せて、床柱なる水牛の角の懸花入は松に隼の勧工場｜蒔絵金々として、花を見ず。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、勧工場のある奥の方にあつた。",
              "citation": {
                "source": "紅葉山人訪問記",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が覚えてるだけでも真珠を七箇箝めた領留針、無線｜七宝の宝玉匣、仏蘭西製の象牙骨の扇子、何とかといふ名高い絵工の書いた十二ヶ月美人とかの帖、何れも其辺の勧工場で買へない高料い品を月に一遍位は必と持つて来た子。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処の角には勧工場と云つて何品でも売る所があるし、右へ行くと三丁目の電車、左へ行くと赤門の前――赤門といへば大学の事てすよ、それ、日本一の学校、名前位は聞いた事があるんでせうさ。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "角の勧工場と家の看板さへ知つてりや。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "勧工場は、小さいながらも盛岡にもある。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座の通り、新橋のステイシヨン、勧工場にも幾度か入つた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉乗や、勧工場の大きな花瓶が、チラリ、チラリと心を掠める。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんならね、晩に勧工場で買ってらッしゃいな。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私は聞直した、――勧工場というものは其時分まだ国には無かったから。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小川町の勧工場で。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
