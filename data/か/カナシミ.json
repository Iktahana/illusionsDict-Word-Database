        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "故郷に残してきた古い友人たちへの悲しみ（＝深い情愛）を、彼は生涯忘れることはなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "弱き者への悲しみ（＝深い同情と情愛）が、彼女を社会活動へと駆り立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "失われた文化への悲しみ（＝喪失感からくる郷愁と愛着）が、彼の研究の原動力だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
