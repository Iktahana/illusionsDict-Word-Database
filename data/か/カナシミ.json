    "definitions": [
      {
        "index": 1,
        "gloss": "sadness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "訃報を聞いたとき、胸にこみ上げてきたのは深い悲しみだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の目に映る深い悲しみは、誰もがその重さを感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "戦争のニュースを見るたびに、言葉にできない悲しみに襲われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は、愛犬を亡くした悲しみを乗り越えようと必死だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこに此の世の喜びの話や悲しみの話は、彼のためには大きすぎる声で語られ、彼の瞳はうるみ、語り手は去つてゆく。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが嘆きわが悲しみよ、かうべを昂げよ。",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その志明かなれば冬の夜を、われは嘆かず、人々の憔燥のみの悲しみや憧れに引廻される女等の鼻唄を、我が瑣細なる罰と感じそが、わが皮膚を刺すにまかす。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "降りくる悲しみを少しもうけとめないで、安易で架空な有頂天を幸福と感じ做し自分を売る店を探して走り廻るとは、なんと悲しく悲しいことだ……３神よ私をお憐み下さい！",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は弱いので、　悲しみに出遇ふごとに自分が支へきれずに、　生活を言葉に換へてしまひます。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "）あの偉大なるトルストイを始めとして、世の多くの貴族と生れながらのエゴイストとが、悩み苦しみて求めるものは、実にこの「生えざる」苗を求めんとして嘆き訴ふる悲しみの声に外ならない。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして私と彼とは、互にその欠陥せる病癖を悲しみ、互にその夢想せるしかも正反対の性情の美しさを交換した。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は田舎の程度の低い学校を出たばかりで、充分の高等教育を受けなかったので、常に自分の無学を悲しみ、良人に対して満足な奉仕ができないことを嘆き詫びた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子戦死の報を聞くや、つと立って台所に行き、しゃっしゃっと米をといだという母親のぶざまと共に、この男の悲しみの顛倒した表現をも、苦笑してゆるしてもらいたい。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は掛合い万歳は好きでない」「君は自分の手塩にかけた作品を市場にさらしたあとの突き刺されるような悲しみを知らないようだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども僕は着飾った苺の悲しみを知っている。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにその悲しみ方に色々ある。",
              "citation": {
                "source": "小林秀雄小論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しみが萎ませたよるべなき女よ！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般社会人の悲しみは、常にそれ自ら僕等の心に反映してゐる悲しみなのだ。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飄々として唸りながら、無限に高く、穹窿の上で悲しみながら、いつも一つの遠い追憶が漂っている！",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも前と同じく、はかなく寂しい悲しみを、心の影でじっと凝視しているような句境である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした彼の郷愁は、遂に無限の時間を越えて凧きのふの空の有りどころ　と、悲しみ極まり歌い尽さねばならなかった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対に彼は、人間性の普遍な悲しみを体験して、本質に宗教的なモラルを持ったところの、真のヒューマニストの詩人であった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの小さな家の中で、手毎に瓜の皮をむいてる人々は、一人一人に自己の悲しみを持ってるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの悲しみこそ、無限の時空の中に生きて、有限の果敢ない生活をするところの、孤独な寂しい人間共の悲しみである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ寄り集って手を握り、互に人の悲しみを感じながら、憐れに沈黙する外はないのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの隣人の悲しみこそ、それ自ら人類一般の悲しみであり、併せてまた芭蕉自身の悲哀なのだ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉もまた仏陀と共に、隣人の悲しみを我身に悲しみ、友人の死を宇宙に絶叫して悲しみ嘆いた。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しだいに四方を眺むれば、遠き地平を超え、黒き眞冬を超えて叫びしんりつす、ああ聖地靈感の狼ら、かなしみ切齒なし、にくしんを研ぎてもとむるものを、息絶えんとしてかつはしる。",
              "citation": {
                "source": "巡禮紀行",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人たちはしづかに席に戻り、二人も胸いっぱいのかなしみに似た新らしい気持ちを、何気なくちがった語で、そっと談し合ったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞいちばんのさいはひに至るためにいろいろのかなしみもみんなおぼしめしです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "限りなき親しさと驚きの眼を以て私は君達のよろこびとかなしみとを理会する。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心の「かなしみ」「よろこび」「さびしみ」「おそれ」その他言葉や文章では言ひ現はしがたい複雑した特種の感情を、私は自分の詩のリズムによつて表現する。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我のかなしみは彼のかなしみではない。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばくてりやが生活するところには、病人の皮膚をすかすやうに、べにいろの光線がうすくさしこんで、その部分だけほんのりとしてみえ、じつに、じつに、かなしみたへがたく見える。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
