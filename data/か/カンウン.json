    }
  },
  {
    "uuid": "f870f96d-1cd6-5d6c-a0a7-4f4aca330420",
    "entry": "間雲",
    "reading": {
      "primary": "かんうん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gently floating clouds",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "青い空に白い間雲が、絵画のように浮かんでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "高原の牧場で、間雲がゆったりと流れるのを見上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "午後の日差しの中、間雲が静かに形を変えていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "間雲の下、小鳥たちのさえずりがのどかに響く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あわあわしい白ら雲が空ら一面に棚引くかと思うと、フトまたあちこち瞬く間雲切れがして、むりに押し分けたような雲間から澄みて怜悧し気にみえる人の眼のごとくに朗らかに晴れた蒼空がのぞかれた。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわあわしい白ら雲が空ら一面に棚引くかと思うと、フトまたあちこち瞬く間雲切れがして、むりに押し分けたような雲間から澄みて怜悧し気に見える人の眼のごとくに朗かに晴れた蒼空がのぞかれた。",
              "citation": {
                "source": "あいびき",
                "author": "イワン・ツルゲーネフ　Ivan Turgenev",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち奈良朝に於て種芸、種智、悲田、施療の諸院を開きたる例に則り、諸種の新しき施設を先づわが京都府より試みんとし、府の大参事植村正直氏を初め、友人金閣寺住職伊藤貫宗、銀閣寺住職佐佐間雲巖諸氏に議りて、その協賛を得つ。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はまた明治四年より病院の創立に志し、伊藤貫宗、稻葉宙方、佐佐間雲巖諸氏と共に、京都府下に於る各宗の寺院を勧誘して出資せしめ、明治六年十一月一日に到りて英国の医師を主任とし開業式を行へり。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、彼の恐怖心は、瞬間雲散霧消した。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩間雲意｜黯淡タリ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして三年の間雲の如く變幻浮動する心の姿を眺め暮した。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間雲はふたりの頭の上を流れていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "今回は妙な連中と数週間雲隠れしておる。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
