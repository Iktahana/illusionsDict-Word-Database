[
  {
    "uuid": "e9e31e24-e2d1-5005-acc2-7bb57d45e874",
    "entry": "上の句",
    "reading": {
      "primary": "かみのく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
