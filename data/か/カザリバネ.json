        "examples": {
          "standard": [
            {
              "text": "その帽子には、黒い飾り羽が上品にあしらわれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古代の戦士が被る兜には、威厳を示すための大きな飾り羽が付いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "民族衣装の儀式で、長老が鮮やかな飾り羽をつけた冠を被った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "鳥の飾り羽を使った工芸品は、独特の風合いを持っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ほんたうに氷が飾り羽根のやうですわ。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いてなほ、うつくしき飾り羽や、たのめなき陽や。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "建築上の装飾の大部分は文字通り空虚なものであり、九月の嵐は借り物の飾り羽毛のようにそれを吹きとばし、その実質は何の損害も受けずにのこるであろう。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
