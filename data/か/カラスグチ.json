        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「今の製図はCADが主流だけど、昔は烏口を使って一本ずつ丁寧に線を引いていたんだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "烏口にインクを差し込み、定規を汚さないように慎重に直線を引く作業には熟練の技が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おっと、烏口のネジを締めすぎたかな。線が細くなりすぎて掠れてしまったよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "烏口の先端を砥石で研ぎ、自分好みの線の太さが出るように調整するのが彼のこだわりだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「飛田の手だと思うなッ」　ふくら脛が重たくなって、両肱をもたせた製図板に重心をかけて小休みしていたサイは、びくっとした顔になって、烏口を持ち直した。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏口だの定規だのが、ばらばらにお義理のようにとりあげられた。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、まだすっかり落着けないらしくどこか気落ちのしたような風で烏口をいじりはじめた。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイにしろ、烏口へ墨汁のふくませかたから教えられた飛田と離れることは、何か普通の気持でないのであった。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
