        "examples": {
          "standard": [
            {
              "text": "週末は湖でカヤックを漕ぎ、水面に近い視点から季節の移ろいを感じるのが最高の贅沢だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「見て！ あそこの岩場の影に、色鮮やかなカヤックが数台並んで停まっているよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "初めてのカヤック体験だったが、パドルの使い方のコツを掴むと、意外なほどスムーズに水面を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "穏やかな瀬戸内海をカヤックで巡り、無人の浜辺で手作りのランチを楽しむツアーに参加した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それならわたしは、そこをあんたのカヤックとあんたの矢で飾ってあげるよ。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
