[
  {
    "uuid": "9c60c077-17f7-56b0-b03c-5c610c84fa4b",
    "entry": "確実性",
    "reading": {
      "primary": "かくじつせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
