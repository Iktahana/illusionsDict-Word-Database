    },
    "definitions": [
      {
        "index": 1,
        "gloss": "certainty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この投資には高い確実性があると言えるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の証言には、確実性があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "データの確実性を高めるため、二重チェックを行う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "計画の確実性が問われる場面だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "たとえ遊星運動の説明に関する従来の困難がかなりまで除却され、日蝕観測の結果がかなりまで彼の説に有利であっても、それはこの理論の確実性を増しこそすれ、厳密な意味でその絶対唯一性を決定するに充分なものであるとはにわかには信じられない。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "首を……」　彼はどうにかして自己の陳述に確実性を与へたいと思つた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその話題によほどの確実性と普遍性がなければ、多くはある一角、または半数、三分の一くらゐなところで、いつも立ち消えになつてしまふ。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗右衛門のこの噂は、いつ、どの辺から起つたのか、どれだけの時間を経て屋敷全体に拡がつたものか判らないが、兎に角今までにない確実性と普遍性とを持つてゐる。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこの大きさや体つきの点のほかに、その腕に生前のマリーに見ていた特殊な毛の生え方を見つけたなら、彼のその考えが強められたのは当りまえのことで、その確実性は毛の特殊性、あるいは並はずれな点に比例して増したにちがいない。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、最も基本的であるがゆえに、どんな環境でも、先々長く操作できる確実性がある。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそこの本命に信頼できないとすればまた別問題だが、その確実性を見極めた場合に於いてはたとえその日は勝っていても負けていても、敢然その本命を狙うがよい。",
              "citation": {
                "source": "競馬の一日に就いて",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学は、生物体に於ても無生物体に於ても、一切の現象の存在条件は同じであることを証明し、それによりて、生理学は徐々に、化学や物理学のやうな確実性を帯びて来た。",
              "citation": {
                "source": "エミイル・ゾラの文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと描写に確実性を与えることが急務であろう。",
              "citation": {
                "source": "探偵小説壇の諸傾向",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新胎」について技術的な面で感じることは、現実の錯雑の再現とその全体の確実性の強調として、作品の上で、科学的用語や保険会社の死亡調査報告書、くびくくりの説明図などに場所を与えすぎることは、寧ろ却って読者の実感を白けさせる危険があるのではないかということである。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのたびに当選の確実性がとりあげられ、体がわるければねていてもいいし、活動もほどほどでよいからと言われますが、国会およびすべての部署で働いている党員の経験からそのようなことが不可能であることは十分わかってきていると思います。",
              "citation": {
                "source": "文学について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのいわれた「確実性」が「真実性」となりうるまでは自分のものとはいえませんね。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "愈々共産主義の非確実性を露出しはじめたぞ。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "リーダーズ・ダイジェストをはじめ、日本人が日本で出す新聞や雑誌でも、アメリカの世論統計を引用する場合には、しばしばギャラップの世論調査をつかい、ギャラップの調査の科学性と確実性とが語られた。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして発見され闡明された意識は、デカルトに至って、知識、殊に数学、力学等の認識の確実性の基礎づけに対する関心によって著しい変容に出会った。",
              "citation": {
                "source": "マルクス主義と唯物論",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、どの方法も確実性と絶対不発見性とを具有しているものはなかった。",
              "citation": {
                "source": "蜘蛛",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見せる」ということは作品に確実性を与える。",
              "citation": {
                "source": "ヒューメーンということに就て",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "超現実主義は、普通に吾々が現実と看做してるもののも一つ奥の現実を信ずるもので、夢の世界の確実性と思想の独自な働きとを信ずるのである。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「要するにこれは、犯罪を転嫁しようという行為なのですが、飛去来器といい花火といい、十分理学的に計算出来る性質のものですから、この犯行には相当の確実性があります。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○彼は自己の生存の外的危険から最高の内的確実性を獲得し、苦悩は彼にとって所得となる、○彼の芸術における悪魔的な価値変革力、○運命に対する人間の勝利は、内面的魔術による外的存在の価値変革に外ならないという点から見れば　彼の生活は芸術的には悲劇であり　道徳的には並ぶものなき業績である。",
              "citation": {
                "source": "ツワイク「三人の巨匠」",
                "author": "――ドストイェフスキーの部（偉大な統一の破壊者、永遠の分裂者としての）――",
                "note": "青空文庫"
              }
            },
            {
              "text": "希望の確実性はイマジネーションの確実性と同じ性質のものである。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生問題の解決の鍵は確実性の新しい基準を発見することにあるように思われる。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "此伝へには、まさか幕毎に、さうしたことがあるとは言はないが、どの幕に限るとも言はない点が、確実性を疑はせる。",
              "citation": {
                "source": "芸能民習",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりある歴史的確実性がないと言ふことに当りませう。",
              "citation": {
                "source": "日本芸能の特殊性",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼の熱心と、彼の張っている監視網の確実性によるものであろう。",
              "citation": {
                "source": "すり替え怪画",
                "author": "烏啼天駆シリーズ・５",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある事象に遭うて、忽、類似の事象の記憶を喚び起し、一貫した論理を直観して、さて後、その確実性を証するだけの資料を陳ねて、学問的体裁を整へる、と言つた方式によらない学者が、ないであらうか。",
              "citation": {
                "source": "古代研究　追ひ書き",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二石上乙麻呂の事件なども、逆に或は叙事詩から出て「石上布留の命」と言ふ文句が世間で乙麻呂の事と伝へられた為に、歴史として確実性を持つ様になつたとも思はれぬではない。",
              "citation": {
                "source": "相聞の発達",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
