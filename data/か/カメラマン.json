        "examples": {
          "standard": [
            {
              "text": "テレビ番組の収録中、カメラマンが指示に従って動き回っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スポーツ中継では、ボールの動きを追いかけるカメラマンの技術が光る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画のメイキング映像を見ると、カメラマンの過酷な撮影現場がよくわかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
