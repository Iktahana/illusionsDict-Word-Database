    "definitions": [
      {
        "index": 1,
        "gloss": "all parts",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "定期メンテナンスのため、機械の各部を入念にチェックした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "建物の安全性を確保するため、設計図の各部に変更がないか最終確認が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "社長からの指示が各部に伝達され、全社的にプロジェクトが始動した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "精密機器のため、輸送中の衝撃で各部に異常がないか検査する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "近頃｜和蘭グロニンゲンのカプタイン博士等は、従来多年の観測の結果を綜合して精細な研究を遂げた末に、天体に散布せる諸恒星は自ずから二派の流れに分れている事を発見した、すなわち天体各部の星の運動が目指す方向を反対に延長して見るとほぼ定まった二つの星座に集注する。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはつまり主として機関の上下運動の反動で船体各部の振動を起すためであるから、機関の各部分の重量をうまく取り、反動のないようにすれば防がれる。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような時代においてもしある科学の全般にわたって間口も広く奥行も深く該博深遠な知識をもった学者があって、それが学習者を指導し各部分の専門的研究者や応用家の相談相手になって行くとすれば実にこの上もない事である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり各部門においては現在既知の知識の終点を究め、同時に未来の進路に対して適当の指針を与え得るものが先ず理想的の権威と称すべきものではあるまいか。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲の各部をリードしている楽器を時々に抽出してその方に吾々の注意を向けてくれる。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは各部分が秀れた描寫であるに拘らず、それを緊めくゝるものが稀薄なせいである。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その怪物の透明な肢体の各部がいろいろ複雑微妙な運動をしている。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "各部署の戦闘のはげしさは、負傷者の数と、思い切り無遠慮なその負傷ぶりによって完全に表現されていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう場合に寄り集まった材料が互いに別々な畑から寄せ集められたものである以上各部分の間にはなんらの必然的な連絡はなく、従ってそれらの堆積はやはり単なる素材の堆積であり団塊であるというだけで、結局はその学者なる陶工の旋盤の上に載せられた粘土の団塊とたいした変わりはないであろう。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒谷とか金閣寺とかいう所へ行くと、案内の小僧さんが建築の各部分の什物の品々の来歴などを一々説明してくれる。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の身体各部が最初の格好な物さしである。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "出発点における主題に含まれているものを順次にその構成要素に解きほごして行ってその各部の具体的設計を完成する過程である。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このようにしてできた設計が完成すれば次には、これらの各部分が工人の手によって実物に作り上げられなければならない。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一通り自分の飛行船の各部を詳細に検査して、見送りの人々に一礼してその中に這入って、静かに号砲の鳴るのを待ち構えている。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "実習地とでもいふのか、津軽の各部落から選ばれた模範農村青年たちの作つた畑や果樹園、水田などが、それらの建築物の背後に、実に美しく展開してゐた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに戦う段になると、それらの各部分は歓喜のあまり、花にむらがる夏の蜂のようにいっせいにワァーッと歓声を挙げるのだ。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "外に出て一応各部署を点検し終わると、ふたたび幕営に入り、雷のごとき鼾声を立てて熟睡した。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、私といふ人間の肉體を組立ててゐる各部分に注意が行き亙るにつれ、次第に、私といふ人間の所在が判らなくなつて來た。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし又この鼻の表現を自由に支配して他の各部の表現と一致共鳴させる事が出来たならば、二重、三重、否、数重の意味を同時に表現することが出来る。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "王の顔面の表現機関は王の鼻の左右大臣であり、その他の全身各部の表現作用は、その召使であり奴隷でありました。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して動揺してはならぬ」という通牒を各部隊に出すように手筈をしていたのですが……。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵も今川勢に比べると比べものにならない位に小勢ではあるが、各部将以下死を決して少しも恐るる色がなかった。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "各部隊共兵三千、総軍一万五千である。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "各部隊の長は皆勝頼の一門であるが、揃って孰れも勝れた大将でもなく、この戦い敗れた後は命全うして信州へ逃げ帰った。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "力と頼む各部隊の驍将等が悉く討死して指揮を仰ぐに由ない上に、総大将の退陣と聞いては、さしもの武田勢も乱軍である。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "征韓偉略　水戸彰考館総裁川口｜長孺の著で、秀吉の譜、宗氏家記、毛利家記、黒田記略、清正記等各部将の家記を始め、朝鮮の懲※録、明の明史までも参照して簡単ではあるが信頼すべきもの。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（流行らぬ寄席か化物屋敷じゃあるまいし……）そう心の中で呟いて、豹一は北寮、中寮、南寮の順に各部屋のデコレーションを見て廻った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直に実物のとおりの各部分の色を、それらの各部分に相当する「各部分」に塗ったのでは、できあがった結果の「全体」はさっぱり実物らしくない。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより以来電車はとかくぶっそうな感じがしてならないのだが、甲武線は一筋だと、かねて聞いているから安心して乗った。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめのうちは、構造や性能などがあらまし分かれば、あとは勇敢無比を世界に誇るわが海軍の爆撃機や軍艦でもって、とにかくぶっ潰せるものと思っていた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
