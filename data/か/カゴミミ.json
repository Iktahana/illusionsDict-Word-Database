        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "さっき言ったこと、もう忘れちゃったの？君は本当に籠耳だね！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "大事な約束をすっぽかした。最近、どうも籠耳で困ってるんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あれ、どこに置いたっけ？」って、毎日聞いている気がする。もう籠耳だよ、まったく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで問ふ者は籠耳になつて仕舞つて、教へは聞いたには違ひ無いが何らの益をも得ずに終るといふ事も少く無い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして又所謂「籠耳」で終る傾向が有りは仕まいかと危まれるけれども、若し左樣で有つたならば、それは聽者にも談者にも、着手の處といふことが強く印記されて居なかつた爲として、省みなければならないので、教其の物に就て是非をす可きではないのであらう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで問う者は籠耳（耳を通過するだけ）になってしまって、教は聞いたには違いないが何等の益も得ずに終るという事も少なくない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして又いわゆる「籠耳」で終る傾向になるのではないかと心配である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
