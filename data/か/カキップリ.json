        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の論文は、独特の書きっぷりで読み手を惹きつける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その作家の書きっぷりは、若者に絶大な人気がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の手紙と比べると、社長の書きっぷりがずいぶん変わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "面接で提出した小論文の書きっぷりが評価されたらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "こんな熱に浮かされたような書きっぷりでいいものだろうか？",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英雄の最後でも画くようなそういう書きっぷりにはいささか辟易したが、とにかく三造はすぐに洗足の伯父の家へ行った。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この字の書きっぷりじゃ、きっと大べっぴんですぜ」「うるさいよ」「え……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれをを探せというような書きっぷりであった。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、きっと、もっと簡明な書きっぷりで書くことを。",
              "citation": {
                "source": "若者の言葉（『新しきシベリアを横切る』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
