[
  {
    "uuid": "f52cdc58-acd7-5dc2-b54f-01945571b3a3",
    "entry": "烏瓜",
    "reading": {
      "primary": "からすうり",
      "alternatives": [
        "カラスウリ"
      ],
      "is_heteronym": false
    },
    "grammar": {
