        "examples": {
          "standard": [
            {
              "text": "特注品の加工費は、一般的な量産品よりも大幅に高くなる傾向がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この金属部品の加工費は、複雑な形状のため見積もりが高くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "衣料品の製造では、生地代の他に縫製や染色の加工費が発生する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、古い木材を新しい家具にリメイクするための加工費を問い合わせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "――何しろ、高が流しの門付け修業には殆んど資本はかかっていないが、雛妓にまで就業させるには原料の費用も加工費もかかっている。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "話の筋は極くたわいもないのだが、それでもよく考えてみると、何だかこうひどく妙な気がするんでね。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何だかこうひどく侮辱された気持でした。",
              "citation": {
                "source": "消えた霊媒女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
