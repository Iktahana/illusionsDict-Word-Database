        "examples": {
          "standard": [
            {
              "text": "その馬は美しい川原毛の毛並みをしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "競馬のレースで、川原毛の牝馬が注目を集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は川原毛の馬のブリーダーとして有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "当時は特に留意せなんだが、ほどなく老人死した後考うるに、駱和名川原毛黒い髦の白馬だというから、不毛に当らず。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "川原は砂礫多く草少なき故、老人の説通りわずかに春草ある処を馬の川原毛から名を移して称うるのかと思えど、死人に質し得ず。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬は三頭でしてね、『一頭は三年まえに買っただし、川原毛のやつは、やはり川原毛のやつと交換えたのでがす。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
