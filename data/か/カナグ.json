          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アンティークの棚に合う真鍮製の金具を探しに、金物屋まで足を運んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "カバンの肩紐の金具が馬鹿になってしまい、歩くたびに勝手に外れてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この額縁、かなり重いから、壁側の受け金具もしっかりしたやつを選んでね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "窓枠の固定金具が錆び付いて、力いっぱい引かないと窓が開かなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この御手洗の屋根の四本の柱の根元を見ると、土台のコンクリートから鉄金棒が突き出ていて、それが木の根の柱の中軸に掘込んだ穴にはまるようになっており、柱の根元を横に穿った穴にボルトを差込むとそれが土台の金具を貫通して、それで柱の浮上がるのを止めるという仕掛になっていたものらしい。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人用の烟管の吸口と雁首に附けた金具に、銀と赤銅とを用いて、銀白色の帯青灰色との横縞を見せているのがある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めは二つの爪あるいは牙の根元を糸や金具で縛ったものを用いていたが、後には一片の彫刻物で代用するようになり、後には真中の継目の痕も略されて新月形になってしまったという事がわかった。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "埃のなかで鞍の金具だけが光つてゐる。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本で製造して売っている金具付きのステッキはみんな少し使っていると金具がもげたり、はじけたり、へこんだりしてだめである。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火災後、橋々の上には、箪笥やカバンの金具が一面にちらばっていたのでも、おおよそ想像が出来る。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑桁の金具がキシキシ鳴った。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、そのうしろから、ふいに送話器の喇叭状の金具をめがけて、急激に、ドシンと突きつけられた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、カンテラと、金の金具のついた縁なしの眼鏡を岩の断面にすりつけた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵のうち人びとが掴まされたビラの類が不思議に街の一と所に吹き溜められていたり、吐いた痰がすぐに凍り、落ちた下駄の金具にまぎれてしまったりする夜更けを、彼は結局は家へ帰らねばならないのだった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰色の壁と純白な窓掛けとで囲まれたきりで、色彩といえばただ鈍い紅殻塗りの戸棚と、寝台の頭部に光る真鍮の金具のほかには何もない、陰鬱に冷たい病室が急にあたたかくにぎやかになった。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とぴたりと帯に手を当てると、帯しめの金金具が、指の中でパチリと鳴る。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾子はぞろりと外出の装、繻珍の丸帯を今｜〆めて、姿見に向いたるが、帯留の黄金金具をぱちんと懸けつつ振返りて、「おや、照子｜様。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この金具のみにても、貴重なるものは百金を要す、平打なるあり、丸打なるあり、ゴム入あり、菖蒲織あり、くはしくは流行の部に就いて見るべし。",
              "citation": {
                "source": "当世女装一斑",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「巌丈な金具じゃええ。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は必死になって※いて漸くその恐しい指を払い除けることが出来たが、今度はピストルの金具の鳴る音を聞き、そして彼の頭を真直ぐに狙っているギラギラ磨かれた銃口とずんぐりとした汚れた男の顔と向き合った。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかとけいの飾金具、首にかけた金鎖や、ダイヤモンドのゆびわなど、すでにごしょうちのとおりですから申しません。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の中の家具に塗ってあるニスが濡れ色になって来て、銀色の金具は冷たく曇った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "光蓮寺の山門をすこし小さくしたような、さびた金具などのついた古めかしい門である。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれが真珠、いずれが豚、つくづく主客てんとうして、今は、やけくそ、お嫁入り当時の髪飾り、かの白痴にちかき情人の写真しのばせ在りしロケットさえも、バンドの金具のはて迄。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほう」　それは見る眼にも眩しい金と銀の金具をちりばめた轎であった。",
              "citation": {
                "source": "棄轎",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その農夫が怪しい轎を見た日のこと、それから数分と経たない時刻に、その村からよっぽど離れた村の農夫が、これも畑から帰っていると、路傍に金と銀の金具のある轎があった。",
              "citation": {
                "source": "棄轎",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、それが近寄つてくるにつれて、金屬と板との擦れ合ふやうな鈍音が聞えるのは、双の靴底に重い鐵の金具が打ち着けてあつたからに違ひない。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒絹の手袋した右手に金金具、茶なめし皮のオペラパツクを、左手に派手な透模樣のパラソルを、そして、金紗づくめのけばけばしい着附、束髪に厚化粧、三十三四と見える年頃が、停車中の車内のむしむした、變にダルな空氣をぱつと引き立たせるに十分だつた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "箪笥、長持、挟箱、金高蒔絵、銀金具。",
              "citation": {
                "source": "雛がたり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊枝　ぎざぎざ針を植ゑたる金具もて、われとわが胸を十字に掻い傷つけ……千代　はれ、まあ。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士はもう森林や砂礫をかなぐり捨てて熔岩の滑らかな岩盤をむきだしにしている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "とつおいつ思いあぐねるうち、いよいよ無力の孩児としての感じを自分に深めて来た老翁は、いまは何もかもかなぐり捨て、ひたすら娘に縋り付き度くなった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画の頂点はヒロインが舞台で衣裳をかなぐり捨てブロンドのかつらを叩きつけて煩わしい虚偽の世界から自由な真実の天地に躍り出す場面であって、その前のすべてのストーリーはこの頂点へ導くための設計であるように見える。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風の又三郎など、怖っかなぐなぃ。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
