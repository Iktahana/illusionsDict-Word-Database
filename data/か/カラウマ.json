    "definitions": [
      {
        "index": 1,
        "gloss": "unburdened horse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅の準備を終え、馬は何も積まれずに待っている。まるで空馬のようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は身軽に旅立った。まるで空馬のように、一切の荷物を背負っていない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの子は荷物を持たなくていいんだね、空馬で楽そうだ」と、村人が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この道は急勾配だから、空馬にして馬の負担を減らそう」と、案内人が提案した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "空馬車、　空馬車、　空馬車。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんて高言しながら――」「彼の大尽風がマメイドまで保てば、まことにお目出度い話だが――もう間もなく、空馬車に載つかつて、ぼんやり木兎のやうな眼をして帰つて来るだらうよ。",
              "citation": {
                "source": "馬車の歌",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "などと呟きながら――」「親父は何うでも好いから、あの空馬車が恋しいよ。",
              "citation": {
                "source": "馬車の歌",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "後より芝山行の空馬車來りけるが、御者車を停めて、乘らむことを勸む。",
              "citation": {
                "source": "三里塚の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗ればよいのに乗りもしないで、二頭の空馬をうしろに随えながら、ゆらりゆらりと大股に歩き出しました。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝本の馬車の馭者台には百合子が、そして先へ立つた空馬車には八重が、互に何やら呼応し合ひながら、手綱を振つて駆け出した。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日ア歸り荷だで、行ぐ時ア空馬車｜曳つぱつて行ぐのだもの。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日ア帰り荷だで、行ぐ時ア空馬車｜曳つぱつて行ぐのだもの。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪子も、すつかり当惑してしまつて、説明の仕様もなくなつたので、そのまゝ吾家を目指して慌てゝ駆け出すと、ドリアンは正しく娘の影の如く従順に、空馬車の輪をガラ／＼と音立てゝ、追つて行つた。",
              "citation": {
                "source": "ダイアナの馬",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に帰る沢山の空馬力、自転車、労働者が照明の不充分な塵っぽい堤を陸続、互に先を越そうとしながらせっかちに通る。",
              "citation": {
                "source": "九月の或る日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来の人は空馬車が走ると思っていたといいます。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "度が過ぎた、羽目をはずしすぎたと気づくと、彼女は悲しくなって、ああ私はやっぱりどたどたした肥っちょでがさつな酔払い女だと思いながら、最初に眼についた空馬車にアチミアーノフと一緒に乗り込んだ。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟と別れた甚三が、空馬を曳いて帰りかけた時、「馬子！",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場櫻間中庸馬場は四角だ　四角に歩め足並そろへて　ホイ　トロツト　トロツト　　　　　　　　青い空馬場は四角だ　四角に馳けろたてがみユサユサ　ホイ　ギヤロツプ　ギヤロツプ　　　　　　　　雲がとぶ",
              "citation": {
                "source": "馬場",
                "author": "櫻間中庸",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ帰りに荷物を沢山積んで来るので往きには空馬が沢山あるから」というような話で、よい都合に話が成り立ちそうですからいろいろ頼んで居りますと、その友達である雲南省の商人がそこへ出て来たです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がその人から麝香を買うたり、あるいはまた宝鹿の血角を買うた事もあり薬を拵えた事もあって、私が取引上真実を守ることをよく承知して居るからして、早速引受けてくれたけれども、その人の言うには「私の所には空馬がない。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへちょうど通りかかったのは、空馬を引いた、背に男の子を負うた女。",
              "citation": {
                "source": "大菩薩峠",
                "author": "市中騒動の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "清七と二人、また、空馬車に乗って、帰った。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラガラと空馬車をひいて、行ってしまった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ともあれ、駒を、おあずかりいたしましょう」　と、梨丸は、空馬の手綱を曳きながら、主人のあとに従って、そこの土塀門まで尾いて行った。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "心得顔に、「はっ」　と、藤三はすぐ空馬の口を曳いて、池の汀へ馬の脚を沈めた。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「忠信、継信、空馬を二頭これへ曳いて来い」五「はっ。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空樽を積んで街道を行く空馬車を先に見かけて、「馬車屋のおッさん、どこへ行くのかね」　と、湯隆が追ッついて呼びかけた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒繋ぎで、空馬が跳ねている。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく、虎之助の槍持と、空馬を曳いた郎党が追いついて来た。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、小冠者も、空馬を拾った。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の下からうまくとけて出て青い麦です。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いくらやっても俳句のできない性質の人があるし、始めからうまい人もある。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は今までの十行を一行に書くという工夫からうまれたスタイルの前に、書かねばならぬことも捨てて来た。",
              "citation": {
                "source": "文学的饒舌",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "美代子と揉み合ったために落としたものか、或はその折解けかかっていたのが小野に絡みつかれている間に、あんな薄いヘラヘラしたものですからうまい工合に彼の外套のふところか何かへ紛れ込んだものか、どっちともはっきりしたことは思い当りません。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
