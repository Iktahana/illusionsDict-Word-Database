        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "公園の隅で拍子木の音が鳴り響くと、近所の子供たちが紙芝居の周りに集まってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幼稚園の先生が感情たっぷりに紙芝居を読んでくれるのを、園児たちは目を輝かせて見つめている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地域のボランティア活動で、地元の民話を題材にした手作りの紙芝居を上演した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「はい、ここで場面が変わるよ」と言って、おじいさんは紙芝居の舞台からゆっくりと絵を引き抜いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "世にも美しい天工の紙芝居である。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙芝居にしても悪くはなさそうである。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手な紙芝居みたいになるかも知れませんが、笑わずに、まあ聞き給え。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "トーキーが出来てから、弁士では食って行けず、暫らく紙芝居などやっていたが、それもすたれて、貧乏たらしくごろごろしていたが、ある日忽然と河童路地から姿を消したのだった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "とぼとぼ河堀口へ帰って行く道、紙芝居屋が、自転車の前に子供を集めているのを見ると、ふと立ち停って、ぼんやり聴いていたくらい、その日の私は途方に暮れていました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日から私は紙芝居屋になりました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから大今里のトキワ会という紙芝居協会へ三円払って絵と道具を借りた。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その年も押しつまったある夜、紙芝居をすませて帰ってきますと、今里の青年会館の前に禁酒宣伝の演説会の立看板が立っていたので、どんなことを喋るのか、喋り方を見てやろうと思いながら、はいって聴きました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ東成禁酒会の宣伝隊長は谷口という顔の四角い人でしたが、私は谷口さんに頼まれて時々演説会場で禁酒宣伝の紙芝居を実演したり、東成禁酒会附属少年禁酒会長という肩書をもらって、町の子供を相手に禁酒宣伝や貯金宣伝の紙芝居を見せたりしました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともそれまでも、紙芝居を持って大阪の町々をまわりながら、それとなく行方を探していたことはいましたが、見つからない。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "命の恩人を探す人生紙芝居」という変な見出しで書きたてましたので、私はこれは困ったことになったわいと恥しい思いをしていました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「既報“人生紙芝居”の相手役秋山八郎君の居所が奇しくも本紙記事が機縁となって判明した。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりから町の子供相手の紙芝居に出かける支度中の長藤君は古谷氏の話を聞いて狂喜しさっそくこの旨を既報“人生紙芝居”のワキ役、済生会大阪府支部主事田所勝弥氏（四八）、東成禁酒会宣伝隊長谷口直太郎氏（三八）に報告、一同打ち揃って前記古谷氏宅に秋山君を訪れ、ここに四年ぶりの対面が行われた。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、私は相変らず大阪に残って紙芝居。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人手をたずさえて、人生紙芝居の第一歩を踏みだしましょうと、まじめなのか、からかっているのか、お話にならない。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙芝居を持って町を歩くと、「人生紙芝居」という囁きが耳にはいりました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞は私の紙芝居の宣伝をしてくれたわけですが、しかし、そのためかえって私は紙芝居をよしてしまった。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "貯金の宣伝は紙芝居でずいぶんやったし、それに私の経歴が経歴ですから、われながら苦笑するくらいの適任だと言えるわけですが、しかしたった一つ私の悪い癖は、生れつき言葉がぞんざいで、敬語というものが巧く使えない。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ書かない作品中の色々な場面が、紙芝居の絵のように次から次へと現れて来て仕方がない。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時の最も親しい遊道具だった「一｜片なら無彩色・二｜片なら色つき」の紙芝居（それを玩具屋から買って来て家で組立て「アラディン」や「ロビン・フッド」や「三本指のジャック」を自ら演出して遊ぶのだが）の影響であろうか、スティヴンスンの創作は何時でも一つ一つの情景の想起から始まる。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次々に何十という紙芝居の舞台面が、其等を繋ぐ物語を伴って頭の中に現れ、目前にありありと見える其等の一つ一つを順々に描写し続けることによって、彼の物語は誠に楽しく出来上るのだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙芝居式の謎々小説よ。",
              "citation": {
                "source": "探偵小説漫想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＴＯＷＮＳ　ＧＥＡＲが支援するものは、音付きの電子紙芝居作りだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレが鼻たれ小僧だったころには強力なメディアだった本物の紙芝居の機能に加え、電子化したＴＯＷＮＳ版にはいろいろなボタンを画面上に仕込んで任意のページに飛んだり、仕掛けておいた音を出したりといった機能が付け加えられている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つを並べてデータ処理にＴＯＷＮＳ　ＧＥＡＲを使う気にはなれないが、電子紙芝居作りなら面白い。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして十一月七日、息せき切って駆け込んだ新製品発表会は、この電子紙芝居によるＦＭ　ＴＯＷＮＳの表現力を表に立ててスタートを切ったばかりだった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
