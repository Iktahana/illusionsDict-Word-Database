    },
    "definitions": [
      {
        "index": 1,
        "gloss": "inconspicuous",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「会議の記録を読み返したら、A君も出席してたんだね。影の薄い人だから忘れてたよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "グループの中で一番影の薄い存在だった彼が、まさか一番早く出世するとは。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は目立つことを嫌い、あえて影の薄い脇役に徹することで自由を確保していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一つの乳牛に消化不良なのがあって、今井獣医の来たのは井戸ばたに夕日の影の薄いころであった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "切り離すと、もうそれは自分の活きた経験でなくなって、まるで影の薄い抽象的な「誰でも」の知識になってしまう。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄気味の悪い「ひげ」が黄鼠のような目を輝らせて杉の杜の陰からにらんだところを今少し詳しく言えば、　豊吉は善人である、また才もある、しかし根がない、いや根も随分あるが、どこかに影の薄いような気味があって、そのすることが物の急所にあたらない。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "手術後目立っておとなしく上品にはなったが、なんとなく影の薄い存在となったようである。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その意味からは橘屋の娘の恋愛関係も浅くおろかなものとも思えないようになって来て影の薄い女だけに、いじらしさも、また増して来る。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とどの顔も白茶けた、影の薄い、衣服前垂の汚目ばかり火影に目立って、煤びた羅漢の、トボンとした、寂しい、濁った形が溝端にばらばらと残る。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝三郎の妻は痩形でどこか影の薄い感じのする顔立ちだが、どちらかといえば陽気好きである。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に上古から文芸復興期にかけ、全盛の栄華を尽した叙事詩は、十八世紀末葉以来｜漸く人々に疎外され、最近に至って全く影の薄いものになってしまった。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蝶子さんを見ると、私の理想主義もピューリタニズムも影の薄い無理なものに思われて来る。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こうなると、高谷君の議論もよほど影の薄いものになって来た。",
              "citation": {
                "source": "麻畑の一夜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "影の薄い大學生よりも、溌剌たる高等小學生の方が遙かに立派だと、私も思ふ。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの乳牛に消化不良なのがあつて、今井獸醫の來たのは、井戸端に夕日の影の薄い頃であつた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月末の暗い夜で、雨気を含んだ低い大空には影の薄い星が三つ四つ、あるか無きかのように光っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえ、なんらの事件のない時でさえ彼は、考え込んでばかりいて、影の薄い印象を人に与えていた。",
              "citation": {
                "source": "死屍を食う男",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はあわれむべく影の薄い一人の男性に過ぎなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのたくさんの女の中の影の薄い一人の女として彼は自分を扱っているのではないか。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん」　影の薄い奴だが、妙に声が太い。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし大抵そういう場合の舞台のすがたは何となく生気に乏しい、影の薄いものであるが、かの新蔵ばかりはいつ見ても舞台の意気凜然たるものがあった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとても影の薄いのが著るしく眼に立って、わたしはその悼ましい姿をみるに堪えなかった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「感心をしない」ということは、昔は「感心をする」という積極的な心理作用の反対の状態を示すための、極めて消極的な影の薄い言葉にすぎなかつたはずであるが、現在では「感心をしない」ということ自身が独立した一つの能動的心理作用にまで昇格してしまつた観がある。",
              "citation": {
                "source": "雑文的雑文",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後三時頃の懶い眠に襲われて、日影の薄い部屋に、うつらうつらしていた頭脳が急にせいせいして来て、お島は手摺ぎわへ出て、美しい雨脚を眺めていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に晩年に押詰められた私達のこの年齢では、故郷は相当懐しいものであつていゝ筈だが、私の現在の生活環境が余りに複雑なためか、或ひは私の過去の生活が影の薄いものであつたためか、他の田舎の町を素通りするのと、気持は大差はなかつた。",
              "citation": {
                "source": "町の踊り場",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "たツた僅かのあひだ見ないうちに、身體までが實際あんなに影の薄い怨靈になつてしまつたのかと思はれた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて私の推称が其影の薄いものになる事は、龍村さんの為にも、私自身の為にも遺憾千万な次第であるが、同時に又それだからこそ、私は御同業の芸術家諸君を妄に貶しめる無礼もなく、安んじて龍村さんの女帯を天下に推称する事が出来るのである。",
              "citation": {
                "source": "龍村平蔵氏の芸術",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "名は小夜と申しまして、私の口から申し上げますのも、異なものでございますが、至って素直な、はにかみ易い――その代りまた無口過ぎて、どこか影の薄いような、寂しい生れつきでございました。",
              "citation": {
                "source": "疑惑",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れきって明るくはあるが、どこか影の薄いような秋の日に甲羅を干しながら、ぼんやり河岸縁に蹲んでいる労働者もある。",
              "citation": {
                "source": "世間師",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙風船は影の薄い東洋人にばかり似合ふのかと思ふと、このロシヤのお婆さんにもひどくしつくりと似合ひました。",
              "citation": {
                "source": "シベリヤの三等列車",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」それは昭和四年の事であつたが、その後の事実は作者の予想した通りで、作者の表現法は年と共に進んで極る所がなく、「心の遠景」なども忘却の靄の中に埋没してしまふ許り影の薄い存在となつたのである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
