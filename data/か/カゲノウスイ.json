[
  {
    "uuid": "4f843033-e99c-5fae-a721-aa0b44e194ac",
    "entry": "影の薄い",
    "reading": {
      "primary": "かげのうすい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
