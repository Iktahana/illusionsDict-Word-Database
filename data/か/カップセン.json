        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "チームは次のカップ戦に向けて、いつも以上に練習に励んでいる。優勝を目指す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昨日のカップ戦、まさかの番狂わせだったね。下位チームが強豪を破ったよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "サッカーのカップ戦は、一発勝負だからこそ予測不可能な展開が面白い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "優勝候補が次々と敗退し、今年のカップ戦は波乱の展開で観客を沸かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "テニスのデヴィス・カップ戦がすんだあと、Ｓ選手と女流ピアニストのＴがベルリンから遊びに来ていたところへ石黒がやってきたら、ＳとＴが顔色を変えて石黒をやっつけはじめた。",
              "citation": {
                "source": "予言",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今度ですでに四度目のデビスカップ戦に行く処だった、現に昨年の秋デビスカップ戦を済まして帰って来たばかりだ。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
