[
  {
    "uuid": "d550dbf6-0bf3-5b91-a86b-88dbee6ae7c0",
    "entry": "かき集める",
    "reading": {
      "primary": "かきあつめる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to gather up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "床に散らばったおもちゃを、子供たちが一生懸命かき集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "落ち葉をほうきで一箇所にかき集めて、ゴミ袋に入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あ！落としちゃった！」そう言って、彼は地面に落ちたコインを急いでかき集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ただ一つの広告が国中からこんなにも大勢かき集めるとは、想像もつかんことですよ。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、この岩のあいだのえりぬきの場所は、上等な種類の魚がとれるばかりではなく、数もずっとたくさんなので、私どもはよく、同じ商売の臆病な連中が一週間かかってもかき集めることのできないくらいの魚を、たった一日でとったものでした。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "伴左衞　英雄豪傑とは、こゝろにもない議論を吐いて、世間の人を瞞着して、軍用金をかき集めるのだなどと平氣で云ふのだ。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、貴方に自分の活気を皆吸われ、死ぬまでにと思って、かき集める人に侍って居なければならないの？",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "道路にのこしすてられた草鞋、馬の藁沓、それから馬糞の類なぞをかき集めるものがある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "と弁じてあるが、それにしても貧乏な炭焼が神仙に近づいて、黄石公もどきに一巻の書を授かったとあってみれは、箕でかき集める程の光る石が、浮世を外に床しく暮らす炭焼渡世の藤太や小五郎に、授けられたとあっても不思議はない。",
              "citation": {
                "source": "炭焼長者譚",
                "author": "系図の仮托と民族の改良",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は中腰になつて、卓上の書類をかき集めると、そのままヴェランダへ降りて行つた。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛川へなぞいらしってはいけませんよ」　おせい様とお高は、たがいにかき集めるように抱き合って、長いこと泣いた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればといって、この悪魔の弟子どもを戸外に放つならば、とたんに四方八方へかけ出し、これをかき集める苦労というものは、ほとんど筆紙に尽せぬほど。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "八人の小悪魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷中の菊がその辺に居るだろうし、手に及ばなかったら、お山同心にお願いして中間でも人足でも出来るだけかき集めるのだ」「親分は？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "お品さんと言ふものが無きや、もう半歳辛棒して、期限になつた貸金をかき集めると、三四千兩は手に入れられたんだ」「――」「が、お品さんに見られたら、跛者やしわん棒や、臆病者の眞似をして居るのは、辛かつたぜ」　宗次は自分の英雄的な姿を誇るやうに、漕ぐ手を休めては時々お品の前に立ち上がるのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "双生兒の呪",
                "note": "青空文庫"
              }
            },
            {
              "text": "かき集めると、小判でちょうど三十枚あるではありませんか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "八人芸の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "お品さんというものがなきゃ、もう半歳辛棒して、期限になった貸金をかき集めると、三四千両は手に入れられたんだ」「…………」「が、お品さんに見られたら、跛者やしわん棒や、臆病者の真似をしているのは、辛かったぜ」　宗次は自分の英雄的な姿を誇るように、漕ぐ手を休めては時々お品の前に立ち上がるのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "双生児の呪",
                "note": "青空文庫"
              }
            },
            {
              "text": "修正を読んで何より直接に感じる文学的印象は、ジードが自説に少しでも有利そうな材料を、あれこれとかき集めるのに汲々としていると云ったような弱々しさである。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "学芸自由同盟の復活などが、何となく散票をかき集めるような気持がして、同盟という団体そのものの肉体的リアリティーがあまりピンと来なかったのは、ここにその原因があったと云ってよく、その復活が遂に実現出来なかったのも之によるのではないかと考えられる。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗説をあれこれかき集めるのでもないわ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "上にのっている熊手は、農業に使用するのではなく、海藻をかき集める粗雑な道具である。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人夫婦に逢つて、いろ／＼訊いた上、昨夜外へ出なかつたかどうか、近所の噂もかき集めるんだ――宜いか」「そんな事ならわけはありませんよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "五つの壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "」やがて彼は、決心した調子でそういって、自分の持ちものをかき集めるやいなや、急いで谷にそって家畜を追って行った。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏の糞をかき集めると、畑の肥料になるのである。",
              "citation": {
                "source": "南方郵信",
                "author": "中村地平",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやそれどころか、人は誰でもそういう例を、いくらでもかき集めることができるくらいなのであるから、わたしは時々分別ある人たちまでが、この種の断片を取り合せて、それらを一つに継合せようと無理をしておられるのを見ると、何だかおかしな気がする。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "証拠や理由などは自らこれを十分に出すことができる」と）、（a）わたしはどっちの側に与するにしても、いつも、わたしにそれを支持させるにたるだけの理由とまことらしさとを、十分にかき集める。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても知りたがったのはなぜ借金を譲渡したかだが、もちろん言ったさ、あんたが大規模な投機にはまっているから、かき集めるだけの資金が欲しかったんだと。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっしもかき集めるだけの有り金を突っ込みやす。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は有り金をかき集める限りつぎ込んで、値上がりに賭けた。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主は、奥へ引つこんで、暫く出て来なかつたが、軈て下駄を引きずるやうにして、笑ひながら、「かきあつめるやうにして、全財産ですよ」と、卓子に十枚づつの百円札を十字に重ねて行つた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより完全なものではないが、浜辺に四角の大きな水ぶねをおいて、それに潮水をくみいれ、太陽の熱でもってその水気を蒸発させ、その底にのこった塩をかきあつめるようにしたのである。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん父の男爵もモウケルことで子供に劣るような人物ではないから、せッせと物色して目ぼしい物をかきあつめる。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の袋は内容が乏しく、自分のも加えて三人の仲間がかきあつめることのできた額は、ただの二百ドルだつた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
