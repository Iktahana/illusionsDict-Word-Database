        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はその鋭い眼光を活かして、時代劇で憎たらしい悪徳商人の敵役を熱演した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今回の敵役、あまりにも冷酷でゾクゾクしたよ！」と観客が興奮気味に語り合っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "物語の主人公を引き立て、深みを与えるには、魅力的な敵役の存在が絶対に欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "四郎の人気はだんだん落ちて、この頃では、白粉や紅を塗って田舎芝居で散々｜愚弄される敵役に使われているという風評になった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主役をつとめるノバリーク兄弟とその敵役ショーンブルクの相貌もこの一種特別な感じを強めるもののように思われた。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四郎の人気はだんだん落ちて、この頃では、白粉や紅を塗って田舎芝居で散々愚弄される敵役に使われているという風評になった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵役と老役を以て知らる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "初代左団次の弟にて、敵役と道化役の達者なり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あすこの店はおまへの敵役の子供がゐる家ぢやない」　すると、まきは照れ臭さうに眼を伏せて「はあ、でも、量りがようございますから」　と、せい／″＼頭を使つて言つた。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、敵役の中でも石川五右衛門は甚だ嫌ひですな。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやな敵役には蜜柑の皮が抛られる。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝説には三井寺はもっと敵役になっているが、さまではと和げて置いた。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Gottsched は敵役であつた。",
              "citation": {
                "source": "長谷川辰之助",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水右衛門の方には助太刀の敵役があらわれて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカの作家などにさえ最近まで、ドイツ人をわざとらしく敵役に回したものが随分あったように思う。",
              "citation": {
                "source": "私の要求する探偵小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居でするように、こゝで敵役の悪侍なんぞが邪魔に這入らないんですから、お話が些と面白くもないようですが、どうも仕方がありません。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "花見の場で酔っ払っているような奴は、大抵お腰元なんぞに嫌われる敵役で、白塗りの色男はみんな素面ですよ。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "座頭役、敵役の評判では見物は来ないものだといふのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四郎型が二枚目にしたてられて主人公となる世界においては源太型は常に赤面にしたてられて敵役となるのがきまりだ。",
              "citation": {
                "source": "余裕のことなど",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吉にも、労働者らしい鳥打の方がよくて、ビールの口金を勲章にしたのや空罐をかぶったのは敵役だということだけは分る。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その姿は見れば見るほど、敵役の寸法に嵌っていた。",
              "citation": {
                "source": "魚河岸",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "手塚は毎日そこへ出張して芝居の稽古をした、かれは監督であり座長であった、ろばは敵役や老役を引きうけた、新ちゃんは母親やお婆さんになった、若くてきれいで人気のある役は手塚が取ったが、ここに一番困ったのは若い娘に扮する女の子がないことである、手塚はそれを文子にあてた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして別席へ退いて、私どもへいうには、今日かように烈しく言ったのは、わざと敵役に廻ったのであるから、藩の方々は、これに反して、温和に説諭さるるがよい、その方が利き目があろうと注意した。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍賀の役は、軽いうちに、どこか篤実な所が見えねばならぬ役筋だが、今一息で、調子が敵役じみ、惣体にやりつぱなしと言ふ風が見えたり。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其芸風が女形にも伝つて、元禄期の立女形の立役敵役をも凌ぐ程の勇力や、意気の強さを形づくつたのである。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しかう言ふ真女形畠の役ばかりでなく、立役の領分として、敵役にも、和事にも著しく手を拡げて来てゐる。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が、役者の身分を立役・敵役・女形・道化などゝきめて来てゐるが、役者自身、其きめを何処まで、心に持つて居たかゞ問題である。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "原作と違ふ点は、今度出る――久しく上場せられなくて、今度出ることになつた時鳥殺しの場の敵役である。",
              "citation": {
                "source": "草双紙と講釈の世界",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "須磨子ののらに対するくろぐすたつとは、島村抱月の解釈の為か、いつも敵役の性根で演出せられて居た様に思ふ。",
              "citation": {
                "source": "雑感",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体……くろぐすたつとの出現その事が、如何にも敵役々々してゐる。",
              "citation": {
                "source": "雑感",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ片市の敵役を見ましたが、この人は眼があまりに善良なため、その人らしくなりませんでした。",
              "citation": {
                "source": "実悪役者を望む",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から、どう言ふものか敵役の名人と云はれた人は善良な人物だつたやうです。",
              "citation": {
                "source": "実悪役者を望む",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "東儀鉄笛等のは、単純な敵役に過ぎなかつた。",
              "citation": {
                "source": "辻の立ち咄",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
