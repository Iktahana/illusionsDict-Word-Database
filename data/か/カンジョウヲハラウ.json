    "definitions": [
      {
        "index": 1,
        "gloss": "to settle one's account",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はいつも、みんなのために率先して勘定を払ってくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "今回の出張費は、会社が全額勘定を払ってくれることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「今日のランチ代、私に勘定を払わせて！」と彼女は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「おあいそ」　君勇は勘定を払うと、すくっと起ち上って、「――お先イに。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ」「じゃ、あたし今暇だから、御案内しましょう」「でも……」　躊躇したが、宮子はさっさと起ち上って、勘定を払うと、「じゃ、参りましょうか」　鶴雄をうながして、べにやを出た。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、例のスリが急に立ち上って、勘定を払うと、セントルイスを出て行こうとした。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、勘定を払うのさえ忘れて逃げ出した。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘定を払う前にあんまり味をほめすぎるのは考え物だ。",
              "citation": {
                "source": "決戦川中島　上杉謙信の巻",
                "author": "――越後守安吾将軍の奮戦記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘定を払う段に、カバンが失くなっているのに気がついた。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "この先生にしたって、本当に勘定を払う気持があるなら、このまま家へ帰って、明朝返しにくるがいい。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔っ払うと者ども続けと居合す男女をひきつれて威勢よく飲みまわり、威勢よく勘定を払う。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白い博奕を打ってやろう」　勘定を払うと伊集院五郎、フラリと酒場から外へ出た。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして月末の勘定を払う時初めて費用の案外多くかかったのに驚くという有様である。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘定を払う客か、値切る客か、只呑みの客か、下足を見ただけで見当は付くだろう」　平次は妙なことを聞きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "橋の上の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "その勘定を払う手付き、札入れの厚さなどを、五郎はじっと見ていた。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "とすれば、なんのために巡査を呼ぶか、恥をかいたうえに勘定を払うためにか。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこですっかり気分をもち直し、やがて勘定を払うと、踉々蹌々、元の道をもどって行った。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
