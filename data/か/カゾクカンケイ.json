        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "思春期の子供との家族関係は、時には難しく感じることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "良好な家族関係は、子供の成長に良い影響を与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "引っ越しを機に、疎遠になっていた親戚との家族関係が改善された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "心理カウンセリングでは、家族関係の問題に焦点を当てて話し合いが行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その上、家族関係の方にも、義兄の自殺、頼みにしていた夫人の令弟の発病など、いろいろ不幸がつづいていた。",
              "citation": {
                "source": "芥川の事ども",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブランクというのは「収穫以前」で作者森山氏は主題の更に重厚な展開のために、主人公のような社会層のインテリゲンツィアと家族関係との奥に潜められている心理的因子を主人公の側からとらえ、掘り下げる必要があったことを心付かずにいた。",
              "citation": {
                "source": "数言の補足",
                "author": "――七日附本欄伊藤整氏への答として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「収獲以前」は、一般の読者に作者と殆んど同一人と想像させる左翼的な主人公をめぐる家族関係を描いた小説である。",
              "citation": {
                "source": "全体主義への吟味",
                "author": "――今日の民衆、知識人への課題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族関係というふうのものも近代の意味では確立していなかったから、互いにとって親族的な縦横の関係は無視されていた。",
              "citation": {
                "source": "人間の結婚",
                "author": "――結婚のモラル――",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来本会の構成メンバーは主として学校教師、官吏、会社員等のインテリ、小市民層に属するものであり、警察官の単なる事務的な行動に対してさえそれがただ警察の手によって行われたというだけの理由によって、何等かの疑念と危惧とを抱くところの極めて温良なる職場関係、家族関係乃至親戚関係等に囲まれている。",
              "citation": {
                "source": "〔付〕唯物論研究に就て（戸坂潤手記）",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九の少女は、自分の日々がその中で営まれている環境の内部にある複雑な家族関係とその感情、弟の短い生涯を悲劇的にした家族制度の因習ということには、とりくむ実力をもっていなかったことが、この短篇に語られているのである。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第一巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族制度の重しの下で、藤村の文学にあらわれているように、「家」の探求やせまい家族関係の中での「自分」の主張におわらせた。",
              "citation": {
                "source": "自我の足かせ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また家族関係もキリストの本意でないことは明らかに聖書でわかります。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛の生活と家族関係とは両立できないと思います。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の下町の強い伝統を持った家族関係の中で経済的な不如意を都会人らしい体裁で取りつくろいながら生きている人々の間で育ち、大学時代から現実生活の問題を常に念頭に置いていなければならなかった青年時代の芥川龍之介。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族関係の上に除きがたい障礙が生じたためである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に彼は課長の家庭生活と家族関係をさぐって、相手が年頃の娘を持っており、それがやはり、夜な夜な悪魔が豌豆を搗きにやってきそうな御面相の持主であることを嗅ぎ出した。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それであるからして、そういった史学上珍重すべき家系を、遺伝学の見地から見たとすれば、あるいは奇妙な形をした蕈のように見えもするだろうし、また、故人降矢木｜算哲博士の神秘的な性格から推して、現在の異様な家族関係を考えると、今度は不気味な廃寺のようにも思われてくるのだった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして小面倒な家族関係で揉まれていたら、今ごろはもう少し人間が悧巧になっていたかと思うけれど、何しろのっぽう一方で暮してきたんだから自分ながら始末にいけない。",
              "citation": {
                "source": "贋物",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもアミタールという麻酔剤で半酔状態にされ話した所によると父死亡、母健在、兄三人のうち二人戦死、嫁した姉妹があるなどの家族関係がぴったりあっているのです。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その三　精神病診断書",
                "note": "青空文庫"
              }
            },
            {
              "text": "横田さんの父親と保子さんの父親とは親しかったから、自然に両方の家族関係の人達も知り合いになったのだろう。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら或る程度までの二人の親しい振舞は家族関係といふ特殊な名目がそれを承認せしめ得るからであつた。",
              "citation": {
                "source": "煤煙の臭ひ",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かうした事実は二人が家族関係である以上勝手である。",
              "citation": {
                "source": "煤煙の臭ひ",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もこのうち宗教的信仰を懐いていると見做してよい所謂信徒を別にして、大部分の者は単にその家族関係から云って一定宗派の寺院の檀徒だというに止まっているから、宗派神道の可なりに熱心な信徒と、直接その数を比較することが出来ない（各派の宗派神道の信徒総数は約千六百九十万である）。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体我輩は家族関係や金銭上には比較的自由で、幼い頃父は失ったけれど、母はしっかりしていられたから、自由に行動することが出来たのである。",
              "citation": {
                "source": "青年の天下",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "周知の如く武鑑とは現代の紳士録の先駆的出版物であって、徳川一門から譜代外様の大名諸侯残らずその家の紋どころ、槍飾り馬標、領地江戸邸、各家の家族関係から重臣まで記載してある。",
              "citation": {
                "source": "長屋天一坊",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公の身近な家族関係、直接の先祖、懐胎について考察する。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも判然としているのは、子供が母の話をせず、父親が妻とか家族関係の話をしないことだ。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギャロッドは患者の家族関係を調べて１）アルカプトン尿排泄は生まれつきのものであり、２）兄弟姉妹にも患者がいるが、両親はほとんど全部が健康である、３）両親に「いとこ」結婚が多い、ことに注目して1901年に報告しランセットに記録がある。",
              "citation": {
                "source": "アルカプトン尿の発現",
                "author": "THE INCIDENCE OF ALKAPTONURIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことは必ず家族関係を複雑にし、年老いたる者を不幸にする種であったが、それすらも避けることが許されなかった。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
