        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「やった、合格した！」かと思えば、次の瞬間には「でも、これからどうしよう…」と不安になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「まさか、彼が犯人だったなんて！」かと思えば、なんだか納得してしまう自分がいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
