        "examples": {
          "standard": [
            {
              "text": "昨夜のパーティーは、DJの選曲がカオスで、誰もが予測不能なダンスを踊っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プロジェクトの締め切り前はいつも、デスクの上がカオス状態になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいルールが導入されてから、社内のコミュニケーションは一時的なカオスに陥った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "カオス理論かなんか導入しないと、計算できない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "通例無秩序の状態を名づけるのにギリシア語のカオス（Chaos）を用いるが、これは元来物質の至る所均等な分布を意味する。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "カオスからコスモスへの生成を説いた古代人の哲學には深い眞理が含まれてゐる。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "カオスからコスモスへの生成を説いた古代人の哲学には深い真理が含まれている。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、各々の部門と部門の連絡の不充分な裂目の中にすべりこんでしまい、一つのカオスと成っていったからである。",
              "citation": {
                "source": "組織としての図書館へ",
                "author": "――マックリーシュの業績――",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙はコスモス（秩序）であって、カオス（渾沌）ではない。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして豊島さん自身は俗人よりもよりコントンたるカオスの中で救いようのない自己の妄執を見つめていらッしゃるのかも知れないのである。",
              "citation": {
                "source": "豊島さんのこと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "生や死や愛や信仰について語った哲学はいくらでもあるが、道端に落ちている十円玉について、インスタントラーメンの空き袋について、ゴミ箱の中のカオスについて語った哲学はない。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろと変化があり事件が多くカオス的とさえ言えるフランクの一生のうちにおいてこの本の執筆は一貫した方針であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "結果は光、音、興奮の刺激的なカオスである。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ライプニッツは1714年に自然発生は不可能であるという信念および植物も動物も腐敗のカオスから生ずる筈はないことを表明した。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
