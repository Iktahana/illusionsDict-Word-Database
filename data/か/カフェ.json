    "definitions": [
      {
        "index": 1,
        "gloss": "café",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ねえ、駅前にできた新しいカフェ、もう行ってみた？ フレンチトーストが絶品らしいよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "仕事が煮詰まったときは、お気に入りのカフェの窓際席に座って思考を整理することにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「すみません、この近くにコンセントが使えるカフェってありますか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわ、このカフェのラテアート、クマの形をしててめちゃくちゃ可愛い！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "此処は銀座の裏通りのカフェー、卓子の上で扇風器は、哀しげな唸りをつづけてゐる。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "カフェーに這入つてゐた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭に退屈した若い良人が、ダンス場やカフェ這入りを定期的にして、而もそれに満足もしない。",
              "citation": {
                "source": "時代色",
                "author": "――歪んだポーズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "観音様が流行らないなら、モガの一人も張り飛ばして、食堂でアイスカフェーの食券一枚。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カフェーでもいれますか？",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "カフェーを沸かしながら彼女は卓上電話をとると、麹町にある彼女の経営している店に電流を通じて、その日のスケジュールをつくるために店員たちと約束客の時間の繰合わせについて打合せを始めた。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "山ノ手の町のとあるカフェで二人の青年が話をしていた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座などとちがって、狭い山ノ手のカフェでは、孤独な客が他所のテーブルを眺めたりしながら時を費すことはそう自由ではない。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれはそのカフェがその近所に多く住んでいる下等な西洋人のよく出入りするという噂を、少し陰気に裏書きしていた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを眺めながら、彼は今夜カフェで話し合った青年のことを思い出していた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのたびに彼はそれがカフェで話し合った青年によもやちがいがないだろうと思い、自分の心に企らんでいる空想に、そのたび戦慄を感じた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カフェで会った男の言っていたような窓は相不変見えなかった。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在でも月刊雑誌の編集部では随筆の類は「中間物」と称する部類に編入され、カフェーの内幕話や、心中実話の類と肩をならべ、そうしていわゆる「創作」と称する小説戯曲とは全然別の繩張り中に収容されているようである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗末なカフェーへはいって休んでいると、奥のほうの卓を囲んで四五人の男女がマンドリンをひいて歌っています。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもつぶしきれない時間をカフェーやコンディトライの大理石のテーブルの前に過ごし、新聞でも見ながら「ミット」や「オーネ」のコーヒーをちびちびなめながら淡い郷愁を瞞着するのが常習になってしまった。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時か四時ごろのカフェーにはまだ吸血鬼の粉黛の香もなく森閑としてどうかするとねずみが出るくらいであった。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔のペテルブルグ一流のカフェーの菓子はなかなかにぜいたくでうまいものであった。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マデレーヌの近くの一流のカフェーで飲んだコーヒーのしずくが凝結して茶わんと皿とを吸い着けてしまって、いっしょに持ち上げられたのに驚いた記憶もある。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は、私とその夜はじめてカフェで落ち合ったばかりの、犬の毛皮の胴着をつけた若い百姓であった。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がカフェにはいっても、決して意気込んだ様子を見せなかった。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこのカフェにも、色気に乏しい慾気ばかりの中年の女給がひとりばかりいるものであるが、私はそのような女給にだけ言葉をかけてやった。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩をすぼめ、大股をつかってカフェを出てしまって、学校の寮につくまで私はいちども振りかえらぬのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "決闘の夜、私は「ひまわり」というカフェにはいった。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はひとつカフェにつづけて二度は行かなかった。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がそのカフェの隅の倚子に坐ると、そこの女給四人すべてが、様様の着物を着て私のテエブルのまえに立ち並んだ。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこのカフェでは、とうてい落ちつけないことを知っていた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この仮説を敷衍すれば、熱い酒に冷たい豆腐のひややっこ、アイスクリームの直後のホットカフェーの賞美されるのもやはり一種の涼味の享楽だという事になる。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう爆音を街頭に放散しているものの随一はカフェやバーの正面の装飾美術であろう。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イギリスの家庭の美風は、｜お茶時で維持されている」「フランス人の機智は、珈琲店（日本のカフェーとは違います）で培養される」。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オペラに向って左角がカフェ・ド・ユ・ラ・ペイユだ。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
