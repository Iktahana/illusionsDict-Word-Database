        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの先生の講義は火木土の2限に入ってるから、週3で大学に通うことになるね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ゴミの収集日、うちは火木土が燃えるゴミの回収日なんだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "火木土だけ夜勤に入るシフトに変えてもらえませんか？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "週に3日、火木土のペースでジムに通い始めてから体調が目に見えて良くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "火木土は、午後七時から八時頃までにいらしつてください。",
              "citation": {
                "source": "髪の毛と花びら",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "新来の訴願者は火木土といふことになつてゐたので、いづれにしてもこの日は受附けてもらへない日だつた。",
              "citation": {
                "source": "老残",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのう『朝日』に公判の日どり七月十一日より火木土と書かれて居りましたが、それらのことはいずれ三十日におめにかかって。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月中は日曜月曜とつづいた休日があるだけで、火木土、火木土と八時―四時頃まで出ます［自注19］。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちらへは、火木土のうち、火の出がけによってそれからあっちへゆくようにしようと考えますが、どうでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "［自注19］七月中は日曜月曜とつづいた休日があるだけで、火木土、火木土と八時―四時頃まで出ます――公判の日どりと、時間わり。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこの火木土がとべば、私はその間に図書館通いいたします。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間うちはやむを得なかったの、火木土だもので。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は火木土ですから大変いいわ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことにまとまりのつかない、しかもくどくどしいお話を申上げました。",
              "citation": {
                "source": "自力更生より自然力更生へ",
                "author": "三澤勝衛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
