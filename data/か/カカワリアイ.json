        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今後あの悪質な業者とは、一切の関わり合いを持たないよう社内に通達を出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "長年にわたる取引先との深い関わり合いの中で、今回の共同プロジェクトが自然と立ち上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "警察は、現場から逃走した人物と被害者の過去の関わり合いについて慎重に捜査を進めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "仕事で関わり合いになる前だが、このようにわずかな時間で物が得られるのかと驚いた覚えがある。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホームズくんとは、ちょっとした事件で関わり合いになったきりだ、け、ど、その才能と人物は尊敬してたんだよォ。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼とはちょっとした関わり合いがあるが、君の意見に賛成だ。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと、気分を害することが起こると思うが、関わり合いにならんことだ。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがその行為が人間生活の中にかかわりあい、様々の生きた意味をもってくる経路は、誰の目にもいつもはっきり見えているとは言えない。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "リアリズムと云えば自然主義の系列の些末主義の範囲で規定して、そこからの脱出をロマンティシズムに見るような、今日の時代の性格へのかかわりあいかたにこそ、今日の文学の弱い部分があらわれているのだと思う。",
              "citation": {
                "source": "作家と時代意識",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは櫛まきお藤が源十郎へのはらいせにつれ出したのだが、源十郎はそうとは知らずにその尻をそっくりおさよ婆さんへ持ってきて、今までお艶を幽閉しておいた納戸へこんどはおさよを押しこめ、第一におさよお艶のかかわりあいから聞き出そうと毎日のように折檻した。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大槻、戸塚はもとより、竹内、林、また三宅も某殿のふぐり玉にかかわりあい、それぞれの見識にしたがって勉強しているわけであったが、皆がてんでにおなじような実検をしていても効ないことだから、各々の分担をきめ、それぞれの受持で知識を深めるほうがよいと言う意見が出て、あらためて持役をきめた。",
              "citation": {
                "source": "玉取物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「待て原田、待て」と兵部は疑わしそうに甲斐の眼をにらんだ、「毒死の事実が、どうして東市正にとって危険なのだ、これと東市正とどういうかかわりあいがある」「申上げなければなりますまい」と甲斐が云った。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "波子と世帯を持って、可愛い子までできた今は、照子との妙なかかわりあいは避けたかったというような常識的な理由ではない。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神的なコミュニティへのかかわりあいは、自己発見をひとりひとりがつづけていくことにより、さらに強固にされていく。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカを全面的に否定していて、アメリカ政府とのかかわりあいなどまったく持とうとしなかったビートとおなじく不思議な非政治性あるいはアナーキズムに片方では支えられ、他方ではフィーリングとしての愛と薬品による恍惚境によって支えられていたため、ヒッピー・ムーヴメントは、ほとんどなにもなしとげなかった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
