    "definitions": [
      {
        "index": 1,
        "gloss": "ornamental hairpin",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は着物に合わせて、繊細な細工が施された鼈甲のかんざしを選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "舞妓さんが挿している美しいかんざしに、外国人観光客は皆、目を奪われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "母親が成人式の娘に、代々受け継がれてきた銀製のかんざしを贈った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "馬場の足もとに、真赤な麻の葉模様の帯をしめ白い花の簪をつけた菊ちゃんが、お給仕の塗盆を持って丸く蹲って馬場の顔をふり仰いだまま、みじろぎもせずじっとしていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が頭から銀の簪をぬいて燈心を掻き立てている姿の幻のようなものを想い出すと同時にあの燈油の濃厚な匂いを聯想するのが常である。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はい、これは、お照さんの簪。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その不思議な宿の大きい葛籠でも脊負つて來て下さつたら、それを證據に、私だつて本當にしないものでもないが、そんな稻の穗などを持つて來て、そのお人形さんの簪だなんて、よくもまあそのやうな、ばからしい出鱈目が言へたもんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うるさいのね、さあ、これでいいの」彼女は柚木が本気に自分を見入っているのに満足しながら、薬玉の簪の垂れをピラピラさせて云った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座で半襟、簪、其他娘が喜びさうな品を買ひ整へて汽車に乘つた。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪は房りとするのを束ねてな、櫛をはさんで簪で留めている、その姿の佳さというてはなかった。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と仔細は語らずただ思い入ってそう言うたが、実は以前から様子でも知れる、金釵玉簪をかざし、蝶衣を纏うて、珠履を穿たば、正に驪山に入って、相抱くべき豊肥妖艶の人が、その男に対する取廻しの優しさ、隔なさ、深切さに、人事ながら嬉しくて、思わず涙が流れたのじゃ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "忰というのも、煙管、簪、同じ事を業とする。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわれ、祖母に導かれて、振袖が、詰袖が、褄を取ったの、裳を引いたの、鼈甲の櫛の照々する、銀の簪の揺々するのが、真白な脛も露わに、友染の花の幻めいて、雨具もなしに、びしゃびしゃと、跣足で田舎の、山近な町の暗夜を辿る風情が、雨戸の破目を朦朧として透いて見えた。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八田巡査はこれを見て、躊躇するもの一｜秒時、手なる角燈を差し置きつ、と見れば一枝の花簪の、徽章のごとくわが胸に懸かれるが、ゆらぐばかりに動悸烈しき、お香の胸とおのが胸とは、ひたと合いてぞ放れがたき。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてなる女の髪黒く面白きが、此の花を簪にしたる、いと美はし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の簪には、此の花などこそをかしかるべけれ。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉は一葉をいたく小さくしたるが如く、一つの茎に花の六つ七つ五つ咲くさまは玉簪花の如し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "封筒の片隅を指先で小さくむしっておいて、結いたての日本髪（ごくありきたりの髷だったが、何という名だか園は知らなかった）の根にさした銀の平打の簪を抜いて、その脚でするすると一方を切り開いた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その拍子に一挺の金｜簪のような鋭い火線が、爆竹色に霧散して月の面を掠める煙の中に鋭くひらめいた。",
              "citation": {
                "source": "窓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかみさんは、わしが差上げた簪を頭に挿したり、抜いて眺めたりされた。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "永いこともないおかみさんは簪はもう要らんでしょうし。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中で徳永の命をこめて彫ったという沢山の金銀｜簪の音がする。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "簪の突込み加減も、じれッたいを知った風。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、その夜は、ちょうど植木｜店の執持薬師様と袖を連ねた、ここの縁結びの地蔵様、実は延命地蔵尊の縁日で、西河岸で見初て植木店で出来る、と云って、宵は花簪、蝶々｜髷、やがて、島田、銀杏返、怪しからぬ円髷まじり、次第に髱の出た、襟脚の可いのが揃って、派手に美しく賑うのである。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と抜出ていた簪を、反らした掌で、スッと留めて、「そうね……姉さんの御志で、お雛様の栄螺と蛤を、一石橋から流すと云うのに一人ぽっち。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にね、――潰島田に水色の手柄を掛けた――年数が経って、簪も抜けたり、その鬢の毛も凄いような、白い顔に解れたが――一重桜の枝を持って、袖で抱くようにした京人形、私たち妹も、物心覚えてから、姉に肖ている、姉さんだ姉さんだと云い云いしたのが、寂しくその蜜柑箱に立っていた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　ほつれた圓髷に、黄金の平打の簪を、照々と左插。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "靜かに進んで禮をする時、牡丹に八ツ橋を架けたやうに、花の中をが前後に三｜人屬いて、淺緑の衣に同じ裳をした……面は、雪の香が沈む……銀の櫛照々と、兩方の鬢に十二｜枚の黄金の簪、玉の瓔珞はら／＼と、お孃さん。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "髻結いたる下髪の丈に余れるに、色｜紅にして、たとえば翡翠の羽にてはけるが如き一条の征矢を、さし込みにて前簪にかざしたるが、瓔珞を取って掛けし襷を、片はずしにはずしながら、衝と廻廊の縁に出づ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（簪の箭を取って授けつつ）楊弓を射るように――釘を打って呪詛うのは、一念の届くのに、三月、五月、三｜年、五年、日と月と暦を待たねばなりません。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの光りにも恥かしい、……私の紅い簪なんぞ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "媛神、半ば簪して、その鏡を視る。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金は勿論であるが、櫛でもかんざしでも、煙草入れでも、眼に触れるものは何でも逃がさなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
