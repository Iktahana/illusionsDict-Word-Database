        "examples": {
          "standard": [
            {
              "text": "その神社は、かつて官幣社として厚い庇護を受けていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史ある官幣社を訪れ、厳かな雰囲気に包まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多くの官幣社が、国の重要な祭祀を担っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "明治時代以降、官幣社の制度は再編され、その役割も変化した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "波上宮へお參りをすると、これは明の詩人が筍崖と呼んだ港の外に突出した珊瑚礁の塊の上に立つてゐる沖繩縣内唯一の官幣社である。",
              "citation": {
                "source": "沖繩の旅",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            }
          ]
        }
