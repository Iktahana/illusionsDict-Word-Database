          "standard": [],
          "literary": [
            {
              "text": "乾電池がすぐなくなりますから、それよりか……」「また婚前交際ですか。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "右肩には防毒面の入ったズックの鞄を、また左肩には乾電池で働く携帯用のラジオ受信機を、しっかり身体につけて出た。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "同夜苦心ノ末、コイル、コンデンサー、乾電池等ヲセット中ヨリ取外シ、短波長送信機ヲ組立テント試ミタリ。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "神戸市立板宿小学校時代の最良の思い出は、六年生のとき、教師に代わって、理科の授業で乾電池の使い方を講義したことだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾電池に興味を持った西は、誰に指示されるでもなく百科事典や中学、高校の教科書でその使い方や働きについて調べ、あらかじめ教科書にびっしりと書き込みを入れていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には乾電池を使った、機巧の複雑なものもある。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "段々火花を小さくして行っても、火の点け方も巧くなるせいか、しまいには二ボルトの乾電池で針金の先を付けたり離したりして出来る、やっと目に見えるかどうかという程の小さい火花でも十分点火することが出来るようになった。",
              "citation": {
                "source": "球皮事件",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷面以下の調査と複写にかれこれ五時間は連続点灯させてきたので、いかに特殊な処方の乾電池とはいえ精々もっても後四時間程度なのが明白だった――尤も、特に興味深い場所あるいは難所以外は懐中電灯のうち一本を点灯させずにおくことでこの限界を越えて安全マージンをなんとか確保できるだろう。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "よるの部終って、向島の夕立荘へ、大辻と二人、矢井乾電池の若旦那てものに馳走になりに行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷幹一の斡センで屋井乾電池の屋井に呼ばれた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "目がリンのように光るのは、乾電池で青い豆電灯がついているんだ。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その電球は、ほそいコードで、ポケットに入れた乾電池につながっている。",
              "citation": {
                "source": "夜光人間",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井に乾電池をおいて、そこからコードが、豆電球につながっているのさ。",
              "citation": {
                "source": "夜光人間",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
