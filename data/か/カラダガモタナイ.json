        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「このまま現場の人手不足が続くなら、みんな体がもたないですよ。早急に新しい人を補充してください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「はぁ……。毎日3時間睡眠のまま一週間も続くと、さすがに気力だけじゃ体がもたないな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「悪いけど、この炎天下での作業は一度中断させてくれ。これ以上続けたら、俺の体がもたない」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「週末も休みなしでプロジェクトを進めるのはいいけど、ほどほどにね。来週の本番まで体がもたないよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "と言つてみたり、たまには石の上にも寝なきや一人者は身体がもたないだらうにね、などゝ言つたりする。",
              "citation": {
                "source": "母の上京",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "力稼業の身体がもたないよ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十六　家族は六人・目一ツ半",
                "note": "青空文庫"
              }
            },
            {
              "text": "澱粉だけでは身体がもたないから、蛋白やビタミンは他から補給する必要がある。",
              "citation": {
                "source": "稲の一日",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍ子、体がもたないので社を一週に二三度出ることにして、原稿だけ送るようにしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "書斎で頭脳労働をやっているものは、時々散歩でもしないと体がもたない。",
              "citation": {
                "source": "夢",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道とちがって東京はヤケに暑く、屍体がもたないんだそうだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜も泊まっていけといわれたが、ふた晩続きで三日目はからだがもたない。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
