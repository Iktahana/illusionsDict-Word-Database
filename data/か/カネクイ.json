        "examples": {
          "standard": [
            {
              "text": "最新のゲーム機は金食いだから、お小遣いを貯めないと買えないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの会社の新規事業は、今のところ金食い状態で利益が出ていないらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い輸入車は部品代も高く、本当に金食いだと実感している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の趣味は高級ワインの収集で、かなりの金食いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "勤めた農場は商売一本槍で、商いにしか目がなく、レスブリッジの試みには冷淡で、金食い虫だと決めつけた。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "金食い虫の道楽は無茶で気まぐれな性格のせいだ。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
